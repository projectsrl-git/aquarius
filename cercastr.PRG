
************************************************************************************************
* -->> PROGRAMMA PER LA RICERCA DI UNA STRINGA DENTRO AI FORM
*
* -->> IL PRG PRIMA ESTRAE TUTTI GLI SCHERMI CREANDO UN CURSORE
* -->> DALL'ELABORAZIONE DEL CURSORE ESTRARRA' GLI SCHERMI CON LA STRINGA
* -->> TROVATA E SCRIVERA' UNA TABELLA CHE VERRA' STAMPATA
* 
* -->> ATTENZIONE !!!!!!!!!
* -->> LANCIANDO LA PROCEDURA CON SOLO UN PARAMETRO SI HA UN ELENCO DELLE FORM IN CUI
* -->> SI TROVA LA STRINGA
*
* -->> SE SI INSERISCE IL SECONDO PARAMETRO, LA PROCEDURA SOSTITUISCE CON TALE PARAMETRO
* -->> LA STRINGA TROVATA (SECONDO PARAMETRO)
*
* -->> SINTASSI:
* -->>          CERCASTR WITH _STR,_STR2
* -->>          DOVE: _STR    	E'LA STRINGA DA CERCARE
* -->>                _STR2   	E'LA STRINGA CON CUI SOSTITUIRE QUELLA TROVATA
* -->>                _METODO 	E'IL CAMPO IN CUI CERCARE LA STRINGA
* -->>                _SEESISTE ACCETTO SE ESISTE NEL METODO
*
* -->> ESEMPIO:
* -->>          CERCASTR WITH "007","PUB_RAMRCA","PROPERTIES"

************************************************************************************************
PARA _TIPO,_STR2,_METODO,_SEESISTE

_AAA=PARAMETER()

IF _AAA < 2
  _STR2=""
  _METODO="METHODS"
  _SEESIDTE=""
ENDIF

IF _AAA < 3
  _METODO="METHODS"
  _SEESIDTE=""
ENDIF

IF _AAA < 4
  _SEESIDTE=""
ENDIF

IF EMPTY(_METODO)
  _METODO="METHODS"
ENDIF

SET PROCEDURE TO PRG\WINLIB 	ADDITIVE

SET DEFAULT TO FORM

               
PUBLIC _IND
_IND=0

*=======================================================
*
* INIZIO PARTE UGUALE A QUELLA DEL CERCASTP.PRG
*
*=======================================================

PIPPO=0

CREATE CURSOR SCHERMO(PROCEDURA C(100))

SET SAFE OFF

AA=0
BB=0
V_MODI=.F.

SET DEFAULT TO \AQUARIUS\FORM

NTXT = ADIR(MATXT,'*.SCX')

FOR TXT = 1 TO NTXT
  NOMEFILE = MATXT[TXT,1]
  SELECT SCHERMO
  APPEND BLANK
  REPLACE PROCEDURA WITH NOMEFILE
  AA=AA+1
  WAIT WINDOWS "SCHERMI ESTRATTI CONTROLLATI: "+STR(AA) NOWAIT
ENDFOR

RELEASE WINDOW DISPLAY

SELECT SCHERMO
GO TOP

*=======================================================
*
* FINE PARTE UGUALE A QUELLA DEL CERCASTP.PRG
*
*=======================================================

*CREATE CURSOR SCHERMO(PROCEDURA C(25))
CREATE CURSOR WSCR(NOME C(100),POSIZ C(70))

SET SAFE OFF

BB=0
CC=0

*-->> RICERCA DELLA STRINGA
**********************************************************

SELECT SCHERMO
GO TOP
DO WHILE !EOF()

  _PROC=PROCEDURA
  
  IF !( ".SCX" $ ALLTRIM(_PROC))
	_PROC=ALLTRIM(_PROC)+".SCX"
  ENDIF

  SELECT 99
  USE
  USE &_PROC
  SET FILTER TO PLATFORM="WINDOWS"
  GO TOP
  DO WHILE !EOF()
    
    _METO=UPPER(&_METODO)

    IF UPPER(_TIPO) $ _METO
      _POSIZ=ALLTRIM(PARENT)+'.'+ALLTRIM(OBJNAME)
      
      IF !EMPTY(_SEESISTE)
        IF !(UPPER(_SEESISTE) $ _METO)
	      BB=BB+1
	      WAIT WINDOW "SCHERMI ESTRATTI:    "+STR(AA)+CHR(13)+; 
    	              "PROCEDURE LETTE:     "+STR(BB)+CHR(13)+; 
        	          "STRINGHE SOSTITUITE: "+STR(CC) NOWAIT
          SKIP+1
          LOOP
        ENDIF
      ENDIF

      IF !EMPTY(_STR2)
        REPLACE &_METODO WITH STRTRAN(_METO,_TIPO,_STR2)
        CC=CC+1
      ENDIF
  
      SELECT WSCR
      APPEND BLANK
      REPLACE NOME  WITH  _PROC
      REPLACE POSIZ WITH  _POSIZ
    ENDIF

    BB=BB+1
    WAIT WINDOW "SCHERMI ESTRATTI:    "+STR(AA)+CHR(13)+; 
                "PROCEDURE LETTE:     "+STR(BB)+CHR(13)+; 
                "STRINGHE SOSTITUITE: "+STR(CC) NOWAIT

    SELECT 99
    SKIP+1
  ENDDO

  SELECT SCHERMO
  SKIP+1
ENDDO


SELECT WSCR
GO TOP
COPY TO WSCR.txt sdf
SELECT WSCR
GO TOP
BROWSE NORMAL

SET DEFAULT TO \AQUARIUS

DISPLAY ALL TO PRINTER PROMPT NOCONSOLE

WAIT WINDOW "OPERAZIONE TERMINATA"

CLOSE ALL
CLEAR ALL



