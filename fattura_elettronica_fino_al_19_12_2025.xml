<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<p:FatturaElettronica xmlns:ds="http://www.w3.org/2000/09/xmldsig#" xmlns:p="http://ivaservizi.agenziaentrate.gov.it/docs/xsd/fatture/v1.2" versione="#AZI_FORTRA#">
    <FatturaElettronicaHeader>
        <DatiTrasmissione>
            <IdTrasmittente>
                <IdPaese>#AZI_IDPAESEIN#</IdPaese>
                <IdCodice>#AZI_PIVAIN#</IdCodice>
            </IdTrasmittente>
            <ProgressivoInvio>99999</ProgressivoInvio>
            <FormatoTrasmissione>#AZI_FORTRA#</FormatoTrasmissione>
            <CodiceDestinatario>#ORD_IDSDI#</CodiceDestinatario>#ORD_EPEC#
        </DatiTrasmissione>
        <CedentePrestatore>
            <DatiAnagrafici>
                <IdFiscaleIVA>
                    <IdPaese>#AZI_IDPAESE#</IdPaese>
                    <IdCodice>#AZI_PIVA#</IdCodice>
                </IdFiscaleIVA>
                <CodiceFiscale>#AZI_CODFIS#</CodiceFiscale>
                <Anagrafica>
                    <Denominazione>#AZI_RAGSOC#</Denominazione>#CEDENTEPRESTATOREDATIANAGRAFICIANAGRAFICACODEORI#
                </Anagrafica>
                #CEDENTEPRESTATOREDATIANAGRAFICIALBOPROFESSIONALE##CEDENTEPRESTATOREDATIANAGRAFICIPROVINCIAALBO##CEDENTEPRESTATOREDATIANAGRAFICINUMEROISCRIZIONEALBO##CEDENTEPRESTATOREDATIANAGRAFICIDATAISCRIZIONEALBO#
                <RegimeFiscale>#AZI_REGIMEFI#</RegimeFiscale>
            </DatiAnagrafici>
            <Sede>
                <Indirizzo>#AZI_INDIRI#</Indirizzo>
                <NumeroCivico>#AZI_NRCIVICO#</NumeroCivico>
                <CAP>#AZI_CAP#</CAP>
                <Comune>#AZI_LOCALI#</Comune>
                <Provincia>#AZI_PROVINCIA#</Provincia>
                <Nazione>#AZI_NAZION#</Nazione>
            </Sede>
            <IscrizioneREA>
                <Ufficio>#AZI_UFFICIO#</Ufficio>
                <NumeroREA>#AZI_NRREA#</NumeroREA>#CEDENTEPRESTATOREISCRIZIONEREACAPITALESOCIALE#
                <SocioUnico>#AZI_SOCIOU#</SocioUnico>
                <StatoLiquidazione>#AZI_STATOL#</StatoLiquidazione>
            </IscrizioneREA>
            <Contatti>
                #CEDENTEPRESTATORECONTATTITELEFONO##CEDENTEPRESTATORECONTATTIFAX#
                <Email>#AZI_EMAIL#</Email>
            </Contatti>
        </CedentePrestatore>
        <CessionarioCommittente>
            <DatiAnagrafici>
                #CESSIONARIOCOMMITTENTEDATIANAGRAFICIIDFISCALEIVA#
                <Anagrafica>
                    <Denominazione>#ORD_RAGSOC#</Denominazione>
                </Anagrafica>
            </DatiAnagrafici>
            <Sede>
                <Indirizzo>#ORD_INDIRI#</Indirizzo>
                <CAP>#ORD_CAP#</CAP>
                <Comune>#ORD_LOCALI#</Comune>#CESSIONARIOCOMMITTENTESEDEPROVINCIA#
                <Nazione>#ORD_IDPAESE#</Nazione>
            </Sede>
        </CessionarioCommittente>
        <TerzoIntermediarioOSoggettoEmittente>
            <DatiAnagrafici>
                <IdFiscaleIVA>
                    <IdPaese>#AZI_IDPAESEIN#</IdPaese>
                    <IdCodice>#AZI_PIVAIN#</IdCodice>
                </IdFiscaleIVA>
                <Anagrafica>
                    <Denominazione>#AZI_RAGSOCIN#</Denominazione>
                </Anagrafica>
            </DatiAnagrafici>
        </TerzoIntermediarioOSoggettoEmittente>
    </FatturaElettronicaHeader>
    <FatturaElettronicaBody>
        <DatiGenerali>
            <DatiGeneraliDocumento>
                <TipoDocumento>#TIPODOCUMENTO#</TipoDocumento>
                <Divisa>#ORD_VALUTA#</Divisa>
                <Data>#DATIGENERALIDOCUMENTODATA#</Data>
                <Numero>#DATIGENERALIDOCUMENTONUMERO#</Numero>#DATIGENERALIDOCUMENTODATIRITENUTA##DATIGENERALIDOCUMENTODATIBOLLOBOLLOVIRTUALE#
                <ImportoTotaleDocumento>#IMPORTOTOTALEDOCUMENTO#</ImportoTotaleDocumento>#DATIGENERALIDOCUMENTOCAUSALE#
            </DatiGeneraliDocumento>
            <DatiOrdineAcquisto>
                <RiferimentoNumeroLinea>#NUMERO_RIGA#</RiferimentoNumeroLinea>
                <IdDocumento>#DATIORDINEACQUISTOIDDOCUMENTO#</IdDocumento>#DATIORDINEACQUISTODATA##DATIORDINEACQUISTONUMITEM##CODICECOMMESSACONVENZIONE##CODICECUP##CODICECIG#
            </DatiOrdineAcquisto>
            <DatiDDT>
                <NumeroDDT>#DATIDDTNUMERODDT#</NumeroDDT>
                <DataDDT>#DATIDDTDATA#</DataDDT>
                <RiferimentoNumeroLinea>#NUMERO_RIGA#</RiferimentoNumeroLinea>
            </DatiDDT>
        </DatiGenerali>
        <DatiBeniServizi>
            <DettaglioLinee>
                <NumeroLinea>#NUMERO_RIGA#</NumeroLinea>#DETTAGLIOLINEETIPOCESSIONEPRESTAZIONE#
                <CodiceArticolo>
                    <CodiceTipo>#CODICE_TIPO#</CodiceTipo>
                    <CodiceValore>#CODICE_VALORE#</CodiceValore>
                </CodiceArticolo>
                <Descrizione>#ORD_DESART#</Descrizione>
                <Quantita>#ORD_QTAORD#</Quantita>
                <PrezzoUnitario>#ORD_PREZZO#</PrezzoUnitario>#DETTAGLIOLINEESCONTOMAGGIORAZIONE#
                <PrezzoTotale>#ORD_VALORE#</PrezzoTotale>
                <AliquotaIVA>#DETTAGLIOLINEEALIQUOTAIVA#</AliquotaIVA>#DETTAGLIOLINEERITENUTA##DETTAGLIOLINEENATURAIVA##DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE#
				#DETTAGLIOLINEEALTRIDATIGESTIONALI#
            </DettaglioLinee>
            <DatiRiepilogo>
                <AliquotaIVA>#DATIRIEPILOGOALIQUOTAIVA#</AliquotaIVA>#DATIRIEPILOGONATURA##DATIRIEPILOGOSPESEACCESSORIE##DATIRIEPILOGOARROTONDAMENTO#
                <ImponibileImporto>#DATIRIEPILOGOIMPONIBILEIMPORTO#</ImponibileImporto>
                <Imposta>#DATIRIEPILOGOIMPOSTA#</Imposta>
                <EsigibilitaIVA>#DATIRIEPILOGOESIGIBILITAIVA#</EsigibilitaIVA>#DATIRIEPILOGORIFERIMENTONORMATIVO#
            </DatiRiepilogo>
        </DatiBeniServizi>
        <DatiPagamento>
            <CondizioniPagamento>#AZI_CONPAG#</CondizioniPagamento>
            <DettaglioPagamento>
                <ModalitaPagamento>#DETTAGLIOPAGAMENTOMODALITAPAGAMENTO#</ModalitaPagamento>
                <DataScadenzaPagamento>#DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO#</DataScadenzaPagamento>
                <ImportoPagamento>#DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO#</ImportoPagamento>#DETTAGLIOPAGAMENTOIBAN#
            </DettaglioPagamento>
        </DatiPagamento>
        #ALLEGATI#
    </FatturaElettronicaBody>
</p:FatturaElettronica>
