WAIT WINDOWS "Sto ricalcolando la versione del software"  NOWAIT

*!*	SET PROCEDURE TO PRG\WINLIB.PRG ADD
SET CENTURY ON 
SET DATE TO GERMAN 

CLOSE DATABASES ALL

CREATE CURSOR PROGRAMMI ;
       (NOME_PROGRAMMA C(200),DATA_AGGIORNAMENTO C(10),ORA_AGGIORNAMENTO C(8))
INDEX ON DATA_AGGIORNAMENTO+ORA_AGGIORNAMENTO TAG I_DATA_ORA DESC
SET ORDER TO I_DATA_ORA


RICERCA_FILE_PROGRAMMI("FORM\*.SCX")
RICERCA_FILE_PROGRAMMI("PRG\*.PRG")
RICERCA_FILE_PROGRAMMI("RICERCHE\*.PRG")
RICERCA_FILE_PROGRAMMI("SC_SQL\*.SQL")
RICERCA_FILE_PROGRAMMI("REPORT\*.FRX")
RICERCA_FILE_PROGRAMMI("*.VCX")


SELECT PROGRAMMI 
GO TOP


_DATA_VER=DATA_AGGIORNAMENTO 
_ORA_VER=ORA_AGGIORNAMENTO 

USE VERSIONE IN 0 AGAIN SHARED 
SELECT VERSIONE 
GO TOP
REPLACE VER_VERSIO WITH "Ver."+STRTRAN(_DATA_VER,"/",".")+"."+STRTRAN(PADL(ALLTRIM(_ORA_VER),8,"0"),":",".")

SELECT VERSIONE 
USE

CLOSE DATABASES ALL


****************************************
PROCEDURE RICERCA_FILE_PROGRAMMI
****************************************

LPARAMETERS _PATH


NUMFILE = ADIR(MATFILE,ALLTRIM(_PATH))


IF NUMFILE = 0
   =MESSAGEB("File "+ALLTRIM(_PATH)+" trovato",16,"*** ATTENZIONE ***")
   RETURN
ENDIF


FOR FF = 1 TO NUMFILE							&& ELABORAZIONE MULTIPLIPA DEI FILE SCRIPT SQL CONTENUTI NELLA DIRECTORY

  	NOME_FILE = MATFILE[FF,1]
  	DATA_FILE = MATFILE[FF,3]
  	ORA_FILE  = MATFILE[FF,4]

	SELECT PROGRAMMI 
	APPEND BLANK
	REPLACE NOME_PROGRAMMA 		WITH ALLTRIM(NOME_FILE)
    *REPLACE DATA_AGGIORNAMENTO	WITH RIBALTA2(DTOC(DATA_FILE))
    REPLACE DATA_AGGIORNAMENTO	WITH SUBSTR(DTOC(DATA_FILE),7,4) + "/" + SUBSTR(DTOC(DATA_FILE),4,2) + "/" + SUBSTR(DTOC(DATA_FILE),1,2)
    REPLACE ORA_AGGIORNAMENTO	WITH ORA_FILE  

ENDFOR

RETURN

