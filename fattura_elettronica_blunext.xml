        <IdFiscaleIVA>
          <IdPaese>#AZI_IDPAESE#</IdPaese>
          <IdCodice>#AZI_CODFIS#</IdCodice>
        </IdFiscaleIVA>
        <CodiceFiscale>#AZI_PIVA#</CodiceFiscale>
        <Anagrafica>
          <Denominazione>#AZI_RAGSOC#</Denominazione>
          <CodEORI>#AZI_CODEORI#</CodEORI>
        </Anagrafica>
        <AlboProfessionale>#AZI_ALBO#</AlboProfessionale>
        <ProvinciaAlbo>#AZI_PRVALBO#</ProvinciaAlbo>
        <NumeroIscrizioneAlbo>#AZI_NUMISALBO#</NumeroIscrizioneAlbo>
        <DataIscrizioneAlbo>#AZI_DTALBO#</DataIscrizioneAlbo>
        <RegimeFiscale>#AZI_REGIMEFI#</RegimeFiscale>
      </DatiAnagrafici>
      <Sede>
        <Indirizzo>#AZI_INDIRI#</Indirizzo>
        <NumeroCivico>#AZI_NRCIVICO#</NumeroCivico>
        <CAP>#AZI_CAP#</CAP>
        <Comune>#AZI_LOCALI#</Comune>
        <Provincia>#AZI_PROVINCIA#</Provincia>
        <Nazione>#AZI_NAZION#</Nazione>
      </Sede>
      <IscrizioneREA>
        <Ufficio>#AZI_UFFICIO#</Ufficio>
        <NumeroREA>#AZI_NRREA#</NumeroREA>
        <CapitaleSociale>#AZI_CAPITSO#</CapitaleSociale>
        <SocioUnico>#AZI_SOCIOU#</SocioUnico>
        <StatoLiquidazione>#AZI_STATOL#</StatoLiquidazione>
      </IscrizioneREA>
      <Contatti>
        <Telefono>#AZI_TELEFO#</Telefono>
        <Fax>#AZI_FAX#</Fax>
        <Email>#AZI_EMAIL#</Email>
      </Contatti>
    </CedentePrestatore>
    <CessionarioCommittente>
      <DatiAnagrafici>
        <IdFiscaleIVA>
          <IdPaese>#ORD_IDPAESE#</IdPaese>
          <IdCodice>#ORD_PARIVA#</IdCodice>
        </IdFiscaleIVA>
        <Anagrafica>
          <Denominazione>#ORD_RAGSOC#</Denominazione>
        </Anagrafica>
      </DatiAnagrafici>
      <Sede>
        <Indirizzo>#ORD_INDIRI#</Indirizzo>
        <CAP>#ORD_CAP#</CAP>
        <Comune>#ORD_LOCALI#</Comune>
        <Provincia>#ORD_PROVIN#</Provincia>
        <Nazione>#ORD_IDPAESE#</Nazione>
      </Sede>
    </CessionarioCommittente>
    <TerzoIntermediarioOSoggettoEmittente>
      <DatiAnagrafici>
        <IdFiscaleIVA>
          <IdPaese>#AZI_IDPAESEIN#</IdPaese>
          <IdCodice>#AZI_PIVAIN#</IdCodice>
        </IdFiscaleIVA>
        <Anagrafica>
          <Denominazione>#AZI_RAGSOCIN#</Denominazione>
        </Anagrafica>
      </DatiAnagrafici>
    </TerzoIntermediarioOSoggettoEmittente>
    <SoggettoEmittente>#AZI_SOGGEMIN#</SoggettoEmittente>
  </FatturaElettronicaHeader>
  <FatturaElettronicaBody xmlns="">
    <DatiGenerali>
      <DatiGeneraliDocumento>
        <TipoDocumento>#TIPODOCUMENTO#</TipoDocumento>
        <Divisa>#ORD_VALUTA#</Divisa>
        <Data>#DATIGENERALIDOCUMENTODATA#</Data>
        <Numero>#DATIGENERALIDOCUMENTONUMERO#</Numero>
        <ImportoTotaleDocumento>#ORD_VALORE#</ImportoTotaleDocumento>
        <Art73>SI</Art73>
      </DatiGeneraliDocumento>
      <DatiOrdineAcquisto>
        <RiferimentoNumeroLinea>>#NUMERO_RIGA#</RiferimentoNumeroLinea>
        <IdDocumento>#DATIORDINEACQUISTOIDDOCUMENTO#</IdDocumento>
        <Data>#DATIORDINEACQUISTODATA#</Data>
      </DatiOrdineAcquisto>
      <DatiDDT>
