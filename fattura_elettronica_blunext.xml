<?xml version="1.0"?>
<FatturaElettronica xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" versione="#AZI_FORTRA#" xmlns="http://ivaservizi.agenziaentrate.gov.it/docs/xsd/fatture/v1.2">
  <FatturaElettronicaHeader xmlns="">
    <DatiTrasmissione>
      <IdTrasmittente>
        <IdPaese>#AZI_IDPAESE#</IdPaese>
        <IdCodice>#AZI_PIVAIN#</IdCodice>
      </IdTrasmittente>
      <ProgressivoInvio>99999</ProgressivoInvio>
      <FormatoTrasmissione>#AZI_FORTRA#</FormatoTrasmissione>
      <CodiceDestinatario>#ORD_IDSDI#</CodiceDestinatario>
      <PECDestinatario>#ORD_EPEC#</PECDestinatario>
    </DatiTrasmissione>
    <CedentePrestatore>
