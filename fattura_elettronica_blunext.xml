        <NumeroLinea>#NUMERO_RIGA#</NumeroLinea>
        <CodiceArticolo>
          <CodiceTipo>#CODICE_TIPO#</CodiceTipo>
          <CodiceValore>#CODICE_VALORE#</CodiceValore>
        </CodiceArticolo>
        <Descrizione>#ORD_DESART#</Descrizione>
        <Quantita>#ORD_QTAORD#</Quantita>
        <PrezzoUnitario>#ORD_PREZZO#</PrezzoUnitario>
        <ScontoMaggiorazione>
          <Tipo>SC</Tipo>
          <Percentuale>#ORD_SC1#</Percentuale>
          <Importo>#IMPORTO_SCONTO#</Importo>
        </ScontoMaggiorazione>
        <PrezzoTotale>#ORD_VALORE#</PrezzoTotale>
        <AliquotaIVA>22.00</AliquotaIVA>
      </DettaglioLinee>
      <DatiRiepilogo>
        <AliquotaIVA>#DATIRIEPILOGOALIQUOTAIVA#</AliquotaIVA>
        <ImponibileImporto>#DATIRIEPILOGOIMPONIBILEIMPORTO#</ImponibileImporto>
        <Imposta>#DATIRIEPILOGOIMPOSTA#</Imposta>
        <EsigibilitaIVA>#DATIRIEPILOGOESIGIBILITAIVA#</EsigibilitaIVA>
      </DatiRiepilogo>
    </DatiBeniServizi>
    <DatiPagamento>
      <CondizioniPagamento>#AZI_CONPAG#</CondizioniPagamento>
      <DettaglioPagamento>
        <ModalitaPagamento>#AZI_MODPAG#</ModalitaPagamento>
        <ImportoPagamento>#IMPORTO_PAGAMENTO#</ImportoPagamento>
        <IBAN>#AZI_IBAN#</IBAN>
      </DettaglioPagamento>
    </DatiPagamento>
