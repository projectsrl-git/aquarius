PARAMETERS V_SEEK

DO CASE
   CASE V_SCELTA=1                          && ACCESSO PER CODICE
      _II_SEEK = WPARA+ALLTRIM(V_SEEK)
      TEXT TO _ii_cSql NOSHOW
		SELECT SUBSTRING(CODICE,1,5) AS tipo, SUBSTRING(CODICE,6,6) AS CODICE, DESCRI, CODPGO, LIBERA
		FROM para
		where codice LIKE ?_II_SEEK+'%'
		ORDER BY CODICE
	  ENDTEXT

   CASE V_SCELTA=2                          && ACCESSO PER DESCRIZIONE
      _II_SEEK = ALLTRIM(V_SEEK)
      TEXT TO _ii_cSql NOSHOW
		SELECT SUBSTRING(CODICE,1,5) AS tipo, SUBSTRING(CODICE,6,6) AS CODICE, DESCRI, CODPGO, LIBERA
		FROM para
		where SUBSTRING(CODICE,1,5) = ?WPARA AND descri LIKE ?_II_SEEK+'%'
		ORDER BY DESCRI
	  ENDTEXT

ENDCASE


