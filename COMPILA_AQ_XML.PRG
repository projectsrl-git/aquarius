WAIT WINDOWS "Sto ricompilando fatturazione_elettronica_lib per AQ_XML"  NOWAIT

*ERASE PRG\*.FXP
ERASE PRG\FATTURAZIONE_ELETTRONICA_LIB.FXP
ERASE PRG\STARTUP_XML.FXP
ERASE PRG\*.BAK
*COMPILE PRG\*.PRG
COMPILE PRG\STARTUP_XML
COMPILE PRG\FATTURAZIONE_ELETTRONICA_LIB

*ERASE RICERCHE\*.FXP
ERASE RICERCHE\*.BAK
*COMPILE RICERCHE\*.PRG

WAIT WINDOWS "Sto compilando AQ_XML" NOWAIT
BUILD EXE AQ_XML FROM AQ_XML

*WAIT WINDOWS "Sto ricalcolando la versione di Aquarius" NOWAIT
*DO VERSIONE
        
WAIT WINDOWS 'Per eseguire il progetto: DO aq_xml WITH "SER","VIVIANI"' 

WAIT WINDOWS "Fine compilazione progetti" NOWAIT


