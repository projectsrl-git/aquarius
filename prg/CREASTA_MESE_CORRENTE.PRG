*****************************************************************************************
**** ROUTINE PER LA CREAZIONE DELL'ARCHIVIO STATISTICO DELLE FATTURE PER IL MESE CORRENTE
*****************************************************************************************


**=> ERASMO - INIZIO 23/12/2015
XDESCRI = "ATTENZIONE:"+CHR(10)+CHR(10)+"Programma non piů disponibile: l'archivio statistico viene ora gestito con una vista"
MESSAGGIO_GROSSO_ROSSO(XDESCRI)
RETURN .F.
**=> ERASMO - FINE 23/12/2015

V_CLIDAL = ""
V_CLIAL  = ""
_DATADAL = "01/" + SUBSTR(DTOC(DATE()),4,7)
_DATAAL  = DTOC(DATE())

*!*	*******************************************************
*!*	LOCAL _X_FILENAME,V_FILE,_STRINGA
*!*	_X_FILENAME = "D:\TEST_TIMER\FILE_TIMER_" + STRTRAN(DTOC(DATE()),'/','-')+"_"+STRTRAN(TIME(),':','-') + "_" + STRTRAN(TRANSFORM(SECONDS()),',','_') + SYS(2015) + ".TXT"
*!*	IF FILE(_X_FILENAME)
*!*		_cEraseExistingFile = "ERASE '" + _X_FILENAME + "'"
*!*		&_cEraseExistingFile
*!*	ENDIF
*!*	V_FILE = FCREATE(_X_FILENAME)
*!*	_STRINGA = 	"INIZIO PROCEDURA DI CREAZIONE ARCHIVIO STATISTICO"
*!*	FPUTS(V_FILE,_STRINGA)
*!*	=FCLOSE(V_FILE)
*!*	*******************************************************

_CONTINUA = .T.  && PERMETTE DI MOSTRARE DELLE WAIT WINDOWS INVECE CHE LE MESSAGEBOX
DO CREASTA WITH _CONTINUA

RETURN


*****************
PROCEDURE CREASTA
*****************

LPARAMETERS _CONTINUA

IF PARAMETERS() >= 1
ELSE
   _CONTINUA = .F.
ENDIF

***********************************************************************
*** NUOVA VERSIONE CON SOSTITUZIONE QUERY FRAMMENTATE IN UN'UNICA QUERY
***********************************************************************
IF _CONTINUA
	WAIT WINDOW "Aggiornamento archivio statistico in corso..." NOWAIT
ELSE
	V_RIT= MESSAGEBOX("La seguente funzione annulla i movimenti statistici esistenti e li ricarica"+CHR(13)+;
						"Proseguire l'elaborazione ?",36,'*** ATTENZIONE ***')
	IF V_RIT = 6  && RISPOSTA SI
		WAIT WINDOW "Creazione archivio statistico in corso..." NOWAIT
	ELSE
		RETURN
	ENDIF
ENDIF

V_CLIDAL = ALLTRIM(V_CLIDAL)
V_CLIAL  = ALLTRIM(V_CLIAL)
PERDAL	 = RIBALTA2(_DATADAL)
PERAL	 = RIBALTA2(_DATAAL)
AMDAL	 = SUBSTR(PERDAL,1,4)+SUBSTR(PERDAL,6,2)
AMAL	 = SUBSTR(PERAL,1,4)+SUBSTR(PERAL,6,2)

IF _CONTINUA
ELSE
	WAIT WINDOW "Cancellazione vecchio archivio statistico in corso..." NOWAIT
ENDIF
*=> Cancellazione di tutti i records che rientrano nel range di date digitate
*=> per la tabella sql U_STC_AN
CSQL = "DELETE FROM U_STC_AN WHERE STC_DTDOC >= ?PERDAL AND STC_DTDOC <= ?PERAL"
IF !ExecCommand(CSQL,"U_STC_AN")
	RETURN (.f.)
ENDIF

IF _CONTINUA
	WAIT WINDOW "Aggiornamento archivio statistico in corso..." NOWAIT
ELSE
	WAIT WINDOW "Creazione archivio statistico in corso..." NOWAIT
ENDIF


* RIELABORA LE FATTURE E LE RICARICA 
* ==================================
* => Preparazione di variabili con i filtri che mi servono per estrapolare i dati dall'archivio
* => sql delle testate e dei dettagli fatture
cSql=""     
cNomeCursorSql="FATTURE"
TEXT TO cSql NOSHOW
	SELECT 
		TT.ORD_CODSOC AS STC_CODSOC, 
		SUBSTRING(TT.ORD_DATORD,1,4)+SUBSTRING(TT.ORD_DATORD,6,2) AS STC_DATA, 
		TT.ORD_DATORD AS STC_DTDOC, 
		TT.ORD_AGE AS STC_CODAGE, 
		COALESCE(AG.AGE_RAGSOC,'') AS STC_DESAGE, 
		TT.ORD_CODCLI AS STC_CODCLI, 
		TT.ORD_RAGSOC AS STC_DESCLI, 
		ORD_CODART AS STC_CODART, 
		ORD_DESART AS STC_DESART, 
		ORD_UM AS STC_UNIMIS, 		
		COALESCE(AR.ART_LINEA,'') AS STC_LINEA, 
		DD.ORD_QTAORD * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS STC_QTAVEN, 
		CASE AR.ART_PUBBLI 
			WHEN 'S' THEN 0 
			ELSE ROUND(DD.ORD_VALORE * TT.ORD_CAMBIO * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END),2) 
		END AS STC_VALORE, 		
		TT.ORD_CAUS AS STC_TOP, 		
		TT.ORD_CAP AS STC_CAP, 				
		TT.ORD_VALUTA AS STC_VALUTA, 
		TT.ORD_CAMBIO AS STC_CAMBIO, 
		TT.ORD_NUMORD AS STC_NUMORD, 
		COALESCE(AR.ART_PRZCOS,0) AS STC_PRZCOS, 
		CASE AR.ART_PUBBLI 
			WHEN 'S' THEN 0 
			ELSE ROUND(DD.ORD_VALORE * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END),2) 
		END AS STC_VALVAL, 
		CASE ORD_UM 
			WHEN 'MQ' THEN DD.ORD_QTAORD * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) 
			ELSE DD.ORD_QTAMQ * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) 
		END AS ORD_QTAMQ, 
		DD.ORD_QTAMQ1 * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAMQ1, 
		DD.ORD_QTAML * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAML, 
		DD.ORD_QTAML1 * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAML1, 
		DD.ORD_QTAKG * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAKG, 
		DD.ORD_QTAKG1 * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAKG1, 		
		ORD_CODMAT AS ORD_CODMAT, 
		ORD_DESMAT AS ORD_DESMAT, 
		ORD_SPESSO AS ORD_SPESSO, 
		ORD_ALTEZZ AS ORD_ALTEZZ, 
		ORD_LUNGHE AS ORD_LUNGHE, 
		ORD_NUMBOB AS ORD_NUMBOB, 
		ORD_DATPED AS ORD_DATPED, 
		ORD_NOTEBO AS ORD_NOTEBO, 
		ORD_DESIMB AS ORD_DESIMB, 
		ORD_LOTMIN AS ORD_LOTMIN, 
		DD.ORD_QTAKGI * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAKGI, 
		DD.ORD_QTAKGE * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAKGE, 
		ORD_CDAPRD AS ORD_CDAPRD, 
		ORD_DSAPRD AS ORD_DSAPRD, 			
		COALESCE(CL.CLI_ZONA,'') AS STC_ZONA, 
		COALESCE(AR.ART_SERIE,'') AS STC_SERIE, 
		COALESCE(ZON.DESCRI,'') AS STC_DESZON, 
		COALESCE(SER.DESCRI,'') AS STC_DESSER, 
		DD.ORD_QTAMCE * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAMCE, 
		DD.ORD_QTAMC1 * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAMC1, 
		DD.ORD_QTAMC * (CASE SUBSTRING(CAUS.LIBERA,11,1) WHEN 'S' THEN -1 ELSE 1 END) AS ORD_QTAMC
	FROM U_FAT_DD AS DD
	INNER JOIN U_FAT_TT AS TT ON TT.TAGGANCIO = DD.DAGGANCIO 
	LEFT OUTER JOIN U_CLI_AN AS CL ON CL.CLI_CODSOC = TT.ORD_CODSOC AND CL.CLI_CODCLI = TT.ORD_CODCLI 
	LEFT OUTER JOIN U_AGE_AN AS AG ON AG.AGE_CODSOC = TT.ORD_CODSOC AND AG.AGE_CODICE = TT.ORD_AGE 
	LEFT OUTER JOIN PARA AS CAUS ON CAUS.CODICE = 'TOP'+TT.ORD_CAUS 
	LEFT OUTER JOIN U_ART_PR AS AR ON AR.ART_CODSOC = TT.ORD_CODSOC AND AR.ART_CODPRI = DD.ORD_CODART 
	LEFT OUTER JOIN PARA AS SER ON SER.CODICE = 'SER'+AR.ART_SERIE 
	LEFT OUTER JOIN PARA AS ZON ON ZON.CODICE = 'ZON'+CL.CLI_ZONA 
	WHERE 
		TT.ORD_CODSOC = '<<PUB_CODSOC>>' AND 
		TT.ORD_DATORD BETWEEN '<<PERDAL>>' AND '<<PERAL>>' AND 
		DD.ORD_DESART <> '*** COMMENTO ***' AND 
		DD.ORD_CODART <> 'POLIECO'
	ORDER BY DD.DAGGANCIO, DD.ORD_SEQUEN
ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT FATTURE
GO TOP
IF EOF()
	WAIT CLEAR
	MESSAGEBOX("Nessuna fattura da rielaborare",16,"Attenzione")
	RETURN
ENDIF
SCAN
	IF _CONTINUA
		WAIT WINDOW "Aggiornamento archivio statistico - Caricamento dati (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 
	ELSE
		WAIT WINDOW "Creazione archivio statistico - Caricamento dati (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 
	ENDIF
	
	SCATTER MEMVAR MEMO
		
	cSql = "select * from U_STC_AN where 0=1"
	IF !ExecRW(cSql,"U_STC_AN","R")
	  return(.f.)
	ENDIF
	
	SELECT U_STC_AN
	APPEND BLANK
	REPLACE STC_CODSOC WITH PUB_CODSOC
	REPLACE STC_DATA   WITH M.STC_DATA
	REPLACE STC_DTDOC  WITH M.STC_DTDOC
	REPLACE STC_CODAGE WITH M.STC_CODAGE
	REPLACE STC_DESAGE WITH M.STC_DESAGE
	REPLACE STC_CODCLI WITH M.STC_CODCLI
	REPLACE STC_DESCLI WITH M.STC_DESCLI
	REPLACE STC_CODART WITH M.STC_CODART
	REPLACE STC_DESART WITH M.STC_DESART
	REPLACE STC_UNIMIS WITH M.STC_UNIMIS
	REPLACE STC_LINEA  WITH M.STC_LINEA
	REPLACE STC_QTAVEN WITH M.STC_QTAVEN
	**REPLACE STC_VALORE WITH CAMBIO(M.STC_VALUTA,M.STC_VALORE,M.STC_CAMBIO)		&& sergio : non va bene in quanto poi i report eseguono a loro volta la routine cambio
	REPLACE STC_VALORE WITH M.STC_VALORE
	REPLACE STC_TOP	   WITH M.STC_TOP
	REPLACE STC_CAP	   WITH M.STC_CAP
	REPLACE STC_VALUTA WITH M.STC_VALUTA
	REPLACE STC_CAMBIO WITH M.STC_CAMBIO
	REPLACE STC_NUMORD WITH M.STC_NUMORD
	*REPLACE STC_PRZCOS WITH CAMBIO(M.STC_VALUTA,M.STC_PRZCOS,M.STC_CAMBIO)			&& sergio : non va bene in quanto poi i report eseguono a loro volta la routine cambio
	*REPLACE STC_VALVAL WITH CAMBIO(M.STC_VALUTA,M.STC_VALVAL ,M.STC_CAMBIO)		&& sergio : non va bene in quanto poi i report eseguono a loro volta la routine cambio
	REPLACE STC_PRZCOS WITH M.STC_PRZCOS
	REPLACE STC_VALVAL WITH M.STC_VALVAL
	REPLACE ORD_QTAMQ  WITH M.ORD_QTAMQ 
	REPLACE ORD_QTAMQ1 WITH M.ORD_QTAMQ1
	REPLACE ORD_QTAML  WITH M.ORD_QTAML  
	REPLACE ORD_QTAML1 WITH M.ORD_QTAML1 
	REPLACE ORD_QTAKG  WITH M.ORD_QTAKG  
	REPLACE ORD_QTAKG1 WITH M.ORD_QTAKG1 
	REPLACE ORD_CODMAT WITH M.ORD_CODMAT
	REPLACE ORD_DESMAT WITH M.ORD_DESMAT
	REPLACE ORD_SPESSO WITH M.ORD_SPESSO
	REPLACE ORD_ALTEZZ WITH M.ORD_ALTEZZ
	REPLACE ORD_LUNGHE WITH M.ORD_LUNGHE
	REPLACE ORD_NUMBOB WITH M.ORD_NUMBOB
	REPLACE ORD_DATPED WITH M.ORD_DATPED
	REPLACE ORD_NOTEBO WITH M.ORD_NOTEBO
	REPLACE ORD_DESIMB WITH M.ORD_DESIMB
	REPLACE ORD_LOTMIN WITH M.ORD_LOTMIN
	REPLACE ORD_QTAKGI WITH M.ORD_QTAKGI 
	REPLACE ORD_QTAKGE WITH M.ORD_QTAKGE	
	REPLACE ORD_CDAPRD WITH M.ORD_CDAPRD 
	REPLACE ORD_DSAPRD WITH M.ORD_DSAPRD 
	REPLACE STC_ZONA   WITH M.STC_ZONA
	REPLACE STC_SERIE  WITH M.STC_SERIE
	REPLACE STC_DESZON WITH M.STC_DESZON
	REPLACE STC_DESSER WITH M.STC_DESSER
	REPLACE ORD_QTAMCE WITH M.ORD_QTAMCE
	REPLACE ORD_QTAMC  WITH M.ORD_QTAMC 
	REPLACE ORD_QTAMC1 WITH M.ORD_QTAMC1
	
	IF !ExecRW(cSql,"U_STC_AN","W")
	  return(.f.)
	ENDIF
	
	SELECT FATTURE
ENDSCAN

WAIT CLEAR

IF _CONTINUA
	WAIT WINDOW "Aggiornamento archivio statistico terminato correttamente" NOWAIT
ELSE
	V_RIT= MESSAGEB('Creazione archivio statistico terminata correttamente',62,'*** ATTENZIONE ***')
ENDIF

SELECT(_ACT_SEL)

RETURN

