
RIT = MESSAGEBOX("Procedo con l'acquisizione dei raggruppamenti del sole24ore ?",292,"ATTENZIONE")
IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF

** ASSEGNAZIONE DELLA VARIABILE PATH **************************
		
V_PATH = "\COVERTEC\FILE_DA_CONVERTIRE\BE" 


****** DEFINIZIONE DEL CURSORE STP

IF !ExecCommand("select * from PARA where 1=0","curs_PARA")
   return
ENDIF

WAIT WINDOWS "ATTENDERE PREGO, CANCELLAZIONE VECCHI RAGGRUPPAMENTI SOLE24ORE" NOWAIT


*!*	*** CANCELLAZIONE DEI RECORD DELLA TABELLA PARA SQL

cSql = "delete from PARA where CODICE LIKE 'RSO%' "
IF !ExecCommand(cSql,"PARA")
   return(.f.)
ENDIF

******** DEFINISCE LE VARIABILI E CREA IL CURSORE DI SUPPORTO

RELEASE Y_CAMPO,V_CAMPO,_CTR,_PROGRE,A
PUBLIC Y_CAMPO,V_CAMPO,_CTR,_PROGRE,A
Y_CAMPO = ""
V_CAMPO = ""
_CTR    = 0
_PROGRE = ""
A=1

CREATE CURSOR TRANSITO (TRA_RECORD C(250))

*SELECT TRANSITO
*APPEND FROM &V_PATH SDF

**** CARICAMENTO DEL FILE IN FORMATO TESTO

SELECT TRANSITO  
gcTable = GETFILE('', 'Seleziona file da acquisire', 'Converti',0)
IF empty(gcTable) .or. gcTable = ""
   =MESSAGEBOX("Nessun file selezionato, operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF
APPEND FROM &gcTable SDF
GO TOP

***** ELABORA IL CURSORE transito PER CREARE IL CURSORE STP

SELECT TRANSITO
GO TOP

_CONTA = 0

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   M.CODICE = 'RSO'+ALLTRIM(SUBSTR(TRA_RECORD,1,4))
   M.DESCRI = ALLTRIM(SUBSTR(TRA_RECORD,5,200))
   
   SELECT curs_PARA				&& CREAZIONE DEL CURSORE STP PER IL SUCCESSIVO AGGIORNAMENTO IN AMBIENTE SQL
   APPEND BLANK
   GATHER MEMVAR MEMO 				&& EFFETTUA LA REPLACE NEL CURSORE STP FOX SOSTITUENDO LE REPLACE DI OGNI SINGOLO CAMPO 
												   
   _CONTA = _CONTA + 1
   _CTR   = _CTR + 1
   A      = A + 10
   
   WAIT WINDOWS "RECORDS SCRITTI : "+STR(_CTR,10,0) NOWAIT

   SELECT TRANSITO      
   SKIP +1
		  
ENDDO

SELECT curs_PARA
GO TOP

****** AGGIORNA TABELLA PARA SQL

IF !ExecRW('','PARA','I','','curs_para')
   return(.f.)
ENDIF
	 
=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

RETURN

