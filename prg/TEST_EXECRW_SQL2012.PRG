
CREATE CURSOR TEMPO ;
	(CON_SOC C(2), CON_ANNO C(4), CON_CONTO C(13), CON_DESCR C(40),CON_IMP_D    N(13) , CON_IMP_A N(13) , CON_TIPOCO C(1), ;
		CON_PARIVA C(11), CON_CLASS9 C(13),CON_POSBIL C(1),;
		        CON_SALDOI N(17,3),CON_NUMPAR C(13),CON_CCO C(13),CON_CCO1 C(13),CON_CCO2 C(13),CON_CCO3 C(13),CON_CCO4 C(13))

WAIT WINDOW "Stň copiando il piano dei conti" NOWAIT

CONT=0 
x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '2013'"
x_cond = x_soci + " and " + x_anno
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP


DO WHILE .T. 
   
   IF EOF()
      EXIT
   ENDIF
    
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
    
   CONT=CONT+1
   SCATTER MEMVAR 

   SELECT TEMPO
   APPEND BLANK
   GATHER MEMVAR 

   SELECT CUR_CONTI 
   SKIP +1
    
ENDDO  


    
** AZZERA    IL NUOVO PIANO DEI CONTI

WAIT WINDOW "Stň cancellando il piano dei conti NUOVO" NOWAIT

IF !ExecCommand("DELETE from conti where CON_ANNO = '2117'","DEL_conti")
   return(.f.)
ENDIF

IF !ExecCommand("select * from conti where 0=1","cu_conti")
   return(.f.)
ENDIF


WAIT WINDOW "Stň AZZERANDO il piano dei conti " NOWAIT
SELECT TEMPO
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
   
   SOC		= CON_SOC
   AN		= CON_ANNO
   CON		= CON_CONTO
   DES		= CON_DESCR
   DA		= 0
   AV		= 0
   TIPC 	= CON_TIPOCO
   PAR  	= CON_PARIVA
   CLA  	= CON_CLASS9
   POS  	= CON_POSBIL
   SAL  	= CON_SALDOI
   NUM  	= CON_NUMPAR

   SCATTER MEMVAR           

   SELECT CU_CONTI
   APPEND BLANK
   REPLACE CON_SOC    WITH SOC
   REPLACE CON_ANNO   WITH '2117'
   REPLACE CON_CONTO  WITH CON
   REPLACE CON_DESCR  WITH DES
   REPLACE CON_IMP_D  WITH 0
   REPLACE CON_IMP_A  WITH 0
   REPLACE CON_DA01   WITH 0
   REPLACE CON_AV01   WITH 0
   REPLACE CON_DA02   WITH 0
   REPLACE CON_AV02   WITH 0
   REPLACE CON_DA03   WITH 0
   REPLACE CON_AV03   WITH 0
   REPLACE CON_DA04   WITH 0
   REPLACE CON_AV04   WITH 0
   REPLACE CON_DA05   WITH 0
   REPLACE CON_AV05   WITH 0
   REPLACE CON_DA06   WITH 0
   REPLACE CON_AV06   WITH 0
   REPLACE CON_DA07   WITH 0
   REPLACE CON_AV07   WITH 0
   REPLACE CON_DA08   WITH 0
   REPLACE CON_AV08   WITH 0
   REPLACE CON_DA09   WITH 0
   REPLACE CON_AV09   WITH 0
   REPLACE CON_DA10   WITH 0
   REPLACE CON_AV10   WITH 0
   REPLACE CON_DA11   WITH 0
   REPLACE CON_AV11   WITH 0
   REPLACE CON_DA12   WITH 0
   REPLACE CON_AV12   WITH 0
   REPLACE CON_SALDOI WITH 0
   REPLACE CON_TIPOCO WITH TIPC
   REPLACE CON_PARIVA WITH PAR
   REPLACE CON_CLASS9 WITH CLA
   REPLACE CON_POSBIL WITH POS
   REPLACE CON_NUMPAR WITH NUM
   REPLACE CON_CCO    WITH M.CON_CCO
   REPLACE CON_CCO1   WITH M.CON_CCO1
   REPLACE CON_CCO2   WITH M.CON_CCO2
   REPLACE CON_CCO3   WITH M.CON_CCO3
   REPLACE CON_CCO4   WITH M.CON_CCO4
   REPLACE CHI_DARE   WITH 0
   REPLACE CHI_AVERE  WITH 0
       
   SELECT TEMPO 
   SKIP +1

ENDDO



WAIT WINDOW "Stň INSERENDO il piano dei conti " NOWAIT

SET STEP ON
IF !ExecRW('','conti','I','','CU_CONTI')
   return(.f.)
ENDIF

MESSAGEBOX("PROGRAMMA ESEGUITO")

RETURN
