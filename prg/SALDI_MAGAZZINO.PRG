
RELEASE _V_DATADA,_V_DATAAL,_V_CODMAG,_V_DESMAG
PUBLIC _V_DATADA,_V_DATAAL,_V_CODMAG,_V_DESMAG

_V_DATADA = "01/01/"+ALLTRIM(STR(VAL(PUB_ANNO)-1,4,0))
_V_DATAAL = "31/12/"+ALLTRIM(STR(VAL(PUB_ANNO)-1,4,0))
_V_CODMAG = ""
_V_DESMAG = ""

_CONTINUA = .F.
DO FORM FORM\SALDI_MAGAZZINO_SEL_FILTRI LINKED
IF !_CONTINUA
	MESSAGEBOX("Operazione abbandonata",48,"Informazione")
	RETURN .F.
ENDIF

x_dtda = "MO.MOV_DTREGI >= '" + RIBALTA2(_V_DATADA) + "'"
x_dtal = "MO.MOV_DTREGI <= '" + RIBALTA2(_V_DATAAL) + "'"
x_cond = x_dtda + " and " + x_dtal
IF !EMPTY(_V_CODMAG)
	x_cond = x_cond + " and MO.MOV_CODMAG = '" + ALLTRIM(_V_CODMAG) + "'"
ENDIF				

WAIT WINDOWS "Estrazione saldo movimenti per valorizzazione magazzino alla data..." NOWAIT

cSql=""
cNomeCursorSql="SALDO_MOVIMENTI"
TEXT TO cSql NOSHOW

	SELECT * FROM (
		SELECT 
			MOV_CODMAG AS COD_MAGAZZINO,
			COALESCE(PARA_MAG.DESCRI,'') AS DESCR_MAGAZZINO,
			ART_CODMAT AS COD_TIPO_PRODOTTO,
			COALESCE(PARA_MAT.DESCRI,'') AS DESCR_TIPO_PRODOTTO,
			MOV_ANAART AS COD_ARTICOLO,
			ART_UMMAGA AS UM_MAG,
			SUM((CASE MOV_SEGNO WHEN '-' THEN 0 ELSE 1 END) * MOV_QTAMOV) AS QTA_UM_MAG_CARICATA,
			SUM((CASE MOV_SEGNO WHEN '-' THEN 1 ELSE 0 END) * MOV_QTAMOV) AS QTA_UM_MAG_SCARICATA,
			SUM((CASE MOV_SEGNO WHEN '-' THEN -1 ELSE 1 END) * MOV_QTAMOV) AS SALDO_QTAMOV,
			ART_UNIMIS AS UM_ACQ,
			CASE ART_UNIMIS
				WHEN 'KG' THEN SUM((CASE MOV_SEGNO WHEN '-' THEN 0 ELSE 1 END) * MOV_QTAKG) 
				WHEN 'ML' THEN SUM((CASE MOV_SEGNO WHEN '-' THEN 0 ELSE 1 END) * MOV_QTAML) 
				ELSE SUM((CASE MOV_SEGNO WHEN '-' THEN 0 ELSE 1 END) * MOV_QTAMOV)
			END AS QTA_UM_ACQ_CARICATA,
			CASE ART_UNIMIS
				WHEN 'KG' THEN SUM((CASE MOV_SEGNO WHEN '-' THEN 1 ELSE 0 END) * MOV_QTAKG) 
				WHEN 'ML' THEN SUM((CASE MOV_SEGNO WHEN '-' THEN 1 ELSE 0 END) * MOV_QTAML) 
				ELSE SUM((CASE MOV_SEGNO WHEN '-' THEN 1 ELSE 0 END) * MOV_QTAMOV)
			END AS QTA_UM_ACQ_SCARICATA,
			CASE ART_UNIMIS
				WHEN 'KG' THEN SUM((CASE MOV_SEGNO WHEN '-' THEN -1 ELSE 1 END) * MOV_QTAKG) 
				WHEN 'ML' THEN SUM((CASE MOV_SEGNO WHEN '-' THEN -1 ELSE 1 END) * MOV_QTAML) 
				ELSE SUM((CASE MOV_SEGNO WHEN '-' THEN -1 ELSE 1 END) * MOV_QTAMOV)
			END AS SALDO_QTA_UM_ACQ
--			CASE ART_UNIMIS
--				WHEN 'KG' THEN SUM((CASE MOV_SEGNO WHEN '-' THEN -1 ELSE 1 END) * MOV_QTAKG * MOV_PREACQ)
--				ELSE SUM((CASE MOV_SEGNO WHEN '-' THEN -1 ELSE 1 END) * MOV_QTAMOV * MOV_PREACQ)
--			END AS SALDO_VALORE	
		FROM ( 
		
			SELECT 
				MOV_DTREGI,
				MOV_CODMAG,
				MOV_ANAART,
				MOV_CODART,
				MOV_SEGNO,
				CASE
					WHEN ART.ART_UNIMIS = 'KG' AND (ART.ART_CODCAT = 'BO' OR SUBSTRING(MAT.LIBERA,1,1) = '1')
						THEN COALESCE(MO1.MOV_QTAMOV,MO.MOV_QTAMOV)
					ELSE MO.MOV_QTAMOV
				END AS MOV_QTAMOV,
				CASE
					WHEN ART.ART_UNIMIS = 'KG' AND ART.ART_UNIMIS = ART.ART_UMMAGA
						THEN MO.MOV_QTAMOV
					WHEN ART.ART_UNIMIS = 'KG' AND (ART.ART_CODCAT = 'BO' OR SUBSTRING(MAT.LIBERA,1,1) = '1')
						THEN COALESCE(MO1.MOV_QTAKG,MO.MOV_QTAKG)
					ELSE MO.MOV_QTAKG
				END AS MOV_QTAKG,
				MOV_QTAML,
				CASE
					WHEN ART.ART_UNIMIS = 'KG' AND (ART.ART_CODCAT = 'BO' OR SUBSTRING(MAT.LIBERA,1,1) = '1')
					THEN COALESCE(MO1.MOV_PREACQ,MO.MOV_PREACQ)
					ELSE MO.MOV_PREACQ
				END AS MOV_PREACQ
			FROM U_MAG_MO AS MO
			LEFT OUTER JOIN U_ART_PR AS ART ON ART.ART_CODPRI = MOV_ANAART
			LEFT OUTER JOIN PARA AS MAT ON MAT.CODICE = ART.ART_CODMAT
			OUTER APPLY (SELECT TOP 1 MOV_PREACQ,MOV_QTAMOV,MOV_QTAKG FROM U_MAG_MO AS TMP_MO 
							WHERE TMP_MO.MOV_SEGNO = '+' AND TMP_MO.MOV_CODMAG = MO.MOV_CODMAG AND TMP_MO.MOV_LEGAME = MO.MOV_LEGAME AND MO.MOV_ANAART = TMP_MO.MOV_ANAART ORDER BY mov_dtregi,mov_oramov) AS MO1
			WHERE 
				MO.MOV_QTAMOV > 0 AND 
				<<x_cond>>
			
			) AS U_MAG_MO
		LEFT OUTER JOIN U_ART_PR ON MOV_ANAART = ART_CODPRI
		LEFT OUTER JOIN PARA AS PARA_MAT ON 'MAT'+U_ART_PR.ART_CODMAT = PARA_MAT.CODICE
		LEFT OUTER JOIN PARA AS PARA_MAG ON 'MAG'+U_MAG_MO.MOV_CODMAG = PARA_MAG.CODICE
		GROUP BY 
			MOV_CODMAG,
			COALESCE(PARA_MAG.DESCRI,''),
			ART_CODMAT,
			COALESCE(PARA_MAT.DESCRI,''),
			MOV_ANAART,
			ART_UNIMIS,
			ART_UMMAGA
		) AS MAIN
	WHERE SALDO_QTAMOV <> 0
	ORDER BY 
		COD_MAGAZZINO,
		COD_TIPO_PRODOTTO,
		COD_ARTICOLO
		
ENDTEXT
_CLIPTEXT=CSQL
IF !ExecPreparedCommand(cSql,cNomeCursorSql,.T.)
	return(.F.)
ENDIF
*** SE L'UTENTE HA ANNULLATO LA QUERY IL CURSORE POTREBBE NON ESISTERE, 
*** QUINDI NON PERMETTO DI ANDARE AVANTI
IF !USED("SALDO_MOVIMENTI")
	RETURN .F.
ENDIF

SELECT SALDO_MOVIMENTI
GO TOP
IF EOF()
	MESSAGEBOX("Nessun dato da estrarre per i filtri selezionati",64,"Informazione")
ELSE
	_TITOLO_EXCEL1 = "Estrazione saldo movimenti di magazzino alla data"
	_TITOLO_EXCEL2 = "Periodo di riferimento dal " + _V_DATADA + " al " + _V_DATAAL
	_TITOLO_EXCEL3 = ""
	_TOTALI_GENERALI = .T.
	DO ESTRXLS WITH "SALDO_MOVIMENTI",_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,_TOTALI_GENERALI
	
	MESSAGEBOX("Fine elaborazione",64,"Informazione")
ENDIF

