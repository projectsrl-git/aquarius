*** PER LE PROCEDURE EXTRACONTABILI EFFETTI-ATTIVI
*** SE HO FATTO SPLIT DI UNA PARTITA CORRISPONDENTE AD UN DOC-EXTRACONTABILE 
*** DEVO SUDDIVIDERE ANCHE IL DETTAGLIO DELLO STESSO DOC SUL CORRISPONDENTE ARCHIVIO



LOCAL	_SALVA_RECORD_CORRENTE_PAGAMENTI,;
		_SALVA_ORDER_CORRENTE_PAGAMENTI ,;
		_SALVA_RECORD_CORRENTE_PAGATI,;
		_SALVA_ORDER_CORRENTE_PAGATI ,;		
		_SALVA_RECORD_CORRENTE_MOVIMENTI,;
		_SALVA_ORDER_CORRENTE_MOVIMENTI,;  
		_NUOVO_ID_PARTITA,;
		_IMPORTO_NUOVO,;
		_STATUS		  ,;
		_SYSDOC		  ,;
		_ID_PARTITA	  ,;
		_CONTA_FIGLI


SELECT PAGAMENTI
gnFieldcount = AFIELDS(gaMyArray)  && Create array

*** PARTITE DI EXTRACOTABILI SPLITTATE DA PAGARE O NO
CREATE CURSOR EXTRASPLIT FROM ARRAY gaMyArray

_CONTA_FIGLI=0

*###################################  GESTIONE FIGLI DI SPLIT ####################################ŕ

*** CARICO TUTTI I FIGLI DI DOC-EXTRACONTABILI SPLITTATI
SELECT PAGAMENTI
GO TOP
DO WHILE !EOF()

	IF EMPTY(LEGA_SPLIT) && IDENTIFICA CHE SI TRATTA DI UN FIGLIO
		SELECT PAGAMENTI
		SKIP
		LOOP
	ENDIF

	*** SPLIT EFFETTI ATTIVI
   	IF TIPOLOGIA="EFF.ATT." 
   		SCATTER MEMVAR
   		SELECT EXTRASPLIT 
   		APPEND BLANK
   		GATHER MEMVAR
  		
   		_CONTA_FIGLI=_CONTA_FIGLI+1
   	ENDIF	
	

	SELECT PAGAMENTI
	SKIP
ENDDO


SELECT PAGATI
GO TOP
DO WHILE !EOF()

	IF EMPTY(LEGA_SPLIT) && IDENTIFICA CHE SI TRATTA DI UN FIGLIO
		SELECT PAGATI
		SKIP
		LOOP
	ENDIF

	*** SPLIT EFFETTI ATTIVI
   	IF TIPOLOGIA="EFF.ATT." 
   		SCATTER MEMVAR
   		SELECT EXTRASPLIT 
   		APPEND BLANK
   		GATHER MEMVAR
  		
   		_CONTA_FIGLI=_CONTA_FIGLI+1
   	ENDIF	
   	
	SELECT PAGATI
	SKIP
ENDDO

*** SE NON CI SONO FIGLI --> NON CI SONO SPLIT
IF _CONTA_FIGLI=0
	RETURN
ENDIF

*** EXTRASPLIT ORA CONTIENE SOLO I FIGLI

*###################################  GESTIONE PADRI DI SPLIT ####################################ŕ

	
*** CARICO TUTTI I PADRI SPLITTATI	
*** PADRI_SPLIT CONTIENE SOLO ID_PARTITA E TIPOLOGIA DI TUTTI I PADRI CHE STO CONSIDERANDO
SELECT 	LEGA_SPLIT AS ID_PARTITA,;
		TIPOLOGIA ;
  FROM EXTRASPLIT ;
  GROUP BY 	LEGA_SPLIT ,;
  			TIPOLOGIA ;
  INTO CURSOR PADRI_SPLIT

SELECT PADRI_SPLIT
GO TOP
DO WHILE !EOF()
		
	_ID_PARTITA=ID_PARTITA 		
	
	*** CERCO SUI PAGATI LA PARTITA LEGATA A QUESTO DETTAGLIO
	*** E GLI CAMBIO ID_PARTITA PER RIAGGANCIARLO CON QUESTO ID_UNIQUE
	
	SELECT PAGATI
	_SALVA_RECORD_CORRENTE_PAGATI=RECCOUNT()
	_SALVA_ORDER_CORRENTE_PAGATI =ORDER()		
	
	SET ORDER TO ID_PARTITA 
	SEEK _ID_PARTITA
	IF FOUND()
		SCATTER MEMVAR
		SELECT EXTRASPLIT 
   		APPEND BLANK
   		GATHER MEMVAR
	ELSE
		*** CERCO SUI PAGAMENTI  LA PARTITA LEGATA A QUESTO DETTAGLIO
		*** E GLI CAMBIO ID_PARTITA PER RIAGGANCIARLO CON QUESTO ID_UNIQUE
		
		SELECT PAGAMENTI  
		_SALVA_RECORD_CORRENTE_PAGAMENTI=RECCOUNT()
		_SALVA_ORDER_CORRENTE_PAGAMENTI =ORDER()		
		
		SET ORDER TO ID_PARTITA 
		SEEK _ID_PARTITA
		IF FOUND()
			SCATTER MEMVAR
			SELECT EXTRASPLIT 
	   		APPEND BLANK
	   		GATHER MEMVAR
		ENDIF
		
		SELECT PAGAMENTI 
		GO _SALVA_RECORD_CORRENTE_PAGAMENTI
		SET ORDER TO &_SALVA_ORDER_CORRENTE_PAGAMENTI 
	ENDIF
	
	SELECT PAGATI
	GO _SALVA_RECORD_CORRENTE_PAGATI
	SET ORDER TO &_SALVA_ORDER_CORRENTE_PAGATI 
	
   	
	SELECT PADRI_SPLIT
	SKIP
ENDDO


*** EXTRASPLIT ORA CONTIENE ANCHE I PADRI OLTRE AI FIGLI

*###################################################  DUPLICAZIONE DETTAGLI ##############################
*
*** MACRO CICLO PER CONSIDERARE TUTTI GLI SPLIT CHE HO FATTO 
*** ALL'INTERNO SI ESAMINANO I SINGOLI CASI E SI DUPLICANO I DETTAGLI DEI DOC-EXTRACONTABILI CORRISPONDENTI
*

*** PADRI_SPLIT CONTIENE SOLO ID_PARTITA E TIPOLOGIA DI TUTTI I PADRI CHE STO CONSIDERANDO
SELECT PADRI_SPLIT

GO TOP


DO WHILE !EOF()

	*** SPLIT EFFETTI ATTIVI
   	IF 	TIPOLOGIA!="EFF.ATT." 
  		
   		SELECT PADRI_SPLIT
   		SKIP 
   		LOOP
   	ENDIF	
	
	
	*** IMPOSTO LA CHIAVE DI RICERCA PER I DETTAGLI DEL DOC-EXTRACONTABILE
	_ID_UNIQUE=ID_PARTITA
	
	*** CARICO UN CURSOR CON I DETTAGLI DEL DOC-EXTRACONTABILE
	cSql=""     
	cNomeCursorSql="_XXX_U_ASC_DD"
	
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
		SELECT * FROM U_ASC_DD 
		WHERE ID_UNIQUE ='<<_ID_UNIQUE>>'
		
	ENDTEXT					&& FINE SCRITTURA QUERY
	
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF	
	
	SELECT _XXX_U_ASC_DD
	GO TOP
	IF EOF()
		***		NON HO TROVATO NESSUN DOC-EXTRACONTABILE CON QUELLA CHIAVE
		SELECT PADRI
		SKIP
		LOOP
	ENDIF
	
	SELECT _XXX_U_ASC_DD
	SCATTER MEMVAR
	_IMPORTO_ORGINALE=M.ASS_IMPTOD
	
	
	*** CANCELLO IL VECCHIO DETTAGLIO
	cSql=""     
	cNomeCursorSql="_XXX_U_ASC_DD"
	
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
		DELETE FROM U_ASC_DD 
		WHERE ID_UNIQUE ='<<_ID_UNIQUE>>'
		
	ENDTEXT					&& FINE SCRITTURA QUERY
	
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF	
	

	*** ESAMINO OGNI SINGOLO CASO DI SPLIT
	*** CON TUTTI IL SUO PADRE E I SUOI FIGLI
	
	SELECT EXTRASPLIT 
	GO TOP
	
	DO WHILE !EOF()
	
		*** SCARTA TUTTI I PADRI DIVERSI DA QUELLO CHE STO CONSIDERANDO
		*** E TUTTI I FIGLI CHE NON SONO DI QUESTO PADRE _ID_UNIQUE
		IF (ID_PARTITA<>_ID_UNIQUE) AND (LEGA_SPLIT<>_ID_UNIQUE) 
			SELECT EXTRASPLIT 
			SKIP 
			LOOP
		ENDIF
	
		_IMPORTO_NUOVO	=ABS(NSALDO)	&& DEVO USARLO PER AGGIORNARE L'ASSEGNO E UN ASSEGNO NON PUO' ESSERE NEGATIVO
		_SYSDOC			=SYS(2015)
		_ID_PARTITA		=ID_PARTITA		&& LO SALVO PERCHE' POI DEVO ANDARE SU PAGATI/PAGAMENTI E CAMBIARLO

		*** CREO NUOVI IMPORTI
		M.ASS_IMPTOD=_IMPORTO_NUOVO
		
		*** IMPOSTO INCASSATO O EMESSO
		*M.ASS_STATUS=_STATUS
		M.ASS_STATUS="Emesso"
		
		M.ASS_SYSDOC=_SYSDOC
		
		cSql="select * from U_ASC_DD where 1=0"
		IF !ExecRW(cSql,"U_ASC_DD","R")
	   		return(.f.)
		ENDIF

		APPEND BLANK
				
		RELEASE M.ID_UNIQUE

		GATHER MEMVAR
		IF !ExecRW(cSql,"U_ASC_DD","W")
		   return(.f.)
		ENDIF		
		
		
		*** CERCO ID_UNIQUE DEL DETTAGLIO CHE HO APPENA INSERITO
		*** ACCEDO PER _SYSDOC
		cSql=""     
		cNomeCursorSql="_XXX_U_ASC_DD"
		
		TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
		
			SELECT * FROM U_ASC_DD 
			WHERE ASS_SYSDOC ='<<_SYSDOC>>'
			
		ENDTEXT					&& FINE SCRITTURA QUERY
		
		IF !ExecPreparedCommand(cSql,cNomeCursorSql)
			return(.F.)
		ENDIF			
		
		SELECT _XXX_U_ASC_DD
		GO TOP
		IF EOF()
			***		NON HO TROVATO NESSUN DOC-EXTRACONTABILE CON QUELLA CHIAVE
			SELECT EXTRASPLIT 
			SKIP
			LOOP
		ENDIF
		
		_NUOVO_ID_PARTITA=ID_UNIQUE
		

		*** CERCO SUI MOVIMENTI  LA PARTITA LEGATA A QUESTO DETTAGLIO
		*** E GLI CAMBIO ID_MOVIMEN PER RIAGGANCIARLO CON QUESTO ID_UNIQUE
		***
		*** QUESTO SERVE PER LA SUCCESSIVA CONTABILIZZAZIONE
		
		SELECT MOVIMENTI  
		_SALVA_RECORD_CORRENTE_MOVIMENTI  =RECCOUNT()
		_SALVA_ORDER_CORRENTE_MOVIMENTI   =ORDER()		
		
		SET ORDER TO ID_MOVIMEN 
		SEEK _ID_PARTITA
		IF FOUND()
			REPLACE ID_MOVIMEN  WITH _NUOVO_ID_PARTITA
		ENDIF
		
		GO _SALVA_RECORD_CORRENTE_MOVIMENTI  
		SET ORDER TO &_SALVA_ORDER_CORRENTE_MOVIMENTI  


		*** CERCO SUI PAGATI LA PARTITA LEGATA A QUESTO DETTAGLIO
		*** E GLI CAMBIO ID_PARTITA PER RIAGGANCIARLO CON QUESTO ID_UNIQUE
		***
		*** QUESTO SERVE PER EVENTUALI ANNULLI DI MOVIMENTI O NUOVI MOVIMENTI
		
		SELECT PAGATI
		_SALVA_RECORD_CORRENTE_PAGATI=RECCOUNT()
		_SALVA_ORDER_CORRENTE_PAGATI =ORDER()		
		
		SET ORDER TO ID_PARTITA 
		SEEK _ID_PARTITA
		IF FOUND()
			REPLACE ID_PARTITA WITH _NUOVO_ID_PARTITA
		ELSE
			*** PROBABILMENTE E' SU QUELLI ANCORA DA PAGARE			
			
			*** CERCO SUI PAGAMENTI  LA PARTITA LEGATA A QUESTO DETTAGLIO
			*** E GLI CAMBIO ID_PARTITA PER RIAGGANCIARLO CON QUESTO ID_UNIQUE
			***
			*** QUESTO SERVE PER EVENTUALI ANNULLI DI MOVIMENTI O NUOVI MOVIMENTI
			
			SELECT PAGAMENTI  
			_SALVA_RECORD_CORRENTE_PAGAMENTI=RECCOUNT()
			_SALVA_ORDER_CORRENTE_PAGAMENTI =ORDER()		
			
			SET ORDER TO ID_PARTITA 
			SEEK _ID_PARTITA
			IF FOUND()
				REPLACE ID_PARTITA WITH _NUOVO_ID_PARTITA
			ENDIF
			
			GO _SALVA_RECORD_CORRENTE_PAGAMENTI
			SET ORDER TO &_SALVA_ORDER_CORRENTE_PAGAMENTI 
			
		ENDIF
		
		SELECT PAGATI
		GO _SALVA_RECORD_CORRENTE_PAGATI
		SET ORDER TO &_SALVA_ORDER_CORRENTE_PAGATI 
		
		SELECT EXTRASPLIT 
		SKIP
		
	ENDDO
	
	SELECT PADRI_SPLIT
	SKIP 
ENDDO
	