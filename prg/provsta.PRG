*************************************************************************************
*							STAMPA PROVVIGIONI AGENTI								*
*************************************************************************************

_DATARIF = RIBALTA2(_DATARIF)
_DATARBM = RIBALTA2(_DATARBM)
_DATAEFF = RIBALTA2(_DATAEFF)
DATADAL  = RIBALTA2(DATADAL)
DATAAL   = RIBALTA2(DATAAL)
NEW_PAG  = 55
NPG      = 0

**-->  INIZIO CURSORI COMUNI 

CREATE CURSOR XSTAMPA(_XAGEX_ C (03),RIGA C (190))

CREATE CURSOR TOTALI(;
  CHIAVE     C (10),;
  T_IMPINC   N (15,2),;
  T_IMPMAT   N (15,2),;
  P_PROINC   N (15,2),;
  P_PROMAT   N (15,2),;
  P_PROINCN  N (15,2),;
  P_PROMATN  N (15,2),;
  T_PROINC   N (15,2),;
  T_PROMAT   N (15,2))
INDEX ON CHIAVE TAG TOTALI

**-->  FINE CURSORI COMUNI 

IF BALL_LISTA=1 							&& STAMPA LISTA DI CONTROLLO
   DO PROLISTA
   _DATARIF = RIBALTA2(_DATARIF)
   _DATARBM = RIBALTA2(_DATARBM)
   _DATAEFF = RIBALTA2(_DATAEFF)
   DATADAL  = RIBALTA2(DATADAL)
   DATAAL   = RIBALTA2(DATAAL)
   SELECT TOTALI
   ZAP
   RETURN
ENDIF
 
 


_DATARIF = RIBALTA2(_DATARIF)
_DATARBM = RIBALTA2(_DATARBM)
_DATAEFF = RIBALTA2(_DATAEFF)
DATADAL  = RIBALTA2(DATADAL)
DATAAL   = RIBALTA2(DATAAL)

SELECT TOTALI
ZAP

=MESSAGEBOX("Fine elaborazione ",62,"ATTENZIONE")
    
RETURN





***************************
PROCEDURE PROLISTA                    && LISTA DI CONTROLLO
***************************
**** STAMPO PER AGENTE
**** LE PROVVIGIONI MATURATE & INCASSATE
**** RIFERITE AL CLIENTE+FATTURA+ARTICOLO  CON % PROVVIGIONI + PREZZI / QTA

CREATE CURSOR CLIENTE(;
  ORD_CODSOC C (2),;
  ORD_AGE    C (3),;
  ORD_DESAGE C (40),;
  ORD_CODCLI C (10),;
  ORD_RAGSOC C (40),;
  ORD_NUMORD C (06),;
  ORD_DATORD C (10),;
  ORD_CODART C (16),;
  ORD_DESCR  C (30),;
  ORD_QTAORD N (15,2),;
  ORD_PRZNET N (15,2),;
  ORD_VALORE N (15,2),;
  ORD_PRORIG N (6,2),;
  ORD_PRZOK  N (15,2),;
  ORD_VALOK  N (15,2),;
  ORD_NEGA   N (15,2),;
  ORD_PROINC N (15,2),;
  ORD_INCANE N (15,2),;
  ORD_PROTOT N (15,2))

INDEX ON ORD_CODSOC+STR(VAL(ORD_AGE),2,0) + ALLTRIM(ORD_CODCLI)+ORD_NUMORD+ORD_CODART TAG CLIENTE
INDEX ON ORD_CODSOC+ORD_AGE+ORD_RAGSOC+ORD_NUMORD+ORD_CODART TAG RAGSOC
INDEX ON ORD_CODSOC+STR(VAL(ORD_AGE),2,0) + ORD_DATORD + ORD_NUMORD TAG NUMFAT

CTRELAB=0



** ##################################################################################### ** 
** CARICA LE FATTURE DEL MESE DIGITATO MA ANCHE LE FATTURE STORICHE DEI MESI             **
** PRECEDENTI , PARCHEGGIATE IN PROVVI DICHIARATE PAGATE DAL CALCOLO PROVVIGIONALE       **
** ##################################################################################### **


x_dt1   = DATADAL
x_dt2   = DATAAL
x_data  = "ord_datord between '" + x_dt1 + "' and '" + x_dt2 + "' or ord_princa <> 0"
cSql    = "SELECT * FROM provvi WHERE " + x_data + " order by ord_datord"
IF !ExecCommand(cSql,"PROVVI")
   return(.f.)
ENDIF
SELECT PROVVI
GO TOP


DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
  

   IF !EMPTY(_AGEAL)        && DAL AL            
	  IF VAL(ORD_AGE) => VAL(_AGEDEP)
	 	 IF VAL(ORD_AGE) <= VAL(_AGEAL)
		 ELSE
		    SKIP +1
		    LOOP
		 ENDIF 
	  ELSE
	     SKIP +1
	     LOOP
	  ENDIF
   ELSE
	  IF !EMPTY(_AGEDEP)   && SOLO AGENTE DIGITATO
		 IF ALLTRIM(ORD_AGE)==ALLTRIM(_AGEDEP)
		 ELSE
		    SKIP +1
		    LOOP
		 ENDIF
	  ENDIF
   ENDIF
  
   SELECT PROVVI  

   V_CODART = ORD_CODART
  
   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(V_CODART) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   __DESCR = ART_DESCR


   SELECT PROVVI  
  
   V_CODCLI = ORD_CODCLI
  
   **  DATA DI VALIDITA' CLIENTE
   x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "cli_codcli = '" + ALLTRIM(V_CODCLI) + "'"
   x_cond = x_soci + " and " + x_codi   
   cSql = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
   IF !ExecCommand(cSql,"CUR_CLIENTE")
      RETURN .F.
   ENDIF
   SELECT CUR_CLIENTE
   GO TOP   
   IF EOF()
      V_CLDTOK = SPACE(10)
   ELSE
      V_CLDTOK = CLI_DTCLOK
   ENDIF

   IF !EMPTY(V_CLDTOK)     && SE CLIENTE A LEGALE NON TRATTA PIU' MOVIMENTI DI FATTURA
      SELECT PROVVI
      SKIP +1
      LOOP
   ENDIF
  
   SELECT PROVVI
   SCATTER MEMVAR
   
   M.ORD_DESAGE=GETDAGE()
  
   IF M.ORD_PROVVI<0     && CASO NOTA DI CREDITO DEVO RENDERE NEGATIVO L'IMPORTO
      M.ORD_VALORE=M.ORD_VALORE*(-1)
   ENDIF  

   SELECT CLIENTE
   SET ORDER TO CLIENTE
   APPEND BLANK 
   GATHER MEMVAR
   REPLACE ORD_PROINC   WITH M.ORD_PRINCA
   REPLACE ORD_AGE      WITH STR(VAL(ORD_AGE),2,0) 
   REPLACE ORD_DESCR    WITH __DESCR


   DO TOT03 WITH STR(VAL(ORD_AGE),2,0)
      
   CTRELAB=CTRELAB+1
   
   WAIT WINDOW "Dettagli Elaborati"+STR(CTRELAB,8,0) NOWAIT
  
   SELECT PROVVI 
   SKIP +1

ENDDO

RELEASE WINDOW DISPLAY

SELECT CLIENTE
GO TOP

RIT=MESSAGEBOX("SI = ordino per codice cliente"+CHR(13)+"NO = ordino per numero e data fattura",292,"SCELTA ORDINAMENTO DATI")
IF RIT=6
   SET ORDER TO CLIENTE
ELSE
   SET ORDER TO NUMFAT
ENDIF  
    
TOT=0
TOT_INCA=0

AGE_OLD = ORD_AGE
_DESCRI = GETDAGEX()

VRIGA=7

PRIMA_TT = .T.
SELECT CLIENTE
GO TOP


DO WHILE !EOF()
   IF PRIMA_TT 
      PRIMA_TT = .F.
	  SELECT XSTAMPA
	  SCRITTA="PROVVIGIONI MATURATE E INCASSATE PER CLIENTE PER AGENTE :"+_DESCRI
	  DO PROSTTS WITH SCRITTA,13
      SELECT CLIENTE
   ENDIF  
   
   
   SCATTER MEMVAR


   IF M.ORD_PROTOT  = 0 .AND. M.ORD_PROINC = 0
      SKIP +1
      LOOP
   ENDIF

   IF AGE_OLD <> ORD_AGE
      SELECT XSTAMPA
	  APPEND BLANK
*!*		  REPLACE RIGA WITH SPACE(49)+"TOTALE :  "+TRAN(TOT,"9,999,999.99")+"   "+TRAN(TOT_INCA,"9,999,999.99")
	  IF _ok_spooler
		   REPLACE _XAGEX_  WITH SPACE(03)
	  ELSE
		   REPLACE _XAGEX_  WITH AGE_OLD   
	  ENDIF
	  REPLACE RIGA WITH SPACE(117)+"TOTALE : "+TRAN(TOT,"9,999,999.99")+" "+TRAN(TOT_INCA,"9,999,999.99")

	  APPEND BLANK
	  IF _ok_spooler
		   REPLACE _XAGEX_  WITH SPACE(03)
	  ELSE
		   REPLACE _XAGEX_  WITH AGE_OLD   
	  ENDIF
	  REPLACE RIGA WITH ""

	  DO TOTMATINC WITH STR(VAL(AGE_OLD),2,0),"RIASSUNTIVO MAT. & INC. PER CLIENTE , AGENTE :"+_DESCRI
      SELECT CLIENTE
      AGE_OLD = ORD_AGE  
	  _DESCRI = GETDAGEX()
	  SCRITTA="PROVVIGIONI MATURATE E INCASSATE PER CLIENTE PER AGENTE :"+_DESCRI
      SELECT CLIENTE
      DO PROSTTS WITH SCRITTA,13
      TOT=0
      TOT_INCA=0
      SELECT CLIENTE
 
   ENDIF
   IF M.ORD_INCANE <> 0
      XNEGA=M.ORD_INCANE   && INCASSO NEGATIVO
   ELSE  
      XNEGA=M.ORD_NEGA     && MATURATO NEGATIVO
   ENDIF  
   
   SELECT XSTAMPA
   APPEND BLANK
   IF _ok_spooler
	   REPLACE _XAGEX_  WITH SPACE(03)
   ELSE
	   REPLACE _XAGEX_  WITH AGE_OLD   
   ENDIF
   
   IF M.ORD_PRORIG = 0
	  REPLACE RIGA WITH SUBSTR(M.ORD_NUMORD,1,6)+" "+RIBALTA2(M.ORD_DATORD)+" "+SUBSTR(M.ORD_CODCLI,1,7)+" "+SUBSTR(M.ORD_RAGSOC,1,15)+" "+SUBSTR(M.ORD_CODART,1,12)+" "+SUBSTR(M.ORD_DESCR,1,13)+" "+TRANSFORM(M.ORD_QTAORD,"9999.99")+" "+TRAN(M.ORD_PRZNET,"999,999.99")+TRAN(M.ORD_VALORE,"99,999,999.99")+TRAN(M.ORD_PRZOK,"999,999.99")+"NO.LIS"+" "+TRAN(XNEGA,"999,999.99")+""+TRAN(M.ORD_PROTOT,"9999,999.99")+"   "+TRAN(M.ORD_PROINC,"999,999.99")
   ELSE
	  REPLACE RIGA WITH SUBSTR(M.ORD_NUMORD,1,6)+" "+RIBALTA2(M.ORD_DATORD)+" "+SUBSTR(M.ORD_CODCLI,1,7)+" "+SUBSTR(M.ORD_RAGSOC,1,15)+" "+SUBSTR(M.ORD_CODART,1,12)+" "+SUBSTR(M.ORD_DESCR,1,13)+" "+TRANSFORM(M.ORD_QTAORD,"9999.99")+" "+TRAN(M.ORD_PRZNET,"999,999.99")+TRAN(M.ORD_VALORE,"99,999,999.99")+TRAN(M.ORD_PRZOK,"999,999.99")+TRANSFORM(M.ORD_PRORIG,"999.99")+" "+TRAN(XNEGA,"999,999.99")+""+TRAN(M.ORD_PROTOT,"9999,999.99")+"   "+TRAN(M.ORD_PROINC,"999,999.99")
   ENDIF
   TOT=TOT+M.ORD_PROTOT
   TOT_INCA=TOT_INCA+M.ORD_PROINC
   VRIGA=VRIGA+1
   IF VRIGA>=NEW_PAG
      VRIGA=7
      APPEND BLANK
      REPLACE RIGA WITH ""
      SELECT CLIENTE
      DO PROSTTS WITH SCRITTA,13
   ENDIF  
   SELECT CLIENTE
   SKIP +1
ENDDO

SELECT XSTAMPA
APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH SPACE(117)+"TOTALE : "+TRAN(TOT,"9,999,999.99")+" "+TRAN(TOT_INCA,"9,999,999.99")

APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH ""

DO TOTMATINC WITH STR(VAL(AGE_OLD),2,0),"RIASSUNTIVO MAT. & INC. PER CLIENTE/FATTURA, AGENTE :"+_DESCRI


IF _ok_spooler
	DO CREA_SPOOL WITH "XSTAMPA","MAT & INC.LISTA CONTR.AG:"+AGE_OLD
    =MESSAGEBOX("Fine elaborazione. Procedi con la stampa tramite lo spooler",62,"ATTENZIONE")
ELSE

	SELECT XSTAMPA
	GO TOP
	IF EOF()
	   =MESSAGEBOX("Nessun dato da stampare",62,"ATTENZIONE")
	ELSE
	   _V_PREVIEW = .T.
	   _V_STAMPA  = .T.
	   DO PRG\MENUSTA WITH "XSTAMPA",_V_PREVIEW,_V_STAMPA,"XXX","STPROVVI","STPROVVI.FRX"
	ENDIF
    =MESSAGEBOX("Stampa provvigioni agente terminata correttamente",62,"ATTENZIONE")
ENDIF

RETURN


**********************
PROCEDURE PROSTTS
**********************
PARA ST_TITOLO,INT_SCELTA

SEL=STR(SELECT())

DO CASE 
  CASE INT_SCELTA=1
    M.RIGA5="*CLIENTE     * DESCRIZIONE                              * PROV MATURATA *"
  CASE INT_SCELTA=2
    M.RIGA5="*CLIENTE     * DESCRIZIONE                              * PROV INCASSATA*"
  CASE INT_SCELTA=3
    M.RIGA5="*CLIENTE     * DESCRIZIONE                              * PROV MATURATA  * PROV INCASSATA *"   
  CASE INT_SCELTA=4
    M.RIGA5="*CLIENTE     * DESCRIZIONE                              * NUMERO * DATA FATT. * PROV MATURATA *"
  CASE INT_SCELTA=5
    M.RIGA5="*CLIENTE     * DESCRIZIONE                              * NUMERO * DATA FATT. * PROV INCASSATA*"
  CASE INT_SCELTA=6
    M.RIGA5="*CLIENTE     * DESCRIZIONE                    * NUMERO * DATA FATT. * PROV MATURATA * PROV INCASSATA*"
  CASE INT_SCELTA=7
    M.RIGA5="*CLIENTE     * DESCRIZIONE                              * NUMERO * DATA FATT. * ARTICOLO         * PROV MATURATA *"
  CASE INT_SCELTA=8
    M.RIGA5="*CLIENTE     * DESCRIZIONE                              * NUMERO * DATA FATT. * ARTICOLO         * PROV INCASSATA*"
  CASE INT_SCELTA=9
    M.RIGA5="*CLIENTE     * DESCRIZIONE                              * NUMERO * DATA FATT. * ARTICOLO         * PROV MATURATA * PROV INCASSATA*"
  CASE INT_SCELTA=10
    M.RIGA5="* ARTICOLO         * DESCRIZIONE                              * PROV MATURATA *"
  CASE INT_SCELTA=11
    M.RIGA5="* ARTICOLO         * DESCRIZIONE                              * PROV INCASSATA*"
  CASE INT_SCELTA=12
    M.RIGA5="* ARTICOLO         * DESCRIZIONE                              * PROV MATURATA * PROV INCASSATA*"
  CASE INT_SCELTA=13
    M.RIGA5="Fat.   Data Fat. Cod.Cli. Cliente         Articolo     Descrizione     Qta   Pre-Unitario   Importo    Listino  P.%     Imp.Add.   Prov.Mat.  Prov.Inc."
 
  OTHERWISE
    M.RIGA5=""  
ENDCASE

M.RIGA4=REPLICATE("*",LEN(ALLTRIM(M.RIGA5)))
M.RIGA6=M.RIGA4

NPG = NPG +1

SELECT XSTAMPA
APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH ""
APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH ""
APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH ""



M.RIGA0=PUB_DESSOC+SPACE(20)+"DATA : "+DTOC(DATE()) + SPACE(25) + "Pagina : "+STR(NPG,6,0)
M.RIGA1=ST_TITOLO
M.RIGA2="PERIODO DI FATTURAZIONE DAL "+RIBALTA2(DATADAL)+" AL "+RIBALTA2(DATAAL)

IF SOLO_DEP && SOLO SE TRATTO DEPOSITO 
	M.RIGA3="AGENTE : "+ORD_AGE+"  -  "+ORD_DESAGE  
ELSE
	M.RIGA3="          "
ENDIF

SELECT XSTAMPA
APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH M.RIGA0

APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH M.RIGA1

APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH M.RIGA2

APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH M.RIGA3

APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH M.RIGA4
APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH M.RIGA5
APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH M.RIGA6
APPEND BLANK
IF _ok_spooler
   REPLACE _XAGEX_  WITH SPACE(03)
ELSE
   REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF

SELECT &SEL

RETURN



******************************
PROCEDURE TITOLO_COMUNE
******************************
PARA TC_TITOLO,TC_PRIMA,TC_DOPO

SELECT XSTAMPA

IF TC_PRIMA
   M.RIGA0=PUB_DESSOC+SPACE(20)+"DATA : "+DTOC(DATE())
   APPEND BLANK
   IF _ok_spooler
     REPLACE _XAGEX_  WITH SPACE(03)
   ELSE
     REPLACE _XAGEX_  WITH AGE_OLD   
   ENDIF

   REPLACE RIGA WITH M.RIGA0
   M.RIGA1="PERIODO DI FATTURAZIONE DAL "+RIBALTA2(DATADAL)+" AL "+RIBALTA2(DATAAL)
   APPEND BLANK
   IF _ok_spooler
     REPLACE _XAGEX_  WITH SPACE(03)
   ELSE
     REPLACE _XAGEX_  WITH AGE_OLD   
   ENDIF

   REPLACE RIGA WITH M.RIGA1
   APPEND BLANK
ENDIF  

M.RIGA2="*************************************************************************"
APPEND BLANK
IF _ok_spooler
  REPLACE _XAGEX_  WITH SPACE(03)
ELSE
  REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF
REPLACE RIGA WITH M.RIGA2

M.RIGA3=REPLICATE(" ",(80-LEN(ALLTRIM(TC_TITOLO)))/2)+ALLTRIM(TC_TITOLO)
APPEND BLANK
IF _ok_spooler
  REPLACE _XAGEX_  WITH SPACE(03)
ELSE
  REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF

REPLACE RIGA WITH M.RIGA3



M.RIGA4="*************************************************************************"
APPEND BLANK
IF _ok_spooler
  REPLACE _XAGEX_  WITH SPACE(03)
ELSE
  REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF

REPLACE RIGA WITH M.RIGA4

IF TC_DOPO
   M.RIGA5="*CLIENTE     * DESCRIZIONE                              *  PROVVIGIONE  *"
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

   REPLACE RIGA WITH M.RIGA5
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

   M.RIGA6="*************************************************************************"
   REPLACE RIGA WITH M.RIGA6
ENDIF

APPEND BLANK
IF _ok_spooler
  REPLACE _XAGEX_  WITH SPACE(03)
ELSE
  REPLACE _XAGEX_  WITH AGE_OLD   
ENDIF

RETURN




***********************
PROCEDURE TOTMATINC
***********************
PARA KEY_SEEK,PRINT_TIT,NO_TEXT

SAVE_SEL=STR(SELECT())

DO TITOLO_COMUNE WITH PRINT_TIT,NO_TEXT

SET EXACT OFF
SELECT TOTALI
SET ORDER TO TOTALI
SEEK KEY_SEEK
IF FOUND()
   SCATTER MEMVAR
   M.T_PROMAT = M.P_PROMAT + M.P_PROMATN  && PROMATN E' NEGATIVO QUINDI TOGLIE
   M.T_PROINC = M.P_PROINC + M.P_PROINCN  && PROINCN E' NEGATIVO QUINDI TOGLIE
   SELECT XSTAMPA
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF
   
   REPLACE RIGA WITH "Totale Imponibile Maturato          "+TRAN(M.T_IMPMAT,"9999,999,999.99")  
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

   REPLACE RIGA WITH "Totale Imponibile Incassato         "+TRAN(M.T_IMPINC,"9999,999,999.99")  
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

   REPLACE RIGA WITH "Parziale Provvigioni Maturate       "+TRAN(M.P_PROMAT,"9999,999,999.99")  
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

   REPLACE RIGA WITH "Parziale Provvigioni Incassate      "+TRAN(M.P_PROINC,"9999,999,999.99")  
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

   REPLACE RIGA WITH "Parziale Provvigioni Maturate Neg.  "+TRAN(M.P_PROMATN,"9999,999,999.99")  
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

   REPLACE RIGA WITH "Parziale Provvigioni Incassate Neg. "+TRAN(M.P_PROINCN,"9999,999,999.99")  
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

   REPLACE RIGA WITH "Totale Provvigioni Maturate         "+TRAN(M.T_PROMAT,"9999,999,999.99")  
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

   REPLACE RIGA WITH "Totale Provvigioni Incassate        "+TRAN(M.T_PROINC,"9999,999,999.99")  
   APPEND BLANK
	IF _ok_spooler
	  REPLACE _XAGEX_  WITH SPACE(03)
	ELSE
	  REPLACE _XAGEX_  WITH AGE_OLD   
	ENDIF

