***************************
PROCEDURE TOT03
***************************
PARA KEY_SEEK

SEL=STR(SELECT())

SET EXACT OFF
SELECT TOTALI
SET ORDER TO TOTALI
SEEK KEY_SEEK
IF !FOUND()
   APPEND BLANK 
   REPLACE CHIAVE     WITH KEY_SEEK
   IF M.ORD_PROTOT<>0
      REPLACE T_IMPMAT   WITH T_IMPMAT+M.ORD_VALORE
   ENDIF
   IF M.ORD_PROTOT>=0
      REPLACE P_PROMAT   WITH M.ORD_PROTOT
   ELSE
      REPLACE P_PROMATN  WITH M.ORD_PROTOT
   ENDIF
   REPLACE T_PROMAT   WITH M.ORD_PROTOT+M.ORD_NEGA
   IF M.ORD_PRINCA<>0    && .DAV
      REPLACE T_IMPINC   WITH M.ORD_VALORE
      REPLACE P_PROINC   WITH M.ORD_PRINCA
      REPLACE P_PROINCN  WITH M.ORD_INCANE
      REPLACE T_PROINC   WITH M.ORD_PRINCA
      IF M.ORD_PRINCA<0    && .DAV
         REPLACE P_PROINCN  WITH M.ORD_PRINCA
      ENDIF  
   ENDIF
ELSE
   REPLACE T_PROMAT   WITH T_PROMAT+M.ORD_PROTOT+M.ORD_NEGA
   IF M.ORD_PROTOT<>0
      REPLACE T_IMPMAT   WITH T_IMPMAT+M.ORD_VALORE
   ENDIF
   IF M.ORD_PROTOT>=0
      REPLACE P_PROMAT   WITH P_PROMAT+M.ORD_PROTOT
   ELSE
      REPLACE P_PROMATN  WITH P_PROMATN+M.ORD_PROTOT
   ENDIF
   IF M.ORD_PRINCA<>0  
      REPLACE T_IMPINC   WITH T_IMPINC  + M.ORD_VALORE
      REPLACE P_PROINC   WITH P_PROINC  + M.ORD_PRINCA
      REPLACE P_PROINCN  WITH P_PROINCN + M.ORD_INCANE
      REPLACE T_PROINC   WITH T_PROINC  + M.ORD_PRINCA
      IF M.ORD_PRINCA<0    && .DAV
         REPLACE P_PROINCN  WITH P_PROINCN + M.ORD_PRINCA
      ENDIF  
   ENDIF
ENDIF  

SELECT &SEL
RETURN


