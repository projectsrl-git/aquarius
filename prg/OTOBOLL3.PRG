


V_EVASIONE = 0
V_EVASPARZ = 0
OK_PROC    = .F.



SELECT CU_ORD_TT
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
  
   AGGA    = TAGGANCIO
   VRAGSOC = ALLTRIM(ORD_RAGEMI)
   VNUMORD = ORD_NUMORD
   VDATORD = ribalta2(ORD_DATORD)
   
   **=> ERASMO - INIZIO 12/03/2013
   _PRIMA_MOD_CODOPE = MOD_CODOPE
   _PRIMA_MOD_NOMOPE = MOD_NOMOPE 
   _PRIMA_MOD_DATREG = MOD_DATREG 
   _PRIMA_MOD_ORAREG = MOD_ORAREG 
   _PRIMA_ORD_LASTUSE = ORD_LASTUSE 
   **=> ERASMO - FINE 12/03/2013
   
   IF USED('CCU_ORD_DD')
      SELECT CCU_ORD_DD
      USE
   ENDIF  
  
   x_cond = "daggancio = '" + ALLTRIM(AGGA) + "'"
   Csql   = "select * from u_ord_dd where " + x_cond + " order by daggancio,ord_sequen"
   IF !ExecRW(cSql,"CCU_ORD_DD","R")
      return(.f.)
   ENDIF 

   SELECT CCU_ORD_DD
   GO TOP

   DO WHILE .T.
    
      IF EOF()
         EXIT
      ENDIF
    
      IF DELETED()
         SKIP +1
         LOOP
      ENDIF
      
      **=> ERASMO - INIZIO 11/01/2012
      IF !EMPTY(ALLTRIM(ORD_CODART)) AND ORD_DESART <> "*** COMMENTO ***"
	      _X_TIPO = CERCATIPO(ORD_CODART)
	      SELECT CCU_ORD_DD
	      REPLACE ORD_TIPO WITH _X_TIPO
      ENDIF
      REPLACE ORD_EVASEL WITH .F.
      **=> ERASMO - FINE 11/01/2012

      IF ((("*** COMMENTO ***" $ ORD_DESART)) .OR. (!ORD_CHIUSO .AND. ORD_QTAORD > ORD_QTAEV))
      ELSE
         SKIP +1
         LOOP
      ENDIF

	  __KEY_AGG = ID_UNIQUE		&& SIMONE - 02/09/2009
         
      

		_ww_codsoc = PUB_CODSOC
		_ww_anaart = ORD_CODART
		_ww_codmag = ORD_MAGA
		_ww_prenot = .T.  && SOLO GIACENZE NON PRENOTATE
		_ww_codint = ""
		_ww_altezz = ORD_ALTEZZ
		_ww_lunghe = ORD_LUNGHE
		_ww_fila_x = ""
		_ww_pian_x = ""
		_ww_ubic_x = ""
		_GIACENZA = AQM_RILEVA_GIACENZE_DISPONIBILI(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x)
		V_GIACE = _GIACENZA


      SELECT CCU_ORD_DD
      REPLACE ORD_QTAORG WITH V_GIACE
      REPLACE ORD_NOTA   WITH ALLTRIM(ORD_NOTE)
      
      REPLACE KEY_AGG 	 WITH __KEY_AGG		&& SIMONE - 02/09/2009
      
      **=> ERASMO - INIZIO 13/01/2012
      REPLACE ORD_QTADEV WITH ORD_QTAPRD1 
      REPLACE ORD_NUMBOD WITH ORD_NPZPRD1 
      REPLACE ORD_QTADEV2 WITH ORD_QTAPRD2 
      REPLACE ORD_NUMBOD2 WITH ORD_NPZPRD2 
      REPLACE ORD_QTADEV3 WITH ORD_QTAPRD3 
      REPLACE ORD_NUMBOD3 WITH ORD_NPZPRD3 
      **=> ERASMO - FINE 13/01/2012
      
      SKIP +1
   ENDDO      
  
   SELECT CCU_ORD_DD
   GO TOP


   _AGGIORNA_ARCHIVIO_ORDINI			= .T.
   _SELEZIONA_ESPOSIZIONE_COLONNE		= 1
   _CURSORE_DA_VISUALIZZARE 			= "CU_ORD_TT"
   _DESCRIZIONE_FORM					= ___DESCRIZIONE_FORM

   _YES_CONTINUA = .F.  && ERASMO - 30/12/2011
   DO FORM FORM\menu_otobolle_dettagli WITH _AGGIORNA_ARCHIVIO_ORDINI,_SELEZIONA_ESPOSIZIONE_COLONNE,_CURSORE_DA_VISUALIZZARE,_DESCRIZIONE_FORM LINKED
   
	**=> ERASMO - INIZIO 12/03/2013
	IF _YES_CONTINUA
		*** SE NEL FRATTEMPO QUALCUNO HA MODIFICATO L'ORDINE DAL GESTIONALE, IMPEDISCO DI ANDARE AVANTI NELL'EVASIONE
		*** PER EVITARE PROBLEMI DI INCONGRUENZA E SOPRATTUTTO PER EVITARE LA DUPLICAZIONE DELLE RIGHE ORDINE,
		*** IN QUANTO IL GESTIONALE MENU_ORD000 RIGENERA AD OGNI AGGIORNAMENTO LA CHIAVE PRIMARIA U_ORD_DD.ID_UNIQUE
		IF USED('TMP_ORD_TT')
			SELECT TMP_ORD_TT
			USE
		ENDIF  
		_DOPO_MOD_CODOPE = ""
		_DOPO_MOD_NOMOPE = "" 
		_DOPO_MOD_DATREG = ""
		_DOPO_MOD_ORAREG = ""
		_DOPO_ORD_LASTUSE = ""
		x_cond = "taggancio = '" + ALLTRIM(AGGA) + "'"
		Csql	= "select MOD_CODOPE, MOD_NOMOPE, MOD_DATREG, MOD_ORAREG, ORD_LASTUSE from u_ord_tt where " + x_cond
		IF !ExecCommand(cSql,"TMP_ORD_TT")
			return(.f.)
		ENDIF
		SELECT TMP_ORD_TT
		GO TOP
		IF !EOF()
			_DOPO_MOD_CODOPE = MOD_CODOPE
			_DOPO_MOD_NOMOPE = MOD_NOMOPE 
			_DOPO_MOD_DATREG = MOD_DATREG 
			_DOPO_MOD_ORAREG = MOD_ORAREG 
			_DOPO_ORD_LASTUSE = ORD_LASTUSE 
		ENDIF
		
		DO CASE
			CASE ALLTRIM(_PRIMA_MOD_CODOPE) <> ALLTRIM(_DOPO_MOD_CODOPE) OR ALLTRIM(_PRIMA_MOD_DATREG) <> ALLTRIM(_DOPO_MOD_DATREG) OR ;
				ALLTRIM(_PRIMA_MOD_ORAREG) <> ALLTRIM(_DOPO_MOD_ORAREG)
				_YES_CONTINUA = .F.
				XDESCRI = CHR(10) + "EVASIONE NON POSSIBILE:" + CHR(10) + CHR(10) + ;
				 "Ordine " + ALLTRIM(VNUMORD) + " modificato nel frattempo dall'utente " + CHR(10) + ;
				 ALLTRIM(_DOPO_MOD_NOMOPE) + CHR(10) + ;
				 "Ricaricare l'ordine e riprovare" + CHR(10) + CHR(10) + ;
				 "Contattare comunque l'utente " + ALLTRIM(_DOPO_MOD_NOMOPE) + " per sincronizzare le operativitŕ di entrambi!!!"
				
			CASE ALLTRIM(_PRIMA_ORD_LASTUSE) <> ALLTRIM(_DOPO_ORD_LASTUSE)
				_YES_CONTINUA = .F.
				XDESCRI = CHR(10) + "EVASIONE NON POSSIBILE:" + CHR(10) + CHR(10) + ;
				 "Ordine " + ALLTRIM(VNUMORD) + " utilizzato nel frattempo per " + ALLTRIM(_DOPO_ORD_LASTUSE) + CHR(10) + ;
				 "Ricaricare l'ordine e riprovare" + CHR(10) + CHR(10) + ;
				 "Contattare comunque l'utente per sincronizzare le operativitŕ di entrambi!!!"
		ENDCASE
		
		IF !_YES_CONTINUA
			MESSAGGIO_MEGA(XDESCRI,"0,128,255")
		ENDIF
	ENDIF
	**=> ERASMO - FINE 12/03/2013
   
   **=> ERASMO - INIZIO 05/01/2012
   IF !_YES_CONTINUA 
      SELECT CU_ORD_TT
      REPLACE SELEZIONE WITH "" ALL
      RETURN .F.
   ENDIF
   **=> ERASMO - FINE 05/01/2012
   


	CREATE CURSOR TO_UPDATE (;
		CHIAVE	C(40),;
		ORD		N(10,2),;		
		DA_EV	N(10,2),;
		EV		N(10,2);
	)	
	INDEX ON ALLTRIM(CHIAVE) TAG I_CHIAVE


    *** Riempimento del cursore di appoggio "_RIGHE_MODIFICATE"
    SELECT CCU_ORD_DD
    GO TOP
	HH=AFIELDS(TRANSITO)
	CREATE CURSOR _RIGHE_MODIFICATE FROM ARRAY TRANSITO
	SELECT _RIGHE_MODIFICATE 
	INDEX ON ALLTRIM(KEY_AGG) TAG I_KAGG
	
    SELECT CCU_ORD_DD
    GO TOP
	DO WHILE !EOF()
	
	 	IF !ORD_EVASEL
			SELECT CCU_ORD_DD 	
			SKIP
			LOOP
		ENDIF
		
		SCATTER MEMVAR MEMO
		SELECT _RIGHE_MODIFICATE 
		APPEND BLANK
		GATHER MEMVAR MEMO
		SELECT CCU_ORD_DD
		SKIP + 1
	ENDDO


	SELECT _RIGHE_MODIFICATE
	SET ORDER TO I_KAGG
	GO TOP
	_V_KEY_AGG		= ''
	_V_TOTQTA_ORD   = 0
	_V_TOTQTA_DA_EV = 0
	_V_TOTQTA_EV    = 0
	
	DO WHILE !EOF()
	
		IF (ORD_QTADEV + ORD_QTADEV2) = 0 				&& SE SPEDISCO SOLO UNA SECONDA SCELTA ORD_QTADEV = 0 E ORD_QTADEV2 > 0
			SKIP + 1
			LOOP
		ENDIF
		
		SELECT _RIGHE_MODIFICATE
		_V_KEY_AGG      = ALLTRIM(KEY_AGG)
		_V_TOTQTA_ORD   = ORD_QTAORD
		_V_TOTQTA_DA_EV = ORD_QTADEV
		_V_TOTQTA_EV    = ORD_QTAEV

		__SEEK = _V_KEY_AGG

		SELECT TO_UPDATE
		SET ORDER TO I_CHIAVE
		SEEK __SEEK 
		IF FOUND()
			_V_TOTQTA_DA_EV = _V_TOTQTA_DA_EV + DA_EV  
			REPLACE DA_EV  	WITH _V_TOTQTA_DA_EV 
			*** SE NON E' STATO VALORIZZATO CON UN VALORE <> 0 PRECEDENTEMENTE, LO FACCIO ORA
			IF _V_TOTQTA_EV	<> 0
				REPLACE EV  WITH _V_TOTQTA_EV    			
			ENDIF
		ELSE
			SELECT TO_UPDATE		
			APPEND BLANK
			REPLACE CHIAVE 	WITH _V_KEY_AGG
			REPLACE DA_EV  	WITH _V_TOTQTA_DA_EV 
			REPLACE EV		WITH _V_TOTQTA_EV  		&& VIENE AGGIORNATO SOLO UNA VOLTA PERCHE' QUANDO SI DUPLICANO LE RIGHE, VIENE DUPLICATO IL CAMPO  						
			REPLACE ORD		WITH _V_TOTQTA_ORD      && VIENE AGGIORNATO SOLO UNA VOLTA PERCHE' QUANDO SI DUPLICANO LE RIGHE, VIENE DUPLICATO IL CAMPO  									
		ENDIF

		SELECT _RIGHE_MODIFICATE
		SKIP + 1
		
	ENDDO

	
	
   SELECT CCU_ORD_DD
   GO TOP
   V_EVASIONE = 0
   V_EVASPARZ = 0
   _STO_VARIANDO_UNA_RIGA_ORDINE = .F.
         
   DO WHILE .T.
      
      IF EOF()
         EXIT
      ENDIF
      
      **=> ERASMO - INIZIO 11/01/2012
      IF !ORD_EVASEL
         SKIP +1
         LOOP
      ENDIF
      
      IF ORD_CHIUSO
         SKIP +1
         LOOP
      ENDIF
      **=> ERASMO - FINE 11/01/2012
  
      IF "*** COMMENTO ***" $ ORD_DESART
      ELSE
         V_EVASIONE = V_EVASIONE + ORD_QTADEV + ORD_QTADEV2  && ERASMO - 19/12/2011
         V_EVASPARZ = V_EVASPARZ + ORD_QTADEV + ORD_QTADEV2  && ERASMO - 19/12/2011
      ENDIF

 	  IF ORD_QTADEV = 0
		*!*	############################################### VERIFICA SE RIGA ORDINE MODIFICATA NELLE QTA/ALTEZZE/LUNGHEZZE
	     
		 IF VAR_NUMBOB <> 0  OR VAR_ALTEZZ <> 0 OR VAR_LUNGHE <> 0
	        
	        _STO_VARIANDO_UNA_RIGA_ORDINE = .T.
	        
			REPLACE ORD_NUMBOB	WITH	VAR_NUMBOB	
			REPLACE ORD_ALTEZZ	WITH	VAR_ALTEZZ
			REPLACE ORD_LUNGHE	WITH	VAR_LUNGHE

			REPLACE ORD_QTAKG1	WITH	VAR_QTAKG1	
			REPLACE ORD_QTAMQ1	WITH	VAR_QTAMQ1	
			REPLACE ORD_QTAML1	WITH	VAR_QTAML1	

			REPLACE ORD_QTAKG	WITH	VAR_QTAKG
			REPLACE ORD_QTAMQ	WITH	VAR_QTAMQ
			REPLACE ORD_QTAML	WITH	VAR_QTAML

			IF ORD_UM = 'KG'
			   REPLACE ORD_QTAORD WITH ORD_QTAKG
			ENDIF
			IF ORD_UM = 'MQ'
			   REPLACE ORD_QTAORD WITH ORD_QTAMQ
			ENDIF
			IF ORD_UM = 'ML'
			   REPLACE ORD_QTAORD WITH ORD_QTAML
			ENDIF

		
		 ENDIF VAR_NUMBOB <> 0

		 REPLACE VAR_NUMBOB	WITH	0	
		 REPLACE VAR_ALTEZZ	WITH	0
		 REPLACE VAR_LUNGHE	WITH	0

		 REPLACE VAR_QTAKG1	WITH	0	
		 REPLACE VAR_QTAMQ1	WITH	0	
		 REPLACE VAR_QTAML1	WITH	0	

		 REPLACE VAR_QTAKG	WITH	0
		 REPLACE VAR_QTAMQ	WITH	0
		 REPLACE VAR_QTAML	WITH	0

	  ENDIF

 
      SKIP +1  

   ENDDO                  

   IF V_EVASIONE  <>  0
      OK_PROC=.T.
   ELSE
      **=> ERASMO - INIZIO 11/01/2012
      SELECT CU_ORD_TT
      REPLACE SELEZIONE WITH ""
      **=> ERASMO - FINE 11/01/2012
      OK_PROC=.F.
      SELECT CCU_ORD_DD
      GO TOP
   ENDIF

   *** SIMONE - 02/09/2009 - INIZIO
   *** FASE DI AGGIORNAMENTO CURSORE PRINCIPALE DETTAGLI "CCU_ORD_DD"
   *** A PARTIRE DAL CURSORE ELABORATO IN PRECEDENZA
   SELECT TO_UPDATE
   GO TOP
   DO WHILE !EOF()  
   
	   __QTAEV_DA_AGG   = 0  
   	   __QTADAEV_DA_AGG = 0
   
   	   __KEY_UNIQUE     = ALLTRIM(TO_UPDATE.CHIAVE)
   	   __QTAORDINATA    = TO_UPDATE.ORD
   	   __QTAINEVASIONE  = TO_UPDATE.DA_EV
   	   __QTAGIAEVASA    = TO_UPDATE.EV
   	   
   	   __QTAEV_DA_AGG   = __QTAGIAEVASA + __QTAINEVASIONE 
   	   __QTADAEV_DA_AGG = __QTAORDINATA - __QTAEV_DA_AGG    
   	   
       SELECT CCU_ORD_DD
       *REPLACE ORD_QTAEV  WITH __QTAEV_DA_AGG   FOR ID_UNIQUE = __KEY_UNIQUE ALL  && ERASMO - 11/01/2013 - L'AGGIORNAMENTO DELLA QUANTITA' EVASA AVVIENNE ALL'INTERNO DELL'AQMLIB.PRG
       **REPLACE ORD_QTADEV WITH __QTADAEV_DA_AGG FOR ID_UNIQUE = __KEY_UNIQUE ALL     && COMMENTATA, SBALLEREBBE I CALCOLI  
   	   
	   SELECT TO_UPDATE   
	   SKIP + 1
   ENDDO

  *** SIMONE - 02/09/2009 - FINE


 
 *!*	########################################################### RIPORTA LE MODIFICHE ALLE RIGHE ORDINI  ##############################################

	IF !ExecRW('','U_ORD_DD','I','','CCU_ORD_DD')	
	   return(.f.)
	ENDIF


    IF  _STO_VARIANDO_UNA_RIGA_ORDINE 
      PUB_ERRORE=MESSAGEBOX('Ordine : '+VNUMORD+CHR(13)+"variato correttamente",64,'*** ATTENZIONE ***')
  	  DO ORDCAVOL WITH ALLTRIM(AGGA)	&& RICALCOLA IL TOTALE DELL'ORDINE RILEGGENDO IL DATA BASE EFFETTIVO
    ENDIF

     
   SELECT CU_ORD_TT
   
   IF V_EVASIONE<>0
		REPLACE	ORD_EVAPAR WITH .T.		&& SERGIO 2008-02-10 HO EVASO PARZIALMENTE UNA RIGA ORDINE PER CUI SUCCESSIVAMENTE L'ORDINE DEVE ESSERE PRESO IN CONSIDERAZOONE , SENZA QUESTO FLAG SELEZIONANDO PIU' ORDINI E NON EVADENDOLI CREA LE TESTATE VUOTE OPPURE ORDINI CON SOLO I COMMENTI
   ENDIF

   SKIP +1
  
ENDDO

RETURN