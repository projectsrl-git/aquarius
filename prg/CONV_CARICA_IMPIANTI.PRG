	REPLACE CSCAD_C     	WITH ""             
	REPLACE CSCAD_D1     	WITH ""             
	REPLACE CSCAD_D2     	WITH ""                
	REPLACE CSCAD_E1     	WITH ""             
	REPLACE CSCAD_E2     	WITH ""              
	REPLACE CSCAD_F1     	WITH ""              
	REPLACE CSCAD_F2     	WITH ""                

       
	REPLACE  CUGELLO      WITH ""     
	*REPLACE  ANNOCOSTRU   WITH 0      
	REPLACE  ANNOCOSTRU   WITH M.ANNOCOSTRU  && ERASMO - 19/12/2023
	
	REPLACE  BRU_ID_BRU   			WITH ""
	REPLACE  BRU_TIPO_BRU 			WITH ""
	REPLACE  BRU_POT_MIN  			WITH 0     
	REPLACE  BRU_POT_MAX  			WITH 0   
	REPLACE  BRU_POT_MIN_KW   		WITH 0  
	REPLACE  BRU_POT_MAX_KW   		WITH 0  
	REPLACE  BRU_POT_REAL_KW  		WITH 0 
	REPLACE  BRU_POT_MIN_GASS_KW   	WITH 0 
	REPLACE  BRU_POT_MAX_GASS_KW   	WITH 0  
	REPLACE  BRU_POT_REAL_GASS_KW   WITH 0 
	REPLACE  BRU_POT_MIN_MC   		WITH 0   
	REPLACE  BRU_POT_MAX_MC   		WITH 0   
	REPLACE  BRU_POT_REAL_MC  		WITH 0 
	REPLACE  BRU_POT_REAL_KG  		WITH 0 
	REPLACE  BRU_EMULSIONE    		WITH .F.  
	REPLACE  BRU_PROGRESSIVO  		WITH .F. 
	REPLACE  BRU_UGELLO_1     		WITH 0     
	REPLACE  BRU_UGELLO_2     		WITH 0     
	REPLACE  BRU_PRESS_POMP   		WITH 0  
	REPLACE  BRU_CONSU_GAS    		WITH 0    
	REPLACE  BRU_A_NORMA           	WITH .F.           
	
