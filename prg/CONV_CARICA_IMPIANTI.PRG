		REPLACE DT_DISMESS  	WITH "" 
	ENDIF	
	
	REPLACE GRUPPO WITH "GRUPPO 1"
	
	IF !ExecRW("select * from IMPIANTI_DD where 0=1","IMPIANTI_DD","W")
	   return(.f.)
	ENDIF
	

	_CT_CAL 	= _CT_CAL 	+ 1 


	RETURN .T.
	
ENDFUNC



***********************************
FUNCTION CARICA_IMPIANTI_TE_CALDAIA
***********************************
