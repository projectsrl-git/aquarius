	IF SUBSTR(DTOC(M.DT_ULT_MAN_ORD),3,1) = "/" 	&& FORMATO GG/MM/AAAA 
		REPLACE  DT_ULT_MAN_ORD		WITH RIBALTA2(DTOC(M.DT_ULT_MAN_ORD)) 
	ENDIF	
		
	IF SUBSTR(DTOC(M.DT_INIZ_BV),3,1) = "/" 	&& FORMATO GG/MM/AAAA 
		REPLACE  DT_INIZ_BV		WITH RIBALTA2(DTOC(M.DT_INIZ_BV)) 
	ENDIF		
	IF SUBSTR(DTOC(M.DT_SCAD_BV),3,1) = "/" 	&& FORMATO GG/MM/AAAA 
		REPLACE  DT_SCAD_BV		WITH RIBALTA2(DTOC(M.DT_SCAD_BV)) 
