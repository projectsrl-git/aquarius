	IF SUBSTR(DTOC(M.DT_ACCENSIONE),3,1) = "/" 	&& FORMATO GG/MM/AAAA 
		REPLACE  DT_ACCENSIONE		WITH RIBALTA2(DTOC(M.DT_ACCENSIONE)) 
	ENDIF		
	IF SUBSTR(DTOC(M.DT_ULT_RISTRUTT),3,1) = "/" 	&& FORMATO GG/MM/AAAA 
		REPLACE  DT_ULT_RISTRUTT		WITH RIBALTA2(DTOC(M.DT_ULT_RISTRUTT)) 
	ENDIF		
	IF SUBSTR(DTOC(M.DT_DISMESS),3,1) = "/" 	&& FORMATO GG/MM/AAAA 
		REPLACE  DT_DISMESS		WITH RIBALTA2(DTOC(M.DT_DISMESS)) 
	ENDIF		
     

	IF DTOC(M.DT_ULT_MAN) = "  /  /    " OR 	DTOC(M.DT_ULT_MAN) = "    /  /  "
		REPLACE DT_ULT_MAN    	WITH "" 
	ENDIF
	IF DTOC(M.DT_ULT_MAN_ORD) = "  /  /    " OR 	DTOC(M.DT_ULT_MAN_ORD) = "    /  /  "
		REPLACE DT_ULT_MAN_ORD	WITH "" 
	ENDIF
	
	IF DTOC(M.DT_INIZ_BV) = "  /  /    " OR 	DTOC(M.DT_INIZ_BV) = "    /  /  "
		REPLACE DT_INIZ_BV  	WITH "" 
	ENDIF

	IF DTOC(M.DT_SCAD_BV) = "  /  /    " OR 	DTOC(M.DT_SCAD_BV) = "    /  /  "
		REPLACE DT_SCAD_BV   	WITH "" 
	ENDIF	

	IF DTOC(M.DT_ACCENSIONE) = "  /  /    " OR 	DTOC(M.DT_ACCENSIONE) = "    /  /  "
		REPLACE DT_ACCENSIONE	WITH "" 
