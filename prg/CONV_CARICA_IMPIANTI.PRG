**************************************
FUNCTION CARICA_IMPIANTI_DD_BRUCIATORE
**************************************
** CREA IL RECORD DEL BRUCIATORE SU IMPIANTI_DD

		
	WAIT WINDOWS "Bruciatore caricato: " + M.ID_PMKEY NOWAIT


	SELECT SCHEDEBRU								&& CARICA DATI DEL BRUCIATORE
	SCATTER MEMVAR MEMO	

	** ########################################################## VARIABII GESTITE NEL RECORD CALDAIA MA NON NEL BRUCIATORE #######################################
	
		M.DT_ULT_MAN		= ""
		M.DT_INIZ_BV		= ""
		M.DT_SCAD_BV		= ""
		M.DT_ACCENSIONE	= ""
		M.DT_ULT_RISTRUTT	= ""
		M.DT_DISMESS		= ""

	** ########################################################## VARIABII GESTITE NEL RECORD CALDAIA MA NON NEL BRUCIATORE #######################################



	** ################################################## DATI BRUCIATORE #######################################
		
	IF !ExecRW("select * from IMPIANTI_DD where 0=1","IMPIANTI_DD","R")
	   return(.f.)
	ENDIF
	
	SELECT IMPIANTI_DD
	APPEND BLANK
	GATHER MEMVAR MEMO

	REPLACE TIPO_COMPONENTE	WITH "002"									&& BRUCATORE         
	REPLACE ID_PMKEY        WITH _KEY_ID_PMKEY     
    REPLACE CCODSCHE        WITH ALLTRIM(_KEY_CCODSCHE)	   
    REPLACE LINKINTE		WITH SYS(2015)								&& COLLEGAMENTO CON GLI INTERVENTI TECNICI PER LA MANUTENZIONE PROGRAMMATA
    REPLACE ORD_LINKCOMP 	WITH SYS(2015)								&& COLLEGAMENTO CON GLI INTERVENTI TECNICI VENDITE_DC PER L'AGGANCIO DEI COMPONENTI IN MANUTENZIONE

	REPLACE  ID_RIGO      WITH M.ID_RIGO      
	REPLACE  CDITTABRU    WITH M.CDITTABRU    
	REPLACE  CMODBRU      WITH M.CMODBRU      
	REPLACE  CMATBRU      WITH M.CMATBRU  
	REPLACE  CCALCAL      WITH M.CCALCAL
	REPLACE  COD_PRODUT   WITH M.COD_PRODUT   
	REPLACE  CNOTE1       WITH M.CNOTE1       
	REPLACE  CNOTE2       WITH M.CNOTE2       
	REPLACE  CNOTE3       WITH M.CNOTE3       
	REPLACE  CFLAGGARZ    WITH M.CFLAGGARZ    
	REPLACE  DISMESSA     WITH M.DISMESSA     

	
*!*		REPLACE  DT_INSTALL     WITH RIBALTA2(DTOC(M.DT_INSTALL))              
*!*		REPLACE  CDAINGARNZ 	WITH RIBALTA2(DTOC(M.CDAINGARNZ))	
*!*		REPLACE  CDAFIGARNZ 	WITH RIBALTA2(DTOC(M.CDAFIGARNZ))	


*!*		IF SUBSTR(DTOC(M.DT_INSTALL),3,1) = "/" 	&& FORMATO GG/MM/AAAA 
*!*			REPLACE  DT_INSTALL		WITH RIBALTA2(DTOC(M.DT_INSTALL)) 
*!*		ENDIF		
*!*		IF SUBSTR(DTOC(M.CDAINGARNZ),3,1) = "/" 	&& FORMATO GG/MM/AAAA 
*!*			REPLACE  CDAINGARNZ		WITH RIBALTA2(DTOC(M.CDAINGARNZ)) 
*!*		ENDIF		
*!*		IF SUBSTR(DTOC(M.CDAFIGARNZ),3,1) = "/" 	&& FORMATO GG/MM/AAAA 
*!*			REPLACE  CDAFIGARNZ		WITH RIBALTA2(DTOC(M.CDAFIGARNZ)) 
*!*		ENDIF
	
	**=> ERASMO - INIZIO 11/01/2024
	REPLACE BRU_DT_INSTALL WITH RIBALTA2(DTOC(M.DT_INSTALL))
	REPLACE BRU_CDAINGARNZ WITH RIBALTA2(DTOC(M.CDAINGARNZ))
	REPLACE BRU_CDAFIGARNZ WITH RIBALTA2(DTOC(M.CDAFIGARNZ))		
	**=> ERASMO - FINE 11/01/2024

	REPLACE  CDITTACAL    WITH M.CDITTABRU    
	REPLACE  CMODCAL      WITH M.CMODBRU  
	REPLACE  CMATCAL	  WITH M.CMATBRU 

	IF DTOC(M.DT_INSTALL) = "  /  /    " OR 	DTOC(M.DT_INSTALL) = "    /  /  "
		REPLACE DT_INSTALL  	WITH "" 
	ENDIF
	
	IF DTOC(M.CDAINGARNZ)  = "  /  /    " OR 	DTOC(M.CDAINGARNZ)  = "    /  /  "
		REPLACE CDAINGARNZ  	WITH "" 
	ENDIF

	IF DTOC(M.CDAFIGARNZ) = "  /  /    " OR 	DTOC(M.CDAFIGARNZ) = "    /  /  "
		REPLACE CDAFIGARNZ  	WITH "" 
	ENDIF	

	REPLACE GRUPPO WITH "GRUPPO 1"
	
	IF !ExecRW("select * from IMPIANTI_DD where 0=1","IMPIANTI_DD","W")
	   return(.f.)
	ENDIF

	_CT_BRU = _CT_BRU + 1


	RETURN .T.
	
ENDFUNC



