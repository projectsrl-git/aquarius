SET DEFAULT TO &PUB_DIR


__connectString = PUB_NOMEDB
__connectString_DATABASE = SUBSTR(__connectString,AT("DATABASE=",__connectString),AT(';',SUBSTR(__connectString,AT("DATABASE=",__connectString)))-1)
_V_DBAL = STRTRAN(__connectString_DATABASE,"DATABASE=","")
__config_name = "conversioni_" + _V_DBAL + ".cfg"
*PERCORSO_TREVICALOR= "D:\Trevicalor\asterdat"
PERCORSO_TREVICALOR=legge_config(__config_name,"PERCORSO_ASTERDAT")						&& RICERCA VARIABILE
WAIT WINDOWS "PERCORSO ARCHIVI TREVICALOR: " + PERCORSO_TREVICALOR
SET DEFAULT TO &PERCORSO_TREVICALOR


RIT = MESSAGEBOX("PROCEDO CON IL CARICAMENTO DELLE TABELLE IMPIANTI (SCHEDETEST/SCHEDE/SCHEDEBRU) TREVICALOR ? " + REPLICATE(CHR(13),2) + ;
		"Continuare?",4+32+256,"ATTENZIONE")

IF RIT = 7
   MESSAGEBOX("Operazione abbandonata",48,"Informazione")
   RETURN
ENDIF
	

*** CANCELLAZIONE TABELLE INTERVENTI
WAIT WINDOWS "Cancellazione INTERVENTI ...  -  Prego Attendere" NOWAIT


cSql   = "truncate table IMPIANTI_TT" 
IF !ExecCommand(cSql,"IMPIANTI_TT")
   return(.f.)
ENDIF

cSql   = "truncate table IMPIANTI_DD" 
IF !ExecCommand(cSql,"IMPIANTI_DD")
   return(.f.)
ENDIF

cSql   = "truncate table IMPIANTI_TE" 
IF !ExecCommand(cSql,"IMPIANTI_TE")
   return(.f.)
ENDIF



_V_PERCORSO= PERCORSO_TREVICALOR

SET EXCLUSIVE ON

V_PATH = ALLTRIM(_V_PERCORSO)
SET DEFAULT TO &V_PATH
=OPENDB("MOVIARTI")
SELECT MOVIARTI
*INDEX ON ALLTRIM(CCODSCHE)+RIBALTA2(DTOC(CDATINT))+ALLTRIM(CCODART) TAG ID_RIC  ADDITIVE
INDEX ON CDATINT DESCENDING ADDITIVE TAG D_DATINT
*SET ORDER TO ID_RIC  
GO TOP

V_PATH = ALLTRIM(_V_PERCORSO)
SET DEFAULT TO &V_PATH
=OPENDB("MOVITEST")
SELECT MOVITEST
INDEX ON CDATINT DESCENDING ADDITIVE TAG D_DATINT
SET ORDER TO D_DATINT
GO TOP

V_PATH = ALLTRIM(_V_PERCORSO)
SET DEFAULT TO &V_PATH
=OPENDB("SCHEDETEST")									&& TESTATA IMPIANTI
SELECT SCHEDETEST
*INDEX ON ALLTRIM(CCODSCHE)  TAG ID_IMPI  ADDITIVE
*SET ORDER TO ID_IMPI  
GO TOP

V_PATH = ALLTRIM(_V_PERCORSO)
SET DEFAULT TO &V_PATH
=OPENDB("SCHEDE")										&& CALDAIE
SELECT SCHEDE
INDEX ON ALLTRIM(ID_PMKEY)  TAG ID_PKEY  ADDITIVE
INDEX ON ALLTRIM(CCODSCHE)  TAG ID_SCHE  ADDITIVE
SET ORDER TO ID_SCHE  
GO TOP


V_PATH = ALLTRIM(_V_PERCORSO)
SET DEFAULT TO &V_PATH
=OPENDB("SCHEDEBRU")									&& BRUCIATORI
SELECT SCHEDEBRU
INDEX ON ALLTRIM(ID_PMKEY)  TAG ID_PKEY  ADDITIVE
INDEX ON ALLTRIM(CCODSCHE)  TAG ID_SCHE  ADDITIVE
SET ORDER TO ID_SCHE  
GO TOP



WAIT WINDOWS "Caricamento IMPIANTI_TT da archivio SCHEDETEST attendere prego ....." NOWAIT


RELEASE _KEY_ID_PMKEY,_KEY_CCODSCHE 
PUBLIC _KEY_ID_PMKEY,_KEY_CCODSCHE 

_KEY_ID_PMKEY 	= ""					&& CHIAVE DI AGGANCIO DEI RECORD
_KEY_CCODSCHE 	= ""					&& CODICE IMPIANTO


_CT_IMP  	= 0				&& CONTA IMPIANTI
_CT_CAL 	= 0				&& CONTA CALDAIE
_CT_BRU 	= 0				&& CONTA BRUCIATORI
_CT_CALT	= 0				&& CONTA DATI TECNICI CALDAIE
_CT_BRUT	= 0				&& CONTA DATI TECNICI BRUCIATORI



SELECT SCHEDETEST
GO TOP 

*!*	SET FILTER TO CCODSCHE = 'AGNA.BIANCHI'
*!*	GO TOP



SCAN

	SCATTER MEMVAR MEMO
	
	M.ID_PMKEY    	= ALLTRIM(M.ID_PMKEY)					&& CHIAVE DI AGGANCIO DEI RECORD
	M.CCODSCHE 		= CONV_CLEAR(APITOSPA(M.CCODSCHE))		&& CODICE IMPIANTO
	*M.CCODSCHE 		= CONV_CLEAR(M.CCODSCHE)  && ERASMO - 05/01/2024

	_KEY_ID_PMKEY 	= ALLTRIM(M.ID_PMKEY)					&& CHIAVE DI AGGANCIO DEI RECORD
	_KEY_CCODSCHE 	= ALLTRIM(M.CCODSCHE)					&& CODICE IMPIANTO
	
		
	WAIT WINDOWS "Impianto caricato: " + M.ID_PMKEY NOWAIT
	
*!*		IF 'LISC.CENTRO' $ M.CCODSCHE
*!*			SET STEP ON
*!*		ELSE
*!*			SKIP +1
*!*			LOOP
*!*		ENDIF

*!*		IF RECNO() >= 500
*!*		   EXIT
*!*		ENDIF
	
	**=> ERASMO - INIZIO 06/09/2023
	_LOC_CODLOC = ""
	*** SOLO SE CLIENTI CHE NON SIANO CONDOMINI, CREO UNA SPECIFICA LOCALITA' DI CONSEGNA IN BASE AI DATI "DESTINATARIO CORRISPONDENZA" PRESENTI SU ASTER	
	_CLI_CATCLI = ""
	IF !EMPTY(M.CCODCLI)
		x_cond = "CLI_CODCLI = '" + TRC(PUB_LCL,ALLTRIM(M.CCODCLI)) + "'"
		Csql   = "SELECT CLI_CATCLI FROM U_ANA_CL WHERE " + x_cond
		IF !ExecCommand(cSql,"CHK_ANA_CL")
			return(.f.)
		ENDIF
		SELECT CHK_ANA_CL
		GO TOP
		IF !EOF()
			_CLI_CATCLI = UPPER(ALLTRIM(CLI_CATCLI))
		ENDIF
	ENDIF
	
	*** EDIT 11/01/2024: ANCHE E SOPRATTUTTO PER CLIENTI CONDOMINI, CREO UNA SPECIFICA LOCALITA' DI CONSEGNA IN BASE AI DATI "DESTINATARIO CORRISPONDENZA" SE PRESENTI SU ASTER;
	*** VERRA' EVENTUALMENTE AGGIORNATA DA APPOSITO FILE EXCEL IN SUCCESSIVA CONVERSIONE "Completa i dati dei destinatari fatture (amministratori) su U_CLI_AN/U_LOC_AN (EXCEL 5.0)"
	*IF UPPER(ALLTRIM(_CLI_CATCLI)) == "CON"
	*ELSE
	_LOC_CODLOC		= ""
	_LOC_CODCLI		= TRC(PUB_LCL,ALLTRIM(M.CCODCLI))
	_LOC_RAGSOC		= M.CRAGSOC
	_LOC_INDIRI		= M.CINDDES
	_LOC_CAP			= M.CCAPDES
	_LOC_LOCALI		= M.CLOCDES
	_LOC_PROVIN		= M.CPRODES
	_LOC_DESNAZ  	= ""
	_LOC_ATTENZIONE	= ""
	_LOC_VARIE		= IIF(!EMPTY(ALLTRIM(M.CTELDES)),"TEL: " + ALLTRIM(M.CTELDES),"")
	_LOC_VARIE		= IIF(!EMPTY(ALLTRIM(M.CFAXDES)),ALLTRIM(_LOC_VARIE) + IIF(!EMPTY(ALLTRIM(_LOC_VARIE))," - ","") + " -- " + ALLTRIM(M.CFAXDES),ALLTRIM(_LOC_VARIE))
	
	IF !EMPTY(ALLTRIM(_LOC_RAGSOC)) OR !EMPTY(ALLTRIM(_LOC_INDIRI)) OR !EMPTY(ALLTRIM(_LOC_CAP)) OR !EMPTY(ALLTRIM(_LOC_LOCALI)) OR !EMPTY(ALLTRIM(_LOC_PROVIN)) OR !EMPTY(ALLTRIM(_LOC_VARIE))  && ERASMO - 11/01/2024
		__CF  = "C"
		x_soci = "LOC_CODSOC = '" + PUB_CODSOC + "'"
		x_ccff = "LOC_CF     = '" + __CF + "'"
		x_clie = "LOC_CODCLI = '" + STRTRAN(_LOC_CODCLI,"'","''") + "'"
		x_ragc = "LOC_RAGSOC = '" + STRTRAN(_LOC_RAGSOC,"'","''") + "'"
		x_indc = "LOC_INDIRI = '" + STRTRAN(_LOC_INDIRI,"'","''") + "'"
		x_capc = "LOC_CAP = '" + STRTRAN(_LOC_CAP,"'","''") + "'"
		x_locc = "LOC_LOCALI = '" + STRTRAN(_LOC_LOCALI,"'","''") + "'"
		x_proc = "LOC_PROVIN = '" + STRTRAN(_LOC_PROVIN,"'","''") + "'"
		x_varc = "LOC_VARIE = '" + STRTRAN(_LOC_VARIE,"'","''") + "'"
		x_cond = x_soci + " and " + x_ccff + " and " + x_clie + " and " + x_ragc + " and " + x_indc + " and " + x_capc + " and " + x_locc + " and " + x_proc + " and " + x_varc 
		cSql = "select * from u_loc_an where " + x_cond + " order by loc_codsoc,loc_cf,loc_codcli,loc_codloc"
		IF !ExecCommand(cSql,"TMP_LOC_AN")
		   RETURN .F. 
		ENDIF
		SELECT TMP_LOC_AN
		GO TOP
		IF !EOF()
			_LOC_CODLOC = ALLTRIM(LOC_CODLOC)
		ELSE
		
			_ACT_SELECT = SELECT()
			_LOC_CODLOC = ""
			x_soci = "loc_codsoc = '" + PUB_CODSOC + "'"
			x_ccff = "loc_cf = '" + __CF + "'"
			x_clie = "loc_codcli = '" + _LOC_CODCLI + "'"
			x_cond = x_soci + " and " + x_ccff + " and " + x_clie
			cSql = "select loc_codloc from u_loc_an where " + x_cond + " order by loc_codloc desc"
			IF !ExecCommand(cSql,"CX_LOC_AN")
			   RETURN .F. 
			ENDIF
			SELECT CX_LOC_AN
			GO TOP
			IF EOF()
				_LOC_CODLOC = "001"
			ELSE
				SELECT MAX(VAL(loc_codloc)) AS N_CODLOC FROM CX_LOC_AN INTO CURSOR CN_LOC_AN
				SELECT CN_LOC_AN
				GO TOP
				IF !ISNULL(N_CODLOC)
					_nUltCodLoc = N_CODLOC
					IF _nUltCodLoc > 0
						_LOC_CODLOC = TRC(3,ALLTRIM(STR(_nUltCodLoc + 1,3,0)))
					ELSE
						_LOC_CODLOC = ""
					ENDIF
				ELSE
					_LOC_CODLOC = ""
				ENDIF
			ENDIF
			SELECT(_ACT_SELECT)

			cSql = "select * from u_loc_an where 1=0"
			IF !ExecRW(cSql,"U_LOC_AN","R")
			   RETURN .F. 
			ENDIF
			APPEND BLANK
			REPLACE LOC_CODSOC WITH PUB_CODSOC
			REPLACE LOC_CODLOC WITH _LOC_CODLOC
			REPLACE LOC_CODCLI WITH _LOC_CODCLI
			REPLACE LOC_RAGSOC WITH _LOC_RAGSOC
			REPLACE LOC_LOCALI WITH _LOC_LOCALI
			REPLACE LOC_INDIRI WITH _LOC_INDIRI
			REPLACE LOC_CAP    WITH _LOC_CAP
			REPLACE LOC_CF     WITH "C"
			REPLACE LOC_PROVIN WITH _LOC_PROVIN
			REPLACE LOC_TRASME WITH ""
			REPLACE LOC_DATINS WITH RIBALTA2(DTOC(DATE()))
			REPLACE LOC_GGEVAS WITH 0
			REPLACE LOC_ATTENZIONE WITH ""
			REPLACE LOC_VARIE  WITH _LOC_VARIE
			REPLACE LOC_CODNAZ WITH ""
			REPLACE LOC_DESNAZ WITH ""
			REPLACE LOC_CODAGE WITH ""
			IF !ExecRW(cSql,"U_LOC_AN","W")
			   RETURN .F. 
			ENDIF
		ENDIF
	ENDIF
	**=> ERASMO - FINE 06/09/2023
	
	**=> ERASMO - INIZIO 11/01/2024
	*** IMPOSTO COME RAGIONE SOCIALE QUELLA AGGIORNATA DELL'ANAGRAFICA CLIENTE
	_CLI_RAGSOC = ""
	IF !EMPTY(M.CCODCLI)
		x_cond = "CLI_CODCLI = '" + TRC(PUB_LCL,ALLTRIM(M.CCODCLI)) + "'"
		Csql   = "SELECT CLI_RAGSOC FROM U_CLI_AN WHERE " + x_cond
		IF !ExecCommand(cSql,"CHK_CLI_AN")
			return(.f.)
		ENDIF
		SELECT CHK_CLI_AN
		GO TOP
		IF !EOF()
			M.CRAGSOC = CLI_RAGSOC
		ENDIF
	ENDIF
	**=> ERASMO - FINE 11/01/2024

	=CARICA_IMPIANTI_TT()
	
*!*		**=> ERASMO - INIZIO 17/05/2023
*!*		*** I DATI ANAGRAFICI DEL CLIENTE PRINCIPLAE SONO IMPOSTATI NELL'IMPIANTO, PER CUI AGGIORNO TALI DATI IN ANAGRAFICA CLIENTI AQUARIUS
*!*		IF !EMPTY(M.CCODCLI)
*!*			x_cond = "CLI_CODCLI = '" + TRC(PUB_LCL,ALLTRIM(M.CCODCLI)) + "'"
*!*			Csql   = "SELECT * FROM U_CLI_AN WHERE " + x_cond
*!*			IF !ExecRW(cSql,"U_CLI_AN","R")
*!*				return(.f.)
*!*			ENDIF
*!*			SELECT U_CLI_AN
*!*			GO TOP
*!*			IF !EOF()
*!*				*REPLACE CRAGSOC WITH M.CRAGSOC
*!*				REPLACE CLI_INDIR WITH M.CINDINS
*!*				REPLACE CLI_LOCALI WITH M.CLOCINS
*!*				REPLACE CLI_PROVIN WITH M.CPROINS
*!*				REPLACE CLI_CAP WITH M.CCAPINS
*!*				REPLACE CLI_ZONA WITH M.CZONAINS
*!*				*REPLACE CLI_CODDIR WITH M.CCODSCHE	&& 21/06/2023 SERGIO: RIPORTO ANCHE IL CODICE SCHEDA
*!*			ENDIF
*!*			IF !ExecRW(cSql,"U_CLI_AN","W")
*!*				return(.f.)
*!*			ENDIF
*!*		ENDIF
*!*		**=> ERASMO - FINE 17/05/2023

	**=> ERASMO - INIZIO 06/09/2023
	*** SOLO SE CLIENTE CONDOMINIO, I DATI ANAGRAFICI DEL CLIENTE PRINCIPALE SONO IMPOSTATI NELL'IMPIANTO, PER CUI AGGIORNO TALI DATI IN ANAGRAFICA CLIENTI AQUARIUS
	IF _CLI_CATCLI = 'CON'
		x_cond = "CLI_CODCLI = '" + TRC(PUB_LCL,ALLTRIM(M.CCODCLI)) + "'"
		Csql   = "SELECT * FROM U_CLI_AN WHERE " + x_cond
		IF !ExecRW(cSql,"U_CLI_AN","R")
			return(.f.)
		ENDIF
		SELECT U_CLI_AN
		GO TOP
		IF !EOF()
			REPLACE CLI_INDIR WITH M.CINDINS
			REPLACE CLI_LOCALI WITH M.CLOCINS
			REPLACE CLI_PROVIN WITH M.CPROINS
			REPLACE CLI_CAP WITH M.CCAPINS
			REPLACE CLI_ZONA WITH M.CZONAINS
		ENDIF
		IF !ExecRW(cSql,"U_CLI_AN","W")
			return(.f.)
		ENDIF
	ENDIF
	**=> ERASMO - FINE 06/09/2023

	SELECT SCHEDE										&& CARICA DATI DELLA CALDAIA
	SET ORDER TO ID_PKEY  
	GO TOP
	_SEEK = _KEY_ID_PMKEY 
	SEEK _SEEK 
	IF FOUND()

		DO WHILE .NOT.EOF()
			
			SELECT SCHEDE
			SCATTER MEMVAR MEMO
			
			IF _KEY_ID_PMKEY <> ALLTRIM(M.ID_PMKEY)
				EXIT
			ENDIF
						
			
			__V_CCODLIS   = ALLTRIM(STR(M.CCODLIS,3,0))	&& CODICE RAGRUPPAMENTO/LISTINO
			
			SELECT MOVIARTI
			SET ORDER TO D_DATINT
			GO TOP
			*** RICERCA ARTICOLO BOLLO
			SET FILTER TO ALLTRIM(CCODSCHE)=ALLTRIM(M.CCODSCHE) AND RIBALTA2(DTOC(CDATINT))=RIBALTA2(DTOC(M.DT_ULT_MAN)) AND (SUBSTR(CCODART,1,5)="2.AUT" OR SUBSTR(CCODART,1,5)="2.REG")
			GO TOP
			IF !EOF()
				*** TROVATO ARTICOLO BOLLO SU INTERVENTO - M.DT_ULT_MAN = DATA ULTIMA MANUTENZIONE OBBLIGATORIA
				M.DT_ULT_MAN = M.DT_ULT_MAN  && DATA ULTIMA MANUTENZIZONE DAM OBBLIGATORIA
				M.DT_ULT_MAN_ORD = CTOD("")
				*** CERCO L'ULTIMO INTERVENTO IN ASSOLUTO SU QUELL'IMPIANTO PER VALORIZZARE LA DATA ULTIMA MANUTENZIONE ORDINARIA
				SELECT MOVITEST
				SET FILTER TO CCODSCHE=M.CCODSCHE
				SET ORDER TO D_DATINT
				GO TOP
				IF !EOF()
					M.DT_ULT_MAN_ORD = CDATINT  && DATA ULTIMA MANUTENZIZONE ORDINARIA
				ENDIF				
			ELSE
				*** NON TROVATO ARTICOLO BOLLO SU INTERVENTO - M.DT_ULT_MAN = DATA ULTIMA MANUTENZIONE ORDINARIA
				M.DT_ULT_MAN_ORD = M.DT_ULT_MAN  && DATA ULTIMA MANUTENZIZONE ORDINARIA
				M.DT_ULT_MAN = CTOD("")
				*** RICERCA ULTIMA DATA ARTICOLO BOLLO PER VALORIZZARE
				SELECT MOVIARTI
				SET FILTER TO CCODSCHE=M.CCODSCHE AND (SUBSTR(CCODART,1,5)="2.AUT" OR SUBSTR(CCODART,1,5)="2.REG")
				SET ORDER TO D_DATINT
				GO TOP
				IF !EOF()
					M.DT_ULT_MAN = CDATINT  && DATA ULTIMA MANUTENZIZONE DAM OBBLIGATORIA
				ENDIF
			ENDIF
			
			M.DT_ULT_MAN_ORD = M.DT_ULT_MAN  && ERASMO - 31/01/2024 - DATA ULTIMA MANUTENZIZONE ORDINARIA = DATA ULTIMA MANUTENZIONE GENERICA
			
			SELECT SCHEDE

			=CARICA_IMPIANTI_DD_CALDAIA()				&& CREA IL RECORD DELLA CALDAIA SU IMPIANTI_DD
			=CARICA_IMPIANTI_TE_CALDAIA()				&& CREA IL RECORD DELLA CALDAIA SU IMPIANTI_TE  DATI TECNICI
			
			SELECT SCHEDE
			SKIP +1
		
		ENDDO

	ENDIF


	SELECT SCHEDEBRU									&& CARICA DATI DEL BRUCIATRE SE ESISTONO
	SET ORDER TO ID_PKEY  
	GO TOP
	_SEEK = _KEY_ID_PMKEY 
	SEEK _SEEK 
	IF FOUND()

		DO WHILE .NOT.EOF()
			
			SELECT SCHEDEBRU
			SCATTER MEMVAR MEMO

			IF _KEY_ID_PMKEY <> ALLTRIM(M.ID_PMKEY)
				EXIT
			ENDIF


			=CARICA_IMPIANTI_DD_BRUCIATORE()			&& CREA IL RECORD DELLA CALDAIA SU IMPIANTI_DD
			=CARICA_IMPIANTI_TE_BRUCIATORE()			&& CREA IL RECORD DELLA CALDAIA SU IMPIANTI_TE  DATI TECNICI
			
			SELECT SCHEDEBRU
			SKIP +1
		
		ENDDO

	ENDIF


	SELECT SCHEDETEST
	
*!*		IF _CT_IMP >= 100
*!*			EXIT
*!*		ENDIF
	
ENDSCAN

 


SET EXCLUSIVE OFF

WAIT WINDOWS "Impianti: " + STR(_CT_IMP,5,0) + CHR(13) + "Caldaie: " + STR(_CT_CAL,5,0) + CHR(13) + "Bruciatori: " + STR(_CT_BRU,5,0) + CHR(13) + "Dati tecnici caldaia: " + STR(_CT_CALT,5,0)  + CHR(13) + "Dati tecnici bruciatore: " + STR(_CT_BRUT,5,0) + CHR(13) 



=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

SET DEFAULT TO &PUB_DIR

RETURN





***************************
FUNCTION CARICA_IMPIANTI_TT
***************************

	**==> CREAZIONE TABELLA IMPIANTO
		
	IF !ExecRW("select * from IMPIANTI_TT where 0=1","IMPIANTI_TT","R")
	   return(.f.)
	ENDIF
	
	
	SELECT IMPIANTI_TT
	APPEND BLANK
	GATHER MEMVAR MEMO

	REPLACE ID_PMKEY        WITH _KEY_ID_PMKEY  
    REPLACE CCODSCHE        WITH ALLTRIM(_KEY_CCODSCHE) 	   

	REPLACE DT_REGIST     	WITH RIBALTA2(DT_REGIST)              
	REPLACE CDATAFATT    	WITH RIBALTA2(CDATAFATT)             
	
	**=> ERASMO - INIZIO 26/01/2023
	IF !EMPTY(ALLTRIM(CCODCLI))
		REPLACE CCODCLI WITH TRC(PUB_LCL,ALLTRIM(CCODCLI))
	ENDIF
	IF !EMPTY(ALLTRIM(COD_AMMIN))
		REPLACE COD_AMMIN WITH TRC(PUB_LCL,ALLTRIM(COD_AMMIN))
	ENDIF
	IF !EMPTY(ALLTRIM(ID_RESPONS))
		REPLACE ID_RESPONS WITH TRC(PUB_LCL,ALLTRIM(ID_RESPONS))
	ENDIF
	IF !EMPTY(ALLTRIM(ID_PROPRIE))
		REPLACE ID_PROPRIE WITH TRC(PUB_LCL,ALLTRIM(ID_PROPRIE))
	ENDIF
	**=> ERASMO - FINE 26/01/2023
	
	**=> ERASMO - INIZIO 06/09/2023
	IF !EMPTY(_LOC_CODLOC)
		REPLACE CRAGSOC1 WITH _LOC_CODLOC
	ENDIF
	**=> ERASMO - FINE 06/09/2023
	
	IF !ExecRW("select * from IMPIANTI_TT where 0=1","IMPIANTI_TT","W")
	   return(.f.)
	ENDIF
	
	_CT_IMP 	= _CT_IMP 	+ 1 


	RETURN .T.

ENDFUNC


***********************************
FUNCTION CARICA_IMPIANTI_DD_CALDAIA
***********************************
** CREA IL RECORD DELLA CALDAIA SU IMPIANTI_DD

	SELECT SCHEDE										&& CARICA DATI DELLA CALDAIA
	SCATTER MEMVAR MEMO
	
	WAIT WINDOWS "Caldaia caricata: " + M.ID_PMKEY NOWAIT

		
	IF !ExecRW("select * from IMPIANTI_DD where 0=1","IMPIANTI_DD","R")
	   return(.f.)
	ENDIF
	
	SELECT IMPIANTI_DD
	APPEND BLANK
	GATHER MEMVAR MEMO
	
	
	REPLACE TIPO_COMPONENTE	WITH "001"									&& CALDAIA         
	REPLACE ID_PMKEY        WITH _KEY_ID_PMKEY     
    REPLACE CCODSCHE        WITH ALLTRIM(_KEY_CCODSCHE)	   
    REPLACE LINKINTE		WITH SYS(2015)								&& COLLEGAMENTO CON GLI INTERVENTI TECNICI PER LA MANUTENZIONE PROGRAMMATA
    REPLACE ORD_LINKCOMP 	WITH SYS(2015)								&& COLLEGAMENTO CON GLI INTERVENTI TECNICI VENDITE_DC PER L'AGGANCIO DEI COMPONENTI IN MANUTENZIONE


	REPLACE DT_INSTALL     	WITH RIBALTA2(DTOC(M.DT_INSTALL))              
	REPLACE CINIZCONTR     	WITH RIBALTA2(DTOC(M.CINIZCONTR))              
	
	** 04/07/2023 SERGIO INIZIO: LA DATA DI SCADENZA CONTRATTO IN ASTER E' INVERTITA CON LA DATA DI FINE ATTIVITA' SERVIZI
	*REPLACE CSCADCONTR     	WITH RIBALTA2(DTOC(M.CSCADCONTR))   
	REPLACE CSCADCONTR     	WITH RIBALTA2(DTOC(M.DT_FINE))   
	** 04/07/2023 SERGIO FINE: LA DATA DI SCADENZA CONTRATTO IN ASTER E' INVERTITA CON LA DATA DI FINE ATTIVITA' SERVIZI
	          
	REPLACE CDAINGARNZ     	WITH RIBALTA2(DTOC(M.CDAINGARNZ))            
	REPLACE CDAFIGARNZ     	WITH RIBALTA2(DTOC(M.CDAFIGARNZ))            
	REPLACE DT_CONFERM     	WITH RIBALTA2(DTOC(M.DT_CONFERM))             
	REPLACE DT_DISDETT     	WITH RIBALTA2(DTOC(M.DT_DISDETT))       
	REPLACE DT_INIZIO     	WITH RIBALTA2(DTOC(M.DT_INIZIO))              

	** 04/07/2023 SERGIO INIZIO: LA DATA DI SCADENZA CONTRATTO IN ASTER E' INVERTITA CON LA DATA DI FINE ATTIVITA' SERVIZI
	*REPLACE DT_FINE     	WITH RIBALTA2(DTOC(M.DT_FINE))                
	REPLACE DT_FINE     	WITH RIBALTA2(DTOC(M.CSCADCONTR)) 	
