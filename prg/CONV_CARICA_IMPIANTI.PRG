	REPLACE CSCAD_E1     	WITH RIBALTA2(DTOC(M.CSCAD_E1))               
	REPLACE CSCAD_E2     	WITH RIBALTA2(DTOC(M.CSCAD_E1))               
	REPLACE CSCAD_F1     	WITH RIBALTA2(DTOC(M.CSCAD_F1))               
	REPLACE CSCAD_F2     	WITH RIBALTA2(DTOC(M.CSCAD_F2))               

