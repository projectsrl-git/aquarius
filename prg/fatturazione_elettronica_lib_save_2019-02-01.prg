SELECT HEADER_FATTURA_ELETTRONICA
GO TOP
_ATCH_iddocumento = TAGGANCIO
_ATCH_tipo = 'FAT'
_V_PARA_PATH = ""
_V_PATH_DESTIN = ""
x_codi = "codice = 'ALL" + _ATCH_tipo + "'"
x_cond = x_codi
cSql   = "select * from para where " + x_cond
IF !ExecCommand(cSql,"TMP_PARA")
	return(.f.)
