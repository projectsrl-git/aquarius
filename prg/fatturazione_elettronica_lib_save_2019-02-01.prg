
********************************************************************************************************
PROCEDURE CREA_FATTURA_ELETTRONICA
*
* SINTASSI:
*
* CREA_FATTURA_ELETTRONICA('000001','2014',SYS(5)+SYS(2003)+'\FATTURE_ELETTRONICHE'
*
********************************************************************************************************
PARAMETERS _NUMERO_FATTURA,_ANNO_FATTURA,_DIRECTORY_DI_CREAZIONE
    
LOCAL POSIZIONE_INIZIO_DETTAGLI,POSIZIONE_FINE_DETTAGLI,POSIZIONE_INIZIO_DDT,POSIZIONE_FINE_DDT
LOCAL POSIZIONE_INIZIO_ORDINE,POSIZIONE_FINE_ORDINE,POSIZIONE_INIZIO_RIEPILOGO_IVA,POSIZIONE_FINE_RIEPILOGO_IVA  && ERASMO - 07/11/2018

IF PCOUNT()<3
	MESSAGEBOX("Errore nei parametri della fattura elettonica: manca numero o mese-anno fattura",48,"Errore fattura elettronica")
ENDIF

**=> ERASMO - INIZIO 08/01/2019
_cNumeroFattura = TOGLI_CARATTERI_SPECIALI(ALLTRIM(_NUMERO_FATTURA))
_cNumeroFattura = PADL(_cNumeroFattura,6,'0')
*_NUMERO_FATTURA = _cNumeroFattura
**=> ERASMO - FINE 08/01/2019

IF FILE("fattura_elettronica.xml")	  && Esiste il file? 
ELSE
	MESSAGEBOX("File fattura_elettronica.xml non presente nella directory di AQUARIUS. Il file č necessario per creare le fatture elettroniche.";
		+CHR(13)+"Contattare assistenza",48,"Errore creazione XML fatturazione elettronica")

	DO CHIUDI_CURSORI
	
	RETURN .F.
ENDIF

WAIT WINDOWS "CREAZIONE FILE DI FATTURA ELETTRONICA IN CORSO..." NOWAIT

*SET STEP ON
*DO CREA_CURSOR_DATI_AZIENDA

_YES_CONTINUA = .T.  && ERASMO - 07/11/2018

DO CREA_CURSOR_HEADER_FATTURA_ELETTRONICA

DO CREA_CURSOR_DATI_AZIENDA  && ERASMO - 07/11/2018

DO CREA_CURSOR_BODY_FATTURA_ELETTRONICA

DO CREA_CURSOR_RIFERIMENTI_DDT

DO CREA_CURSOR_RIFERIMENTI_ORDINE  && ERASMO - 07/11/2018

DO CREA_CURSOR_RIEPILOGO_IVA  && ERASMO - 07/11/2018

DO CREA_CURSOR_DETTAGLI_PAGAMENTO  && ERASMO - 14/01/2019

DO CONTROLLI_FORMALI

**=> ERASMO - INIZIO 07/11/2018
IF !_YES_CONTINUA
	DO CHIUDI_CURSORI
	WAIT CLEAR
	RETURN .F.
ENDIF
**=> ERASMO - FINE 07/11/2018

*** crea il file xml: per ora č vuoto e nei passi successivi vengono aggiunti i vari elementi
SELECT CU_AZIENDA
_PIVA=ALLTRIM(AZI_PIVA)
*_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+RIGHT(ALLTRIM(_NUMERO_FATTURA),5)+".xml"
DO CASE
	CASE PUB_FEPROGR = 1  && Progressivo alfanumerico per nomenclatura file - Usa Numero fattura ridotto a 5 caratteri
		*_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+SUBSTR(ALLTRIM(_NUMERO_FATTURA),1,1)+SUBSTR(ALLTRIM(_NUMERO_FATTURA),3,4)+".xml"
		_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+SUBSTR(ALLTRIM(_cNumeroFattura),1,1)+SUBSTR(ALLTRIM(_cNumeroFattura),3,4)+".xml"  && ERASMO - 16/01/2019
		
	CASE PUB_FEPROGR = 2  && Progressivo alfanumerico per nomenclatura file - Usa codice random alfanumerico di 5 caratteri
		_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+RIGHT(SYS(2015),5)+".xml"
	
	OTHERWISE
		_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+RIGHT(SYS(2015),5)+".xml"
ENDCASE


STRTOFILE("",_FILE_FATTURA_XML ,0)

_FATTURA_ELETTRONICA_COMPLETA=FILETOSTR("fattura_elettronica.xml")

_FATTURA_ELETTRONICA_COMPLETA=SOSTITUISCE_CAMPI_CURSOR_SU_TESTO("CU_AZIENDA",_FATTURA_ELETTRONICA_COMPLETA)

**==> SERGIO 02/11/2018 - INIZIO
_FATTURA_ELETTRONICA_COMPLETA=SOSTITUISCE_CAMPI_CURSOR_SU_TESTO("CU_AZIENDA_PB",_FATTURA_ELETTRONICA_COMPLETA)
**==> SERGIO 02/11/2018 - FINE

**=> ERASMO - INIZIO 07/11/2018
**** ORDINE CLIENTE
POSIZIONE_INIZIO_ORDINE	=ATC("<DatiOrdineAcquisto>",_FATTURA_ELETTRONICA_COMPLETA)
POSIZIONE_FINE_ORDINE	=ATC("</DatiOrdineAcquisto>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiOrdineAcquisto>")  

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,1,POSIZIONE_INIZIO_ORDINE-1)
APPEND_XML_FILE("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)    

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_ORDINE,POSIZIONE_FINE_ORDINE-POSIZIONE_INIZIO_ORDINE)
APPEND_XML_FILE("RIFERIMENTI_ORDINE",_STRING_XML,_FILE_FATTURA_XML )
**=> ERASMO - FINE 07/11/2018

**** DDT
POSIZIONE_INIZIO_DDT	=ATC("<DatiDDT>",_FATTURA_ELETTRONICA_COMPLETA)
POSIZIONE_FINE_DDT		=ATC("</DatiDDT>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiDDT>")  

*!*	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,1,POSIZIONE_INIZIO_DDT-1)
*!*	APPEND_XML_FILE("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML )    

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_DDT,POSIZIONE_FINE_DDT-POSIZIONE_INIZIO_DDT)
APPEND_XML_FILE("RIFERIMENTI_DDT",_STRING_XML,_FILE_FATTURA_XML)
**** DDT

POSIZIONE_INIZIO_DETTAGLI	=ATC("<DettaglioLinee>",_FATTURA_ELETTRONICA_COMPLETA)
POSIZIONE_FINE_DETTAGLI		=ATC("</DettaglioLinee>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DettaglioLinee>")

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_DDT+1,POSIZIONE_INIZIO_DETTAGLI-POSIZIONE_FINE_DDT-1)
APPEND_XML_FILE("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_DETTAGLI,POSIZIONE_FINE_DETTAGLI-POSIZIONE_INIZIO_DETTAGLI)
APPEND_XML_FILE("FatturaElettronica",_STRING_XML,_FILE_FATTURA_XML)

**=> ERASMO - INIZIO 07/11/2018
**** RIEPILOGO IVA
POSIZIONE_INIZIO_RIEPILOGO_IVA	=ATC("<DatiRiepilogo>",_FATTURA_ELETTRONICA_COMPLETA)
POSIZIONE_FINE_RIEPILOGO_IVA	=ATC("</DatiRiepilogo>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiRiepilogo>")  

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_RIEPILOGO_IVA,POSIZIONE_FINE_RIEPILOGO_IVA-POSIZIONE_INIZIO_RIEPILOGO_IVA)
APPEND_XML_FILE("RIEPILOGO_IVA",_STRING_XML,_FILE_FATTURA_XML)
**=> ERASMO - FINE 07/11/2018

*!*	**=> ERASMO - INIZIO 14/01/2019
*!*	POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO	=ATC("<DettaglioPagamento>",_FATTURA_ELETTRONICA_COMPLETA)
*!*	POSIZIONE_FINE_DETTAGLIOPAGAMENTO	=ATC("</DettaglioPagamento>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DettaglioPagamento>")  

*!*	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_RIEPILOGO_IVA,POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO-POSIZIONE_FINE_RIEPILOGO_IVA)
*!*	APPEND_XML_FILE("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)

*!*	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO,POSIZIONE_FINE_DETTAGLIOPAGAMENTO-POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO)
*!*	APPEND_XML_FILE("DETTAGLI_PAGAMENTO",_STRING_XML,_FILE_FATTURA_XML)
*!*	**=> ERASMO - FINE 14/01/2019

*_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_DETTAGLI)
*_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_RIEPILOGO_IVA)  && ERASMO - 07/11/2018
*!*	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_DETTAGLIOPAGAMENTO)  && ERASMO - 14/01/2019
*!*	APPEND_XML_FILE("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)

**=> ERASMO - INIZIO 17/01/2019
SELECT DETTAGLI_PAGAMENTO
GO TOP
IF !EOF()
	POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO	=ATC("<DettaglioPagamento>",_FATTURA_ELETTRONICA_COMPLETA)
	POSIZIONE_FINE_DETTAGLIOPAGAMENTO	=ATC("</DettaglioPagamento>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DettaglioPagamento>")  

	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_RIEPILOGO_IVA,POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO-POSIZIONE_FINE_RIEPILOGO_IVA)
	APPEND_XML_FILE("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)

	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO,POSIZIONE_FINE_DETTAGLIOPAGAMENTO-POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO)
	APPEND_XML_FILE("DETTAGLI_PAGAMENTO",_STRING_XML,_FILE_FATTURA_XML)
	
	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_DETTAGLIOPAGAMENTO)
	APPEND_XML_FILE("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)
ELSE
	POSIZIONE_FINE_DATIBENISERVIZI =ATC("</DatiBeniServizi>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiBeniServizi>")
	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_RIEPILOGO_IVA,POSIZIONE_FINE_DATIBENISERVIZI-POSIZIONE_FINE_RIEPILOGO_IVA)
	APPEND_XML_FILE("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)
	
	POSIZIONE_FINE_DATIPAGAMENTO =ATC("</DatiPagamento>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiPagamento>") 
	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_DATIPAGAMENTO)
	APPEND_XML_FILE("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)
ENDIF
**=> ERASMO - FINE 17/01/2019

**=> ERASMO - INIZIO 07/11/2018
x_ndoc = "ORD_NUMORD = '" + _NUMERO_FATTURA + "'"
x_ddoc = "ORD_ANNO = '" + _ANNO_FATTURA + "'"
x_cond = x_ndoc + " and " + x_ddoc
cSql   = "UPDATE U_FAT_TT SET ORD_FILEXML = '" + ALLTRIM(_FILE_FATTURA_XML) + "' where " + x_cond
IF !ExecCommand(cSql,'UPD_FAT_TT')
   return(.f.)
ENDIF
**=> ERASMO - FINE 07/11/2018

WAIT WINDOW "CREAZIONE FATTURA ELETTRONICA "+_FILE_FATTURA_XML+" TERMINATA CORRETTAMENTE" TIMEOUT 1

DO CHIUDI_CURSORI  && ERASMO - 07/11/2018

RETURN .T.

