******************************************************************************
PROCEDURE CREA_CURSOR_BODY_FATTURA_ELETTRONICA
******************************************************************************
_COND_COMMENTI = IIF(PUB_FECOMM,""," AND DD.ORD_QTAORD>0")  && ERASMO - 22/01/2019
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY DD.ORD_SEQUEN)) AS NUMERIC(4,0)) AS NR_RIGA,  -- ERASMO - 14/01/2019
		DD.ORD_QTAORD,
		--CASE WHEN COALESCE(PR.ART_SERIE,'') <> '' THEN ART_SERIE ELSE 'ART' END AS CODICE_TIPO,
		--CASE WHEN COALESCE(PR.ART_CATBEN,'') <> '' THEN ART_CATBEN ELSE DD.ORD_CODART END AS CODICE_VALORE,
		CASE WHEN ((SELECT AZI_PRDISP FROM U_AZI_PA) = 1) AND COALESCE(PR.ART_SERIE,'') <> '' THEN ART_SERIE ELSE 'ART' END AS CODICE_TIPO,
		--CASE WHEN ((SELECT AZI_PRDISP FROM U_AZI_PA) = 1) AND COALESCE(PR.ART_CATBEN,'') <> '' THEN ART_CATBEN ELSE DD.ORD_CODART END AS CODICE_VALORE,
		CASE WHEN (DD.ORD_CODART='' AND DD.ORD_DESART='*** COMMENTO ***') THEN '*** COMMENTO ***' 
			WHEN ((SELECT AZI_PRDISP FROM U_AZI_PA) = 1) AND COALESCE(PR.ART_CATBEN,'') <> '' THEN ART_CATBEN ELSE DD.ORD_CODART END AS CODICE_VALORE,  -- ERASMO - 22/01/2019
		DD.ORD_CODART,
		--DD.ORD_DESART,
		--CASE DD.ORD_DESART WHEN '' THEN '-' ELSE DD.ORD_DESART END AS ORD_DESART,  -- ERASMO - 09/01/2019
		CASE DD.ORD_DESART WHEN '' THEN '-' WHEN '*** COMMENTO ***' THEN SUBSTRING(ORD_NOTE,1,1000) ELSE DD.ORD_DESART END AS ORD_DESART,  -- ERASMO - 22/01/2019
		DD.ORD_PREZZO,
		--DD.ORD_SC1,
		DD.ORD_PREZZO - DD.ORD_PRZNET AS IMPORTO_SCONTO,
		--(DD.ORD_PREZZO - DD.ORD_PRZNET) * DD.ORD_QTAORD AS IMPORTO_SCONTO,
		DD.ORD_SC1,  -- ERASMO - 15/01/2019
		DD.ORD_SC2,  -- ERASMO - 15/01/2019
		DD.ORD_SC3,  -- ERASMO - 15/01/2019
		DD.ORD_SC4,  -- ERASMO - 15/01/2019
		DD.ORD_SC5,  -- ERASMO - 15/01/2019
		CAST('' AS TEXT) AS DETTAGLIOLINEESCONTOMAGGIORAZIONE,
		DD.ORD_PRZNET,
		DD.ORD_VALORE,
		--CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC(6,2)) AS DettaglioLineeAliquotaIVA,
		CASE WHEN DD.ORD_DESART = '*** COMMENTO ***' THEN (SELECT COALESCE(CAST(SUBSTRING(LIBERA,1,3) AS NUMERIC(6,2)),0.00) FROM PARA 
															WHERE CODICE = 'IVA'+(SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = DD.DAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' ORDER BY DAGGANCIO,ORD_SEQUEN))
			ELSE COALESCE(CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC(6,2)),0.00) 
		END AS DettaglioLineeAliquotaIVA,  -- ERASMO - 22/01/2019
		--CASE WHEN CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC (3,0)) = 0 THEN '<Natura>'+RTRIM(SUBSTRING(IVA.LIBERA,145,2))+'</Natura>' ELSE '' END AS DETTAGLIOLINEENATURAIVA,
		CASE WHEN DD.ORD_DESART = '*** COMMENTO ***' THEN 
				CASE WHEN (SELECT RTRIM(SUBSTRING(LIBERA,145,2)) FROM PARA WHERE CODICE = 'IVA'+(SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = DD.DAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' ORDER BY DAGGANCIO,ORD_SEQUEN)) = '' THEN '' 
					ELSE '<Natura>'+(SELECT RTRIM(SUBSTRING(LIBERA,145,2)) FROM PARA WHERE CODICE = 'IVA'+(SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = DD.DAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' ORDER BY DAGGANCIO,ORD_SEQUEN)) +'</Natura>'
				END
			WHEN CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC (3,0)) = 0 THEN '<Natura>'+RTRIM(SUBSTRING(IVA.LIBERA,145,2))+'</Natura>' ELSE '' 
		END AS DETTAGLIOLINEENATURAIVA,  -- ERASMO - 22/01/2019
		CASE
			WHEN DD.ORD_SYSFAT <> '' AND COALESCE((SELECT TOP 1 ORD_RIFAMMFE FROM BUDGET_CONS WHERE ORD_SYSFAT = DD.ORD_SYSFAT),'') <> ''
				THEN '<RiferimentoAmministrazione>'+RTRIM(COALESCE((SELECT TOP 1 ORD_RIFAMMFE FROM BUDGET_CONS WHERE ORD_SYSFAT = DD.ORD_SYSFAT),''))+'</RiferimentoAmministrazione>'
			WHEN TT.ORD_RIFAMMFE <> '' THEN '<RiferimentoAmministrazione>'+RTRIM(ORD_RIFAMMFE)+'</RiferimentoAmministrazione>'
			ELSE ''
		END AS DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE,
		SPACE(254) AS DETTAGLIOLINEETIPOCESSIONEPRESTAZIONE
	FROM U_FAT_DD AS DD
	LEFT OUTER JOIN U_FAT_TT AS TT
	ON DD.DAGGANCIO=TT.TAGGANCIO
	LEFT OUTER JOIN PARA AS IVA
	ON 'IVA'+DD.ORD_IVA = IVA.CODICE
	LEFT OUTER JOIN U_ART_PR AS PR
	ON DD.ORD_CODART = PR.ART_CODPRI
	--WHERE DD.ORD_QTAORD>0 AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'
	WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'  <<_COND_COMMENTI>>  -- ERASMO - 22/01/2019
	ORDER BY DD.ORD_SEQUEN

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"FatturaElettronica")
	return(.F.)
ENDIF

**=> ERASMO/FABIANO - INIZIO 05/07/2016
SELECT FatturaElettronica
GO TOP
SCAN
	_ORD_DESART = ALLTRIM(ORD_DESART)
	_ORD_DESART = PARSE_STRING_XML(_ORD_DESART)
	REPLACE ORD_DESART WITH _ORD_DESART
ENDSCAN
GO TOP
**=> ERASMO/FABIANO - FINE 05/07/2016

**=> ERASMO - INIZIO 15/01/2019
SELECT FatturaElettronica
GO TOP
SCAN
	_STRINGA_SCONTO = ""
	IF IMPORTO_SCONTO > 0
		IF (IMPORTO_SCONTO*100)-FLOOR(IMPORTO_SCONTO*100) <> 0  && SE LO SCONTO HA PIU' DI 2 DECIMALI ALLORA INSERISCO LE PERCENTUALI DI SCONTO
			IF ORD_SC1 > 0
				_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC1,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
			ENDIF
			IF ORD_SC2 > 0
				_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC2,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
			ENDIF
			IF ORD_SC3 > 0
				_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC3,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
			ENDIF
			IF ORD_SC4 > 0
				_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC4,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
			ENDIF
			IF ORD_SC5 > 0
				_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC5,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
			ENDIF
		ELSE
			_STRINGA_SCONTO = "<ScontoMaggiorazione><Tipo>SC</Tipo><Importo>" + STRTRAN(ALLTRIM(STR(IMPORTO_SCONTO,15,2)),',','.') + "</Importo></ScontoMaggiorazione>"
		ENDIF
	ENDIF
	REPLACE DETTAGLIOLINEESCONTOMAGGIORAZIONE WITH _STRINGA_SCONTO
ENDSCAN
GO TOP
**=> ERASMO - FINE 15/01/2019

RETURN
* FINE PROCEDURE CREA_CURSOR_BODY_FATTURA_ELETTRONICA
******************************************************************************


******************************************************************************
PROCEDURE CREA_CURSOR_RIFERIMENTI_DDT
******************************************************************************
_COND_COMMENTI = IIF(PUB_FECOMM,""," AND DD.ORD_QTAORD>0")  && ERASMO - 22/01/2019
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY DD.ORD_SEQUEN)) AS NUMERIC(4,0)) AS NR_RIGA,  -- ERASMO - 14/01/2019
		DD.ORS_NUMDDT AS DATIDDTNUMERODDT,
		SUBSTRING(DD.ORS_DATDDT,1,4)+'-'+SUBSTRING(DD.ORS_DATDDT,6,2)+'-'+SUBSTRING(DD.ORS_DATDDT,9,2) AS DATIDDTDATA,
		DD.ORD_DESART  -- ERASMO - 22/01/2019
	FROM U_FAT_DD AS DD
	LEFT OUTER JOIN U_FAT_TT AS TT
	ON DD.DAGGANCIO=TT.TAGGANCIO
	--WHERE DD.ORD_QTAORD>0 AND DD.ORS_NUMDDT<>'' AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'
	--WHERE DD.ORD_QTAORD>0 AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'  -- ERASMO - 14/01/2019
	WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'  <<_COND_COMMENTI>>  -- ERASMO - 22/01/2019
	ORDER BY DD.ORD_SEQUEN

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"RIFERIMENTI_DDT")
	return(.F.)
ENDIF

**=> ERASMO - INIZIO 14/01/2019
SELECT RIFERIMENTI_DDT
DELETE FOR EMPTY(DATIDDTNUMERODDT)
DELETE FOR ORD_DESART = '*** COMMENTO ***'  && ERASMO - 22/01/2019
GO TOP
**=> ERASMO - FINE 14/01/2019

RETURN
* FINE PROCEDURE CREA_CURSOR_RIFERIMENTI_DDT
******************************************************************************


**=> ERASMO - INIZIO 07/11/2018
******************************************************************************
PROCEDURE CREA_CURSOR_RIFERIMENTI_ORDINE
******************************************************************************
_COND_COMMENTI = IIF(PUB_FECOMM,""," AND DD.ORD_QTAORD>0")  && ERASMO - 22/01/2019
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY DD.ORD_SEQUEN)) AS NUMERIC(4,0)) AS NR_RIGA,  -- ERASMO - 14/01/2019
		TT.ORD_NUMORC AS DATIORDINEACQUISTOIDDOCUMENTO,
		REPLACE(TT.ORD_DATORC,'/','-') AS DATIORDINEACQUISTODATA,
		DD.ORS_NUMORC AS DATIORDINEACQUISTOIDDOCUMENTO_DD,
		REPLACE(DD.ORS_DATORC,'/','-') AS DATIORDINEACQUISTODATA_DD,
		CASE WHEN TT.ORD_CIG<>'' THEN '<CodiceCIG>'+RTRIM(TT.ORD_CIG)+'</CodiceCIG>' ELSE '' END AS CodiceCIG,
		CASE WHEN TT.ORD_CUP<>'' THEN '<CodiceCUP>'+RTRIM(TT.ORD_CUP)+'</CodiceCUP>' ELSE '' END AS CodiceCUP,
		DD.ORD_SYSFAT AS ORD_SYSFAT,
		DD.ORD_DESART  -- ERASMO - 22/01/2019
	FROM U_FAT_DD AS DD
	LEFT OUTER JOIN U_FAT_TT AS TT
	ON DD.DAGGANCIO=TT.TAGGANCIO
	--WHERE DD.ORD_QTAORD>0 AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'
	WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'  <<_COND_COMMENTI>>  -- ERASMO - 22/01/2019
	ORDER BY DD.ORD_SEQUEN

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"RIFERIMENTI_ORDINE")
	return(.F.)
ENDIF

SELECT RIFERIMENTI_ORDINE
DELETE FOR ORD_DESART = '*** COMMENTO ***'  && ERASMO - 22/01/2019
GO TOP
SCAN
	_NUMORD = DATIORDINEACQUISTOIDDOCUMENTO_DD
	_DATORD = STRTRAN(DATIORDINEACQUISTODATA_DD,"-","/")
	_SYSFAT = ORD_SYSFAT
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
		SELECT 
			ORD_NUMORC,
			REPLACE(ORD_DATORC,'/','-') AS ORD_DATORC,
			CASE WHEN ORD_CIG<>'' THEN '<CodiceCIG>'+RTRIM(ORD_CIG)+'</CodiceCIG>' ELSE '' END AS ORD_CIG,
			CASE WHEN ORD_CUP<>'' THEN '<CodiceCUP>'+RTRIM(ORD_CUP)+'</CodiceCUP>' ELSE '' END AS ORD_CUP
		FROM U_ORD_TT
		WHERE ORD_NUMORD='<<_NUMORD>>' AND ORD_DATORD='<<_DATORD>>'
	ENDTEXT					&& FINE SCRITTURA QUERY
	IF !ExecPreparedCommand(cSql,"TMP_ORD_TT")
		return(.F.)
	ENDIF
	SELECT TMP_ORD_TT
	GO TOP
	IF !EOF()
		SELECT TMP_ORD_TT
		IF !EMPTY(ORD_NUMORC) AND !EMPTY(ORD_DATORC)
			_NUMORC = ORD_NUMORC
			_DATORC = ORD_DATORC
			SELECT RIFERIMENTI_ORDINE
			REPLACE DATIORDINEACQUISTOIDDOCUMENTO WITH _NUMORC 
			REPLACE DATIORDINEACQUISTODATA WITH _DATORC 
		ENDIF
		SELECT TMP_ORD_TT
		IF !EMPTY(ORD_CIG)
			_CIG = ORD_CIG
			SELECT RIFERIMENTI_ORDINE
			REPLACE CodiceCIG WITH _CIG
		ENDIF
		SELECT TMP_ORD_TT
		IF !EMPTY(ORD_CUP)
			_CUP = ORD_CUP
			SELECT RIFERIMENTI_ORDINE
			REPLACE CodiceCUP WITH _CUP
		ENDIF
	ELSE
		IF !EMPTY(_SYSFAT)
			TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
				SELECT 
					ORD_NUMORC,
					CASE
						WHEN SUBSTRING(ORD_DATORC,3,1) = '/' AND SUBSTRING(ORD_DATORC,6,1) = '/' THEN REPLACE(DBO.RIBALTA2(ORD_DATORC),'/','-')
						ELSE REPLACE(ORD_DATORC,'/','-')
					END AS ORD_DATORC,
					CASE WHEN ORD_CIG<>'' THEN '<CodiceCIG>'+RTRIM(ORD_CIG)+'</CodiceCIG>' ELSE '' END AS ORD_CIG,
					CASE WHEN ORD_CUP<>'' THEN '<CodiceCUP>'+RTRIM(ORD_CUP)+'</CodiceCUP>' ELSE '' END AS ORD_CUP
				FROM BUDGET_CONS
				WHERE ORD_SYSFAT='<<_SYSFAT>>'
			ENDTEXT					&& FINE SCRITTURA QUERY
			IF !ExecPreparedCommand(cSql,"TMP_BUDGET_CONS")
				return(.F.)
			ENDIF
			SELECT TMP_BUDGET_CONS
			GO TOP
			IF !EOF()
				SELECT TMP_BUDGET_CONS
				IF !EMPTY(ORD_NUMORC) AND !EMPTY(ORD_DATORC)
					_NUMORC = ORD_NUMORC
					_DATORC = ORD_DATORC
					SELECT RIFERIMENTI_ORDINE
					REPLACE DATIORDINEACQUISTOIDDOCUMENTO WITH _NUMORC 
					REPLACE DATIORDINEACQUISTODATA WITH _DATORC 
				ENDIF
				SELECT TMP_BUDGET_CONS
				IF !EMPTY(ORD_CIG)
					_CIG = ORD_CIG
					SELECT RIFERIMENTI_ORDINE
					REPLACE CodiceCIG WITH _CIG
				ENDIF
				SELECT TMP_BUDGET_CONS
				IF !EMPTY(ORD_CUP)
					_CUP = ORD_CUP
					SELECT RIFERIMENTI_ORDINE
					REPLACE CodiceCUP WITH _CUP
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDSCAN

**=> ERASMO - INIZIO 14/01/2019
*** INCLUDO INIZIO E FINE TAG NELLA DATA ORDINE, IN QUANTO LA DATA POTREBBE NON ESSERE PRESENTE, E NON E' OBBLIGATORIA
SELECT RIFERIMENTI_ORDINE
GO TOP
SCAN
*!*		IF !EMPTY(DATIORDINEACQUISTODATA)
*!*			REPLACE DATIORDINEACQUISTODATA WITH "<Data>"+DATIORDINEACQUISTODATA+"</Data>"
*!*		ENDIF
	**=> ERASMO - INIZIO 28/01/2019
	IF !EMPTY(ALLTRIM(DATIORDINEACQUISTODATA))
		REPLACE DATIORDINEACQUISTODATA WITH "<Data>"+DATIORDINEACQUISTODATA+"</Data>"
	ELSE
		REPLACE DATIORDINEACQUISTODATA WITH ""
	ENDIF
	**=> ERASMO - INIZIO 28/01/2019
ENDSCAN
GO TOP
**=> ERASMO - FINE 14/01/2019

SELECT RIFERIMENTI_ORDINE
*DELETE FOR EMPTY(DATIORDINEACQUISTOIDDOCUMENTO+DATIORDINEACQUISTODATA+CodiceCIG+CodiceCUP)
DELETE FOR EMPTY(DATIORDINEACQUISTOIDDOCUMENTO)  && ERASMO - 14/01/2019
GO TOP

RETURN
* FINE PROCEDURE CREA_CURSOR_RIFERIMENTI_ORDINE
******************************************************************************
**=> ERASMO - FINE 07/11/2018


