******************************************************************************
PROCEDURE CREA_CURSOR_DATI_AZIENDA
******************************************************************************
*!*	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

*!*		SELECT * FROM U_AZI_AN

*!*	ENDTEXT					&& FINE SCRITTURA QUERY

**=> ERASMO - INIZIO 08/01/2019
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT AZI_CODFIS,AZI_PIVA,AZI_RAGSOC,AZI_INDIRI,AZI_CAP,AZI_LOCALI,AZI_TELEFO,AZI_FAX,
		CASE WHEN AZI_TELEFO = '' THEN '' ELSE '<Telefono>'+RTRIM(AZI_TELEFO)+'</Telefono>' END AS CEDENTEPRESTATORECONTATTITELEFONO,
		CASE WHEN AZI_FAX = '' THEN '' ELSE '<Fax>'+RTRIM(AZI_FAX)+'</Fax>' END AS CEDENTEPRESTATORECONTATTIFAX
	FROM U_AZI_AN

ENDTEXT					&& FINE SCRITTURA QUERY
**=> ERASMO - FINE 08/01/2019

IF !ExecPreparedCommand(cSql,"CU_AZIENDA")
	return(.F.)
ENDIF

**=> ERASMO - INIZIO 07/11/2018
SELECT CU_AZIENDA
GO TOP
REPLACE AZI_RAGSOC WITH PARSE_STRING_XML(AZI_RAGSOC)
REPLACE AZI_INDIRI WITH PARSE_STRING_XML(AZI_INDIRI)
REPLACE AZI_LOCALI WITH PARSE_STRING_XML(AZI_LOCALI)
**=> ERASMO - FINE 07/11/2018

**==> SERGIO 02/11/2018 - INIZIO
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT AZI_IDPAESE,AZI_PIVAIN,AZI_FORTRA,AZI_CODEORI,AZI_ALBO,AZI_PRVALBO,AZI_NUMISALBO,AZI_DTALBO,AZI_REGIMEFI,
		AZI_NRCIVICO,AZI_PROVINCIA,AZI_NAZION,AZI_UFFICIO,AZI_NRREA,AZI_CAPITSO,AZI_SOCIOU,AZI_STATOL,AZI_EMAIL,AZI_IDPAESEIN,
		AZI_PIVAIN,AZI_RAGSOCIN,AZI_SOGGEMIN,AZI_CONPAG,AZI_MODPAG,AZI_IBAN,AZI_IBANFAT,
		CASE WHEN AZI_CODEORI = '' THEN '' ELSE '<CodEORI>'+RTRIM(AZI_CODEORI)+'</CodEORI>' END AS CEDENTEPRESTATOREDATIANAGRAFICIANAGRAFICACODEORI,
		CASE WHEN AZI_CAPITSO = 0 THEN '' ELSE '<CapitaleSociale>'+CAST(CAST(AZI_CAPITSO AS NUMERIC(16,2)) AS VARCHAR(20))+'</CapitaleSociale>' END AS CEDENTEPRESTATOREISCRIZIONEREACAPITALESOCIALE,
		CASE WHEN AZI_ALBO = '' THEN '' ELSE '<AlboProfessionale>'+RTRIM(AZI_ALBO)+'</AlboProfessionale>' END AS CEDENTEPRESTATOREDATIANAGRAFICIALBOPROFESSIONALE,
		CASE WHEN AZI_PRVALBO = '' THEN '' ELSE '<ProvinciaAlbo>'+RTRIM(AZI_PRVALBO)+'</ProvinciaAlbo>' END AS CEDENTEPRESTATOREDATIANAGRAFICIPROVINCIAALBO,
		CASE WHEN AZI_NUMISALBO = '' THEN '' ELSE '<NumeroIscrizioneAlbo>'+RTRIM(AZI_NUMISALBO)+'</NumeroIscrizioneAlbo>' END AS CEDENTEPRESTATOREDATIANAGRAFICINUMEROISCRIZIONEALBO,
		CASE WHEN AZI_DTALBO = '' THEN '' ELSE '<DataIscrizioneAlbo>'+RTRIM(AZI_DTALBO)+'</DataIscrizioneAlbo>' END AS CEDENTEPRESTATOREDATIANAGRAFICIDATAISCRIZIONEALBO
	FROM U_AZI_PB

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"CU_AZIENDA_PB")
	return(.F.)
ENDIF
**==> SERGIO 02/11/2018 - FINE

**=> ERASMO - INIZIO 07/11/2018
SELECT CU_AZIENDA_PB
GO TOP
REPLACE AZI_UFFICIO WITH PARSE_STRING_XML(AZI_UFFICIO)
REPLACE AZI_SOGGEMIN WITH PARSE_STRING_XML(AZI_SOGGEMIN)
REPLACE AZI_RAGSOCIN WITH PARSE_STRING_XML(AZI_RAGSOCIN)

_ORD_IDSDI = ""
_ORD_CAUS = ""
_ORD_CODCLI = ""
SELECT HEADER_FATTURA_ELETTRONICA
GO TOP
IF !EOF()
	_ORD_IDSDI = ALLTRIM(ORD_IDSDI)
	_ORD_CAUS = ALLTRIM(ORD_CAUS)
	_ORD_CODCLI = ALLTRIM(ORD_CODCLI)
ENDIF

*!*	IF LEN(_ORD_IDSDI) <= 6
*!*		SELECT CU_AZIENDA_PB
*!*		GO TOP
*!*		REPLACE AZI_FORTRA WITH "FPA12"
*!*	ENDIF
*!*	IF LEN(_ORD_IDSDI) = 7
*!*		SELECT CU_AZIENDA_PB
*!*		GO TOP
*!*		REPLACE AZI_FORTRA WITH "FPR12"
*!*	ENDIF

_FORMATO_TRASMISSIONE = "FPR12"
IF _ORD_CAUS = "FVS"  && FORZATURA PER CARDIOLINE
	_FORMATO_TRASMISSIONE = "FPA12"
ELSE
	v_seek	= PUB_CODSOC + _ORD_CODCLI
	v_chiave = "cli_codsoc+cli_codcli"
	IF seek_std('u_ana_cl',v_seek,v_chiave,'CL_CLIENTE')
	   SELECT CL_CLIENTE
	   IF CLI_PA
	      _FORMATO_TRASMISSIONE = "FPA12"
	   ENDIF
	ENDIF
ENDIF

IF (EMPTY(_ORD_IDSDI) OR ALLTRIM(_ORD_IDSDI) $ '0000000#XXXXXXX') AND _FORMATO_TRASMISSIONE = "FPA12"
	MESSAGEBOX("Codice Destinatario obbligatorio per la fattura PA n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA,16,"Attenzione")
	_YES_CONTINUA = .F.
	RETURN .F.
ENDIF

SELECT CU_AZIENDA_PB
GO TOP
REPLACE AZI_FORTRA WITH _FORMATO_TRASMISSIONE

SELECT HEADER_FATTURA_ELETTRONICA
GO TOP
IF !EOF()
	v_seek 	 = 'CPA'+ALLTRIM(ORD_CPA)
	v_chiave = "codice"
	IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
	   SELECT CUR_PARA
	   _PAGANT = SUBSTR(LIBERA,252,1)
	   _SCADEN = ALLTRIM(SUBSTR(LIBERA,11,239))
	   _RATE = OCCURS(SPACE(1),_SCADEN)
	   SELECT CU_AZIENDA_PB
	   GO TOP
	   IF _RATE > 1
	      REPLACE AZI_CONPAG WITH "TP01"  && pagamento a rate
	   ELSE
	      IF _PAGANT = "S"
	         REPLACE AZI_CONPAG WITH "TP03"  && anticipo
	      ELSE
	         REPLACE AZI_CONPAG WITH "TP02"  && pagamento completo
	      ENDIF
	   ENDIF
	ENDIF
ENDIF
**=> ERASMO - FINE 07/11/2018

DO CERCA_IBAN_FATTURA_CLIENTE  && ERASMO - 07/11/2018

*!*	**=> ERASMO - INIZIO 14/01/2019
*!*	SELECT CU_AZIENDA_PB
*!*	IF EMPTY(AZI_IBAN) OR LEN(ALLTRIM(AZI_IBAN)) <> 27
*!*		MESSAGEBOX("Codice IBAN vuoto o non corretto per la fattura n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA,16,"Attenzione")
*!*		_YES_CONTINUA = .F.
*!*		RETURN .F.
*!*	ENDIF
*!*	**=> ERASMO - FINE 14/01/2019

DO CERCA_MODALITA_PAGAMENTO_FATTURA_CLIENTE  && ERASMO - 07/11/2018

RETURN
* FINE PROCEDURE CREA_CURSOR_DATI_AZIENDA
******************************************************************************



******************************************************************************
PROCEDURE CREA_CURSOR_HEADER_FATTURA_ELETTRONICA
******************************************************************************
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY TT.ORD_NUMORD)) AS NUMERIC(4,0)) AS NR_RIGA,  -- ERASMO - 14/01/2019
		TT.TAGGANCIO,  -- ERASMO - 14/12/2018
		TT.ORD_VALORE,
		TT.ORD_VALORE+ROUND(TT.I_OMAGGIO,2)+ROUND(TT.T_OMAGGIO,2) AS IMPORTOTOTALEDOCUMENTO,  -- ERASMO - 18/01/2019
		CASE --ORD_CAUS
			--WHEN 'FVS' THEN
			--	CASE
			--		WHEN (SELECT COUNT(*) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' AND ORD_IVA = 'SP') > 0 THEN 'S'
			--		ELSE 'D'
			--	END
			--ELSE 'I'
			WHEN (SELECT COUNT(*) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' AND ORD_IVA IN 
				(SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND NOIVACARCLI = 'S')) > 0 THEN 'S'  -- ERASMO - 07/11/2018
			ELSE 'I'  -- ERASMO - 07/11/2018
		END AS ESIGIBILITA_IVA,
		CASE
			--WHEN (SELECT COUNT(*) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' AND ORD_IVA = 'SP') > 0 THEN ORD_IMPONIB
			WHEN (SELECT COUNT(*) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' AND ORD_IVA IN 
				(SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND NOIVACARCLI = 'S')) > 0 THEN ORD_IMPONIB  -- ERASMO - 07/11/2018
			ELSE ORD_VALORE
		END AS IMPORTO_PAGAMENTO,
		--TT.ORD_VALORE/1.22 AS ORD_IMPONIB,
		ORD_IMPONIB,
		--ROUND(TT.ORD_VALORE*(1-1/1.22),2) AS ORD_IMPOSTA,
		ORD_IMPOSTA,
		--TT.ORD_INDIRI,
		SUBSTRING(TT.ORD_INDIRI,1,60) AS ORD_INDIRI,  -- ERASMO - 21/01/2019
		--TT.ORD_CAP,
		--SUBSTRING(TT.ORD_CAP,1,5) AS ORD_CAP,  -- ERASMO - 10/01/2019
		CASE 
			WHEN SUBSTRING(TT.ORD_CODNAZ,1,2) <> 'IT' AND (TT.ORD_CAP = '' OR ISNUMERIC(TT.ORD_CAP) = 0) THEN '99999'
			ELSE SUBSTRING(TT.ORD_CAP,1,5)
		END AS ORD_CAP,  -- ERASMO - 24/01/2019
		--TT.ORD_LOCALI,
		SUBSTRING(TT.ORD_LOCALI,1,60) AS ORD_LOCALI,  -- ERASMO - 21/01/2019
		TT.ORD_PROVIN,
		--TT.ORD_VARIE,
		--TT.ORD_CIG AS CodiceCIG,
		--CASE WHEN TT.ORD_CIG<>'' THEN '<CodiceCIG>'+RTRIM(TT.ORD_CIG)+'</CodiceCIG>' ELSE '' END AS CodiceCIG,  -- ERASMO/FABIANO - 05/07/2016
		--TT.ORD_CUP AS CodiceCUP,
		--CASE WHEN TT.ORD_CUP<>'' THEN '<CodiceCUP>'+RTRIM(TT.ORD_CUP)+'</CodiceCUP>' ELSE '' END AS CodiceCUP,  -- ERASMO/FABIANO - 11/08/2015
		CASE WHEN (SELECT COALESCE(SUBSTRING(LIBERA,11,1),'') FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS) = 'S' THEN 'TD04' ELSE 'TD01' END AS TIPODOCUMENTO,  -- ERASMO - 22/09/2015
		SUBSTRING(TT.ORD_DATORD,1,4)+'-'+SUBSTRING(TT.ORD_DATORD,6,2)+'-'+SUBSTRING(TT.ORD_DATORD,9,2) AS DatiGeneraliDocumentoData,
		TT.ORD_NUMORD AS DatiGeneraliDocumentoNumero,
		--SUBSTRING(TT.ORD_DATORC,1,4)+'-'+SUBSTRING(TT.ORD_DATORC,6,2)+'-'+SUBSTRING(TT.ORD_DATORC,9,2) AS DatiOrdineAcquistoData,
		--TT.ord_numorc AS DatiOrdineAcquistoIdDocumento,
		TT.ORD_VALUTA ,
		TT.ORD_PARIVA ,
		--TT.ORD_RAGSOC ,
		SUBSTRING(TT.ORD_RAGSOC,1,80) AS ORD_RAGSOC,  -- ERASMO - 21/01/2019
		--CASE RTRIM(TT.ORD_IDSDI) WHEN '' THEN (CASE RTRIM(TT.ORD_VARIE) WHEN '' THEN (CASE SUBSTRING(TT.ORD_CODNAZ,1,2) WHEN 'IT' THEN '0000000' ELSE 'XXXXXXX' END) 
		--	ELSE RTRIM(TT.ORD_VARIE) END) ELSE RTRIM(TT.ORD_IDSDI) END AS ORD_IDSDI ,  -- ERASMO - 07/11/2018
		CASE RTRIM(TT.ORD_IDSDI)
			WHEN '' THEN (
				CASE SUBSTRING(TT.ORD_CODNAZ,1,2)
					WHEN 'IT' THEN '0000000' 
					ELSE 'XXXXXXX' 
				END) 
			ELSE RTRIM(TT.ORD_IDSDI)
		END AS ORD_IDSDI ,  -- ERASMO - 21/01/2019
		CASE RTRIM(TT.ORD_EPEC) WHEN '' THEN '' ELSE ('<PECDestinatario>'+RTRIM(TT.ORD_EPEC)+'</PECDestinatario>') END AS ORD_EPEC ,  -- ERASMO - 07/11/2018	      
		TT.ORD_BANCA ,  -- ERASMO - 07/11/2018
		TT.ORD_CODCLI , -- ERASMO - 07/11/2018
		TT.ORD_CPA ,    -- ERASMO - 07/11/2018
		TT.ORD_CAUS ,   -- ERASMO - 07/11/2018
		TT.ORD_NUMORD ,   -- ERASMO - 15/01/2019
		TT.ORD_DATORD ,   -- ERASMO - 15/01/2019
		TT.ORD_NUMORD ,   -- ERASMO - 15/01/2019
		CASE SUBSTRING(TT.ORD_CODNAZ,1,2) WHEN 'IT' THEN 'IT' ELSE (SELECT RTRIM(LIBERA) FROM PARA WHERE CODICE = 'STA'+TT.ORD_CODNAZ) END AS ORD_IDPAESE,  -- ERASMO - 07/11/2018
		TT.ORD_VALUTA,   -- ERASMO - 07/11/2018
		CAST('' AS TEXT) AS ALLEGATI,  -- ERASMO - 28/11/2018
		CASE RTRIM(TT.ORD_PROVIN) WHEN '' THEN '' ELSE ('<Provincia>'+RTRIM(TT.ORD_PROVIN)+'</Provincia>') END AS CESSIONARIOCOMMITTENTESEDEPROVINCIA,  -- ERASMO - 08/01/2019
		CASE SUBSTRING(TT.ORD_CODNAZ,1,2)
			WHEN 'IT' THEN 
				CASE
					WHEN RTRIM(TT.ORD_PARIVA) = RTRIM((SELECT CLI_PARIVA FROM U_CLI_AN WHERE CLI_CODCLI = TT.ORD_CODCLI)) THEN '<IdFiscaleIVA><IdPaese>IT</IdPaese><IdCodice>'+RTRIM(TT.ORD_PARIVA)+'</IdCodice></IdFiscaleIVA>'	-- ERASMO - 16/01/2019
					WHEN RTRIM(TT.ORD_PARIVA) = RTRIM((SELECT CLI_CODFIS FROM U_CLI_AN WHERE CLI_CODCLI = TT.ORD_CODCLI)) THEN '<CodiceFiscale>'+RTRIM(TT.ORD_PARIVA)+'</CodiceFiscale>'											-- ERASMO - 16/01/2019
					ELSE '<IdFiscaleIVA><IdPaese>IT</IdPaese><IdCodice>'+RTRIM(TT.ORD_PARIVA)+'</IdCodice></IdFiscaleIVA>'																											-- ERASMO - 16/01/2019
				END																																																					-- ERASMO - 16/01/2019
				ELSE '<IdFiscaleIVA><IdPaese>'+(SELECT RTRIM(LIBERA) FROM PARA WHERE CODICE = 'STA'+TT.ORD_CODNAZ)+'</IdPaese><IdCodice>'+RTRIM(TT.ORD_PARIVA)+'</IdCodice></IdFiscaleIVA>'											-- ERASMO - 16/01/2019
		END AS CESSIONARIOCOMMITTENTEDATIANAGRAFICIIDFISCALEIVA	
	FROM U_FAT_TT AS TT
	WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'
	
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"HEADER_FATTURA_ELETTRONICA")
	return(.F.)
ENDIF

