      EXIT
   ENDIF

   IF SUBSTR(_DESART,V_IND,3) = 'TRA' 
      V_CODCOL = 'TRA'
      V_DESCOL = 'TRASPARENTE'
      V_TROV   = .T.
      EXIT
   ENDIF
   
