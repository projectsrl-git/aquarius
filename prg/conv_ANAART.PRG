*********************
PROCEDURE TOGLI_PUNTI
*********************

YY      = LEN(V_CAMPO)
XX      = 1
Y_CAMPO =  ' '
DO WHILE .T.
   IF XX > YY
      EXIT
   ENDIF
   IF SUBSTR(V_CAMPO,XX,1) = '.' 
   ELSE
      Y_CAMPO = Y_CAMPO + SUBSTR(V_CAMPO,XX,1) 
   ENDIF
   XX = XX + 1
ENDDO

RETURN


**********************
PROCEDURE CERCA_COLORE
**********************

PARAMETERS _CODART,_DESART

V_TROV   = .F.
V_IND    = 1
V_MAX    = LEN(ALLTRIM(_CODART))

DO WHILE .T.

   IF V_IND > V_MAX
      EXIT
   ENDIF
   
   IF SUBSTR(_CODART,V_IND,3) = 'B/N' 
      V_CODCOL = 'B/N'
      V_DESCOL = 'BIANCO/NERO'
      V_TROV   = .T.
      EXIT
   ENDIF
   
   IF SUBSTR(_CODART,V_IND,3) = 'BLU' 
      V_CODCOL = 'BLU'
      V_DESCOL = 'BLU'
      V_TROV   = .T.
      EXIT
   ENDIF
   
   IF SUBSTR(_CODART,V_IND,3) = 'GIA' 
      V_CODCOL = 'GIA'
      V_DESCOL = 'GIALLO'
      V_TROV   = .T.
      EXIT
   ENDIF

   IF SUBSTR(_CODART,V_IND,3) = 'RSA' 
      V_CODCOL = 'RSA'
      V_DESCOL = 'ROSA'
      V_TROV   = .T.
      EXIT
   ENDIF

   IF SUBSTR(_CODART,V_IND,2) = 'RS' .OR. SUBSTR(_CODART,V_IND,4) = 'ROSE'
      V_CODCOL = 'RSE'
      V_DESCOL = 'ROSč'
      V_TROV   = .T.
      EXIT
   ENDIF

   IF SUBSTR(_CODART,V_IND,3) = 'VER' 
      V_CODCOL = 'VER'
      V_DESCOL = 'VERDE'
      V_TROV   = .T.
      EXIT
   ENDIF

   IF SUBSTR(_CODART,V_IND,3) = 'BIA' 
      V_CODCOL = 'BIA'
      V_DESCOL = 'BIANCO'
      V_TROV   = .T.
      EXIT
   ENDIF

   IF SUBSTR(_CODART,V_IND,3) = 'ARA' 
      V_CODCOL = 'ARA'
      V_DESCOL = 'ARANCIONE'
      V_TROV   = .T.
      EXIT
   ENDIF

   IF SUBSTR(_CODART,V_IND,3) = 'V/N' .OR. SUBSTR(_CODART,V_IND,3) = 'VN' 
      V_CODCOL = 'V/N'
      V_DESCOL = 'VERDE/NERO'
      V_TROV   = .T.
      EXIT
   ENDIF

   IF SUBSTR(_CODART,V_IND,3) = 'VBN'
      V_CODCOL = 'VBN'
      V_DESCOL = 'VERDE/BIANCO/NERO'
      V_TROV   = .T.
      EXIT
   ENDIF

   V_IND = V_IND + 1
   
ENDDO

IF V_TROV
   RETURN
ENDIF

V_TROV   = .F.
V_IND    = 1
V_MAX    = LEN(ALLTRIM(_DESART))

DO WHILE .T.

   IF V_IND > V_MAX
      EXIT
   ENDIF
   
