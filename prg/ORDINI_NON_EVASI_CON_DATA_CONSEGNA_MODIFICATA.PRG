************************************
* ORDINI_NON_EVASI_CON_DATA_CONSEGNA_MODIFICATA
************************************

LPARAMETERS _GIORNI_PRECEDENTI

IF PCOUNT()<1
	RETURN .F.
ENDIF

SET STEP ON 

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO,V_GIORNI_PRECEDENTI
PUBLIC V_TITOLO,V_GIORNI_PRECEDENTI

V_GIORNI_PRECEDENTI = _GIORNI_PRECEDENTI

V_TITOLO	= "Ordini non evasi con data di consegna modificata"

WAIT WINDOWS "ESEGUE PROGRAMMA ORDINI_NON_EVASI_CON_DATA_CONSEGNA_MODIFICATA" TIMEOUT 3

*** REPORT RIEPILOGO
cSql=""     
cNomeCursorSql="CU_ORDINATO"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 	
		CODICE_CLIENTE,
		CLIENTE,
		NUM_ORDINE,
		DATA_ORDINE_RIBALTATA, 
		DATA_ORDINE,
		CENTRO_COSTO,
		DESCRIZIONE_CENTRO_COSTO,
		DATA_CONSEGNA_RIBALTATA,
		DATA_CONSEGNA,
		(SELECT TOP 1 VALORE_PREC FROM LOG_EVENTI WHERE TIPO_EVENTO='ORDINI' AND CAMPO_MODIFICATO='DATA CONSEGNA' AND DATA_EVENTO = convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111)  AND COD_USER='ZAMBONI' AND DESCRIZIONE NOT LIKE 'ARTICOLO .%' AND NUM_ORDINE=SUBSTRING(GRUPPO_EVENTO,8,6)) AS DATA_PREC,
		MOTIVAZIONE,
		SUM(VALORE) AS VALORE
	FROM ORDINI_NON_EVASI
	WHERE NUM_ORDINE IN (SELECT SUBSTRING(GRUPPO_EVENTO,8,6) AS NUMORD FROM LOG_EVENTI WHERE TIPO_EVENTO='ORDINI' AND CAMPO_MODIFICATO='DATA CONSEGNA' AND DATA_EVENTO = convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111)  AND COD_USER='ZAMBONI' AND DESCRIZIONE NOT LIKE 'ARTICOLO .%' )
	GROUP BY CENTRO_COSTO,DESCRIZIONE_CENTRO_COSTO,CODICE_CLIENTE,CLIENTE,NUM_ORDINE,DATA_ORDINE_RIBALTATA,DATA_ORDINE,DATA_CONSEGNA_RIBALTATA,DATA_CONSEGNA,MOTIVAZIONE
	ORDER BY DESCRIZIONE_CENTRO_COSTO,CLIENTE,NUM_ORDINE,MOTIVAZIONE


ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


SELECT CU_ORDINATO

_PDF_REPORT_ 		=ALLTRIM(CERCAREPO("XXX","ORDINI_NON_EVASI_CON_DATA_CONSEGNA_MODIFICATA","ORDINI_NON_EVASI_CON_DATA_CONSEGNA_MODIFICATA.FRX"))
_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "CU_ORDINATO"

IF !EMPTY(_PDF_SUBDIR_ )
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
