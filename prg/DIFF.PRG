*************************
PROCEDURE IVATOTCDIFF 
*************************
* TOTALI IVA CLIENTI A FRONTE DI FATTURE IN DIFFERITA CREATE AUTOMATICAMENTE DAI DDT    *
   
SELECT IVA_CL

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
REPLACE RIGAT     WITH SPACE(50)
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666777
REPLACE CHIAVE_R  WITH "TOC"

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
REPLACE RIGAT     WITH SPACE(50)
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666777
REPLACE CHIAVE_R  WITH "TOC"

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
RIGA_D=SPACE(50)

REPLACE RIGAT     WITH REPLICATE(PUB_CAROR,124) 
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666777
REPLACE CHIAVE_R  WITH "TOC"

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
PERI=MESE_C + " " +ANNO
REPLACE RIGAT     WITH "				SEZIONE VENDITE RELATIVA AL PERIODO " + PERI
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666777
REPLACE CHIAVE_R  WITH "TOC"

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
RIGA_D=SPACE(50)
REPLACE RIGAT     WITH REPLICATE(PUB_CAROR,124) 
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 777777
REPLACE CHIAVE_R  WITH "TOC"

*** >>>>>  TOTALI IVA CLIENTI 
VD_IMPONI = 0
VD_IMPOST = 0
CD_IMPONI = 0
CD_IMPOST = 0


IMPONIB_FD = 0  && IVE FATTURE
IMPOSTA_FD = 0
IMPONIB_ND = 0  && IVE NOTE CREDITO
IMPOSTA_ND = 0
IMPONIB_CD = 0  && IVE CORRISPETTIVI
IMPOSTA_CD = 0
IMPONIB_XD = 0  && IVE INDEDUCIBILI
IMPOSTA_XD = 0

x_soci = "ito_codsoc = '" + PUB_CODSOC + "'"
x_anno = "ito_anno = '" + ANNO + "'"
x_mese = "ito_mese >= '" + MESE_DAL + "'"
x_tipo = "(ito_clifor = 'D')"
x_cond = x_soci + " and " + x_anno + " and " + x_mese + " and " + x_tipo
CSQL   = "select * from u_iva_to where " + x_cond + " order by ito_codsoc,ito_anno,ito_mese,ito_clifor" 
IF !ExecCommand(CSQL,"u_iva_to")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_TO
GO TOP

DO WHILE .T. 

   IF EOF()
      EXIT
   ENDIF

   IF ITO_MESE < MESE_DAL .OR. ITO_MESE > MESE_AL
      SKIP + 1
      LOOP
   ENDIF


   IF PUB_NFATDIFFERITA
	   IF ITO_CLIFOR <> "D"   && ELABORA SOLO I MOVIMENTI RELATIVI ALLE FATTURE CREATE AUTOMATICAMENTE DA DDT
	      SKIP +1
	   	  LOOP
	   ENDIF
   ENDIF

   V_CODIVA  = ITO_CODIVA 
   V_FATNOT  = ITO_FATNOT 
   V_DESIVA  = ITO_DESIVA
   VD_IMPONI = ITO_IMPONI
   VD_IMPOST = ITO_IMPOST
   V_IND100  = ITO_IND100
 
   v_seek	= 'IVA'+V_CODIVA
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      TIPOIVA   = SUBSTR(LIBERA,100,1)
   ELSE
      TIPOIVA   = " "
   ENDIF

   SELECT U_IVA_TO
 
   IF TIPOIVA <> "I"
      IF V_FATNOT = "F" 
         IMPONIB_FD =  IMPONIB_FD  + ITO_IMPONI  && IVE FATTURE
         IMPOSTA_FD =  IMPOSTA_FD  + ITO_IMPOST
      ENDIF 
   ENDIF  

   IF TIPOIVA <> "I"
      IF V_FATNOT = "N" 
         IMPONIB_ND =  IMPONIB_ND  + ITO_IMPONI  && IVE NOTE CREDITO
         IMPOSTA_ND =  IMPOSTA_ND  + ITO_IMPOST
      ENDIF 
   ENDIF 

   IF TIPOIVA <> "I"
      IF V_FATNOT = "C" 
         IMPONIB_CD =  IMPONIB_CD  + ITO_IMPONI  && IVE CORRISPETTIVI
         IMPOSTA_CD =  IMPOSTA_CD  + ITO_IMPOST
      ENDIF 
   ENDIF 

   IF TIPOIVA = "I" 
      IMPONIB_XD =  IMPONIB_XD  + ITO_IMPONI  && IVE INDEDUCIBILI 
      IMPOSTA_XD =  IMPOSTA_XD  + ITO_IMPOST
   ENDIF 

   SELECT IVA_CL
   PUB_RIGA = PUB_RIGA + 1   
   IF PUB_RIGA > SALTO_PAG
      DO IVATESTO             && TESTATA BOLLATO
   ENDIF

   SELECT IVA_CL
   APPEND BLANK
 
   IF ALLTRIM(V_FATNOT) = "N"
  	  S_IMPONI = VD_IMPONI * -1
	  S_IMPOST = VD_IMPOST * -1
   ELSE
	  S_IMPONI = VD_IMPONI 
	  S_IMPOST = VD_IMPOST 
   ENDIF

   RIGA_D = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
   RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(S_IMPONI,"999,999,999,999.99"),1,18) 
   RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(S_IMPOST,"999,999,999,999.99"),1,18)

   REPLACE RIGAT       WITH RIGA_D 
   REPLACE RIGA        WITH SPACE(50)
   REPLACE CHIAVE      WITH 666777
   REPLACE CHIAVE_R    WITH "TOC"

   REPLACE ITO_CODIVA  WITH V_CODIVA 
   REPLACE ITO_FATNOT  WITH V_FATNOT 
   REPLACE ITO_DESIVA  WITH V_DESIVA
   REPLACE ITO_IMPONI  WITH VD_IMPONI
   REPLACE ITO_IMPOST  WITH VD_IMPOST
   REPLACE ITO_IND100  WITH V_IND100
  
   SELECT U_IVA_TO
   SKIP + 1

ENDDO

SELECT IVA_CL

* AZZERO L'IVA INDEDUC. PERCHE' NON DEVE ESSERE TOLTA DAL TOTALE MA SOLO NON FIGURARE

IMPONIB_XD=0
IMPOSTA_XD=0

** TOTALI IVA CLIENTI
** ==================

SELECT IVA_CL
PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
   PUB_RIGA = PUB_RIGA + 1
   APPEND BLANK
   RIGA_D=SPACE(50)
   REPLACE RIGAT     WITH REPLICATE(PUB_CAROR,124) 
   REPLACE RIGA      WITH SPACE(50)
   REPLACE CHIAVE    WITH 666777
   REPLACE CHIAVE_R  WITH "TOC"
   PUB_RIGA = PUB_RIGA + 1
   APPEND BLANK 
   PERI=MESE_C + " " +ANNO
   REPLACE RIGAT     WITH "				SEZIONE VENDITE RELATIVA AL PERIODO " + PERI
   REPLACE RIGA      WITH SPACE(50)
   REPLACE CHIAVE    WITH 666777
   REPLACE CHIAVE_R  WITH "TOC"
ENDIF

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
RIGA_D=SPACE(50)
REPLACE RIGAT     WITH REPLICATE(PUB_CAROR,124) 
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 777777
REPLACE CHIAVE_R  WITH "TOC"

APPEND BLANK
REPLACE IMPONI    WITH IMPONIB_FD - IMPONIB_ND - IMPONIB_XD
REPLACE IMPOST    WITH IMPOSTA_FD - IMPOSTA_ND - IMPOSTA_XD

REPLACE CHIAVE_R  WITH "TOC"
REPLACE CHIAVE    WITH 666777

** SOMMA IVA VENDITE + CORRISPETTIVI - NOTE CREDITO
**=================================================
VD_IMPONI = IMPONIB_FD + IMPONIB_CD - IMPONIB_ND - IMPONIB_XD
VD_IMPOST = IMPOSTA_FD + IMPOSTA_CD - IMPOSTA_ND - IMPOSTA_XD
CD_IMPONI = IMPONIB_FD + IMPONIB_CD - IMPONIB_ND - IMPONIB_XD
CD_IMPOST = IMPOSTA_FD + IMPOSTA_CD - IMPOSTA_ND - IMPOSTA_XD

V_IMPONI = V_IMPONI + VD_IMPONI 
V_IMPOST = V_IMPOST + VD_IMPOST 
C_IMPONI = C_IMPONI + CD_IMPONI 
C_IMPOST = C_IMPOST + CD_IMPOST 


RIGA_D = " >>>>> TOTALI GENERALI   " 
RIGA_D = RIGA_D + SPACE(12) + " | " + SUBSTR(TRANSFORM(VD_IMPONI,"999,999,999,999.99"),1,18)
RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(VD_IMPOST,"999,999,999,999.99"),1,18) 
REPLACE RIGAT     WITH RIGA_D 
REPLACE RIGA      WITH SPACE(50)

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
RIGA_D=SPACE(50)
REPLACE CHIAVE_R  WITH "TOC"
REPLACE RIGAT     WITH REPLICATE(PUB_CAROR,124) 
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666777

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
  DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
REPLACE CHIAVE_R  WITH "TOC"
REPLACE RIGAT     WITH SPACE(50)
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666777

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
REPLACE CHIAVE_R  WITH "TOC"
REPLACE RIGAT     WITH SPACE(50)
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666777

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
REPLACE CHIAVE_R  WITH "TOC"
REPLACE RIGAT     WITH SPACE(50)
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666777

RETURN
