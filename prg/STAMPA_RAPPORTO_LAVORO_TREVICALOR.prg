WAIT WINDOWS "ESEGUE PROGRAMMA STAMPA_RAPPORTO_LAVORO_TREVICALOR" NOWAIT  && ERASMO - 23/04/2025

x_soci = "TT.ORD_CODSOC = '" + PUB_CODSOC + "'"
IF !EMPTY(ALLTRIM(_AGGANCIO))
	x_agga = "TT.TAGGANCIO = '" + _AGGANCIO + "'"
ELSE
	x_agga = "TT.ORD_DTPROGR = '" + RIBALTA2(DTOC(DATE())) + "'"
ENDIF
x_cond = x_soci + " and " + x_agga

cSql=""
cNomeCursorSql="SEL_RAPPORTO_LAVORO"
TEXT TO cSql NOSHOW
	SELECT
		SPACE(10) AS SELEZIONE,
		TAGGANCIO
		,ORD_NUMORD
		,ORD_DATORD
		,ORD_CODCLI
		,ORD_RAGSOC
		,ORD_DTPROGR
		,ORD_CCODSCHE
		,COALESCE(MIN(ORD_ORAINIPRO),'') AS ORD_ORAINIPRO
	FROM (
		SELECT
			 TT.*
			,DT.ORD_ORAINIPRO
		FROM VENDITE_TT AS TT
		LEFT OUTER JOIN VENDITE_DT AS DT ON DT.DAGGANCIO = TT.TAGGANCIO
		WHERE <<X_COND>>
	) AS MAIN
	GROUP BY
		TAGGANCIO
		,ORD_NUMORD
		,ORD_DATORD
		,ORD_CODCLI
		,ORD_RAGSOC
		,ORD_DTPROGR
		,ORD_CCODSCHE
	ORDER BY ORD_DTPROGR,ORD_ORAINIPRO
ENDTEXT

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

