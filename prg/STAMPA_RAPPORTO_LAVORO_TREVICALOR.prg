SELECT SEL_RAPPORTO_LAVORO
GO TOP
DO WHILE .T.
	 
	IF EOF()
		EXIT
	ENDIF
	 
	IF DELETED()
		SKIP +1
		LOOP
	ENDIF
	 
*!*		IF SELEZIONE = "==>"
*!*		ELSE
*!*			SKIP +1
*!*			LOOP
*!*		ENDIF

	_XX_DATORD = ORD_DATORD
	_XX_NUMORD = ORD_NUMORD
	_XX_CODCLI = ORD_CODCLI
	_XX_AGGANC = TAGGANCIO  && ERASMO - 07/11/2024
	
	x_soci = "ord_codsoc = '" + PUB_CODSOC + "'"
	x_dord = "ord_datord = '" + _XX_DATORD + "'"
	x_nord = "ord_numord = '" + _XX_NUMORD + "'"
	x_agga = "taggancio = '" + _XX_AGGANC + "'"  && ERASMO - 07/11/2024
	*x_cond = x_soci + " and " + x_dord + " and " + x_nord
	x_cond = x_soci + " and " + x_dord + " and " + x_nord + " and " + x_agga  && ERASMO - 07/11/2024
	cSql	= "select * from VENDITE_TT where " + x_cond
	IF !ExecCommand(cSql,"CVENDITE_TT")
		return(.f.)
	ENDIF
	SELECT CVENDITE_TT
	DELETE FOR ORD_CODCLI <> _XX_CODCLI
	GO TOP
	SCATTER MEMVAR MEMO
	
	*THISFORM.cerca_dettagli()
	
	IF USED("U_DOC_DD")
		SELECT U_DOC_DD
		USE
	ENDIF

	SELECT &_V_ARCH_STA
	SET FILTER TO
	SET ORDER TO
	ZAP

	** RIEMPIE IL CURSORE DI TUTTI I DETTAGLI DOCUMENTO  --------------------------------------------------------------*
	x_agga = "daggancio = '" + M.TAGGANCIO + "'"
	x_cond = x_agga
	Csql = "select * from VENDITE_DD where " + x_cond + " order by ord_sequen"  
	IF !ExecCommand(cSql,"U_DOC_DD")
		return(.f.)
	ENDIF
	SELECT U_DOC_DD
	GO TOP

	DO WHILE .T.

		IF EOF()
			EXIT
		ENDIF

		IF DELETED()
			SKIP +1
			LOOP
		ENDIF
		
		SCATTER MEMVAR MEMO
		
		SELECT &_V_ARCH_STA
		APPEND BLANK
		
		M.ORS_NUMORD = M.ORD_NUMORD 
		M.ORS_DATORD = M.ORD_DATORD 
		M.ORS_CODCLI = M.ORD_CODCLI		 
		
		DO &_V_ARCH_DD
			
		SELECT U_DOC_DD
		SKIP +1

	ENDDO
	
	SELECT CVENDITE_TT
	GO TOP
	SCATTER MEMVAR MEMO
	
	_cPROGRAMMA__ = "INRPJITA_SMALL"
	_cREPORTNEW__ = "INRPJITA.FRX"
	_cREPORT__    = ALLTRIM(CERCAREPO("XXX",_cPROGRAMMA__,_cREPORTNEW__))
	_V_OPZSTA     = 999
	
	SELECT CVENDITE_TT
	DO RISTA_INR WITH _cREPORT__
	
	IF !EMPTY(ALLTRIM(FILE_PDF_APPENA_GENERATO)) AND FILE(FILE_PDF_APPENA_GENERATO,1)
		_FILE_PDF_APPENA_GENERATO_NEW = ALLTRIM(_PDF_DIRECTORY_) + '\' + JUSTFNAME(FILE_PDF_APPENA_GENERATO)
		_run = 'MOVE "' + ALLTRIM(FILE_PDF_APPENA_GENERATO) + '" "' + ALLTRIM(_PDF_DIRECTORY_) + '"'
		RUN &_run
		IF FILE(_FILE_PDF_APPENA_GENERATO_NEW,1)
		
			**=> ERASMO - INIZIO 10/01/2025
			*** SE PASSATO NEI PARAMETRI, RINOMINO IL FILE GENERATO
			IF !EMPTY(_NOMEFILE)
				_FILE_PDF_APPENA_GENERATO_NEW_RENAMED = JUSTPATH(_FILE_PDF_APPENA_GENERATO_NEW) + "\" + _NOMEFILE
				_cmd = 'RENAME "' + _FILE_PDF_APPENA_GENERATO_NEW + '" TO "' + _FILE_PDF_APPENA_GENERATO_NEW_RENAMED + '"'
				&_cmd
				IF FILE(_FILE_PDF_APPENA_GENERATO_NEW_RENAMED,1)
					_FILE_PDF_APPENA_GENERATO_NEW = _FILE_PDF_APPENA_GENERATO_NEW_RENAMED
				ENDIF				
			ENDIF  
			**=> ERASMO - FINE 10/01/2025
		
			_ALLEGATI_MAIL = ALLTRIM(_ALLEGATI_MAIL) + IIF(EMPTY(ALLTRIM(_ALLEGATI_MAIL)),"",";") + JUSTFNAME(ALLTRIM(_FILE_PDF_APPENA_GENERATO_NEW))
		ELSE
			_ERRORE = .T.
		ENDIF
	ELSE
		_ERRORE = .T.
	ENDIF
		
	SELECT SEL_RAPPORTO_LAVORO
	SKIP +1

ENDDO

