
****************************************
* CARDIOLINE_FR_SINCRONIZZA_ARTICOLI
****************************************

LPARAMETERS _par_db_sorgente,_par_group_codsys

IF PCOUNT() >= 1
ELSE
	MESSAGEBOX("Parametri di ingresso insufficienti",16,"Attenzione")
	RETURN .F.
ENDIF

IF PCOUNT() >= 2
ELSE
	_par_group_codsys = ""
ENDIF

_CONTA_INS = 0
_CONTA_AGG = 0

_MSG_WARNINGS = ""

_LOG_CODSYS = IIF(EMPTY(_par_group_codsys),SYS(2015),_par_group_codsys)
_LOG_OGGETTO = "ARTICOLI"
_LOG_DATA = RIBALTA2(DTOC(DATE()))
_LOG_ORA = TIME()
_LOG_DB_SORGENTE = _par_db_sorgente
_LOG_CODOPE = ALLTRIM(PUB_CODOPE)
_LOG_NOMOPE = ALLTRIM(PUB_NOMOPE)

_SEC_INI = SECONDS()

*** SCRITTURA RECORD TABELLA LOG_DBSYNC
cSql = "select * from LOG_DBSYNC where 1=0"
IF !ExecRW(cSql,"LOG_DBSYNC","R")
   return(.f.)
ENDIF
SELECT LOG_DBSYNC
APPEND BLANK
REPLACE CODSYS WITH _LOG_CODSYS
REPLACE OGGETTO WITH _LOG_OGGETTO
REPLACE DATA WITH _LOG_DATA
REPLACE ORA WITH _LOG_ORA
REPLACE DB_SORGENTE WITH _LOG_DB_SORGENTE
REPLACE ESITO WITH ""
REPLACE MESSAGGIO WITH "ELABORAZIONE"
REPLACE NRECINS WITH 0
REPLACE NRECAGG WITH 0
REPLACE TEMPO_IMPIEGATO WITH 0
REPLACE CODOPE WITH _LOG_CODOPE
REPLACE NOMOPE WITH _LOG_NOMOPE
	
IF !ExecRW(cSql,"LOG_DBSYNC","W")
   return(.f.)
ENDIF

*** COMPONGO I CURSORI DI APPOGGIO CHE CONTERRANNO I DATI DEGLI ARTICOLI
cSql = "select * from U_ART_PR where 1=0"
IF !ExecCommand(cSql,"CU_ART_PR")
   return(.f.)
ENDIF
INDEX ON ART_CODPRI TAG I_CODPRI

cSql = "select * from U_ART_AN where 1=0"
IF !ExecCommand(cSql,"CU_ART_AN")
   return(.f.)
ENDIF
INDEX ON ART_CODPRI TAG I_CODPRI

*** ELABORAZIONE ARTICOLI SU DB SORGENTE INSERITI O MODIFICATI RISPETTO ALL'ULTIMA SINCRONIZZAZIONE ANDATA A BUON FINE
WAIT WINDOWS "Lettura articoli su db sorgente '" + _LOG_DB_SORGENTE + "' inseriti o modificati rispetto all'ultima sincronizzazione..." NOWAIT

_ULT_TS_SYNC_ART = ""
cSql   = "SELECT TOP 1 LAST_DATE FROM (SELECT DATA+ORA AS LAST_DATE FROM LOG_DBSYNC WHERE OGGETTO = '" + _LOG_OGGETTO + "' AND ESITO = 'OK' UNION SELECT '1950/01/0100:00:00' AS LAST_DATE) AS T ORDER BY LAST_DATE DESC"
IF !ExecCommand(cSql,"ULT_TS_SYNC_ART")
	return(.f.)
ENDIF
SELECT ULT_TS_SYNC_ART
GO TOP
_ULT_TS_SYNC_ART = LAST_DATE

IF !SwicthDBConnection(ALLTRIM(_LOG_DB_SORGENTE))
   MESSAGEBOX("DataBase sorgente '" + _LOG_DB_SORGENTE + "' inesistente o non raggiungibile",16,"Attenzione")
   IF !SetHomeDB()
      RETURN(.f.)
   ENDIF
   RETURN .F.
ENDIF

*_ULT_TS_SYNC_ART = '1950/01/0100:00:00'  && ###TEST### TUTTI GLI ARTICOLI ###TEST###

x_vend = "(PR.ART_PRZVEN > 0 OR PR.ART_PRZVE2 > 0 OR AN.ART_NOLISLCK = 1)"
x_date = "PR.ART_CODPRI <> '' AND (CASE AN.MOD_DATREG WHEN '' THEN (AN.REG_DATREG+CASE AN.REG_ORAREG WHEN '' THEN '23:59:59' ELSE AN.REG_ORAREG END) ELSE AN.MOD_DATREG+CASE AN.MOD_ORAREG WHEN '' THEN '23:59:59' ELSE AN.MOD_ORAREG END END) > '" + _ULT_TS_SYNC_ART + "'"
x_cond = x_vend + " AND " + x_date
cSql=""     
cNomeCursorSql="TMP_ART_PR"
TEXT TO cSql NOSHOW
	SELECT PR.* FROM U_ART_PR AS PR
	LEFT OUTER JOIN U_ART_AN AS AN ON AN.ART_CODPRI = PR.ART_CODPRI
	WHERE <<x_cond>>
	ORDER BY PR.ART_CODPRI
ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	IF !SetHomeDB()
		RETURN(.f.)
	ENDIF
	return(.F.)
ENDIF
SELECT TMP_ART_PR
GO TOP
SCAN
	SCATTER MEMVAR MEMO
	SELECT CU_ART_PR
	APPEND BLANK
	GATHER MEMVAR MEMO
ENDSCAN

x_vend = "(AN.ART_NOLISLCK = 1 OR AN.ART_CODPRI IN (SELECT ART_CODPRI FROM U_ART_PR WHERE ART_PRZVEN > 0 OR ART_PRZVE2 > 0))"
x_date = "AN.ART_CODPRI <> '' AND (CASE AN.MOD_DATREG WHEN '' THEN (AN.REG_DATREG+CASE AN.REG_ORAREG WHEN '' THEN '23:59:59' ELSE AN.REG_ORAREG END) ELSE AN.MOD_DATREG+CASE AN.MOD_ORAREG WHEN '' THEN '23:59:59' ELSE AN.MOD_ORAREG END END) > '" + _ULT_TS_SYNC_ART + "'"
x_cond = x_vend + " AND " + x_date
cSql=""     
cNomeCursorSql="TMP_ART_AN"
TEXT TO cSql NOSHOW
	SELECT AN.* FROM U_ART_AN AS AN
	WHERE <<x_cond>>
	ORDER BY AN.ART_CODPRI
ENDTEXT

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	IF !SetHomeDB()
		RETURN(.f.)
	ENDIF
	return(.F.)
ENDIF
SELECT TMP_ART_AN
GO TOP
SCAN
	SCATTER MEMVAR MEMO
	SELECT CU_ART_AN
	APPEND BLANK
	GATHER MEMVAR MEMO
ENDSCAN

IF !SetHomeDB()
	RETURN(.f.)
ENDIF

SELECT CU_ART_PR
GO TOP
SCAN
	
	WAIT WINDOWS "Elaborazione articolo " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + " in corso (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT
	
	SCATTER MEMVAR MEMO
	
	SELECT CU_ART_AN
	SET FILTER TO ART_CODPRI = M.ART_CODPRI
	GO TOP
	IF !EOF()
		SCATTER MEMVAR MEMO
	ELSE
		SCATTER MEMVAR MEMO BLANK
	ENDIF
	
	x_cond = "ART_CODPRI = '" + M.ART_CODPRI + "'"
	cSql = "SELECT * FROM U_ART_PR WHERE " + x_cond
	IF !ExecRW(cSql,"U_ART_PR","R")
		return(.f.)
	ENDIF
	SELECT U_ART_PR
	GO TOP
	IF EOF()
		APPEND BLANK
		_CONTA_INS = _CONTA_INS + 1
	ELSE
		_CONTA_AGG = _CONTA_AGG + 1
	ENDIF
	DO U_ART_PR
	IF !ExecRW(cSql,"U_ART_PR","W")
		return(.f.)
	ENDIF
		
	x_cond = "ART_CODPRI = '" + M.ART_CODPRI + "'"
	cSql = "SELECT * FROM U_ART_AN WHERE " + x_cond
	IF !ExecRW(cSql,"U_ART_AN","R")
		return(.f.)
	ENDIF
	SELECT U_ART_AN
	GO TOP
	IF EOF()
		APPEND BLANK
	ENDIF
	DO U_ART_AN
	IF !ExecRW(cSql,"U_ART_AN","W")
		return(.f.)
	ENDIF
	
ENDSCAN

_MESSAGGIO = ""
IF _CONTA_INS > 0
	_MESSAGGIO = _MESSAGGIO + IIF(EMPTY(_MESSAGGIO),"",CHR(13)+CHR(10)) + "Totale articoli inseriti: " + ALLTRIM(STR(_CONTA_INS))
ELSE
	_MESSAGGIO = _MESSAGGIO + IIF(EMPTY(_MESSAGGIO),"",CHR(13)+CHR(10)) + "Nessun articolo inserito"
ENDIF
IF _CONTA_AGG > 0
	_MESSAGGIO = _MESSAGGIO + IIF(EMPTY(_MESSAGGIO),"",CHR(13)+CHR(10)) + "Totale articoli aggiornati: " + ALLTRIM(STR(_CONTA_AGG))
ELSE
	_MESSAGGIO = _MESSAGGIO + IIF(EMPTY(_MESSAGGIO),"",CHR(13)+CHR(10)) + "Nessun articolo aggiornato"
ENDIF

cSql = "select * from LOG_DBSYNC WHERE OGGETTO = '" + _LOG_OGGETTO + "' AND CODSYS = '" + _LOG_CODSYS + "'"
IF !ExecRW(cSql,"LOG_DBSYNC","R")
   return(.f.)
ENDIF
SELECT LOG_DBSYNC
GO TOP
IF !EOF()
	REPLACE ESITO WITH "OK"
	REPLACE MESSAGGIO WITH ALLTRIM(_MSG_WARNINGS) + IIF(EMPTY(_MSG_WARNINGS),"",CHR(13)+CHR(10)) + _MESSAGGIO
	REPLACE NRECINS WITH _CONTA_INS
	REPLACE NRECAGG WITH _CONTA_AGG
	_SEC_FIN = SECONDS()
	REPLACE TEMPO_IMPIEGATO WITH ROUND(_SEC_FIN - _SEC_INI, 0)
ENDIF
IF !ExecRW(cSql,"LOG_DBSYNC","W")
   return(.f.)
ENDIF

WAIT CLEAR

IF EMPTY(ALLTRIM(_par_group_codsys))
	MESSAGEBOX(_MESSAGGIO,64,"Informazione",5000)
ENDIF

_OK_SYNC_ARTICOLI = .T.
			
RETURN .T.
