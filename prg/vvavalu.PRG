* CREA VALUTE PER I PAESI EURO SU TUTTO L'ANNO APERTO

SS=STR(SELECT())

v_seek	 = PUB_CODSOC
v_chiave = "azi_codsoc"
IF seek_std('u_azi_an',v_seek,v_chiave,'CUR_AZIENDA')
   SELECT CUR_AZIENDA
   SCATTER MEMVAR MEMO
ELSE
   OK_NFAGE = .F.
   WAIT WINDOW "Per cortesia codifica il parametro bollati iva"
   RETURN
ENDIF

PUB_CAMBIO = 1

_VALUTA=PUB_VALRIF

v_seek	 = "VVA"+_VALUTA
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   PUB_CAMBIO = VAL(ALLTRIM(LIBERA))
ELSE	
   =MESSAGEBOX('Anno contabile : '+PUB_ANNO+CHR(13)+'valuta euro inesistente '+CHR(13)+'inserirlo per cortesia '+CHR(13)+'FORZO IL CAMBIO SU EUR = 1',64,'*** ATTENZIONE ***') 
   PUB_CAMBIO = 1
ENDIF

DT_INI = "01/01/"+PUB_ANNO

FOR H= 1 TO 365
    DT_INI = DTOC(CTOD(DT_INI) + 1)
    IF RIBALTA2(DT_INI) < RIBALTA2(DATADAL)
       LOOP
    ENDIF   
    IF RIBALTA2(DT_INI) > RIBALTA2(DATAAL)
       LOOP
    ENDIF   

    WAIT WINDOWS "Sto creando le valute per il giorno :"+ DT_INI nowait
    
	=AQUAVALU(M.AZI_VAL01,DT_INI) 
	=AQUAVALU(M.AZI_VAL02,DT_INI) 
	=AQUAVALU(M.AZI_VAL03,DT_INI) 
	=AQUAVALU(M.AZI_VAL04,DT_INI) 
	=AQUAVALU(M.AZI_VAL05,DT_INI) 
	=AQUAVALU(M.AZI_VAL06,DT_INI) 
	=AQUAVALU(M.AZI_VAL07,DT_INI) 
	=AQUAVALU(M.AZI_VAL08,DT_INI) 
	=AQUAVALU(M.AZI_VAL09,DT_INI) 
	=AQUAVALU(M.AZI_VAL10,DT_INI) 
	=AQUAVALU(M.AZI_VAL11,DT_INI) 
	=AQUAVALU(M.AZI_VAL12,DT_INI) 
	=AQUAVALU(M.AZI_VAL13,DT_INI) 
	=AQUAVALU(M.AZI_VAL14,DT_INI) 
	=AQUAVALU(M.AZI_VAL15,DT_INI) 
	=AQUAVALU(M.AZI_VAL16,DT_INI) 
	=AQUAVALU(M.AZI_VAL17,DT_INI) 
*!*		=AQUAVALU(M.AZI_VAL18,DT_INI) 
*!*		=AQUAVALU(M.AZI_VAL19,DT_INI) 
