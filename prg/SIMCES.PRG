SELECT CUR_SIMUL
GO TOP

DO CASE
	CASE ORD_STAMPA = 1
		XORDER = "ORD_NUCESP"
	CASE ORD_STAMPA = 2
		XORDER = "ORD_DTUTIL, CAM_CATEG"
	CASE ORD_STAMPA = 3
		XORDER = "CAM_CATEG, CAM_DESCR"
ENDCASE

********** CONTROLLO MODIFICHE
PROVAX = .F.

SELECT XCURSORE
GO TOP

DO WHILE !EOF()
	IF C_FLAG = .T.
		PROVAX = .T.
		EXIT
	ELSE
		SKIP + 1
	ENDIF
ENDDO

IF PROVAX = .F.
	=MESSAGEBOX("Non è stato effettuato nessun cambiamento!!",62,"ATTENZIONE")
	RETURN
ENDIF

********** CONTROLLO MODIFICHE

SELECT XCURSORE
GO TOP
IF _RIEPILOGO = 0
	IF !EOF()
*!*			DO PRG\MENUSTA WITH "XCURSORE",.T.,.F.,"XXX","SIMCES","SIMCES.FRX"

		REPORT FORM \COVERTEC\REPORT\SIMCES.FRX  PREVIEW   && TO PRINTER   

	ELSE
		=MESSAGEBOX("Nessun record da stampare!",62,"ATTENZIONE")
	ENDIF
ELSE

	TEXT TO staSql NOSHOW
		SELECT *, SUM(C_VALORE) AS TOTVALORE, SUM(C_QUOTA) AS TOTQUOTA, SUM(C_QUOTAORI) AS TOTQUOTAORI FROM XCURSORE GROUP BY C_CATEG ORDER BY C_CATEG INTO CURSOR STACURSORE
	ENDTEXT
	
	&staSql

	SELECT STACURSORE
	GO TOP
	IF !EOF()
		DO PRG\MENUSTA WITH "STACURSORE",.T.,.F.,"XXX","SIMCES1","SIMCES1.FRX"
	ELSE
		=MESSAGEBOX("Nessun record da stampare!",62,"ATTENZIONE")
	ENDIF

ENDIF
