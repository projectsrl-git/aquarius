*!*	_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 

_ALLEGATI = ""
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI,_ID_EMAIL_DA_INVIARE,_CORPO2


SELECT(_SAVE_SEL )
	
