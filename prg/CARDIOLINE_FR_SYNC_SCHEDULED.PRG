****************************************
* CARDIOLINE_FR_SYNC_SCHEDULED
****************************************

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO
PUBLIC V_TITOLO

V_TITOLO = "Sincronizzazione dati Cardioline IT -> Cardioline FR"

WAIT WINDOWS "ESEGUE PROGRAMMA CARDIOLINE_FR_SYNC_SCHEDULED" TIMEOUT 3

SET PROCEDURE TO PRG\APPLILIB ADDITIVE
SET PROCEDURE TO PRG\XLSLIB	ADDITIVE
SET PROCEDURE TO PRG\REPLIB	ADDITIVE
*SET PROCEDURE TO PRG\WINLIB ADDITIVE
SET PROCEDURE TO PRG\PROJLIB ADDITIVE
SET PROCEDURE TO PRG\AQMLIB ADDITIVE
SET PROCEDURE TO PRG\CONTABILELIB ADDITIVE

RELEASE PUB_ANNO,PUB_CARORF,PUB_DECQTA,PUB_SKART,PUB_FORMAR,PUB_BOLLA,PUB_MAGPDMVERS,PUB_SCPPDMSPED,PUB_SPASCA,PUB_SCAPPT,PUB_INTXLS, ;
	PUB_MASTRO,PUB_SOTTOG,PUB_LCL,PUB_CONTO,PUB_CC,PUB_CTRCLOR,PUB_BFO,PUB_MPIU,PUB_MMEN,PUB_CAPAGL,PUB_CAUCAL,PUB_CACARI,PUB_CACATA,PUB_CACART,PUB_CASCLE,PUB_CAPRNO,PUB_CAPPDMVERS,PUB_CAPPDMSPED,PUB_CAPPMIVERS,PUB_MAGNO0
PUBLIC PUB_ANNO,PUB_CARORF,PUB_DECQTA,PUB_SKART,PUB_FORMAR,PUB_BOLLA,PUB_MAGPDMVERS,PUB_SCPPDMSPED,PUB_SPASCA,PUB_SCAPPT,PUB_INTXLS, ;
	PUB_MASTRO,PUB_SOTTOG,PUB_LCL,PUB_CONTO,PUB_CC,PUB_CTRCLOR,PUB_BFO,PUB_MPIU,PUB_MMEN,PUB_CAPAGL,PUB_CAUCAL,PUB_CACARI,PUB_CACATA,PUB_CACART,PUB_CASCLE,PUB_CAPRNO,PUB_CAPPDMVERS,PUB_CAPPDMSPED,PUB_CAPPMIVERS,PUB_MAGNO0
PUB_ANNO = SUBSTR(DTOC(DATE()),7,4)
PUB_CARORF = ""
PUB_DECQTA = 0
PUB_SKART = .F.
PUB_FORMAR = ""
PUB_BOLLA = ""
PUB_MAGPDMVERS = ""
PUB_SCPPDMSPED = ""
PUB_SPASCA = ""
PUB_SCAPPT = ""
PUB_INTXLS = .F.
PUB_MASTRO = 0
PUB_SOTTOG = 0
PUB_LCL = 0
PUB_CONTO = 0
PUB_CC = ""
PUB_CTRCLOR = .F.
PUB_BFO = ""
PUB_MPIU = ""
PUB_MMEN = ""
PUB_MAGNO0 = ""

Csql = "SELECT * FROM RES_OPER WHERE CODICE = '" + PUB_CODOPE + "'"
IF !ExecCommand(cSql,'CU_RES_OPER')
	return(.f.)
ENDIF
SELECT CU_RES_OPER
GO TOP
IF !EOF()
	PUB_NOMOPE = DESCRI
ENDIF

Csql = "SELECT * FROM U_AZI_AN"
IF !ExecCommand(cSql,'CU_AZI_AN')
	return(.f.)
ENDIF
SELECT CU_AZI_AN
GO TOP
IF !EOF()
	PUB_CARORF = AZI_CARORF
	PUB_DECQTA = AZI_DECQTA
	PUB_SKART = AZI_SKART
	PUB_FORMAR = AZI_FORMAR
	PUB_BOLLA = AZI_BOLLA
	PUB_MASTRO = AZI_MASTRO   && GRUPPO CONTABILITA GENERALE       + 1
	PUB_SOTTOG = AZI_SOTTOG   && SOTTOGRUPPO CONTABILITA GENERALE  + 1
	PUB_LCL    = AZI_CONTO    && CONTO CONTABILE
	PUB_CONTO  = AZI_CONTO
	IF PUB_MASTRO <> 0
	   PUB_MASTRO = PUB_MASTRO + 1
	ELSE
	   PUB_MASTRO = 4
	ENDIF
	IF PUB_SOTTOG <> 0
	   PUB_SOTTOG = PUB_SOTTOG + 1
	ELSE
	   PUB_SOTTOG = 6
	ENDIF
	IF PUB_LCL = 0					&& valore giŕ impostato e valido anche per i clienti/fornitori
	   PUB_LCL = (14 - PUB_SOTTOG)
	ENDIF
	PUB_BFO = AZI_BFO
ENDIF

Csql = "SELECT * FROM U_AZI_PA"
IF !ExecCommand(cSql,'CU_AZI_PA')
	return(.f.)
ENDIF
SELECT CU_AZI_PA
GO TOP
IF !EOF()
	PUB_MAGPDMVERS = AZI_MAGPDMVERS
	PUB_SPASCA = AZI_SPASCA
	PUB_SCAPPT = AZI_SCAPPT
	PUB_MPIU = AZI_MPIU
	PUB_MMEN = AZI_MMEN
	PUB_CAPAGL = AZI_CAPAGL
	PUB_CAUCAL = AZI_CAUCAL
	PUB_CACARI = AZI_CACARI
	PUB_CACATA = AZI_CACATA
	PUB_CACART = AZI_CACART
	PUB_CASCLE = AZI_CASCLE
	PUB_CAPRNO = AZI_CAPRNO
	PUB_CAPPDMVERS = AZI_CAPPDMVERS
	PUB_MAGNO0 = AZI_MAGNO0
ENDIF

Csql = "SELECT * FROM U_AZI_PB"
IF !ExecCommand(cSql,'CU_AZI_PB')
	return(.f.)
ENDIF
SELECT CU_AZI_PB
GO TOP
IF !EOF()
	PUB_SCPPDMSPED = AZI_SCPPDMSPED
	PUB_INTXLS = AZI_INTXLS	
	PUB_CTRCLOR = AZI_CTRCLOR
	PUB_CAPPDMSPED = AZI_CAPPDMSPED
	PUB_CAPPMIVERS = AZI_CAPPMIVERS
ENDIF

_ERRORE = .F.
_LOG_GROUP_CODSYS = SYS(2015)
_CORPO2 = ""

*** PRE-CONTROLLO ELABORAZIONI PENDENTI
cSql = "SELECT * FROM LOG_DBSYNC WHERE ESITO = '' AND SUBSTRING(MESSAGGIO,1,12) = 'ELABORAZIONE'"
IF !ExecCommand(cSql,"TMP_CTRL_DBSYNC")
	return(.F.)
ENDIF
SELECT TMP_CTRL_DBSYNC
GO TOP
IF !EOF()
	_ERRORE = .T.
	_CORPO2 = V_TITOLO + REPLICATE(CHR(13)+CHR(10),2) + "Sono in corso una o piů elaborazioni pendenti, schedulazione annullata"
ELSE
	
	_OK_SYNC_ARTICOLI = .F.
	DO PRG\CARDIOLINE_FR_SINCRONIZZA_ARTICOLI WITH "CARDIOLINE",_LOG_GROUP_CODSYS
	IF !_OK_SYNC_ARTICOLI
		_ERRORE = .T.
	ENDIF
	Csql = "SELECT * FROM LOG_DBSYNC WHERE CODSYS = '" + _LOG_GROUP_CODSYS + "' AND OGGETTO = 'ARTICOLI'"
	IF !ExecCommand(cSql,'TMP_LOG_DBSYNC')
		return(.f.)
	ENDIF
	SELECT TMP_LOG_DBSYNC
	GO TOP
	IF !EOF()
		_CORPO2 = ALLTRIM(_CORPO2) + IIF(!EMPTY(ALLTRIM(_CORPO2)),REPLICATE(CHR(13)+CHR(10),2),"") + V_TITOLO + "(esito " + ALLTRIM(ESITO) + "):"
		_CORPO2 = ALLTRIM(_CORPO2) + CHR(13)+CHR(10) + ALLTRIM(MESSAGGIO)
	ENDIF
	
	_OK_SYNC_GIACENZE = .F.
	DO PRG\CARDIOLINE_FR_SINCRONIZZA_GIACENZE WITH "CARDIOLINE",_LOG_GROUP_CODSYS
	IF !_OK_SYNC_GIACENZE
		_ERRORE = .T.
	ENDIF
	Csql = "SELECT * FROM LOG_DBSYNC WHERE CODSYS = '" + _LOG_GROUP_CODSYS + "' AND OGGETTO = 'GIACENZE'"
	IF !ExecCommand(cSql,'TMP_LOG_DBSYNC')
		return(.f.)
	ENDIF
	SELECT TMP_LOG_DBSYNC
	GO TOP
	IF !EOF()
		_CORPO2 = ALLTRIM(_CORPO2) + IIF(!EMPTY(ALLTRIM(_CORPO2)),REPLICATE(CHR(13)+CHR(10),2),"") + V_TITOLO + "(esito " + ALLTRIM(ESITO) + "):"
		_CORPO2 = ALLTRIM(_CORPO2) + CHR(13)+CHR(10) + ALLTRIM(MESSAGGIO)
	ENDIF
	

ENDIF

