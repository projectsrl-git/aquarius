*****************************************************************************************************************
* XXX_FILIN     = NOME FILE DI INPUT DA ELABORARE
* XXX_PREVIEW   = FLAG .T. O .F. PER ANTEPRIMA
* XXX_STAMPA    = FLAG .T. O .F. PER STAMPARE
* XXX_TIPO      = PARAMETRO TIPO PER RICERCARE REPORT SU CERCAREPO
* XXX_PROGRAMMA = PARAMETRO NOME PROGRAMMA PER RICERCARE REPORT SU CERCAREPO
* XXX_REPORT    = PARAMETRO NOME REPORT PER RICERCARE REPORT SU CERCAREPO
* XXX_OKXLS     = PARAMETRO CHE ABILITA O DISABILITA LA POSSIBILITA' DI CONVERSIONI EXCEL && ERASMO 16/05/2006
* XXX_TITFORM   = PARAMETRO CHE ASSEGNA UNA CAPTION PERSONALIZZATA AL MODULO DI STAMPA
* XXX_REPBEHAV  = TIPO DI COMPORTAMENTO PER IL RENDERING DEL REPORT SI STAMPA: 80 (NORMALE); 90 (OBJECT ASSISTED)
*****************************************************************************************************************

PARA XXX_FILIN,XXX_PREVIEW,XXX_STAMPA,XXX_TIPO,XXX_PROGRAMMA,XXX_REPORT,XXX_OKXLS,XXX_TITFORM,XXX_REPBEHAV,XXX_NOPDF

_NUM_PAR = PARAMETERS()

IF _NUM_PAR <= 7
	XXX_TITFORM = "Modulo di stampa"
ENDIF 
	
IF _NUM_PAR <= 6
   	XXX_OKXLS = .F.
	XXX_TITFORM = "Modulo di stampa"
ENDIF

**=> ERASMO - INIZIO 13/05/2013
IF _NUM_PAR <= 8
   	XXX_REPBEHAV = 80
ENDIF
**=> ERASMO - FINE 13/05/2013

**=> ERASMO - INIZIO 23/03/2016
IF _NUM_PAR <= 9
   	XXX_NOPDF = .F.
ENDIF
**=> ERASMO - FINE 23/03/2016

RELEASE YYY_FILIN,YYY_PREVIEW,YYY_STAMPA,YYY_TIPO,YYY_PROGRAMMA,YYY_REPORT,YYY_FILOUT,YYY_OKXLS,YYY_TITFORM
PUBLIC  YYY_FILIN,YYY_PREVIEW,YYY_STAMPA,YYY_TIPO,YYY_PROGRAMMA,YYY_REPORT,YYY_FILOUT,YYY_OKXLS,YYY_TITFORM

*!*	*!*	SERGIO 2007-10-22 PER PROBLEMATICHE DI DRIVER WINDOWS FUNZIONA O ANTEPRIMA O STAMPA , MAI ENTRAMBI INSIEME
*!*	IF XXX_STAMPA AND XXX_PREVIEW
*!*		XXX_STAMPA = .F.
*!*	ENDIF
*!*	*!*	SERGIO 2007-10-22 PER PROBLEMATICHE DI DRIVER WINDOWS FUNZIONA O ANTEPRIMA O STAMPA , MAI ENTRAMBI INSIEME

YYY_FILIN     = XXX_FILIN
YYY_PREVIEW   = XXX_PREVIEW
YYY_STAMPA    = XXX_STAMPA
YYY_TIPO      = XXX_TIPO
YYY_PROGRAMMA = XXX_PROGRAMMA
YYY_REPORT    = XXX_REPORT
YYY_OKXLS     = XXX_OKXLS && ERASMO 16/05/2006
YYY_TITFORM   = XXX_TITFORM && SIMONE 12/10/2007
YYY_NOPDF     = XXX_NOPDF && ERASMO 23/03/2016

SET REPORTBEHAVIOR XXX_REPBEHAV  && ERASMO - 13/05/2013

YYY_FILOUT    = CERCAREPO("XXX",YYY_PROGRAMMA,YYY_REPORT)
IF YYY_FILOUT <> "NNN"
   DO FORM FORM\MENUSTA_SUWAMA WITH YYY_FILIN,YYY_FILOUT,YYY_PREVIEW,YYY_STAMPA,YYY_OKXLS,YYY_TITFORM,YYY_NOPDF
ENDIF

RETURN


