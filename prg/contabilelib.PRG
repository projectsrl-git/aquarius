GO TOP

SELECT(AABBSXSKK)
RETURN



*****************************************************************************************
*	 						 AGGIORNA IL PARTITARIO FORNITORI		           		    *
*****************************************************************************************			
* FUNZIONE GENERALIZZATA PER AGGIORNARE IL PARTITARIO FORNITORI
*
* LA FUNZIONE COMPORTA DIVERSE TIPOLOGIE DI AGGIORNAMENTO SENZA ALTERARE IL LEGAME CON LA PRIMA NOTA
* FUNZIONALITA' :
*
*   - CAMBIA LA DATA DI SCADENZA DELLA RIGA DELLA PARTITA
*   - CAMBIA L'IMPORTO DELLA SINGOLA RIGA DELLA PARTITA
*   - CREA UNA ULTERIORE RIGA DI PARTITA CON IMPORTO E NUOVA SCADENZA (SENZA ALTERARE IL TOTALE DELLA PARTITA ORIGINALE)
*   - CONTRAGGIORNA IL RECORD 100 DELLA PARTITA RIPORTANDO LA NUOVA DATA ULTIMA DI SCADENZA ???????
*   - CONTROAGGIORNA IL TOTALE DELLA PARTITA NEL CASO DI INSERIMENTO DI NUOVE SCADENZE + IMPORTI SENZA ALTERARE QUINDI IL TOTALE ORIGINALE
*   - SI SALVA LE VECCHIE DATE DI SCADENZA ED IMPORTI NELLA TABELLA SCADENZE_POST
*   - RICREA I SALDI DELLA PARTITA
*
*
* PARAMETRI DELLA FUNZIONE
* _cf = C : CLIENTI
*       F : FORNITORI
*
* _codcli = codice del cliente o del fornitore
*
* _npart  = numero partita cliente fornitore
*
* _dtscad = data di scadenza della singola riga della partita
*
* _estrai =
*           AGGIORNA    : AGGIORNA I SALDI SUI PARTITARI
*           ANNU    	: ANNULLA TUTTI I SALDI DELLA PARTITA 			
*
*
* _cursoragg = cursore di aggiornamento del partitario riportante le condizioni di aggiornamento
*
*    regole di scrittura del cursore _cursoragg :
*
*	 flag sesposto = .t. e l'importo quantpag = totale della partita originale cambia semplicemente la scadenza della partita
*
*	 flag sesposto = .t. e l'importo quantpag = ripartita sulle tranche (da 1 a 5 non tutte sono obbligatorie)
*                          la funzione crea delle nuove tranche di scadenza in funzione della scadenza
*                          raggruppando nel caso l'importo della scadenza se nella partita esistono piů date di
*                          scadenza ugauali
*
*	 la somma degli importi memorizzati in tutte le tranche quantpag  devono formare il totale della partita originale
*                          (questo controllo č a carico del VIP o di chi usa la routin)
*
*

FUNCTION AGGIORNA_PARTITARI_CF
PARA _cf,_codcli,_npart,_dtscad,_estrai,_cursoragg


AABBSXS  = SELECT()


		
		DO CASE

   			CASE _estrai = "AGGIORNA"

			
            *!*	 DEFINIZIONE DEL CRSORE DI SUPPORTO PER LO STORICO DELLE SCADENZE

				IF !ExecRW("select * from scapos_for where 0=1","scapos_for","R")
				  return(.f.)
				ENDIF

            *!*	 DEFINIZIONE DEL CURSORE DI SUPPORTO PER LO SDOPPIAMENTO DEI RECORD

				IF !ExecCommand("select * from PART_FOR where 0=1","CSPART_FOR")
				  return(.f.)
				ENDIF


			*!*		ESTARE TUTTA LA PARTITA
				__condi__="PAR_NPART = ?_NPART AND PAR_CODCLI = ?_CODCLI "  && SOLO LE RIGHE DI SCADENZA MIRATE DELLA PARTITA

				cSql="SELECT *"+" FROM PART_FOR WHERE " + __condi__ +" order by PAR_CODCLI"

				IF !ExecRW(cSql,"PART_FOR","R")
				   return(.f.)
				ENDIF


			*!*		AGGIORNA IL PARTITARIO CAMBIANDO IMPORTI
		

				=CAMBIA_LA_SINGOLA_SCADENZA(_dtscad,_cursoragg,"PART_FOR")				


			*!*		RICREA I SALDI DELLA PARTITA
*!*	2008-05-30 SERGIO/SIMONE - NO SALDI
*!*					=CREA_SALDI_CF(_cf,_codcli,_npart,"XXXXXXXXXX","CREA")
*!*					
								



		ENDCASE




SELECT(AABBSXS)
RETURN



*****************************************************************************************
*	  AGGIORNA IL PARTITARIO CAMBIANDO LA SINGOLA SCADENZA			           		    *
*****************************************************************************************			
* FUNZIONE GENERALIZZATA PER AGGIORNARE IL PARTITARIO FORNITORI
*
*  	_dtscad 		:	data di scadenza originale
*	_cursoragg		: 	cursore contenente i valori da cambiare sul partitario
*	_cursordaagg	:	dati effettivi del partitario
*
*
*

FUNCTION CAMBIA_LA_SINGOLA_SCADENZA
PARA _dtscad,_cursoragg,_cursordaagg

AABBSyS  = SELECT()



		=AGGIORNA_SCADENZA_IMPORTO(_dtscad,_cursoragg,"PART_FOR")


		*!*		AGGIORNAMENTO PARTITARI / POSTICIPI

		SELECT &_cursordaagg
		GO top

		IF !ExecRW('','part_for','I','','&_cursordaagg')
		   return(.f.)
		ENDIF

		SELECT SCAPOS_FOR
		GO top

		IF !ExecRW('','SCAPOS_FOR','I','','SCAPOS_FOR')
		   return(.f.)
		ENDIF




SELECT(AABBSyS)
RETURN







*****************************************************************************************
*	 						 AGGIORNA LA DATA DI SCADENZA E L'IMPORTO          		    *
*****************************************************************************************			
*	COPIA LA PARTITA NEL CURSORE MODIFICANDOLO SECONDO LE SEGUENTI CASISTICHE :
*	SE ATTIVO SOLO cxsesposto MODIFICA LA DATA DI SCADENZA 								
*	SE ATTIVO cxsepago E cxsesposto E L'IMPORTO E' DIVERSO DALL'IMPORTO ORIGINALE :
*			DUPLICA IL RECORD LASCIANDO LA DIFFERENZA SULLA SCADENZA ORIGINALE 			
*			RIPORTA LA DATA DI SCADENZA NUOVA SUL NUOVO RECORD E L'IMPORTO DA DA PGARE DELIBERATO
*


FUNCTION AGGIORNA_SCADENZA_IMPORTO
PARA _dtscad,_cursoragg,_cursordaagg



		__TDARE 		= 0
		__TAVERE 		= 0	
		__CONTARIFD  	= 0
		__CONTARIFA  	= 0

		SELECT &_cursordaagg
		GO TOP
		
		DO WHILE !EOF()
		
		
			  	SCATTER MEMVAR MEMO
			
			    IF PAR_NPROG = 100

					SELECT &_cursordaagg
					SKIP +1
					LOOP

			    ENDIF
		
				
				IF PAR_DTSCAD = RIBALTA2(_dtscad)		&&  SCADENZA TROVATA : AGGIORNO CREANDO ULTERIORI SCADENZE

					_SALDO_SCADENZA = 0
					=CERCA_NUOVA_SCADENZA_IMPORTO(_dtscad,_cursoragg,"PART_FOR")
					=CALCOLA_DIFFERENZA(_dtscad,_cursoragg,"PART_FOR")

				ENDIF

				SELECT &_cursordaagg
				SKIP +1


		ENDDO



		=RAGGRUPPA_SCADENZE(_dtscad,_cursoragg,"PART_FOR")




RETURN




*****************************************************************************************
*	 						 AGGIORNA LA DATA DI SCADENZA E L'IMPORTO          		    *
*****************************************************************************************			


FUNCTION CERCA_NUOVA_SCADENZA_IMPORTO
PARA _dtscad,_cursoragg,_cursordaagg


		SELECT &_cursoragg		&& CURSORE CONTENENTE I RIFERIMENTI DELLE NUOVE EVENTUALI SCADENZE
		GO TOP


		_trovato  		= 0
		_ctx  			= 5
		_combinazioni 	= 1
		cxachescad    	= _dtscad
		
		FOR _combinazioni = 1 TO _ctx
			
			cxsesposto    = "C"+STR(_combinazioni,1,0) +"sesposto"
			cxachescad    = "C"+STR(_combinazioni,1,0) +"achescad"

			cxsepago      = "C"+STR(_combinazioni,1,0) +"sepago"
			cxquantpag    = "C"+STR(_combinazioni,1,0) +"quantpag"
			cxmotivo	  = "C"+STR(_combinazioni,1,0) +"motivo"
			cxnomope	  = "C"+STR(_combinazioni,1,0) +"nomope"
						
		   	IF &cxsesposto

				m.cxachescad    = &cxachescad
				m.cxquantpag   	= &cxquantpag
				m.cxmotivo		= &cxmotivo
				m.cxnomope		= &cxnomope
								
				=CREA_NUOVE_SCADENZE(_dtscad,_cursoragg,"PART_FOR")
		   		
		   	ENDIF


			
			SELECT &_cursoragg
			GO TOP

						
		ENDFOR



RETURN





*****************************************************************************************
*	 		 CREA LE NUOVE SCADENZE SALVANDOLE NEL CURSORE DI APPOGGIO         		    *
*****************************************************************************************			

FUNCTION CREA_NUOVE_SCADENZE
PARA _dtscad,_cursoragg,_cursordaagg





	    SELECT &_cursordaagg									&& PARTITARIO
		SCATTER MEMVAR MEMO 									&& SI SALVA IL RECOD PRIMA

		SELECT CSPART_FOR										&& SI SALVA LA NUOVA SCADENZA NEL CURSORE DI APPOGGIO
		APPEND BLANK
		GATHER MEMVAR MEMO
		_SALDO_SCADENZA     = _SALDO_SCADENZA + m.cxquantpag	&& SOMMA GLI IMPORTI DI TUTTE LE NUOVE SCADENZE
		
		IF m.cxquantpag <> 0
			REPLACE PAR_FATT 	WITH m.cxquantpag				&& NUOVO IMPORTO PAGATO
		ENDIF
		
		REPLACE par_DTSCAD 	WITH RIBALTA2(m.cxachescad)			&& NUOVA DATA DI SCADENZA
		REPLACE id_unique 	WITH " "							&& RIPULISCE LA CHIAVE ORIGINALE


		SELECT SCAPOS_FOR										&& CREA CURSORE DEI POSTICIPI
	    APPEND BLANK
	    GATHER MEMVAR MEMO					
		REPLACE NEW_DTSCAD 	WITH RIBALTA2(m.cxachescad)			&& NUOVA DATA DI SCADENZA
		REPLACE PAR_DTPOST 	WITH RIBALTA2(DTOC(DATE()))			&& DATA DI QUANDO AVVIENE IL POSTICIPO
		REPLACE PAR_MOTIVO 	WITH m.cxmotivo						&& MOTIVO DEL POSTICIPO
		REPLACE PAR_NOMOPE 	WITH m.cxnomope						&& EFFETTUATO/AUTORIZZATO




RETURN


*****************************************************************************************
*	 						CALCOLA LA DIFFERENZA E AGGIORNA IL PARTITARIO     		    *
*****************************************************************************************			


FUNCTION CALCOLA_DIFFERENZA
PARA _dtscad,_cursoragg,_cursordaagg



		SELECT &_cursordaagg


		DO CASE
		
			CASE PAR_FATT > _SALDO_SCADENZA

				_DIFFE = PAR_FATT - _SALDO_SCADENZA
				REPLACE PAR_FATT 	WITH _DIFFE	&& IMPORTO DATO DALLA DIFFERENZA TRA VECCIO SALDO E NUOVO SALDO DELLE SCADENZE DESIDERATE
		
			CASE PAR_FATT = _SALDO_SCADENZA
				DELETE 				&& CANCELLA IL RECORD DEL PARTITARIO IN QUANTO SOSTITUITO DALLE NUOVE SCADENZE
		
			CASE PAR_FATT < _SALDO_SCADENZA
				_DIFFE = _SALDO_SCADENZA - PAR_FATT
