RETURN


*************************************************************************
*  		 CONTROAGGIORNA SALDI IN PREVISIONALE                           *
*************************************************************************

PROCEDURE REG_CONTROAGGIORNA_SALDI_PREVISIONALE_CONTI



		      P_IMPA= PRE_IMP_A
		      P_IMPD= PRE_IMP_D
		      IF M.TOP = "CHI"
		         MESE    = "12"
		      ELSE
		         MESE    = SUBSTR(DATAREG,4,2)
		      ENDIF
		      VAR     = "PRE_AV"+MESE
		      VAR2    = "PRE_DA"+MESE

		      CLI_FOR = SUBSTR(CON_TIPOCO,1,1)


			  * CHI_EUR_ITL
			  IF M.TOP = "CHI"
			     REPLACE   PRE_IMP_D   WITH P_IMPD-CAMBIO(PUB_VALPRE,____DARE,PUB_CAMPRE)
		         REPLACE   PRE_IMP_A   WITH P_IMPA-CAMBIO(PUB_VALPRE,____AVERE,PUB_CAMPRE)
		         REPLACE   &VAR2       WITH CAMBIO(PUB_VALPRE,____DARE,PUB_CAMPRE)-&VAR2
		    	 REPLACE   &VAR        WITH CAMBIO(PUB_VALPRE,____AVERE,PUB_CAMPRE)-&VAR
			  ELSE	
			     REPLACE   PRE_IMP_D   WITH P_IMPD-CAMBIO(XVALUTA,____DARE,XCAMBIO)
		         REPLACE   PRE_IMP_A   WITH P_IMPA-CAMBIO(XVALUTA,____AVERE,XCAMBIO)
		         REPLACE   &VAR2       WITH CAMBIO(XVALUTA,____DARE,XCAMBIO)-&VAR2
		    	 REPLACE   &VAR        WITH CAMBIO(XVALUTA,____AVERE,XCAMBIO)-&VAR
			  ENDIF

		     IF CON_TIPOCO = "C"  OR CON_TIPOCO = "F"
				  IF TI_TOP = "S"	&& FATTURA CLIENTE/FORNITORE
					 IF _NOTAC <> "S"	&& NOTA CREDITO CLIENTE/FORNITORE
					     REPLACE   PRE_FATTURA   WITH PRE_FATTURA - CAMBIO(XVALUTA,(____DARE+____AVERE),XCAMBIO)
					 ENDIF
				  ENDIF
				  IF _NOTAC = "S"	&& NOTA CREDITO CLIENTE/FORNITORE
				     REPLACE   PRE_NOTAC   WITH PRE_NOTAC - CAMBIO(XVALUTA,(____DARE+____AVERE),XCAMBIO)
				  ENDIF
		     ENDIF




RETURN


