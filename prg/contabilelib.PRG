*****************************************
FUNCTION NormalizzaContoSimilcee(tcConto AS String) AS String
*****************************************
* Rimuove l'ultimo punto se presente per evitare segmenti vuoti
IF RIGHT(tcConto, 1) == "."
    tcConto = LEFT(tcConto, LEN(tcConto) - 1)
ENDIF

LOCAL lnIncolonnati, lcRisultato, lnSegmenti, i, lcSegmento
LOCAL ARRAY laPezzi[1]

* Spezza il conto in base ai punti usando ALINES
lnSegmenti = ALINES(laPezzi, tcConto, 1, ".")
lcRisultato = ""

* Ricompone il conto trasformando ogni pezzo in una stringa di 3 caratteri riempita con zeri
* Es: "4" -> "004", "12" -> "012"
FOR i = 1 TO lnSegmenti
    lcRisultato = lcRisultato + PADL(ALLTRIM(laPezzi[i]), 3, "0") + "."
ENDFOR

RETURN lcRisultato

ENDFUNC
**=> ERASMO - FINE 18/05/2026
