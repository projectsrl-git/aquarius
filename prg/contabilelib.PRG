********************************
PROCEDURE QUA_REG
********************************

TOTALE_DARE     = 0
TOTALE_AVERE    = 0
TOTALE_IMPOSTA  = 0
T_DARE          = 0
T_AVERE         = 0
T_IMPOSTA       = 0
RIQUADRA        = 0

M.T_DARE_AVERE	= 0
IMPOSTA_DARE	= 0
IMPOSTA_AVERE	= 0

SELECT CORPO_MOV
SONO_QUI=RECNO()
SET ORDER TO I_CORPOMOV
GO TOP

IF EOF()
   RETURN
ENDIF

DO WHILE !EOF()

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF DARE <> 0
      RIQUADRA=DARE+IMPOSTA+RIQUADRA
   ENDIF

   IF DARE <> 0
      T_DARE		= DARE+T_DARE+IMPOSTA
      TOTALE_DARE 	= TOTALE_DARE + DARE
      IMPOSTA_DARE	= IMPOSTA_DARE + IMPOSTA
   ENDIF

   IF AVERE <> 0
      T_AVERE=AVERE+IMPOSTA+T_AVERE
      TOTALE_AVERE  = TOTALE_AVERE + AVERE
      IMPOSTA_AVERE	= IMPOSTA_AVERE + IMPOSTA

   ENDIF

   IF AVERE = 0 .AND. DARE = 0                   && FATTURE CLIENTI CON MAT PUBBLICITARIO
      T_AVERE=AVERE+IMPOSTA+T_AVERE
      TOTALE_AVERE = TOTALE_AVERE + AVERE
   ENDIF


   ** 2015/05/26 FABIANO/SERGIO GESTIONE ANTICIPI CON CAMBIO SEGNO : IN QUESTO CASO IL VALORE ERA NEGATIVO E CON QUESTO FLAG RIESCO POI A RISALIRE AL VALORE NEGATIVO SIA IN PRIMA NOTA CHE IN BOLLATO
   IF   ANT_CAMB_SEGNO
        TOTALE_IMPOSTA  = TOTALE_IMPOSTA - IMPOSTA
   ELSE
        TOTALE_IMPOSTA  = TOTALE_IMPOSTA + IMPOSTA
   ENDIF
   ** 2015/05/26 FABIANO/SERGIO GESTIONE ANTICIPI CON CAMBIO SEGNO : IN QUESTO CASO IL VALORE ERA NEGATIVO E CON QUESTO FLAG RIESCO POI A RISALIRE AL VALORE NEGATIVO SIA IN PRIMA NOTA CHE IN BOLLATO


   SKIP +1

ENDDO



SELECT CORPO_MOV
SET ORDER TO I_CORPOMOV
GO SONO_QUI

M.T_DARE        =       TOTALE_DARE
M.T_AVERE       =       TOTALE_AVERE
M.T_IMPOSTA     =       TOTALE_IMPOSTA

M.T_DARE_AVERE	= 		(TOTALE_DARE + IMPOSTA_DARE)  -  (TOTALE_AVERE + IMPOSTA_AVERE)
***M.T_DARE_AVERE	= 		ABS(TOTALE_DARE-TOTALE_AVERE) - TOTALE_IMPOSTA



IF RIQUADRA<>M.TOTDOCU
   RETURN
ENDIF

RETURN


