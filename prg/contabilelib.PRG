	IF !EOF()
		SCAN
			*** I PAGAMENTI/INCASSI HANNO PAR_TIPODO = 'PAG', IN CASO DI NOTA DI CREDITO QUESTO CAMPO ASSUME IL VALORE 'FAT'
			IF PAR_TIPODO = 'PAG' AND EMPTY(_DataPagamento__ult)
				_DataPagamento__ult = PAR_DTREG
