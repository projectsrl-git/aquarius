***************************************************************************
FUNCTION carica_riepiloghi_contabili
***************************************************************************
PARA __CONTO,__CIVA,__VALORE,__DESCRI


SELE=SELECT()

IF !EMPTY(ALLTRIM(__CONTO))
   _SEEK = __CONTO
   SELECT RIEP_CONTI
   SET ORDER TO RIEP_CONTI
   SEEK _SEEK
   IF FOUND()
     REPLACE W_VALORE WITH W_VALORE + __VALORE
   ELSE
     APPEND BLANK
     REPLACE W_CONTO  WITH __CONTO
     REPLACE W_DESCRI WITH __DESCRI
     REPLACE W_VALORE WITH __VALORE
   ENDIF
ENDIF


IF !EMPTY(ALLTRIM(__CIVA))
   _SEEK = __CIVA
   SELECT RIEP_IVA
   SET ORDER TO RIEP_IVA
   SEEK _SEEK
   IF FOUND()
     REPLACE W_VALORE WITH W_VALORE + __VALORE
   ELSE
     APPEND BLANK
     REPLACE W_CIVA   WITH __CIVA
     REPLACE W_DESCRI WITH __DESCRI
     REPLACE W_VALORE WITH __VALORE
   ENDIF
ENDIF

SELECT(SELE)

RETURN




