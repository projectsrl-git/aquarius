x_conp = x_soci + " and " + x_annp + " and " + x_cont
IF M.TOP = "CHI"
   Csql   = "select * from ccosto where " + x_conp + " order by con_soc,con_anno,con_conto"
ELSE
   Csql   = "select * from ccosto where " + x_cond + " order by con_soc,con_anno,con_conto"
ENDIF
IF !ExecRW(cSql,"CCOSTO","R")
   return(.f.)
ENDIF
SELECT CCOSTO
IF RECCOUNT() = 0
   PUB_ERRORE=MESSAGEBOX('Centro di costo inesistente : '+Z_CODCCO+CHR(13)+'durante aggiornamento reg. : '+NREG,64,'*** ATTENZIONE ***')
ELSE



    IF !EMPTY(PUB_BLOCCA_SBLOCCA_PREVISIONALE)


		      * --------  Blocca / sblocca registrazione previsionale -------- *
			  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIEFFETTIVA"
					DO REG_CONVERTE_IN_EFFETTIVA_CCOSTO
			  ENDIF
			  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIPREVISIONALE"
					DO REG_CONVERTE_IN_PREVISIONALE_CCOSTO	
			  ENDIF
		      * --------  Blocca / sblocca registrazione previsionale -------- *

    ELSE

		   IF ALLTRIM(PUB_TIPOGE) = "PREVISIONALE"
			   P_IMPD  = PRE_IMP_D
			   IF M.TOP = "CHI"
			      MESE    = "12"
			   ELSE
			      MESE    = SUBSTR(DATAREG,4,2)
			   ENDIF
			   VAR2    = "PRE_DA"+MESE
			   * CHI_EUR_ITL
			   IF M.TOP = "CHI"
				  REPLACE   PRE_IMP_D   WITH P_IMPD+CAMBIO(PUB_VALPRE,Z_VALORE,PUB_CAMPRE)
			      REPLACE   &VAR2       WITH CAMBIO(PUB_VALPRE,Z_VALORE,PUB_CAMPRE)+&VAR2
			   ELSE
			      REPLACE   PRE_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,Z_VALORE,XCAMBIO)
			      REPLACE   &VAR2       WITH CAMBIO(XVALUTA,Z_VALORE,XCAMBIO)+&VAR2
			   ENDIF
		   ELSE
			   P_IMPD  = CON_IMP_D
			   IF M.TOP = "CHI"
			      MESE    = "12"
			   ELSE
			      MESE    = SUBSTR(DATAREG,4,2)
			   ENDIF
			   VAR2    = "CON_DA"+MESE
			   * CHI_EUR_ITL
			   IF M.TOP = "CHI"
				  REPLACE   CON_IMP_D   WITH P_IMPD+CAMBIO(PUB_VALPRE,Z_VALORE,PUB_CAMPRE)
			      REPLACE   &VAR2       WITH CAMBIO(PUB_VALPRE,Z_VALORE,PUB_CAMPRE)+&VAR2
			   ELSE
			      REPLACE   CON_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,Z_VALORE,XCAMBIO)
			      REPLACE   &VAR2       WITH CAMBIO(XVALUTA,Z_VALORE,XCAMBIO)+&VAR2
			   ENDIF
		   ENDIF

    ENDIF

ENDIF
IF !ExecRW(cSql,"CCOSTO","W")
   return(.f.)
ENDIF

RETURN

