PROCEDURE CAMBIA_NUMERO_PARTITA_CLI
PARAMETERS __NPNEW__

AXABBSS_CL    = SELECT()
SELECT WORK
GO TOP

DO WHILE .NOT. EOF()

   IF WPAGA  = 0
      SELECT WORK
      SKIP +1
      LOOP
   ENDIF

    ** LEGGE IL PAGAMENTO DAL PARTITARIO FORNITORI
   	__IDUNIQUE = WIDUNIQUE
	x_codi  = "id_unique = '" + __idunique + "'"
	cSql="SELECT * FROM part_cli WHERE " + x_codi + " order by par_codsoc,par_codcli"
	IF !ExecRW(cSql,"part_cli","R")
	   RETURN .F.
	ENDIF

	SELECT part_cli
	replace par_npart WITH __npnew__ 					&& ATTRIBUISCE IL NUMERO DELLA PARTITA DELLA FATTURA DEL CLIENTE
