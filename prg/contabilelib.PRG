*************************************************************************************
*							PROCEDURE GESTIONE DEI VERSAMENTI IN BANCA				*
* 							CON DIFFERENZE CAMBI									*
*************************************************************************************
PROCEDURE VERSBAN
*************************************************************************************

PUB_OK = .F.   && VERIFICA SE EFFETTIVAMENTE AGGIORNA GLI ARCHIVI

SELECT CORPO_MOV
SET ORDER TO I_CORPOMOV
GO TOP
IF EOF()
   PUB_ERRORE=MESSAGEBOX('Per cortesia digita'+CHR(13)+'almeno qualche dato',64,'*** ATTENZIONE ***')
   RETURN
ENDIF

MESE        = ""
VAR         = ""
VAR2        = ""
V_TOTDOC    = 0
V_IMPOSTA   = 0
V_CIVA1     = SPACE(03)
V_CIVA2     = SPACE(03)
V_CIVA3     = SPACE(03)
V_CIVA4     = SPACE(03)
V_CIVA5     = SPACE(03)
V_IMPOIVA1  = 0
V_IMPOIVA2  = 0
V_IMPOIVA3  = 0
V_IMPOIVA4  = 0
V_IMPOIVA5  = 0
V_IMPSIVA1  = 0
V_IMPSIVA2  = 0
V_IMPSIVA3  = 0
V_IMPSIVA4  = 0
V_IMPSIVA5  = 0

PUB_OK = .T.   && VERIFICA SE EFFETTIVAMENTE AGGIORNA GLI ARCHIVI

NREG 		= SPACE(06)
PN_C 		= SPACE(06)
NPROT		= SPACE(06)
VER_CONTO	= "C"

DO REG_NUMRPN              && AGGIORNA PARAMETRI NUM.REEGISTRAZ.  INTERNO
DO REG_NUMREG              && AGGIORNA PARAMETRI NUM.REG.PRIMA N.  UTENTE
DO REG_NUMPRO              && AGGIORNA PARAMETRO NUM.PROTOCOLLO FORNITORE
DO REG_DETIVA              && DETERMINA RIPARTIZIONI IVA
DO VER_AGGDBA              && AGGIORNA CONTI/MOV_CONT/PATITARI

FATTURA='P'

RETURN


*************************************************************************
*   AGGIORNAMENTO DEI D.BASE CONTI/MOV_CONT/PART_CLIPART_FOR            *
*************************************************************************
PROCEDURE VER_AGGDBA
*************************************************************************

XDESF   = ""
FL_INDI = .F.
SELECT CORPO_MOV
SET ORDER TO I_CORPOMOV
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   SCATTER  MEMVAR

   TOPX   	= M.RIC_TOP
   V_FR   	= .F.
   XDATAVAL  = RIBALTA2(M.RIC_DTFATT)
   DATADOC   = RIBALTA2(M.RIC_DTFATT)
   DATAREG   = RIBALTA2(M.RIC_DTFATT)
   XCAMBIO   = CAMBIO
   XVALUTA   = VALUTA
   XDIFFCA   = DIFFCA
   XXCAMBIO  = CAMBIO				
   XXVALUTA  = VALUTA
   CON       = CONTO
   COMM      = DESCRIZ
   COM1      = DESCRI1

   IF XVALUTA <> PUB_VALRIF
      DA      = CAMBIO(XVALUTA,M.DARE,XCAMBIO)        && IMPORTO DARE
      AV      = CAMBIO(XVALUTA,M.AVERE,XCAMBIO)       && IMPORTO AVERE
      XVALUTA = PUB_VALRIF
      XCAMBIO = 1
   ELSE
      DA      = DARE       && IMPORTO DARE
      AV      = AVERE      && IMPORTO AVERE
   ENDIF

   IV     = IVA        && CODICE IVA
   IMP    = IMPOSTA    && IMPOSTA
   DESCO  = DESCRIC
   CECOS  = CECO       && CODICE CENTRO DI COSTO
   WCCAGE = CCAGE      && SALVA CODICE AGENTE PER FATTURE CLIENTI SU MOV_CEE
   KABBUO = ABBUONO    && SALVA EVENTUALE ABBUONO CLIENTI/FORNITORI
   XNOTE  = NOTE
   XCCLI  = CCLI
   XCFOR  = CFOR

   v_seek	= 'TOP' + TOPX
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
  	  TI_TOP	=SUBSTR(LIBERA,2,1)
   ELSE
	  TI_TOP	=SPACE(1)
   ENDIF
   IF TI_TOP	= "S" .OR. TI_TOP	= "C" && SOLO SE FATTURA/CORRISPETTIVI GESTISCE IVA
   ELSE
      IV  = 'NO'
   ENDIF

   IF !FL_INDI
      FL_INDI = .T.
	  **  0 --->>>> AGGIORNA IL D.B.INDICE PRIME NOTE
      IF !ExecCommand("select * from indice where 0=1","cur_indice")
         return(.f.)
      ENDIF
      SELECT CUR_INDICE
      APPEND BLANK
	  REPLACE MOV_SOC    WITH PUB_CODSOC
	  REPLACE MOV_ANNO   WITH PUB_ANNO
	  REPLACE MOV_DTREG  WITH RIBALTA2(DATAREG)
	  REPLACE MOV_NREGIS WITH ALLTRIM(NREG)
	  REPLACE MOV_DTDOC  WITH RIBALTA2(DATADOC)
	  REPLACE MOV_NDOC   WITH NDOC
	  REPLACE MOV_TOP    WITH TOPX
	  REPLACE MOV_NPROT  WITH ALLTRIM(NPROT)
	  REPLACE MOV_CONTO  WITH CON
	  REPLACE MOV_IVA    WITH IV
	  REPLACE MOV_IMPOST WITH IMP
	  REPLACE MOV_DESMOV WITH COMM
	  REPLACE MOV_DESMO1 WITH COM1
	  REPLACE MOV_NUMPRO WITH ALLTRIM(PN_C)
	  REPLACE MOV_IMP    WITH (DA+AV)
	  REPLACE MOV_NOTE   WITH XNOTE
	  REPLACE MOV_FATRI  WITH V_FR        && FATTURE FORNITORI IN RITARDO
      REPLACE MOV_BOLLATOIVA    WITH BOLLATOIVA


	  REPLACE MOV_COSATRATTA 		WITH M.___COSATRATTA
	  REPLACE MOV_GRADOIMPORTANZA 	WITH M.___GRADOIMPORTANZA
	  REPLACE MOV_FORMAPAGAMENTO 	WITH M.___FORMAPAGAMENTO
	  REPLACE MOV_TIPOCONTRATTO 	WITH M.___TIPOCONTRATTO
	  REPLACE MOV_CODACQ			WITH M.___CODACQ
	  REPLACE MOV_PRIPAGA			WITH M.___PRIPAGA


		* --------  Gestione contabilitŕ previsionale -------- *
		  IF ALLTRIM(PUB_TIPOGE) = "PREVISIONALE"
		     REPLACE MOV_CONTABILITA_PREVISIONALE    WITH "P"
		  ELSE
		     REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "
		  ENDIF
		* --------  Gestione contabilitŕ previsionale -------- *

      * --------  Blocca / sblocca registrazione previsionale -------- *
	  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIEFFETTIVA"
	      REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "
	  ENDIF
	  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIPREVISIONALE"
	      REPLACE MOV_CONTABILITA_PREVISIONALE    WITH "P"
	  ENDIF
      * --------  Blocca / sblocca registrazione previsionale -------- *


      * ------- MAX Nuovi Campi Per Euro ------- *
      REPLACE MOV_CAMBIO WITH XCAMBIO
      REPLACE MOV_VALUTA WITH XVALUTA
      REPLACE MOV_DTVAL  WITH RIBALTA2(XDATAVAL)
      * ------- MAX Nuovi Campi Per Euro ------- *


      ** ------- GESTIONE EFFETTI --------**
   	  REPLACE MOV_NUMATRI WITH M.EFF_NUMATRI
      REPLACE MOV_EFFETDA WITH M.EFF_EFFETDA
      REPLACE MOV_INTEPER WITH M.EFF_INTEPER
      REPLACE MOV_NOTEFF  WITH M.EFF_NOTEFF
      ** ------- GESTIONE EFFETTI --------**

	  IF DA <> 0
	     REPLACE MOV_TMOV   WITH "D"
	  ELSE
	     REPLACE MOV_TMOV   WITH "A"
	  ENDIF
      IF !ExecRW('','indice','I','','CUR_INDICE')
         return(.f.)
      ENDIF
   ENDIF

   **  1 --->>>> AGGIORNA IL D.B. DEI MOVIMENTI CONTABILI
   X_CONTOP = SPACE(13)
   IF !ExecCommand("select * from mov_cont where 0=1","cur_movcont")
      return(.f.)
   ENDIF
   SELECT CUR_MOVCONT
   APPEND BLANK
   REPLACE MOV_SEQUEN WITH M.SEQUEN
   REPLACE MOV_SOC    WITH PUB_CODSOC
   REPLACE MOV_ANNO   WITH PUB_ANNO
   REPLACE MOV_DTREG  WITH RIBALTA2(DATAREG)
   REPLACE MOV_NREGIS WITH ALLTRIM(NREG)
   REPLACE MOV_DTDOC  WITH RIBALTA2(DATADOC)
   REPLACE MOV_ANNODO WITH SUBSTR(MOV_DTDOC,1,4)   &&  23/04/2003
   REPLACE MOV_NDOC   WITH NDOC
   REPLACE MOV_TOP    WITH TOPX
   REPLACE MOV_NPROT  WITH ALLTRIM(NPROT)
   REPLACE MOV_CONTO  WITH CON
   REPLACE MOV_IVA    WITH IV
   REPLACE MOV_IMPOST WITH IMP
   REPLACE MOV_DESMOV WITH COMM
   REPLACE MOV_DESMO1 WITH COM1
   REPLACE MOV_NUMPRO WITH ALLTRIM(PN_C)
   REPLACE MOV_IMP    WITH (DA+AV)
   REPLACE MOV_NOTE   WITH XNOTE
   REPLACE MOV_CCLI   WITH XCCLI	
   REPLACE MOV_CFOR   WITH XCFOR	
   REPLACE MOV_CCO    WITH CECOS
   REPLACE MOV_CEE    WITH WCCAGE
   X_CONTOP = ALLTRIM(STR(RECNO()))		 && GESTIONE PER AGGANCIO CENTRI DI COSTO IN VARIAZIONE
   REPLACE MOV_CONTOP WITH X_CONTOP
   REPLACE MOV_IMPORT WITH M.SOLOIVA   && GESTIONE REGISTRAZIONI CONTABILI DI SOLO IVA
   REPLACE MOV_FATRI  WITH V_FR        && FATTURE FORNITORI IN RITARDO
   REPLACE MOV_BOLLATOIVA    WITH BOLLATOIVA

   REPLACE MOV_EXTRA_NUMDOC WITH M.EXTRA_NUMDOC
   REPLACE MOV_EXTRA_DATDOC WITH M.EXTRA_DATDOC
   REPLACE MOV_EXTRA_IMPDOC WITH M.EXTRA_IMPDOC
   REPLACE MOV_EXTRA_SYSDOC WITH M.EXTRA_SYSDOC


   REPLACE MOV_COSATRATTA 		WITH M.___COSATRATTA
   REPLACE MOV_GRADOIMPORTANZA 	WITH M.___GRADOIMPORTANZA
   REPLACE MOV_FORMAPAGAMENTO 	WITH M.___FORMAPAGAMENTO
   REPLACE MOV_TIPOCONTRATTO 	WITH M.___TIPOCONTRATTO
   REPLACE MOV_CODACQ			WITH M.___CODACQ
   REPLACE MOV_PRIPAGA			WITH M.___PRIPAGA

   REPLACE MOV_PUBBLI			WITH M.MPUBBLI


	* --------  Gestione contabilitŕ previsionale -------- *
	  IF ALLTRIM(PUB_TIPOGE) = "PREVISIONALE"
	     REPLACE MOV_CONTABILITA_PREVISIONALE    WITH "P"
	  ELSE
	     REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "
	  ENDIF
	* --------  Gestione contabilitŕ previsionale -------- *

      * --------  Blocca / sblocca registrazione previsionale -------- *
	  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIEFFETTIVA"
	      REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "
	  ENDIF
	  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIPREVISIONALE"
	      REPLACE MOV_CONTABILITA_PREVISIONALE    WITH "P"
	  ENDIF
      * --------  Blocca / sblocca registrazione previsionale -------- *


   * ------- MAX Nuovi Campi Per Euro ------- *
   REPLACE MOV_DTVAL  WITH RIBALTA2(XDATAVAL)
   REPLACE MOV_VALUTA WITH XVALUTA
   REPLACE MOV_CAMBIO WITH XCAMBIO
   * ------- MAX Nuovi Campi Per Euro ------- *

   ** ------- GESTIONE EFFETTI --------**
   REPLACE MOV_NUMATRI WITH M.EFF_NUMATRI
   REPLACE MOV_EFFETDA WITH M.EFF_EFFETDA
   REPLACE MOV_INTEPER WITH M.EFF_INTEPER
   REPLACE MOV_NOTEFF  WITH M.EFF_NOTEFF
   ** ------- GESTIONE EFFETTI --------**

   IF DA <> 0
      REPLACE MOV_TMOV   WITH "D"
   ELSE
	  REPLACE MOV_TMOV   WITH "A"
   ENDIF
   IF !ExecRW('','mov_cont','I','','CUR_MOVCONT')
      return(.f.)
   ENDIF

   XDESF = " "
   x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "cli_codcli = '" + SUBSTR(CON,PUB_SOTTOG,PUB_CONTO) + "'"
   **=> SERGIO - INIZIO 18/12/2021
   IF PUB_CONTOSIMILCEE
   		x_codi = "cli_codcli = '" + SCORPRA_CODICE_CLIENTE_FORNITORE_SE_SIMILCEE(CON) + "'"
   ENDIF
   **=> SERGIO - FINE 18/12/2021
   
   
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
   IF !ExecCommand(cSql,"CUR_CLIENTI")
      return(.f.)
   ENDIF
   SELECT CUR_CLIENTI
   GO TOP
   IF EOF()
   ELSE
 	  XDESF=ALLTRIM(CLI_RAGSOC)
   ENDIF

   **  2 --->>>> AGGIORNA IL D.B. DEI CONTI
   x_soci = "con_soc = '" + PUB_CODSOC + "'"
   x_anno = "con_anno = '" + PUB_ANNO + "'"
   x_cont = "con_conto = '" + ALLTRIM(CON) + "'"
   x_cond = x_soci + " and " + x_anno + " and " + x_cont
   Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
   IF !ExecRW(cSql,"CONTI","R")
      return(.f.)
   ENDIF
   SELECT CONTI
   IF RECCOUNT() = 0
      PUB_ERRORE=MESSAGEBOX('Conto inesistente '+CHR(13)+'durante aggiornamento',64,'*** ATTENZIONE ***')
 	  RETURN
   ELSE
      P_IMPA  = CON_IMP_A
      P_IMPD  = CON_IMP_D
      MESE    = SUBSTR(DATAREG,4,2)
      VAR     = "CON_AV"+MESE
      VAR2    = "CON_DA"+MESE
      CLI_FOR = SUBSTR(CON_TIPOCO,1,1)
      REPLACE   CON_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,DA,XCAMBIO)
	  REPLACE   CON_IMP_A   WITH P_IMPA+CAMBIO(XVALUTA,AV,XCAMBIO)
	  REPLACE   &VAR2       WITH CAMBIO(XVALUTA,DA,XCAMBIO)+&VAR2
	  REPLACE   &VAR        WITH CAMBIO(XVALUTA,AV,XCAMBIO)+&VAR
   ENDIF
   IF !ExecRW(cSql,"CONTI","W")
      return(.f.)
   ENDIF

   v_seek	= 'GEN'+PUB_CODSOC
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
   ELSE
      WAIT WINDOW "Errore manca parametro GEN 4 caratteri conti fornitori"
	  RETURN
   ENDIF
   FF=SUBSTR(LIBERA,18,PUB_SOTTOG-1)
   CC=SUBSTR(LIBERA,1,PUB_SOTTOG-1)



	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 

	   IF SUBSTR(CON,1,PUB_GRUPPOCF) =  CC
	      IF XDIFFCA <> "S"      && NON TRATTA DIFFERENZE CAMBI SUI PARTITARI CLIENTI
		     DO VER_PARTIT      && AGGIORNAMENTO PARTITARI
		  ENDIF
	   ENDIF


	ELSE

	   IF SUBSTR(CON,1,PUB_SOTTOG-1) =  CC
	      IF XDIFFCA <> "S"      && NON TRATTA DIFFERENZE CAMBI SUI PARTITARI CLIENTI
		     DO VER_PARTIT      && AGGIORNAMENTO PARTITARI
		  ENDIF
	   ENDIF

	ENDIF
	** SERGIO 18/12/2021 FINE  




   SELECT CORPO_MOV
   SKIP +1

ENDDO

PUB_ERRORE=MESSAGEBOX('Numero di registrazione '+CHR(13)+'di prima nota creato : '+ALLTRIM(NREG),64,'*** ATTENZIONE ***')

RETURN


*************************************************************************
*   AGGIORNAMENTO DEI D.BASE PART_CLI / PART_FOR                        *
*************************************************************************
PROCEDURE VER_PARTIT
*************************************************************************

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(CON) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"CUR_CONTI")
   return(.f.)
ENDIF
SELECT CUR_CONTI
GO TOP
IF EOF()
   PUB_ERRORE=MESSAGEBOX('Conto inesistente durante'+CHR(13)+'aggiornamento partitario',64,'*** ATTENZIONE ***')
   RETURN
ENDIF
CLI_FOR = SUBSTR(CON_TIPOCO,1,1)

IF CLI_FOR='C'
   DO VER_PARCLI         && AGGIORNA PARTITARIO CLIENTI
ENDIF
	
RETURN


*************************************************************************
*   AGGIORNAMENTO PARTITARIO CLIENTI                                    *
*************************************************************************
PROCEDURE VER_PARCLI
*************************************************************************

x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
x_codi = "cli_codcli = '" + SUBSTR(CON,PUB_SOTTOG,PUB_CONTO) + "'"
**=> SERGIO - INIZIO 18/12/2021
IF PUB_CONTOSIMILCEE
	x_codi = "cli_codcli = '" + SCORPRA_CODICE_CLIENTE_FORNITORE_SE_SIMILCEE(CON) + "'"
ENDIF
**=> SERGIO - FINE 18/12/2021

x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"CUR_CLIENTE")
   return(.f.)
ENDIF
SELECT CUR_CLIENTE
GO TOP
IF EOF()
   V_TELEFO  = CLI_TELEFO
   V_PARIVA  = CLI_PARIVA
   V_CONPAG  = CPA
   IF V_CONPAG  = "XXX"  .OR. V_CONPAG  = SPACE(03)
      V_CONPAG  = CLI_CONPAG
   ENDIF
ELSE
   V_TELEFO  = SPACE(15)
   V_PARIVA  = SPACE(11)
   V_CONPAG  = CPA
   IF V_CONPAG  = "XXX"
      V_CONPAG  = SPACE(03)
   ENDIF
ENDIF

IF !ExecCommand("select * from part_cli where 0=1","cur_partcli")
   return(.f.)
ENDIF
SELECT CUR_PARTCLI
REC_PART=RECNO()
REPLACE PAR_CODSOC  WITH PUB_CODSOC
REPLACE PAR_ANNO    WITH PUB_ANNO
REPLACE PAR_TIPODO  WITH "FAT"
IF FATTURA='P'
   REPLACE PAR_TIPODO  WITH "PAG"
ENDIF
IF FATTURA='I'
   REPLACE PAR_TIPODO  WITH "INS"
ENDIF
IF FATTURA='N'
   REPLACE PAR_TIPODO  WITH "NCR"
ENDIF
REPLACE PAR_CODCLI  WITH CON
REPLACE PAR_RAGSOC  WITH DESCRIC
REPLACE PAR_DTREG   WITH RIBALTA2(DATAREG)
REPLACE PAR_DTFAT   WITH RIBALTA2(DATADOC)
REPLACE PAR_TIPFAT  WITH TOPX
REPLACE PAR_TOTIM   WITH (V_TOTDOC-V_IMPOSTA)
REPLACE PAR_TIMPOS  WITH V_IMPOSTA
