ENDFUNC


****************************************
PROCEDURE SELE_FOR_DA_GRIGLIA_PRIMA_NOTA 
****************************************
PARA XXX_CONTO,_NASCONDE_FATTURE_LEGATE_A_EFFETTI_PASSIVI

V_NASCONDE_FATTURE_LEGATE_A_EFFETTI_PASSIVI=""
IF PCOUNT()=2
	V_NASCONDE_FATTURE_LEGATE_A_EFFETTI_PASSIVI=_NASCONDE_FATTURE_LEGATE_A_EFFETTI_PASSIVI
ENDIF

WAIT WINDOWS "Ricerca saldi partite in corso - attendere prego..." NOWAIT

* VERIFICA SE DEVE MOSTRARE LA GRIGLIA DEI PAGMENTI MULTIPLI
SELECT CORPO_MOV


=DEF_EURO()		&& DEFINISCE IL CURSORE PER LA GESTIONE DEI PARTITARI


CREATE CURSOR WORK (;
  WIDUNIQUE C(200), ;
  WANNO    C(04), ;
  WSELEZ   C(06), ;
  WCONTO   C(13), ;
  WPART    C(10), ;
  WPARTW   C(10), ;
  WTOP     C(10), ;
  WNREGIS  C(06), ;
  WNUMFAT  C(20), ;
  WDATFAT  C(10), ;
  WDATFAK  C(10), ;
  WPROTO   N(10), ;
  WNPORI   C(10), ;
  WDTSCAD  C(10), ;
  WDTSCAX  C(10), ;
  WCOVAL   C(03), ;
  WIMPVRIF N(17,3), ;
  WCAMBIO  N(17,10), ;
  WIMPORTO N(17,3), ;
  WAVERE   N(17,3), ;
  WIMPITL  N(17,3), ;
  WIMPVAL  N(17,3), ;
  WABBUO   N(17,3), ;
  WPAGA    N(17,3), ;
  WFATAGE  C(06), ;
  WPAGATO  N(17,3), ;
  Wcosatratta C(5), ;
  Wgradoimportanza C(5), ;
  Wformapagamento C(5), ;
  Wtipocontratto C(5), ;
  Wcodacq C(3), ;
  WSCARTABOLLATO C(1), ;
  WANOMAX C(3), ;
  WTIPOPA C(10), ;
  WBLOCCO L, ;
  WSTORIA M, ;
  WPREFFE C(1), ;
  Wpripaga C(4), ;
  WDESPRIMANOT C(254), ;
  WNPROTS C(254))



INDEX ON WPART+WDTSCAX    	                     		TAG WORK
INDEX ON RIBALTA2(WDATFAT)+WNUMFAT+WDTSCAX              TAG WORKD
INDEX ON WANNO+STR(VAL(WPARTW))                 		TAG WORKE

PUB_NOAGG = .F.
IF PUB_VARPN		&& VARIAZIONE DELLA PRIMA NOTA
   PUB_NOAGG = .T.
   DO REG_ANCLFO   && ANNULLO PARTITARI	
ENDIF


IF CANT = "F"							&& GESTIONE PAGAMENTO FORNITORE ANTICIPATO
	DO REG_NUMPRF 						&& PRELEVA IL NUMERO DI PARTITA
ENDIF



OK_WORK = .F.


x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
x_codi = "par_codcli = '" + ALLTRIM(XXX_CONTO) + "'"
x_tipo = "NOT(PAR_TIPODO = 'FAT' AND PAR_NPROG = 100) AND NOT(PAR_TIPODO = 'INC' AND PAR_NPROG = 100) AND NOT(PAR_TIPFAT = 'AR$')"
cSql   = "SELECT PART_FOR.* FROM PART_FOR " + ;
         "WHERE " + x_soci + " and " + x_codi + " and " + x_tipo + " order by par_codsoc,par_codcli"
IF !ExecCommand(cSql,"cur_partfor")
   return(.f.)
ENDIF
SELECT CUR_PARTFOR
GO TOP


IF EOF()
   WAIT CLEAR
   RETURN
ENDIF


DO WHILE !EOF()

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF



   SELECT CUR_PARTFOR

   * VERIFICA SE LA PARTITA E' CHIUSA
   VCONTO   = PAR_CODCLI	&& CODICE DEL FORNITORE
   VPARTITA = PAR_NPART	 	&& PARTITA FORNITORE
   VCURSORE = "VERPART"	 	&& NOME DEL CURSORE DI LAVORO
   VRAGGR   = .T.           && .T. RAGGRUPPA RITORNA UN RECORD CON IL SALDO DI TUTTI I MOVIMENTI DARE-AVERE
   VDIFFAR  = .F.			&& .T. CREA UN RECORD PER CHIUDERE LA PARTITA NEL CASO DI DIFFERENZA DOVUTA ALL'EURO DI 0,02 CENTESIMI
   VTIPO    = "F"			&& C= CLIENTE F= FORNITORE	

   IF AGGANCIAPARTITARI = "S"			&& MOSTRA ANCHE LE PARTITE CHIUSE NEL CASO DI AGGANCIO DEI PARTITARI
   ELSE

	   IF EUR_PART(VTIPO,"PART_FOR",VCONTO,VPARTITA,VCURSORE,VRAGGR,VDIFFAR," ",V_NASCONDE_FATTURE_LEGATE_A_EFFETTI_PASSIVI)  && PARTITA CHIUSA

		  SELECT CUR_PARTFOR	
	      SKIP + 1
	      LOOP
	   ENDIF
   ENDIF		
	
   SELECT CUR_PARTFOR


   M.WIDUNIQUE 			= ID_UNIQUE		&& SALVA ID UNIQUE DELLA RIGA DEL PARTITARIO
   M.WANNO    			= PAR_ANNO
   M.WSELEZ   			= SPACE(06)
   M.WCONTO   			= PAR_CODCLI
   M.WPART    			= STR(PAR_NPART,10,0)
   M.WPARTW   			= STR(PAR_NPART,10,0)
   M.WNUMFAT  			= PAR_NUMFAT
   M.WNREGIS  			= PAR_NREG
   M.WDATFAT  			= PAR_DTFAT
   M.WDATFAK  			= PAR_DTFAT
   M.WTOP     			= PAR_TIPFAT
   *M.WPROTO   			= PAR_NPART
   M.WPROTO   			= PAR_NPART
   M.WDTSCAD  			= PAR_DTSCAD
   M.WDTSCAX  			= PAR_DTSCAD
   M.WNP      			= STR(PAR_NPART,10,0)
   *M.WFATAGE  			= PAR_NPROT
   M.WCAMBIO  			= PAR_CAMBIO
   M.WCOVAL   			= PAR_VALUTA
   M.Wcosatratta 		= PAR_cosatratta
   M.Wgradoimportanza 	= PAR_gradoimportanza
   M.Wformapagamento 	= PAR_formapagamento
   M.Wtipocontratto 	= PAR_tipocontratto
   M.Wcodacq 			= PAR_codacq
   M.Wpripaga			= PAR_pripaga
   M.Wanomax			= PAR_anomax					&& PROCEDURA CONTROLLO BOLLE/FATTURE
   M.WTIPOPA            = PAR_tipopa 					&& PROCEDURA RECUPERO CREDITI
   M.WBLOCCO            = PAR_BLOCCO        			&& PAGAMENTO BLOCCATO
   M.WSTORIA            = PAR_STORIA        			&& IDENTIFICA LA SITUAZIONE DELLA PARTITA
   M.WPREFFE			= PAR_CONTABILITA_PREVISIONALE

   M.MOVNUMPRO = PAR_NUMPRO		&& ERASMO - 10/06/2015

   IF EMPTY(M.Wanomax)					
	    M.Wanomax	=  M.WTIPOPA						&& SEGNALO IL RECUPER CREDITI/ALTRO
   ENDIF


   M.Wnpori             = PAR_npori


   IF PAR_TIPODO="FAT" .OR. PAR_TIPODO="INS"
      IF PAR_TIPFAT = "AR$"   && TRATTA L'ARROTONDAMENTO PRECEDENTEMENTE CREATO
	      M.WIMPORTO = PAR_FATT
    	  M.WIMPITL  = 0
    	  M.WIMPVAL  = 0
      ELSE
		  **=> ERASMO - INIZIO 07/07/2015
 		  *** NON DEVE RIPESCARE IL CAMBIO DAI CAMBI GIORNALIERI, MA CONSIDERARE QUELLO CHE GIA' CONTIENE NELLA TABELLA (IL CAMPO PAR_FATT E' GIA' IN VALUTA)
          M.WIMPORTO = ROUND(PAR_FATT * M.WCAMBIO, PUB_DECVAL)
          M.WIMPITL  = TLIRE(M.WCOVAL,PAR_FATT,M.WDATFAT)
          M.WIMPVAL  = PAR_FATT
          IF PAR_TMOV = "D"	&&NOTA DI CREDITO
             M.WIMPORTO = M.WIMPORTO * -1
             M.WIMPITL  = M.WIMPITL * -1
             M.WIMPVAL  = M.WIMPVAL * -1
          ENDIF
		  **=> ERASMO - FINE 07/07/2015
      ENDIF
      M.WPAGATO  = 0
      M.WIMPVRIF = PAR_FATT
   ELSE
      IF PAR_TIPFAT = "AR$"   && TRATTA L'ARROTONDAMENTO PRECEDENTEMENTE CREATO
	     M.WIMPORTO = PAR_FATT * -1
    	 M.WIMPITL  = 0
         M.WPAGATO  = 0
         M.WIMPVAL  = 0
      ELSE
		 **=> ERASMO - INIZIO 07/07/2015
 		 *** NON DEVE RIPESCARE IL CAMBIO DAI CAMBI GIORNALIERI, MA CONSIDERARE QUELLO CHE GIA' CONTIENE NELLA TABELLA (IL CAMPO PAR_FATT E' GIA' IN VALUTA)
         M.WIMPORTO = ROUND(PAR_FATT * M.WCAMBIO, PUB_DECVAL)
         M.WIMPITL  = TLIRE(M.WCOVAL,PAR_FATT,M.WDATFAT)
         M.WIMPVAL  = PAR_FATT
         IF PAR_TMOV = "A"	&&NOTA DI CREDITO
         ELSE
            M.WIMPORTO = M.WIMPORTO * -1
            M.WIMPITL  = M.WIMPITL * -1
            M.WIMPVAL  = M.WIMPVAL * -1
         ENDIF
		 **=> ERASMO - FINE 07/07/2015
         M.WPAGATO  = (TLIRE(M.WCOVAL,PAR_FATT,M.WDATFAT))
      ENDIF
      M.WIMPVRIF = PAR_FATT * -1
   ENDIF

   SELECT WORK
   SET ORDER TO WORK
	**=> ERASMO/FABIANO - INIZIO 07/09/2015 - NON RAGGRUPPA PER SCADENZA
	IF PUB_SPFNRDS  && PARAMETRO AZIENDALE "In selezione partite fornitori da Prima Nota NON raggruppa per data scadenza"
		APPEND BLANK
		GATHER MEMVAR MEMO
		REPLACE WIMPVRIF WITH M.WIMPVRIF
		REPLACE WDATFAT  WITH RIBALTA2(M.WDATFAT)
		REPLACE WDTSCAD  WITH RIBALTA2(M.WDTSCAD)
	ELSE
		_SEEK = M.WPART+M.WDTSCAX
		SEEK _SEEK
		IF FOUND()
		   REPLACE WIMPORTO WITH WIMPORTO+M.WIMPORTO
		   REPLACE WIMPITL  WITH WIMPITL+M.WIMPITL
		   REPLACE WPAGATO  WITH WPAGATO +M.WPAGATO
		   REPLACE WIMPVAL  WITH WIMPVAL+M.WIMPVAL
		ELSE
		   APPEND BLANK
		   GATHER MEMVAR MEMO
		   REPLACE WIMPVRIF WITH WIMPVRIF+M.WIMPVRIF
		   REPLACE WDATFAT  WITH RIBALTA2(M.WDATFAT)
		   REPLACE WDTSCAD  WITH RIBALTA2(M.WDTSCAD)
		ENDIF
	ENDIF
	**=> ERASMO/FABIANO - FINE 07/09/2015

	**=> ERASMO - INIZIO 04/06/2015
	*** ARROTONDAMENTO ALLA SECONDA CIFRA DECIMALE
	REPLACE WIMPORTO WITH ROUND(WIMPORTO,2)
    REPLACE WIMPITL  WITH ROUND(WIMPITL,2)
    REPLACE WPAGATO  WITH ROUND(WPAGATO,2)
    REPLACE WIMPVAL  WITH ROUND(WIMPVAL,2)
    REPLACE WIMPVRIF WITH ROUND(WIMPVRIF,2)
	**=> ERASMO - FINE 04/06/2015

	**=> ERASMO - INIZIO 04/06/2015
	*** ARROTONDAMENTO ALLA SECONDA CIFRA DECIMALE
	REPLACE WIMPORTO WITH ROUND(WIMPORTO,2)
    REPLACE WIMPITL  WITH ROUND(WIMPITL,2)
    REPLACE WPAGATO  WITH ROUND(WPAGATO,2)
    REPLACE WIMPVAL  WITH ROUND(WIMPVAL,2)
    REPLACE WIMPVRIF WITH ROUND(WIMPVRIF,2)
	**=> ERASMO - FINE 04/06/2015

	**=> ERASMO - INIZIO 10/06/2015
	*** CERCO LA DESCRIZIONE IN PRIMA NOTA
	X_DESPRIMANOT = ALLTRIM(WDESPRIMANOT)
	X_NPROTS = ""
	cSql=""
	cNomeCursorSql="MOV_CONT_CURS"
	TEXT TO cSql NOSHOW
		SELECT MOV_DESMOV, MOV_NPROT
		FROM
			mov_cont
		WHERE
			mov_soc = '<<PUB_CODSOC>>'
			AND mov_numpro = '<<M.MOVNUMPRO>>'
		ORDER BY MOV_SEQUEN
	ENDTEXT
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
		
	SELECT MOV_CONT_CURS
	GO TOP
	SCAN
		IF !EMPTY(MOV_DESMOV)
			IF ALLTRIM(MOV_DESMOV) $ ALLTRIM(X_DESPRIMANOT)
			ELSE
				X_DESPRIMANOT = X_DESPRIMANOT + IIF(EMPTY(X_DESPRIMANOT),""," - ") + ALLTRIM(MOV_DESMOV)
			ENDIF
		ENDIF
		IF !EMPTY(MOV_NPROT)																											&& ERASMO - 10/07/2015
			X_NPROTS = ALLTRIM(X_NPROTS) + IIF(ALLTRIM(MOV_NPROT) $ X_NPROTS, "", IIF(EMPTY(X_NPROTS), "", "; ") + ALLTRIM(MOV_NPROT))	&& ERASMO - 10/07/2015
		ENDIF																															&& ERASMO - 10/07/2015
	ENDSCAN
	
	SELECT WORK
	REPLACE WDESPRIMANOT WITH SUBSTR(ALLTRIM(X_DESPRIMANOT),1,254)
	IF !EMPTY(X_NPROTS)																													&& ERASMO - 10/07/2015
		REPLACE WNPROTS WITH ALLTRIM(WNPROTS) + IIF(ALLTRIM(X_NPROTS) $ WNPROTS, "", IIF(EMPTY(WNPROTS), "", "; ") + ALLTRIM(X_NPROTS))	&& ERASMO - 10/07/2015
	ENDIF																																&& ERASMO - 10/07/2015
	**=> ERASMO - FINE 08/06/2015


   SELECT CUR_PARTFOR
   SKIP +1

ENDDO

SELECT WORK
GO TOP


SELECT WORK
SET ORDER TO WORKE
IF AGGANCIAPARTITARI = "S"			&& MOSTRA ANCHE LE PARTITE CHIUSE NEL CASO DI AGGANCIO DEI PARTITARI
ELSE
	SET FILTER TO WIMPORTO <> 0 OR WAVERE <> 0
ENDIF

GO TOP

OK_WORK = .F.
DO WHILE .NOT.EOF()       			&& VERIFICA SE EFFETTIVAMENTE ESISTE FATTURA IN LISTA

   OK_WORK = .T.           			&& SE HO I PAGAMENTI E NON LA FATTURA IMPORTO PAGATO > WIMPORTO

   IF WIMPORTO > 0
     REPLACE WAVERE   WITH ABS(WIMPORTO)
     REPLACE WIMPORTO WITH 0
   ELSE
     REPLACE WIMPORTO WITH ABS(WIMPORTO)
   ENDIF

   SKIP +1

ENDDO

IF !OK_WORK
   WAIT CLEAR
   RIT = MESSAGEBOX("Nessuna partita aperta per il fornitore digitato",62,"CONFERMA")
   RETURN
ENDIF

*HIDE WINDOW PRIMANO2           && NASCONDE LA FINESTRA DI PRIMA NOTA 

* >>> PRELIEVO DEI CONTI ABBUONI PASSIVI/ATTIVI
V_SEEK   = "ABB"+PUB_CODSOC
V_CHIAVE = 'codice'
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   VAL_ABBUO = VAL(ALLTRIM(DESCRI))
   VAL_CONTC = SUBSTR(LIBERA,1,13)
   VAL_CONTF = SUBSTR(LIBERA,15,13)
ELSE
   VAL_ABBUO = 0
   VAL_CONTC = SPACE(13)
   VAL_CONTF = SPACE(13)
ENDIF


x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(XXX_CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP
IF EOF()
   _DESCONTO = ""
ELSE
   _DESCONTO = ALLTRIM(CON_DESCR)
ENDIF


x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(VAL_CONTC) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP
IF EOF()
   VAL_DESC = ""
ELSE
   VAL_DESC = CON_DESCR
ENDIF

WAIT CLEAR

SELECT WORK
SET ORDER TO WORKD
GO TOP

HIDE WINDOW PRIMANO2           && NASCONDE LA FINESTRA DI PRIMA NOTA 
_TITOLO = "Situazione partite aperte del fornitore : "+ _DESCONTO
DO FORM FORM\PRIMAFOR WITH _TITOLO LINKED
SHOW WINDOW PRIMANO2               && RIATTIVA LA FINESTRA DI PRIMA NOTA


REC_SELE=0

* -->> ESPLODO IN CORPO_MOV I MOVIMENTI DI PRIMA NOTA



_SOLO_ORA = .T.   && SALVA IMPORTI DELLA FATTURA DIGITATI DI OGNI SINGOLA RIGA
XDARE     = DARE
XAVERE    = AVERE
_TOTALE_PAGATO = 0


** GESTIONE FATTURE CON ACCONTI ANTICIPATI INIZIO
** VERIFICA SE NEL CASO STIA REGISTRANDO UNA FATTURA CON PAGAMENTO ESISTA SEMPRE ALMENO UN MOVIMENTO DA TRATTARE
** AI FINI DEL BOLLATO IVA SUCCESSIVI (SE AGGANCIO DEI PAGAMENTI DEVO SCARTARE TUTTI I MOVIMENTI PAGAMENTI ECCETTO
** UNO ALTRIMENTI LA FATTURA NON VIENE CARICATE NEL BOLLATO IVA
**
** SE HO AGGANCIATO UNA SOLA RIGA : VA BENE COSI PER CUI NON DEVO ESTIRE IL FLAG WSCARTABOLLATO = 'S'
**
SELECT WORK
GO TOP



COUNT TO _NOIVA FOR WSCARTABOLLATO = 'S'
GO TOP
COUNT TO _NUMPAGAM FOR WPAGA    <> 0
GO TOP


IF _NUMPAGAM = _NOIVA

    IF _NUMPAGAM = 1

      REPLACE WSCARTABOLLATO WITH  ' '  ALL && AGGANCIO DIRETTO DI UN PAGAMENTO SOLO

    ELSE
		DO WHILE .NOT. EOF()

		      IF WSCARTABOLLATO = 'S'
		         REPLACE WSCARTABOLLATO WITH " "
		         EXIT
		      ENDIF

		      SELECT WORK
		      SKIP +1

		ENDDO
    ENDIF

ENDIF

** GESTIONE FATTURE CON ACCONTI ANTICIPATI  FINE

SELECT WORK
GO TOP

PUB_IMPORTO_MODIFICATO = 0	&& GESTIONE DELLA MODIFICA DELLA PRIMA NOTA RICHIAMATA DALLO STORICO CONTABILE

DO WHILE .NOT. EOF()

   IF WABBUO   = 0 .AND.  WPAGA    = 0
      SELECT WORK
      SKIP +1
      LOOP
   ENDIF

   M.CNUMFAT 				= WNUMFAT
   M.CDATFAT 				= RIBALTA2(WDATFAT)
   M.CDTSCAD 				= RIBALTA2(WDTSCAD)
   M.CPROTO  				= WPROTO
   M.CNPORI					= WNPORI
   M.WCONTO  				= WCONTO
   XWABBUO   				= WABBUO
   XWPAGA    				= WPAGA

   XWIMPORTO                = WIMPORTO

   **=> ERASMO/FABIANO - INIZIO 20/06/2016
   _NPARTCF 				= VAL(WPART)
   _NUMFCF 					= WNUMFAT
   _DTSCACF 				= M.WDTSCAD
   **=> ERASMO/FABIANO - FINE 20/06/2016

   *!*	   INTERCETTA L'IMPORTO PAGATO PER LA GESTIONE DELLA MODIFICA DELLA PRIMA NOTA RICHIAMATA DALLO STORICO CONTABILE
   IF ALLTRIM(M.WCONTO) = ALLTRIM(PUB_CONTO_MODIFICA_PN_DA_STORICO_CONTABILE)
   		IF WPAGA <>  0
   			PUB_IMPORTO_MODIFICATO = PUB_IMPORTO_MODIFICATO + WPAGA
   		ENDIF
   ENDIF



   IF XWPAGA    <> 0
	   IF XWIMPORTO   = 0
	       _TOTALE_PAGATO           = _TOTALE_PAGATO + WPAGA			
	   ELSE
	       _TOTALE_PAGATO           = _TOTALE_PAGATO - WPAGA			&& NOTE DI CREDITO
	   ENDIF
   ENDIF


   M.___COSATRATTA 			= WCOSATRATTA
   M.___GRADOIMPORTANZA 	= WGRADOIMPORTANZA
   M.___FORMAPAGAMENTO 		= WFORMAPAGAMENTO
   M.___TIPOCONTRATTO 		= WTIPOCONTRATTO
   M.___CODACQ 				= WCODACQ
   M.___PRIPAGA 			= WPRIPAGA

   M.___SCARTABOLLATO       = WSCARTABOLLATO

   IF WABBUO = 999999
      XWABBUO = 0                               && FORZA ABBUONO A 0 SE NON DA GESTIRE
   ENDIF

   && AGGIORNA CURSORE PRIMA NOTA
   IF WPAGA <> 0

      IF _SOLO_ORA
         SELECT CORPO_MOV
         REPLACE CNUMFAT WITH M.CNUMFAT
         REPLACE CDATFAT WITH M.CDATFAT
         REPLACE CDTSCAD WITH M.CDTSCAD
         REPLACE CPROTO  WITH M.CPROTO
         REPLACE CNPORI  WITH M.CNPORI
         REPLACE ABBUONO WITH XWABBUO

         **=> ERASMO/FABIANO - INIZIO 20/06/2016
         REPLACE NPARTCF WITH _NPARTCF
	     REPLACE NUMFCF WITH _NUMFCF
    	 REPLACE DTSCACF WITH _DTSCACF
         **=> ERASMO/FABIANO - FINE 20/06/2016
         		
		 * --------  Classifica la partita -------- *
		 REPLACE ___COSATRATTA 		WITH M.___COSATRATTA
		 REPLACE ___GRADOIMPORTANZA WITH M.___GRADOIMPORTANZA
		 REPLACE ___FORMAPAGAMENTO 	WITH M.___FORMAPAGAMENTO
		 REPLACE ___TIPOCONTRATTO 	WITH M.___TIPOCONTRATTO
		 REPLACE ___CODACQ			WITH M.___CODACQ
		 REPLACE ___PRIPAGA			WITH M.___PRIPAGA
		 * --------  Classifica la partita -------- *

		 * ---------  Controllo ddt/fatture -------- *
		 * REPLACE PAR_ANOMAX			WITH M.___xanomax
		 * ---------  Controllo ddt/fatture -------- *

         REPLACE ___SCARTABOLLATO   WITH M.___SCARTABOLLATO

         SCATTER MEMVAR MEMO         && SI SALVA IL FORNITORE CHE DETERMINA I PAGAMENTI MULTIPLI
         _SOLO_ORA = .F.

         IF NO_AUT = "S"        && NESSUN AUTOMATISMO


		 	 IF YES_BOLLATO

		         **=> ERASMO/SERGIO - INIZIO 21/05/2015
		         IF XDARE <> 0 OR XAVERE <> 0  && SE NON HO DIGITATO NULLA MANUALMENTE IN FORM PRIMA NOTA
			         IF XDARE <> 0
			            REPLACE DARE WITH XWPAGA
			         ENDIF
			
			         IF XAVERE <> 0
