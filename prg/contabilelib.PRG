**********************************************************************
* Funzione - NUMWORDE  : VERSIONE IN EURO
**********************************************************************
* Data     : 28.06.2001
* Note     : Conversione di importi da cifre a parole
*            agisce su numeri da 0.00 a 999999999999.99
*
FUNCTION NUMWORDE
PARAMETERS NUMERO

SS=STR(SELECT())

UNITA     = "UNO    DUE    TRE    QUATTROCINQUE SEI    SETTE  OTTO   NOVE   "
DECINA1   = "DIECI      UNDICI     DODICI     TREDICI    QUATTORDICI"+;
        "QUINDICI   SEDICI     DICIASSETTEDICIOTTO   DICIANNOVE "
DECINE    = "DIECI    VENTI    TRENTA   QUARANTA CINQUANTASESSANTA "+;
        "SETTANTA OTTANTA  NOVANTA  "
ATTRIBUTI = " MILIARDI MILIONI MILA     "
RELEASE PAROLE
PUBLIC PAROLE

DO CASE
   CASE NUMERO=0
        PAROLE = "ZERO"
   CASE INT(NUMERO)=0
        PAROLE = "ZERO"
   CASE INT(NUMERO)=1
        PAROLE = "UN"
   OTHERWISE
      * CIFRE = STR(ABS(NUMERO),12,0)
       CIFRE = STR(INT(NUMERO),12,0)
       PAROLE = ""
       GRUPPO = 4
       DO WHILE GRUPPO#0
          TRE_CIFRE = SUBSTR(CIFRE,(GRUPPO-1)*3+1,3)
          STRINGA = ""
          DO CASE
             CASE TRE_CIFRE=SPACE(3)
                EXIT
             CASE VAL(TRE_CIFRE)=1
                DO CASE
                   CASE GRUPPO=4
                      STRINGA = "UNO"
                   CASE GRUPPO=3
                      STRINGA = "MILLE"
                   CASE GRUPPO=2
                      STRINGA = "UN MILIONE"
                   CASE GRUPPO=1
                      STRINGA = "UN MILIARDO"
                ENDCASE
             CASE VAL(TRE_CIFRE)>1
               CIFRA = VAL(SUBSTR(TRE_CIFRE,1,1))
               IF CIFRA#0
                  IF CIFRA>1
                      STRINGA = TRIM(SUBSTR(UNITA,(CIFRA-1)*7+1,7))
                  ENDIF
                  STRINGA = STRINGA+"CENTO"
                  IF SUBSTR(TRE_CIFRE,2,1)="8"
                      STRINGA = LEFT(STRINGA,LEN(STRINGA)-1)
                  ENDIF
               ENDIF
               CIFRA = VAL(SUBSTR(TRE_CIFRE,2,1))
               IF CIFRA=1
                  CIFRA = VAL(SUBSTR(TRE_CIFRE,3,1))
                  STRINGA = STRINGA+TRIM(SUBSTR(DECINA1,CIFRA*11+1,11))
               ELSE
                  IF CIFRA>1
                     STRINGA = STRINGA+;
                     TRIM(SUBSTR(DECINE,(CIFRA-1)*9+1,9))
                     IF SUBSTR(TRE_CIFRE,3,1)$"18"
                        STRINGA = LEFT(STRINGA,LEN(STRINGA)-1)
                     ENDIF
                  ENDIF
                  CIFRA = VAL(SUBSTR(TRE_CIFRE,3,1))
                  IF CIFRA>0
                     STRINGA = STRINGA+TRIM(SUBSTR(UNITA,(CIFRA-1)*7+1,7))
                  ENDIF
               ENDIF
              IF GRUPPO#4
                 STRINGA = STRINGA+;
                 TRIM(SUBSTR(ATTRIBUTI,(GRUPPO-1)*9+1,9))
              ENDIF
       ENDCASE
       IF LEN(STRINGA)#0
          IF LEN(PAROLE)#0
             STRINGA = STRINGA+" "
          ENDIF
          PAROLE = STRINGA+PAROLE
       ENDIF
       GRUPPO = GRUPPO-1
    ENDDO
ENDCASE

PAROLE = PAROLE + ' EURO'

DO CARINUM

SET DECIMAL TO 2
V_DECI = NUMERO - INT(NUMERO)
V_DECI = INT(V_DECI * 100)

IF V_DECI = 0
ELSE
   IF V_DECI = 1
      PAROLE = PAROLE + ' E UN CENTESIMO'
   ELSE
      SELECT WNUMERI
      SET ORDER TO I_NUMERO
      SEEK V_DECI
      IF FOUND()
         PAROLE = PAROLE + ' E ' + ALLTRIM(WALF) + ' CENTESIMI'
      ENDIF
   ENDIF
ENDIF

SELECT &SS

RETURN(PAROLE)


