*************************
FUNCTION OK_ARROTB			
*************************
PARA _IMP_DOC,_XVAL
** ARROTONDA TRONCANDO ALLE 1000 LIRE I BOLLATI SE VALUTA ITL
** ARROTONDA TRONCANDO I DECIMALI DEI BOLLATI SE VALUTA EUR

IF _XVAL = "ITL" .OR. _XVAL="LIT"
   _VALO = STR(_IMP_DOC,17,0)
   IF VAL(SUBSTR(_VALO,15,1)) > 4			&& ARROTONDA ALLE 1000
      IF VAL(_VALO) < 0
         _IMP_DO1 = VAL(SUBSTR(_VALO,1,14)) - 1
	  ELSE
         _IMP_DO1 = VAL(SUBSTR(_VALO,1,14)) + 1
	  ENDIF
      _IMP_DOC = VAL(STR(_IMP_DO1,14,0)+"000")
   ELSE
      _IMP_DOC = VAL(SUBSTR(_VALO,1,14)+"000")
   ENDIF
   RETURN(ROUND(_IMP_DOC,0))
ELSE
   IF PUB_VALRIF $ "ITL.LIT"						&& LIRE
	  _VALO = STR(_IMP_DOC,17,0)
	  IF VAL(SUBSTR(_VALO,15,1)) > 4			&& ARROTONDA ALLE 1000
	     IF VAL(_VALO) < 0
            _IMP_DO1 = VAL(SUBSTR(_VALO,1,14)) - 1
		 ELSE
    	    _IMP_DO1 = VAL(SUBSTR(_VALO,1,14)) + 1
		 ENDIF
    	 _IMP_DOC = _IMP_DO1
	  ELSE
    	 _IMP_DOC = VAL(SUBSTR(_VALO,1,14)+"000")
	  ENDIF
	  RETURN(ROUND(_IMP_DOC,0))
   ELSE
	  _VALO = STR(_IMP_DOC,17,2)				&& EURO
	  IF VAL(SUBSTR(_VALO,16,2)) > 49			&& SE LA FRAZIONE E' SUPERIORE A 0,5 FA +/- 1
	     IF VAL(_VALO) < 0
            _IMP_DO1 = VAL(SUBSTR(_VALO,1,14)) - 1
		 ELSE
    	    _IMP_DO1 = VAL(SUBSTR(_VALO,1,14)) + 1
		 ENDIF
    	 _IMP_DOC = _IMP_DO1
	  ELSE
   	     _IMP_DOC = VAL(SUBSTR(_VALO,1,14))
	  ENDIF
	  RETURN(_IMP_DOC)
   ENDIF
ENDIF


