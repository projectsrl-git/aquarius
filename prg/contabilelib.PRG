***********************************************
FUNCTION CONTROLLA_CCO_CGE_INT_CLG
***********************************************
* TIPI DI CONTROLLI :
* CCO : CENTRO DI COSTO
* CGE : CONTO CONTABILE
* INT : SERVIZIO INTRASTAT
* CLG : CLASSE DOGANALE
LPARAMETERS _TIPO_CONTROLLO,_CODICE_DA_CONTROLLARE


CCOCGE__ = SELECT()

LOCAL __TROVATO_CODICE
__TROVATO_CODICE =.F.

_CODICE_DA_CONTROLLARE = APITOSPA(_CODICE_DA_CONTROLLARE)

DO CASE

	CASE _TIPO_CONTROLLO = "CCO"
	

		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		x_cont = "con_conto = '" + ALLTRIM(_CODICE_DA_CONTROLLARE) + "'"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont
		Csql   = "select * from ccosto where " + x_cond + " order by con_soc,con_anno,con_conto"
		IF !ExecCommand(cSql,"cur_ccosto")
		   return(.f.)
		ENDIF
		SELECT cur_ccosto
		GO TOP
		IF EOF()
		
			__TROVATO_CODICE =.F.
			
		ELSE
		
			__TROVATO_CODICE =.T.
			
			IF CON_ABILIT = "N"			&& VERIFICA ULTERIORE SE IL CENTRO COSTO NONOSTATNTE ESISTA SIA ABILITATO O MENO
				__TROVATO_CODICE =.F.
			ENDIF			
			
		ENDIF
		
	
	CASE _TIPO_CONTROLLO = "CGE"

		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		x_cont = "con_conto = '" + ALLTRIM(_CODICE_DA_CONTROLLARE) + "'"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont
		Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
		IF !ExecCommand(cSql,"conti")
		   return(.f.)
		ENDIF
		SELECT conti
		GO TOP
		IF EOF()
			__TROVATO_CODICE =.F.
		ELSE
			__TROVATO_CODICE =.T.
		ENDIF


	CASE _TIPO_CONTROLLO = "CLG"


		V_SEEK   = 'DOG'+ALLTRIM(_CODICE_DA_CONTROLLARE)
		V_CHIAVE = 'codice'
		IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
			__TROVATO_CODICE =.T.
			SELECT CUR_PARA
			IF DISATTIVO
				__TROVATO_CODICE =.F.
			ENDIF
		ELSE
			__TROVATO_CODICE =.F.
		ENDIF

	CASE _TIPO_CONTROLLO = "INT"


		V_SEEK   = 'SEI'+ALLTRIM(_CODICE_DA_CONTROLLARE)
		V_CHIAVE = 'codice'
		IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
			__TROVATO_CODICE =.T.
			SELECT CUR_PARA			
			IF DISATTIVO
				__TROVATO_CODICE =.F.
			ENDIF			
		ELSE
			__TROVATO_CODICE =.F.
		ENDIF



ENDCASE



SELECT(CCOCGE__)

RETURN(__TROVATO_CODICE)


***********************************************
FUNCTION BLOCCO_REGISTRAZIONI_CONTABILI
***********************************************
*
* DATA_REGISTRAZIONE : FORMATO AAAA/MM/GG
*
* LA PROCEDURA RESTITUISCE :
*
* BLOCCA_REGISTRAZIONE = .T. SE APPARTENENTE AL PERIODO DIGITATO
* BLOCCA_REGISTRAZIONE = .F. SE NON APPARTENENTE AL PERIODO DIGITATO
* FATTURE_CLI_FOR      = "S" EFFETTUA IL BLOCCO SOLO SULLE FATTURE CLIENTI/FORNITORI
*
LPARAMETERS DATA_REGISTRAZIONE,FATTURE_CLI_FOR,TIPO_CLI_FOR

**=> ERASMO - INIZIO 27/01/2021
IF PCOUNT() >= 3
ELSE
	TIPO_CLI_FOR = ""
ENDIF
**=> ERASMO - FINE 27/01/2021

XXX_CGE__ = SELECT()

BLOCCA_REGISTRAZIONE = .F.

cSql=""
cNomeCursorSql="BLOCCAPN_CURS"
TEXT TO cSql NOSHOW

	SELECT *
	FROM
		BLOCCAPN
	WHERE
		'<<DATA_REGISTRAZIONE>>' between bpn_datadal and bpn_dataal
	ORDER BY bpn_datadal

ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF
	
BLOCCA_REGISTRAZIONE = .F.		&& registrazine contabile modificabile
SELECT BLOCCAPN_CURS
GO TOP
DO WHILE .NOT.EOF()

		
*!*		IF BETWEEN(DATA_REGISTRAZIONE,BPN_DATADAL,BPN_DATAAL) 	&& BLOCCA SOLO LE FATTURE CLIENTI FORNITORI

*!*			BLOCCA_REGISTRAZIONE = .T.							&& REGISTRAZINE CONTABILE NON MODIFICABILE

*!*			IF BPN_FATCLFO										&& SI DESIDERA IL BLOCCO SOLO ES SI TRATTA DI UNA FATTURA CLIENTE/FORNITORE
*!*				IF FATTURE_CLI_FOR = "S"						&& SI TRATTA DI UNA FATTURA CLIENTE/FORNITORE
*!*					BLOCCA_REGISTRAZIONE = .T.					&& BLOCCA SOLO LE FATTURE CLIENTI FORNITORI
*!*				ELSE 											&& BLOCCA SOLO LE FATTURE CLIENTI FORNITORI
*!*					BLOCCA_REGISTRAZIONE = .F.					&& BLOCCA SOLO LE FATTURE CLIENTI FORNITORI
*!*				ENDIF 											&& BLOCCA SOLO LE FATTURE CLIENTI FORNITORI
*!*			ENDIF												&& BLOCCA SOLO LE FATTURE CLIENTI FORNITORI

*!*		ENDIF 													&& BLOCCA SOLO LE FATTURE CLIENTI FORNITORI


	**=> ERASMO - INIZIO 27/01/2021
	IF BETWEEN(DATA_REGISTRAZIONE,BPN_DATADAL,BPN_DATAAL)
		IF BPN_FATCLFO  && BLOCCA SOLO LE FATTURE CLIENTI FORNITORI
			IF FATTURE_CLI_FOR = "S"  && SI TRATTA DI UNA FATTURA CLIENTE/FORNITORE
				IF EMPTY(TIPO_CLI_FOR) OR BPN_OPZCF = 1  && NON E' STATO PASSATO IL PARAMETRO DI TIPOLOGIA CLI/FOR OPPURE IL CAMPO BPN_OPZCF NON SPECIFICA IL TIPO FATTURA CLI/FOR
					BLOCCA_REGISTRAZIONE = .T.
				ELSE
					IF (TIPO_CLI_FOR = 'C' AND BPN_OPZCF = 2) OR (TIPO_CLI_FOR = 'F' AND BPN_OPZCF = 3)  && SOLO SE SPECIFICO BLOCCO PER TIPO FATTURA CLI/FOR
						BLOCCA_REGISTRAZIONE = .T.
					ENDIF
				ENDIF
			ENDIF
		ELSE
			BLOCCA_REGISTRAZIONE = .T.
		ENDIF
	ENDIF
	**=> ERASMO - FINE 27/01/2021

	SELECT BLOCCAPN_CURS
	SKIP +1
	
ENDDO



SELECT(XXX_CGE__)

RETURN(BLOCCA_REGISTRAZIONE)




