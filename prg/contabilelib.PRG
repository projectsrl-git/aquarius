__DIFDIF =  m.totdocu - __DIFDA 				&& CONFRONTO TRA SALDO CALCOLATO E IMPORTO DEL DOCUMENTO DIGITATO



*** SIMONE - 07/03/2011
*** TOLTO IF SU VARIABILE "NOQUADRA" CHE NON E' GESTITA IN QUESTA PROCEDURA
***   IF  noquadra = "N"
***   SE LA DIFFERENZA TRA DARE E AVERE E' 0 (ZERO), LA REGISTRAZIONE "QUADRA"
***   IL CONTROLLO BASTA FARLO SU QUESTA DIFFERENZA
