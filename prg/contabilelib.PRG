PROCEDURE SITFINAN_PROGRESSIVA_COSTI_RICAVI_UTILI
*************************************************

DATADA = V_ANNO_8+"/01/01"
DATAA  = V_ANNO_1+"/12/31"

***CERCA PRIMI 4 CARATTERI DEL CONTO PER IL CLIENTE
v_seek	 = 'GEN'+PUB_CODSOC
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
ELSE
   WAIT WINDOW "Errore: manca parametro GEN 4 caratteri conti clienti"
   RETURN
ENDIF

CC=SUBSTR(LIBERA,1,PUB_SOTTOG-1)
FF=SUBSTR(LIBERA,18,PUB_SOTTOG-1)

CREATE CURSOR PARA_TOP (TOP_CODICE C(10), ;
 TOP_DESCRI C(45))
INDEX ON TOP_CODICE 		TAG PARA_TOP_I ADDITIVE


IMPA = 0
IMPD = 0
TOT_DARE =  0
TOT_AVERE =  0
	
* CICLO PER ELABORARE I MOVIMENTI APPARTENENTI AL PERIODO RICHIESTO
x_soci = "mov_soc = '" + PUB_CODSOC + "'"
x_anno = "mov_anno = mov_anno"
x_cont = "mov_conto = mov_conto"
x_dtda = "mov_dtreg >= '" + DATADA + "'"
x_data = "mov_dtreg <= '" + DATAA + "'"
x_nreg = "mov_nregis = mov_nregis"

** SERGIO 18/12/2021 INIZIO
IF PUB_CONTOSIMILCEE 
	x_clen = "len(rtrim(ltrim(mov_conto))) >= " + ALLTRIM(STR(PUB_GRUPPOCF))
	
ELSE
	x_clen = "len(rtrim(ltrim(mov_conto))) >= " + ALLTRIM(STR(PUB_SOTTOG))
ENDIF
** SERGIO 18/12/2021 FINE  

x_caus = "mov_top <> 'CHI' and mov_top <> 'APE'"
x_tcon = "(con_tipoco = 'C' or con_tipoco = 'F')"
x_tfat = "(substring(para_top.libera,2,1) = 'S' or substring(para_top.libera,2,1) = 'P')"
x_sfin = "substring(para_top.libera,50,1) <> 'N'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont + " and " + x_dtda + " and " + x_data + " and " + x_nreg + " and " + x_clen + " and " + ;
	x_caus + " and " + x_tcon + " and " + x_tfat + " and " + x_sfin
x_select = "select mov_cont.*, conti.con_tipoco, para_top.descri, para_top.libera from mov_cont " + ;
	"left outer join conti on con_soc = mov_soc and con_anno = mov_anno and con_conto = mov_conto " + ;
	"inner join para as para_top on codice = 'TOP'+mov_top"
cSql = x_select + " WHERE 1=0"
IF !ExecCommand(cSql,"MOV_CONT")  && PER IL CASO DI ANNULLO QUERY MI ASSICURO CHE VENGA CREATO ALMENO UN CURSORE VUOTO
	return(.f.)
ENDIF
cSql = x_select + " WHERE " + x_cond + " order by mov_soc,mov_anno,mov_conto,mov_dtreg"
IF !ExecCommand(cSql,"MOV_CONT",.T.)  && ESEGUO QUERY CON POSSIBILITA' DI ANNULLO
	return(.f.)
ENDIF

SELECT MOV_CONT
GO TOP	
DO WHILE .T.

	IF EOF()
		EXIT
	ENDIF
	
	SELECT MOV_CONT
	
	WAIT WINDOWS "Elaborazione movimenti contabili (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT

	REG	 		= RIBALTA2(MOV_DTREG)
	DOC	 		= RIBALTA2(MOV_DTDOC)
	NUMREG 		= MOV_NREGIS
	PROT		= MOV_NPROT
	TTOP		= MOV_TOP				
	CON			= MOV_CONTO
	WDES_MANU	= MOV_DESMOV
	WCAMBIO		= MOV_CAMBIO	
	WCODVAL		= MOV_VALUTA
	MESE	 	= SUBSTR(REG,4,2)	
	ANNO_REG 	= SUBSTR(REG,7,4)
	
	____TIPOCO 	= ALLTRIM(CON_TIPOCO)
	
	NOTAC		= SUBSTR(LIBERA,11,1)
	FATTURA		= SUBSTR(LIBERA,2,1)
	SITFINAN	= SUBSTR(LIBERA,50,1)
	DESCRTOP	= DESCRI	

	SELECT MOV_CONT

	** SALVA NEL CURSORE APPOSITO IL TOP+DESCRIZIONE
	SELECT PARA_TOP
	SET ORDER TO PARA_TOP_I
	_TTOP = ALLTRIM(TTOP)
	SEEK _TTOP
	IF !FOUND()
		APPEND BLANK
		REPLACE	TOP_CODICE	WITH _TTOP
		REPLACE	TOP_DESCRI	WITH DESCRTOP
	ENDIF	
	
	SELECT MOV_CONT
	IMPD = 0
 	IMPA = 0
		
	IF SUBSTR(MOV_TMOV,1,1)='A'		&& AVERE
		IF F_VALUTA = 1
			IMPA = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		ELSE
			IMPA = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		ENDIF
		IMPD=0
	ENDIF
			
	IF SUBSTR(MOV_TMOV,1,1)='D'		&& DARE
		IF F_VALUTA = 1
			IMPD = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		ELSE
			IMPD = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		ENDIF
		IMPA=0
	ENDIF	

	IF NOTAC = "S" .AND. FATTURA = "S"										&& E' UNA NOTA DI CREDITO , VERIFICO SE SUL CLIENTE O SUL FORNITORE		
		IF ____TIPOCO ='C' 									
			IF F_VALUTA = 1
 				IMPD = (TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO CLIENTI
			ELSE
				IMPD = (TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO CLIENTI
			ENDIF
			IMPA=0
		ELSE
			IF F_VALUTA = 1
 				IMPA = (TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO FORNITORI
			ELSE
				IMPA = (TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO FORNITORI
			ENDIF
			IMPD=0
		ENDIF	
	ENDIF

	WSALDO		= IMPD - IMPA  && SALDO
	TOT_DARE	= TOT_DARE	+ IMPD
	TOT_AVERE	= TOT_AVERE + IMPA
	
	SELECT MOV_CONT
	
	TIPO_ELABORAZIONE = ""
	IF ____TIPOCO = 'C'
		TIPO_ELABORAZIONE = "CLIENTI"
	ENDIF
	IF ____TIPOCO = 'F'
		TIPO_ELABORAZIONE = "FORNITORI"
	ENDIF
	IMPORTO_CALCOLATO = 0
	IF TIPO_ELABORAZIONE = "CLIENTI"
		IMPORTO_CALCOLATO = IMPD
	ENDIF
	IF TIPO_ELABORAZIONE = "FORNITORI"
		IMPORTO_CALCOLATO = IMPA
	ENDIF
	
	IF TIPO_ELABORAZIONE = "CLIENTI"

		FOR _nAnno = 1 TO 8
			_cNomeVarAnno = "V_ANNO_" + ALLTRIM(STR(_nAnno,1,0))
			IF ANNO_REG = &_cNomeVarAnno
				_cNomeVarAnnoMese = "M.CON_DA" + ALLTRIM(MESE) + "_" + ALLTRIM(STR(_nAnno,1,0))
				&_cNomeVarAnnoMese = &_cNomeVarAnnoMese + IMPORTO_CALCOLATO
				_cNomeVarAnnoMeseUtile = "M.CON_UT" + ALLTRIM(MESE) + "_" + ALLTRIM(STR(_nAnno,1,0))
				&_cNomeVarAnnoMeseUtile = &_cNomeVarAnnoMeseUtile + IMPORTO_CALCOLATO
			ENDIF
		ENDFOR

	ENDIF
	
	IF TIPO_ELABORAZIONE = "FORNITORI"

		FOR _nAnno = 1 TO 8
			_cNomeVarAnno = "V_ANNO_" + ALLTRIM(STR(_nAnno,1,0))
			IF ANNO_REG = &_cNomeVarAnno
