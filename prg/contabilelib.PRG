FUNCTION TRASFERISCE_SCADENZE_SPECIALI
*!*	**************************************************************
*!*	FUNZIONE PER IL TRASFERIMENTO DELLE SCADENZE SPECIALI DA UN DOCUMENTO AD UN ALTRO
*!*	
*!*	PARAMETRI :
*!*	
*!*		_PAR_UNCINO_SORGENTE		:	CHIAVE DI ACCESSO ALL'ARCHIVIO DELLE SCADENZE SPECIALI (RECORD SORGENTE)
*!*	
*!*		_PAR_NUMORD					:	NUMERO DOCUMENTO PER L'ARCHIVIO DELLE SCADENZE SPECIALI DESTINAZIONE
*!*
*!*		_PAR_DATORD					:	DATA DOCUMENTO PER L'ARCHIVIO DELLE SCADENZE SPECIALI DESTINAZIONE
*!*
*!*
*!*	VARIABILE DI RITORNO :
*!*	
*!*		_RET_UNCINO_DESTINAZIONE	:	CHIAVE DI ACCESSO ALL'ARCHIVIO DELLE SCADENZE SPECIALI (RECORD DI DESTINAZIONE CREATI)
*!*	
*!*	

LPARAMETERS _PAR_UNCINO_SORGENTE,_PAR_NUMORD,_PAR_DATORD

IF PCOUNT() < 3
	RETURN ""
ENDIF

_SCAD_SELE=SELECT()

v_seek = _PAR_UNCINO_SORGENTE
IF seek_std('SCADENZE',v_seek,'TIPRENDO','TMP_SCADENZE')
ELSE
	RETURN ""
ENDIF

LOCAL _RET_UNCINO_DESTINAZIONE
_RET_UNCINO_DESTINAZIONE = STR(NEWPROG('NUMSSS01'),10)

SELECT TMP_SCADENZE
GO TOP
SCAN

    _TIPRENDO  = _RET_UNCINO_DESTINAZIONE
    _CODSOC    = ORD_CODSOC
    _IDFOR     = ORD_IDFOR
    _CODCLI    = ORD_CODCLI
    _RAGSOC    = ORD_RAGSOC
    _VALUTA    = ORD_VALUTA
    _CAMBIO    = ORD_CAMBIO
    _DATORD    = IIF(SUBSTR(_PAR_DATORD,3,1)='/',_PAR_DATORD,RIBALTA2(_PAR_DATORD))
    _NUMORD    = _PAR_NUMORD
    _TRANCH	   = ORD_TRANCH
    _VALORE	   = ORD_VALORE
    _CPA	   = ORD_CPA
    _SELEZIONE = ""
    _DTSCAD	   = ORD_DTSCAD
    _RIBA	   = ORD_RIBA
    _DESSCAD   = ORD_DESCRI
    _SEQUEN    = SEQUEN

	cSql = "select * from SCADENZE where 1=0"
	IF !ExecRW(cSql,"SCADENZE","R")
	  return(.f.)
	ENDIF

    SELECT SCADENZE
    APPEND BLANK

    REPLACE TIPRENDO  	WITH _TIPRENDO
    REPLACE ORD_CODSOC  WITH _CODSOC
    REPLACE ORD_IDFOR   WITH _IDFOR
    REPLACE ORD_CODCLI  WITH _CODCLI
    REPLACE ORD_RAGSOC  WITH _RAGSOC
    REPLACE ORD_VALUTA  WITH _VALUTA
    REPLACE ORD_CAMBIO  WITH _CAMBIO
    REPLACE ORD_DATORD  WITH _DATORD
    REPLACE ORD_NUMORD	WITH _NUMORD
    REPLACE ORD_TRANCH	WITH _TRANCH
    REPLACE ORD_VALORE	WITH _VALORE
    REPLACE ORD_CPA		WITH _CPA
    REPLACE SELEZIONE 	WITH _SELEZIONE
    REPLACE ORD_DTSCAD	WITH _DTSCAD
    REPLACE ORD_RIBA	WITH _RIBA
    REPLACE ORD_DESCRI	WITH ALLTRIM(_DESSCAD)
    REPLACE SEQUEN    	WITH _SEQUEN

	IF !ExecRW(cSql,"SCADENZE","W")
	  return(.f.)
	ENDIF

ENDSCAN


SELECT(_SCAD_SELE)

RETURN _RET_UNCINO_DESTINAZIONE
