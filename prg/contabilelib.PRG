    		=AUTOCONTROLLO_INSERISCE_CONTO(AUT_CONTO)
     		SELECT AUTOCONTROLLO_CONTI
   			SKIP +1  		
    		LOOP
   		ENDIF	   		

 		**==>> ACCESSO ALL'ANAGRAFICA CLIENTI PER PRELEVARE DESCRIZIONE
 		AUT_CERCA_CONTO_IN_ANACLI=AUTOCONTROLLO_CERCA_CONTO_SU_ANAGRAFICA_CLIENTE(AUT_CONTO)
   		IF AUT_CERCA_CONTO_IN_ANACLI
