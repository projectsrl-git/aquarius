***********************************************************************************
PROCEDURE QUAD_VAR
***********************************************************************************

TOTALE_DARE    = 0
TOTALE_AVERE   = 0
TOTALE_IMPOSTA = 0
T_DARE         = 0
T_AVERE        = 0
T_IMPOSTA      = 0
RIQUADRA       = 0

SELECT CORPO_MOV
SET ORDER TO I_CORPOMOV
GO TOP

IF EOF()
   =MESSAGEBOX('Nessun conto registrato',16,'*** ATTENZIONE ***')
   RETURN
ENDIF

DO WHILE !EOF()

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF DARE <> 0
      RIQUADRA=DARE+IMPOSTA+RIQUADRA
   ENDIF

   IF DARE <> 0
      T_DARE=DARE+T_DARE+IMPOSTA
      TOTALE_DARE = TOTALE_DARE + DARE
   ENDIF

   IF AVERE <> 0
      T_AVERE=AVERE+IMPOSTA+T_AVERE
      TOTALE_AVERE = TOTALE_AVERE + AVERE
   ENDIF

   IF AVERE = 0 .AND. DARE = 0                   && FATTURE CLIENTI CON MAT PUBBLICITARIO
      T_AVERE=AVERE+IMPOSTA+T_AVERE
      TOTALE_AVERE = TOTALE_AVERE + AVERE
   ENDIF


   ** 2015/05/26 FABIANO/SERGIO GESTIONE ANTICIPI CON CAMBIO SEGNO : IN QUESTO CASO IL VALORE ERA NEGATIVO E CON QUESTO FLAG RIESCO POI A RISALIRE AL VALORE NEGATIVO SIA IN PRIMA NOTA CHE IN BOLLATO
   IF   ANT_CAMB_SEGNO
        TOTALE_IMPOSTA  = TOTALE_IMPOSTA - IMPOSTA
   ELSE
        TOTALE_IMPOSTA  = TOTALE_IMPOSTA + IMPOSTA
  ENDIF
   ** 2015/05/26 FABIANO/SERGIO GESTIONE ANTICIPI CON CAMBIO SEGNO : IN QUESTO CASO IL VALORE ERA NEGATIVO E CON QUESTO FLAG RIESCO POI A RISALIRE AL VALORE NEGATIVO SIA IN PRIMA NOTA CHE IN BOLLATO


   SKIP +1

ENDDO

IF T_DARE<>T_AVERE
   =MESSAGEBOX('Attenzione totale DARE diverso da totale AVERE',16,'*** ATTENZIONE ***')
   SELECT CORPO_MOV
   SET ORDER TO I_CORPOMOV
   GO TOP
   RETURN
ENDIF

M.T_DARE        = TOTALE_DARE
M.T_AVERE       = TOTALE_AVERE
M.T_IMPOSTA     = TOTALE_IMPOSTA

RETURN


