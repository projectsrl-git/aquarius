***************************************************************************************
*  			 			CALCOLA IMPOSTA DA IMPONIBILE DOCUMENTO 			          *
***************************************************************************************
*
*  RESTITUISCE I VALORI: PUB_IMPONIB,PUB_IMPOSTA,PUB_VALORE
*
*
FUNCTION CALCOLA_IMPOSTA_TOTALE_DOCUMENTO
LPARAMETERS __COD_CLIENTE,__COD_IVA,__IMPONIBILE,__DATA_RIFERIMENTO


RELEASE PUB_IMPONIB,PUB_IMPOSTA,PUB_VALORE
PUBLIC PUB_IMPONIB,PUB_IMPOSTA,PUB_VALORE
PUB_IMPONIB	= 0
PUB_IMPOSTA	= 0
PUB_VALORE  = 0


SWS_IVA_SWS=SELECT()

PUBLIC VET_DAL[2],VET_AL[2],VET_DAY[2],DATA_SCAD

x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
x_codi = "cli_codcli = '" + __COD_CLIENTE + "'"
x_cond = x_soci + " and " + x_codi
cSql = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"CUR_CLIENTE")
   RETURN .F.
ENDIF
SELECT CUR_CLIENTE
GO TOP
IF EOF()
   _ESENZI=.F.				&& CLIENTE NON IN ESENZIONE
   _ALRID = CERCA_IVA_DEFAULT("","CODICE",RIBALTA2(__DATA_RIFERIMENTO))
ELSE
   _ALRID    = CLI_ALRID
   IF !EMPTY(CLI_ALRID)
      _ESENZI = .T.			&& CLIENTE IN ESENZIONE
   ELSE
      _ALRID = CERCA_IVA_DEFAULT("","CODICE",RIBALTA2(__DATA_RIFERIMENTO))
      _ESENZI = .F.			&& CLIENTE NON IN ESENZIONE
   ENDIF
ENDIF


IF reccount() <> 0
   VET_DAL[1] = CLI_BDAL
   VET_DAL[2] = CLI_B2DAL
   VET_AL[1]  = CLI_BAL
   VET_AL[2]  = CLI_B2AL
   VET_DAY[1] = CLI_GG1
   VET_DAY[2] = CLI_GG2
   IVA_ESE    = CLI_ALRID
   IVA_CLI    = CLI_CODIVA
   V_CLIES    = CLI_CLIES
   V_DTCLES   = CLI_DTCLES
   V_NSES	  = CLI_NSES
   V_DTNSES   = CLI_DTNSES
   _ALRID     = CLI_ALRID
   IF !EMPTY(CLI_ALRID)
      _ESENZI = .T.			&& CLIENTE IN ESENZIONE
   ELSE
      _ALRID = CERCA_IVA_DEFAULT("","CODICE",RIBALTA2(__DATA_RIFERIMENTO))
      _ESENZI = .F.			&& CLIENTE NON IN ESENZIONE
   ENDIF

   ___FLAG_POSALL = CLI_POSALL			&& POSTICIPI PER TUTTO L'ANNO
   ___CLIENTE     = __COD_CLIENTE		&& POSTICIPI PER TUTTO L'ANNO


ELSE
   VET_DAL[1] = "0000"
   VET_DAL[2] = "0000"
   VET_AL[1]  = "0000"
   VET_AL[2]  = "0000"
   VET_DAY[1] = "0000"
   VET_DAY[2] = "0000"
   IVA_ESE	  = ""
   IVA_CLI	  = ""
   V_CLIES	  = ""
   V_DTCLES   = ""
   V_NSES	  = ""
   V_DTNSES   = ""
   _ALRID = CERCA_IVA_DEFAULT("","CODICE",RIBALTA2(__DATA_RIFERIMENTO))
   _ESENZI = .F.			&& CLIENTE NON IN ESENZIONE

   ___FLAG_POSALL = .F.		&& POSTICIPI PER TUTTO L'ANNO
   ___CLIENTE     = ""		&& POSTICIPI PER TUTTO L'ANNO

ENDIF

PUB_IMPONIB = 0
PUB_IMPOSTA = 0
PUB_VALORE  = 0
MATPUBX     = 0
M.T_OMAGGIO = 0
M.I_OMAGGIO = 0
IVA1   		= SPACE(3)
IVA2   		= SPACE(3)
IVA3   		= SPACE(3)
IVA4   		= SPACE(3)
IVA5   		= SPACE(3)
IMPO1  		= 0
IMPO2  		= 0
IMPO3  		= 0
IMPO4  		= 0
IMPO5  		= 0
IMPOS1 		= 0
IMPOS2 		= 0
IMPOS3 		= 0
IMPOS4 		= 0
IMPOS5 		= 0

_CT_PUBBLI 	= 0
_CT_OMAGGI  = 0




COD_IVA = __COD_IVA
IMPONIB = __IMPONIBILE

v_seek	= 'IVA'+COD_IVA
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   ALIQ = SUBSTR(LIBERA,1,3)
   NUM_ALIQ = VAL(ALIQ)
ELSE
   NUM_ALIQ = 0
ENDIF


IMPOSTA = (IMPONIB * NUM_ALIQ) / 100



IF EMPTY(IVA1) .OR. (IVA1 = COD_IVA)
  IVA1   = COD_IVA
  IMPO1  = IMPO1+IMPONIB
  IMPOS1 = IMPOS1 + IMPOSTA
ELSE
  IF EMPTY(IVA2) .OR. (IVA2 = COD_IVA)
     IVA2   = COD_IVA
     IMPO2  = IMPO2+IMPONIB
     IMPOS2 = IMPOS2 + IMPOSTA
  ELSE
     IF EMPTY(IVA3) .OR. (IVA3 = COD_IVA)
        IVA3   = COD_IVA
        IMPO3  = IMPO3+IMPONIB
        IMPOS3 = IMPOS3 + IMPOSTA
     ELSE
        IF EMPTY(IVA4) .OR. (IVA4 = COD_IVA)
           IVA4   = COD_IVA
           IMPO4  = IMPO4+IMPONIB
           IMPOS4 = IMPOS4 + IMPOSTA
        ELSE
           IF EMPTY(IVA5) .OR. (IVA5 = COD_IVA)
              IVA5   = COD_IVA
              IMPO5  = IMPO5+IMPONIB
              IMPOS5 = IMPOS5 + IMPOSTA
           ENDIF
        ENDIF
     ENDIF
  ENDIF
ENDIF


V_SPESE = 0
V_IMPSP = 0


* -->> INSERISCO L'IVA DELLE SPESE(22%) SULLE IVE AL 22
FOR HF=1 TO 5
  _IMPO ="IMPO"+ALLTRIM(STR(HF))
  _IMPOS="IMPOS"+ALLTRIM(STR(HF))
  IF ROUND((&_IMPOS/&_IMPO)*100,0)=20
     &_IMPOS=&_IMPOS+V_IMPSP
     EXIT
  ENDIF
NEXT

IMPOS1		=	ROUND((IMPOS1+.0000),2)
IMPOS2		=	ROUND((IMPOS2+.0000),2)
IMPOS3		=	ROUND((IMPOS3+.0000),2)
IMPOS4		=	ROUND((IMPOS4+.0000),2)		
IMPOS5		=	ROUND((IMPOS5+.0000),2)

PUB_IMPONIB = IMPO1 + IMPO2 + IMPO3 + IMPO4 + IMPO5
PUB_IMPOSTA = IMPOS1 + IMPOS2 + IMPOS3 + IMPOS4 + IMPOS5

PUB_IMPONIB = PUB_IMPONIB + V_SPESE
PUB_VALORE  = PUB_IMPONIB + PUB_IMPOSTA - MATPUBX




RETURN



