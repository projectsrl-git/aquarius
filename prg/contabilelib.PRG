LOCAL __I

FOR __I=1 TO _LUNG_STRI

   	IF SUBSTR(_STRI,__I,1) = "." OR SUBSTR(_STRI,__I,1) = "." OR SUBSTR(_STRI,__I,1) = "0" OR SUBSTR(_STRI,__I,1) = "1" OR SUBSTR(_STRI,__I,1) = "2" OR SUBSTR(_STRI,__I,1) = "3" OR SUBSTR(_STRI,__I,1) = "4" OR SUBSTR(_STRI,__I,1) = "5" OR SUBSTR(_STRI,__I,1) = "6" OR SUBSTR(_STRI,__I,1) = "7" OR SUBSTR(_STRI,__I,1) = "8" OR SUBSTR(_STRI,__I,1) = "9"
   	ELSE
		_NOMENCLATURA_CORRETTA   = .F. 
		EXIT  		
   	ENDIF


ENDFOR

RETURN _NOMENCLATURA_CORRETTA

