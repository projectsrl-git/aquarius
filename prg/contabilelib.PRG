**********************
FUNCTION CALCFOR
**********************
* Funzione di calcolo totali per programma mandati ordinari
* Viene utilizzato nel report MAND002

PARA _CODICE
PRIVATE FS

FS = SELECT()

SELECT TFORN
SET ORDER TO CODICE
SEEK _CODICE
IF !FOUND()
   RETURN 0
ENDIF

ESCI = 0

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP + 1
      LOOP
   ENDIF

   IF CODICE = _CODICE
   ELSE
      EXIT
   ENDIF

   ESCI = ESCI + TOTMAND

   SELECT TFORN
   SKIP + 1

ENDDO

SELECT(FS)

RETURN(ESCI)


