******************
PROCEDURE FANNICLX
******************

***************************************************
*  AGGIORNA CONTI :                               *
*     - ESERCIZIO IN CHIUSURA :                   *
*         - ELABORA MO_CONCA TRATTANDO I TOP CHI  *
*           AGGIORNA CONTI                        *
*                                                 *
*     - ESERCIZIO IN APERTURA :                   *
*         - ELABORA MO_CONCA TRATTANDO I TOP APE  *
*           AGGIORNA CONTI                        *
*                                                 *
*                                                 *
*     - RIVALUTA IN BASE AL CAMBIO DI MOV_CONT    *
*                                                 *
*                                                 *
*                                                 *
*                                                 *
***************************************************

WAIT WINDOW "Stň aggiornando i saldi anno in chiusura "+PUB_ANNO  NOWAIT

QU = 0

x_soci = "mov_soc = '" + PUB_CODSOC + "'"
x_cond = x_soci
Csql   = "select * from mo_conca where " + x_cond + " order by mov_soc,mov_anno,mov_conto"
IF !ExecCommand(cSql,"cur_moconca")
   return(.f.)
ENDIF
SELECT cur_moconca
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF MOV_TOP  <> "CHI"
      SKIP +1
      LOOP
   ENDIF

   *** AGGIORNO IL DATABASES CONTI

   DA  = 0
   AV  = 0

   IF MOV_TMOV  = "D" .OR. MOV_TMOV  = "A"
   ELSE
      WAIT WINDOW "Registrazione senza D/A"+STR(MOV_NREGIS,10,0)+"<<<<<<<<<<<<"
      SKIP +1
      LOOP
   ENDIF

   IF MOV_TMOV  = "D"
      DA =  MOV_IMP
   ENDIF

   IF MOV_TMOV  = "A"
      AV =  MOV_IMP
   ENDIF

   XNR     = MOV_NREGIS
   XNP     = MOV_NUMPRO
   XCONTO  = MOV_CONTO
   DATAREG = MOV_DTREG
   XVALUTA = PUB_VALRIF
   XCAMBIO = 1

   x_soci = "con_soc = '" + PUB_CODSOC + "'"
   x_anno = "con_anno = '" + PUB_ANNO + "'"
   x_cont = "con_conto = '" + ALLTRIM(XCONTO) + "'"
   x_cond = x_soci + " and " + x_anno + " and " + x_cont
   Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
   IF !ExecRW(cSql,"conti","R")
      return(.f.)
   ENDIF
   SELECT conti
   GO TOP
   IF !EOF()
      MESE     = SUBSTR(DATAREG,6,2)
      D_ARE    = "CON_DA"+"12"
      A_VERE   = "CON_AV"+"12"
      P_IMPD   = CON_IMP_D
      P_IMPA   = CON_IMP_A
      IF DA <> 0
  	     REPLACE CON_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,DA,XCAMBIO)  	&& SALDO TOTALE
         REPLACE &D_ARE      WITH &D_ARE+CAMBIO(XVALUTA,DA,XCAMBIO)  	&& SINGOLO MESE
