************************************
PROCEDURE CALC_MOV
************************************

x_soci = "mov_soc = '" + PUB_CODSOC + "'"
x_anno = "mov_anno = '" + PUB_ANNO + "'"
x_cont = "mov_conto = '" + ALLTRIM(CONTO_IN) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
cSql   = "select * from mov_cont where " + x_cond + " order by mov_soc,mov_anno,mov_conto,mov_sequen"
IF !ExecCommand(cSql,"CUR_MOVCONT")
   RETURN .F.
ENDIF
SELECT CUR_MOVCONT
GO TOP		

DA = 0
AV = 0
OK_TROV = .F.

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF MOV_TOP = "CHI"
      IF !F_CHIUSURA                && NON TRATTA I MOVIMENTI DI CHIUSURA
         SELECT CUR_MOVCONT
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   IF !ALL_MESI            && CONTROLLA SOLO IL MESE DESIDERATO
      IF VAL(SUBSTR(MOV_DTREG,6,2)) <> VAL(MESECON)
         SELECT CUR_MOVCONT
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   *** CALCOLO SALDI

   IF MOV_TMOV  = "D"
      DA = DA +  CAMBIO(MOV_VALUTA,MOV_IMP,MOV_CAMBIO)
   ENDIF

   IF MOV_TMOV  = "A"
      AV = AV +  CAMBIO(MOV_VALUTA,MOV_IMP,MOV_CAMBIO)
   ENDIF

   OK_TROV= .T.
   * WAIT WINDOW "IN ELAB.SU MOV."+V_SEEK +"-"+STR(DA)+"-"+STR(AV)+"-"

   IF MOV_TMOV = "D" .OR.  MOV_TMOV = "A"
   ELSE
      WAIT WINDOW "Conto :"+CONTO_IN+"con movimenti con D/A errato"
   ENDIF

   QU = QU + 1
   WAIT WINDOW "Movimenti elaborati "+STR(QU,10,0) NOWAIT

   SELECT CUR_MOVCONT
   SKIP +1

ENDDO

IF OK_TROV
   FL_ERR = .F.
   IF P_IMPD      <> DA
      FL_ERR = .T.
   ENDIF
   IF P_IMPA      <> AV
      FL_ERR = .T.
   ENDIF
   IF FL_ERR
      DO ERR_MOV
   ENDIF
   * WAIT WINDOW "IN ELAB.SU CONTO."+CONTO_IN +"-"+STR(P_IMPD)+"-"+STR(P_IMPA)+"-"
ENDIF

RETURN

***********************************
PROCEDURE ERR_MOV
***********************************

SELECT DB_ERROR
APPEND BLANK
REPLACE C_CONTO    WITH CONTO
REPLACE C_DESCRI   WITH DESCRI

REPLACE M_DARE     WITH DA                             && MOVIMENTI
REPLACE M_AVERE    WITH AV                             && MOVIMENTI

REPLACE C_DARE     WITH P_IMPD         && CONTI
REPLACE C_AVERE    WITH P_IMPA             && CONTI

RETURN


