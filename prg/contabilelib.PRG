*************************************************************************
*                CREA SALDI CONTI CONTABILI DA MOV_CONT					*
*************************************************************************
*!*	LA FUNZIONE RITORNA UN CURSORE CONTENENTE L'ANNO/MESE IL CODICE DEL CONTO,IL TOTALE DARE,AVERE,SALDO
*!*	DEL SINGOLO CONTO CONTABILE OPPURE DI TUTTI I CONTI
*!*	
*!*	PARAMETRI:
*!*	
*!*	__TUTTI_CONTI_ = 'SALDO_COMPLETO' 		: CREA I SALDI DI TUTTI I CONTI CONTABILI DELL'ANNO DESIDERATO
*!*	__TUTTI_CONTI_ = 'SALDO_COMPLETO_TOP' 	: CREA I SALDI DI TUTTI I CONTI CONTABILI DELL'ANNO DESIDERATO ANALIZZANDO SOLO IL TOP RICHIESTO E PASSATO ALLA FUNZIONE
*!*	__TUTTI_CONTI_ = 'SALDO_CONTO' 			: CREA IL SALDO DEL CONTO CONTABILE INDICATO PER L'ANNO DESIDERATO
*!*	__TUTTI_CONTI_ = 'SALDO_CONTO_TOP' 	    : CREA IL SALDO DEL CONTO CONTABILE INDICATO PER L'ANNO DESIDERATO ANALIZZANDO SOLO IL TOP RICHIESTO E PASSATO ALLA FUNZIONE
*!*	
*!*	
*!*	OUTPUT 	: 	SALDI_CONTI					: CURSORE CONTENENTE IL ANNO/MESE , CODICE DEL CONTO, TOTALE DARE,AVERE,SALDO
*!*	
*!*	
FUNCTION CREA_SALDI_CONTI_CONTABILI
PARA __TUTTI_CONTI_,__CODICE_CONTO_,__ANNO_,__TOP_

ScxS=STR(SELECT())

IF USED("SALDI_CONTI")
	SELECT SALDI_CONTI
	USE
ENDIF

cSql=""
cNomeCursorSql="SALDI_CONTI"

DO CASE

	*** FABIANO 01/11/2012 - CORREGGO LA CONDIZIONE DEL CASE CON == PERCHE' NON DISTINGUE 'SALDO_CONTO' DA 'SALDO_CONTO_TOP'
	
	CASE __TUTTI_CONTI_ == 'SALDO_COMPLETO'
		
		TEXT TO CSQL NOSHOW

			SELECT MOV_CONTO,SUBSTRING(MOV_DTREG,1,7) AS ANNOMM,
				SUM(CASE WHEN MOV_TMOV='D' THEN MOV_IMP ELSE 0 END) AS DARE,
				SUM(CASE WHEN MOV_TMOV='A' THEN MOV_IMP ELSE 0 END) AS AVERE,
				SUM(CASE WHEN MOV_TMOV='D' THEN MOV_IMP ELSE -1*MOV_IMP END) AS SALDO
			FROM MOV_CONT
			WHERE MOV_ANNO = '<<__ANNO_>>'
			GROUP BY MOV_CONTO,SUBSTRING(MOV_DTREG,1,7)
			ORDER BY MOV_CONTO,SUBSTRING(MOV_DTREG,1,7)


		ENDTEXT

	CASE __TUTTI_CONTI_ == 'SALDO_COMPLETO_TOP'
		
		TEXT TO CSQL NOSHOW

			SELECT MOV_CONTO,SUBSTRING(MOV_DTREG,1,7) AS ANNOMM,
				SUM(CASE WHEN MOV_TMOV='D' THEN MOV_IMP ELSE 0 END) AS DARE,
				SUM(CASE WHEN MOV_TMOV='A' THEN MOV_IMP ELSE 0 END) AS AVERE,
				SUM(CASE WHEN MOV_TMOV='D' THEN MOV_IMP ELSE -1*MOV_IMP END) AS SALDO
			FROM MOV_CONT
			WHERE MOV_ANNO = '<<__ANNO_>>' AND MOV_TOP = '<<__TOP_>>'
			GROUP BY MOV_CONTO,SUBSTRING(MOV_DTREG,1,7)
			ORDER BY MOV_CONTO,SUBSTRING(MOV_DTREG,1,7)

		ENDTEXT


	CASE __TUTTI_CONTI_ == 'SALDO_CONTO'
		
		TEXT TO CSQL NOSHOW

			SELECT MOV_CONTO,SUBSTRING(MOV_DTREG,1,7) AS ANNOMM,
				SUM(CASE WHEN MOV_TMOV='D' THEN MOV_IMP ELSE 0 END) AS DARE,
				SUM(CASE WHEN MOV_TMOV='A' THEN MOV_IMP ELSE 0 END) AS AVERE,
				SUM(CASE WHEN MOV_TMOV='D' THEN MOV_IMP ELSE -1*MOV_IMP END) AS SALDO
			FROM MOV_CONT
			WHERE MOV_ANNO = '<<__ANNO_>>' AND MOV_CONTO = '<<__CODICE_CONTO_>>'
			GROUP BY MOV_CONTO,SUBSTRING(MOV_DTREG,1,7)
			ORDER BY MOV_CONTO,SUBSTRING(MOV_DTREG,1,7)

		ENDTEXT



	CASE __TUTTI_CONTI_ == 'SALDO_CONTO_TOP'
		
		TEXT TO CSQL NOSHOW

			SELECT MOV_CONTO,SUBSTRING(MOV_DTREG,1,7) AS ANNOMM,
				SUM(CASE WHEN MOV_TMOV='D' THEN MOV_IMP ELSE 0 END) AS DARE,
				SUM(CASE WHEN MOV_TMOV='A' THEN MOV_IMP ELSE 0 END) AS AVERE,
				SUM(CASE WHEN MOV_TMOV='D' THEN MOV_IMP ELSE -1*MOV_IMP END) AS SALDO
			FROM MOV_CONT
			WHERE MOV_ANNO = '<<__ANNO_>>' AND MOV_CONTO = '<<__CODICE_CONTO_>>' AND MOV_TOP = '<<__TOP_>>'
			GROUP BY MOV_CONTO,SUBSTRING(MOV_DTREG,1,7)
			ORDER BY MOV_CONTO,SUBSTRING(MOV_DTREG,1,7)

		ENDTEXT





ENDCASE



IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF		




SELECT &ScxS

RETURN


