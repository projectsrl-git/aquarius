____E_SONO_PROPRIO_QUI = RECNO()
GO TOP

IF !EOF()

	DO WHILE.NOT.EOF()

		IF DELETED()
			SELECT cu_rif_cf
			SKIP +1
			LOOP	
		ENDIF
		
		IF ALLTRIM(RIF_CODICE) = ALLTRIM(M.RIF_CODICE)
