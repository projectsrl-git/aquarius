	PROCEDURE optiongroup1.Valid
		
		WITH THISFORM.olecontrol1
			IF THIS.Value = 1
				.ChartType = 1  && 2d Bar
				*** LAYOUT LABELS BARRE DELLE SERIE
				FOR _nSerie = 1 TO .columnCount
					*.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.LocationType = 5  && VtChLabelLocationTypeInside
					*.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.TextLayout.Orientation = 2  && VtOrientationUp
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.LocationType = 1  && VtChLabelLocationTypeAbovePoint
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.TextLayout.Orientation = 0  && VtOrientationHorizontal
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.VtFont.Name = "Arial"
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.VtFont.Size = 8
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.VtFont.Style = 1  && Bold
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.VtFont.VtColor.Set(0,0,255)
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.ValueFormat = "0.00"
				ENDFOR
			ELSE
				.ChartType = 3  && 2d Line
				*** LAYOUT LABELS LINEE DELLE SERIE
				FOR _nSerie = 1 TO .columnCount
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.LocationType = 1  && VtChLabelLocationTypeAbovePoint
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.TextLayout.Orientation = 0  && VtOrientationHorizontal
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.VtFont.Name = "Arial"
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.VtFont.Size = 8
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.VtFont.Style = 1  && Bold
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.VtFont.VtColor.Set(0,0,255)
					.Plot.SeriesCollection(_nSerie).DataPoints(-1).DataPointLabel.ValueFormat = "0.00"
				ENDFOR
			ENDIF
		ENDWITH
	ENDPROC


	PROCEDURE cmdStampa.Click

*!*			_OLD_SEL = SELECT()

*!*			*** COPIA IL GRAFICO NELLA CLIPBOARD
*!*			THISFORM.olecontrol1.Refresh
*!*			THISFORM.olecontrol1.EditCopy

*!*			*** SALVA L'IMMAGINE SU DISCO E LA STAMPA NEL REPORT SPECIFIATO
*!*			cTargetFile = SYS(5) + SYS(2003) + "\clipboard" + SYS(2015) + ".bmp"
*!*			DO PRG\CREA_IMMAGINE_DA_CLIPBOARD WITH cTargetFile

*!*			IF FILE(cTargetFile)
*!*				IF USED("CUR_STA_IMAGE")
*!*					SELECT CUR_STA_IMAGE
*!*					USE
*!*				ENDIF
*!*				CREATE CURSOR CUR_STA_IMAGE (FILENAME C(254))
*!*				APPEND BLANK
*!*				REPLACE FILENAME WITH cTargetFile

*!*				DO PRG\MENUSTA WITH "CUR_STA_IMAGE",.T.,.F.,"XXX","SITFINAN_GRAPH","SITFINAN_GRAPH.FRX",.F.

*!*				SELECT CUR_STA_IMAGE
*!*				USE

*!*				_command = "DELETE FILE '" + ALLTRIM(cTargetFile) + "'"
*!*				&_command
*!*			ENDIF

*!*			*** SVUOTO LA CLIPBOARD DI WINDOWS
*!*			_CLIPTEXT = ""

*!*			SELECT(_OLD_SEL)
				
		***############################################################################################################
		*** Codice sostituito con funzioni interamente basate sulle API di Windows
		*** a causa del BUG: MSChart EditCopy Sends Incorrect Legends To Clipboard
		*** Vedi http://support.microsoft.com/kb/197487/it
		***############################################################################################################

		_OLD_SEL = SELECT()

		*** COPIA L'IMMAGINE DEL FORM IN UN FILE BMP ATTRAVERSO LA CLIPBOARD DI WINDOWS
		_opzcopy = "FILE"
		_Left = 0
		_Top = 0
		_Width = THISFORM.olecontrol1.Width - 7
		_Height = THISFORM.olecontrol1.Height - 9
		_nomefile = SYS(5) + SYS(2003) + "\clipboard" + SYS(2015) + ".bmp"
		DO PRG\CATTURA_IMMAGINE_FORM WITH _opzcopy,_Left,_Top,_Width,_Height,_nomefile

		IF FILE(_nomefile)
			IF USED("CUR_STA_IMAGE")
				SELECT CUR_STA_IMAGE
				USE
			ENDIF
			CREATE CURSOR CUR_STA_IMAGE (FILENAME C(254))
			APPEND BLANK
			REPLACE FILENAME WITH _nomefile
			
			DO PRG\MENUSTA WITH "CUR_STA_IMAGE",.T.,.F.,"XXX","SITFINAN_GRAPH","SITFINAN_GRAPH.FRX",.F.
			
			SELECT CUR_STA_IMAGE
			USE
			
			_command = "DELETE FILE '" + ALLTRIM(_nomefile) + "'"
			&_command
		ENDIF

		*** SVUOTO LA CLIPBOARD DI WINDOWS
		_CLIPTEXT = ""

		SELECT(_OLD_SEL)
		
	ENDPROC


