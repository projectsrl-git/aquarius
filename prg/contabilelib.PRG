      IF V_CHIUSO
         SKIP +1
         LOOP
      ENDIF
   ENDIF													&& PARTE NUOVA

   XXANOMAX	= PAR_ANOMAX

   SELECT PART_EUR
   SET ORDER TO PART_EUR
   SEEK ALLTRIM(JCONTO) + STR(JPARTITA,10,0)
   IF FOUND()
      IF CODNAZ = SPACE(03)
         REPLACE CODNAZ WITH XXCODNAZ
         REPLACE DESNAZ WITH XXDESNAZ
      ENDIF
      REPLACE RAGSOC WITH XXRAGSOC
      REPLACE ANOMAX WITH XXANOMAX
   ENDIF

   SELECT CUR_PART_FORN
   SKIP + 1

ENDDO

WAIT CLEAR
SELECT PART_EUR
GO TOP

RETURN


