*****************************************************************************
PROCEDURE AUT_DACF  &&  CONTROPARTITE DA CLIENTI/FORNITORI ******************
*****************************************************************************
* DIGITO IMPORTO TOTALE DOCUMENTO
* DIGITO IL CONTO DELLA PRIMA CONTROPARTITA
* FACCIO ABBINAMENTO TRA PARTITA PRIMARIA E CONTROPARTITE DA ANACLI/ANAFOR

IF PR_ANA1 && CARICA LA LISTA SOLO SE NON  E' GIA' STATO FATTO
   RETURN
ENDIF

PR_ANA1 = .T.

IF (PUB_VARPN=.T.) .OR. (PUB_ANNPN=.T.)
ELSE
   IF ACCODA
      IF !EMPTY(CCOD01)
         APPEND BLANK
         STORE SPACE(13) TO M.CECO
         STORE 0         TO M.DARE
         STORE 0         TO M.AVERE
         STORE SPACE(03) TO M.IVA
         STORE 0         TO M.IMPOSTA
         IF EMPTY(CO_IVA)
            TIP       = " "
            PUB_ERRORE=MESSAGEBOX('PER CORTESIA INSERIRE CODICE IVA '+CHR(13)+'IN ANAGRAFICA CLIENTI/FORNITORI',64,'*** ATTENZIONE ***')
         ENDIF
         IF !EMPTY(CO_IVA)
            v_seek	 = 'TOP' + M.TOP
            v_chiave = "codice"
            IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
               SELECT CUR_PARA
               TP     = SUBSTR(LIBERA,1,1)
               NATURA = TP
               TIP    = SUBSTR(LIBERA,2,1)
            ELSE
               NATURA = "D"
               TIP    = " "
            ENDIF
            STORE CO_IVA TO M.IVA
            v_seek	 = 'IVA'+M.IVA
            v_chiave = "codice"
            IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
            ELSE
               PUB_ERRORE=MESSAGEBOX('Codice iva non esistente'+CHR(13)+;
                                     'in arhivio parametri',64,'*** ATTENZIONE ***')
            ENDIF
            SELECT CUR_PARA
            LIB       = VAL(SUBSTR(LIBERA,1,3))
            PERIVAI   = VAL(SUBSTR(LIBERA,110,3))
            TIPOIVA   = SUBSTR(LIBERA,100,1)
            SCARTO    = 0
            M.IMPOSTA = M.TOTDOCU - (M.TOTDOCU  * 100 / (LIB+100))
            IF XVALUTA = "ITL" .OR.  M.XVALUTA = "LIT"
               IF M.IMPOSTA-INT(M.IMPOSTA)<>0
                  M.IMPOSTA = INT(M.IMPOSTA)+1
               ENDIF
            ELSE
               M.IMPOSTA    = ROUND((M.IMPOSTA),2)
            ENDIF
            * GESTIONE AUTOMATICA IMPORTO SU CONTROPARTITA
            IF NATURA = "D"
               M.AVERE = M.TOTDOCU - M.IMPOSTA
            ENDIF
            IF NATURA = "A"
               M.DARE  = M.TOTDOCU - M.IMPOSTA
            ENDIF
            ** GESTIONE IVA INDEDUCIBILE AL XXX%
            IF PERIVAI <> 0
               M.IMPOSTA =(M.AVERE+M.DARE)*LIB/100
               IF XVALUTA = "ITL" .OR.  M.XVALUTA = "LIT"
                  IF M.IMPOSTA-INT(M.IMPOSTA)<>0
                     M.IMPOSTA = INT(M.IMPOSTA)+1
                  ENDIF
               ELSE
                  M.IMPOSTA    = ROUND((M.IMPOSTA),2)
               ENDIF
               IVINDE=M.IMPOSTA*(PERIVAI/100)
               IF XVALUTA = "ITL" .OR.  M.XVALUTA = "LIT"
                  IF IVINDE-INT(IVINDE)<>0
                     IVINDE=INT(IVINDE)+1
                  ENDIF
               ELSE
                  IVINDE =       ROUND((IVINDE),2)
               ENDIF
               =RIPORTAI()           && RIPORTA IL VALORE SUL COSTO
            ENDIF
         ENDIF
         * ===>>> SE NO FATTURA / CORRISPETTIVO NON CALCOLA IVA
         IF TIP = "S" .OR. TIP = "C"
         ELSE
            IF NATURA = "D"
               M.AVERE = M.TOTDOCU
            ENDIF
            IF NATURA = "A"
               M.DARE = M.TOTDOCU
            ENDIF
            STORE "NO" TO M.IVA
            STORE 0    TO M.IMPOSTA
         ENDIF
         STORE X_DESMOV TO M.DESCRIZ
         STORE X_DESMO1 TO M.DESCRI1
         STORE CCOD01   TO M.CONTO
         x_soci = "con_soc = '" + PUB_CODSOC + "'"
         x_anno = "con_anno = '" + PUB_ANNO + "'"
         x_cont = "con_conto = '" + ALLTRIM(M.CONTO) + "'"
         x_cond = x_soci + " and " + x_anno + " and " + x_cont
         Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
         IF !ExecCommand(cSql,"cur_conti")
            return(.f.)
         ENDIF
         SELECT cur_conti
         GO TOP
         IF EOF()
         ELSE
            M.DESCRIC = CON_DESCR
         ENDIF
         SELECT CORPO_MOV
