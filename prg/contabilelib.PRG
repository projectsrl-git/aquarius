**************************************************************************
FUNCTION NEWPROG           && AGGIORNA NUMERO PROGRESSIVO INTERNO
**************************************************************************
PARA V1

v_seek   = V1
v_chiave = "codice"
cSql     = "select * from para where " + v_chiave + " = '" + v_seek + "'"
IF !ExecRW(cSql,"PARA","R")
   return(.f.)
ENDIF
SELECT PARA
IF RECCOUNT() <> 0
   V2=VAL(LIBERA)
   REPLACE LIBERA WITH STR(V2+1)
ELSE
   **=> PROJECT - INIZIO 10/11/2005
   * V2=0
   V2_X = SUBSTR(DTOC(DATE()),10,1)
   V2_X = V2_X + '000000000'
   V2   = VAL(V2_X)
   **=> PROJECT - FINE 10/11/2005
   APPEND BLANK
   REPLACE CODICE WITH V1
   REPLACE LIBERA WITH STR(V2+1)
   REPLACE DESCRI WITH "NUMERO PROGRESSIVO - "+V1
ENDIF
V_CAM = ALLTRIM(SUBSTR(LIBERA,1,10))
V_LEN = LEN(V_CAM)
V_DIF = 10 - V_LEN
IF V_DIF = 0
ELSE
   V_DAT = DTOC(DATE())
   V_LIB = SUBSTR(V_DAT,10,1)
   IF V_DIF = 9
      V_LIB = V_LIB + '00000000' + V_CAM
   ENDIF
   IF V_DIF = 8
      V_LIB = V_LIB + '0000000' + V_CAM
   ENDIF
   IF V_DIF = 7
      V_LIB = V_LIB + '000000' + V_CAM
   ENDIF
   IF V_DIF = 6
      V_LIB = V_LIB + '00000' + V_CAM
   ENDIF
   IF V_DIF = 5
      V_LIB = V_LIB + '0000' + V_CAM
   ENDIF
   IF V_DIF = 4
      V_LIB = V_LIB + '000' + V_CAM
   ENDIF
   IF V_DIF = 3
      V_LIB = V_LIB + '00' + V_CAM
   ENDIF
   IF V_DIF = 2
      V_LIB = V_LIB + '0' + V_CAM
   ENDIF
   IF V_DIF = 1
      V_LIB = V_LIB + V_CAM
   ENDIF
   REPLACE LIBERA WITH V_LIB
ENDIF
IF !ExecRW(cSql,"PARA","W")
   return(.f.)
ENDIF


RETURN(V2)


