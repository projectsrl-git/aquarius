IF M.IVA_OTTOBR<> 0
	*M.IVA_10RESI	= M.IVA_09RESI- M.IVA_OTTOBR
	__PLAFOND_RESIDUO  =	M.IVA_10RESI
ENDIF

IF M.IVA_NOVEMB<> 0
	*M.IVA_11RESI	= M.IVA_10RESI- M.IVA_NOVEMB
	__PLAFOND_RESIDUO  =	M.IVA_11RESI
ENDIF

IF M.IVA_DICEMB<> 0
	*M.IVA_12RESI	= M.IVA_11RESI- M.IVA_DICEMB
	__PLAFOND_RESIDUO  =	M.IVA_12RESI
