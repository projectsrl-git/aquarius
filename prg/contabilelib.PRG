**=> ERASMO - INIZIO 08/04/2024
*** RICERCA PARTITE FORNITORI SLEGATE TRA I PAGAMENTI APPENA INIBITI, PER PROPORRE LEGAME AUTOMATICO, EVITANDO DI DOVERLO FARE SEPARATAMENTE DAL FORM DEL PARTITARIO
IF !EMPTY(_CONTO_VIS_ANT_FORN) AND !EMPTY(_c_N_PARTITE)
	*** CERCO IL NR. PARTITA APPENA ASSEGNATO ALLA FATTURA CHE STO REGISTRANDO
	_n_N_PART_FAT = 0
	_c_DTSCAD_FAT = ""
	x_soci = "PAR_CODSOC = '" + PUB_CODSOC + "'"
	x_prog = "PAR_NPROG <> 100"
	x_codi = "PAR_CODCLI = '" + ALLTRIM(_CONTO_VIS_ANT_FORN) + "'"
	x_npro = "PAR_NUMPRO = '" + ALLTRIM(PN_C) + "'"
	x_cond = x_soci + " and " + x_prog + " and " + x_codi + " and " + x_npro 
	pSql   = "SELECT PAR_NPART, PAR_DTSCAD FROM PART_FOR WHERE " + x_cond + " ORDER BY PAR_DTSCAD"
	IF !ExecCommand(pSql,"TMP_PART_FOR")
		return(.F.)
	ENDIF
	SELECT TMP_PART_FOR
	GO TOP
	IF !EOF()
		_n_N_PART_FAT = PAR_NPART
		_c_DTSCAD_FAT = PAR_DTSCAD
		
		x_soci = "PAR_CODSOC = '" + PUB_CODSOC + "'"
		x_prog = "PAR_NPROG <> 100"
		x_codi = "PAR_CODCLI = '" + ALLTRIM(_CONTO_VIS_ANT_FORN) + "'"
		x_npar = "PAR_NPART IN (" + _c_N_PARTITE + ")"
		x_cond = x_soci + " and " + x_prog + " and " + x_codi + " and " + x_npar
		pSql=""
		TEXT TO pSql NOSHOW 	&& INIZIO SCRITTURA QUERY
			SELECT * FROM (
				SELECT 
					PART.* ,
					CASE WHEN PAR_NPART IN (SELECT DISTINCT PAR_NPART
												FROM PART_FOR AS PART 
												LEFT OUTER JOIN PARA AS PARTOP
												ON 'TOP'+PART.PAR_TIPFAT = PARTOP.CODICE
												WHERE PAR_CODSOC='<<PUB_CODSOC>>'
													AND PAR_CODCLI='<<ALLTRIM(_CONTO_VIS_ANT_FORN)>>'
													AND PAR_NPROG<>100 
													AND COALESCE(SUBSTRING(PARTOP.LIBERA,2,1),'') IN ('S','F','A') AND COALESCE(SUBSTRING(PARTOP.LIBERA,11,1),'') <> 'S') THEN 'OK'
						
						WHEN PAR_NPART IN (SELECT DISTINCT PAR_NPART FROM
											(SELECT PAR_NPART, COUNT(*) AS CONTA_RIGHE_PARTITA FROM PART_FOR AS PART 
												WHERE PAR_CODSOC='<<PUB_CODSOC>>' AND PAR_CODCLI='<<ALLTRIM(_CONTO_VIS_ANT_FORN)>>'
													AND PAR_NPROG<>100 GROUP BY PAR_NPART) AS TMP_PART WHERE CONTA_RIGHE_PARTITA >= 2) THEN 'OK'
													
						ELSE 'KO'
					END AS LEGATA
				FROM PART_FOR AS PART
				WHERE <<x_cond>>
			) AS MAIN
			WHERE MAIN.LEGATA = 'KO'
			ORDER BY PAR_DTREG,PAR_NREG
		ENDTEXT					&& FINE SCRITTURA QUERY
		
		IF !ExecPreparedCommand(pSql,"SEL_PART_DA_LEG")
			return(.F.)
		ENDIF
		SELECT SEL_PART_DA_LEG
		GO TOP
		IF !EOF()
			_RISP = MESSAGEBOX("Legare automaticamente le partite slegate dei pagamenti appena inibiti alla prima scadenza della fattura " + ALLTRIM(NDOC) + " ?",4+32,"Attenzione")
			IF _RISP = 6
				SELECT SEL_PART_DA_LEG
				GO TOP
				_RESIDUO_IMPEUR_FAT = _CONTO_VIS_ANT_FORN_IMPEUR
				_CONTA_PARTITE_TOTALI = 0
				_CONTA_PARTITE_LEGATE = 0
				SCAN
					_CONTA_PARTITE_TOTALI = _CONTA_PARTITE_TOTALI + 1
					IF _RESIDUO_IMPEUR_FAT > 0
						_idUniquePartFor = ID_UNIQUE
						_mov_numproPartFor = PAR_NUMPRO
						_mov_npartPartFor = PAR_NPART
						*uSql = "UPDATE PART_FOR SET PAR_NPART = " + ALLTRIM(STR(_c_N_PART_FAT,10,0)) + ", PAR_DTSCAD = '" + _c_DTSCAD_FAT + "' WHERE ID_UNIQUE = '" + _idUniquePartFor +"'"
						cSql = "SELECT * FROM PART_FOR WHERE ID_UNIQUE = '" + _idUniquePartFor +"'"
						IF !ExecRW(cSql,"PART_FOR","R")
							return(.F.)
						ENDIF
						SELECT PART_FOR
						GO TOP
						IF !EOF()
							IF (PAR_FATT * PAR_CAMBIO) <= _RESIDUO_IMPEUR_FAT
								REPLACE PAR_NPART WITH _n_N_PART_FAT
								REPLACE PAR_DTSCAD WITH _c_DTSCAD_FAT
								_RESIDUO_IMPEUR_FAT = _RESIDUO_IMPEUR_FAT - (PAR_FATT * PAR_CAMBIO)
							ELSE
								*** IMPORTO PAGAMENTO MAGGIORE DEL RESIDUO FATTURA: SPLITTO LA PARTITA DI PAGAMENTO IN 2 PARTI
								SCATTER MEMVAR MEMO
								REPLACE PAR_FATT WITH ((PAR_FATT * PAR_CAMBIO) - _RESIDUO_IMPEUR_FAT) / PAR_CAMBIO
								APPEND BLANK
								DO REPLACE_INTO_CURSOR WITH "PART_FOR"
								REPLACE PAR_FATT WITH ((PAR_FATT * PAR_CAMBIO) - ((PAR_FATT * PAR_CAMBIO) - _RESIDUO_IMPEUR_FAT)) / PAR_CAMBIO
								REPLACE PAR_NPART WITH _n_N_PART_FAT
								REPLACE PAR_DTSCAD WITH _c_DTSCAD_FAT
								_RESIDUO_IMPEUR_FAT = _RESIDUO_IMPEUR_FAT - (PAR_FATT * PAR_CAMBIO)
							ENDIF
						ENDIF
						IF !ExecRW(cSql,"PART_FOR","W")
							return(.F.)
						ENDIF						
						_CONTA_PARTITE_LEGATE = _CONTA_PARTITE_LEGATE + 1
						
						uSql = "UPDATE MOV_CONT SET MOV_NPART = " + ALLTRIM(STR(_n_N_PART_FAT,10,0)) + " WHERE MOV_NUMPRO = '" + _mov_numproPartFor + "' AND MOV_NPART = " + ALLTRIM(STR(_mov_npartPartFor,10,0))
						IF !ExecCommand(uSql,"UPD_MOV_CONT")
							return(.F.)
						ENDIF
					ENDIF
				ENDSCAN				
				IF _CONTA_PARTITE_LEGATE > 0
					IF _CONTA_PARTITE_LEGATE = _CONTA_PARTITE_TOTALI
						MESSAGEBOX("Tutte le partite dei pagamenti selezionati legate completamente alla fattura",64,"Informazione")
					ELSE
						MESSAGEBOX("Non tutte le partite dei pagamenti selezionati legate completamente alla fattura" + REPLICATE(CHR(13),2) + ;
							"Verificare il partitario e legare manualmente le partite dei pagamenti",48,"Informazione")
					ENDIF
				ELSE
					MESSAGEBOX("Verificare il partitario per legare correttamente le partite dei pagamenti",48,"Attenzione")
				ENDIF
			ELSE
				MESSAGEBOX("Legare manualmente le partite dei pagamenti dal Partitario",64,"Informazione")
			ENDIF
		ENDIF
		
	ENDIF
ENDIF
