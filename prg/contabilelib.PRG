		  IF !EOF()
			 ____DESCO  = CON_DESCR
		  ENDIF



	      SELECT MOV_CONT

		  REG    	  = RIBALTA2(MOV_DTREG)
		  DOC    	  = RIBALTA2(MOV_DTDOC)
		  NUMREG 	  = MOV_NREGIS
		  PROT   	  = MOV_NPROT
		  TTOP   	  = MOV_TOP
		  CON         = MOV_CONTO
		  WDES_MANU   = MOV_DESMOV
		  WCAMBIO	  = MOV_CAMBIO	
		  WCODVAL     = MOV_VALUTA
		  NUMPRO 	  = MOV_NUMPRO 	
		  NUMDOC 	  = MOV_NDOC 	  		
		  WCPA		  = MOV_MODPAG
		  WCODIVA     = MOV_IVA
		  __MOVIMP	  = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))		&& PRENDO SOLO MOV_IMP
		  __PERCIVA   = PERC_IVA
		  __TIPOTOP   = TIPO
		  __RIBASN    = RIBA
		  __NPROT	  = MOV_NPROT
		  __DTDOC     = MOV_DTDOC
		  *__SOLOCLI   = ALLTRIM(SUBSTR(MOV_CONTO,PUB_SOTTOG,PUB_CONTO))
	 	  * 18/12/2021 SERGIO INIZIO
	 	  IF PUB_CONTOSIMILCEE
			   __SOLOCLI   = SCORPRA_CODICE_CLIENTE_FORNITORE_SE_SIMILCEE(MOV_CONTO)
		  ELSE
			   __SOLOCLI   = ALLTRIM(SUBSTR(MOV_CONTO,PUB_SOTTOG,PUB_CONTO))
		  ENDIF
	 	  * 18/12/2021 SERGIO FINE

		  __TMOVORIG  = MOV_TMOV

		
		
		  ** VERIFICA SE NOTA CREDITO
	      v_seek   = 'TOP'+ALLTRIM(TTOP)
	      v_chiave = "codice"
	      IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
	         SELECT CUR_PARA
		     NOTAC	   = SUBSTR(LIBERA,11,1)
		     FATTURA   = SUBSTR(LIBERA,2,1)
		     SITCPA    = SUBSTR(LIBERA,53,1)
		     DESCRTOP  = DESCRI
		  ELSE
		     NOTAC	   = " "
		     FATTURA   = " "
		     SITCPA    = " "
		     DESCRTOP  = "??????????"
		  ENDIF
	
	

		  IF ____TIPOCO = "F" AND FATTURA = "S"		&& ENTRO SOLO SE "CONTO FORNITORE" E TIPO DOCUMENTO = "FATTURA O NOTA CREDITO"
		
		  	*** FACCIO SOMMATORIA DEGLI AVERE(PER LE FATTURE FORNITORE)
		  	*** QUESTA MODIFICA E' FATTA PER GESTIRE PER ESEMPIO
		  	***
		  	*** 1)LE RITENUTE DI ACCONTO FORNITORE
		  	***   NON UTILIZZANDO LA PROCEDURA DI AQUARIUS, VENGONO FARRE REGISTRAZIONI CON DUE IMPORTI IN AVERE
		  	***   I DUE IMPORTI IN AVERE SONO :
		  	*** 	- L'IMPORTO DA PAGARE AL FORNITORE
		  	*** 	- L'IMPORTO EQUIVALENTE ALLA RITENUTA DI ACCONTO
		  	***
		  	*** 2)GLI ARROTONDAMENTI DI DECIMALI DI EURO FATTI SULLE FATTURE TELECOM
		  	***
		  	*** N.B. (E' COSTATO UN BAGNO DI SANGUE)
		  	
			  x_npro = "mov_numpro = '" + ALLTRIM(NUMPRO) + "'"
			
			  IF NOTAC = 'S'
	  			  x_tmov = "mov_tmov = 'D'"
			  ELSE
	  			  x_tmov = "mov_tmov = 'A'"			
			  ENDIF
  			  x_cond = x_npro + " and " + x_tmov 	  			
			  Csql   = "select MOV_IMP,MOV_CONTO,MOV_TMOV from MOV_CONT where " + x_cond	  			
			
			  IF !ExecCommand(cSql,"CU_SUM")
			     return(.f.)
			  ENDIF
			  SELECT CU_SUM
			  GO TOP

			  __TROVATA_FATTURA_CON_IMPORTO_A_ZERO = .F.
			  __MOVIMP_RICALC  = 0

			  DO WHILE !EOF()
			
			  		IF (ALLTRIM(MOV_CONTO) = ALLTRIM(CON)) AND ;
			  		   (MOV_TMOV <> __TMOVORIG) AND ;
			  		   (MOV_IMP = __MOVIMP)
							__TROVATA_FATTURA_CON_IMPORTO_A_ZERO = .T.						
			  		ENDIF
			
			  		__MOVIMP_RICALC  = __MOVIMP_RICALC + MOV_IMP
			
			  		SELECT CU_SUM
			  		SKIP + 1
			  ENDDO

			  IF __TROVATA_FATTURA_CON_IMPORTO_A_ZERO
				  __MOVIMP = 0
			  ELSE
			   	  __MOVIMP = __MOVIMP_RICALC
			  ENDIF

		  ENDIF
	
	
	
	
	
		  ** SALVA NEL CURSORE APPOSITO IL TOP+DESCRIZIONE
		  SELECT PARA_TOP
		  SET ORDER TO PARA_TOP_I
		  GO TOP
		
		  _TTOP = ALLTRIM(TTOP)
		  SEEK _TTOP
		  IF !FOUND()
			 APPEND  BLANK
	  	     REPLACE   TOP_CODICE  WITH _TTOP
	  	     REPLACE   TOP_DESCRI  WITH DESCRTOP
		  ENDIF	  	  	  	




	      SELECT MOV_CONT
	
	 	  IMPD = 0
	 	  IMPA = 0
	 	
	
		  IF SUBSTR(MOV_TMOV,1,1)='A'      && AVERE
	         IF F_VALUTA = 1
	            IMPA = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
	         ELSE
	            IMPA = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
			 ENDIF
		     IMPD=0
		  ENDIF
			
		  IF SUBSTR(MOV_TMOV,1,1)='D'      && DARE
	         IF F_VALUTA = 1
	            IMPD = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
	         ELSE
	            IMPD = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
			 ENDIF
		     IMPA=0
		  ENDIF
	
	      IF NOTAC = "S" .AND. FATTURA = "S"										&& E' UNA NOTA DI CREDITO , VERIFICO SE SUL CLIENTE O SUL FORNITORE		
			  IF ____TIPOCO ='C' 									
		         IF F_VALUTA = 1
	    	        IMPD = (TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO CLIENTI
	        	 ELSE
	            	IMPD = (TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO CLIENTI
				 ENDIF
			     IMPA	= 0
			  ELSE
		         IF F_VALUTA = 1
	    	        IMPA = (TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO FORNITORI
	        	 ELSE
	            	IMPA = (TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO FORNITORI
				 ENDIF
			     IMPD=0
			  ENDIF	
		  ENDIF
	
		  *WSALDO        = IMPD - IMPA                     && SALDO
		  WSALDO = 0
		  IF ABS(IMPD) > 0
		  	WSALDO = ABS(IMPD)
		  ELSE
		  	WSALDO = ABS(IMPA)		
		  ENDIF
		
		  __IMPOST 		= MOV_IMPOST
		
		  TOT_DARE  	= TOT_DARE  + IMPD
		  TOT_AVERE  	= TOT_AVERE + IMPA

		  IF ____TIPOCO ='C'
		     _DARE      = "CON_DAC"
		     _AVERE     = "CON_AVC"
		  ELSE	
		     _DARE      = "CON_DAF"
		     _AVERE     = "CON_AVF"
		  ENDIF


		  __MOVIMP = CAMBIO(WCODVAL,__MOVIMP,WCAMBIO)
		
		  SELECT TABLEAU_CGE
		  SET ORDER TO ID_TAB

		
*!*			  _RK = ALLTRIM(CON)+ALLTRIM(RIBALTA2(REG))+ALLTRIM(NUMREG)
*!*			  SEEK _RK

		  _RK = ALLTRIM(CON)+ALLTRIM(RIBALTA2(REG))+ALLTRIM(NUMREG)+ALLTRIM(NUMPRO)
		  SEEK _RK

		
		  IF FOUND()
	  	     REPLACE   &_DARE      WITH &_DARE  + IMPD
	  	     REPLACE   &_AVERE     WITH &_AVERE + IMPA
	  	     IF ABS(IMPD) > 0
	  	     	REPLACE   CON_SALDO   WITH CON_SALDO + ABS(IMPD)
	  	     ENDIF

	  	     IF ABS(IMPA) > 0
	  	     	REPLACE   CON_SALDO   WITH CON_SALDO + ABS(IMPA)
	  	     ENDIF

	  	     REPLACE   MOVIMP	   WITH MOVIMP + __MOVIMP
	  	
	  	     *REPLACE   CON_SALDO   WITH CON_SALDO + WSALDO        	
	  	  ELSE
			 APPEND BLANK
	  	     REPLACE   CLFO        WITH ____TIPOCO	  	
	  	     REPLACE   CODCLFO     WITH ALLTRIM(CON)
	  	     REPLACE   DESCLFO     WITH ____DESCO  	
	  	     REPLACE   SOLOCLI     WITH __SOLOCLI   	 	  	
	  	     REPLACE   NPROT	   WITH __NPROT	  	   	       	
	  	     REPLACE   DTDOC	   WITH __DTDOC     	  	   	       	     	  	     	  	
	  	     REPLACE   TOP         WITH ALLTRIM(_TTOP)	  	
	  	     REPLACE   CPA         WITH ALLTRIM(WCPA)
	   	     REPLACE   PERIODO     WITH SUBSTR(RIBALTA2(REG),1,4)
	  	     REPLACE   &_DARE      WITH IMPD
	  	     REPLACE   &_AVERE     WITH IMPA
	  	     *REPLACE   CON_SALDO   WITH CON_SALDO + WSALDO     	
	  	     *REPLACE   CON_SALDO   WITH WSALDO
	  	       	
	  	     IF ABS(IMPD) > 0
	  	     	REPLACE   CON_SALDO   WITH ABS(IMPD)
	  	     ENDIF

	  	     IF ABS(IMPA) > 0
	  	     	REPLACE   CON_SALDO   WITH ABS(IMPA)
	  	     ENDIF

	  	     REPLACE   MOVIMP	   WITH __MOVIMP
	  	     REPLACE   MOVNUMPRO   WITH NUMPRO 	  	
	  	     REPLACE   CAMBIO      WITH WCAMBIO
	  	     REPLACE   VALUTA      WITH WCODVAL
	  	     REPLACE   NUMERODOC   WITH NUMDOC
	  	      	       	
	  	     REPLACE   CODIVA      WITH WCODIVA
	   	     REPLACE   DATREG 	   WITH ribalta2(REG)
	  	     REPLACE   NUMREGIS	   WITH NUMREG 	       	
	  	     REPLACE   DB_NOTAC	   WITH NOTAC
	  	     REPLACE   DB_FATTURA  WITH FATTURA
	  	     REPLACE   PERCIVA     WITH __PERCIVA   	  	
	  	     REPLACE   DB_CLFO     WITH __TIPOTOP
	  	     REPLACE   DB_RIBA     WITH __RIBASN    	  	
		  ENDIF

		  SELECT MOV_CONT
		  SKIP +1

	   ENDDO


	
	SELECT TABLEAU_CGE
