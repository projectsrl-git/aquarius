*****************************************************************************
PROCEDURE STAVERS
*****************************************************************************

* CREA CURSORE CON I DETTAGLI DELL'INCASSO

CREATE CURSOR TES_DET;
(DAGGANCIO C(10),RIC_PROGR C(6), RIC_DTFATT C(10), RIC_TOP C(10), RIC_CONTO C(10), RIC_DESCON C(40), RIC_NUMFAT C(6), RIC_DATFAT C(10), RIC_DATSCA C(10), RIC_TOTALE N(17,3), RIC_VALUTA C(3), RIC_CAMBIO N(17,10), RIC_DA C(1), RIC_ABBUON N(17,3), TOTALED N(17,3), TOTALEA N(17,3))

SELECT WINQUERY
GO TOP

DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   SCATTER MEMVAR MEMO
   M.TOTALED = 0
   M.TOTALEA = 0
   IF !ExecCommand("select * from U_VER_DD where daggancio = ?M.TAGGANCIO","U_VER_DD")
      return(.f.)
   ENDIF
   SELECT U_VER_DD
   GO TOP
   IF EOF()
      WAIT WINDOWS "Mancano i dettagli del progressivo :"+M.TAGGANCIO+"<<<<"
   ELSE
  	  DO WHILE .T.
  	     IF EOF()
  	        EXIT
  	     ENDIF
   		 SCATTER MEMVAR MEMO
		 IF M.RIC_DA = "D"
		    M.TOTALED = M.TOTALED + CAMBIO(M.RIC_VALUTA,M.RIC_TOTALE,M.RIC_CAMBIO)
		 ELSE
		    M.TOTALEA = M.TOTALEA + CAMBIO(M.RIC_VALUTA,M.RIC_TOTALE,M.RIC_CAMBIO)
		 ENDIF
         x_soci = "con_soc = '" + PUB_CODSOC + "'"
         x_anno = "con_anno = '" + PUB_ANNO + "'"
         x_cont = "con_conto = '" + ALLTRIM(M.RIC_CONTO) + "'"
         x_cond = x_soci + " and " + x_anno + " and " + x_cont
         Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
         IF !ExecCommand(cSql,"cur_conti")
            return(.f.)
         ENDIF
         SELECT cur_conti
         GO TOP
         IF EOF()
         ELSE
	        M.RIC_DESCON  = CON_DESCR
	     ENDIF
         *** V_SEEK   = PUB_CODSOC+PUB_ANNO+ALLTRIM(M.RIC_CONTO)
         *** V_CHIAVE = 'con_soc+con_anno+con_conto'
         *** IF seek_std('conti',v_seek,v_chiave,'CUR_CONTI')
  	     ***    SELECT CUR_CONTI
	     ***    M.RIC_DESCON  = CON_DESCR
	     *** ENDIF
  		 SELECT TES_DET
   		 APPEND BLANK
   		 GATHER MEMVAR MEMO		
		 SELECT U_VER_DD
		 SKIP +1
 	  ENDDO
   ENDIF
   SELECT WINQUERY
   SKIP +1
ENDDO

RETURN


