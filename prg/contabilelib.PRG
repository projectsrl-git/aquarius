PROCEDURE REG_CESPITI

AX_CESPI    = SELECT()


   x_anno = "leg_anno = '" + ALLTRIM(_XCX_MOV_ANNO) + "'"
   x_nreg = "leg_nregis = '" + ALLTRIM(_XCX_MOV_NREGIS) + "'"
   x_cont = "leg_conto = '" + ALLTRIM(_XCX_MOV_CONTO) + "'"
   x_seqn = "leg_sequen = " + ALLTRIM(STR(_XCX_MOV_SEQUEN))
   x_cond = x_anno + " and " + x_nreg + " and " + x_cont + " and " + x_seqn

   IF EMPTY(_XCX_MOV_CODCES)
   ELSE
      cSql   = "select * from u_leg_cm where " + x_cond
      IF !ExecRW(cSql,"U_LEG_CM","R")
        return(.f.)
      ENDIF
      SELECT U_LEG_CM
      APPEND BLANK
      REPLACE LEG_CODCES WITH _XCX_MOV_CODCES
