      REPLACE LEG_CONTO  WITH _XCX_MOV_CONTO
      REPLACE LEG_SEQUEN WITH _XCX_MOV_SEQUEN
      IF !ExecRW(cSql,"U_LEG_CM","W")
        return(.f.)
      ENDIF
   ENDIF



SELECT(AX_CESPI)
RETURN


*************************************************************************
*  			 CONTROAGGIORNA LE PROCEDURE EXTRA CONTABILI                *
*************************************************************************

PROCEDURE REG_EXTRAAGG
PARAMETERS __TPROC__


AXABBSZ    = SELECT()


DO CASE

	CASE  __TPROC__  = "CON"

        SELECT EXTRAWORK
        GO TOP
        IF EOF()
	      	PUB_ERRORE=MESSAGEBOX('HAI MODIFICATO UNA REGISTRAZIONE LEGATA ALLE PROCEDURE'+CHR(13)+"EXTRACONTABILI SENZA RICONTROLLARE GLI IMPORTI :"+CHR(13)+"ORA LA REGISTRAZIONE NON E' PIU' LEGATA AL DOCUMENTO EXTRACONTABILE",64,'*** ATTENZIONE ***')
        ENDIF

        DO WHILE !EOF()

            SCATTER MEMVAR MEMO



		    ** ACCESSO ALLA RIGA DEL CONTRATTO PER CODICE SYSDOC PER RIPORTARE IL NUOVO AGGANCIO NUMPRO
				x_codi = "con_sysdoc = '" + M.EXTRA_SYSDOC + "'"
				cSql="SELECT * FROM U_CON_DD WHERE "+ x_codi + " order by con_sysdoc"
			    IF !ExecRW(cSql,"u_con_dd","R")
			 	   return(.f.)
			    ENDIF

				SELECT u_con_dd
				REPLACE CON_NUMPRO WITH ALLTRIM(PN_C)
				REPLACE CON_STATUS WITH "Contabilizzato"

			    IF !ExecRW("","u_con_dd","W")
				   return(.f.)
			    ENDIF

		
		    ** ACCESSO ALLA RIGA DEL CONTRATTO PER CODICE NUMPROOLD PER TOGLIERE IL VECCHIO AGGANCIO NUMPRO
				__FILE__ 		= "U_CON_DD"
				__NUMPRO__ 		= M.EXTRA_NUMPROOLD
				__CODI__ 		= "con_numpro = '" + __NUMPRO__ + "'"
				__CAMPO__ 		= "CON_NUMPRO"
				__VALOREDAAGG__	= "SPACE(10)"
				__CAMPO2__ 		= "CON_STATUS"
				__VALORE2DAAGG__= ""
				
				=REG_EXTRAREP(__FILE__,__NUMPRO__,__CODI__,__CAMPO__,__VALOREDAAGG__,__CAMPO2__,__VALORE2DAAGG__)

	
		
            SELECT EXTRAWORK		
		    SKIP + 1
		
        ENDDO


	CASE  __TPROC__  = "ASS"

        SELECT EXTRAWORK
        GO TOP

        DO WHILE !EOF()

            SCATTER MEMVAR MEMO



		    ** ACCESSO ALLA RIGA DELL'ASSEGNO PER CODICE SYSDOC PER RIPORTARE IL NUOVO AGGANCIO NUMPRO
				x_codi = "ass_sysdoc = '" + M.EXTRA_SYSDOC + "'"
				cSql="SELECT * FROM U_ASS_DD WHERE "+ x_codi + " order by ass_sysdoc"
			    IF !ExecRW(cSql,"u_ass_dd","R")
			 	   return(.f.)
			    ENDIF

				SELECT u_ass_dd
				REPLACE ASS_NUMPRO WITH ALLTRIM(PN_C)
				REPLACE ASS_STATUS WITH "Contabilizzato"
				

			    IF !ExecRW("","u_ass_dd","W")
				   return(.f.)
			    ENDIF

		
		    ** ACCESSO ALLA RIGA  DELL'ASSEGNO PER CODICE NUMPROOLD PER TOGLIERE IL VECCHIO AGGANCIO NUMPRO
				__FILE__ 		= "U_ASS_DD"
				__NUMPRO__ 		= M.EXTRA_NUMPROOLD
				__CODI__ 		= "ASS_NUMPRO = '" + __NUMPRO__ + "'"
				__CAMPO__ 		= "ASS_NUMPRO"
				__VALOREDAAGG__	= "SPACE(10)"
				__CAMPO2__ 		= "ASS_STATUS"
				__VALORE2DAAGG__= "Emesso"
				
				=REG_EXTRAREP(__FILE__,__NUMPRO__,__CODI__,__CAMPO__,__VALOREDAAGG__,__CAMPO2__,__VALORE2DAAGG__)

		
		
		
            SELECT EXTRAWORK		
		    SKIP + 1
		
        ENDDO


	CASE  __TPROC__  = "ASC"

        SELECT EXTRAWORK
        GO TOP

        DO WHILE !EOF()

            SCATTER MEMVAR MEMO



		    ** ACCESSO ALLA RIGA DELL'ASSEGNO PER CODICE SYSDOC PER RIPORTARE IL NUOVO AGGANCIO NUMPRO
				x_codi = "ass_sysdoc = '" + M.EXTRA_SYSDOC + "'"
				cSql="SELECT * FROM U_ASC_DD WHERE "+ x_codi + " order by ass_sysdoc"
			    IF !ExecRW(cSql,"U_ASC_DD","R")
			 	   return(.f.)
			    ENDIF

				SELECT U_ASC_DD
				REPLACE ASS_NUMPRO WITH ALLTRIM(PN_C)
				REPLACE ASS_STATUS WITH "Contabilizzato"
				

			    IF !ExecRW("","U_ASC_DD","W")
				   return(.f.)
			    ENDIF

		
		    ** ACCESSO ALLA RIGA  DELL'ASSEGNO PER CODICE NUMPROOLD PER TOGLIERE IL VECCHIO AGGANCIO NUMPRO
				__FILE__ 		= "U_ASC_DD"
