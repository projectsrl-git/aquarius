**=> ERASMO - INIZIO 19/05/2022
*** SE PREVISTO, PROPONGO DI VALORIZZARE IL CAMPO M.NUCOM (INDICE.MOV_NUCOM) CON IL mov_sysdoc DEL DOCUMENTO EFFETTIVO PER IL QUALE SI STA REGISTRANDO L'AUTOFATTURA DI INTEGRAZIONE IVA
IF !EMPTY(_SYSDOC_SET_AUTOFATTURA_FORN) AND EMPTY(_NUCOM_FORN)
	_RISP = MESSAGEBOX("Selezionare la fattura del fornitore effettivo al quale legare questa autofattura?",4+32,"Attenzione")
	IF _RISP = 6
		_ok_SYSDOC_IMPOSTATO = .F.
		_C_FORNITORE = PJ_INPUTBOX("Selezione fornitore effettivo autofattura","Digitare il fornitore","",.F.,"")
		IF !EMPTY(_C_FORNITORE)
			v_SEEK = PUB_CODSOC+PUB_ANNO+ALLTRIM(_C_FORNITORE)
			_C_FORNITORE = seek_conti('',v_seek,'con_conto','con_descr','','TMP_FORNITORI',.T.)			
			IF !EMPTY(ALLTRIM(_C_FORNITORE))
				_CLI_FOR = UPPER(SUBSTR(TMP_FORNITORI.CON_TIPOCO,1,1))
				_C_DESFOR = ALLTRIM(TMP_FORNITORI.CON_DESCR)
				IF _CLI_FOR == "F"
				
					x_soci = "MOV.MOV_SOC = '" + PUB_CODSOC + "'"
					x_anno = "MOV.MOV_ANNO = MOV.MOV_ANNO"
					x_cont = "MOV.MOV_CONTO = '" + ALLTRIM(_C_FORNITORE) + "'"
					x_fatf = "IND.MOV_TOP IN (SELECT SUBSTRING(CODICE,4,10) FROM PARA WHERE SUBSTRING(LIBERA,2,1) = 'S' AND SUBSTRING(LIBERA,12,1) = 'F')"
					*x_cond = x_soci + " and " + x_anno + " and " + x_cont + " and " + x_fatf
					**=> ERASMO - INIZIO 29/07/2022
					x_dtrg = "IND.MOV_DTREG >= '2022/06/01'"  && SOLO LE FATTURE REGISTRATE DOPO IL 01/06/2022, COME DA SPECIFICHE CLIENTE ([Ticket #10948] Collegamento Autofattura - Fattura Fornitore)
					x_escl = "IND.MOV_SYSDOC NOT IN (SELECT MOV_NUCOM FROM MOV_CONT WHERE MOV_TOP IN (SELECT SUBSTRING(CODICE,4,10) FROM PARA WHERE CODICE LIKE 'TOP%' AND SUBSTRING(LIBERA,2,1) = 'S' AND SUBSTRING(LIBERA,1,1) = 'A'))"  && ESCLUDE FATTURE GIA' LEGATE
					x_cond = x_soci + " and " + x_anno + " and " + x_cont + " and " + x_fatf + " and " + x_dtrg + " and " + x_escl
					**=> ERASMO - FINE 29/07/2022
					cSql   = "SELECT SPACE(10) AS SELEZIONE, IND.MOV_NDOC, IND.MOV_DTDOC, IND.MOV_NREGIS, IND.MOV_DTREG, IND.MOV_VALUTA, IND.MOV_IMP, IND.MOV_SYSDOC FROM MOV_CONT AS MOV " + ;
							 "RIGHT OUTER JOIN INDICE AS IND ON IND.MOV_NUMPRO = MOV.MOV_NUMPRO WHERE " + x_cond + " ORDER BY IND.MOV_DTREG DESC,CAST(IND.MOV_NREGIS AS NUMERIC(10,0)) DESC"
					IF !ExecCommand(cSql,"SEL_MOV_CONT")
					   return(.f.)
					ENDIF
					SELECT SEL_MOV_CONT
					GO TOP
					IF !EOF()
						DO prg\browseview WITH "SEL_MOV_CONT","Selezione fattura fornitore " + _C_DESFOR,"MOV_NDOC:Nr. doc.,W:20;MOV_DTDOC:Data doc.,W:10;MOV_NREGIS:Nr. reg.,W:10;MOV_DTREG:Data reg.,W:10;" + ;
							"MOV_VALUTA:Valuta,W:10;MOV_IMP:Importo,W:10;",500,600,.F.,.T.
						IF NumeroRecordLetti = 0
						ELSE
						
							SELECT SEL_MOV_CONT
							GO TOP
							SCAN
								IF !EMPTY(ALLTRIM(SELEZIONE))
									_C_SYSDOC = ALLTRIM(MOV_SYSDOC)
									IF !EMPTY(_C_SYSDOC)
										SELECT CORPO_MOV
										GO TOP
										SCAN
											IF ALLTRIM(CONTO) = _SYSDOC_SET_AUTOFATTURA_FORN
												REPLACE __NUCOM WITH _C_SYSDOC
												_ok_SYSDOC_IMPOSTATO = .T.
											ENDIF
										ENDSCAN
									ENDIF
								ENDIF
							ENDSCAN
						ENDIF
					ELSE
						MESSAGEBOX("Nessuna fattura trovata per il Fornitore selezionato",48,"Informazione")
					ENDIF
				ELSE
					MESSAGEBOX("Il conto selezionato non č un conto di tipo Fornitore",48,"Informazione")
				ENDIF
			ENDIF
		ENDIF
		
		IF _ok_SYSDOC_IMPOSTATO
			MESSAGEBOX("Fattura Fornitore legata",64,"Informazione")
		ELSE
			MESSAGEBOX("Fattura Fornitore non legata",48,"Informazione")
		ENDIF
	ENDIF
ENDIF
**=> ERASMO - FINE 19/05/2022

