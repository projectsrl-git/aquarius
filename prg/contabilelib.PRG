******************************
PROCEDURE PCLILEGA
******************************

VCODICE=PREFIX+M.CODICE4

IF !ExecCommand("select *, PAR_NPART AS OLD_NPART, PAR_CODPAG AS OLD_CODPAG, PAR_NUMFAT AS OLD_NUMFAT ,PAR_DTSCAD AS OLD_DTSCAD from part_cli where 0=1","part_cli")  && ERASMO - 05/03/2012
   return(.f.)
ENDIF
SELECT PART_CLI

HH=AFIELDS(TRAN_PAR)
CREATE CURSOR CPART_CL FROM ARRAY TRAN_PAR
*!*	INDEX ON PAR_CODSOC+PAR_ANNO+STR(PAR_NPART,10,0)+STR(PAR_NPROG,5,0) TAG PARTITA ADDITIVE

SELECT  CPART_CL
=_ELAPART("CLI",VCODICE)

SELECT CPART_CL
GO TOP

TITOLO="ELENCO PARTITE DEL CLIENTE "+M.NOMECLI


**=> ERASMO - INIZIO 10/02/2012
DO FORM FORM\LEGA_PART WITH "CPART_CL",TITOLO
IF !_lCONFERMA
	MESSAGEBOX('Nessun aggiornamento eseguito',64,'Informazione')
	RETURN .F.
ENDIF
**=> ERASMO - FINE 10/02/2012

SET DELETED OFF
SELECT CPART_CL
_SONO_QUI__ = RECNO()

INDEX ON PAR_CODSOC+PAR_ANNO+PAR_DTREG+STR(PAR_NPROG,5,0) 	TAG PARTITA ADDITIVE
INDEX ON PAR_ANNO+STR(PAR_NPART,10,0)+PAR_DTSCAD 			TAG DTSCAD_ ADDITIVE
SET ORDER TO DTSCAD_
GO top


DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   **=> ERASMO - INIZIO 05/03/2012
   _X_ANNO = M.PAR_ANNO
   _NPART_ORIGINALE = OLD_NPART
   _NPART_MODIFICATO = _NPART_ORIGINALE
   **=> ERASMO - FINE 05/03/2012

   IF DELETED()
      _DELETE = M.PAR_SYS
      CSQL="DELETE FROM PART_CLI WHERE PAR_SYS = ?_DELETE"
      IF !ExecCommand(CSQL,"PART_CLI")
		 PUB_ERRORE=MESSAGEBOX('1 - Movimento su partitario non trovato',62,'*** ATTENZIONE ***')
         RETURN (.f.)
      ENDIF
      SELECT CPART_CL
      SKIP +1
      LOOP
   ENDIF

*!*	IF PAR_NPART = 9121744
*!*	SET STEP ON
*!*	ENDIF

   v_seek	 = M.PAR_SYS
   v_chiave  = "par_sys"
   cSql      = "select * from part_cli where " + v_chiave + " = '" + v_seek + "'"
   IF !ExecRW(cSql,"PART_CLI","R")
      return(.f.)
   ENDIF
   SELECT PART_CLI
   IF RECCOUNT() = 0
      PUB_ERRORE=MESSAGEBOX('2 - Movimento su partitario non trovato',62,'*** ATTENZIONE ***')
   ELSE
      IF ALLTRIM(M.PAR_NUMFAT) <> ALLTRIM(PAR_NUMFAT)
         REPLACE PAR_NUMFAT   WITH ALLTRIM(M.PAR_NUMFAT)
      ENDIF
      IF M.PAR_NPART <> PAR_NPART
         REPLACE PAR_NPART   WITH M.PAR_NPART
         _NPART_MODIFICATO = M.PAR_NPART  && ERASMO - 05/03/2012
      ENDIF
      IF M.PAR_CODPAG <> PAR_CODPAG
         REPLACE PAR_CODPAG   WITH M.PAR_CODPAG
      ENDIF
	  *** FABIANO - MODIFICA DATA SCADENZA - 30/03/2012
      IF M.PAR_DTSCAD <> PAR_DTSCAD
         REPLACE PAR_DTSCAD WITH M.PAR_DTSCAD
      ENDIF
	  *** FABIANO - MODIFICA DATA SCADENZA - 30/03/2012

   ENDIF
   IF !ExecRW(cSql,"PART_CLI","W")
      return(.f.)
   ENDIF

   **=> ERASMO - INIZIO 05/03/2012
   *** SE NR.PARTITA MODIFICATO, AGGIORNO RECORD 100 SULLA PARTITA ORIGINALE RIPORTANDO IL NUMERO DI PARTITA/ULTIMA DATA SCADENZA ANCHE SUL RECORD 100
   IF _NPART_MODIFICATO <> _NPART_ORIGINALE

         *** RICERCA LA DATA DI SCADENZA PIU' VECCHIA
         _ULTIMA_DATA_SCADENZA  = ''
         VTIPODO= 'FAT'
         x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
         x_clie = "par_codcli = '" + ALLTRIM(VCODICE) + "'"
         x_npar = "par_npart = " + ALLTRIM(STR(_NPART_ORIGINALE,10,0))
         x_anno = "par_anno = '" + ALLTRIM(_X_ANNO) + "'"
         x_prog = "par_nprog <> 100"
         x_tido = "par_tipodo = '" + ALLTRIM(VTIPODO) + "'"
         x_cond = x_soci + " and " + x_clie + " and " + x_npar + " and " + x_anno + " and " + x_prog + " and " + x_tido
         cSql   = "SELECT * FROM PART_CLI WHERE " + x_cond + " order by PAR_DTSCAD"
         IF !ExecCommand(CSQL,"PART_CLI_DTSCAD")
            return
         ENDIF
         SELECT PART_CLI_DTSCAD
         GO TOP
         IF !EOF()
         	GO BOTT
         	_ULTIMA_DATA_SCADENZA = PAR_DTSCAD
         ENDIF

         *** AGGIORNO RECORD 100 SULLA PARTITA ORIGINALE
         x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
         x_clie = "par_codcli = '" + ALLTRIM(VCODICE) + "'"
         x_npar = "par_npart = " + ALLTRIM(STR(_NPART_ORIGINALE,10,0))
         x_anno = "par_anno = '" + ALLTRIM(_X_ANNO) + "'"
         x_prog = "par_nprog = 100"
         x_cond = x_soci + " and " + x_clie + " and " + x_npar + " and " + x_anno + " and " + x_prog
         cSql   = "SELECT * FROM PART_CLI WHERE " + x_cond + " order by par_codsoc,PAR_ANNO,PAR_DTREG,PAR_NPROG"
         IF !ExecRW(cSql,"PART_CLI","R")
            return
         ENDIF
         SELECT PART_CLI
         GO TOP
         IF !EOF()

            REPLACE PAR_NPART WITH M.PAR_NPART

			IF !EMPTY(_ULTIMA_DATA_SCADENZA)
				REPLACE PAR_dtscad WITH _ULTIMA_DATA_SCADENZA
			ENDIF

         ENDIF
         IF !ExecRW(cSql,"PART_CLI","W")
            return(.f.)
         ENDIF
   ENDIF
   **=> ERASMO - FINE 05/03/2012


   SELECT CPART_CL
   SKIP +1

ENDDO

SELECT CPART_CL
SET ORDER TO PARTITA
GO TOP
IF !EOF()
	GO _SONO_QUI__
ENDIF

PUB_ERRORE=MESSAGEBOX('Operazione eseguita correttamente',62,'*** ATTENZIONE ***')

RETURN


