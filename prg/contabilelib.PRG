   D_TOTALE = DA_TOTALE
   Z_SALDOI = ZA_SALDOI

   SELECT WOPE_SBC
   SET ORDER TO WOPE_SBC
   _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
   SEEK _SKK
   IF FOUND()
      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
   ELSE
      ** CASO ANOMALO DEVO COMUNQUE RICREARE IL GRUPPO TOTALE DI TESTATA CHE TOTALE TOTALE
      APPEND BLANK
      REPLACE DA_TIPO   WITH TT_TIPO
      REPLACE DA_CODCON WITH V_CONTO
      REPLACE DA_DESCR  WITH "__TOTALE : " + ALLTRIM(GETDCON(V_CONTO))


      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
      _SKK =  ALLTRIM(V_CONTO)+ "  "
      SEEK _SKK
      IF !FOUND()
         APPEND BLANK
         REPLACE DA_TIPO   WITH "  "
         REPLACE DA_CODCON WITH V_CONTO
         REPLACE DA_DESCR  WITH GETDCON(V_CONTO)
      ENDIF
   ENDIF
   SELECT WOPE_SB3
   SKIP +1
ENDDO

** SALVA I RECORD DI TOTALE GENERALI SU TOTALI ZD_ / ZA_   (TOTALI INTERMEDI DI GRUPPO)

SELECT WOPE_SBC
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DA_TIPO <> "ZZ"
      SELECT WOPE_SBC
      SKIP +1
      LOOP
   ENDIF

   SELECT WOPE_TOT
   SET ORDER TO WOPE_TOT
   APPEND BLANK

   REPLACE DA_TIPO   WITH WOPE_SBC.DA_TIPO
   REPLACE DA_CODCON WITH WOPE_SBC.DA_CODCON
   REPLACE DA_DESCR  WITH WOPE_SBC.DA_DESCR
   REPLACE ZD_TOTALE WITH WOPE_SBC.ZD_TOTALE
   REPLACE ZA_TOTALE WITH WOPE_SBC.ZA_TOTALE
   REPLACE ZA_SALDOI WITH WOPE_SBC.ZA_SALDOI

   SELECT WOPE_SBC
   SKIP +1

ENDDO


** CALCOLA LA PERCENTUALE DEI SINGOLO SOTTOGRUPPO RISPETTO AL TOTALE SOPRA SALVATO SU TOTALI ZD_ / ZA_   (TOTALI INTERMEDI DI GRUPPO)

SELECT WOPE_SBC
GO TOP


DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DA_TIPO = "ZZ"
      SELECT WOPE_SBC
      SKIP +1
      LOOP
   ENDIF

   TT_TIPO  = "ZZ"
 
   
	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
	   V_CONTO  = SUBSTR(DA_CODCON,1,PUB_GRUPPOCF)
	ELSE
	   V_CONTO  = SUBSTR(DA_CODCON,1,PUB_SOTTOG-1)
	ENDIF
	** SERGIO 18/12/2021 FINE     
	   
   SELECT WOPE_TOT
   SET ORDER TO WOPE_TOT
   _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
   SEEK _SKK
   IF FOUND()
      _D_TOTALE = ZD_TOTALE
      _A_TOTALE = ZA_TOTALE
      *!*	      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
   ELSE
      _D_TOTALE = 0
      _A_TOTALE = 0
   ENDIF

   SELECT WOPE_SBC

*!*	   IF DA_TOTALE <> 0
   IF _D_TOTALE <> 0
   	  REPLACE ZD_PERC WITH  ROUND((DA_TOTALE / _D_TOTALE ) * 100,2)
   ELSE
   	  REPLACE ZD_PERC WITH  0
   ENDIF

*!*	   IF AV_TOTALE <> 0
   IF _A_TOTALE <> 0
   	  REPLACE ZA_PERC WITH  ROUND((AV_TOTALE / _A_TOTALE ) * 100,2)
   ELSE
   	  REPLACE ZA_PERC WITH  0
   ENDIF


   SKIP +1

ENDDO


IF __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI
	
	SELECT WOPE_SBC
	GO TOP

	DO WHILE .T.
	
	   IF EOF()
	      EXIT
	   ENDIF
	
	   IF ALLTRIM(DA_TIPO) <> "ZZ"

        DELETE

	   ENDIF
	

		
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
        IF !EMPTY(___ANNOP)
			x_anno = "con_anno = '" + ___ANNOP + "'"
		ELSE
			x_anno = "con_anno = '" + PUB_ANNO + "'"
		ENDIF
		x_cont = "con_conto = '" + ALLTRIM(WOPE_SBC.DA_CODCON) + "'"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont
		Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
		IF !ExecCommand(cSql,"xcontix")
		   return(.f.)
		ENDIF
		SELECT xcontix
		GO TOP
		IF EOF()
			_DA_DESCR  = "*** CONTO INESISTENTE SUL PIANO DEI CONTI ***"
		ELSE
			_DA_DESCR  = ALLTRIM(CON_DESCR)
		ENDIF
	
	
	   SELECT WOPE_SBC	
       REPLACE DA_DESCR  WITH _DA_DESCR
       REPLACE AV_DESCR  WITH _DA_DESCR
*!*	       REPLACE DA_TIPO   WITH SPACE(13)

	   SKIP +1	
	
	ENDDO WHILE .T.
	
	
ENDIF

*!*	INIZIO SBC400
IF OK_SALDI				&& non tratta i movimenti di dettaglio con saldo a 0

	SELECT WOPE_SBC
	GO TOP

	
	DO WHILE .NOT.EOF()

	   IF DA_TIPO = "DD"
		   	

			__SALDO_NEW = ZA_SALDOI + (DA_TOTALE - AV_TOTALE)
		   	IF __SALDO_NEW  = 0
		   		
	        	DELETE

		   	ENDIF


	   ENDIF DA_TIPO = "DD"

	   SELECT WOPE_SBC
	   SKIP +1


	ENDDO WHILE .NOT.EOF()

ENDIF




IF __NON_STAMPA_I_CLIENTI_FORNITORI
	
	SELECT WOPE_SBC
	GO TOP
	
	DO WHILE .T.
	
	   IF EOF()
	      EXIT
	   ENDIF
	
	   _DA_TIPO = DA_TIPO
		
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
        IF !EMPTY(___ANNOP)
			x_anno = "con_anno = '" + ___ANNOP + "'"
		ELSE
			x_anno = "con_anno = '" + PUB_ANNO + "'"
		ENDIF
		x_cont = "con_conto = '" + ALLTRIM(WOPE_SBC.DA_CODCON) + "'"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont
		Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
		IF !ExecCommand(cSql,"xcontix")
		   return(.f.)
		ENDIF
		SELECT xcontix
		GO TOP
		IF EOF()
			_DA_DESCR  = "*** CONTO INESISTENTE SUL PIANO DEI CONTI ***"
		ELSE

			
			_DA_DESCR  = ALLTRIM(CON_DESCR)

			IF _DA_TIPO = "ZZ"
				_DA_DESCR  = "__TOTALE : " + ALLTRIM(CON_DESCR)
			ENDIF
			

		ENDIF
	

	    IF CON_TIPOCO  =  "C" OR CON_TIPOCO  =  "F"

	      SELECT WOPE_SBC
	
          DELETE
	
	      SKIP +1
	      LOOP
	
	    ENDIF

	
	   SELECT WOPE_SBC	
       REPLACE DA_DESCR  WITH _DA_DESCR
       REPLACE AV_DESCR  WITH _DA_DESCR
*!*	       REPLACE DA_TIPO   WITH SPACE(13)

	   SKIP +1	
	
	ENDDO WHILE .T.

	
ENDIF



** CALCOLA LA PERCENTUALE TOTALE SUI CONTI DI TIPO ZZ RISPETTO AL CONTO RICAVI

*!*	RICERCA IL CODICE DEL CONTO RICAVO IN TABELLA

v_SEEK = "PRI"+pub_codsoc
IF seek_std('PARA',v_seek,'CODICE','CUR_PARA')
   SELECT CUR_PARA
   ___CTOPERC=ALLTRIM(LIBERA)
ELSE
   ___CTOPERC=""
ENDIF


IF !EMPTY(ALLTRIM(___CTOPERC))

	TT_TIPO  = "ZZ"
	

	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
		V_CONTO  = SUBSTR(___CTOPERC,1,PUB_GRUPPOCF)	   
	ELSE
	   	V_CONTO  = SUBSTR(___CTOPERC,1,PUB_SOTTOG-1)
	ENDIF
	** SERGIO 18/12/2021 FINE  
	
	SELECT WOPE_TOT
	SET ORDER TO WOPE_TOT
    _T_TOTALE   = 0
	_SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
	SEEK _SKK
	IF FOUND()
	  IF ZD_TOTALE <> 0
	  		_T_TOTALE = ZD_TOTALE
	  ENDIF
	  IF ZA_TOTALE <> 0
	  		_T_TOTALE = ZA_TOTALE
	  ENDIF
	ELSE
	   _T_TOTALE = 0
	ENDIF


	SELECT WOPE_SBC
	GO TOP


	DO WHILE .T.
	
	   IF EOF()
	      EXIT
	   ENDIF

	   IF DA_TIPO <> "ZZ"
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF

	   IF ALLTRIM(___CTOPERC) = ALLTRIM(DA_CODCON)
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF

	   SELECT WOPE_SBC
	
	   REPLACE ZD_PERC WITH  0
	   REPLACE ZA_PERC WITH  0  	
	   REPLACE ZT_PERC WITH  0  	
	
	   IF ZD_TOTALE <> 0
	      IF _T_TOTALE <> 0
	   	  	REPLACE ZT_PERC WITH  ROUND((ZD_TOTALE / _T_TOTALE ) * 100,2)
	   	  ENDIF
	   ENDIF
	
	   IF ZA_TOTALE <> 0
	      IF _T_TOTALE <> 0
	   	  	REPLACE ZT_PERC WITH  ROUND((ZA_TOTALE / _T_TOTALE ) * 100,2)
	   	  ENDIF
	   ENDIF
	

	   SKIP +1

	ENDDO

ENDIF


SELECT WOPE_SBC
GO TOP



SET NEAR OFF
RETURN

*************************************************************************
FUNCTION CREA_SALDI_PIANO_CONTI
*************************************************************************
PARA V_DBASE

   AXABBS_Z    = SELECT()

   SELECT &V_DBASE

	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
	   IF LEN(ALLTRIM(CON_CONTO))  <  PUB_GRUPPOCF
	      SELECT(AXABBS_Z)
	      RETURN
	   ENDIF	
	ELSE
	   IF LEN(ALLTRIM(CON_CONTO))  <  PUB_SOTTOG
	      SELECT(AXABBS_Z)
	      RETURN
	   ENDIF	
   ENDIF
   ** SERGIO 18/12/2021 FINE  





   WCONTO    = CON_CONTO
   WDESCRI   = CON_DESCR
   WDARE     = CON_IMP_D
   WAVERE    = CON_IMP_A
   WSALDO    = (CON_IMP_D - CON_IMP_A)


   IF WSALDO = 0
      SELECT(AXABBS_Z)
      RETURN
   ENDIF

   SELECT TEMPO_DB

   APPEND BLANK
   REPLACE  CONTO   WITH WCONTO
   REPLACE  DESCRI  WITH WDESCRI
   REPLACE  DARE    WITH WDARE
   REPLACE  AVERE   WITH WAVERE
   REPLACE  SALDO   WITH WSALDO
   *REPLACE  MOVIM   WITH WMOVIM

   SELECT(AXABBS_Z)


RETURN

*************************************************************************
PROCEDURE SBC500  && STAMPA BILANCIO NORMALE
*************************************************************************
PARA V_POSBIL,V_CONINI,V_CONFIN,V_DAL,V_AL,PUB_ANNO,V_DBASE

V_SALDOI = 0

IF PCOUNT() = 6
   V_DBASE = "CONTI"
ENDIF

CREATE CURSOR WOPE_SB1 (DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),DA_SALDOI N(20,8),DA_PERC N(8,4),DA_TIPOCO C(1))
CREATE CURSOR WOPE_SB2 (AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),AV_SALDOI N(20,8),AV_PERC N(8,4),AV_TIPOCO C(1))
CREATE CURSOR WOPE_SB3 (DA_TIPO C(02),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8))
CREATE CURSOR WOPE_SBC (DA_TIPO C(02),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZD_TOTALE N(20,8),ZA_TOTALE N(20,8))
INDEX ON ALLTRIM(DA_CODCON) + DA_TIPO TAG WOPE_SBC ADDITIVE


SET NEAR ON
SELECT &V_DBASE
SEEK PUB_CODSOC+PUB_ANNO

DETTAGLI = .T.
PRIMOD   = .T.
PRIMOA   = .T.
V_GRSG   = ""
V_OLDD   = ""
V_OLDA   = ""

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED() .OR. CON_ANNO != PUB_ANNO
      SKIP +1
      LOOP
   ENDIF




   
   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 

	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,PUB_GRUPPOCF)==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF

	   IF LEN(ALLTRIM(CON_CONTO)) < PUB_GRUPPOCF
	      SKIP +1
	      LOOP
	   ENDIF

   ELSE

	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,(PUB_SOTTOG-1))==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF

	   IF LEN(ALLTRIM(CON_CONTO)) < (PUB_SOTTOG-1)
	      SKIP +1
	      LOOP
	   ENDIF

   ENDIF
   ** SERGIO 18/12/2021 FINE  
   
   



   IF CON_TIPOCO = "O"    && SCARTA CONTI ORDINARI
      SKIP +1
      LOOP
   ENDIF

   IF CON_POSBIL  <> V_POSBIL
      SKIP +1
      LOOP
   ENDIF


   V_CONTO  = CON_CONTO
   V_TIPOCO = CON_TIPOCO
   V_DESCR  = CON_DESCR
   

   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
	   V_GRSG   = SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
   ELSE
	   V_GRSG   = SUBSTR(V_CONTO,1,(PUB_SOTTOG-1))
   ENDIF
   ** SERGIO 18/12/2021 FINE  


   v_seek 	 = "BIL"+V_GRSG
   v_chiave  = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      IF SUBSTR(LIBERA,1,1)=="S"
         DETTAGLI=.T.
      ELSE
         DETTAGLI=.F.
      ENDIF
   ELSE
      DETTAGLI=.F.
   ENDIF

   SELECT &V_DBASE

   V_TOTD = 0
   V_TOTA = 0
   FOR H=V_DAL TO V_AL
       VD="CON_DA"+STRTRAN(STR(H,2)," ","0")
       VA="CON_AV"+STRTRAN(STR(H,2)," ","0")
       V_TOTD=V_TOTD+&VD
       V_TOTA=V_TOTA+&VA
   NEXT

   DO SBCAGWF

   SELECT &V_DBASE
   SKIP +1

ENDDO

SELECT WOPE_SB1
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   V_CONTO  = DA_CODCON
   V_DESCR  = DA_DESCR
   V_TOTALE = DA_TOTALE


   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_GRUPPOCF
	      TT_TIPO = "  "
	   ELSE
	      TT_TIPO = "DD"
	   ENDIF
   ELSE
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_SOTTOG
	      TT_TIPO = "  "
	   ELSE
	      TT_TIPO = "DD"
	   ENDIF
   ENDIF
   ** SERGIO 18/12/2021 FINE  



   SELECT WOPE_SBC
   SET ORDER TO WOPE_SBC
   _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
   SEEK _SKK
   IF !FOUND()
      APPEND BLANK
      REPLACE DA_TIPO   WITH TT_TIPO
      REPLACE DA_CODCON WITH V_CONTO
      REPLACE DA_DESCR  WITH V_DESCR
      REPLACE DA_TOTALE WITH V_TOTALE
   ELSE
      REPLACE DA_TOTALE WITH DA_TOTALE  + V_TOTALE
   ENDIF

   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
  
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_GRUPPOCF && GESTIONE RIGA TOTALE
	      TT_TIPO = "ZZ"
	      SELECT WOPE_SBC
	      SET ORDER TO WOPE_SBC
	      _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
	      SEEK _SKK
	      IF !FOUND()
	         APPEND BLANK
	         REPLACE DA_TIPO   WITH TT_TIPO
	         REPLACE DA_CODCON WITH V_CONTO
	         REPLACE DA_DESCR  WITH SPACE(27) + "TOTALE CONTO"
	      ENDIF
	   ENDIF  
  
   ELSE
   
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_SOTTOG  && GESTIONE RIGA TOTALE
	      TT_TIPO = "ZZ"
	      SELECT WOPE_SBC
	      SET ORDER TO WOPE_SBC
	      _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
	      SEEK _SKK
	      IF !FOUND()
	         APPEND BLANK
	         REPLACE DA_TIPO   WITH TT_TIPO
	         REPLACE DA_CODCON WITH V_CONTO
	         REPLACE DA_DESCR  WITH SPACE(27) + "TOTALE CONTO"
	      ENDIF
	   ENDIF

   ENDIF
   ** SERGIO 18/12/2021 FINE  





   SELECT WOPE_SB1
   SKIP
ENDDO

SELECT WOPE_SB2
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   V_CONTO  = AV_CODCON
   V_DESCR  = AV_DESCR
   V_TOTALE = AV_TOTALE
   

   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
  
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_GRUPPOCF
	      TT_TIPO = "  "
	   ELSE
	      TT_TIPO = "DD"
	   ENDIF

  
   ELSE
   
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_SOTTOG
	      TT_TIPO = "  "
	   ELSE
	      TT_TIPO = "DD"
	   ENDIF

   ENDIF
   ** SERGIO 18/12/2021 FINE  





   SELECT WOPE_SBC
   SET ORDER TO WOPE_SBC
   _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
   SEEK _SKK
   IF !FOUND()
      APPEND BLANK
      REPLACE DA_TIPO   WITH TT_TIPO
      REPLACE DA_CODCON WITH V_CONTO
      REPLACE DA_DESCR  WITH V_DESCR
      REPLACE AV_CODCON WITH V_CONTO
      REPLACE AV_DESCR  WITH V_DESCR
      REPLACE AV_TOTALE WITH V_TOTALE
   ELSE
      REPLACE AV_TOTALE WITH AV_TOTALE  + V_TOTALE
   ENDIF

   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
  
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_GRUPPOCF  && GESTIONE RIGA TOTALE
	      TT_TIPO = "ZZ"
	      SELECT WOPE_SBC
	      SET ORDER TO WOPE_SBC
	      _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
	      SEEK _SKK
	      IF !FOUND()
	         APPEND BLANK
	         REPLACE DA_TIPO   WITH TT_TIPO
	         REPLACE DA_CODCON WITH V_CONTO
	         REPLACE DA_DESCR  WITH SPACE(27) + "TOTALE CONTO"
	      ENDIF
	   ENDIF

  
   ELSE
   
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_SOTTOG  && GESTIONE RIGA TOTALE
	      TT_TIPO = "ZZ"
	      SELECT WOPE_SBC
	      SET ORDER TO WOPE_SBC
	      _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
	      SEEK _SKK
	      IF !FOUND()
	         APPEND BLANK
	         REPLACE DA_TIPO   WITH TT_TIPO
	         REPLACE DA_CODCON WITH V_CONTO
	         REPLACE DA_DESCR  WITH SPACE(27) + "TOTALE CONTO"
	      ENDIF
	   ENDIF

   ENDIF
   ** SERGIO 18/12/2021 FINE  





   SELECT WOPE_SB2
   SKIP +1
ENDDO

** SALVA I DETTAGLI

SELECT WOPE_SBC
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   V_CONTO = DA_CODCON
   TT_TIPO = DA_TIPO


   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
  
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_GRUPPOCF  
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF

  
   ELSE
   
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_SOTTOG
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF

   ENDIF
   ** SERGIO 18/12/2021 FINE


   SCATTER MEMVAR
   SELECT WOPE_SB3
   APPEND BLANK
   GATHER MEMVAR
   SELECT WOPE_SBC
   SKIP +1

ENDDO

** RICALCOLO TOTALI GENERALI SU TOTALI ZD_ / ZA_   (TOTALI INTERMEDI DI GRUPPO)

SELECT WOPE_SB3
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF


   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
   		V_CONTO  = SUBSTR(DA_CODCON,1,PUB_GRUPPOCF)
   ELSE
   		V_CONTO  = SUBSTR(DA_CODCON,1,(PUB_SOTTOG-1))
   ENDIF
   ** SERGIO 18/12/2021 FINE


   TT_TIPO  = "ZZ"
   A_TOTALE = AV_TOTALE
   D_TOTALE = DA_TOTALE
   SELECT WOPE_SBC
   SET ORDER TO WOPE_SBC
   _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
   SEEK _SKK
   IF FOUND()
      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
   ELSE
      ** CASO ANOMALO DEVO COMUNQUE RICREARE IL GRUPPO TOTALE DI TESTATA CHE TOTALE TOTALE
      APPEND BLANK
      REPLACE DA_TIPO   WITH TT_TIPO
      REPLACE DA_CODCON WITH V_CONTO
      REPLACE DA_DESCR  WITH SPACE(27) + "TOTALE CONTO"
      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
      _SKK =  ALLTRIM(V_CONTO)+ "  "
      SEEK _SKK
      IF !FOUND()
         APPEND BLANK
         REPLACE DA_TIPO   WITH "  "
         REPLACE DA_CODCON WITH V_CONTO
         REPLACE DA_DESCR  WITH GETDCON(V_CONTO)
      ENDIF
   ENDIF

   SELECT WOPE_SB3
   SKIP +1

ENDDO

SET NEAR OFF
RETURN


*************************************************************************
PROCEDURE SBC600  && STAMPA BILANCIO NORMALE
*************************************************************************
PARA V_POSBIL,V_CONINI,V_CONFIN,Z_DAL,Z_AL,Z_DAA,Z_AAA,V_DBASE

V_SALDOI = 0

IF PCOUNT() = 7
   V_DBASE = "CONTI"
ENDIF

CREATE CURSOR WOPE_SB3 (DA_TIPO C(02),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),;
                        AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZD_TOTALE N(20,8),ZA_TOTALE N(20,8),ZA_SALDOI N(20,8),DA_TIPOCO C(1))
CREATE CURSOR WOPE_SBC (DA_TIPO C(02),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),;
                        AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZD_TOTALE N(20,8),ZA_TOTALE N(20,8),ZA_SALDOI N(20,8),DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CODCON) + DA_TIPO TAG WOPE_SBC ADDITIVE


SET NEAR ON
SELECT &V_DBASE
SET ORDER TO CONTO
SEEK PUB_CODSOC+Z_DAA

DETTAGLI = .T.
PRIMOD   = .T.
PRIMOA   = .T.
V_GRSG   = ""
V_OLDD   = ""
V_OLDA   = ""

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED() .OR. (VAL(CON_ANNO) < VAL(Z_DAA) .OR. ;
                      VAL(CON_ANNO) > VAL(Z_AAA))
      SKIP +1
      LOOP
   ENDIF

   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,PUB_GRUPPOCF)==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF 
  
	   IF LEN(ALLTRIM(CON_CONTO)) < PUB_GRUPPOCF
	      SKIP +1
	      LOOP
	   ENDIF
  
   ELSE
	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,PUB_SOTTOG-1)==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF 
	   
	   IF LEN(ALLTRIM(CON_CONTO)) < PUB_SOTTOG
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF
   ** SERGIO 18/12/2021 FINE





   IF CON_TIPOCO = "O"    && SCARTA CONTI ORDINARI
      SKIP +1
      LOOP
   ENDIF

   IF CON_POSBIL  <> V_POSBIL
      SKIP +1
      LOOP
   ENDIF

   V_CONTO  = CON_CONTO
   V_TIPOCO = CON_TIPOCO
   V_DESCR  = CON_DESCR


   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
	   V_GRSG   = SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
  
   ELSE
	   V_GRSG   = SUBSTR(V_CONTO,1,PUB_SOTTOG-1)
   ENDIF
   ** SERGIO 18/12/2021 FINE


   V_SALDOI = CON_SALDOI

   v_seek 	 = "BIL"+V_GRSG
   v_chiave  = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      IF SUBSTR(LIBERA,1,1)=="S"
         DETTAGLI=.T.
      ELSE
         DETTAGLI=.F.
      ENDIF
   ELSE
      DETTAGLI=.F.
   ENDIF

   SELECT &V_DBASE

   V_TOTD = 0
   V_TOTA = 0
   IF Z_DAA = Z_AAA
      X_DAL = VAL(Z_DAL)
      X_AL  = VAL(Z_AL)
      FOR H=X_DAL TO X_AL
          VD="CON_DA"+STRTRAN(STR(H,2)," ","0")
          VA="CON_AV"+STRTRAN(STR(H,2)," ","0")
          V_TOTD=V_TOTD+&VD
          V_TOTA=V_TOTA+&VA
      NEXT
   ELSE
      IF CON_ANNO = Z_DAA
         X_DAL = VAL(Z_DAL)
         X_AL  = 12
         FOR H=X_DAL TO X_AL
             VD="CON_DA"+STRTRAN(STR(H,2)," ","0")
             VA="CON_AV"+STRTRAN(STR(H,2)," ","0")
             V_TOTD=V_TOTD+&VD
             V_TOTA=V_TOTA+&VA
         NEXT
      ENDIF
      IF CON_ANNO = Z_AAA
         X_DAL = 1
         X_AL  = VAL(Z_AL)
         FOR H=X_DAL TO X_AL
             VD="CON_DA"+STRTRAN(STR(H,2)," ","0")
             VA="CON_AV"+STRTRAN(STR(H,2)," ","0")
             V_TOTD=V_TOTD+&VD
             V_TOTA=V_TOTA+&VA
         NEXT
      ENDIF
  ENDIF

  IF OK_SALDI
     IF V_TOTD = 0 .AND. V_TOTA = 0
        SELECT &V_DBASE
        SKIP +1
        LOOP
     ENDIF
  ENDIF

  DO SBCAGWF1

  SELECT &V_DBASE
  SKIP +1

ENDDO

SELECT WOPE_SBC
select * from WOPE_SBC into cursor wope_sbc_save

SELECT WOPE_SBC
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF ZA_SALDOI < 0
      SA_DIFFE=AV_TOTALE-ABS(ZA_SALDOI)
      IF SA_DIFFE < 0
         REPLACE AV_TOTALE WITH 0
         REPLACE DA_TOTALE WITH DA_TOTALE + ABS(SA_DIFFE)
      ELSE
         REPLACE AV_TOTALE WITH ABS(SA_DIFFE)
      ENDIF
   ELSE
      SA_DIFFE=DA_TOTALE-ABS(ZA_SALDOI)
      IF SA_DIFFE < 0
         REPLACE DA_TOTALE WITH 0
         REPLACE AV_TOTALE WITH AV_TOTALE + ABS(SA_DIFFE)
      ELSE
         REPLACE DA_TOTALE WITH ABS(SA_DIFFE)
      ENDIF
  ENDIF
  SKIP+1
ENDDO

** SALVA I DETTAGLI

VA_TOTALE = 0
VD_TOTALE = 0
VA_SALDOI = 0

select wope_sbc_save
sum da_totale to VA_TOTALE
sum av_totale to VD_TOTALE

SELECT WOPE_SBC
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   V_CONTO = DA_CODCON
   TT_TIPO = DA_TIPO

   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
 	   IF LEN(ALLTRIM(V_CONTO)) < PUB_GRUPPOCF
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF
   ELSE
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_SOTTOG
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF
   ** SERGIO 18/12/2021 FINE


   SCATTER MEMVAR

   M.AV_SALDOI = M.ZA_SALDOI

   ** CALCOLO DEI TOTALI GENERALI
   *  VA_TOTALE = VA_TOTALE + M.DA_totale
   *  VD_TOTALE = VD_TOTALE + M.AV_totale

   SELECT WOPE_SB3
   APPEND BLANK
   GATHER MEMVAR

   SELECT WOPE_SBC
   SKIP +1

ENDDO

** RICALCOLO TOTALI GENERALI SU TOTALI ZD_ / ZA_   (TOTALI INTERMEDI DI GRUPPO)

SELECT WOPE_SB3
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF


   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
   		V_CONTO  = SUBSTR(DA_CODCON,1,PUB_GRUPPOCF)

   ELSE
   		V_CONTO  = SUBSTR(DA_CODCON,1,PUB_SOTTOG-1)
   ENDIF
   ** SERGIO 18/12/2021 FINE

   TT_TIPO  = "ZZ"
   A_TOTALE = AV_TOTALE
   D_TOTALE = DA_TOTALE
   Z_SALDOI = ZA_SALDOI

   SELECT WOPE_SBC
   SET ORDER TO WOPE_SBC
   _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
   SEEK _SKK
   IF FOUND()
      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
   ELSE
      ** CASO ANOMALO DEVO COMUNQUE RICREARE IL GRUPPO TOTALE DI TESTATA CHE TOTALE TOTALE
      APPEND BLANK
      REPLACE DA_TIPO   WITH TT_TIPO
      REPLACE DA_CODCON WITH V_CONTO
      REPLACE DA_DESCR  WITH SPACE(27) + "TOTALE CONTO"
      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
      _SKK =  ALLTRIM(V_CONTO)+ "  "
      SEEK _SKK
      IF !FOUND()
         APPEND BLANK
         REPLACE DA_TIPO   WITH "  "
         REPLACE DA_CODCON WITH V_CONTO
         REPLACE DA_DESCR  WITH GETDCON(V_CONTO)
      ENDIF
   ENDIF

   SELECT WOPE_SB3
   SKIP +1

ENDDO

SELECT WOPE_SBC

SET NEAR OFF
RETURN

***************************************************************************
 PROCEDURE SBC700  && STAMPA BILANCIO NORMALE CON CONFRONTO ANNO PRECEDENTE
***************************************************************************
PARA V_POSBIL,V_CONINI,V_CONFIN,V_DAL,V_AL,PUB_ANNO,V_DBASE,__STAMPA_SOLO_I_CLIENTI_FORNITORI,__STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI,___ANNOP

V_SALDOI = 0

IF PCOUNT() = 6
   V_DBASE = "CONTI"
   __STAMPA_SOLO_I_CLIENTI_FORNITORI  = .F.
   __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI = .F.
   ___ANNOP = ""
ENDIF

IF PCOUNT() = 7
   __STAMPA_SOLO_I_CLIENTI_FORNITORI  = .F.
   __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI = .F.
   ___ANNOP = ""
ENDIF

CREATE CURSOR TEMPO_DB;
  (CONTO C(13),DESCRI C(40),DARE N(20,8),AVERE N(20,8), SALDO N(20,8), MOVIM C(02))

CREATE CURSOR WOPE_SB3 (DA_TIPO C(02),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),;
                        AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZD_TOTALE N(20,8),ZA_TOTALE N(20,8),ZA_SALDOI N(20,8),DA_TIPOCO C(1))

CREATE CURSOR WOPE_SBC (DA_TIPO C(02),;
						DA_CODCON C(13),;
						DA_DESCR C(40),;
                        AV_CODCON C(13),;
                        AV_DESCR C(40),;
						DA_TOTALE N(20,8),;
                        AV_TOTALE N(20,8),;
                        ZD_TOTALE N(20,8),;
                        ZA_TOTALE N(20,8),;
                        ZA_SALDOI N(20,8),;
						DA_AP_TOTALE N(20,8),;
                        AV_AP_TOTALE N(20,8),;
                        ZD_AP_TOTALE N(20,8),;
                        ZA_AP_TOTALE N(20,8),;
                        DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CODCON) + DA_TIPO TAG WOPE_SBC ADDITIVE


SET NEAR ON
SELECT &V_DBASE
SET ORDER TO CONTO
IF !EMPTY(___ANNOP)								&& CONFRONTO ANNO PRECEDENTE
	SEEK PUB_CODSOC+___ANNOP
ELSE
	SEEK PUB_CODSOC+PUB_ANNO
ENDIF

DETTAGLI = .T.
PRIMOD   = .T.
PRIMOA   = .T.
V_GRSG   = ""
V_OLDD   = ""
V_OLDA   = ""


DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF !EMPTY(___ANNOP)								&& CONFRONTO ANNO PRECEDENTE
	   IF DELETED() .OR. CON_ANNO != ___ANNOP
	      SKIP +1
	      LOOP
	   ENDIF
   ELSE
	   IF DELETED() .OR. CON_ANNO != PUB_ANNO
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF
   	
   	
   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 

	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,PUB_GRUPPOCF)==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF

	   IF LEN(ALLTRIM(CON_CONTO)) < PUB_GRUPPOCF
	      SKIP +1
	      LOOP
	   ENDIF

   ELSE

	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,PUB_SOTTOG-1)==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF

	   IF LEN(ALLTRIM(CON_CONTO)) < PUB_SOTTOG
	      SKIP +1
	      LOOP
	   ENDIF

   ENDIF
   ** SERGIO 18/12/2021 FINE   	
   	

   IF CON_TIPOCO = "O"    && SCARTA CONTI D'ORDINE
      =CREA_SALDI_PIANO_CONTI(V_DBASE)
      SKIP +1
      LOOP
   ENDIF

   IF CON_POSBIL  <> V_POSBIL
      SKIP +1
      LOOP
   ENDIF

   IF __STAMPA_SOLO_I_CLIENTI_FORNITORI
	   IF CON_TIPOCO  =  "C" OR CON_TIPOCO  =  "F"
       ELSE
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF



   V_CONTO  = CON_CONTO
   V_TIPOCO = CON_TIPOCO
   V_DESCR  = CON_DESCR

   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
	   V_GRSG   = SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
   ELSE
	   V_GRSG   = SUBSTR(V_CONTO,1,PUB_SOTTOG-1)
   ENDIF
   ** SERGIO 18/12/2021 FINE   	

   V_SALDOI = CON_SALDOI

   v_seek 	 = "BIL"+V_GRSG
   v_chiave  = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      IF SUBSTR(LIBERA,1,1)=="S"
         DETTAGLI=.T.
      ELSE
         DETTAGLI=.F.
      ENDIF
   ELSE
      DETTAGLI=.F.
   ENDIF

   SELECT &V_DBASE

   V_TOTD = 0
   V_TOTA = 0

   FOR H=V_DAL TO V_AL
       VD="CON_DA"+STRTRAN(STR(H,2)," ","0")
       VA="CON_AV"+STRTRAN(STR(H,2)," ","0")
       V_TOTD=V_TOTD+&VD
       V_TOTA=V_TOTA+&VA
   NEXT

   IF OK_SALDI
      IF V_TOTD = 0 .AND. V_TOTA = 0
         SELECT &V_DBASE
         SKIP +1
         LOOP
      ENDIF
   ENDIF


   ** SE L'ESERCIZIO PRECEDENTE E' STATO CHIUSO , RIPORTA IL SALDO DI CHIUSURA AL FINE DI EVIDENZIARE NEL
   ** BILANCIO I SALDI PRIMA DELLACHIUSURA EFFETTIVA


   IF CHI_DARE <> 0
	  V_TOTD = V_TOTD - CHI_DARE
   ENDIF

   IF CHI_AVERE <> 0
	  V_TOTA = V_TOTA - CHI_AVERE
   ENDIF



   DO SBCAGWF1

   SELECT &V_DBASE
   SKIP +1

ENDDO


SELECT WOPE_SBC

select  * from WOPE_SBC into cursor wope_sbc_save

SELECT WOPE_SBC
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF ZA_SALDOI < 0
      SA_DIFFE=AV_TOTALE-ABS(ZA_SALDOI)
      IF SA_DIFFE < 0
         REPLACE AV_TOTALE WITH 0
         REPLACE DA_TOTALE WITH DA_TOTALE + ABS(SA_DIFFE)
      ELSE
         REPLACE AV_TOTALE WITH ABS(SA_DIFFE)
     ENDIF
  ELSE
     SA_DIFFE=DA_TOTALE-ABS(ZA_SALDOI)
     IF SA_DIFFE < 0
        REPLACE DA_TOTALE WITH 0
        REPLACE AV_TOTALE WITH AV_TOTALE + ABS(SA_DIFFE)
     ELSE
        REPLACE DA_TOTALE WITH ABS(SA_DIFFE)
     ENDIF
  ENDIF
  SKIP+1
ENDDO

** SALVA I DETTAGLI

VA_TOTALE = 0
VD_TOTALE = 0
VA_SALDOI = 0

select wope_sbc_save
DO WHILE .not. EOF()

	VA_TOTALE = VA_TOTALE + ROUND(da_totale,2)
	VD_TOTALE = VD_TOTALE + ROUND(av_totale,2)

	SKIP +1
ENDDO

*!*	sum da_totale to VA_TOTALE
*!*	sum av_totale to VD_TOTALE

SELECT WOPE_SBC
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   V_CONTO=DA_CODCON
   TT_TIPO=DA_TIPO

   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_GRUPPOCF
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF
	   
   ELSE
	   IF LEN(ALLTRIM(V_CONTO)) < PUB_SOTTOG
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF
   ** SERGIO 18/12/2021 FINE 


   SCATTER MEMVAR
   M.AV_SALDOI = M.ZA_SALDOI
   ** CALCOLO DEI TOTALI GENERALI
   *  VA_TOTALE = VA_TOTALE + M.DA_totale
   *  VD_TOTALE = VD_TOTALE + M.AV_totale
   SELECT WOPE_SB3
   APPEND BLANK
   GATHER MEMVAR
   SELECT WOPE_SBC
   SKIP +1
ENDDO

** RICALCOLO TOTALI GENERALI SU TOTALI ZD_ / ZA_   (TOTALI INTERMEDI DI GRUPPO)

SELECT WOPE_SB3
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF

   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
	   V_CONTO  = SUBSTR(DA_CODCON,1,PUB_GRUPPOCF)	   
   ELSE
	   V_CONTO  = SUBSTR(DA_CODCON,1,PUB_SOTTOG-1)
   ENDIF
   ** SERGIO 18/12/2021 FINE 


   TT_TIPO  = "ZZ"
   A_TOTALE = AV_TOTALE
   D_TOTALE = DA_TOTALE
   Z_SALDOI = ZA_SALDOI
   SELECT WOPE_SBC
   SET ORDER TO WOPE_SBC
   _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
   SEEK _SKK
   IF FOUND()
      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
   ELSE
      ** CASO ANOMALO DEVO COMUNQUE RICREARE IL GRUPPO TOTALE DI TESTATA CHE TOTALE TOTALE
      APPEND BLANK
      REPLACE DA_TIPO   WITH TT_TIPO
      REPLACE DA_CODCON WITH V_CONTO
      REPLACE DA_DESCR  WITH SPACE(27) + "TOTALE CONTO"
      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
      _SKK =  ALLTRIM(V_CONTO)+ "  "
      SEEK _SKK
      IF !FOUND()
         APPEND BLANK
         REPLACE DA_TIPO   WITH "  "
         REPLACE DA_CODCON WITH V_CONTO
         REPLACE DA_DESCR  WITH GETDCON(V_CONTO)
      ENDIF
   ENDIF
   SELECT WOPE_SB3
   SKIP +1
ENDDO


IF __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI
	
	SELECT WOPE_SBC
	GO TOP
	
	DO WHILE .T.
	
	   IF EOF()
	      EXIT
	   ENDIF
	
	   IF ALLTRIM(DA_TIPO) <> "ZZ"

        DELETE

	   ENDIF
	
	
		
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
        IF !EMPTY(___ANNOP)
			x_anno = "con_anno = '" + ___ANNOP + "'"
		ELSE
			x_anno = "con_anno = '" + PUB_ANNO + "'"
		ENDIF
		x_cont = "con_conto = '" + ALLTRIM(WOPE_SBC.DA_CODCON) + "'"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont
		Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
		IF !ExecCommand(cSql,"xcontix")
		   return(.f.)
		ENDIF
		SELECT xcontix
		GO TOP
		IF EOF()
			_DA_DESCR  = "*** CONTO INESISTENTE SUL PIANO DEI CONTI ***"
		ELSE
			_DA_DESCR  = CON_DESCR
		ENDIF
	
	
	   SELECT WOPE_SBC	
       REPLACE DA_DESCR  WITH _DA_DESCR
       REPLACE AV_DESCR  WITH _DA_DESCR
*!*	       REPLACE DA_TIPO   WITH SPACE(13)

	   SKIP +1	
	
	ENDDO WHILE .T.
	
	
ENDIF


SELECT WOPE_SBC
GO TOP


SET NEAR OFF
RETURN


**************************************************************************
PROCEDURE SBCAGWF
**************************************************************************

V_SALDO = V_TOTD - V_TOTA

IF V_DBASE = "CONTI"
   IF V_SALDO = 0
      RETURN
   ENDIF
ENDIF

IF V_SALDO > 0
   SELECT WOPE_SB1
   APPEND BLANK
   REPLACE DA_CODCON WITH V_CONTO
   REPLACE DA_DESCR  WITH V_DESCR
   REPLACE DA_TIPOCO WITH V_TIPOCO
   REPLACE DA_TOTALE WITH ABS(V_SALDO)
   REPLACE DA_SALDOI WITH V_SALDOI
   
   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
	   V_OLDD=SUBSTR(V_CONTO,1,(PUB_GRUPPOCF))
   ELSE
	   V_OLDD=SUBSTR(V_CONTO,1,(PUB_SOTTOG-1))
   ENDIF
   ** SERGIO 18/12/2021 FINE 
   
   
   PRIMOD=.F.
ELSE
   SELECT WOPE_SB2
   APPEND BLANK
   REPLACE AV_CODCON WITH V_CONTO
   REPLACE AV_DESCR  WITH V_DESCR
   REPLACE AV_TIPOCO WITH V_TIPOCO
   REPLACE AV_TOTALE WITH ABS(V_SALDO)
   REPLACE AV_SALDOI WITH V_SALDOI
   
   ** SERGIO 18/12/2021 INIZIO
   IF PUB_CONTOSIMILCEE 
	   V_OLDA=SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
   ELSE
	   V_OLDA=SUBSTR(V_CONTO,1,(PUB_SOTTOG-1))
   ENDIF
   ** SERGIO 18/12/2021 FINE    
   
   PRIMOA=.F.
ENDIF

RETURN


**************************************************************************
PROCEDURE SBCAGWF1
**************************************************************************

V_SALDO = V_TOTD - V_TOTA

IF V_DBASE = "CONTI"
   IF V_SALDO = 0
      RETURN
   ENDIF
ENDIF

IF V_SALDO > 0
   SELECT WOPE_SBC
   SET ORDER TO WOPE_SBC
   _KK= ALLTRIM(V_CONTO) + "DD"
   SEEK _KK
   IF !FOUND()
      APPEND BLANK
      REPLACE DA_CODCON WITH V_CONTO
      REPLACE DA_TIPO   WITH "DD"
	  REPLACE DA_DESCR  WITH V_DESCR
      REPLACE DA_TIPOCO WITH V_TIPOCO
      REPLACE DA_TOTALE WITH ABS(V_SALDO)
      REPLACE ZA_SALDOI WITH V_SALDOI
   ELSE
      REPLACE DA_TOTALE WITH DA_TOTALE + ABS(V_SALDO)
      REPLACE ZA_SALDOI WITH ZA_SALDOI + V_SALDOI
   ENDIF
ELSE
   SELECT WOPE_SBC
   SET ORDER TO WOPE_SBC
   _KK= ALLTRIM(V_CONTO) + "DD"
   SEEK _KK
   IF !FOUND()
      APPEND BLANK
      REPLACE DA_CODCON WITH V_CONTO
      REPLACE DA_TIPO   WITH "DD"
      REPLACE DA_DESCR  WITH V_DESCR
      REPLACE DA_TIPOCO WITH V_TIPOCO
      REPLACE AV_TOTALE WITH ABS(V_SALDO)
	  REPLACE ZA_SALDOI WITH V_SALDOI
   ELSE
      REPLACE AV_TOTALE WITH AV_TOTALE + ABS(V_SALDO)
	  REPLACE ZA_SALDOI WITH ZA_SALDOI + V_SALDOI
   ENDIF
ENDIF

RETURN



********************************************
PROCEDURE SITFINAN_CPA
********************************************

RELEASE ____TIPOCO
PUBLIC ____TIPOCO
____TIPOCO = ""

DATADA = ANNO+"/01/01"
DATAA  = ANNO+"/12/31"
AAPART = SUBSTR(DATADA,1,4)

ANNO_MESE_DAL = ALLTRIM(ANNO)+"/"+ALLTRIM(MESE___)
ANNO_MESE_AL  = ALLTRIM(ANNO)+"/"+ALLTRIM(MESEAL___)

__TOTALE_CLIENTI	= 0
__TOTALE_FORNITORI	= 0

v_seek	 = 'GEN'+PUB_CODSOC
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
ELSE
   WAIT WINDOW "Errore manca parametro GEN 4 caratteri conti clienti"
   RETURN
ENDIF


CC=SUBSTR(LIBERA,1,PUB_SOTTOG-1)
FF=SUBSTR(LIBERA,18,PUB_SOTTOG-1)


x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + ANNO + "'"
x_cond = x_soci + " and " + x_anno

IF !EMPTY(M.COD)
   x_codi = " AND MOV_CONTO = '" + ALLTRIM(M.COD) + "'"
ELSE
   x_codi = ""
   M.descr   = "Tutti i clienti/fornitori"
ENDIF



WAIT WINDOWS "........elaborazione movimenti contabili in corso attendere prego" nowait
	
***----------	
		
   	IMPA      = 0
   	IMPD      = 0
   	IMP_BOF   = 0
   	OK_CREA   = .T.
   	XAAPART   = AAPART
   	TOT_DARE  =  0
   	TOT_AVERE =  0
   	PIU_RIP 	 = .T.
	
		
   	x_soci = "mov_soc = '" + PUB_CODSOC + "'"
	x_anno = "1=1"  			&& non considera + l'anno ma la data di registrazione
	x_datda = "mov_dtreg >= '" + DATADA + "'"
	x_data  = "mov_dtreg <= '" + DATAA  + "'"
	

	cSql   = "SELECT * FROM mov_cont WHERE " + x_soci + " and " + x_anno + " and " + x_datda  + " and " + x_data + ;
	                                     +  x_codi + " order by MOV_ANNO,MOV_DTREG,MOV_NUMPRO,MOV_SEQUEN"


   IF !ExecCommand(cSql,"MOV_CONT")
      return(.f.)
   ENDIF
   SELECT MOV_CONT
   GO TOP
 	
   DO WHILE .T.
	
	  IF EOF()
	     EXIT
	  ENDIF
	
	  IF DELETED()
	     SELECT MOV_CONT
	     SKIP +1
		 LOOP
	  ENDIF

	   ** SERGIO 18/12/2021 INIZIO
	   IF PUB_CONTOSIMILCEE 
		   
	      IF LEN(ALLTRIM(MOV_CONTO))  <  PUB_GRUPPOCF
		     SELECT MOV_CONT
		     SKIP +1
			 LOOP
		  ENDIF
		   
	   ELSE

	      IF LEN(ALLTRIM(MOV_CONTO))  <  PUB_SOTTOG
		     SELECT MOV_CONT
		     SKIP +1
			 LOOP
		  ENDIF

	   ENDIF
	   ** SERGIO 18/12/2021 FINE   


	  IF !EMPTY(MESE___)
		  IF SUBSTR(MOV_DTREG,1,7) < ANNO_MESE_DAL
			 SELECT MOV_CONT
			 SKIP +1
			 LOOP
		  ENDIF	
		  IF SUBSTR(MOV_DTREG,1,7) > ANNO_MESE_AL
			 SELECT MOV_CONT
			 SKIP +1
			 LOOP
		  ENDIF
	  ENDIF
	
	  IF MOV_TOP = "CHI"
		 SELECT MOV_CONT
		 SKIP +1
		 LOOP
	  ENDIF

	  IF MOV_TOP = "APE"
		 SELECT MOV_CONT
		 SKIP +1
		 LOOP
	  ENDIF
	


	  ____TIPOCO = ""
	  ____DESCO  = ""
	  x_soci = "con_soc = '" + PUB_CODSOC + "'"
	  x_anno = "con_anno = '" + PUB_ANNO + "'"
	  x_cont = "con_conto = '" + ALLTRIM(MOV_CONTO) + "'"
	  x_cond = x_soci + " and " + x_anno + " and " + x_cont
	  Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
	  IF !ExecCommand(cSql,"cur_conti_")
	     return(.f.)
	  ENDIF
	  SELECT cur_conti_
	  GO TOP
	  IF !EOF()

			 ____TIPOCO = CON_TIPOCO
			 ____DESCO  = CON_DESCR
			
			 IF ____TIPOCO ='C' OR ____TIPOCO ='F'		&& SCARTA CONTI DIVERSI DA CLIENTI/FORNITORI
			 ELSE
			    SELECT MOV_CONT
			    SKIP + 1
			    LOOP
	 	     ENDIF	

	  ENDIF

      SELECT MOV_CONT


		
	  REG    	  = RIBALTA2(MOV_DTREG)
	  DOC    	  = RIBALTA2(MOV_DTDOC)
	  NUMREG 	  = MOV_NREGIS
	  PROT   	  = MOV_NPROT
	  TTOP   	  = MOV_TOP
	  CON         = MOV_CONTO
	  WDES_MANU   = MOV_DESMOV
	  WCAMBIO	  = MOV_CAMBIO	
	  WCODVAL     = MOV_VALUTA
	  NUMPRO 	  = MOV_NUMPRO 	
	
	
	  WCPA		  = MOV_MODPAG


	  IF ALLTRIM(TTOP) = 'ERB'	&& SALTO LE RIBA AUTOMATICHE
		    SELECT MOV_CONT
		    SKIP + 1
		    LOOP
	  ENDIF


	  IF ALLTRIM(WCPA) = ''

		  IF ____TIPOCO ='C'
		  	
		  	  _xs_ = SELECT()
		  	
			  x_numpro = "par_numpro = '" + NUMPRO + "'"
			  x_nreg   = "par_nreg = '" + NUMREG + "'"
			  x_nprog  = "par_nprog = '100'"
			  x_cond = x_numpro + " and " + x_nreg + " and " + x_nprog
			  Csql   = "select par_codpag from part_cli where " + x_cond
			  IF !ExecCommand(cSql,"SK_CPA")
			     return(.f.)
			  ENDIF
			
			  SELECT SK_CPA
			  WCPA = par_codpag
			
		  	  SELECT(_xs_)		
			
		  ENDIF

	  ENDIF

	  IF ALLTRIM(WCPA) = 'XXX'	&& SALTO LE RIBA AUTOMATICHE
		    SELECT MOV_CONT
		    SKIP + 1
		    LOOP
	  ENDIF

	  *** ESTRAZIONE DEI GIORNI DA PARAMETRO 'CPA' - INIZIO
	  **
	  	  _xy_ = SELECT()
	  	
	  	  __GGCPA  	 = '0'
	  	  __GGSCAFIS = 0
	  	  __DESCPA = ''  	
	  	
		  x_cond  = "CODICE = 'CPA" + WCPA + "' "
		  Csql   = "SELECT CODICE,DESCRI,SUBSTRING(LIBERA,11,LEN(LIBERA)) AS GGSCAD,SCAFISS FROM PARA WHERE " + x_cond
		  IF !ExecCommand(cSql,"GG_CPA")
		     return(.f.)
		  ENDIF
		
		  SELECT GG_CPA
		  IF !EMPTY(ALLTRIM(GGSCAD))
			  __GGCPA 	 = ALLTRIM(GGSCAD)
			  __GGSCAFIS = SCAFISS
		  ELSE
			  __GGCPA 	 = '0'
			  __GGSCAFIS = 0
		  ENDIF
		  __DESCPA = ALLTRIM(DESCRI)
		
	  	  SELECT(_xy_)		

	  **
	  *** ESTRAZIONE DEI GIORNI DA PARAMETRO 'CPA' - FINE




	  __idxdividi = 0
	  __addendo   = 0
	  __strToConvert = STRTRAN(__GGCPA,' ','#')
	
	  IF OCCURS('#',__strToConvert) > 0
	
	  		__idxdividi = OCCURS('#',__strToConvert) + 1
	  		__strToConvert = __strToConvert + '#'

			__somma = 0
	  		DO WHILE .T.
	  		
	  			__addendo = VAL(SUBSTR(__strToConvert,1,AT('#',__strToConvert)-1))
				__strToConvert = SUBSTR(__strToConvert,AT('#',__strToConvert)+1,LEN(__strToConvert))
				
				__somma = __somma + __addendo
				
				IF OCCURS('#',__strToConvert) = 0
					EXIT
				ENDIF
				
			ENDDO
				
		    __VGGCPA = (__somma / __idxdividi) + __GGSCAFIS
		
	  ELSE
	
  	  	  	IF __GGCPA  == '0' .OR. ALLTRIM(__GGCPA) == ''
	  	  	  	__GGCPA = '1'	&& PER LA RIMESSA DIRETTA, PER ES., PRENDIAMO UN GIORNO COME VALORE SIGNIFICATIVO
  	  	  	ENDIF

	  		__VGGCPA = VAL(__GGCPA) + __GGSCAFIS
	
	  ENDIF




	
	  ** VERIFICA SE NOTA CREDITO
      v_seek   = 'TOP'+ALLTRIM(TTOP)
      v_chiave = "codice"
      IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
         SELECT CUR_PARA
	     NOTAC	   = SUBSTR(LIBERA,11,1)
	     FATTURA   = SUBSTR(LIBERA,2,1)
	     SITCPA    = SUBSTR(LIBERA,53,1)
	     DESCRTOP  = DESCRI
	  ELSE
	     NOTAC	   = " "
	     FATTURA   = " "
	     SITCPA    = " "
	     DESCRTOP  = "??????????"
	  ENDIF


      IF FATTURA = "S" .OR. FATTURA = "P"		&& SCARTA EVENTUALI MOVIMENTI DI GIRO CONTO SUI CLIENTI O SUI FORNITORI
      ELSE
		  SELECT MOV_CONT
		  SKIP + 1
		  LOOP
	  ENDIF	

      IF SITCPA = "S"
      ELSE
		  SELECT MOV_CONT
		  SKIP + 1
		  LOOP
	  ENDIF		


	  ** SALVA NEL CURSORE APPOSITO IL TOP+DESCRIZIONE
	  SELECT PARA_TOP
	  SET ORDER TO PARA_TOP_I
	  GO TOP
	
	  _TTOP = ALLTRIM(TTOP)
	  SEEK _TTOP
	  IF !FOUND()
		 APPEND  BLANK
  	     REPLACE   TOP_CODICE  WITH _TTOP
  	     REPLACE   TOP_DESCRI  WITH DESCRTOP
	  ENDIF	  	  	  	


      SELECT MOV_CONT

 	  IMPD = 0
 	  IMPA = 0

	  IF SUBSTR(MOV_TMOV,1,1)='A'      && AVERE
         IF F_VALUTA = 1
            IMPA = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
         ELSE
            IMPA = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		 ENDIF
	     IMPD=0
	  ENDIF
		
	  IF SUBSTR(MOV_TMOV,1,1)='D'      && DARE
         IF F_VALUTA = 1
            IMPD = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
         ELSE
            IMPD = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		 ENDIF
	     IMPA=0
	  ENDIF

      IF NOTAC = "S" .AND. FATTURA = "S"										&& E' UNA NOTA DI CREDITO , VERIFICO SE SUL CLIENTE O SUL FORNITORE		
		  IF ____TIPOCO ='C' 									
	         IF F_VALUTA = 1
    	        IMPD = (TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO CLIENTI
        	 ELSE
            	IMPD = (TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO CLIENTI
			 ENDIF
		     IMPA=0
		  ELSE
	         IF F_VALUTA = 1
    	        IMPA = (TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO FORNITORI
        	 ELSE
            	IMPA = (TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC)) * -1)		&& GESTIONE NOTE DI CREDITO FORNITORI
			 ENDIF
		     IMPD=0
		  ENDIF	
	  ENDIF

	  WSALDO        = IMPD - IMPA                     && SALDO
	  TOT_DARE  	= TOT_DARE  + IMPD
	  TOT_AVERE  	= TOT_AVERE + IMPA

	  IF ____TIPOCO ='C'
	     _DARE      = "CON_DAC"
	     _AVERE     = "CON_AVC"
	     __TOTALE_CLIENTI = __TOTALE_CLIENTI + WSALDO
	  ELSE	
	     _DARE      = "CON_DAF"
	     _AVERE     = "CON_AVF"
	     __TOTALE_FORNITORI = __TOTALE_FORNITORI + WSALDO        	
	  ENDIF

	  SELECT STAT_CPA
	  SET ORDER TO __CPA
	

	  _RK = ALLTRIM(CON)+ALLTRIM(WCPA)
	  SEEK _RK
	
	  IF FOUND()
  	     REPLACE   &_DARE      WITH &_DARE  + IMPD
  	     REPLACE   &_AVERE     WITH &_AVERE + IMPA
  	     REPLACE   CON_SALDO   WITH CON_SALDO + WSALDO        	
  	  ELSE
		 APPEND  BLANK
  	     REPLACE   CLFO        WITH ____TIPOCO	  	
  	     REPLACE   CODCLFO     WITH ALLTRIM(CON)
  	     REPLACE   DESCLFO     WITH ____DESCO
  	     REPLACE   CPA         WITH ALLTRIM(WCPA)
  	     REPLACE   DESCPA      WITH ALLTRIM(__DESCPA)  	
  	     REPLACE   CGGCPA 	   WITH ALLTRIM(__GGCPA)	  	   	       	       	
   	     REPLACE   VGGCPA 	   WITH __VGGCPA
   	     REPLACE   PERIODO     WITH SUBSTR(RIBALTA2(REG),1,4)
  	     REPLACE   &_DARE      WITH IMPD
  	     REPLACE   &_AVERE     WITH IMPA
  	     REPLACE   CON_SALDO   WITH CON_SALDO + WSALDO     	
	  ENDIF


	  *!* CREA CURSORE PER IL RICALCOLO DELL'IVA

*!*		  IF FATTURA = "S"
*!*			
*!*			  SELECT MOV_CONT
*!*			  __MOV_NUMPRO = MOV_NUMPRO
*!*			  __MOV_CLIFOR = ____TIPOCO
*!*			  IF FATTURA = "S"
*!*			    IF NOTAC = "S"
*!*			  		__MOV_FATNCR = "N"
*!*			  	ELSE
*!*			  		__MOV_FATNCR = "F"
*!*			  	ENDIF
*!*			  ENDIF
*!*		      __MOV_IMP  = MOV_IMP
*!*	
*!*			  SELECT MOV_ERARIO
*!*			  APPEND BLANK
*!*			  REPLACE PERIODO 		WITH SUBSTR(RIBALTA2(REG),1,4)+SUBSTR(RIBALTA2(REG),6,2)
*!*			  REPLACE MOV_NUMPRO 	WITH __MOV_NUMPRO
*!*			  REPLACE MOV_CLIFOR 	WITH __MOV_CLIFOR
*!*			  REPLACE MOV_FATNCR 	WITH __MOV_FATNCR
*!*			  REPLACE MOV_IMP 		WITH __MOV_IMP
*!*		
*!*		  ENDIF FATTURA = "S"


	  SELECT MOV_CONT
	  SKIP +1

   ENDDO


***----------	




*!*	SELECT MOV_ERARIO
*!*	GO top


*!*	DO WHILE .T.
*!*		
*!*	  IF EOF()
*!*	    EXIT
*!*	  ENDIF
*!*	
*!*	  _TIMPOSTA=CERCA_MOVIMENTI_IVA(SUBSTR(PERIODO,1,4),MOV_NUMPRO)
*!*	
*!*	
*!*	  SELECT MOV_ERARIO

*!*	
*!*	  IF MOV_FATNCR  = "N" AND MOV_CLIFOR = "C"			&& VERIFICA SE NOTA CREDITO CLIENTE	, IN QUESTO CASO E' L'ERARIO CHE DEVE RESTITUIRMI L'IMPORTO , COME SE FOSSE UNA FATTURA A FORNITORE
*!*		_TIMPOSTA=_TIMPOSTA * -1
*!*	  ENDIF

*!*	  IF MOV_CLIFOR = "F"								&& VERIFICA SE IVA FORNITORE
*!*	  	IF MOV_FATNCR <> "N"							&& SE NOTA CREDITO LA DEVO PAGARE ALL'ERARIO PE CUI NON DEVE ESSERE NEGATIVA
*!*		  _TIMPOSTA=_TIMPOSTA * -1
*!*		ENDIF
*!*	  ENDIF



*!*	  _PERIODO=SUBSTR(PERIODO,1,4)
*!*	  _MESE   =SUBSTR(PERIODO,5,2)
*!*	  _ERARIO ="CON_ERARIO"+_MESE

*!*	  SELECT STAT_CPA
*!*	  SET ORDER TO __CPA

*!*	  SEEK _PERIODO
*!*	  IF FOUND()
*!*	      REPLACE   &_ERARIO WITH &_ERARIO + _TIMPOSTA
*!*	  ELSE
*!*		 APPEND  BLANK
*!*	  	 REPLACE   PERIODO  WITH _PERIODO	
*!*	     REPLACE   &_ERARIO WITH _TIMPOSTA
*!*	  ENDIF


*!*	  SELECT MOV_ERARIO
*!*	  REPLACE MOV_IMPOST WITH _TIMPOSTA
*!*	
*!*	  SKIP +1

*!*	ENDDO WHILE .T.

*!*	SELECT MOV_ERARIO
*!*	GO TOP

SELECT STAT_CPA
GO TOP

*!*	WAIT WINDOWS "IMPORTO BOF" + STR(IMP_BOF,12,2)

RETURN






********************************************
PROCEDURE TABLEAU_DE_BOARD
********************************************

	**************************************************************************************************
	**************************************************************************************************	
	***
	***		ESTRAZIONE DATI IN CONTABILITA'
	***
	**************************************************************************************************
	**************************************************************************************************	
		RELEASE ____TIPOCO
		PUBLIC ____TIPOCO
		____TIPOCO = ""

		_TOT_DARE  = 0
		_TOT_AVERE = 0

		v_seek	 = 'GEN'+PUB_CODSOC
		v_chiave = "codice"
		IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
		   SELECT CUR_PARA
		ELSE
		   WAIT WINDOW "Errore manca parametro GEN 4 caratteri conti clienti"
		   RETURN
		ENDIF

	    CC=SUBSTR(LIBERA,1,PUB_SOTTOG-1)
        FF=SUBSTR(LIBERA,18,PUB_SOTTOG-1)


		CREATE CURSOR TABLEAU_CGE (;
		 	CLFO C(1), PERIODO C(06), ;
		 	CODCLFO C(15), DESCLFO C(50), ;
		 	NPROT C(10), DTDOC C(10), SOLOCLI C(13), ;		 	
		 	CPA C(10), TOP C(10),;
		 	PERCIVA C(3),;
		 	DATREG C(10),NUMREGIS C(10),;
		 	CON_DAC N(17,3),CON_AVC N(17,3), ;
		 	CON_DAF N(17,3),CON_AVF N(17,3), ;
		 	CON_SALDO N(17,3),;
		 	MOVIMP N(17,3),;		 	
		 	MOVNUMPRO C(13),;
		 	CAMBIO N(15,10),;		 	
		 	VALUTA C(3),;
		 	NUMERODOC C(10),;  		 			 	
		 	CODIVA C(3),;		 	
			PRC N(6,2), PRCSEL N(6,2), PRCCPA N(6,2),;
			DB_NOTAC C(1),;
			DB_FATTURA C(1),;
			DB_CLFO C(1),;
			DB_RIBA C(1))
*!*			INDEX ON ALLTRIM(CODCLFO)+ALLTRIM(DATREG)+ALLTRIM(NUMREGIS)	TAG ID_TAB ADDITIVE
		INDEX ON ALLTRIM(CODCLFO)+ALLTRIM(DATREG)+ALLTRIM(NUMREGIS)+ALLTRIM(MOVNUMPRO)	TAG ID_TAB ADDITIVE		

		INDEX ON ALLTRIM(DATREG)+ALLTRIM(NUMREGIS)+ALLTRIM(CODCLFO)	TAG ELAB ADDITIVE		

		CREATE CURSOR PARA_TOP (TOP_CODICE C(10),;
		 	TOP_DESCRI C(45))
		INDEX ON TOP_CODICE TAG PARA_TOP_I ADDITIVE



		WAIT WINDOWS "........elaborazione MOVIMENTI CONTABILI in corso attendere prego" nowait

			
	   	IMPA      = 0
	   	IMPD      = 0
	   	IMP_BOF   = 0
	   	OK_CREA   = .T.
	   	TOT_DARE  =  0
	   	TOT_AVERE =  0
	   	PIU_RIP 	 = .T.
		
		
		cSql=""
		cNomeCursorSql="MOV_CONT"
					
		TEXT TO cSql NOSHOW
		
			SELECT
				*,
				(SELECT SUBSTRING(LIBERA,1,3) FROM para WHERE CODICE = 'IVA'+MOV_IVA) AS PERC_IVA,
				(SELECT SUBSTRING(LIBERA,12,1) FROM para WHERE CODICE = 'TOP'+MOV_TOP) AS TIPO,
				(SELECT SUBSTRING(LIBERA,10,1) FROM para WHERE CODICE = 'TOP'+MOV_TOP) AS RIBA
			FROM
				mov_cont
			WHERE
				mov_soc = '01'
				AND mov_dtreg >= '<<RIBALTA2(DATADA___)>>'
				AND mov_dtreg <= '<<RIBALTA2(DATAAL___)>>'
			ORDER BY MOV_ANNO,MOV_DTREG,MOV_NUMPRO,MOV_SEQUEN
			
		ENDTEXT

		IF !ExecPreparedCommand(cSql,cNomeCursorSql)
			return(.F.)
		ENDIF		
		
	    SELECT MOV_CONT
	    GO TOP		
		
			
	 	
	   DO WHILE .T.
		
		  IF EOF()
		     EXIT
		  ENDIF
		
		  IF DELETED()
		     SELECT MOV_CONT
		     SKIP +1
			 LOOP
		  ENDIF


		  IF MOV_TOP = "CHI"
			 SELECT MOV_CONT
			 SKIP +1
			 LOOP
		  ENDIF

		  IF MOV_TOP = "APE"
			 SELECT MOV_CONT
			 SKIP +1
			 LOOP
		  ENDIF



		  **=> SERGIO - INIZIO 18/12/2021
		  IF PUB_CONTOSIMILCEE

			  DO CASE
			  		CASE VERYCF_SIMILCEE(MOV_CONTO,"FO") = .T.
					   	  ____TIPOCO = "F"

			  		CASE VERYCF_SIMILCEE(MOV_CONTO,"CL") = .T.
					   	  ____TIPOCO = "C"
					OTHERWISE
						  SELECT MOV_CONT
					      SKIP +1
					      LOOP
			  ENDCASE

		  ELSE
		  
			  DO CASE
			  		CASE VERYCF(SUBSTR(MOV_CONTO,1,PUB_SOTTOG-1),"FO") = .T.
					   	  ____TIPOCO = "F"

			  		CASE VERYCF(SUBSTR(MOV_CONTO,1,PUB_SOTTOG-1),"CL") = .T.
					   	  ____TIPOCO = "C"
					OTHERWISE
						  SELECT MOV_CONT
					      SKIP +1
					      LOOP
			  ENDCASE

		  ENDIF
		  **=> SERGIO - FINE 18/12/2021

		
		
		  x_soci = "con_soc = '" + PUB_CODSOC + "'"
		  x_anno = "con_anno = '" + PUB_ANNO + "'"
		  x_cont = "con_conto = '" + ALLTRIM(MOV_CONTO) + "'"
		  x_cond = x_soci + " and " + x_anno + " and " + x_cont
		  Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
		  IF !ExecCommand(cSql,"cur_conti_")
		     return(.f.)
		  ENDIF
		  SELECT cur_conti_
