*******************************************************
 PROCEDURE ESTRAI_SCAD_CLI
*******************************************************
**
** PARAMETRI DA GESTIRE :
**
**     _TC  		=  TIPO CODICE DA ELABORARE
**						- C = CODICE CLIENTE
**						- A = CODICE AGENTE
**						- N = CODICE NAZIONE
**						- S = SALDI PER CLIENTE						-	NO FILTRO SU PERIODO DAL/AL
**						- R = CREAZIONE PARTITE APERTE PER AGENTI	-	NO FILTRO SU PERIODO DAL/AL
**     _NC  		=  NOME DEL CAMPO DA CONTROLLARE			
**     _DA  		=  CODICE DI INIZIO
**	   _AL          =  CODICE DI FINE
**	   _FI          =  FILTRO DI ELABORAZIONE
**						- 1 = TUTTI
**						- 2 = DAL/AL DIGITATI
**	   _CH         =  TIPI DI PARTITE  							
**                      - A =  PARTITE APERTE			
**                      - C =  PARTITE CHIUSE			
**
**	   _SC         =  S: CREA CURSORE PART_EUR PER CONTO,PARTITA,DATA SCADENZA (FUNZIONE NON ATTIVA)
**
**
*******************************************************

PARA _TC,_NC,_DA,_AL,_FI,_CH,_SC								&& PARTE NUOVA

_N_PAR  = PARAMETERS()											&& PARTE NUOVA
IF _N_PAR   = 5													&& PARTE NUOVA
   _CH = "A"													&& PARTE NUOVA
   _SC = " "													&& PARTE NUOVA
ENDIF															&& PARTE NUOVA	
IF _N_PAR   = 6													&& PARTE NUOVA
   _SC = " "													&& PARTE NUOVA
ENDIF															&& PARTE NUOVA	


WAIT WINDOW "Elaborazione In Corso  -- Prego Attendere --" nowait


__aperte__  ="PAR_FATT <> 0"	 && TUTTE LE PARTITE DEL CLIENTE	

__coddal__  = "par_codcli >= '" + _DA + "'"
__codal__   = "par_codcli <= '"  + _AL + "'"

IF _FI = 1
	__condi__  =  __aperte__
ELSE
	__condi__  = __coddal__ + " and " + __codal__ + " and " + __aperte__
ENDIF


cSql="SELECT "+" * FROM SALDI_CLI WHERE " + __condi__ +" order by PAR_CODCLI,PAR_DTSCAD"

IF !ExecCommand(cSql,"cur_saldi_cli")
   return(.f.)
ENDIF



RETURN

*******************************************************
 PROCEDURE EUR_PAPC
*******************************************************
**
** PARAMETRI DA GESTIRE :
**
**     _TC  		=  TIPO CODICE DA ELABORARE
**						- C = CODICE CLIENTE
**						- A = CODICE AGENTE
**						- N = CODICE NAZIONE
**						- S = SALDI PER CLIENTE						-	NO FILTRO SU PERIODO DAL/AL
**						- R = CREAZIONE PARTITE APERTE PER AGENTI	-	NO FILTRO SU PERIODO DAL/AL
**     _NC  		=  NOME DEL CAMPO DA CONTROLLARE			
**     _DA  		=  CODICE DI INIZIO
**	   _AL          =  CODICE DI FINE
**	   _FI          =  FILTRO DI ELABORAZIONE
**						- 1 = TUTTI
**						- 2 = DAL/AL DIGITATI
**	   _CH         =  PARTITE CHIUSE							&& PARTE NUOVA
**                      - C = ANCHE LE PARTITE CHIUSE			&& PARTE NUOVA
**
**	   _SC         =  S: CREA CURSORE PART_EUR PER CONTO,PARTITA,DATA SCADENZA (FUNZIONE NON ATTIVA)
**
**
*******************************************************

PARA _TC,_NC,_DA,_AL,_FI,_CH,_SC								&& PARTE NUOVA

_N_PAR  = PARAMETERS()											&& PARTE NUOVA
IF _N_PAR   = 5													&& PARTE NUOVA
   _CH = "A"													&& PARTE NUOVA
   _SC = " "													&& PARTE NUOVA
ENDIF															&& PARTE NUOVA	
IF _N_PAR   = 6													&& PARTE NUOVA
   _SC = " "													&& PARTE NUOVA
ENDIF															&& PARTE NUOVA	


WAIT WINDOW "Elaborazione In Corso  -- Prego Attendere --" nowait


=DEF_EURO()		&& DEFINISCE IL CURSORE PER LA GESTIONE DEI PARTITARI


CREATE CURSOR CU_PART_CF ;
		(CONTO C(13),NPART N(10,0),INDICE C(200), NUMPRO C(13),NREG C(08),DTREG C(10), TIPODOC C(10), NUMDOC C(10), CONTABILITA_PREVISIONALE C(1),;
		DTDOC C(10), DTSCAD C(10),VALUTA C(3),CAMBIO N(15,10),D_ITL N(20,3),A_ITL N(20,3),T_ITL N(20,3),D_EUR N(20,3), ;
		A_EUR N(20,3),T_EUR N(20,3),T_DIF N(20,3), CODAGE C(03), DESAGE C(40), CODNAZ C(03), DESNAZ C(40), RAGSOC C(40), NPROT C(10), TDOC C(10), ANOMAX C(3))
		INDEX ON ALLTRIM(CONTO) + STR(NPART,10,0)  							TAG PART_EUR
		INDEX ON ALLTRIM(RAGSOC) + STR(NPART,10,0)  						TAG PART_SOC
		INDEX ON ALLTRIM(CONTO) + DTSCAD									TAG PART_DTS
		INDEX ON ALLTRIM(CODAGE)+ ALLTRIM(CONTO) + DTSCAD  					TAG PART_AGE
		INDEX ON ALLTRIM(CONTO) + ALLTRIM(STR(NPART,10,0)) + DTSCAD 		TAG PART_ESC



**------
CREATE CURSOR NAZIONI (CODCLI C(10),CODNAZ C(3),DESNAZ C(40))
INDEX ON CODCLI TAG CODCLI
**------
CREATE CURSOR AGENTI (CODCLI C(15),CODAGE C(3),DESAGE C(40))
INDEX ON CODCLI TAG CODCLI
**------
PUBLIC V_GO,S_SEL,XXCODNAZ,XXDESNAZ,XXCODAGE,XXDESAGE,PRECLI

IF _TC = 'N'
   DO EUR_ELAN
   SELECT NAZIONI
   SET ORDER TO CODCLI
   GO TOP
   _DA = CODCLI
   GO BOTTOM
   _AL = CODCLI
ENDIF
IF _TC = 'A' .OR. _TC = 'R'
   DO EUR_ELAG
   SELECT AGENTI
   SET ORDER TO CODCLI
   GO TOP
   _DA = CODCLI
   GO BOTTOM
   _AL = CODCLI
ENDIF

PUBLIC PRECLI, JCONTO, PARTITA

v_seek	 = 'GEN'+PUB_CODSOC
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   PRECLI = SUBSTR(LIBERA,1,PUB_SOTTOG-1)
ELSE
   PRECLI = ""
ENDIF


IF _TC = 'C'

*!*	 ______CLIENTE DAL __________________________________________________________________
  XX_CODCLI = ALLTRIM(_DA)
  XX_CODCLI = TRC(PUB_LCL,ALLTRIM(XX_CODCLI))

  x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
  x_codi = "cli_codcli = '" + XX_CODCLI + "'"
  x_cond = x_soci + " and " + x_codi
  cSql = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
  IF !ExecCommand(cSql,"CUR_CLIENTI")
     RETURN .F.
  ENDIF
  SELECT CUR_CLIENTI
  GO TOP
  IF EOF()
     XXCODNAZ = SPACE(03)
  ELSE
     XXCODNAZ = CLI_NAZION
  ENDIF

  V_ER=SOTTOGEN(XXCODNAZ)
  IF !V_ER
	  PRECLI  = PUB_CC
  ENDIF

  DALCLI   = PRECLI+ALLTRIM(XX_CODCLI)



*!*	 ______CLIENTE AL ___________________________________________________________________
  XX_CODCLI = ALLTRIM(_AL)
  XX_CODCLI = TRC(PUB_LCL,ALLTRIM(XX_CODCLI))

  x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
  x_codi = "cli_codcli = '" + XX_CODCLI + "'"
  x_cond = x_soci + " and " + x_codi
  cSql = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
  IF !ExecCommand(cSql,"CUR_CLIENTI")
     RETURN .F.
  ENDIF
  SELECT CUR_CLIENTI
  GO TOP
  IF EOF()
     XXCODNAZ = SPACE(03)
  ELSE
     XXCODNAZ = CLI_NAZION
  ENDIF

  V_ER=SOTTOGEN(XXCODNAZ)
  IF !V_ER
	  PRECLI  = PUB_CC
  ENDIF

  ALCLI    = PRECLI+ALLTRIM(XX_CODCLI)


ENDIF



NUMMOV   = 0
NUMFAT   = 0
V_GO     = 0
XXCODNAZ = ""
XXDESNAZ = ""
XXCODAGE = ""
XXDESAGE = ""


x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
*x_clie = "par_codcli between '" + ALLTRIM(DALCLI) + "' and '" + ALLTRIM(ALCLI) + "'"
** END COUGAR
x_dt1  = RIBALTA2(_DATADAL)
x_dt2  = RIBALTA2(_DATAAL)
x_data = "par_dtreg between '" + x_dt1 + "' and '" + x_dt2 + "'"
x_prog = "par_nprog <> 100"
x_cond = x_soci + " and " + x_prog

IF _TC = 'C'
	x_clie = "par_codcli between '" + ALLTRIM(DALCLI) + "' and '" + ALLTRIM(ALCLI) + "'"
ENDIF
** END COUGAR

IF _FI = 1
ELSE
   x_cond = x_cond + " and " + x_clie
ENDIF

IF _TC = 'R' .OR. _TC = 'S'
ELSE
   x_cond = x_cond + " and " + x_data
endif
cSql="SELECT * FROM PART_CLI WHERE " + x_cond + " order by par_codsoc,par_codcli,par_npart"
IF !ExecCommand(cSql,"CUR_PART_CLIE")
   return(.f.)
ENDIF
SELECT CUR_PART_CLIE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP + 1
      LOOP
   ENDIF

*!*	IF ALLTRIM(PAR_CODCLI) = "01090057900"
*!*	BROWSE NORMAL
*!*	SET STEP ON
*!*	ENDIF

*!*		IF PAR_NPART = 500364
*!*		BROWSE NORMAL
*!*		SET STEP ON
*!*		ENDIF

   XXCODNAZ = ""
   XXDESNAZ = ""
   XXRAGSOC = PAR_RAGSOC
   XXDTSCAD = PAR_DTSCAD


   IF _TC = 'N'
      XX_CODCLI = PAR_CODCLI
      SELECT NAZIONI
      SET ORDER TO CODCLI
      SEEK SUBSTR(XX_CODCLI,5,LEN(XX_CODCLI))
      IF FOUND()
         XXCODNAZ = CODNAZ
         XXDESNAZ = DESNAZ
      ELSE
         SELECT CUR_PART_CLIE
         SKIP + 1
         LOOP
      ENDIF
      WAIT WINDOWS "Sto elaborando la nazione : "+XXCODNAZ+ " Cliente : "+XX_CODCLI  NOWAIT
      SELECT CUR_PART_CLIE
   ENDIF

   IF _TC = 'S'
      XX_CODCLI = PAR_CODCLI
      x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
      *x_codi = "cli_codcli = '" + SUBSTR(XX_CODCLI,PUB_SOTTOG,LEN(XX_CODCLI)) + "'"
      x_codi = "cli_codcli = '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(XX_CODCLI,RAT('.',XX_CODCLI,1)+1))), ALLTRIM(SUBSTR(XX_CODCLI,PUB_SOTTOG,LEN(XX_CODCLI)))) + "'"  && SERGIO - 18/12/2021
      
      x_cond = x_soci + " and " + x_codi
      cSql = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
      IF !ExecCommand(cSql,"CUR_CLIENTI")
         RETURN .F.
      ENDIF
      SELECT CUR_CLIENTI
      GO TOP
      IF EOF()
         XXCODNAZ = SPACE(03)
      ELSE
         XXCODNAZ = CLI_NAZION
      ENDIF

	  V_ER=SOTTOGEN(XXCODNAZ)
	  IF !V_ER
		  PRECLI  = PUB_CC
	  ENDIF


      WAIT WINDOWS "Sto elaborando il cliente : "+XX_CODCLI  NOWAIT
      SELECT CUR_PART_CLIE
   ENDIF

   
	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 

	   IF _FI <> 1
		   IF ALLTRIM(SUBSTR(ALLTRIM(&_NC),1,PUB_GRUPPOCF)) < ALLTRIM(PRECLI)
		      SKIP + 1
		      LOOP
		   ENDIF

		   IF SUBSTR(ALLTRIM(&_NC),1,PUB_GRUPPOCF) > PRECLI
		      EXIT
		   ENDIF
	   ENDIF

	ELSE

	   IF _FI <> 1
		   IF SUBSTR(ALLTRIM(&_NC),1,PUB_SOTTOG-1) < PRECLI
		      SKIP + 1
		      LOOP
		   ENDIF

		   IF SUBSTR(ALLTRIM(&_NC),1,PUB_SOTTOG-1) > PRECLI
		      EXIT
		   ENDIF
	   ENDIF

	ENDIF
	** SERGIO 18/12/2021 FINE  
  
  

   XXCODAGE = ""
   XXDESAGE = ""

   IF _TC = 'A' .OR. _TC = 'R'
      XX_CODCLI = PAR_CODCLI
      SELECT AGENTI
      SET ORDER TO CODCLI
      SEEK SUBSTR(XX_CODCLI,5,LEN(XX_CODCLI))
      IF FOUND()
         XXCODAGE = CODAGE
         XXDESAGE = DESAGE
      ELSE
         SELECT CUR_PART_CLIE
         SKIP + 1
         LOOP
      ENDIF
      WAIT WINDOWS "Sto elaborando l'agente : "+XXCODAGE+ " Cliente :"+XX_CODCLI  NOWAIT
      SELECT CUR_PART_CLIE
   ENDIF

   IF _TC = 'C'
      WAIT WINDOWS "Sto elaborando il cliente : "+PAR_CODCLI  NOWAIT
   ENDIF



   SCATTER MEMVAR MEMO


   S_SEL=SELECT()
   V_GO = RECNO()


   JCONTO   = PAR_CODCLI	 && CODICE DEL CLIENTE
   JPARTITA = PAR_NPART		 && PARTITA CLIETE
   JDTSCAD  = PAR_DTSCAD     && DATA SCADENZA TRANCHE FATTURA
   JCURSORE = "PARTICLI"	 && NOME DEL CURSORE DI LAVORO
   JRAGGR   = .T.         	 && .T. RAGGRUPPA RITORNA UN RECORD CON IL SALDO DI TUTTI I MOVIMENTI DARE-AVERE
   JDIFFAR  = .F.			 && .T. CREA UN RECORD PER CHIUDERE LA PARTITA NEL CASO DI DIFFERENZA DOVUTA ALL'EURO DI 0,02 CENTESIMI
   JTIPO    = 'C'			 && C= CLIENTE F= FORNITORE	
   JRAGSC   = _SC 			 && S= CREA PART_EUR PER DATA SCADENZA
   V_CHIUSO = EUR_PART(JTIPO,"PART_CLI",JCONTO,JPARTITA,JCURSORE,JRAGGR,JDIFFAR,JRAGSC)

   SELECT CUR_PART_CLIE
   SCATTER MEMVAR MEMO

   IF _CH = 'C'												&& PARTE NUOVA
   ELSE														&& PARTE NUOVA
      IF V_CHIUSO
         SKIP +1
         LOOP
      ENDIF
   ENDIF													&& PARTE NUOVA

   M.CONTO       = PAR_CODCLI
   M.RAGSOC      = PAR_RAGSOC
   M.DTREG       = RIBALTA2(PAR_DTREG)
   M.NREG        = PAR_NREG
   M.INDICE      = ALLTRIM(PAR_NUMFAT)
   M.DESMOV      = PAR_DESMOV
   M.DESMOV1     = PAR_DESMO1
   M.CAMBIO      = PAR_CAMBIO
   M.VALUTA      = PAR_VALUTA
   M.DTSCAD      = PAR_DTSCAD
   M.TDOC        = PAR_TIPFAT
   M.NPART       = PAR_NPART
   M.NPROT       = PAR_NPROT					&& .NPROT       = PAR_NUMFAT

   WTF 			 = PAR_TIPFAT
   _WT = 3 - LEN(ALLTRIM(WTF))

   IF EMPTY(M.DTREG)
      M.DTREG = REPLICATE(" " ,10)
   ENDIF

   M.NUMDOC = PAR_NUMFAT
   M.NUMPRO = PAR_NUMPRO
*!*	   SP       = LEN(ALLTRIM(M.NUMDOC))
*!*	   _SP      = (7 - SP)
*!*	   M.NUMDOC = REPLICATE(" " ,_SP)+ ALLTRIM(M.NUMDOC)
   M.NUMDOC = PADL(ALLTRIM(M.NUMDOC),10,SPACE(1))

   M.DTDOC  = RIBALTA2(PAR_DTFAT)
   IF EMPTY(M.DTDOC)
      M.DTDOC = REPLICATE(" " ,10)
   ENDIF
   WTF      = PAR_TIPFAT
   DAT      = RIBALTA2(PAR_DATPAG)
   NAT      = PAR_TMOV    && PRENDE LA NATURA DEL MOVIMENTO DAL DATABASE
   DA       = 0
   AV       = 0
   IF NAT   = "D"
      DA    = PAR_FATT
      DS    = RIBALTA2(PAR_DTSCAD)
   ELSE
      AV    = PAR_FATT
      DS    = RIBALTA2(PAR_DATPAG)
   ENDIF

   XXANOMAX	= PAR_ANOMAX

   SELECT CU_PART_CF
   SET ORDER TO PART_ESC
   __SEEK__SCAD =  ALLTRIM(JCONTO) + ALLTRIM(STR(JPARTITA,10,0)) + JDTSCAD
   SEEK __SEEK__SCAD
   IF FOUND()

      	IF CODAGE = SPACE(03)
         	REPLACE CODAGE WITH XXCODAGE
         	REPLACE DESAGE WITH XXDESAGE
      	ENDIF
      	IF CODNAZ = SPACE(03)
         	REPLACE CODNAZ WITH XXCODNAZ
         	REPLACE DESNAZ WITH XXDESNAZ
      	ENDIF
      	REPLACE RAGSOC WITH XXRAGSOC
      	REPLACE ANOMAX WITH XXANOMAX

   ELSE

	    APPEND BLANK
	    REPLACE CONTO   WITH M.CONTO
	    REPLACE RAGSOC  WITH M.RAGSOC
        REPLACE NPART   WITH M.NPART
	    REPLACE DTREG   WITH M.DTREG
	    REPLACE NREG    WITH M.NREG
	    REPLACE INDICE  WITH M.INDICE
	    REPLACE NUMDOC  WITH M.NUMDOC
	    REPLACE NUMPRO  WITH M.NUMPRO
	    REPLACE DTDOC   WITH M.DTDOC
	    REPLACE DTSCAD  WITH M.DTSCAD
	    REPLACE CAMBIO  WITH M.CAMBIO
	    REPLACE VALUTA  WITH M.VALUTA
	    REPLACE TIPODOC WITH REPLICATE(" " ,_WT) + ALLTRIM(WTF)
	    REPLACE NPROT   WITH M.NPROT
	    REPLACE TDOC    WITH M.TDOC


	    IF NAT = "D"
	 	  REPLACE T_ITL WITH TLIRE(M.VALUTA,DA,RIBALTA2(M.DTDOC))
	 	  REPLACE T_EUR WITH TEURO(M.VALUTA,DA,RIBALTA2(M.DTDOC))
	    ENDIF

	    IF NAT = "A"
	 	  REPLACE T_ITL WITH TLIRE(M.VALUTA,AV,RIBALTA2(M.DTDOC))
	 	  REPLACE T_EUR WITH TEURO(M.VALUTA,AV,RIBALTA2(M.DTDOC))
	    ENDIF

	
      	IF CODAGE = SPACE(03)
         	REPLACE CODAGE WITH XXCODAGE
         	REPLACE DESAGE WITH XXDESAGE
      	ENDIF
      	IF CODNAZ = SPACE(03)
         	REPLACE CODNAZ WITH XXCODNAZ
         	REPLACE DESNAZ WITH XXDESNAZ
      	ENDIF
      	REPLACE RAGSOC WITH XXRAGSOC
      	REPLACE ANOMAX WITH XXANOMAX
			
   		ENDIF

   SELECT CUR_PART_CLIE
   SKIP + 1

ENDDO


WAIT CLEAR

=DEF_EURO()		&& DEFINISCE IL CURSORE PER LA GESTIONE DEI PARTITARI


SELECT CU_PART_CF
GO TOP


DO WHILE .NOT.EOF()


    SELECT CU_PART_CF
    SCATTER MEMVAR MEMO

	SELECT PART_EUR
	APPEND BLANK
	GATHER MEMVAR MEMO


    SELECT CU_PART_CF
    SKIP +1

ENDDO


SELECT PART_EUR
GO TOP

RETURN


*******************************************************
 PROCEDURE EUR_PAPF
*******************************************************
**
** PARAMETRI DA GESTIRE :
**
**     _TC  		=  TIPO CODICE DA ELABORARE
**						- C = CODICE FORNITORE
**						- N = CODICE NAZIONE
**						- S = SALDI PER FORNITORE					-	NO FILTRO SU PERIODO DAL/AL
**						- R = CREAZIONE PARTITE APERTE 				-	NO FILTRO SU PERIODO DAL/AL
**     _NC  		=  NOME DEL CAMPO DA CONTROLLARE			
**     _DA  		=  CODICE DI INIZIO
**	   _AL          =  CODICE DI FINE
**	   _FI          =  FILTRO DI ELABORAZIONE
**						- 1 = TUTTI
**						- 2 = DAL/AL DIGITATI
**	   _CH         =  PARTITE CHIUSE							&& PARTE NUOVA
**                      - C = ANCHE LE PARTITE CHIUSE			&& PARTE NUOVA
**
*******************************************************

PARA _TC,_NC,_DA,_AL,_FI,_CH									&& PARTE NUOVA


_N_PAR  = PARAMETERS()											&& PARTE NUOVA
IF _N_PAR   = 5													&& PARTE NUOVA
   _CH = "A"													&& PARTE NUOVA
ENDIF															&& PARTE NUOVA	


WAIT WINDOW "Elaborazione In Corso  -- Prego Attendere --" nowait

=DEF_EURO()		&& DEFINISCE IL CURSORE PER LA GESTIONE DEI PARTITARI


