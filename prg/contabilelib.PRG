		  PRECLI  = PUB_FF
	  ENDIF

      WAIT WINDOWS "Sto elaborando il fornitore : "+XX_CODCLI  NOWAIT
      SELECT CUR_PART_FORN
   ENDIF



	** SERGIO 18/12/2021 INIZIO
