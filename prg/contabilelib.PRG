	**************************************************************************************************
	**************************************************************************************************	
	***
	***		ESTRAZIONE DATI DA DOCUMENTI FATTURE
	***
	**************************************************************************************************
	**************************************************************************************************	
		CREATE CURSOR TABLEAU_FAT (;
		 	NUMFAT C(6),  DATFAT C(10),;
		 	CODCLI C(13),;		 	
		 	TOPFAT C(10),;
		 	FATNOT C(1),;		 	
		 	CAMBIO N(15,10),;
		 	VALUTA C(3),;		 			 	
		 	IMPONIB N(17,3), IMPOSTA N(17,3), VALORE N(17,3))
		INDEX ON ALLTRIM(DATFAT)+ALLTRIM(NUMFAT) TAG ID_FAT ADDITIVE

		WAIT WINDOWS "........elaborazione DOCUMENTI in corso attendere prego" nowait

		cSql=""
		cNomeCursorSql="FATTURE"
					
		TEXT TO cSql NOSHOW
		
			SELECT
				TESTATA.ORD_NUMORD AS NUMORD,
				TESTATA.ORD_DATORD AS DATORD,
				TESTATA.ORD_CAUS AS TOPFAT,
				TESTATA.ORD_CODCLI AS CLIENTE,
				TESTATA.ORD_SPBOLL AS SPEBOLL,				
				TESTATA.ORD_SPTRAS AS SPETRAS,								
				TESTATA.ORD_CAMBIO AS ORDCAMBIO,								
				TESTATA.ORD_VALUTA AS ORDVALUTA,																
				DETTAGLIO.ORD_VALORE AS IMPONI,
				(SELECT SUBSTRING(LIBERA,1,3) FROM para WHERE CODICE = 'IVA'+DETTAGLIO.ORD_IVA) AS PERC_IVA
			FROM U_FAT_DD AS DETTAGLIO
				LEFT OUTER JOIN U_FAT_TT AS TESTATA
					ON TESTATA.TAGGANCIO = DETTAGLIO.DAGGANCIO
			WHERE
				DETTAGLIO.ORD_DESART <> '*** COMMENTO ***'
				AND TESTATA.ORD_DATORD >= '<<RIBALTA2(DATADA___)>>'
				AND TESTATA.ORD_DATORD <= '<<RIBALTA2(DATAAL___)>>'
			ORDER BY TESTATA.ORD_DATORD,TESTATA.ORD_NUMORD
			
		ENDTEXT


		IF !ExecPreparedCommand(cSql,cNomeCursorSql)
			return(.F.)
		ENDIF		
		
	    SELECT FATTURE
	    GO TOP
	 	
	    DO WHILE !EOF()
		
		  	IF DELETED()
		    	SELECT FATTURE
		    	SKIP +1
				LOOP
		  	ENDIF
		  	
		  	__DATORD  = FATTURE.DATORD
		  	__NUMORD  = FATTURE.NUMORD		  	
		  	__TOP	  = FATTURE.TOPFAT
		  	__CODCLI  = ALLTRIM(FATTURE.CLIENTE)
		  	__CAMBIO  = FATTURE.ORDCAMBIO
		  	__VALUTA  = FATTURE.ORDVALUTA
		  	
		  	__IMPONIB = FATTURE.IMPONI
		  	__PERCIVA = FATTURE.PERC_IVA
		  	__IMPOSTA = __IMPONIB / 100 * VAL(__PERCIVA)
			__VALORE  = __IMPONIB + __IMPOSTA

			__SPEBOLL = FATTURE.SPEBOLL
			__SPETRAS = FATTURE.SPETRAS			

			_SWS_ = SELECT()		  	
			
			x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
			x_codi = "cli_codcli = '" + __CODCLI + "'"
			x_cond = x_soci + " and " + x_codi
			cSql = "select CLI_ALRID from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
			IF !ExecCommand(cSql,"CUR_CLIENTE")
			   RETURN .F.
			ENDIF
			SELECT CUR_CLIENTE
			GO TOP
			IF EOF()
			   _ALRID    = "21"
			   _ESENZI=.F.				&& CLIENTE NON IN ESENZIONE
			ELSE
			   _ALRID    = CLI_ALRID
			   IF !EMPTY(CLI_ALRID)
			      _ESENZI = .T.			&& CLIENTE IN ESENZIONE
			   ELSE
			      _ALRID  = "21"
			      _ESENZI = .F.			&& CLIENTE NON IN ESENZIONE
			   ENDIF
			ENDIF		  	

			SELECT(_SWS_)	

			V_SPESE = __SPEBOLL + __SPETRAS
			IF !_ESENZI  && SOLO SE NON IN ESENZIONE
			   _IMPSPESE = V_SPESE
*!*				   _IVASPESE = V_SPESE / 100 * 20 			
			   _IVASPESE = V_SPESE / 100 * PUB_PERCENTUALE_IVA_DEFAULT
			   _VALSPESE = _IMPSPESE + _IVASPESE
			ELSE
			   _IMPSPESE = V_SPESE 				
			   _IVASPESE = 0 && ESENTE
			   _VALSPESE = _IMPSPESE + _IVASPESE		
			ENDIF



		    ** VERIFICA SE NOTA CREDITO
	        v_seek   = 'TOP'+ALLTRIM(__TOP)
	        v_chiave = "codice"
	        IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
	           SELECT CUR_PARA
		       NOTAC	 = SUBSTR(LIBERA,11,1)
		    ELSE
		       NOTAC	   = " "
		    ENDIF
		
		    IF NOTAC = 'S'
				__FATNOT = 'N'		
		    ELSE
				__FATNOT = 'F'
			ENDIF	
			
		  			  	

			__sk = ALLTRIM(__DATORD)+ALLTRIM(__NUMORD)
			SELECT TABLEAU_FAT
			SET ORDER TO ID_FAT 			
			GO top
			SEEK __sk
			IF FOUND()
				REPLACE  IMPONIB 		WITH IMPONIB + __IMPONIB
				REPLACE  IMPOSTA		WITH IMPOSTA + __IMPOSTA
				REPLACE  VALORE			WITH VALORE  + __VALORE				
			ELSE
				APPEND BLANK
				REPLACE  NUMFAT 		WITH __NUMORD
				REPLACE  DATFAT 		WITH __DATORD
				REPLACE  FATNOT 	    WITH __FATNOT
				REPLACE  CODCLI  		WITH __CODCLI  				 				
				REPLACE  TOPFAT 		WITH __TOP
				REPLACE  IMPONIB 		WITH __IMPONIB + _IMPSPESE
				REPLACE  IMPOSTA		WITH __IMPOSTA + _IVASPESE
				REPLACE  VALORE			WITH __VALORE + _VALSPESE
				REPLACE  CAMBIO 		WITH __CAMBIO
				REPLACE  VALUTA 		WITH __VALUTA 								
			ENDIF
			
	    	SELECT FATTURE
	    	SKIP +1

		ENDDO




	**************************************************************************************************
	**************************************************************************************************	
	***
	***		ESTRAZIONE DATI DA PORTAFOGLIO EFFETTI
	***
	**************************************************************************************************
	**************************************************************************************************	
		CREATE CURSOR TABLEAU_PEF (;
		 	CODCLI C(13), NUMRIC C(6), NUMFAT C(6),;
		 	DATFAT C(10), DATSCA C(10),;
		 	VALUTA C(3), CAMBIO N(15,10),;		 	
		 	IMPONIB N(17,3), IMPOSTA N(17,3), VALORE N(17,3),;
		 	INCGE L )
		INDEX ON ALLTRIM(DATFAT)+ALLTRIM(NUMFAT) TAG ID_PEF ADDITIVE

		WAIT WINDOWS "........elaborazione PORTAFOGLIO EFFETTI in corso attendere prego" nowait


		cSql=""
		cNomeCursorSql="PEF"
					
		TEXT TO cSql NOSHOW
		
			SELECT
				RIC_CODCLI,
				RIC_PROGR,
				RIC_NFATT,
				RIC_DTFATT,
				RIC_DTSCAD,
				RIC_TOTFAT,
				RIC_TRANC,
				RIC_VALUTA,
				RIC_CAMBIO,								
				RIC_CGE
			FROM U_RIC_TT
			WHERE RIC_DTFATT >= '<<RIBALTA2(DATADA___)>>'
				AND RIC_DTFATT <= '<<RIBALTA2(DATAAL___)>>'
			ORDER BY RIC_DTFATT,RIC_NFATT
			
		ENDTEXT

		IF !ExecPreparedCommand(cSql,cNomeCursorSql)
			return(.F.)
		ENDIF		
		
	    SELECT PEF
	    GO TOP

	    DO WHILE !EOF()
		
		  	IF DELETED()
		    	SELECT PEF
		    	SKIP +1
				LOOP
		  	ENDIF
		  	
		  	__CODCLI  = RIC_CODCLI
		  	__NUMRIC  = RIC_PROGR		  	
		  	__DATFAT  = RIC_DTFATT
		  	__NUMFAT  = RIC_NFATT
		  	__DATSCA  = RIC_DTSCAD	
		  	__INCGE   = RIC_CGE			  	
		  	__VALORE  = RIC_TRANC
		  	__VALUTA  = RIC_VALUTA
		  	__CAMBIO  = RIC_CAMBIO		  			  	

			__IMPONIB   = 0
			__IMPOSTA   = 0
		  	__VALORE_FT = 0
		  	
*!*			  	
*!*				__sk = ALLTRIM(__DATFAT)+ALLTRIM(__NUMFAT)
*!*				
*!*				
*!*				*** RECUPERO IMPONIBILE E IMPOSTA DALLA FATTURA
*!*				SELECT TABLEAU_FAT
*!*				SET ORDER TO ID_FAT 			
*!*				GO top
*!*				SEEK __sk
*!*				IF FOUND()
*!*					__IMPONIB    = TABLEAU_FAT.IMPONIB
*!*					__IMPOSTA    = TABLEAU_FAT.IMPOSTA
*!*					__VALORE_FT  = TABLEAU_FAT.VALORE  				
*!*				ENDIF
*!*		
		
			SELECT TABLEAU_PEF	
			SET ORDER TO ID_PEF 		
			GO top
			SEEK __sk
			IF FOUND()
			  *** LA FATTURA HA PIU' TRANCHE
				SELECT PEF
		    	SKIP +1
				LOOP
			ELSE
				APPEND BLANK
				REPLACE  CODCLI 		WITH __CODCLI
				REPLACE  NUMRIC 		WITH __NUMRIC
				REPLACE  NUMFAT 		WITH __NUMFAT  				
				REPLACE  DATFAT 		WITH __DATFAT
				REPLACE  DATSCA 		WITH __DATSCA
				REPLACE  IMPONIB 		WITH __IMPONIB
				REPLACE  IMPOSTA		WITH __IMPOSTA
				REPLACE  VALORE			WITH __VALORE
				REPLACE  VALUTA  		WITH __VALUTA
				REPLACE  CAMBIO  		WITH __CAMBIO  				
				REPLACE  INCGE 			WITH __INCGE   								
			ENDIF
			
	    	SELECT PEF
	    	SKIP +1

		ENDDO






	**************************************************************************************************
	**************************************************************************************************	
	***
	***		ESTRAZIONE MOVIMENTI DI LIQUIDITA
	***
	**************************************************************************************************
	**************************************************************************************************	


		CREATE CURSOR TABLEAU_LIQ (;
		 	CLFO C(1), PERIODO C(06), ;
		 	CODCLFO C(15), DESCLFO C(50), ;
		 	CPA C(10), TOP C(10),;
		 	PERCIVA C(3),;
		 	DATREG C(10),NUMREGIS C(10),;
		 	CON_DAC N(17,3),CON_AVC N(17,3), ;
		 	CON_DAF N(17,3),CON_AVF N(17,3), ;
		 	CON_SALDO N(17,3),;
			PRC N(6,2), PRCSEL N(6,2), PRCCPA N(6,2),;
			DB_NOTAC C(1),;
			DB_FATTURA C(1),;
			DB_CLFO C(1),;
			DB_RIBA C(1))
		INDEX ON ALLTRIM(CODCLFO)+ALLTRIM(DATREG)+ALLTRIM(NUMREGIS)	TAG ID_LIQ ADDITIVE
		INDEX ON ALLTRIM(DATREG)+ALLTRIM(NUMREGIS)+ALLTRIM(CODCLFO)	TAG LIQ ADDITIVE		


		WAIT WINDOWS "........elaborazione MOVIMENTI DI LIQUIDITA in corso attendere prego" nowait


		*** CREAZIONE DEL CURSORE PER IL CALCOLO DELLA LIQUIDITA'
		*** VENGONO PRESE IN COSIDERAZIONE DATE DIVERSE
		cSql=""
		cNomeCursorSql="LIQUIDA"
					
		TEXT TO cSql NOSHOW
		
			SELECT
				*,
				(SELECT SUBSTRING(LIBERA,1,3) FROM para WHERE CODICE = 'IVA'+MOV_IVA) AS PERC_IVA,
				(SELECT SUBSTRING(LIBERA,12,1) FROM para WHERE CODICE = 'TOP'+MOV_TOP) AS TIPO,
				(SELECT SUBSTRING(LIBERA,10,1) FROM para WHERE CODICE = 'TOP'+MOV_TOP) AS RIBA
			FROM
				mov_cont
			WHERE
				mov_soc = '01'
				AND mov_dtreg >= '<<RIBALTA2(DATADALIQ___)>>'
				AND mov_dtreg <= '<<RIBALTA2(DATAALLIQ___)>>'
				AND (SELECT SUBSTRING(LIBERA,2,1) FROM para WHERE CODICE = 'TOP'+MOV_TOP) = 'P'
			ORDER BY MOV_ANNO,MOV_DTREG,MOV_NUMPRO,MOV_SEQUEN
			
		ENDTEXT

		IF !ExecPreparedCommand(cSql,cNomeCursorSql)
			return(.F.)
		ENDIF


		SELECT LIQUIDA
		GO TOP
		DO WHILE .T.
		
		  IF EOF()
		     EXIT
		  ENDIF
		
		  IF DELETED()
		     SELECT LIQUIDA
		     SKIP +1
			 LOOP
		  ENDIF

		   ** SERGIO 18/12/2021 INIZIO
		   IF PUB_CONTOSIMILCEE 
			   
		      IF LEN(ALLTRIM(MOV_CONTO))  <  PUB_GRUPPOCF
			     SELECT LIQUIDA
			     SKIP +1
				 LOOP
