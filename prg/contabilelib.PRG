	TOT_AVERE	= TOT_AVERE + IMPA

	MESE = SUBSTR(REG,4,2)


	*!*	SERGIO 2017/06/01 GESTIONE AUTOMATIZZATA DEI CORRISPETTIVI : GENERO AUTOMATICAMENTE IL CORRISPETTIVO DAL PAGAMENTO DEL CORRISPETTIVO
	*!*	PER EVITARE DI FARE UNA DOPPIA REGISTRAZIONE E PER AVERE LA COLONNA DELLE VENDITE COMPRENSIVA DEL CORRISPETTIVO
	IF FATTURA = "C"		&& E' UN CORRISPETTIVO , VERIFICO SE SUL CLIENTE  		

		IF ____TIPOCO ='C'
		
			_DARE	= "CON_DA"+MESE+"C"

			SELECT MOV_RIE
			SET ORDER TO MOV_RIE
			_RK = SUBSTR(RIBALTA2(REG),1,4)
			SEEK _RK
			IF FOUND()
				REPLACE	&_DARE	WITH &_DARE	+ IMPA
			ELSE
				APPEND BLANK
				REPLACE	PERIODO	WITH _RK
				REPLACE	&_DARE	WITH IMPA
			ENDIF

		ENDIF

	ENDIF
	*!*	SERGIO 2017/06/01 GESTIONE AUTOMATIZZATA DEI CORRISPETTIVI : GENERO AUTOMATICAMENTE IL CORRISPETTIVO DAL PAGAMENTO DEL CORRISPETTIVO
	*!*	PER EVITARE DI FARE UNA DOPPIA REGISTRAZIONE E PER AVERE LA COLONNA DELLE VENDITE COMPRENSIVA DEL CORRISPETTIVO



	IF ____TIPOCO ='C'
		_DARE	= "CON_DA"+MESE+"C"
		_AVERE	= "CON_AV"+MESE+"C"	
	ELSE	
		_DARE	= "CON_DA"+MESE+"F"
		_AVERE	= "CON_AV"+MESE+"F"	
	ENDIF

	SELECT MOV_RIE
	SET ORDER TO MOV_RIE
	_RK = SUBSTR(RIBALTA2(REG),1,4)
	SEEK _RK
	IF FOUND()
		REPLACE	&_DARE	WITH &_DARE	+ IMPD
		REPLACE	&_AVERE	WITH &_AVERE + IMPA
	ELSE
		APPEND BLANK
		REPLACE	PERIODO	WITH _RK
		REPLACE	&_DARE	WITH IMPD
		REPLACE	&_AVERE	WITH IMPA
	ENDIF



	*!* CREA CURSORE PER IL RICALCOLO DELL'IVA
	IF FATTURA = "S" OR FATTURA = "C"	&& FATTURE E/O CORRISPETTIVI CLIENTI
		SELECT MOV_CONT
		__MOV_NUMPRO = MOV_NUMPRO
		__MOV_CLIFOR = ____TIPOCO
		IF FATTURA = "S" OR FATTURA = "C"	&& FATTURE E/O CORRISPETTIVI CLIENTI
			IF NOTAC = "S"
				__MOV_FATNCR = "N"
			ELSE
				__MOV_FATNCR = "F"
			ENDIF
		ENDIF
		__MOV_IMP	= MOV_IMP
	
		SELECT MOV_ERARIO
		APPEND BLANK
		REPLACE PERIODO 	WITH SUBSTR(RIBALTA2(REG),1,4)+SUBSTR(RIBALTA2(REG),6,2)
		REPLACE MOV_NUMPRO 	WITH __MOV_NUMPRO
		REPLACE MOV_CLIFOR 	WITH __MOV_CLIFOR
		REPLACE MOV_FATNCR 	WITH __MOV_FATNCR
		REPLACE MOV_IMP 	WITH __MOV_IMP
	ENDIF

	SELECT MOV_CONT
	SKIP +1
ENDDO

WAIT WINDOWS "Finalizzazione elaborazione movimenti..." NOWAIT


SELECT MOV_ERARIO
GO TOP
DO WHILE .T.
	
  IF EOF()
    EXIT
  ENDIF

  _TIMPOSTA=CERCA_MOVIMENTI_IVA(SUBSTR(PERIODO,1,4),MOV_NUMPRO)


  SELECT MOV_ERARIO


  IF MOV_FATNCR  = "N" AND MOV_CLIFOR = "C"			&& VERIFICA SE NOTA CREDITO CLIENTE	, IN QUESTO CASO E' L'ERARIO CHE DEVE RESTITUIRMI L'IMPORTO , COME SE FOSSE UNA FATTURA A FORNITORE
	_TIMPOSTA=_TIMPOSTA * -1
  ENDIF

  IF MOV_CLIFOR = "F"								&& VERIFICA SE IVA FORNITORE
  	IF MOV_FATNCR <> "N"							&& SE NOTA CREDITO LA DEVO PAGARE ALL'ERARIO PE CUI NON DEVE ESSERE NEGATIVA
	  _TIMPOSTA=_TIMPOSTA * -1
	ENDIF
  ENDIF



  _PERIODO=SUBSTR(PERIODO,1,4)
  _MESE   =SUBSTR(PERIODO,5,2)
  _ERARIO ="CON_ERARIO"+_MESE

  SELECT MOV_RIE
  SET ORDER TO MOV_RIE

  SEEK _PERIODO
  IF FOUND()
      REPLACE   &_ERARIO WITH &_ERARIO + _TIMPOSTA
  ELSE
	 APPEND  BLANK
  	 REPLACE   PERIODO  WITH _PERIODO	
     REPLACE   &_ERARIO WITH _TIMPOSTA
  ENDIF


  SELECT MOV_ERARIO
  REPLACE MOV_IMPOST WITH _TIMPOSTA

  SKIP +1

ENDDO WHILE .T.

SELECT MOV_ERARIO
GO TOP

SELECT MOV_RIE
GO TOP

WAIT CLEAR

RETURN


