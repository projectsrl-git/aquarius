	   x_cond = x_soci + " and " + x_anno + " and " + x_cont
	   Csql   = "select con_conto, con_tipoco from conti where " + x_cond
	   IF !ExecCommand(cSql,"TMP_CONTI")
	      return(.f.)
	   ENDIF
	   SELECT TMP_CONTI
	   GO TOP
	   IF !EOF()
