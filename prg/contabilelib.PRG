*!*		      IF CEE = "R"
*!*		         v_tipreg = '4'     && REGISTRO IVA CESSIONI COMPENSATIVE
*!*			  ENDIF
*!*	      ENDIF


   ENDIF

   *** SIMONE 07/03/2011 - INIZIO
   SELECT CU_AZI_PA
   IF AZI_NRSENO				&& gestione della numerazione separata protocollo PER NOTE OCCASIONALI
      v_seek	= 'TOP'+ALLTRIM(M.TOP)
      v_chiave = "codice"
      IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
         SELECT CUR_PARA
         NOC   = SUBSTR(LIBERA,23,1)
      ELSE
         NOC   = SPACE(1)
      ENDIF
      IF NOC = "N"
         v_tipreg = '3'         && registro bollati fornitori NOTE OCCASIONALI
      ENDIF
   ENDIF
   *** SIMONE 07/03/2011 - FINE

   **=> ERASMO - INIZIO 18/12/2017
   IF PUB_NRSERC				&& Numerazione protocollo separata tra bollato iva fornitori nazionali e Reverse Charge
      v_seek	= 'TOP'+ALLTRIM(M.TOP)
      v_chiave = "codice"
      IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
         SELECT CUR_PARA
         _REVERSE = SUBSTR(LIBERA,23,1)
      ELSE
         _REVERSE = ""
      ENDIF
      IF _REVERSE = "R"
         v_tipreg = '4'         && registro reverse charge
      ENDIF
   ENDIF

   IF PUB_NRSEAU				&& Numerazione protocollo separata tra bollato iva fornitori nazionali e Autofatture
      v_seek	= 'TOP'+ALLTRIM(M.TOP)
      v_chiave = "codice"
      IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
         SELECT CUR_PARA
         _AUTOFATTURA = SUBSTR(LIBERA,23,1)
      ELSE
         _AUTOFATTURA = ""
      ENDIF
      IF _AUTOFATTURA = "A"
         v_tipreg = '5'         && registro autofatture
      ENDIF
   ENDIF
   **=> ERASMO - FINE 18/12/2017

ENDIF

v_chiave  = "codice"
v_seek    = 'NUMPRO'+PUB_ANNO+PUB_CODSOC+ALLTRIM(V_TIPREG)
cSql      = "select * from para where " + v_chiave + " = '" + v_seek + "'"
IF !ExecRW(cSql,"PARA","R")
   return(.f.)
ENDIF
SELECT PARA
IF RECCOUNT() = 0
   SAVE_NP    = NPROT
   V_LIB      = 1
   CS_LIB     = STR(V_LIB)
   NPROT      = CS_LIB
   X_NPROT    = NPROT
   APPEND BLANK
   REPLACE CODICE WITH V_SEEK
   IF EMPTY(ALLTRIM(V_TIPREG))
      REPLACE DESCRI WITH "N.PROTOCOLLO FORNITORE UNICO"
   ELSE
      IF V_TIPREG = '1'
         REPLACE DESCRI WITH "N.PROTOCOLLO FORNITORE NAZIONALE"
      ENDIF
      IF V_TIPREG = '2'
         REPLACE DESCRI WITH "N.PROTOCOLLO FORNITORE ABITUALE CEE"
      ENDIF
      *** SIMONE 07/03/2011 - INIZIO
      IF V_TIPREG = '3'
         REPLACE DESCRI WITH "N.PROTOCOLLO FORNITORE NOTE OCCASIONALI"
      ENDIF
      *** SIMONE 07/03/2011 - INIZIO
*!*	      IF V_TIPREG = '4'
*!*	         REPLACE DESCRI WITH "N.REGISTRO IVA CESSIONI COMPENSATIVE"
*!*	      ENDIF
      **=> ERASMO - INIZIO 18/12/2017
      IF V_TIPREG = '4'
         REPLACE DESCRI WITH "N.PROTOCOLLO FORNITORE REVERSE CHARGE"
      ENDIF
      IF V_TIPREG = '5'
         REPLACE DESCRI WITH "N.PROTOCOLLO FORNITORE AUTOFATTURE"
      ENDIF
      **=> ERASMO - FINE 18/12/2017
   ENDIF
   REPLACE LIBERA WITH ALLTRIM(CS_LIB)
ELSE
   C_LIB   = SUBSTR(LIBERA,1,10)
   V_LIB   = VAL(C_LIB)
   V_LIB   = V_LIB+1
   CS_LIB  = STR(V_LIB)
   SAVE_NP = NPROT
   NPROT   = CS_LIB
   X_NPROT = NPROT
   REPLACE LIBERA  WITH ALLTRIM(CS_LIB)
ENDIF
IF !ExecRW(cSql,"PARA","W")
   return(.f.)
ENDIF

RETURN

