	_R_CODICERAP = CODICERAP
	_R_SUBCODICERAP = SUBCODICERAP
	_R_ALIQUOTARAP = ALIQUOTARAP
	_R_PERCIMPONIBILERAP = PERCIMPONIBILERAP
	_R_FLAGINPS = FLAGINPS
	_R_ALIQUOTAINPS = ALIQUOTAINPS
	_R_PERCIMPONIBILEINPS = PERCIMPONIBILEINPS
	_R_QUOTACOMMITTENTE = QUOTACOMMITTENTE
ENDIF

IF _R_FATTURA_NC = 'S' AND (_R_FLAGRAP OR _R_FLAGINPS)
ELSE
	x_iddc = "IDDocumento = '" + ALLTRIM(_R_MOV_SYSDOC) + "'"
	x_cond = x_iddc
	Csql   = "DELETE from AQ_RAP where " + x_cond
	IF !ExecCommand(cSql,"DEL_AQ_RAP")
	   return(.f.)
	ENDIF
	SELECT(_ACT_SEL)
 	RETURN .F.
ENDIF


