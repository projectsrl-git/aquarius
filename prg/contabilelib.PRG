											  "par_fatt  = " + STRTRAN(ALLTRIM( STR(ABS(ZSALPAR),17,2) ),",",".") + " ," +;
											  "par_impo1 = " + STRTRAN(ALLTRIM( STR(ABS(ZSALPAR),17,2) ),",",".") + ;		
				+ " where id_unique = '"+_UNIQUE+"'"
	
	
		IF !ExecCommand(__x_cSql,"upd_IMPORTO")
		   return(.f.)
		ENDIF
	
	ENDIF

	IF ZPARTITA  <> PAR_NPART
		__x_cSql = "update "+ _ARCH_IN + " set par_npart = " + STR(ZPARTITA) + " where id_unique = '"+_UNIQUE+"'"
		IF !ExecCommand(__x_cSql,"upd_partita")
