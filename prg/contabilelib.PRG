******************************************************************
PROCEDURE UN_MOVIMENTO_CONTABILE_UN_MOVIMENTO_DI_CENTRO_DI_COSTO
******************************************************************


M.DARIP = 0	&& SE NON DIGITATO NE DARE NE AVERE

IF M.DARE <> 0
   M.DARIP = M.DARE
ENDIF
IF M.AVERE <> 0
   M.DARIP = M.AVERE
ENDIF


M.RIPA     = 0
M.SALDO    = 0

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(M.CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP
IF EOF()
ELSE
   STORE CON_DESCR   TO M.DESCONTO
ENDIF

*!*	IF M.PERC1 <> 0
*!*		M.SALDO01 = ((M.DARIP * M.PERC1)/100)
*!*	ENDIF

M.SALDO01 = ((M.DARIP * 100)/100)		&& UN MOVIMENTO CONTABILE UN CENTRO DI COSTO AL 100%

IF M.PERC2 <> 0
	M.SALDO02 = ((M.DARIP * M.PERC2)/100)
ENDIF
IF M.PERC3 <> 0
	M.SALDO03 = ((M.DARIP * M.PERC3)/100)
ENDIF
IF M.PERC4 <> 0
	M.SALDO04 = ((M.DARIP * M.PERC4)/100)
ENDIF
IF M.PERC5 <> 0
	M.SALDO05 = ((M.DARIP * M.PERC5)/100)
ENDIF
IF M.PERC6 <> 0
	M.SALDO06 = ((M.DARIP * M.PERC6)/100)
ENDIF
IF M.PERC7 <> 0
	M.SALDO07 = ((M.DARIP * M.PERC7)/100)
ENDIF
IF M.PERC8 <> 0
	M.SALDO08 = ((M.DARIP * M.PERC8)/100)
ENDIF
IF M.PERC9 <> 0
	M.SALDO09 = ((M.DARIP * M.PERC9)/100)
ENDIF
IF M.PERC10 <> 0
	M.SALDO010 = ((M.DARIP * M.PERC10)/100)
ENDIF


** RICALCOLA IL TOTALE RIPARTITO/D RIPARTIRE PER EVENTUALI ULTERIORI CONTROLLI DI QUADRATURA E PER VALORIZZARE QUESTE VARIABILI USATE AL MOMENTO DELLA REGIATRAZIONE : SERGIO
M.RIPA = 0
M.RIPA = M.RIPA + M.SALDO01
M.RIPA = M.RIPA + M.SALDO02
M.RIPA = M.RIPA + M.SALDO03
M.RIPA = M.RIPA + M.SALDO04
M.RIPA = M.RIPA + M.SALDO05
M.RIPA = M.RIPA + M.SALDO06
M.RIPA = M.RIPA + M.SALDO07
M.RIPA = M.RIPA + M.SALDO08
M.RIPA = M.RIPA + M.SALDO09
M.RIPA = M.RIPA + M.SALDO10

M.SALDO = M.DARIP - M.RIPA




RETURN



