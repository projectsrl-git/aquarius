** 20/07/2022 SERGIO INIZIO: GESTIONE PLAFOND IVA DA RITENUTE ACCONTO
*************************************************************************
*  			 AGGIORNA DATI PLAFOND - RICALCOLA PLAFOND RESIDUO          *
*************************************************************************
PROCEDURE REG_PLAFOND_RITENUTE_ACCONTO

IF !PUB_PLAFACQ 		&& AGGIORNA SOLO ESCLUSIVAMENTE SE E' GESTITO IL PLAFOND IVA NEI PARAMETRI AZIENDALI
	RETURN
ENDIF


IF FATTURA <> "S"  		&& TRATTA SOLO LE FATTURE DI ACQUISTO
	RETURN
ENDIF

IF VER_CONTO <> "F"   	&& TRATTA SOLO I FORNITORI
	RETURN
ENDIF


AXABBSZPLAF = SELECT()

_ANNO_PLAFOND = PUB_ANNO
IF PUB_PLADFA
	SELECT CORPO_MOV_SAVE
	SET ORDER TO I_SEQUEN
	GO TOP
	IF !EOF()
		_ANNO_PLAFOND = SUBSTR(DTDOCUM,7,4)	&& DATA DOCUMENTO DELLA PRIMA NOTA ORIGINALE
	ENDIF
ENDIF

x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
*x_anno = "iva_anno = " + _ANNO_PLAFOND
x_anno = "iva_anno = '" + _ANNO_PLAFOND + "'"  && ERASMO - 19/01/2024
x_cond = x_soci + " and " + x_anno
CSQL   = "select * from U_IVA_ES where " + x_cond + " order by iva_codsoc,iva_anno"
IF !ExecRW(cSql,"U_IVA_ES","R")
  return(.f.)
ENDIF

SELECT U_IVA_ES
IF EOF()
 	
 	_cMsg = "ATTENZIONE" + CHR(13) + CHR(13) + "Aggiornare il plafond iva per gli AQUISTI in esenzione iva" + CHR(13) + "utilizzare la procedura nella gestione dei bollati iva" + CHR(13) + "Fare click su OK per continuare"
	DO MESSAGGIO_STILE_WIN8 WITH _cMsg

	APPEND BLANK
	REPLACE IVA_CODSOC 	WITH PUB_CODSOC
	REPLACE IVA_ANNO   	WITH VAL(PUB_ANNO)
	REPLACE IVA_PLAFOND	WITH 500000			&& PLAFOND INDICATIVO DI PARTENZA

ENDIF
SCATTER MEMVAR MEMO



* ####################################### SOMMA IL NUOVO IMPONIBLE ESENTE DELLA PRIMA NOTA ULTIMA AGGIORNATA #######################################
*                                             SOLO SE NON STO ANNULLANDO LA PRIMA NOTA
SELECT CORPO_MOV_SAVE
SET ORDER TO I_SEQUEN
GO TOP
_MESE_PLAFOND = SUBSTR(DTREGIS,4,2)		&& DATA REGISTRAZIONE DELLA PRIMA NOTA ORIGINALE
IF PUB_PLADFA
	_MESE_PLAFOND = SUBSTR(DTDOCUM,4,2)	&& DATA DOCUMENTO DELLA PRIMA NOTA ULTIMA AGGIORNATA
ENDIF


IF !PUB_ANNPN
	SELECT CORPO_MOV_SAVE
	SET ORDER TO I_SEQUEN
	GO TOP

	DO WHILE !EOF()

	   	IF DELETED()
			SELECT CORPO_MOV_SAVE
	    	SKIP +1
	    	LOOP
	   	ENDIF

		IF ALLTRIM(IVA) = "NO"			&& SCARTA I MOVIMENTI FORNITORI
			SELECT CORPO_MOV_SAVE
	    	SKIP +1
	    	LOOP
	   	ENDIF
	   	
	   	
	   	IF !CERCA_IVA_PLAFOND(IVA)		&& SCARTA I MOVIMENTI IVA CHE NON ENTRANO NEL CALCOLO DEL PLAFOND RESIDUO
			SELECT CORPO_MOV_SAVE
	    	SKIP +1
	    	LOOP
	   	ENDIF
		
		SELECT CORPO_MOV_SAVE
		__IMPORTO_ESENTE = DARE+AVERE

		*** SE NOTA CREDITO CAMBIO SEGNO
		SELECT CORPO_MOV_SAVE
		__TOP = TOP
		__NOTAC = ""
		v_seek   = 'TOP'+ALLTRIM(__TOP)
		v_chiave = "codice"
		IF seek_std('para',v_seek,v_chiave,'TMP_PARA')
			SELECT TMP_PARA
			__NOTAC = SUBSTR(LIBERA,11,1)
		ENDIF
		IF __NOTAC = 'S'
			__IMPORTO_ESENTE = -1 * __IMPORTO_ESENTE
		ENDIF

		SELECT U_IVA_ES
		DO CASE
			CASE _MESE_PLAFOND = "01"
				REPLACE IVA_GENNAI 	WITH IVA_GENNAI + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "02"
				REPLACE IVA_FEBBRA 	WITH IVA_FEBBRA + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "03"
				REPLACE IVA_MARZO  	WITH IVA_MARZO  + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "04"
				REPLACE IVA_APRILE 	WITH IVA_APRILE + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "05"
				REPLACE IVA_MAGGIO 	WITH IVA_MAGGIO + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "06"
				REPLACE IVA_GIUGNO 	WITH IVA_GIUGNO + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "07"
				REPLACE IVA_LUGLIO 	WITH IVA_LUGLIO + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "08"
				REPLACE IVA_AGOSTO 	WITH IVA_AGOSTO + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "09"
				REPLACE IVA_SETTEM 	WITH IVA_SETTEM + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "10"
				REPLACE IVA_OTTOBR 	WITH IVA_OTTOBR + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "11"
				REPLACE IVA_NOVEMB 	WITH IVA_NOVEMB + __IMPORTO_ESENTE
			CASE _MESE_PLAFOND = "12"
				REPLACE IVA_DICEMB 	WITH IVA_DICEMB + __IMPORTO_ESENTE
		ENDCASE
		
	   		
		SELECT CORPO_MOV_SAVE
		SKIP +1
		
	ENDDO

ENDIF


* ####################################### CALCOLO DEL PLAFOND DISPONIBILE #######################################


SELECT U_IVA_ES
DO CASE
	CASE _MESE_PLAFOND = "01"
		REPLACE IVA_01RESI	WITH IVA_PLAFOND - IVA_GENNAI
	CASE _MESE_PLAFOND = "02"
		REPLACE IVA_02RESI	WITH IVA_01RESI  - IVA_FEBBRA
	CASE _MESE_PLAFOND = "03"
		REPLACE IVA_03RESI	WITH IVA_02RESI  - IVA_MARZO
	CASE _MESE_PLAFOND = "04"
		REPLACE IVA_04RESI	WITH IVA_03RESI  - IVA_APRILE
	CASE _MESE_PLAFOND = "05"
		REPLACE IVA_05RESI	WITH IVA_04RESI  - IVA_MAGGIO
	CASE _MESE_PLAFOND = "06"
		REPLACE IVA_06RESI	WITH IVA_05RESI  - IVA_GIUGNO
	CASE _MESE_PLAFOND = "07"
		REPLACE IVA_07RESI	WITH IVA_06RESI  - IVA_LUGLIO
	CASE _MESE_PLAFOND = "08"
		REPLACE IVA_08RESI	WITH IVA_07RESI  - IVA_AGOSTO
	CASE _MESE_PLAFOND = "09"
		REPLACE IVA_09RESI	WITH IVA_08RESI  - IVA_SETTEM
	CASE _MESE_PLAFOND = "10"
		REPLACE IVA_10RESI	WITH IVA_09RESI  - IVA_OTTOBR
	CASE _MESE_PLAFOND = "11"
		REPLACE IVA_11RESI	WITH IVA_10RESI  - IVA_NOVEMB
	CASE _MESE_PLAFOND = "12"
		REPLACE IVA_12RESI	WITH IVA_11RESI  - IVA_DICEMB
ENDCASE



* ####################################### AGGIORNA I DATI RELATIVI AL PLAFOND IVA #######################################

IF !ExecRW(cSql,"U_IVA_ES","W")		
	RETURN .F.
ENDIF

SELECT(AXABBSZPLAF)
RETURN
