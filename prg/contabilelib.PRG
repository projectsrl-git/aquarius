*****************************************************
FUNCTION determina_iban_cliente_fornitore_dalle_cpa
*****************************************************
LPARAMETERS __cl_fo,__cpa,__iban_riba,__iban_boni


_SELibanX=SELECT()

** verifica che tipo di condizione di pagamento č per prelevare dalla'anagrafica l'iban RIBA oppure iban BONIFICI
V_SEEK = 'CPA'+ALLTRIM(__cpa)
IF seek_std('PARA',v_seek,'CODICE','CPA_PARA')
  	_RIBA__ = SUBSTR(CPA_PARA.LIBERA,10,1) 		&& SE "X" : RICEVUTA BANCARIA
ELSE
	_RIBA__ = ""								&& LO CONSIDERA COME BONIFICO
ENDIF

DO CASE
	
	CASE __cl_fo = "C"

		IF _RIBA__ = "X"
			__IBAN__ = __iban_riba
			IF EMPTY(__IBAN__)				&& SE NON ESISTE CERCA DI PRENDERE L'ALTRO IBAN
				__IBAN__ = __iban_boni		&& SE NON ESISTE CERCA DI PRENDERE L'ALTRO IBAN
			ENDIF							&& SE NON ESISTE CERCA DI PRENDERE L'ALTRO IBAN
		ELSE
			__IBAN__ = __iban_boni
			IF EMPTY(__IBAN__)				&& SE NON ESISTE CERCA DI PRENDERE L'ALTRO IBAN
				__IBAN__ = __iban_riba		&& SE NON ESISTE CERCA DI PRENDERE L'ALTRO IBAN
			ENDIF							&& SE NON ESISTE CERCA DI PRENDERE L'ALTRO IBAN
		ENDIF

		IF EMPTY(__IBAN__)
			__IBAN__ = __iban_boni
		ENDIF
		
			
	CASE __cl_fo = "F"

*!*			IF _RIBA__ = "X"
*!*				__IBAN__ = __iban_riba
*!*			ELSE
			__IBAN__ = __iban_boni
			IF EMPTY(__IBAN__)				&& SE NON ESISTE CERCA DI PRENDERE L'ALTRO IBAN
				__IBAN__ = __iban_riba		&& SE NON ESISTE CERCA DI PRENDERE L'ALTRO IBAN
			ENDIF							&& SE NON ESISTE CERCA DI PRENDERE L'ALTRO IBAN
*!*			ENDIF


ENDCASE



SELECT(_SELibanX)


RETURN(__IBAN__)


	
	
****************************************
FUNCTION CARICA_CURSORE_IVA_PRIMA_NOTA
****************************************
LPARAMETERS __IMPONIBILE_DOCUMENTO_,__IMPOSTA_DOCUMENTO_,_CODICE_IVA,__CODICE_VALUTA

_SELivaX=SELECT()

IF _CODICE_IVA = "NO"
	RETURN
ENDIF

_CODICE_IVA = seek_para('IVA',ALLTRIM(_CODICE_IVA),'CODICE','CODICE','4,3','iva_para')
IF EMPTY(_CODICE_IVA)
	SELECT(_SELivaX)
   	RETURN .F.
ENDIF


SELECT IVA_PARA
LIB_     		= VAL(SUBSTR(LIBERA,1,3))
PERIVAI_ 		= VAL(SUBSTR(LIBERA,110,3))
TIPOIVA_ 		= SUBSTR(LIBERA,100,1)
SCARTO_  		= 0
DESCRI_IVA_ 	= ALLTRIM(DESCRI)

__IMPOSTA_INDEDUCIBILE  = 0
__IMPOSTA_DEDUCIBILE	= 0


IF ALLTRIM(TIPOIVA_) <> "I"                   && IVA TOTALMENTE DETRAIBILE

   IF __CODICE_VALUTA = "ITL" .OR. __CODICE_VALUTA ="LIT"
      __IMPOSTA_DEDUCIBILE=ROUND(((__IMPONIBILE_DOCUMENTO_)*LIB_/100)+.49,0)
   ELSE
      __IMPOSTA_DEDUCIBILE=ROUND(((__IMPONIBILE_DOCUMENTO_)*LIB_/100)+.0000,2)
   ENDIF

ELSE

	IF PERIVAI_ <> 0	&& PERCENTUALE IVA INDETRAIBILE

*!*			IF __CODICE_VALUTA = "ITL" .OR. __CODICE_VALUTA="LIT"
*!*			   __IMPOSTA__     =	ROUND(((__IMPONIBILE_DOCUMENTO_)*LIB_/100)+.49,0)
*!*			ELSE
*!*			   __IMPOSTA__     =	ROUND(((__IMPONIBILE_DOCUMENTO_)*LIB_/100)+.0000,2)
*!*			ENDIF

*!*			__IMPOSTA_INDEDUCIBILE      =	__IMPOSTA__ * (PERIVAI_/100)

*!*			IF __CODICE_VALUTA = "ITL" .OR. __CODICE_VALUTA="LIT"
*!*			   __IMPOSTA_INDEDUCIBILE   =	ROUND(__IMPOSTA_INDEDUCIBILE,0)
*!*			ELSE
*!*			   __IMPOSTA_INDEDUCIBILE   =	ROUND(__IMPOSTA_INDEDUCIBILE,2)
*!*			ENDIF

*!*			__IMPOSTA_DEDUCIBILE      	=	__IMPOSTA__ - __IMPOSTA_INDEDUCIBILE				&& IMPOSTA DEDUCIBILE
*!*			__IMPOSTA__   				=	__IMPOSTA_INDEDUCIBILE                         		&& IMPOSTA INDEDUCIBILE

*!*			IF __IMPOSTA_DEDUCIBILE= 0
*!*			   __IMPOSTA_DEDUCIBILE  = 	__IMPOSTA__
*!*			   __IMPOSTA__     = 0                          									&& IMPOSTA INDEDUCIBILE 100%
*!*			ENDIF
		
		*TOTALE_IMPOSTA_ORIGINALE   = __IMPOSTA_DOCUMENTO_ / (PERIVAI_ / 100)
		**=> ERASMO - INIZIO 22/05/2026
		IF PERIVAI_ = 100
			TOTALE_IMPOSTA_ORIGINALE   = __IMPONIBILE_DOCUMENTO_ - (__IMPONIBILE_DOCUMENTO_ / (1 + (LIB_ / 100)))
		ELSE
			TOTALE_IMPOSTA_ORIGINALE   = __IMPOSTA_DOCUMENTO_ / (PERIVAI_ / 100)
		ENDIF
		**=> ERASMO - FINE 22/05/2026
		IVA_INDEDUCIBILE_DA_TOGLIERE_DAL_COSTO = TOTALE_IMPOSTA_ORIGINALE   - __IMPOSTA_DOCUMENTO_
		IMPONIBILE_ORIGINALE       = __IMPONIBILE_DOCUMENTO_ - IVA_INDEDUCIBILE_DA_TOGLIERE_DAL_COSTO

 		__IMPOSTA_DEDUCIBILE       = ROUND(__IMPOSTA_DOCUMENTO_,2)
		__IMPOSTA_INDEDUCIBILE     = ROUND(IVA_INDEDUCIBILE_DA_TOGLIERE_DAL_COSTO,2)
		__IMPONIBILE_DOCUMENTO_	   = IMPONIBILE_ORIGINALE
		
	ENDIF



ENDIF

SELECT CORPO_IVA
SET ORDER TO I_IVA1
_SEEK = _CODICE_IVA
SEEK _SEEK
IF FOUND()

	REPLACE IVA_IMPONIB  WITH IVA_IMPONIB  		+	__IMPONIBILE_DOCUMENTO_			&& IMPONIBILE
