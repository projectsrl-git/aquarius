PROCEDURE CONTROLLO_CONTO_CONTABILE_SIMILCEE
***********************************************************
PARA _STRINGA

IF !PUB_CONTOSIMILCEE		&& CONTROLLO SOLO PER CONTI CONTABILI SIMILCEE 
	RETURN .T.
ENDIF


RELEASE _STRI,_LUNG_STRI,_NOMENCLATURA_CORRETTA
