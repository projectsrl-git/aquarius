*****************************************************************************************
*	 						 RAGGRUPPA PER DATA DI SCADENZA 		          		    *
*****************************************************************************************			

FUNCTION RAGGRUPPA_SCADENZE
PARA _dtscad,_cursoragg,_cursordaagg



	*!*		RAGGRUPPA ULTERIORMENTE PER PARTITA SCADENZA


		SELECT CSPART_FOR
		GO TOP
		
		DO WHILE !EOF()

				SCATTER MEMVAR MEMO				&& SALVA LE VARIABILE DELLE NUOVE SCADENZE



				SELECT &_cursordaagg
				GO TOP

				DO WHILE !EOF()

					
					    IF PAR_NPROG = 100
							SELECT &_cursordaagg
							SKIP +1
							LOOP
					    ENDIF

						IF (PAR_DTSCAD = M.PAR_DTSCAD) AND (PAR_TMOV = M.PAR_TMOV)
	
							REPLACE PAR_FATT	WITH  PAR_FATT + M.PAR_FATT			&& SE TROVA GIA UNA SCADENZA SOMMA L'IMPORTO AL FINE DEL RAGGRUPPAMENTO

							SELECT CSPART_FOR
							
							DELETE				&& CANCELLA LA NUOVA SCADENZA IN QUANTO SOMMATA ALL'ORIGINALE

							EXIT

						ENDIF
			
			            SELECT &_cursordaagg
						SKIP +1
						
				ENDDO

			SELECT CSPART_FOR
			SKIP +1
			
		ENDDO


		*!*		COPIA LE NUOVE SCADENZE RIMASTE NEL PARTITARIO

		
		SELECT CSPART_FOR
		GO TOP
	    SCAN
	      SCATTER MEMVAR MEMO
		  INSERT INTO &_cursordaagg FROM MEMVAR
		ENDSCAN




RETURN





***********************
FUNCTION RICARICA_CPA
***********************
PARA _CPA



** RITORNA LA VARIABILE CPA

AABBSXS  = SELECT()

SELECT CORPO_MOV
PUNTA_MOV = RECNO()
SET ORDER TO I_CORPOMOV
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   _CCC = CONTO
   x_soci = "con_soc = '" + PUB_CODSOC + "'"
   x_anno = "con_anno = '" + PUB_ANNO + "'"
   x_cont = "con_conto = '" + ALLTRIM(_CCC) + "'"
   x_cond = x_soci + " and " + x_anno + " and " + x_cont
   Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
   IF !ExecCommand(cSql,"cur_conti")
      return(.f.)
   ENDIF
   SELECT cur_conti
   GO TOP
   IF EOF()
      SELECT CORPO_MOV
      SKIP +1
      LOOP
   ENDIF
   IF SUBSTR(CON_TIPOCO,1,1) = 'F' .OR. SUBSTR(CON_TIPOCO,1,1) = 'C'
      RELEASE XYZ_COD,XYZ_TIP
      PUBLIC  XYZ_COD,XYZ_TIP
      XYZ_COD = CONTO
      XYZ_TIP = SUBSTR(CON_TIPOCO,1,1)
      EXIT
   ENDIF
   SELECT CORPO_MOV
   SKIP +1

ENDDO

SELECT CORPO_MOV
GO PUNTA_MOV


V_CONPAG  = _CPA

IF V_CONPAG  = "XXX"  .OR. EMPTY(V_CONPAG) .OR. V_CONPAG = SPACE(03)

   RELEASE _OK
   PUBLIC  _OK
   _OK = .F.

   IF XYZ_TIP = 'C'
      x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
      *x_codi = "cli_codcli = '" + SUBSTR(XYZ_COD,PUB_SOTTOG,9) + "'"
	  x_codi = "cli_codcli = '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(XYZ_COD,RAT('.',XYZ_COD,1)+1))), ALLTRIM(SUBSTR(XYZ_COD,PUB_SOTTOG,PUB_CONTO))) + "'"  && SERGIO - 18/12/2021
      
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
      IF !ExecCommand(cSql,"cur_cliente")
         return(.f.)
      ENDIF
      SELECT cur_cliente
      GO TOP
      IF EOF()
      ELSE
         V_CONPAG	= CLI_CONPAG
         XYZ_CPA 	= V_CONPAG
         CPA		= V_CONPAG
         IF XYZ_BAN = SPACE(05) .OR. EMPTY(XYZ_BAN)
            XYZ_BAN = CLI_BAE
         ENDIF	
         PUBLIC VET_DAL[2],VET_AL[2],VET_DAY[2]
         VET_DAL[1]	= CLI_BDAL
         VET_DAL[2]	= CLI_B2DAL
         VET_AL[1] 	= CLI_BAL
         VET_AL[2] 	= CLI_B2AL
         VET_DAY[1]	= CLI_GG1
         VET_DAY[2]	= CLI_GG2
         _OK = .T.
      ENDIF
   ELSE
      x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
      *x_codi = "for_codcli = '" + SUBSTR(XYZ_COD,PUB_SOTTOG,9) + "'"
	  x_codi = "for_codcli = '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(XYZ_COD,RAT('.',XYZ_COD,1)+1))), ALLTRIM(SUBSTR(XYZ_COD,PUB_SOTTOG,PUB_CONTO))) + "'"  && SERGIO - 18/12/2021
      
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
      IF !ExecCommand(cSql,"cur_fornitore")
         return(.f.)
      ENDIF
      SELECT cur_fornitore
      GO TOP
      IF EOF()
      ELSE
         V_CONPAG  	= FOR_CONPAG
         XYZ_CPA 	= V_CONPAG
         CPA		= V_CONPAG
         IF XYZ_BAN = SPACE(05) .OR. EMPTY(XYZ_BAN)
            XYZ_BAN = FOR_BAE
         ENDIF	
         _OK = .T.
      ENDIF
   ENDIF

ENDIF


SELECT CORPO_SCA

SELECT(AABBSXS)
RETURN

