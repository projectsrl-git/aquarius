SCAN
	_MOV_TMOV = MOV_TMOV
	_MOV_IMP = MOV_IMP
	_MOV_IMPOST = MOV_IMPOST
	_MOV_ANNO = MOV_ANNO
	_MOV_CONTO = MOV_CONTO
	
	*_DA_SOMMARE = IIF(_R_VER_CONTO='C' AND _MOV_TMOV='A',.T.,.F.)
	**=> ERASMO - INIZIO 15/12/2025
	_DA_SOMMARE = .T.
	IF _R_VER_CONTO = "C"
		IF _MOV_TMOV='A'
			_DA_SOMMARE = .T.
		ELSE
			_DA_SOMMARE = .F.
		ENDIF
	ELSE
		IF _MOV_TMOV='D'
			_DA_SOMMARE = .T.
		ELSE
			_DA_SOMMARE = .F.
		ENDIF
	ENDIF
	**=> ERASMO - FINE 15/12/2025
	
	IF _DA_SOMMARE
		_R_TotaleParcella = _R_TotaleParcella + _MOV_IMP + _MOV_IMPOST
	ELSE
		_R_TotaleParcella = _R_TotaleParcella - _MOV_IMP - _MOV_IMPOST
	ENDIF
	
	cSql = "SELECT * FROM CONTI WHERE CON_ANNO = '" + _MOV_ANNO + "' AND CON_CONTO = '" + _MOV_CONTO + "'"
	IF !ExecCommand(CSQL,"TMP_CONTI")
	   RETURN (.f.)
	ENDIF
	SELECT TMP_CONTI
	GO TOP
	IF EOF()
		SELECT TMP_MOV_CONT
		LOOP
	ENDIF
	IF CON_SOGGETTORAP
		IF _DA_SOMMARE
			_R_SoggettoRAP = _R_SoggettoRAP + _MOV_IMP
		ELSE
			_R_SoggettoRAP = _R_SoggettoRAP - _MOV_IMP
		ENDIF
	ELSE
		IF CON_PREVIDENZA
			IF _DA_SOMMARE
				_R_ImportoPrevidenza = _R_ImportoPrevidenza + _MOV_IMP
			ELSE
				_R_ImportoPrevidenza = _R_ImportoPrevidenza - _MOV_IMP
			ENDIF
		ELSE	
			IF _DA_SOMMARE
				_R_NonSoggettoRAP = _R_NonSoggettoRAP + _MOV_IMP
			ELSE
				_R_NonSoggettoRAP = _R_NonSoggettoRAP - _MOV_IMP
			ENDIF
		ENDIF
	ENDIF
	
	IF CON_ANTICIPAZIONI
		IF _DA_SOMMARE
			_R_ImportoAnticipazioni = _R_ImportoAnticipazioni + _MOV_IMP
		ELSE
			_R_ImportoAnticipazioni = _R_ImportoAnticipazioni - _MOV_IMP
		ENDIF
	ENDIF
	
	IF CON_BOLLI
		IF _DA_SOMMARE
			_R_ImportoBolli = _R_ImportoBolli + _MOV_IMP
		ELSE
			_R_ImportoBolli = _R_ImportoBolli - _MOV_IMP
		ENDIF
	ENDIF
	
	IF _MOV_IMPOST <> 0
		IF _DA_SOMMARE
			_R_SoggettoIVA = _R_SoggettoIVA + _MOV_IMP
			_R_ImportoIVA = _R_ImportoIVA + _MOV_IMPOST
		ELSE
			_R_SoggettoIVA = _R_SoggettoIVA - _MOV_IMP
			_R_ImportoIVA = _R_ImportoIVA - _MOV_IMPOST
		ENDIF
	ELSE
		IF _DA_SOMMARE
			_R_NonSoggettoIVA = _R_NonSoggettoIVA + _MOV_IMP
		ELSE
			_R_NonSoggettoIVA = _R_NonSoggettoIVA - _MOV_IMP
		ENDIF
	ENDIF
	
	IF CON_INPS
		*IF _DA_SOMMARE
		*	_R_INPS_Totale = _R_INPS_Totale + _MOV_IMP
		*ELSE
		*	_R_INPS_Totale = _R_INPS_Totale - _MOV_IMP
		*ENDIF
	ELSE
		IF CON_SOGGETTOINPS
			IF _DA_SOMMARE
				_R_SoggettoINPS = _R_SoggettoINPS + _MOV_IMP
			ELSE
				_R_SoggettoINPS = _R_SoggettoINPS - _MOV_IMP
			ENDIF
		ENDIF
	ENDIF
	
ENDSCAN

IF _R_FLAGRAP
	_R_ImportoRAP = _R_SoggettoRAP * (_R_PERCIMPONIBILERAP / 100) * (_R_ALIQUOTARAP / 100)
ENDIF

IF _R_FLAGINPS
	_R_INPS_Totale = _R_SoggettoINPS * (_R_PERCIMPONIBILEINPS / 100) * (_R_ALIQUOTAINPS / 100)
	_R_QuotaINPS_Committente = _R_INPS_Totale * (_R_QUOTACOMMITTENTE/ 100)
	_R_QuotaINPS_Percipiente = _R_INPS_Totale - _R_QuotaINPS_Committente
ENDIF

IF _R_NOTACREDITO = "S"
	_R_TotaleParcella = -1 * _R_TotaleParcella
	_R_ImportoRAP = -1 * _R_ImportoRAP
	_R_ImportoAnticipazioni = -1 *_R_ImportoAnticipazioni
	_R_ImportoPrevidenza = -1 * _R_ImportoPrevidenza
	_R_ImportoBolli = -1 * _R_ImportoBolli
	_R_SoggettoIVA = -1 * _R_SoggettoIVA
	_R_NonSoggettoIVA = -1 * _R_NonSoggettoIVA
	_R_ImportoIVA = -1 * _R_ImportoIVA
	_R_INPS_Totale = -1 * _R_INPS_Totale
ENDIF


*** INSERIMENTO/AGGIORNAMENTO FINALE TABELLA AQ_RAP
x_iddc = "IDDocumento = '" + ALLTRIM(_R_MOV_SYSDOC) + "'"
x_cond = x_iddc
