	**=> ERASMO - INIZIO 08/04/2024
	*** SE IL CONTO PER ATTIVAZIONE ALERT ANTICIPI FORNITORI E' ESSO STESSO UN CONTO FORNITORE, NON CHIEDO LA SELEZIONE DEL FORNITORE
	IF _CONTO_SET_ANT_FORN_TIPO == "F"
		_RISP = MESSAGEBOX("Abilitare questo pagamento per mostrare un alert sulle prossime fatture registrate?",4+32,"Attenzione")
		IF _RISP = 6
			SELECT CORPO_MOV
			GO TOP
			SCAN
				IF ALLTRIM(CONTO) = _CONTO_SET_ANT_FORN
					REPLACE __NUCOM WITH "Forn. " + ALLTRIM(CONTO)
				ENDIF
			ENDSCAN
		ELSE
			MESSAGEBOX("Alert non abilitato",48,"Informazione")
		ENDIF
	ELSE
	**=> ERASMO - FINE 08/04/2024
		_RISP = MESSAGEBOX("Selezionare il fornitore per il quale mostrare un alert sulle prossime fatture registrate?",4+32,"Attenzione")
		IF _RISP = 6
			_C_FORNITORE = PJ_INPUTBOX("Selezione fornitore per alert di anticipo","Digitare il fornitore","",.F.,"")
