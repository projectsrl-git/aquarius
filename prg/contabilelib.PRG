FUNCTION CARICA_SALDI_CENTRI_DI_COSTO_DA_MOV_CONT
****************************************************************************************************************
PARA _DB__,_DATADAL__,_DATAAL__,_C_COSTODA__,_C_COSTOA__,___INCLUDE_SALDI_PREVISIONALI,___ELABORA_SOLO_ECONOMICI


_DAL__ = VAL(SUBSTR(_DATADAL__,4,2))
