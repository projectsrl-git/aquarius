*********************************************************************************************************
*  			 SOTTRAE DAL VALORE AGGIORNATO NEL CASO DI ANNULLO/VARIAZIONE PRIMA NOTA				    *
*********************************************************************************************************
FUNCTION REG_AGGIORNA_U_ART_PR
PARAMETERS _COME_AGG,_CDARTI,_CODPRI,_VALORE,_DTUTIL	


AXABBS_Z    = SELECT()

DO CASE

	CASE _COME_AGG = "AGGIORNA"


			**==> crea cursore anagrafica articoli per aggiornare il bene in ammortamento
			x_cond = "ART_CODPRI = '" + ALLTRIM(_CDARTI) + "'"
			Csql   = "select * from u_art_pr where " + x_cond + " order by ART_CODPRI"
			IF !ExecCommand(cSql,"cu_art_pr")
			   return(.f.)
			ENDIF
			SELECT cu_art_pr
			GO TOP
			REPLACE ART_VALORE WITH ART_VALORE + _VALORE
			REPLACE ART_DTUTIL WITH _DTUTIL

			IF !ExecRW('','u_art_pr','I','','cu_art_pr')
			  return(.f.)
			ENDIF


			**==> crea cursore anagrafica articoli per aggiornare l'impianto generale a cui appartiene il bene in ammortamento
			x_cond = "ART_CODPRI = '" + ALLTRIM(_CODPRI) + "'"
			Csql   = "select * from u_art_pr where " + x_cond + " order by ART_CODPRI"
			IF !ExecCommand(cSql,"cu_art_pr")
			   return(.f.)
			ENDIF
			SELECT cu_art_pr
			GO TOP
			REPLACE ART_VALORE WITH ART_VALORE + _VALORE


			IF !ExecRW('','u_art_pr','I','','cu_art_pr')
			  return(.f.)
			ENDIF



	CASE _COME_AGG = "ANNULLA"



			**==> crea cursore anagrafica articoli per aggiornare il bene in ammortamento
			x_cond = "ART_CODPRI = '" + ALLTRIM(_CDARTI) + "'"
			Csql   = "select * from u_art_pr where " + x_cond + " order by ART_CODPRI"
			IF !ExecCommand(cSql,"cu_art_pr")
			   return(.f.)
			ENDIF
			SELECT cu_art_pr
			GO TOP
			REPLACE ART_VALORE WITH ART_VALORE - _VALORE
			REPLACE ART_DTUTIL WITH _DTUTIL

			IF !ExecRW('','u_art_pr','I','','cu_art_pr')
			  return(.f.)
			ENDIF


			**==> crea cursore anagrafica articoli per aggiornare l'impianto generale a cui appartiene il bene in ammortamento
			x_cond = "ART_CODPRI = '" + ALLTRIM(_CODPRI) + "'"
			Csql   = "select * from u_art_pr where " + x_cond + " order by ART_CODPRI"
			IF !ExecCommand(cSql,"cu_art_pr")
			   return(.f.)
			ENDIF
			SELECT cu_art_pr
			GO TOP
			REPLACE ART_VALORE WITH ART_VALORE - _VALORE


			IF !ExecRW('','u_art_pr','I','','cu_art_pr')
			  return(.f.)
			ENDIF


	CASE _COME_AGG = "RICERCA"



			**==> crea cursore anagrafica articoli per aggiornare il bene in ammortamento
			x_cond = "ART_CODPRI = '" + ALLTRIM(_CDARTI) + "'"
			Csql   = "select * from u_art_pr where " + x_cond + " order by ART_CODPRI"
			IF !ExecCommand(cSql,"cu_art_pr")
			   return(.f.)
			ENDIF
			SELECT cu_art_pr
			GO TOP



ENDCASE


SELECT(AXABBS_Z)

RETURN


