***********************************************************************************
PROCEDURE CERCA_CCI
***********************************************************************************


IF EMPTY(X_CONTOP)   && GESTIONE STORICO
   RETURN
ENDIF

* ACCEDO PER NUMERO INTERNO DI PRIMA NOTA + CENTRO DI COSTO PRIMARIO
* AI MOVIMENTI DEI C.COSTI

V_EK  = PUB_CODSOC+PUB_ANNO+NUM_INT+WCONTO+WCOD01+ALLTRIM(X_CONTOP)
XCOD1 = WCOD01
x_soci = "mov_soc = '" + PUB_CODSOC + "'"
x_anno = "mov_anno = '" + PUB_ANNO + "'"
x_npro = "mov_numpro = '" + ALLTRIM(NUM_INT) + "'"
x_copr = "mov_coprim = '" + ALLTRIM(WCONTO) + "'"
x_ccos = "mov_cco = '" + ALLTRIM(WCOD01) + "'"
x_cont = "mov_contop = '" + ALLTRIM(X_CONTOP) + "'"
Csql   = "select * from mov_cco where " + x_soci + " and " + x_anno + " and " + x_npro + " and " + ;
                                          x_copr + " and " + x_ccos + " and " + x_cont + ;
                                          " order by mov_soc,mov_anno,mov_numpro,mov_coprim,mov_cco,mov_contop"
IF !ExecCommand(Csql,"MOV_CCO")
  return(.f.)
ENDIF

SELECT MOV_CCO
GO TOP

DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   XX_CODSYS = MOV_NUMPRO
   XX_CODGRU = MOV_CODGRU
   XX_DESGRU = SPACE(50)
   XX_CODCCO = MOV_CONTO
   XX_DESCCO = SPACE(50)
   XX_NATURA = MOV_TMOV
   XX_PERCEN = MOV_PERCEN
   XX_VALORE = MOV_IMP
   XX_MOVGRU = MOV_CODGRU
   XX_MOVCCO = MOV_CCO
   x_soci = "gru_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "gru_codice = '" + ALLTRIM(XX_CODGRU) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_cco_gr where " + x_cond + " order by gru_codsoc,gru_codice"
   IF !ExecCommand(Csql,"cur_cco_gr")
      return(.f.)
   ENDIF
   SELECT cur_cco_gr
   IF EOF()
   ELSE
      XX_DESGRU = GRU_DESCRI
   ENDIF
   x_soci = "con_soc = '" + PUB_CODSOC + "'"
   x_anno = "con_anno = '" + PUB_ANNO + "'"
   x_codi = "con_conto = '" + ALLTRIM(XX_CODCCO) + "'"
   x_cond = x_soci + " and " + x_anno + " and " + x_codi
   Csql   = "select * from ccosto where " + x_cond + " order by con_soc,con_anno,con_conto"
   IF !ExecCommand(Csql,"cur_ccosto")
      return(.f.)
   ENDIF
   SELECT cur_ccosto
   IF EOF()
   ELSE
      XX_DESCCO = CON_DESCR
   ENDIF
   SELECT CORPO_CCO
   APPEND BLANK
   REPLACE CCO_CODSYS WITH XX_CODSYS
   REPLACE CCO_CODGRU WITH XX_CODGRU
   REPLACE CCO_DESGRU WITH XX_DESGRU
   REPLACE CCO_CODCCO WITH XX_CODCCO
   REPLACE CCO_DESCCO WITH XX_DESCCO
   REPLACE CCO_NATURA WITH XX_NATURA
   REPLACE CCO_PERCEN WITH XX_PERCEN
   REPLACE CCO_VALORE WITH XX_VALORE
   REPLACE CCO_MOVGRU WITH XX_MOVGRU
   REPLACE CCO_MOVCCO WITH XX_MOVCCO
   SELECT MOV_CCO
   SKIP +1
ENDDO

SELECT CORPO_CCO
GO TOP

RETURN


***********************************************************************************
*      CLEAR DELLE VARIABILI                                        			  *
***********************************************************************************
PROCEDURE REG_CLEAR



**==> CURSORE DI SUPPORTO PER MEMORIZZARE I RATEI / RISCONTI
SELECT CURSOR_RAR
INDEX ON RAR_SEQUEN  TAG RARSEQUEN
ZAP


**==> CURSORE DI SUPPORTO PER MEMORIZZARE I DETTAGLI DEGLI ARTICOLI FACENTI PARTE DI UN DDT GESTITO DA PIU' FATTURE
SELECT SAVE_BFO_DD
ZAP

**==> CURSORE DI SUPPORTO PER MEMORIZZARE I LEGAMI DDT / FATTURE
SELECT CU_BFO_LE
