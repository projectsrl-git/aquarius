******************************
PROCEDURE SELE_CLI
******************************
PARA XXX_CONTO,XXX_NDOC

WAIT WINDOWS "Ricerca saldi partite in corso - attendere prego..." NOWAIT

* VERIFICA SE DEVE MOSTRARE LA GRIGLIA DEI PAGAMENTI MULTIPLI
SELECT CORPO_MOV

=DEF_EURO()		&& DEFINISCE IL CURSORE PER LA GESTIONE DEI PARTITARI


**GESTIONE FATTURE CON ACCONTI ANTICIPATI
CREATE CURSOR WORK (;
  WIDUNIQUE C(200), ;
  WANNO    C(04), ;
  WSELEZ   C(06), ;
  WCONTO   C(13), ;
  WPART    C(10), ;
  WPARTW   C(10), ;
  WNREGIS  C(06), ;
  WTOP     C(10), ;
  WFL_FVS  C(01), ;
  WNUMFAT  C(10), ;
  WDATFAT  C(10), ;
  WDATFAK  C(10), ;
  WPROTO   N(10), ;
  WDTSCAD  C(10), ;
  WDTSCAX  C(10), ;
  WCOVAL   C(03), ;
  WIMPVRIF N(17,3), ;
  WCAMBIO  N(17,10), ;
  WIMPORTO N(17,3), ;
  WAVERE   N(17,3), ;
  WIMPITL  N(17,3), ;
  WIMPVAL  N(17,3), ;
  WABBUO   N(17,3), ;
  WPAGA    N(17,3), ;
  WFATAGE  C(06), ;
  WSCARTABOLLATO C(1), ;
  WANOMAX C(3), ;
  WTIPOPA C(10), ;
  WBLOCCO L, ;
  WSTORIA M, ;
  WPREFFE C(1), ;
  WPAGATO  N(17,3), ;
  WDESPRIMANOT C(254))

INDEX ON WPART+WDTSCAX                          		TAG WORK
INDEX ON RIBALTA2(WDATFAT)+WNUMFAT+WDTSCAX              TAG WORKD
INDEX ON WANNO+STR(VAL(WPARTW))                 		TAG WORKE



PUB_NOAGG = .F.
IF PUB_VARPN		&& VARIAZIONE DELLA PRIMA NOTA
   PUB_NOAGG = .T.
   DO REG_ANCLFO   && ANNULLO PARTITARI	
ENDIF

IF CANT = "C"							&& GESTIONE INCASSO CLIENTE ANTICIPATO
	DO REG_NUMPAC 						&& PRELEVA IL NUMERO DI PARTITA
ENDIF


OK_WORK = .F.

