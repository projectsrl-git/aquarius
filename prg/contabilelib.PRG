			ELSE

				IF _TOTALE_PAGATO < 0
			
			       REPLACE DARE  WITH + ABS(_TOTALE_PAGATO)		&& RIPORTA IL TOTALE PAGATO SULLA CONTROPARTITA BANCA PER NOTE CREDITO
			       REPLACE AVERE WITH 0				

		        ELSE
		        	
		  		    IF DARE <> 0
				       REPLACE DARE WITH ABS(_TOTALE_PAGATO)	&& RIPORTA IL TOTALE PAGATO SULLA CONTROPARTITA BANCA
				    ENDIF
				    IF AVERE <> 0
				       REPLACE AVERE WITH ABS(_TOTALE_PAGATO)	&& RIPORTA IL TOTALE PAGATO SULLA CONTROPARTITA BANCA
				    ENDIF

				ENDIF
			
			ENDIF
	
		    STORE IVA TO __IVA
		    IF __IVA  <> "NO"													&& SCORPORA L'IVA SE NOTE CREDITO
				IF DARE <> 0
					  X_VALOR  = 0
				      DO SCORPORO_IMPOSTA2 	WITH ABS(_TOTALE_PAGATO)    		&& OTTIENE L'IMPONIBILE IN X_VALOR
			          REPLACE DARE 			WITH ABS(X_VALOR)
			          REPLACE IMPOSTA		WITH ABS(_TOTALE_PAGATO) - ABS(X_VALOR)
				ENDIF
				IF AVERE <> 0
					  X_VALOR  = 0
				      DO SCORPORO_IMPOSTA2 	WITH ABS(_TOTALE_PAGATO)    		&& OTTIENE L'IMPONIBILE IN X_VALOR
			          REPLACE AVERE 		WITH ABS(X_VALOR)
			          REPLACE IMPOSTA		WITH ABS(_TOTALE_PAGATO) - ABS(X_VALOR)
				ENDIF
		    ENDIF



			REPLACE ___FLCURS WITH "OK"
		    EXIT

		ENDDO
	ENDIF
ENDIF


**** RICALCOLA I TOTALI DARE/AVERE ESCLUDENDOLA CONTROPARTITA BANCA PER LA COMPENSAZIONE


SELECT CORPO_MOV
GO TOP

_TDARE  = 0
_TAVERE = 0

DO WHILE !EOF()

    IF ___FLCURS = "OK"   		&& SCARTA LA CONTROPARTITA BANCA
     SELECT CORPO_MOV
     SKIP +1
     LOOP
    ENDIF


    IF DARE > 0
      _TDARE = _TDARE + DARE
    ENDIF

    IF AVERE > 0
      _TAVERE  = _TAVERE  + AVERE
    ENDIF


    SELECT CORPO_MOV
    SKIP +1

ENDDO

**** MI RIPOSIZIONO SU CONTROPARTITA E CONTROAGGIORNO COMPENSANDO IN DARE O IN AVERE

IF NO_AUT = "S"        && NESSUN AUTOMATISMO
ELSE

	SELECT CORPO_MOV
	GO TOP

	_SALDO = _TDARE  -  _TAVERE

	DO WHILE !EOF()

	    IF ___FLCURS <> "OK"   		&& SCARTO TUTTI I MOVIMENTI NO CONTROPARTITA BANCA
	     SELECT CORPO_MOV
	     SKIP +1
	     LOOP
	    ENDIF
	
	    IF _SALDO > 0 										&& STO PAGANDO FATTURE
	       REPLACE AVERE  WITH  _SALDO - IMPOSTA
	       REPLACE DARE   WITH  0
	    ELSE
	       REPLACE DARE   WITH  (ABS(_SALDO) - IMPOSTA) 	&& COMPENSAZIONI
	       REPLACE AVERE  WITH  0
	    ENDIF

	    EXIT
	
	ENDDO
ENDIF


IF PINCAMULTI <> "S"  && GESTIONE DEI PAGAMENTI MULTIPLI ATTIVA

	*** VERIFICA INCROCIATA SUGLI IMPORTI DELLA LISTA :
	*** NEL CASO SIANO STATI FATTI DEI CALCOLI ECCEDENTI AL VALORE DIGITATO TOTALE DEL TOCUMENTO :
	*** AZZERA I VALORI DARE,AVERE,IMPOSTA E MOSTRA COMUNQUE I CONTI CONTABILI INDICATI NELLE CONTROPARTITE ILLIMITATE DALL'UTENTE


	SELECT CORPO_MOV
	GO TOP

    SUM DARE   TO ___TDARE
    SUM AVERE  TO ___TAVERE

    IF ___TDARE = ___TAVERE

    	_TOTALE_PAGATO = ABS(___TDARE)

    ELSE

    	IF ___TDARE > ___TAVERE
    		_TOTALE_PAGATO = ABS(___TDARE)
    	ELSE
    		_TOTALE_PAGATO = ABS(___TAVERE)  	
    	ENDIF

    ENDIF


	IF M.TOTDOCU < ABS(_TOTALE_PAGATO)   && CASO IN CUI NON CONOSCO L'IMPORTO DA PAGARE , UTENTE DIGITA 1 SU TOT.DOCUMENTOE QUINDI DEVORICALCOLARE IL TOTALEDELDOCUMENTO

	   M.TOTDOCU = ABS(_TOTALE_PAGATO)
	
	ENDIF



	SELECT CORPO_MOV
	GO TOP


	__VERY_DARE 			= 0
	__VERY_AVERE 			= 0

	DO WHILE .NOT. EOF()

		IF DELETED()

			SELECT CORPO_MOV
			SKIP +1
			LOOP

		ENDIF

	    IF DARE <> 0
		    __VERY_DARE = __VERY_DARE + DARE + IMPOSTA	
		    IF __VERY_DARE  > M.TOTDOCU
			          REPLACE DARE 			WITH 0
			          REPLACE IMPOSTA		WITH 0
		    ENDIF
	    ENDIF
	
	    IF AVERE <> 0
		    __VERY_AVERE = __VERY_AVERE + AVERE + IMPOSTA	
		    IF __VERY_AVERE > M.TOTDOCU
			          REPLACE AVERE			WITH 0
			          REPLACE IMPOSTA		WITH 0
		    ENDIF
	    ENDIF
	

		SELECT CORPO_MOV
		SKIP +1

	ENDDO

ENDIF


SELECT CORPO_MOV
GO TOP

SHOW WINDOW PRIMANO2               && RIATTIVA LA FINESTRA DI PRIMA NOTA
RETURN



******************************
PROCEDURE SELE_PAG
******************************
PARA XXX_CONTO

* VERIFICA SE DEVE MOSTRARE LA GRIGLIA DEI PAGMENTI MULTIPLI
SELECT CORPO_MOV

=DEF_EURO()		&& DEFINISCE IL CURSORE PER LA GESTIONE DEI PARTITARI


CREATE CURSOR WORK (;
  WIDUNIQUE C(200), ;
  WANNO    	C(04), ;
  WSELEZ   	C(06), ;
  WCONTO   	C(13), ;
  WPART    	C(10), ;
  WPARTW   	C(10), ;
  WNREGIS  	C(06), ;
  WNUMFAT  	C(06), ;
  WDATFAT  	C(10), ;
  WDATFAK  	C(10), ;
  WPROTO   	N(10), ;
  WDTSCAD  	C(10), ;
  WDTSCAX  	C(10), ;
  WCOVAL   	C(03), ;
  WIMPVRIF 	N(17,3), ;
  WCAMBIO  	N(17,10), ;
  WIMPORTO 	N(17,3), ;
  WIMPITL  	N(17,3), ;
  WABBUO   	N(17,3), ;
  WPAGA    	N(17,3), ;
  WFATAGE  	C(06), ;
  WPAGATO  	N(17,3))

INDEX ON WPART+WDTSCAX                          TAG WORK
INDEX ON RIBALTA2(WDATFAT)+WNUMFAT              TAG WORKD
INDEX ON WANNO+STR(VAL(WPARTW))                 TAG WORKE


OK_WORK = .F.

x_soci  = "par_codsoc = '" + PUB_CODSOC + "'"
x_codi  = "par_codcli = '" + ALLTRIM(XXX_CONTO) + "'"
x_codi1 = "par_tipodo = 'PAG'"
cSql="SELECT * FROM PART_FOR WHERE " + x_soci + " and " + x_codi + " and " + x_codi1 + " order by par_codsoc,par_codcli"
IF !ExecCommand(cSql,"cur_partfor")
   return(.f.)
ENDIF
SELECT CUR_PARTFOR
GO TOP
IF EOF()
   RETURN
ENDIF

DO WHILE !EOF()

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF PAR_TIPODO <> 'PAG'
      SKIP + 1
      LOOP
   ENDIF

   IF PAR_TIPFAT = "AR$"   && TRATTA L'ARROTONDAMENTO PRECEDENTEMENTE CREATO
      SKIP + 1
      LOOP
   ENDIF

   * VERIFICA SE LA PARTITA E' CHIUSA
   VCONTO   = PAR_CODCLI	 && CODICE DEL FORNITORE
   VPARTITA = PAR_NPART	 && PARTITA FORNITORE
   VCURSORE = "VERPART"	 && NOME DEL CURSORE DI LAVORO
   VRAGGR   = .T.           && .T. RAGGRUPPA RITORNA UN RECORD CON IL SALDO DI TUTTI I MOVIMENTI DARE-AVERE
   VDIFFAR  = .F.			 && .T. CREA UN RECORD PER CHIUDERE LA PARTITA NEL CASO DI DIFFERENZA DOVUTA ALL'EURO DI 0,02 CENTESIMI
   VTIPO    = "F"			 && C= CLIENTE F= FORNITORE	

   IF EUR_PART(VTIPO,"PART_FOR",VCONTO,VPARTITA,VCURSORE,VRAGGR,VDIFFAR)  && PARTITA CHIUSA
	  SELECT CUR_PARTFOR	
      SKIP + 1
      LOOP
   ENDIF
	
   SELECT CUR_PARTFOR
   M.WIDUNIQUE 	= ID_UNIQUE	&& SALVA ID UNIQUE DELLA RIGA DEL PARTITARIO
   M.WANNO    	= PAR_ANNO
   M.WSELEZ   	= SPACE(06)
   M.WCONTO   	= PAR_CODCLI
   M.WPART    	= STR(PAR_NPART,10,0)
   M.WPARTW   	= STR(PAR_NPART,10,0)
   M.WNUMFAT  	= PAR_NUMFAT
   M.WNREGIS  	= PAR_NREG
   **M.WNUMFAT  	= NDOC
   M.WDATFAT 	= PAR_DTFAT
   M.WDATFAK 	= PAR_DTFAT
   M.WPROTO   	= PAR_NPART
   M.WDTSCAD  	= PAR_DTSCAD
   M.WDTSCAX  	= PAR_DTSCAD
   M.WNP      	= STR(PAR_NPART,10,0)
   *M.WFATAGE  	= PAR_NPROT
   M.WCAMBIO  	= PAR_CAMBIO
   M.WCOVAL   	= PAR_VALUTA

    IF PAR_TMOV = "A"	&&NOTA DI CREDITO
  	   M.WIMPORTO = TEURO(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT))
	   M.WIMPITL  = TLIRE(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT))
    ELSE
  	   M.WIMPORTO = (TEURO(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT)) *-1)
	   M.WIMPITL  = (TLIRE(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT)) *-1)
    ENDIF

    M.WPAGATO  = (TLIRE(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT)))
    M.WIMPVRIF = PAR_FATT * -1

   SELECT WORK
   SET ORDER TO WORK
   _SEEK = M.WPART+M.WDTSCAX
   SEEK _SEEK
   IF FOUND()
      REPLACE WIMPORTO WITH WIMPORTO+M.WIMPORTO
      REPLACE WIMPITL  WITH WIMPITL+M.WIMPITL
      REPLACE WPAGATO  WITH WPAGATO +M.WPAGATO
   ELSE
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE WIMPVRIF WITH WIMPVRIF+M.WIMPVRIF
      REPLACE WDATFAT  WITH RIBALTA2(M.WDATFAT)
      REPLACE WDTSCAD  WITH RIBALTA2(M.WDTSCAD)
   ENDIF

   SELECT CUR_PARTFOR
   SKIP +1

ENDDO

SELECT WORK
GO TOP


SELECT WORK
SET ORDER TO WORKE
SET FILTER TO WIMPORTO <> 0
GO TOP

OK_WORK = .F.
DO WHILE .NOT.EOF()        && VERIFICA SE EFFETTIVAMENTE ESISTE FATTURA IN LISTA
   OK_WORK = .T.           && SE HO I PAGAMENTI E NON LA FATTURA IMPORTO PAGATO > WIMPORTO
   SKIP +1
ENDDO

IF !OK_WORK
   RIT = MESSAGEBOX("Nessun effetto "+"per il fornitore digitato",62,"CONFERMA")
   RETURN
ENDIF

HIDE WINDOW PRIMANO2           && NASCONDE LA FINESTRA DI PRIMA NOTA

SELECT WORK
SET ORDER TO WORKD
GO TOP

_TITOLO = "Situazione effetti del fornitore : "+ M.DESCRIC
DO FORM FORM\PRIMAPAG WITH _TITOLO LINKED
REC_SELE=0

* -->> ESPLODO IN CORPO_MOV I MOVIMENTI DI PRIMA NOTA

SELECT CORPO_MOV
_SOLO_ORA = .T.   && SALVA ESTREMI PARTITA EFFETTO OGNI SINGOLA RIGA
XDARE     = DARE
XAVERE    = AVERE

SELECT CORPO_MOV
GO TOP

SHOW WINDOW PRIMANO2               && RIATTIVA LA FINESTRA DI PRIMA NOTA
RETURN



******************************
PROCEDURE SELE_DOC
******************************
PARA XXX_CONTO,XXX_NUMINT

CREATE CURSOR WORK (;
  WSYSDOC  		C(10), ;
  WANNO    		C(04), ;
  WSELEZ   		C(06), ;
  WTIPDOC  		C(10), ;
  WDESDOC  		C(30), ;
  WCONTO   		C(13), ;
  WNUMDOC  		C(10), ;
  WDATDOC  		C(10), ;
  WDTSCAD  		C(10), ;
  WNUMPROOLD  	C(10), ;
  WDTCHIC  		C(10), ;
  WCOVAL   		C(03), ;
  WCAMBIO  		N(17,10), ;
  WIMPORTO 		N(17,3), ;
  WPAGA    		N(17,3), ;
  WPAGATO  		N(17,3))

INDEX ON WDTSCAD  				                        TAG WSCA
INDEX ON WANNO+WTIPDOC+WNUMDOC                        	TAG WORK

OK_WORK = .F.
SELECT WORK
SET ORDER TO WORK


DO CASE

	CASE  TPROC = "CON"		&& PROCEDURE EXTRACONTABILI : CONTRATTI PARTICOLARI

		=ESTRAE_CONTRATTI()
		SELECT WORK
		SET ORDER TO WSCA

	CASE  TPROC = "FIN"		&& PROCEDURE EXTRACONTABILI : FINANZIAMENTI/MUTUI

		=ESTRAE_FINANZIAMENTI()
		SELECT WORK
		SET ORDER TO WSCA

	CASE  TPROC = "LEA"		&& PROCEDURE EXTRACONTABILI : LEASING

		=ESTRAE_LEASING()
		SELECT WORK
		SET ORDER TO WSCA

	CASE  TPROC = "ASS" 	&& PROCEDURE EXTRACONTABILI : EFFETTI PASSIVI

		=ESTRAE_EFFETTI()
		SELECT WORK
		SET ORDER TO WSCA

	CASE  TPROC = "ASC" 	&& PROCEDURE EXTRACONTABILI : EFFETTI ATTIVI


		=ESTRAE_EFFETTI_ATTIVI()
		SELECT WORK
		SET ORDER TO WSCA


	CASE  TPROC = "MUT" 	&& PROCEDURE EXTRACONTABILI : MUTUI
	CASE  TPROC = "FID" 	&& PROCEDURE EXTRACONTABILI : FIDI
	CASE  TPROC = "FIN" 	&& PROCEDURE EXTRACONTABILI : FINANZIAMENTI

	CASE  TPROC = "GEN" 	&& PROCEDURE EXTRACONTABILI : GENERICHE
	CASE  TPROC = "ALL" 	&& PROCEDURE EXTRACONTABILI : TUTTE
	
	OTHERWISE
	
	   RIT = MESSAGEBOX("Documento non previsto"+"verifica per favore il tipo operazione : campo tipo procedura",62,"CONFERMA")
	   RETURN

ENDCASE


**** preleva la descrizione del conto contabile

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(XXX_CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP
IF EOF()
   VAL_DESC = ""
ELSE
   VAL_DESC = CON_DESCR
ENDIF

SELECT WORK
GO TOP
IF EOF()
	RETURN
ENDIF

HIDE WINDOW PRIMANO2           && NASCONDE LA FINESTRA DI PRIMA NOTA


_TITOLO = "Situazione documenti extracontabili del fornitore : "+ M.DESCRIC
DO FORM FORM\PRIMADOC WITH _TITOLO LINKED
REC_SELE=0

* -->> ESPLODO IN CORPO_MOV I MOVIMENTI DI PRIMA NOTA

SELECT CORPO_MOV
_SOLO_ORA = .T.   && SALVA IMPORTI DELLA FATTURA DIGITATI DI OGNI SINGOLA RIGA
XDARE     = DARE
XAVERE    = AVERE

SELECT WORK
GO TOP

M.TOTDOCU = 0


DO WHILE .NOT. EOF()

   IF WPAGA = 0
     SELECT WORK
     SKIP +1
     LOOP
   ENDIF

   M.EXTRA_NUMPROOLD 	= WNUMPROOLD
   M.EXTRA_NUMDOC 		= WNUMDOC
   M.EXTRA_DATDOC 		= RIBALTA2(WDATDOC)
   M.EXTRA_IMPDOC 		= WPAGA
   M.EXTRA_SYSDOC 		= WSYSDOC

   XWPAGA         		= WPAGA


   && SALVA I RIFERIMENTI DI TUTTI I DOCUMENTI EXTRA CONTABILI DEI FORNITORI SELEZIONATI
   SELECT EXTRAWORK
   APPEND BLANK
   REPLACE EXTRA_NUMPROOLD 		WITH M.EXTRA_NUMPROOLD
   REPLACE EXTRA_NUMDOC 		WITH M.EXTRA_NUMDOC
   REPLACE EXTRA_DATDOC 		WITH M.EXTRA_DATDOC
   REPLACE EXTRA_IMPDOC 		WITH M.EXTRA_IMPDOC
   REPLACE EXTRA_SYSDOC 		WITH M.EXTRA_SYSDOC
   ____STO_GESTENDO_UN_DOC_EXTRACONTABILE = .T.

   && RICALCOLA IL TOTALE DEL DOCUMENTO

   m.totdocu = m.totdocu + M.EXTRA_IMPDOC

   && AGGIORNA CURSORE PRIMA NOTA

   SELECT CORPO_MOV
   REPLACE EXTRA_NUMDOC WITH M.EXTRA_NUMDOC
   REPLACE EXTRA_DATDOC WITH M.EXTRA_DATDOC
   REPLACE EXTRA_IMPDOC WITH M.EXTRA_IMPDOC
   REPLACE EXTRA_SYSDOC WITH M.EXTRA_SYSDOC
   SCATTER MEMVAR MEMO



   SELECT WORK
   SKIP +1

ENDDO

IF PUB_VARPN = .T.          && VARIAZIONE
ELSE
	SELECT CORPO_MOV
	GO TOP
	IF DARE <> 0
	  REPLACE DARE WITH m.totdocu
	ENDIF

	IF AVERE <> 0
	  REPLACE AVERE WITH m.totdocu
	ENDIF
ENDIF


SHOW WINDOW PRIMANO2               && RIATTIVA LA FINESTRA DI PRIMA NOTA
RETURN




*************************************************************************
*   ESTRAE I CONTRATTI 				                                    *
*************************************************************************

FUNCTION ESTRAE_CONTRATTI


        ** ACCESSO PER FORNITORE
		*x_codi = "con_codfor = '" + ALLTRIM(SUBSTR(XXX_CONTO,PUB_SOTTOG,PUB_CONTO)) + "'"
		x_codi = "con_codfor = '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(XXX_CONTO,RAT('.',XXX_CONTO,1)+1))), ALLTRIM(SUBSTR(XXX_CONTO,PUB_SOTTOG,PUB_CONTO))) + "'"  && SERGIO - 18/12/2021
		
		cSql="SELECT * FROM U_CON_DD WHERE "+ x_codi + " order by con_codfor"
		IF !ExecCommand(cSql,"cur_u_con_dd")
		   return(.f.)
		ENDIF

		SELECT cur_u_con_dd
		GO TOP
	
		___TAGGANCIO 	= DAGGANCIO
		
        ** ACCESSO SUL CONTRATTO
		x_codi = "taggancio = '" + ___taggancio + "'"
		cSql="SELECT * FROM U_CON_TT WHERE " + x_codi + " order by con_tipcon,con_numcon"
		IF !ExecCommand(cSql,"cur_u_con_tt")
		   return(.f.)
		ENDIF

		___TIPCON  = CON_TIPCON
		___DESCON  = CON_DESCON
						
		SELECT cur_u_con_dd
		GO TOP


		DO WHILE !EOF()

		   IF DELETED()
		      SKIP +1
		      LOOP
		   ENDIF

	
			** SE STO VARIANDO UNA PRIMA NOTA RIMOSTRO LE RIGHE DEL DOCUMENTO EXTRA CONTABILE
 			IF (PUB_VARPN=.T.) .OR. (PUB_ANNPN=.T.)	
		
				IF !EMPTY(con_numpro)
					IF ALLTRIM(con_numpro) <> ALLTRIM(XXX_NUMINT)  && SCARTA TUTTI I DOCUMENTI DI ALTRE REGISTRAZIONI
						SELECT cur_u_con_dd
						SKIP +1
						LOOP
					ENDIF
				ENDIF

			ELSE

				IF !EMPTY(con_numpro) 					&& SCARTA TUTTI I DOCUMENTI GIA ASSEGNATI
					SELECT cur_u_con_dd
					SKIP +1
					LOOP
				ENDIF
			
			ENDIF



		   SELECT     cur_u_con_dd
		   M.WSELEZ   = SPACE(06)
		   M.WANNO    = SUBSTR(CON_DTCONT,7,4)
		   M.WCONTO   = CON_CODFOR
		   M.WTIPDOC  = ___TIPCON
		   M.WDESDOC  = ___DESCON
		   M.WNUMDOC  = CON_NUMCON
		   M.WDATDOC  = CON_DTCONT
		   M.WSYSDOC  = CON_SYSDOC
		   M.WDTSCAD  = CON_DATSCA
		   M.WCOVAL   = CON_VALUTA
		   M.WIMPORTO = TEURO(M.WCOVAL,CON_RATIMP,RIBALTA2(M.WDATDOC))
		   M.WPAGATO  = 0
		   M.WNUMPROOLD = CON_NUMPRO  &&VECCHIO NUMERO DI REGISTRAZIONE



  		   SELECT WORK
		   APPEND BLANK
		   GATHER MEMVAR MEMO
		   REPLACE WDATDOC  WITH RIBALTA2(M.WDATDOC)


		   SELECT cur_u_con_dd
		   SKIP +1

		ENDDO

		SELECT WORK
		SET ORDER TO WORK
		GO TOP

		OK_WORK = .F.
		DO WHILE .NOT.EOF()       && VERIFICA SE ESISTONO I MOVIMENTI
		   OK_WORK = .T.
		   SKIP +1
		ENDDO

		IF !OK_WORK
		   RETURN
		ENDIF


RETURN

*************************************************************************
*   ESTRAE I FINANZIAMENTI/MUTUI			                            *
*************************************************************************

FUNCTION ESTRAE_FINANZIAMENTI



        ** ACCESSO PER FORNITORE
		*x_codi = "FIN_CODFOR= '" + ALLTRIM(SUBSTR(XXX_CONTO,PUB_SOTTOG,PUB_CONTO)) + "'"
		x_codi = "FIN_CODFOR= '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(XXX_CONTO,RAT('.',XXX_CONTO,1)+1))), ALLTRIM(SUBSTR(XXX_CONTO,PUB_SOTTOG,PUB_CONTO))) + "'"  && SERGIO - 18/12/2021
		
		cSql="SELECT * FROM U_FIN_DD WHERE "+ x_codi + " order by FIN_codfor"
		IF !ExecCommand(cSql,"cur_U_FIN_dd")
		   return(.f.)
		ENDIF

		SELECT cur_U_FIN_dd
		GO TOP
	
		___TAGGANCIO 	= DAGGANCIO
		
        ** ACCESSO SUL CONTRATTO
		x_codi = "taggancio = '" + ___taggancio + "'"
		cSql="SELECT * FROM U_FIN_TT WHERE " + x_codi + " order by FIN_numcon"
		IF !ExecCommand(cSql,"cur_U_FIN_tt")
		   return(.f.)
		ENDIF

		___TIPCON  = "FINANZ"
		___DESCON  = FIN_DESFIN
		___DATCON  = FIN_DATCON
		___VALUTA  = FIN_VALUTA	
						
		SELECT cur_U_FIN_dd
		GO TOP


		DO WHILE !EOF()

		   IF DELETED()
		      SKIP +1
		      LOOP
		   ENDIF

	
			** SE STO VARIANDO UNA PRIMA NOTA RIMOSTRO LE RIGHE DEL DOCUMENTO EXTRA CONTABILE
 			IF (PUB_VARPN=.T.) .OR. (PUB_ANNPN=.T.)	
		
				IF !EMPTY(FIN_numpro)
					IF ALLTRIM(FIN_numpro) <> ALLTRIM(XXX_NUMINT)  && SCARTA TUTTI I DOCUMENTI DI ALTRE REGISTRAZIONI
						SELECT cur_U_FIN_dd
						SKIP +1
						LOOP
					ENDIF
				ENDIF

			ELSE

				IF !EMPTY(FIN_numpro) 					&& SCARTA TUTTI I DOCUMENTI GIA ASSEGNATI
					SELECT cur_U_FIN_dd
					SKIP +1
					LOOP
				ENDIF
			
			ENDIF



		   SELECT     cur_U_FIN_dd
		   M.WSELEZ   = SPACE(06)
		   M.WANNO    = SUBSTR(FIN_DTRIMB,7,4)
		   M.WCONTO   = FIN_CODFOR
		   M.WTIPDOC  = ___TIPCON
		   M.WDESDOC  = ___DESCON
		   M.WNUMDOC  = FIN_NUMCON
		   M.WDATDOC  = ___DATCON
		   M.WSYSDOC  = FIN_SYSDOC
