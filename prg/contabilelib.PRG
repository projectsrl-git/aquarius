*************************************************************
FUNCTION CONTROLLO_CLIENTE_FORNITORE
*************************************************************
LPARAMETERS _PAR_COD_CONTO

LOCAL CLIENTE_FORNITORE

* CONTROLLO SE IL CONTO DELLA GRIGLIA E' UN CLIENTE O UN FORNITORE, SE NO NON ESEGUE NESSUN AUTOMATISMO ALL'INTERNO DELLA GRIGLIA DELLA PRIMA NOTA
X_SOCI = "CON_SOC = '" + PUB_CODSOC + "'"
X_ANNO = "CON_ANNO = '" + PUB_ANNO + "'"
X_CONT = "CON_CONTO = '" + ALLTRIM(_PAR_COD_CONTO) + "'"
X_COND = X_SOCI + " AND " + X_ANNO + " AND " + X_CONT
CSQL   = "SELECT * FROM CONTI WHERE " + X_COND + " ORDER BY CON_SOC,CON_ANNO,CON_CONTO"
IF !EXECCOMMAND(CSQL,"CUR_CONTI_CONTROL")
  RETURN(.F.)
ENDIF

SELECT CUR_CONTI_CONTROL
GO TOP

IF !EOF()
  
  CLI_FORNI  = SUBSTR(CON_TIPOCO,1,1)
  
  IF CLI_FORNI = "C" OR CLI_FORNI = "F"
  	CLIENTE_FORNITORE = .T.
  ELSE
  	CLIENTE_FORNITORE = .F.
  ENDIF

ELSE
	WAIT WINDOWS "DIGITARE IN CONTO CONTABILE SIGNIFICATIVO"
  	CLIENTE_FORNITORE = .F.
ENDIF

RETURN(CLIENTE_FORNITORE)



