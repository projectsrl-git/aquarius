*******************************************************************************
PROCEDURE PRNITALI
******************

IF SUBSTR(_CODA,1,4) = '/NAM'
   _COCO ='8010001      '     && NOTE ACC. ITALIA MACCHINE
   RETURN
ENDIF

IF SUBSTR(_CODA,1,4) = '/NAR'
   _COCO ='8010002      '     && NOTE ACC.RICAMBI ITALIA MACCHINE
   RETURN
ENDIF

IF SUBSTR(_CODA,1,2) = '/M'
   _COCO ='8010001      '     && VENDITE ITALIA MACCHINE
   RETURN
ENDIF

