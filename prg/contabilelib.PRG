Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   SELECT &_DB__
   APPEND BLANK
   GATHER MEMVAR MEMO

   REPLACE CON_IMP_D  WITH 0
   REPLACE CON_IMP_A  WITH 0


   __MESE 		= 1
   __FINE_MESE 	= 12

   DO WHILE .T.

      IF __MESE > __FINE_MESE
         EXIT
      ENDIF

      V_MM = STR(__MESE,2,0)
      IF LEN(ALLTRIM(V_MM)) = 2
      ELSE
         V_MM = '0' + ALLTRIM(V_MM)
      ENDIF

	  REPLACE CON_DA&V_MM WITH 0
	  REPLACE CON_AV&V_MM WITH 0

      __MESE = __MESE +1

   ENDDO


   SELECT CUR_CONTI
   SKIP +1

ENDDO



** RIPORTA I CONTI DEL'ANNO SUCCESSIVO NEL CASO NON ESISTANO SULL'ESERCIZIO DI PARTENZA


__ANNOSUC__ = SUBSTR(_DATAAL__,7,4)


x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + __ANNOSUC__ + "'"
