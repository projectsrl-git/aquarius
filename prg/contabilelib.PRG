	IF !EOF()
		_cRitorno = .T.
	ENDIF
	SELECT &_cNomeCursoreConti
	USE
ELSE
	IF LEN(ALLTRIM(_PAR_COD_CONTO)) < PUB_SOTTOG
		_cRitorno = .T.
	ENDIF
ENDIF
