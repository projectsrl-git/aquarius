IF !ExecRW('','mov_cco','I','','CUR_MOVCCO')
   return(.f.)
ENDIF

**  2 --->>>> AGGIORNA IL D.B. DEI CENTRI DI COSTO

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_annp = "con_anno = '" + PUB_ANNOP + "'"
