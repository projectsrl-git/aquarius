*****************************************************************************
PROCEDURE AUT_PRSI  &&  CONTROPARTITE DA TIPO OPERAZIONE CON TOT.DOC. *******
*****************************************************************************
* DIGITO IMPORTO TOTALE DOCUMENTO
* DIGITO LA DESCRIZIONE CONTABILE
* CARICO NELLA LISTA I CONTI INDICATI NEL TOP ATTRIBUENDO L'IMPORTO DEL DOCUMENTO

*____________ VERIFICA LA GESTIONE DEI CORRISPETTIVI
v_seek   = 'TOP'+ALLTRIM(M.TOP)
v_chiave = 'codice'
cSql="SELECT * FROM para WHERE "+V_CHIAVE+ " = ?V_SEEK"
IF !ExecCommand(cSql,"top_para")
   return(.f.)
ENDIF
SELECT TOP_PARA
GO TOP
IF EOF()
   TIP = " "
ELSE
   TIP = SUBSTR(LIBERA,2,1)
ENDIF

IF TIP = "C"    && CORRISPETTIVI
   DO AUT_CORR
   RETURN
ENDIF

IF (PUB_VARPN=.T.) .OR. (PUB_ANNPN=.T.)
ELSE
   IF ACCODA
      IF !EMPTY(TCOD01)
         STORE SPACE(13) TO M.CECO
         STORE 0         TO M.DARE
         STORE 0         TO M.AVERE
         STORE "NO"      TO M.IVA
         STORE 0         TO M.IMPOSTA
         STORE X_DESMOV  TO M.DESCRIZ
         STORE X_DESMO1  TO M.DESCRI1
         STORE TCOD01    TO M.CONTO
         v_seek   = 'TOP'+ALLTRIM(M.TOP)
         v_chiave = 'codice'
         cSql="SELECT * FROM para WHERE "+V_CHIAVE+ " = ?V_SEEK"
         IF !ExecCommand(cSql,"top_para")
            return(.f.)
         ENDIF
         SELECT TOP_PARA
