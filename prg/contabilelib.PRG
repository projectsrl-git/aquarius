*************************************************************************
* SCALA L'IMPORTO DELLA NOTA ACCREDITO ASSOCIATA ALLE FATTURE           *
*************************************************************************
FUNCTION SCALA_IMPORTO_NOTA_ACCREDITO_DALLA_FATTURA
PARAMETERS _codcli_,_nparti_,_importo_da_scalare_


AXABBSS    = SELECT()

IF EMPTY(ALLTRIM(_nparti_))
	SELECT(AXABBSS)
	RETURN
ENDIF


 SELECT CU_FAT_TT
 GO TOP


 DO WHILE .T.

	IF EOF()
	   EXIT
	ENDIF
	
	IF DELETED()
	   SKIP + 1
	   LOOP
	ENDIF

 	IF ALLTRIM(ord_codcli) = ALLTRIM(_codcli_)
 	ELSE
	   SELECT CU_FAT_TT
	   SKIP + 1
	   LOOP
	ENDIF

 	IF ALLTRIM(ord_nprot) = ALLTRIM(_nparti_)
 	ELSE
	   SELECT CU_FAT_TT
	   SKIP + 1
	   LOOP
	ENDIF

 	IF  ord_valore = 0
	   SELECT CU_FAT_TT
	   SKIP + 1
	   LOOP
	ENDIF

    IF  ord_tranche <= _importo_da_scalare_

       _importo_da_scalare_ = _importo_da_scalare_ - ord_tranche  && deve esistere almeno un'altra fattura

       replace ord_valore    WITH 0								  && per questa fattura non viene emessa riba in quanto compensata
       replace ord_tranche   WITH 0								  && per questa fattura non viene emessa riba in quanto compensata
       replace N_C_ASS_A_FAT WITH "S"

       _importo_da_scalare = _importo_da_scalare_				  && SALVA L'IMPORTO DA SCALARE PER LA FATTURA SUCCESSIVA

       SELECT(AXABBSS)
       RETURN

    ELSE

       replace ord_valore    WITH ord_valore  - _importo_da_scalare_
       replace ord_tranche   WITH ord_tranche - _importo_da_scalare_

       _importo_da_scalare_  = 0

       replace N_C_ASS_A_FAT WITH "S"
       _importo_da_scalare = _importo_da_scalare_				  && SALVA L'IMPORTO DA SCALARE PER LA FATTURA SUCCESSIVA
       SELECT(AXABBSS)
       RETURN

    ENDIF




    SELECT CU_FAT_TT
    SKIP +1

 ENDDO WHILE .T.


_importo_da_scalare = _importo_da_scalare_			&& SALVA L'IMPORTO DA SCALARE PER LA FATTURA SUCCESSIVA

SELECT(AXABBSS)

RETURN


******************************************************
*      CREA SCADENZE ESPLODENDOLE IN UN CURSORE      *
******************************************************
* elabora il cursore in input con la stringa TRANCHE
* ESPLODE le scadenze e le salva nel cursore di output
* cancellando il record correte del cursore di input

FUNCTION CREA_SCADENZE_IN_CURSORE
PARAMETERS _cursore_input,_cursore_output,_tranche


AXABBSS    = SELECT()

*!*	SI SALVA LE VARIABILI DEL RECORD IN INPUT

SELECT &_cursore_input
SCATTER MEMVAR MEMO


IF SCAD_SPE = "S"	&& CONDIZIONI DI PAGAMENTO SPECIALI		
   SELECT &_cursore_output
   APPEND BLANK
   GATHER MEMVAR memo
   SELECT(AXABBSS)
   RETURN
ENDIF



TOT_RIC= 0

SELECT CU_TRANK
GO TOP
DO WHILE .NOT. EOF()



    IF TK_TISCA = "NO" 		&& scarta le tranche non considerate nella gestione delle ricevute bancarie
    	SELECT CU_TRANK
    	SKIP +1
    	LOOP
    ENDIF

    DATA_SCAD = TK_DSCAD
    IMP_TRANK = TK_IMP_SCAD


    TOT_RIC = TOT_RIC + IMP_TRANK
	
    ** ESPLODE TRANCHE
    SELECT &_cursore_output
    APPEND BLANK
    GATHER MEMVAR memo
    REPLACE ORD_TRANCHE  	WITH CAMBIO(M.ORD_VALUTA,IMP_TRANK,M.ORD_CAMBIO)
    REPLACE ORD_DTSCAD   	WITH RIBALTA2(DATA_SCAD)
    REPLACE SCADENZA_ESPLOSA WITH 'S'
	
	SELECT CU_TRANK
	SKIP +1

ENDDO



SELECT(AXABBSS)

RETURN




***************************************************************
*      CREA SCADENZE SPECIALI ESPLODENDOLE IN UN CURSORE      *
***************************************************************
* INTERCETTA LE SCADENZE SPECIALI CONTRO RICEVUTA BANCARIA
* NELL'ARCHIVIO CONDIZIONI PAGAMENTO SPECIALI
* LASCIA INALTERATE LE FATTURE SENZA CONDIZIONI SPECIALI
*
* elabora il cursore in input con la stringa TRANCHE
* ESPLODE le scadenze e le salva nel cursore di output
* cancellando il record correte del cursore di input
*

FUNCTION CREA_SCADENZE_SPECIALI_IN_CURSORE
PARAMETERS _cursore_input,_cursore_output


AXABBSS    = SELECT()

*!*	SI SALVA LE VARIABILI DEL RECORD IN INPUT

  SELECT &_cursore_input
  SCATTER MEMVAR MEMO

  *=SEEK_PARA('CPA',ALLTRIM(M.ORD_CPA),'CODICE','CODICE',"4,10")
  =SEEK_PARA('CPA',ALLTRIM(M.ORD_CPA),'CODICE','CODICE',"4,10","","","",.T.)  && ERASMO - 26/05/2025 - PER CONSIDERARE ANCHE LE C.PAG. DISATTIVATE
  SELECT _pj_para
  GO top
  IF !EOF()
     PUB_CONDSPE = SUBSTR(LIBERA,8,1)		&& CONDIZIONI DI PAGAMENTO SPECIALI  2007-05-05 SERGIO
  ELSE
     PUB_CONDSPE = " "					&& CONDIZIONI DI PAGAMENTO SPECIALI  2007-05-05 SERGIO
  ENDIF

  IF PUB_CONDSPE <> "S"
    	SELECT &_cursore_output				&& LASCIA INALTERATO LA FATTURA SENZA CONDIZIONI DI PAGAMENTO SPECIALI
    	APPEND BLANK
    	GATHER MEMVAR memo
		REPLACE SCADENZA_ESPLOSA WITH ' '
  	    SELECT(AXABBSS)
	    RETURN
  ENDIF


  IF !ExecCommand("select * from scadenze where 0=1","SCADENZE")
	 return(.f.)
  ENDIF

  SELECT SCADENZE
  =AFIELDS(_ARR_CAMPI)
  CREATE CURSOR WPUB_SCAD FROM ARRAY _ARR_CAMPI	
  SELECT WPUB_SCAD
  *INDEX ON RIBALTA2(ORD_DTSCAD) TAG ORD_DTSCAD
  INDEX ON STR(SEQUEN)+RIBALTA2(ORD_DTSCAD) TAG ORD_DTSCAD  && ERASMO - 14/06/2013

  =SCADENZE_SPECIALI(M.TIPRENDO,.F.,.T.,.F.,"CU_FAT_DD")  && CREA UN CAMPO MEMO CON I RIFERIMENTI ALLE SCADENZE SPECIALI


  SELECT WPUB_SCAD					&& CONTIENE SOLO I MOVIMENTI RIBA
  SET ORDER TO ORD_DTSCAD
  GO TOP

  DO WHILE !EOF()


    _TRANCH	   =ORD_TRANCH
	_VALORE	   =ORD_VALORE
	_DTSCAD	   =ORD_DTSCAD
    _DESSCAD   =ALLTRIM(ORD_DESCRI)



    ** ESPLODE TRANCHE
    SELECT &_cursore_output
    APPEND BLANK
    GATHER MEMVAR memo
    REPLACE ORD_TRANCHE  		WITH _TRANCH
    REPLACE ORD_DTSCAD   		WITH RIBALTA2(_DTSCAD)
    REPLACE SCADENZA_ESPLOSA 	WITH 'S'
    REPLACE SCAD_SPE 			WITH 'S'



    SELECT WPUB_SCAD
    SKIP +1

  ENDDO




SELECT(AXABBSS)

RETURN



*!*	**************************************************************
FUNCTION SCADENZE_SPECIALI
*!*	**************************************************************
*!*	FUNZIONE PER LA GESTIONE DELLE SCADENZE SPECIALI
*!*	
*!*	PARAMETRI :
*!*	
*!*		_PPP_UNCINO 		:	CHIAVE DI ACCESSO ALL'ARCHIVIO DELLE SCADENZE SPECIALI
*!*	
*!*	
*!*	
*!*		_PPP_VEDI			:	SE IMPOSTATO A .T. MOSTRA IL FORM PER LA GESTIONE DELLE SCADENZE
*!*	
*!*	
*!*		_PPP_RIBA			:	SE IMPOSTATO A .T. RITORNA UN CURSORE CONTENENTE SOLO LE SCADENZE PER LE RIBA
*!*	
*!*	
*!*		_PPP_CAMPO_MEMO		:	SE IMPOSTATO A .T. RITORNA UN CAMPO MEMO CONTENENTE I RIFERIMENTI DELLE SCADENZE
*!*	
*!*	
*!*		CURSORE_DOCUMENTI	:	CURSORE DOCUMENTO IN CUI INSERIRE I RIFERIMENTI DELLE SCADENZE SPECIALI
*!*	
*!*	


PARAMETERS _PPP_UNCINO,_PPP_VEDI,_PPP_RIBA,_PPP_CAMPO_MEMO,CURSORE_DOCUMENTI,_par_msgbox,_par_msgdiff,_par_flgdiff

IF PCOUNT() < 6
	_par_msgbox = .T.
ENDIF

**=> ERASMO - INIZIO 21/01/2019
IF PCOUNT() < 7
	_par_msgdiff = .F.
ENDIF
**=> ERASMO - FINE 21/01/2019

**=> ERASMO - INIZIO 31/01/2019
IF PCOUNT() < 8
	_par_flgdiff = .F.
ENDIF
**=> ERASMO - FINE 31/01/2019

_SCAD_SELE=SELECT()

RELEASE _SC_TIPRENDO,_SC_SOLORIBA,_SC_CAMPO_MEMO
PUBLIC  _SC_TIPRENDO,_SC_SOLORIBA,_SC_CAMPO_MEMO


_SC_SOLORIBA	= _PPP_RIBA
_SC_CAMPO_MEMO 	= _PPP_CAMPO_MEMO
_SC_TIPRENDO	=_PPP_UNCINO

v_SEEK = _SC_TIPRENDO
IF seek_std('SCADENZE',v_seek,'TIPRENDO','CUR_SCADENZE')
	SELECT CUR_SCADENZE
ELSE
	IF _par_msgbox
		MESSAGEBOX("Nessuna scadenza speciale inserita per questo documento.",48,"Attenzione")
	ENDIF
ENDIF

IF _PPP_VEDI
  DO FORM FORM\MENU_SCADSPE LINKED
  RETURN(.T.)
ENDIF

**=> ERASMO - INIZIO 21/01/2019
*IF _par_msgdiff
IF _par_msgdiff OR _par_flgdiff

    PUB_SCADENZE_SPECIALI_ERRATE = .F.  && SERGIO 2019/01/31

	_SC_TOTALE = 0
	SELECT CUR_SCADENZE
	GO TOP
	SCAN
		_SC_TOTALE = _SC_TOTALE + ORD_TRANCH
	ENDSCAN
	
	IF _SC_TOTALE <> PUB_VALORE
	
	   PUB_SCADENZE_SPECIALI_ERRATE = .T.  && SERGIO 2019/01/31

*!*		   DO PLAYWAV WITH "BLIP.WAV"
	   IF _par_msgdiff  && ERASMO - 31/01/2019
			MESSAGEBOX("Totale condizioni di pagamento speciali diverso dal totale documento non č possibile stampare il documento",48,"Attenzione")
	   ENDIF  			&& ERASMO - 31/01/2019
*!*				XDESCRI="Attenzione "
*!*			   SET CLASSLIB TO "proj_lib.vcx" additive
*!*			   oForm=CreateObject("MsgErr")
*!*			   oform.edit1.Value=""+XDESCRI+CHR(13)+;
*!*						  ""+CHR(13)+;			
*!*						  "Totale condizioni di pagamento speciali diverso dal totale documento: non č possibile stampare il documento"
*!*			   oform.Show
*!*			   RELEASE oForm

	ENDIF
	
	RETURN
ENDIF
**=> ERASMO - FINE 21/01/2019

IF _SC_SOLORIBA

	IF !ExecCommand("select * from scadenze where 0=1","SCADENZE")
	  return(.f.)
	ENDIF

	SELECT SCADENZE
	=AFIELDS(_ARR_CAMPI)
	CREATE CURSOR WPUB_SCAD FROM ARRAY _ARR_CAMPI	
  	SELECT WPUB_SCAD
  	INDEX ON STR(SEQUEN)+RIBALTA2(ORD_DTSCAD) TAG ORD_DTSCAD


	v_SEEK = _SC_TIPRENDO
	IF seek_std('SCADENZE',v_seek,'TIPRENDO','CUR_SCADENZE')
		SELECT CUR_SCADENZE
	ELSE
		IF _par_msgbox
			MESSAGEBOX("Nessuna scadenza speciale inserita per questo documento.",48,"Attenzione")
		ENDIF
		SELECT(_SCAD_SELE)
		RETURN(.F.)
	ENDIF


  	SELECT CUR_SCADENZE
  	INDEX ON STR(SEQUEN)+RIBALTA2(ORD_DTSCAD) TAG ORD_DTSCAD
    SET ORDER TO ORD_DTSCAD
	GO top
	
	DO WHILE !EOF()
	
	    IF ALLTRIM(TIPRENDO)!=ALLTRIM(_SC_TIPRENDO)
	      EXIT
	    ENDIF
	
	    IF _PPP_RIBA .AND. !ORD_RIBA
	      SELECT CUR_SCADENZE
	      SKIP
	      LOOP
	    ENDIF
	
	    _TIPRENDO  =TIPRENDO
	    _CODSOC    =ORD_CODSOC
	    _IDFOR     =ORD_IDFOR
	    _CODCLI    =ORD_CODCLI
	    _RAGSOC    =ORD_RAGSOC
	    _VALUTA    =ORD_VALUTA
	    _CAMBIO    =ORD_CAMBIO
	    _DATORD    =ORD_DATORD
	    _NUMORD    =ORD_NUMORD
	    _TRANCH	   =ORD_TRANCH
	    _VALORE	   =ORD_VALORE
	    _CPA	   =ORD_CPA
	    _SELEZIONE =SELEZIONE
	    _DTSCAD	   =ORD_DTSCAD
	    _RIBA	   =ORD_RIBA
	    _DESSCAD   =ALLTRIM(ORD_DESCRI)

	    SELECT WPUB_SCAD
	    APPEND BLANK

	    REPLACE TIPRENDO  	WITH _TIPRENDO
	    REPLACE ORD_CODSOC  WITH _CODSOC
	    REPLACE ORD_IDFOR   WITH _IDFOR
	    REPLACE ORD_CODCLI  WITH _CODCLI
	    REPLACE ORD_RAGSOC  WITH _RAGSOC
	    REPLACE ORD_VALUTA  WITH _VALUTA
	    REPLACE ORD_CAMBIO  WITH _CAMBIO
	    REPLACE ORD_DATORD  WITH _DATORD
	    REPLACE ORD_NUMORD	WITH _NUMORD
	    REPLACE ORD_TRANCH	WITH _TRANCH
	    REPLACE ORD_VALORE	WITH _VALORE
	    REPLACE ORD_CPA		WITH _CPA
	    REPLACE SELEZIONE 	WITH _SELEZIONE
	    REPLACE ORD_DTSCAD	WITH _DTSCAD
	    REPLACE ORD_RIBA	WITH _RIBA
	    REPLACE ORD_DESCRI	WITH ALLTRIM(_DESSCAD)

	    SELECT CUR_SCADENZE
	    SKIP
	
	ENDDO

  SELECT WPUB_SCAD
  SET ORDER TO ORD_DTSCAD
  GO TOP
  _PROGRE=0

  DO WHILE !EOF()
    _PROGRE=_PROGRE+ORD_TRANCH
    REPLACE PROGRESSIV WITH _PROGRE
    SELECT WPUB_SCAD
    SKIP
  ENDDO

ENDIF

_lScadSpecialeInCommento = 	('ORD' $ CURSORE_DOCUMENTI AND PUB_SSPORD = 1) OR ;
							('FAP' $ CURSORE_DOCUMENTI AND PUB_SSPFAP = 1) OR ;
							('FAT' $ CURSORE_DOCUMENTI AND PUB_SSPFAT = 1) OR ;
							('ORF' $ CURSORE_DOCUMENTI AND PUB_SSPORF = 1)

IF _SC_CAMPO_MEMO

	v_SEEK = _SC_TIPRENDO
	IF seek_std('SCADENZE',v_seek,'TIPRENDO','CUR_SCADENZE')
	  SELECT CUR_SCADENZE
	ELSE
	ENDIF

    PUB_MEMO = ""

  	SELECT CUR_SCADENZE
  	INDEX ON STR(SEQUEN)+RIBALTA2(ORD_DTSCAD) TAG ORD_DTSCAD
    SET ORDER TO ORD_DTSCAD
	GO TOP
	
	DO WHILE !EOF()
	
	    IF ALLTRIM(TIPRENDO)!=ALLTRIM(_SC_TIPRENDO)
	      EXIT
	    ENDIF
	
	    IF EMPTY(PUB_MEMO)
	    	PUB_MEMO = CHR(13) + "Condizioni di pagamento concordate: " + CHR(13)
	    ENDIF
	
	    _TRANCH	   =ORD_TRANCH
	    _DTSCAD	   =ORD_DTSCAD
	    _RIBA	   =ORD_RIBA
	    _DESSCAD   =ALLTRIM(ORD_DESCRI)
	
		PUB_MEMO = PUB_MEMO + " scadenza " + _DTSCAD +  " - " + ALLTRIM(TRANSFORM(_TRANCH,CAMPOMASK(PUB_DECVAL,"99,999,999,999"))) + " - " + _DESSCAD + CHR(13)  && ERASMO - 31/01/2013

	    SELECT CUR_SCADENZE
	    SKIP
	
	ENDDO

    SELECT &CURSORE_DOCUMENTI
    GO TOP
    DELETE FOR ALLTRIM(ORD_CODICE) == "COND-SPEC" AND ALLTRIM(ORD_DESART) == "*** COMMENTO ***" ALL

    SELECT CUR_SCADENZE
    IF RECCOUNT() > 7
    	_lScadSpecialeInCommento = .T.  && FORZO SCADENZE SPECIALI IN NUOVO COMMENTO DOCUMENTO SE PIU' DI 7 SCADENZE (CAPACITA' MAX ARRAYES)
    ENDIF

	IF _lScadSpecialeInCommento  && SCADENZE SPECIALI IN NUOVO COMMENTO DOCUMENTO
		
		IF !EMPTY(PUB_MEMO)
		    SELECT &CURSORE_DOCUMENTI
		    GO TOP
		    M.DAGGANCIO  = DAGGANCIO
		    M.ORS_NUMORD = ORS_NUMORD
		    M.ORS_DATORD = ORS_DATORD
		    M.ORS_CODCLI = ORS_CODCLI
		    M.ORS_RAGSOC = ORS_RAGSOC
		    M.ORD_CODSYS = SYS(2015)
		
		    APPEND BLANK
		    m.ord_codart = SPACE(16)
		    M.ORD_MAGA   = SPACE(06)
		    M.ORD_DESART = "*** COMMENTO ***"
		    M.ORD_DES2   = SPACE(25)
		    M.ORD_UM	 = SPACE(02)
		    M.ORD_IVA	 = SPACE(02)
		    M.ORD_PREZZO = 0
		    M.ORD_QTAORD = 0
		    M.ORD_PRZNET = 0
		    M.ORD_VALORE = 0
		    M.ORD_SC1    = 0
		    M.ORD_SC2    = 0
		    M.ORD_SC3    = 0	
		    M.ORD_NOTE   = PUB_MEMO
		    M.ORD_PUBBLI = " "
		    M.ORD_SEQUEN = 88900
		    M.ORD_CODICE = "COND-SPEC"
		    GATHER MEMVAR MEMO
		ENDIF

	ELSE  && SCADENZE SPECIALI IN VARIABILI ARRAYES DATA(7), IMPORTO(7), DESCR_SCAD(7)
		
		SELECT &CURSORE_DOCUMENTI
		DELETE FOR ALLTRIM(ORD_CODICE) == "COND-SPEC" AND ALLTRIM(ORD_DESART) == "*** COMMENTO ***" ALL  && ERASMO/SERGIO/LUCA - 27/02/2013
				
		*!*	RIPORTA LE DATE DI SCADENZA E IMPORTO NEI VETTORI RELATIVI ALLA GESTIONE DELLE SCADENZE DEL REPORT
		RELEASE DATA
		RELEASE IMPORTO
		RELEASE DESCR_SCAD

		PUBLIC ARRAY DATA(7)
		PUBLIC ARRAY IMPORTO(7)
		PUBLIC ARRAY DESCR_SCAD(7)

		I = 0
		SELECT CUR_SCADENZE
		GO TOP

		DO WHILE (!EOF()) .AND. (I < 7)
			I = I + 1
			DATA[I]			= ORD_DTSCAD
			IMPORTO[I]		= ORD_TRANCH
			DESCR_SCAD[I]	= ALLTRIM(ORD_DESCRI)
			SELECT CUR_SCADENZE
			SKIP +1
		ENDDO

		I = I + 1
		FOR HH = I TO 7
			DATA[HH]		= ""
			IMPORTO[HH]		= 0
			DESCR_SCAD[HH]	= ""
		NEXT
		
	ENDIF

ENDIF

RELEASE _SC_TIPRENDO,_SC_SOLORIBA,_SC_CAMPO_MEMO
_SCAD_SELE=SELECT()

SELECT(_SCAD_SELE)

RETURN(.T.)



