*************************************************************************
*  			 CONVERTE IN EFFETTIVA IN PIANO DEI CONTI                   *
*************************************************************************

PROCEDURE REG_CONVERTE_IN_EFFETTIVA_CONTI



		      P_IMPA= CON_IMP_A
		      P_IMPD= CON_IMP_D
		      IF M.TOP = "CHI"
		         MESE    = "12"
		      ELSE
		         MESE    = SUBSTR(DATAREG,4,2)
		      ENDIF
		      VAR     = "CON_AV"+MESE
		      VAR2    = "CON_DA"+MESE
	
		      CLI_FOR = SUBSTR(CON_TIPOCO,1,1)
			  * CHI_EUR_ITL
			  IF M.TOP = "CHI"
			
			     REPLACE   CON_IMP_D   WITH P_IMPD+CAMBIO(PUB_VALPRE,____DARE,PUB_CAMPRE)
		         REPLACE   CON_IMP_A   WITH P_IMPA+CAMBIO(PUB_VALPRE,____AVERE,PUB_CAMPRE)
		         REPLACE   &VAR2       WITH CAMBIO(PUB_VALPRE,____DARE,PUB_CAMPRE)+&VAR2
		    	 REPLACE   &VAR        WITH CAMBIO(PUB_VALPRE,____AVERE,PUB_CAMPRE)+&VAR

			  ELSE	
			
			     REPLACE   CON_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,____DARE,XCAMBIO)
		         REPLACE   CON_IMP_A   WITH P_IMPA+CAMBIO(XVALUTA,____AVERE,XCAMBIO)
		         REPLACE   &VAR2       WITH CAMBIO(XVALUTA,____DARE,XCAMBIO)+&VAR2
		    	 REPLACE   &VAR        WITH CAMBIO(XVALUTA,____AVERE,XCAMBIO)+&VAR
		
			  ENDIF

		      IF CON_TIPOCO = "C"  OR CON_TIPOCO = "F"
				  IF TI_TOP = "S"	&& FATTURA CLIENTE/FORNITORE
					  IF _NOTAC <> "S"	&& NOTA CREDITO CLIENTE/FORNITORE
					     REPLACE   CON_FATTURA   WITH CON_FATTURA + CAMBIO(XVALUTA,(____DARE+____AVERE),XCAMBIO)
					  ENDIF
				  ENDIF
				  IF _NOTAC = "S"	&& NOTA CREDITO CLIENTE/FORNITORE
				     REPLACE   CON_NOTAC   WITH CON_NOTAC + CAMBIO(XVALUTA,(____DARE+____AVERE),XCAMBIO)
				  ENDIF
		      ENDIF


RETURN

			


*************************************************************************
*  		 CONVERTE IN PREVISIONALE IL PIANO DEI CONTI                    *
*************************************************************************

PROCEDURE REG_CONVERTE_IN_PREVISIONALE_CONTI




  P_IMPA= PRE_IMP_A
  P_IMPD= PRE_IMP_D
  IF M.TOP = "CHI"
     MESE    = "12"
  ELSE
     MESE    = SUBSTR(DATAREG,4,2)
  ENDIF
  VAR     = "PRE_AV"+MESE
  VAR2    = "PRE_DA"+MESE
  CLI_FOR = SUBSTR(CON_TIPOCO,1,1)
  * CHI_EUR_ITL
  IF M.TOP = "CHI"
     REPLACE   PRE_IMP_D   WITH P_IMPD+CAMBIO(PUB_VALPRE,____DARE,PUB_CAMPRE)
     REPLACE   PRE_IMP_A   WITH P_IMPA+CAMBIO(PUB_VALPRE,____AVERE,PUB_CAMPRE)
     REPLACE   &VAR2       WITH CAMBIO(PUB_VALPRE,____DARE,PUB_CAMPRE)+&VAR2
	 REPLACE   &VAR        WITH CAMBIO(PUB_VALPRE,____AVERE,PUB_CAMPRE)+&VAR
  ELSE	
     REPLACE   PRE_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,____DARE,XCAMBIO)
     REPLACE   PRE_IMP_A   WITH P_IMPA+CAMBIO(XVALUTA,____AVERE,XCAMBIO)
     REPLACE   &VAR2       WITH CAMBIO(XVALUTA,____DARE,XCAMBIO)+&VAR2
	 REPLACE   &VAR        WITH CAMBIO(XVALUTA,____AVERE,XCAMBIO)+&VAR
  ENDIF

  IF CON_TIPOCO = "C"  OR CON_TIPOCO = "F"
	  IF TI_TOP = "S"	&& FATTURA CLIENTE/FORNITORE
		  IF _NOTAC <> "S"	&& NOTA CREDITO CLIENTE/FORNITORE
		     REPLACE   PRE_FATTURA   WITH PRE_FATTURA + CAMBIO(XVALUTA,(____DARE+____AVERE),XCAMBIO)
		  ENDIF
	  ENDIF
	  IF _NOTAC = "S"	&& NOTA CREDITO CLIENTE/FORNITORE
	     REPLACE   PRE_NOTAC   WITH PRE_NOTAC + CAMBIO(XVALUTA,(____DARE+____AVERE),XCAMBIO)
	  ENDIF
  ENDIF



RETURN

*************************************************************************
*   AGGIORNAMENTO DEI D.BASECONTI/MOV_CONT A FRONTE DI IVA              *
*************************************************************************
PROCEDURE REG_AGGIVA

* AGGIORNA IL CONTO IVA SE ESISTE IVA
*  - ACCEDO AL PARAMETRO IVA PER PRELEVARE IL CONTO IVA
*  - CREO MOV_CONT CON IL CONTO TROVATO SU TAB_LIBERA
*  - AGGIORNO IL D.B. CONTI CON IL CONTO TROVATO

IF IV  = 'NO'  && NON GESTISCE IVA
   RETURN
ENDIF

v_seek   = 'IVA'+ALLTRIM(IV)
v_chiave = "codice"
IF seek_std('PARA',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   IF VER_CONTO = "C"
      CONTO_IVA=SUBSTR(LIBERA,5,13)                   && CONTO IVA CLIENTI
   ELSE
      IF VER_CONTO = "F"
         CONTO_IVA=SUBSTR(LIBERA,20,20)            && CONTO IVA FORNITORI
      ELSE
         WAIT WINDOW "TOP ne cliente ne fornitore"
         CONTO_IVA=SUBSTR(LIBERA,5,13)             && CONTO IVA CLIENTI
      ENDIF
   ENDIF
   IF !ExecCommand("select * from mov_cont where 0=1","cur_movcont")
      return(.f.)
   ENDIF
   SELECT CUR_MOVCONT
   APPEND  BLANK
   PUB_SEQUEN = PUB_SEQUEN + 10
   REPLACE MOV_SEQUEN WITH PUB_SEQUEN    && M.SEQUEN
   REPLACE MOV_SOC    WITH PUB_CODSOC
   REPLACE MOV_ANNO   WITH PUB_ANNO
   REPLACE MOV_DTREG  WITH RIBALTA2(DATAREG)
   REPLACE MOV_NREGIS WITH ALLTRIM(NREG)
   REPLACE MOV_DTDOC  WITH RIBALTA2(DATADOC)
   REPLACE MOV_ANNODO WITH SUBSTR(MOV_DTDOC,1,4)   &&  23/04/2003

   REPLACE MOV_DTCOMP	WITH RIBALTA2(DATACOMP)			&& SERGIO/ERASMO 04/04/2019
   IF EMPTY(DATACOMP) OR DATACOMP = '  /  /    '		&& SERGIO/ERASMO 04/04/2019
   	  REPLACE MOV_DTCOMP	WITH RIBALTA2(DATADOC)		&& SERGIO/ERASMO 04/04/2019
   ENDIF												&& SERGIO/ERASMO 04/04/2019


   REPLACE MOV_NDOC   WITH NDOC
   REPLACE MOV_TOP    WITH TOPX
   REPLACE MOV_NPROT  WITH ALLTRIM(NPROT)
   REPLACE MOV_CONTO  WITH ALLTRIM(CONTO_IVA)
   REPLACE MOV_IVA    WITH IV
   REPLACE MOV_IMPOST WITH 0
   IF !EMPTY(XDESF)
      REPLACE MOV_DESMOV WITH XDESF
   ELSE
      REPLACE MOV_DESMOV WITH COMM
   ENDIF
   REPLACE MOV_NPART  WITH PUB_NPARF
   REPLACE MOV_DESMO1 WITH COM1
   REPLACE MOV_NUMPRO WITH ALLTRIM(PN_C)
   REPLACE MOV_IMP    WITH IMP
   REPLACE MOV_FATRI  WITH V_FR        && FATTURE FORNITORI IN RITARDO
   REPLACE MOV_BOLLATOIVA    WITH BOLLATOIVA

   REPLACE MOV_EXTRA_NUMDOC WITH M.EXTRA_NUMDOC
   REPLACE MOV_EXTRA_DATDOC WITH M.EXTRA_DATDOC
   REPLACE MOV_EXTRA_IMPDOC WITH M.EXTRA_IMPDOC
   REPLACE MOV_EXTRA_SYSDOC WITH M.EXTRA_SYSDOC

   REPLACE MOV_COSATRATTA 		WITH M.___COSATRATTA
   REPLACE MOV_GRADOIMPORTANZA 	WITH M.___GRADOIMPORTANZA
   REPLACE MOV_FORMAPAGAMENTO 	WITH M.___FORMAPAGAMENTO
   REPLACE MOV_TIPOCONTRATTO 	WITH M.___TIPOCONTRATTO
   REPLACE MOV_CODACQ			WITH M.___CODACQ
   REPLACE MOV_PRIPAGA			WITH M.___PRIPAGA

   REPLACE MOV_PUBBLI           WITH M.MPUBBLI

      * --------  Gestione contabilitŕ previsionale -------- *
	  IF ALLTRIM(PUB_TIPOGE) = "PREVISIONALE"
	      REPLACE MOV_CONTABILITA_PREVISIONALE    WITH "P"
      ELSE
	      REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "
	  ENDIF
      * --------  Gestione contabilitŕ previsionale -------- *

      * --------  Blocca / sblocca registrazione previsionale -------- *
	  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIEFFETTIVA"
	      REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "
	  ENDIF
	  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIPREVISIONALE"
	      REPLACE MOV_CONTABILITA_PREVISIONALE    WITH "P"
	  ENDIF
      * --------  Blocca / sblocca registrazione previsionale -------- *


   * ------- MAX Nuovi Campi Per Euro ------- *
   REPLACE MOV_DTVAL  WITH RIBALTA2(XDATAVAL)
   REPLACE MOV_CAMBIO WITH XCAMBIO
   REPLACE MOV_VALUTA WITH XVALUTA
   * ------- MAX Nuovi Campi Per Euro ------- *

   ** ------- GESTIONE EFFETTI --------**
   REPLACE MOV_NUMATRI WITH M.EFF_NUMATRI
   REPLACE MOV_EFFETDA WITH M.EFF_EFFETDA
   REPLACE MOV_INTEPER WITH M.EFF_INTEPER
   REPLACE MOV_NOTEFF  WITH M.EFF_NOTEFF
   ** ------- GESTIONE EFFETTI --------**

   IF DA <> 0
      REPLACE MOV_TMOV   WITH "D"
   ELSE
      REPLACE MOV_TMOV   WITH "A"
   ENDIF

   IF FATTURA = "S"  							&& SOLO PER FATTURE GESTISCE IL CAMPO MOV_STATO_CEE PER INTRASTAT
 	   REPLACE MOV_STATO_CEE WITH M.STATO_CEE
   ELSE
   	   REPLACE MOV_STATO_CEE WITH ""
   ENDIF


   **==> Gestione del Log
   X_TIPOPE = 'INS'
   X_PROGRA = 'PRIMAFUN'
   X_ARCHIV = 'MOV_CONT'
   X_CODCON = MOV_CONTO
   X_DESCON = MOV_DESMOV
   X_NUMREG = MOV_NREGIS
   X_DATREG = MOV_DTREG
   X_NUMDOC = MOV_NDOC
   X_DATDOC = MOV_DTDOC
   X_VALDOC = MOV_IMP
   =LOG_CONT2(X_TIPOPE,X_PROGRA,X_ARCHIV,X_CODCON,X_DESCON,X_NUMREG,X_DATREG,X_NUMDOC,X_DATDOC,X_VALDOC)
   IF !ExecRW('','mov_cont','I','','CUR_MOVCONT')
      return(.f.)
   ENDIF
ELSE
   PUB_ERRORE=MESSAGEBOX('Errore nella ricerca'+CHR(13)+'del conto IVA',64,'*** ATTENZIONE ***')
   RETURN
ENDIF

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(CONTO_IVA) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecRW(cSql,"CONTI","R")
   return(.f.)
ENDIF
SELECT CONTI
IF RECCOUNT() = 0
   PUB_ERRORE=MESSAGEBOX('Conto IVA inesistente'+CHR(13)+'in parametro IVA',64,'*** ATTENZIONE ***')
ELSE
   C_&VAR=&VAR
   C_IMP_A=CON_IMP_A
   IF DA <> 0
      REPLACE CON_IMP_D   WITH CON_IMP_D+CAMBIO(XVALUTA,IMP,XCAMBIO)
      REPLACE &VAR2       WITH CAMBIO(XVALUTA,IMP,XCAMBIO)+&VAR2       && VAR2 = DARE
   ELSE
      REPLACE CON_IMP_A   WITH CON_IMP_A+CAMBIO(XVALUTA,IMP,XCAMBIO)
      REPLACE &VAR        WITH &VAR+CAMBIO(XVALUTA,IMP,XCAMBIO)        && VAR = AVERE
   ENDIF
ENDIF
IF !ExecRW(cSql,"CONTI","W")
   return(.f.)
ENDIF

RETURN


