	   ENDIF
   ENDIF
   SELECT CORPO_MOV
   
   *** IN CASO DI REGISTRAZIONE DI TIPO FATTURA FORNITORE, DETERMINO IL CONTO PER EVENTUALE VISUALIZZAZIONE ALERT ANTICIPI FORNITORI
   IF M.FATTURA = 'S' AND M.NATURA = 'A'
	   x_soci = "con_soc = '" + PUB_CODSOC + "'"
	   x_anno = "con_anno = '" + PUB_ANNO + "'"
