***************************************
FUNCTION AGGIORNA_MASTRI_SOTTOGRUPPI
PARAMETERS __DB_,__ANNO_,__LUNGHEZZA_
***************************************

		
cSql=""
cNomeCursorSql="CUR_TOTALI"
			
TEXT TO cSql NOSHOW

	SELECT
	 CO.CON_DESCR,
	 CDETT.*
	FROM <<__DB_>> AS CO
	LEFT OUTER JOIN (
	 SELECT
	  SUBSTRING(CON_CONTO,1,<<__LUNGHEZZA_>>) AS CON_CONTO,
	  SUM(CON_IMP_D) AS CON_IMP_D,
	  SUM(CON_DA01) AS CON_DA01,
	  SUM(CON_DA02) AS CON_DA02,
	  SUM(CON_DA03) AS CON_DA03,
	  SUM(CON_DA04) AS CON_DA04,
	  SUM(CON_DA05) AS CON_DA05,
	  SUM(CON_DA06) AS CON_DA06,
	  SUM(CON_DA07) AS CON_DA07,
	  SUM(CON_DA08) AS CON_DA08,
	  SUM(CON_DA09) AS CON_DA09,
	  SUM(CON_DA10) AS CON_DA10,
	  SUM(CON_DA11) AS CON_DA11,
	  SUM(CON_DA12) AS CON_DA12,
	  SUM(CON_IMP_A) AS CON_IMP_A,
	  SUM(CON_AV01) AS CON_AV01,
	  SUM(CON_AV02) AS CON_AV02,
	  SUM(CON_AV03) AS CON_AV03,
	  SUM(CON_AV04) AS CON_AV04,
	  SUM(CON_AV05) AS CON_AV05,
	  SUM(CON_AV06) AS CON_AV06,
	  SUM(CON_AV07) AS CON_AV07,
	  SUM(CON_AV08) AS CON_AV08,
	  SUM(CON_AV09) AS CON_AV09,
	  SUM(CON_AV10) AS CON_AV10,
	  SUM(CON_AV11) AS CON_AV11,
	  SUM(CON_AV12) AS CON_AV12
	 FROM <<__DB_>>
     WHERE  LEN(RTRIM(CON_CONTO)) > <<__LUNGHEZZA_>>
	 GROUP BY SUBSTRING(CON_CONTO,1,<<__LUNGHEZZA_>>)) AS CDETT
	ON CDETT.CON_CONTO=CO.CON_CONTO
	WHERE CO.CON_ANNO='<<__ANNO_>>' AND LEN(CO.CON_CONTO)=<<__LUNGHEZZA_>>  AND CDETT.CON_CONTO IS NOT NULL
	ORDER BY CO.CON_CONTO

	
ENDTEXT

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF		

SELECT CUR_TOTALI
GO TOP


