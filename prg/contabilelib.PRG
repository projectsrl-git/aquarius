**********************************************************************
PROCEDURE AUTO_DATO
**********************************************************************
* Documento prestabilito in modo incompleto da TOP digitando l'importo
* - Digito importo totale documento
* - Digito il conto della prima contropartita
* - In automatico, completa la lista con le contropartite previste in TOP
*   mettendo in dare/avere i relativi importi calcolati

IF PR_TOP1 && CARICA LA LISTA SOLO SE NON  E' GIA' STATO FATTO
   RETURN
ENDIF
PR_TOP1 = .T.

IF (PUB_VARPN=.T.) .OR. (PUB_ANNPN=.T.)
ELSE
   IF ACCODA
      IF IL_CCO = 'S' .OR. IN_CCO = 'S'
         =AUT_CONTROPARTITE_ILLIMITATE(m.totdocu)
      ENDIF
   ENDIF
ENDIF

STORE SPACE(13) TO M.CECO
STORE SPACE(13) TO M.CONTO
STORE 0         TO M.DARE
STORE 0         TO M.AVERE
STORE SPACE(03) TO M.IVA
STORE 0         TO M.IMPOSTA
STORE SPACE(25) TO M.DESCRIZ
STORE SPACE(25) TO M.DESCRI1
STORE SPACE(25) TO M.DESCRIC

STORE SPACE(13) TO CCOD01
STORE SPACE(13) TO CCOD02
STORE SPACE(13) TO CCOD03
STORE SPACE(13) TO CCOD04
STORE SPACE(13) TO CCOD05

RETURN


*******************************************
FUNCTION AUT_CONTROPARTITE_ILLIMITATE
*******************************************
PARAMETERS __VALO


SELECT CORPO_MOV
M.SEQUEN = SEQUEN
M.DAAV   = DAAV		&& SERGIO 15/12/2021
 
TOT_IMPOSTA_RIGA = 0  && ERASMO/SERGIO - 10/02/2022

x_soci = "leg_codsoc = '" + PUB_CODSOC + "'"
x_ctop = "leg_codtop = '" + ALLTRIM(M.TOP) + "'"
cSql   = "SELECT * FROM U_CCO_LE WHERE " + x_soci + " and " + x_ctop + " order by leg_codsoc,leg_codtop,leg_sequen"
IF !ExecCommand(cSql,"cur_cco_le")
   return(.f.)
ENDIF
SELECT CUR_CCO_LE
GO TOP
COUNT TO _CONTA_CONTROPARTITE
GO TOP

IF EOF()
	*!*	    PUB_ERRORE=MESSAGEBOX('Nessuna contropartita inserita nel parametro TOP : '+ALLTRIM(M.TOP),64,'*** ATTENZIONE ***')
	RETURN		
ENDIF


RELEASE __TOTCALCDAR,__TOTCALCAVE
PUBLIC __TOTCALCDAR,__TOTCALCAVE
__TOTCALCDAR = 0
__TOTCALCAVE = 0

STORE SPACE(13)  TO M.CECO
STORE 0          TO M.DARE
STORE 0          TO M.AVERE
STORE SPACE(03)  TO M.IVA
STORE 0          TO M.IMPOSTA
STORE SPACE(25)  TO M.DESCRIZ
STORE SPACE(25)  TO M.DESCRI1


DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   STORE M.LEG_CODIVA TO M.IVA
   STORE M.LEG_NATURA TO M.DAAV	&& SERGIO 15/12/2021

   RELEASE X_VALOR,X_CODSYS,X_OKCCO
   PUBLIC  X_VALOR,X_CODSYS,X_OKCCO
   X_VALOR  = 0
   X_CODSYS = SPACE(10)
   X_OKCCO  = .F.

   IF CALCIMPOS = 'S'
	   X_VALOR  = __VALO 									&& OTTENGO IMPONIBILE+IMPOSTA PER OGNI SINGOLA CONTROPARTITA
   ELSE				
	   IF M.LEG_PERCEN > 0
	   	*** SIMONE - 07/03/2011
		*** SE LA PERCENTUALE E' VALORIZZATA, DEVO CALCOLARE CORRETTAMENTE L'IMPORTO
		*** CON QUESTA FORMULA NON VIENE EFFETTUATO IL CALCOLO CORRETTO
		***   X_VALCONTRO = __VALO / _CONTA_CONTROPARTITE		&& OTTENGO IMPONIBILE+IMPOSTA PER OGNI SINGOLA CONTROPARTITA
	      X_VALCONTRO = __VALO / 100 * M.LEG_PERCEN	
	      DO SCORPORO_IMPOSTA WITH   X_VALCONTRO    		&& OTTIENE L'IMPONIBILE IN X_VALOR
	   ENDIF
   ENDIF

   IF M.LEG_IMPFIS > 0
      X_VALOR = M.LEG_IMPFIS
   ENDIF

   IF M.LEG_PERCEN = 0 AND   M.LEG_IMPFIS = 0   		&& GESTIONE DELLA LISTA SENZA IMPORTI
	   X_VALOR  = 0
   ENDIF

   IF M.LEG_NATURA = "A"
      STORE X_VALOR TO M.AVERE
      STORE 0       TO M.DARE
      __TOTCALCAVE = __TOTCALCAVE + X_VALOR
   ELSE
      STORE X_VALOR TO M.DARE
      STORE 0       TO M.AVERE
      __TOTCALCDAR = __TOTCALCDAR + X_VALOR
   ENDIF

   STORE 0          TO M.IMPOSTA


   IF CALCIMPOS = 'S'
   ELSE
	   IF M.IVA = SPACE(03)
	   ELSE
	      V_SEEK   = 'IVA'+M.IVA
	      V_CHIAVE = 'codice'
	      IF seek_std('para',v_seek,v_chiave,'IVA_PARA')
	         SELECT IVA_PARA
		     M.IVA=UPPER(M.IVA)
	         DO CALCOLO_IMPOSTA
	      ENDIF
	   ENDIF
   ENDIF	


****** SOMMA IL VALORE DELL'IMPOSTA

*!*	   IF M.LEG_NATURA = "A"
*!*	      __TOTCALCAVE = __TOTCALCAVE + M.IMPOSTA
*!*	   ELSE
*!*	      __TOTCALCDAR = __TOTCALCDAR + M.IMPOSTA
*!*	   ENDIF

   IF M.LEG_NATURA = "A"
      __TOTCALCAVE = __TOTCALCAVE + TOT_IMPOSTA_RIGA
   ELSE
      __TOTCALCDAR = __TOTCALCDAR + TOT_IMPOSTA_RIGA
   ENDIF


   STORE SPACE(13)  TO M.CECO
   STORE X_DESMOV   TO M.DESCRIZ
   STORE X_DESMO1   TO M.DESCRI1
   STORE LEG_CODCON TO M.CONTO

   ** 28/06/2023 SERGIO INIZIO: SBIANCA M.DESCRIZ/M.DESCRI1 DURANTE LA GESTIONE DELLE CONTROPARTITE ILLIMITATE: RIPRISTINO I CAMPI
   IF EMPTY(M.DESCRIZ)
   		M.DESCRIZ = SAVE_DESCRIZ
   ENDIF
   IF EMPTY(M.DESCRI1)
   		M.DESCRI1 = SAVE_DESCRI1
   ENDIF	
   ** 28/06/2023 SERGIO FINE: SBIANCA M.DESCRIZ/M.DESCRI1 DURANTE LA GESTIONE DELLE CONTROPARTITE ILLIMITATE: RIPRISTINO I CAMPI

   x_soci = "con_soc = '" + PUB_CODSOC + "'"
   x_anno = "con_anno = '" + PUB_ANNO + "'"
   x_cont = "con_conto = '" + ALLTRIM(M.CONTO) + "'"
   x_cond = x_soci + " and " + x_anno + " and " + x_cont
   Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
   IF !ExecCommand(cSql,"cur_conti")
      return(.f.)
   ENDIF
   SELECT cur_conti
   GO TOP
   IF EOF()
   ELSE
      M.DESCRIC = CON_DESCR
   ENDIF

   X_CODSYS = SYS(2015)
   X_OKCCO  = .F.

   IF M.LEG_CODGRU = SPACE(10) .OR. EMPTY(M.LEG_CODGRU)
   ELSE
      DO AUTO_CGRU
   ENDIF

   IF M.LEG_CODCCO = SPACE(13) .OR. EMPTY(M.LEG_CODCCO)
   ELSE
      DO AUTO_CSIN
   ENDIF

   IF X_OKCCO
      M.CODSYS = X_CODSYS
      M.CODGRU = M.LEG_CODGRU
      M.CODCCO = M.LEG_CODCCO
      M.CECO   = 'SI - C.COSTO'
   ELSE
      M.CODSYS = SPACE(10)
      M.CODGRU = SPACE(10)
      M.CODCCO = SPACE(13)
      M.CECO   = ""
   ENDIF



   SELECT CORPO_MOV
   APPEND BLANK
   M.SEQUEN = M.SEQUEN + 10
   GATHER MEMVAR MEMO

   SELECT CUR_CCO_LE
   SKIP +1

ENDDO




** RICERCA I CONTI ABBUONI  ATTIVI / PASSIVI
* >>> PRELIEVO DEI CONTI ABBUONI PASSIVI/ATTIVI
V_SEEK   = "ABB"+PUB_CODSOC
V_CHIAVE = 'codice'
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   VAL_ABBAT = SUBSTR(LIBERA,1,13)
   VAL_ABBPA = SUBSTR(LIBERA,15,13)
ELSE
   VAL_ABBAT = SPACE(13)
   VAL_ABBPA = SPACE(13)
ENDIF

**** ABBUONO ATTIVO
x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
