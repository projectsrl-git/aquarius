*!*			       REPLACE DARE WITH DARE + ABS(_TOTALE_PAGATO)			&& RIPORTA IL TOTALE PAGATO SULLA CONTROPARTITA
*!*			    ENDIF
*!*			    IF AVERE <> 0
*!*			       REPLACE AVERE WITH AVERE + ABS(_TOTALE_PAGATO)		&& RIPORTA IL TOTALE PAGATO SULLA CONTROPARTITA
*!*			    ENDIF
*!*			ENDIF
*!*			
*!*		ELSE

*!*			SELECT CORPO_MOV
*!*			GO TOP

*!*			DO WHILE !EOF()

*!*			    IF ALLTRIM(CONTO) = ALLTRIM(VAL_CONTC)   	&& SCARTA CONTO ABBUONO SE INSERITO
*!*			      SELECT CORPO_MOV
*!*			      SKIP +1
*!*			      LOOP
*!*			    ENDIF

*!*			    _CONTO_CLI_FOR = CONTO

*!*				x_soci = "con_soc = '" + PUB_CODSOC + "'"
*!*				x_anno = "con_anno = '" + PUB_ANNO + "'"
*!*				x_cont = "con_conto = '" + ALLTRIM(_CONTO_CLI_FOR) + "'"
*!*				x_cond = x_soci + " and " + x_anno + " and " + x_cont
*!*				Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
*!*				IF !ExecCommand(cSql,"cur_conti")
*!*				   return(.f.)
*!*				ENDIF
*!*				SELECT cur_conti
*!*				GO TOP
*!*			    IF !EOF()
*!*			        IF CON_TIPOCO = "C"             		&& SCARTA I CLIENTI
*!*				     SELECT CORPO_MOV
*!*				     SKIP +1
*!*				     LOOP
*!*				    ENDIF
*!*			    ENDIF

*!*			    SELECT CORPO_MOV
*!*						
*!*				IF NO_AUT = "S"        && NESSUN AUTOMATISMO
*!*				ELSE
*!*					IF _TOTALE_PAGATO < 0
*!*				
*!*				       REPLACE AVERE  WITH + ABS(_TOTALE_PAGATO)		&& RIPORTA IL TOTALE PAGATO SULLA CONTROPARTITA BANCA PER NOTE CREDITO
*!*				       REPLACE DARE WITH 0				

*!*			        ELSE
*!*			        	
*!*			  		    IF DARE <> 0
*!*					       REPLACE DARE WITH ABS(_TOTALE_PAGATO)		&& RIPORTA IL TOTALE PAGATO SULLA CONTROPARTITA BANCA
*!*					    ENDIF
*!*					    IF AVERE <> 0
*!*					       REPLACE AVERE WITH ABS(_TOTALE_PAGATO)		&& RIPORTA IL TOTALE PAGATO SULLA CONTROPARTITA BANCA
*!*					    ENDIF

*!*					ENDIF
*!*				ENDIF


*!*				REPLACE ___FLCURS WITH "OK"
*!*			    EXIT

*!*			ENDDO
*!*		ENDIF
*!*	ENDIF

**** RICALCOLA I TOTALI DARE/AVERE ESCLUDENDOLA CONTROPARTITA BANCA PER LA COMPENSAZIONE


SELECT CORPO_MOV
GO TOP

_TDARE  = 0
_TAVERE = 0

DO WHILE !EOF()

    IF ___FLCURS = "OK"   		&& SCARTA LA CONTROPARTITA BANCA
     SELECT CORPO_MOV
     SKIP +1
     LOOP
    ENDIF


    IF DARE > 0
      _TDARE = _TDARE + DARE
    ENDIF

    IF AVERE > 0
      _TAVERE  = _TAVERE  + AVERE
    ENDIF


    SELECT CORPO_MOV
    SKIP +1

ENDDO

**** MI RIPOSIZIONO SU CONTROPARTITA E CONTROAGGIORNO COMPENSANDO IN DARE O IN AVERE

*!*	IF NO_AUT = "S"        && NESSUN AUTOMATISMO
*!*	ELSE
*!*		SELECT CORPO_MOV
*!*		GO TOP


*!*		_SALDO = _TDARE  -  _TAVERE

*!*		DO WHILE !EOF()

*!*		    IF ___FLCURS <> "OK"   		&& SCARTO TUTTI I MOVIMENTI NO CONTROPARTITA BANCA
*!*		     SELECT CORPO_MOV
*!*		     SKIP +1
*!*		     LOOP
*!*		    ENDIF
*!*		
*!*		    IF _SALDO > 0 							&& COMPENSAZIONI
*!*		       REPLACE AVERE  WITH  ABS(_SALDO)
*!*		       REPLACE DARE   WITH  0
*!*		    ELSE
*!*		       REPLACE DARE   WITH  ABS(_SALDO)		&& STO PAGANDO FATTURE
*!*		       REPLACE AVERE  WITH  0
*!*		    ENDIF

*!*		    EXIT
*!*		
*!*		ENDDO
*!*	ENDIF


*!*	IF PINCAMULTI <> "S"  && GESTIONE DEI PAGAMENTI MULTIPLI ATTIVA

*!*		*** VERIFICA INCROCIATA SUGLI IMPORTI DELLA LISTA :
*!*		*** NEL CASO SIANO STATI FATTI DEI CALCOLI ECCEDENTI AL VALORE DIGITATO TOTALE DEL TOCUMENTO :
*!*		*** AZZERA I VALORI DARE,AVERE,IMPOSTA E MOSTRA COMUNQUE I CONTI CONTABILI INDICATI NELLE CONTROPARTITE ILLIMITATE DALL'UTENTE


*!*		SELECT CORPO_MOV
*!*		GO TOP

*!*	    SUM DARE   TO ___TDARE
*!*	    SUM AVERE  TO ___TAVERE

*!*	    IF ___TDARE = ___TAVERE

*!*	    	_TOTALE_PAGATO = ABS(___TDARE)

*!*	    ELSE

*!*	    	IF ___TDARE > ___TAVERE
*!*	    		_TOTALE_PAGATO = ABS(___TDARE)
*!*	    	ELSE
*!*	    		_TOTALE_PAGATO = ABS(___TAVERE)  	
*!*	    	ENDIF

*!*	    ENDIF



*!*		IF M.TOTDOCU < ABS(_TOTALE_PAGATO)   && CASO IN CUI NON CONOSCO L'IMPORTO DA PAGARE , UTENTE DIGITA 1 SU TOT.DOCUMENTOE QUINDI DEVORICALCOLARE IL TOTALEDELDOCUMENTO

*!*		   M.TOTDOCU = ABS(_TOTALE_PAGATO)
*!*		
*!*		ENDIF


*!*		SELECT CORPO_MOV
*!*		GO TOP

*!*		__VERY_DARE 			= 0
*!*		__VERY_AVERE 			= 0

*!*		DO WHILE .NOT. EOF()

*!*			IF DELETED()

*!*				SELECT CORPO_MOV
*!*				SKIP +1
*!*				LOOP

*!*			ENDIF

*!*		    IF DARE <> 0
*!*			    __VERY_DARE = __VERY_DARE + DARE + IMPOSTA	
*!*			    IF __VERY_DARE  > M.TOTDOCU
*!*				          REPLACE DARE 			WITH 0
*!*				          REPLACE IMPOSTA		WITH 0
*!*			    ENDIF
*!*		    ENDIF
*!*		
*!*		    IF AVERE <> 0
*!*			    __VERY_AVERE = __VERY_AVERE + AVERE + IMPOSTA	
*!*			    IF __VERY_AVERE > M.TOTDOCU
*!*				          REPLACE AVERE			WITH 0
*!*				          REPLACE IMPOSTA		WITH 0
*!*			    ENDIF
*!*		    ENDIF
*!*		

*!*			SELECT CORPO_MOV
*!*			SKIP +1

*!*		ENDDO

*!*	ENDIF

SELECT CORPO_MOV
GO TOP


SHOW WINDOW PRIMANO2               && RIATTIVA LA FINESTRA DI PRIMA NOTA
RETURN



