	Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
	IF !ExecCommand(cSql,"cur_conti")
	   return(.f.)
	ENDIF
	SELECT cur_conti
	GO TOP
	IF EOF()
	   VAL_DESCABBPA = ""
	ELSE
	   VAL_DESCABBPA = CON_DESCR
	ENDIF


	IF M.LEG_PERCEN = 0 AND   M.LEG_IMPFIS = 0   		&& GESTIONE DELLA LISTA SENZA IMPORTI
	ELSE
		IF M.TOTDOCU > __DIFDA 							&& IMPORTO DEL DOCUMENTO SUPERIORE DEL SALDO CALCOLATO

		   PUB_ERRORE=MESSAGEBOX('Il totale del documento non quadra : riporto la differenza sul conto abbuoni '+CHR(13)+'per cortesia verifica se OK',64,'*** ATTENZIONE ***')

		   SELECT CORPO_MOV
		   SCATTER MEMVAR MEMO

		   * REIMPOSTA LE VARIABILI   	

		   M.SEQUEN = M.SEQUEN + 10
		   M.IVA	= "NO"
		
		   STORE 0         		 TO M.DARE
		   STORE 0         		 TO M.AVERE
		   STORE 0         		 TO M.IMPOSTA
		   STORE SPACE(13) 		 TO M.CECO
		   STORE X_DESMOV  		 TO M.DESCRIZ
		   STORE X_DESMO1  		 TO M.DESCRI1
		   IF __TOTCALCDAR  >  __TOTCALCAVE
			   STORE ABS(__DIFDIF)     	TO M.DARE
			   STORE VAL_ABBAT 		    TO M.CONTO
			   STORE VAL_DESCABBAT   	TO M.DESCRIC
		   ELSE
			   STORE ABS(__DIFDIF)	    TO M.AVERE
			   STORE VAL_ABBPA 			TO M.CONTO
			   STORE VAL_DESCABBPA   	TO M.DESCRIC
		   ENDIF
		
		   APPEND BLANK
		   GATHER MEMVAR MEMO
		ENDIF
	ENDIF

ENDIF

IF M.LEG_PERCEN = 0 AND   M.LEG_IMPFIS = 0   		&& GESTIONE DELLA LISTA SENZA IMPORTI
ELSE
	IF M.TOTDOCU < __DIFDA 							&& IMPORTO DEL DOCUMENTO INFERIORE DEL SALDO CALCOLATO

	   PUB_ERRORE=MESSAGEBOX('Il totale del documento non quadra : riporto la differenza sul conto abbuoni '+CHR(13)+'per cortesia verifica se OK',64,'*** ATTENZIONE ***')


	   SELECT CORPO_MOV
	   SCATTER MEMVAR MEMO

	   * REIMPOSTA LE VARIABILI   	

	   M.SEQUEN = M.SEQUEN + 10
	   M.IVA	= "NO"
	
	   STORE 0          TO M.DARE
	   STORE 0          TO M.AVERE
	   STORE 0    	    TO M.IMPOSTA
	   STORE SPACE(13)  TO M.CECO
	   STORE X_DESMOV   TO M.DESCRIZ
	   STORE X_DESMO1   TO M.DESCRI1

	   IF __TOTCALCDAR  >  __TOTCALCAVE
		   STORE ABS(__DIFDIF)	    TO M.AVERE			&&IMPORTO DIGITATO NEGATIVO
		   STORE VAL_ABBPA 			TO M.CONTO
		   STORE VAL_DESCABBPA   	TO M.DESCRIC
	   ELSE
		   STORE ABS(__DIFDIF)     	TO M.DARE
		   STORE VAL_ABBAT 			TO M.CONTO
		   STORE VAL_DESCABBAT   	TO M.DESCRIC
	   ENDIF
	
	   APPEND BLANK
	   GATHER MEMVAR MEMO


	ENDIF
ENDIF


RETURN



***************************
FUNCTION RIPORTAI                          && RIPORTA IL VALORE SUL COSTO
***************************

RIPORTO   = M.IMPOSTA-IVINDE
M.IMPOSTA = IVINDE                         && IMPOSTA INDEDUCIBILE

IF RIPORTO = 0
   RIPORTO   = M.IMPOSTA
   M.IMPOSTA = 0                           && IMPOSTA INDEDUCIBILE 100%
ENDIF

IF M.DARE <> 0                             && RIPORTO LA DIFFERENZA SUL CONTO
   M.DARE = M.DARE + RIPORTO
ENDIF

IF M.AVERE <> 0                            && RIPORTO LA DIFFERENZA SUL CONTO
   M.AVERE = M.AVERE + RIPORTO
ENDIF

* QUADRATURA DOCUMENTO INDEDUCIBILE

TOTD_DOPO = M.DARE + M.AVERE + M.IMPOSTA
DIF_IMPOS = ABS(M.TOTDOCU - TOTD_DOPO)

IF DIF_IMPOS <> 0
   IF PERIVAI = 100                        && IVA INDEDUCIBILE AL 100%
      IF M.DARE <> 0                       && RIPORTO LA DIFFERENZA SUL CONTO
         M.DARE = M.DARE + DIF_IMPOS
      ENDIF
      IF M.AVERE <> 0                      && RIPORTO LA DIFFERENZA SUL CONTO
         M.AVERE = M.AVERE + DIF_IMPOS
      ENDIF
   ELSE
      IF M.DARE <> 0
         IF M.DARE != INT(M.DARE)
            SCARTO=M.DARE-INT(M.DARE)
            M.DARE=M.DARE-SCARTO
         ENDIF
      ENDIF
      IF M.AVERE <> 0
         IF M.AVERE != INT(M.AVERE)
            SCARTO=M.AVERE-INT(M.AVERE)
            M.AVERE=M.AVERE-SCARTO
         ENDIF
      ENDIF                                                                                 && AGGIUNTO FABIANO
      M.IMPOSTA = M.IMPOSTA + SCARTO
   ENDIF
ENDIF

RETURN


*************************
PROCEDURE CALCOLO_IMPOSTA
*************************

SELECT IVA_PARA
LIB     = VAL(SUBSTR(LIBERA,1,3))
PERIVAI = VAL(SUBSTR(LIBERA,110,3))
TIPOIVA = SUBSTR(LIBERA,100,1)
SCARTO  = 0

**=> ERASMO - INIZIO 21/10/2022
V_DTIPOMOV = ""
v_seek	= 'IVA'+IIF(LEN(ALLTRIM(CODICE)) > 3, ALLTRIM(SUBSTR(CODICE,4,3)), ALLTRIM(CODICE))
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'TMP_PARA')
   SELECT TMP_PARA
   V_DTIPOMOV = DTIPOMOV
ENDIF
SELECT IVA_PARA
IF UPPER(ALLTRIM(V_DTIPOMOV)) == 'S'
	PERIVAI = 0
ENDIF
**=> ERASMO - FINE 21/10/2022

RELEASE TOT_IMPOSTA_RIGA
PUBLIC TOT_IMPOSTA_RIGA
TOT_IMPOSTA_RIGA=0



IF ALLTRIM(TIPOIVA) <> "I"                   && VERIFICA SE IVA INDEDUCIBILE
   IF XVALUTA = "ITL" .OR. XVALUTA="LIT"
      M.IMPOSTA     =ROUND(((M.DARE+M.AVERE)*LIB/100)+.49,0)
   ELSE
      M.IMPOSTA     =ROUND(((M.DARE+M.AVERE)*LIB/100)+.0000,2)
   ENDIF

   TOT_IMPOSTA_RIGA = M.IMPOSTA


   RETURN
ENDIF

** GESTIONE IVA INDEDUCIBILE AL XXX%

IF XVALUTA = "ITL" .OR. XVALUTA="LIT"
   M.IMPOSTA     =ROUND(((M.DARE+M.AVERE)*LIB/100)+.49,0)
ELSE
   M.IMPOSTA     =ROUND(((M.DARE+M.AVERE)*LIB/100)+.0000,2)
ENDIF

TOT_IMPOSTA_RIGA = M.IMPOSTA
M.TTOTDOCU= M.DARE+M.AVERE+M.IMPOSTA


IF PERIVAI = 0
   RETURN
ENDIF

IVINDE      =M.IMPOSTA*(PERIVAI/100)

IF XVALUTA = "ITL" .OR. XVALUTA="LIT"
   IVINDE   =ROUND(IVINDE,0)
ELSE
   IVINDE   =ROUND(IVINDE,2)
ENDIF

RIPORTO     =M.IMPOSTA-IVINDE
M.IMPOSTA  =IVINDE                              && IMPOSTA INDEDUCIBILE

IF RIPORTO = 0
   RIPORTO   = M.IMPOSTA
   M.IMPOSTA = 0                                && IMPOSTA INDEDUCIBILE 100%
ENDIF

IF M.DARE <> 0                                  && RIPORTO LA DIFFERENZA SUL CONTO
   M.DARE = M.DARE + RIPORTO
ENDIF

IF M.AVERE <> 0                                 && RIPORTO LA DIFFERENZA SUL CONTO
   M.AVERE = M.AVERE + RIPORTO
ENDIF

* QUADRATURA DOCUMENTO INDEDUCIBILE

TOTD_DOPO = M.DARE + M.AVERE + M.IMPOSTA


*DIF_IMPOS = ABS(M.TOTDOCU - TOTD_DOPO)
DIF_IMPOS = ABS(M.TTOTDOCU - TOTD_DOPO)


IF DIF_IMPOS <> 0
   IF PERIVAI = 100                         && IVA INDEDUCIBILE AL 100%
      IF M.DARE <> 0                         && RIPORTO LA DIFFERENZA SUL CONTO
         M.DARE = M.DARE + DIF_IMPOS
      ENDIF
      IF M.AVERE <> 0                        && RIPORTO LA DIFFERENZA SUL CONTO
         M.AVERE = M.AVERE + DIF_IMPOS
      ENDIF
   ELSE
      IF XVALUTA = "ITL" .OR. XVALUTA="LIT"
         IF M.DARE <> 0                       && AGGIUNTO FABIANO
            IF M.DARE != INT(M.DARE)
               SCARTO=M.DARE-INT(M.DARE)
               M.DARE=M.DARE-SCARTO
            ENDIF
         ENDIF                                                                                 && AGGIUNTO FABIANO
         IF M.AVERE <> 0                     && AGGIUNTO FABIANO
            IF M.AVERE != INT(M.AVERE)
               SCARTO=M.AVERE-INT(M.AVERE)
               M.AVERE=M.AVERE-SCARTO
            ENDIF
         ENDIF                                                                                 && AGGIUNTO FABIANO
       	 M.IMPOSTA = M.IMPOSTA + SCARTO
	  ELSE	
         M.IMPOSTA = M.IMPOSTA + DIF_IMPOS
	  ENDIF
   ENDIF

ENDIF

RETURN


