IF _VERIFICA_IMPONIBILE
	IF __PLAFOND_RESIDUO  < _IMPONIBILE_ESENTE
	
	    IF _MOSTRA_MESSAGGIO
		    DO PLAYWAV WITH "BLIP.WAV"
		    XDESCRI="Attenzione "
		    SET CLASSLIB TO "proj_lib.vcx" additive
		    oForm=CreateObject("MsgErr")
   			oform.edit1.Value=""+XDESCRI+CHR(13)+;
	 		  		  "Fornitore in esenzione iva"+CHR(13)+;			
			 		  "Plafond residuo : "+STR(__PLAFOND_RESIDUO,13,2)+CHR(13)+;			
			 		  "Imponibile      : "+STR(_IMPONIBILE_ESENTE,13,2)+CHR(13)+CHR(13)+;			
					  "Esenzione esaurita !!!"
		    oform.Show
		    RELEASE oForm
		ENDIF
				
		_RIT_OK_IVA = .F.	&& NON CONFERMA IL CODICE IVA ESENTE IN QUANTO E' SCADUTA L'ESENZIONE

    ENDIF
ELSE

    IF !PUB_PLAFACQMSG 	 && 2015/08/06 MOSTRA IL MESSAAGGIO SOLO AL RAGGIUNGIMENTO DEL LIMITE PREVISTO
	    DO PLAYWAV WITH "BLIP.WAV"
	    XDESCRI="Attenzione "
	    SET CLASSLIB TO "proj_lib.vcx" additive
	    oForm=CreateObject("MsgErr")
	    oform.edit1.Value=""+XDESCRI+CHR(13)+;
		 		  "Fornitore in esenzione iva"+CHR(13)+CHR(13)+;			
		 		  "Plafond attribuito : "+STR(__PLAFOND_ATTRIBUITO,13,2)+CHR(13)+;			
		 		  "Plafond residuo    : "+STR(__PLAFOND_RESIDUO,13,2)+CHR(13)+;			
				  ""
	    oform.Show
	    RELEASE oForm
	ENDIF
	
ENDIF


SELECT(AXCERCAZPLAF)

RETURN(_RIT_OK_IVA)

