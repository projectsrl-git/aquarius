*************************************************************************
FUNCTION CARICA_SALDI_DA_PRIMA_NOTA
*************************************************************************
PARA _DB__,_DATADAL__,_DATAAL__



SS=STR(SELECT())




IF !ExecCommand("select * from conti where 0=1","conti_curs")
   return(.f.)
ENDIF

SELECT conti_curs
AA = AFIELDS(CONTIXX)
CREATE CURSOR &_DB__ FROM ARRAY CONTIXX			&& CREA UN CURSORE DINAMICO DEL PIANO DEI CONTI CON I SALDI ANCHE DELL'ANNO PRECEDENTE
INDEX ON CON_SOC+CON_ANNO+ALLTRIM(CON_CONTO) 	TAG CONTO ADDITIVE

