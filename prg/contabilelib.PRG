****************************************
PROCEDURE _STARTAQ
****************************************
* Parametro n.1 : TIPO PARAMETRO BASE
* Parametro n.2 : TIPO PARAMETRO EFFETTIVO
* Parametro n.3 : CODICE DI ACCESSO PER LA SEEK
* Parametro n.4 : VALORE DA ASSEGNARE
* Parametro n.5 : PUNTO DI PARTENZA DEL VALORE IN LIBERA
* Parametro n.6 : DESCRIZIONE PARAMETRO
* Parametro n.7 : CREA O NO IL PARAMETRO ETERNO UNCINO PER GLI AGGANCI SU DOCUMENTI TT/DD

PARA _TIPO1,_TIPO2,_CODICE,_VALORE,_PARTEN,_DESCRI,_UNCINO

__KK    = _TIPO1+_TIPO2+_CODICE
__KKU   = _TIPO1+_TIPO2
__DD    = _DESCRI

IF _PARTEN = 1
   __LLNEW = _VALORE
ELSE
   __LLNEW = SPACE(_PARTEN -1)+ _VALORE
ENDIF

__LEN   = LEN(__LLNEW)

IF !ExecRW("select * from para where codice = ?__KK","para","R")
   return
ENDIF
SELECT PARA
IF reccount() <> 0
   IF _PARTEN = 1
      __LLOLD = _VALORE + SUBSTR(LIBERA,__LEN+1,200)
   ELSE
      __LLOLD = SPACE(_PARTEN -1)+ _VALORE + SUBSTR(LIBERA,__LEN+1,200)
   ENDIF
   REPLACE LIBERA WITH __LLOLD
   WAIT WINDOWS "Parametro "+ALLTRIM(_DESCRI)+ " aggiornato correttamente" NOWAIT TIMEOUT 5
ELSE
   APPEND BLANK
   REPLACE CODICE WITH __KK
   REPLACE DESCRI WITH __DD
   REPLACE LIBERA WITH __LLNEW
   IF _UNCINO
	   APPEND BLANK
	   REPLACE CODICE WITH __KKU
	   REPLACE DESCRI WITH __DD
	   REPLACE LIBERA WITH PUB_ANNO+"000000"
   ENDIF
   WAIT WINDOWS "Parametro "+ALLTRIM(_DESCRI)+ " inserito correttamente" NOWAIT TIMEOUT 5
ENDIF

IF !ExecRW("","para","W")
   return
ENDIF

RETURN(.T.)


