   SCATTER MEMVAR MEMO

   M.DTREG       = RIBALTA2(M.PAR_DTREG)
   M._XNREG      = M.PAR_NREG
   M.INDICE      = ALLTRIM(M.PAR_NUMFAT)
   M.DESMOV      = M.PAR_DESMOV
