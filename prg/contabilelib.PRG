								*!*	CREA IL QUINTO CURSORE CONTENENTE IL RECORD DI SALDO DELLE PARTITE SIA APERTE CHE CHIUSE									

									*SELECT '    ' AS id_unique,* FROM cu_saldi_for INTO CURSOR CUR_SALDI_FOR

                                    =RIPORTA_CAMPI_ANAGRAFICA_FORNITORE("cu_saldi_for")

