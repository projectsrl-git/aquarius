x_cond = x_soci + " and " + x_data
Csql   = "select * from mov_cont where " + x_cond + " order by mov_soc,mov_dtreg,mov_conto"
IF !ExecCommand(cSql,"mov_cont")
   return(.f.)
ENDIF
SELECT MOV_CONT
GO TOP
QU = 0

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF


   IF EMPTY(MOV_CONTABILITA_PREVISIONALE) 		&& SCARTA I MOVIMENTI NON EFFETTIVI
   ELSE
      SKIP +1
      LOOP
   ENDIF


   IF MOV_TOP = "CHI"
	  IF !F_CHIUSURA 							&& NON ELABORA I MOVIMENTI DI CHIUSURA
  	     SKIP +1
	     LOOP
	  ENDIF	
   ENDIF

   DA  = 0
   AV  = 0

   IF MOV_TMOV  = "D" .OR. MOV_TMOV  = "A"
   ELSE
 	  WAIT WINDOW "Registrazione senza D/A"+STR(MOV_NREGIS,10,0)+"<<<<<<<<<<<<"
  	  SKIP +1
	  LOOP
   ENDIF

   IF MOV_TMOV  = "D"
      DA =  MOV_IMP
   ENDIF
   IF MOV_TMOV  = "A"
      AV =  MOV_IMP
   ENDIF

   XCONTO  = MOV_CONTO
   DATAREG = MOV_DTREG
   XVALUTA = MOV_VALUTA
   XCAMBIO = MOV_CAMBIO
   XANNO   = MOV_ANNO

*!*	IF ALLTRIM(XCONTO) = '30310117600'
*!*	SET STEP ON
*!*	ENDIF
*!*		

   SELECT &_DB__
   SET ORDER TO CONTO
   V_SEEK = PUB_CODSOC+__ANNO__+ALLTRIM(XCONTO)
   SEEK V_SEEK
   IF FOUND()


      MESE     = SUBSTR(DATAREG,6,2)
      D_ARE    = "CON_DA"+MESE
      A_VERE   = "CON_AV"+MESE
      P_IMPD	= CON_IMP_D
      P_IMPA	= CON_IMP_A
      IF DA <> 0
         *REPLACE &D_ARE      WITH CAMBIO(XVALUTA,&D_ARE+DA,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 20/05/2011
         REPLACE &D_ARE      WITH &D_ARE + CAMBIO(XVALUTA,DA,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 09/04/2018
      ENDIF
      IF AV <> 0
         *REPLACE &A_VERE     WITH CAMBIO(XVALUTA,&A_VERE+AV,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 20/05/2011
         REPLACE &A_VERE     WITH &A_VERE + CAMBIO(XVALUTA,AV,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 09/04/2018
	  ENDIF	

   	  TDARE  = CON_DA01 + CON_DA02 + CON_DA03 + CON_DA04 + CON_DA05 + CON_DA06 + CON_DA07 + CON_DA08 + CON_DA09 + CON_DA10 + CON_DA11 + CON_DA12
   	  TAVERE = CON_AV01 + CON_AV02 + CON_AV03 + CON_AV04 + CON_AV05 + CON_AV06 + CON_AV07 + CON_AV08 + CON_AV09 + CON_AV10 + CON_AV11 + CON_AV12
	
   	  REPLACE CON_IMP_D WITH TDARE
   	  REPLACE CON_IMP_A WITH TAVERE


   ELSE


	      WAIT WINDOW "Conto inesistente :"+XCONTO


*!*		  SELECT &_DB__
*!*		  SET ORDER TO CONTO
*!*		  V_SEEK = PUB_CODSOC+XANNO+ALLTRIM(XCONTO) 	&& ACCEDE AL PIANO DEI CONTI DELL'ANNO SUCCESSIVO PER PRELEVARE LA DESCRIZIONE DEI CAMPI
*!*		  SEEK V_SEEK
*!*		  IF FOUND()
*!*		
*!*		    __CON_SOC    = CON_SOC
*!*		    __CON_ANNO   = __ANNO__
*!*	      	__CON_CONTO  = CON_CONTO
*!*	      	__CON_DESCR  = CON_DESCR
*!*	      	__CON_TIPOCO = CON_TIPOCO
*!*	        __CON_PARIVA = CON_PARIVA
*!*	        __CON_POSBIL = CON_POSBIL
*!*	
*!*	      ELSE
*!*	
*!*	 	    __CON_SOC    = PUB_CODSOC
*!*		    __CON_ANNO   = __ANNO__
*!*	      	__CON_CONTO  = ALLTRIM(XCONTO)
*!*	      	__CON_DESCR  = "CONTO INESISTENTE NELL'ESERCIZIO :"+__ANNO__
*!*	      	__CON_TIPOCO = CON_TIPOCO
*!*	        __CON_PARIVA = ""
*!*	        __CON_POSBIL = CON_POSBIL
*!*	
*!*	
*!*	      ENDIF


*!*	      SELECT &_DB__
*!*	      APPEND BLANK

*!*	      REPLACE CON_SOC    WITH  __CON_SOC
*!*	      REPLACE CON_ANNO   WITH  __ANNO__
*!*	  	  REPLACE CON_CONTO  WITH  __CON_CONTO
*!*	  	  REPLACE CON_DESCR  WITH  __CON_DESCR
*!*	  	  REPLACE CON_TIPOCO WITH  __CON_TIPOCO
*!*	      REPLACE CON_PARIVA WITH  __CON_PARIVA
*!*	      REPLACE CON_POSBIL WITH  __CON_POSBIL

*!*	
*!*	      MESE     = SUBSTR(DATAREG,6,2)
*!*	      D_ARE    = "CON_DA"+MESE
*!*	      A_VERE   = "CON_AV"+MESE
*!*	      P_IMPD	= CON_IMP_D
*!*	      P_IMPA	= CON_IMP_A
*!*	      IF DA <> 0
*!*	         REPLACE &D_ARE      WITH CAMBIO(XVALUTA,&D_ARE+DA,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 20/05/2011
*!*	      ENDIF
*!*	      IF AV <> 0
*!*	         REPLACE &A_VERE     WITH CAMBIO(XVALUTA,&A_VERE+AV,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 20/05/2011
*!*		  ENDIF	
*!*	
*!*	   	  TDARE  = CON_DA01 + CON_DA02 + CON_DA03 + CON_DA04 + CON_DA05 + CON_DA06 + CON_DA07 + CON_DA08 + CON_DA09 + CON_DA10 + CON_DA11 + CON_DA12
*!*	   	  TAVERE = CON_AV01 + CON_AV02 + CON_AV03 + CON_AV04 + CON_AV05 + CON_AV06 + CON_AV07 + CON_AV08 + CON_AV09 + CON_AV10 + CON_AV11 + CON_AV12
*!*		
*!*	   	  REPLACE CON_IMP_D WITH TDARE
*!*	   	  REPLACE CON_IMP_A WITH TAVERE
*!*	
*!*	

   ENDIF

   QU=QU+1
   WAIT WINDOW "Movimenti elaborati "+STR(QU,10,0) NOWAIT

   SELECT MOV_CONT
   SKIP +1

ENDDO






SELECT &SS




RETURN

****************************************************************************************************************************************************************************************
PROCEDURE SBC300  && STAMPA BILANCIO A SEZIONI CONTRAPPOSTE
****************************************************************************************************************************************************************************************
PARA V_POSBIL,V_CONINI,V_CONFIN,V_DAL,V_AL,PUB_ANNO,V_DBASE,__STAMPA_SOLO_I_CLIENTI_FORNITORI,__STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI,__NON_STAMPA_I_CLIENTI_FORNITORI,__INCLUDE_PREVISIONALE


IF PCOUNT() = 6
   V_DBASE = "CONTI"
   __STAMPA_SOLO_I_CLIENTI_FORNITORI  = .F.
   __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI = .F.
   __NON_STAMPA_I_CLIENTI_FORNITORI   = .F.
   __INCLUDE_PREVISIONALE			  = .F.
ENDIF

IF PCOUNT() = 7
   __STAMPA_SOLO_I_CLIENTI_FORNITORI  = .F.
   __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI = .F.
   __NON_STAMPA_I_CLIENTI_FORNITORI   = .F.
   __INCLUDE_PREVISIONALE			  = .F.
ENDIF


V_SALDOI = 0

CREATE CURSOR TEMPO_DB;
  (CONTO C(13),DESCRI C(40),DARE N(20,8),AVERE N(20,8), SALDO N(20,8), MOVIM C(02))

CREATE CURSOR WOPE_SB1 (DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),DA_SALDOI N(20,8),DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CODCON)  TAG WOPE_SB1 ADDITIVE

CREATE CURSOR SWOPE_SB1 (DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),DA_SALDOI N(20,8),DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CODCON)  TAG SWOPE_SB1 ADDITIVE

CREATE CURSOR SAVE_WOPE_SB1 (DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),DA_SALDOI N(20,8),DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CODCON)  TAG IOPE_SB1 ADDITIVE

CREATE CURSOR WOPE_SB2 (AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),AV_SALDOI N(20,8),AV_TIPOCO C(1))
INDEX ON ALLTRIM(AV_CODCON)  TAG WOPE_SB2 ADDITIVE

CREATE CURSOR SWOPE_SB2  (AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),AV_SALDOI N(20,8),AV_TIPOCO C(1))
INDEX ON ALLTRIM(AV_CODCON)  TAG SWOPE_SB2  ADDITIVE

CREATE CURSOR WOPE_SBC (DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),ZA_SALDOI N(20,8))

CREATE CURSOR WOPE_DA (DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),ZA_SALDOI N(20,8))
INDEX ON ALLTRIM(DA_CODCON)  TAG WOPE_DA ADDITIVE

CREATE CURSOR WOPE_AV (DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),ZA_SALDOI N(20,8))
INDEX ON ALLTRIM(AV_CODCON)  TAG WOPE_AV ADDITIVE

SET NEAR ON
SELECT &V_DBASE
SET ORDER TO CONTO
SEEK PUB_CODSOC+PUB_ANNO

DETTAGLI = .T.
PRIMOD   = .T.
PRIMOA   = .T.
V_GRSG   = ""
V_OLDD   = ""
V_OLDA   = ""

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED() .OR. CON_ANNO != PUB_ANNO
      SKIP +1
      LOOP
   ENDIF





	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
	   
	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,PUB_GRUPPOCF)==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF


	ELSE

	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,(PUB_SOTTOG -1))==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF

	ENDIF
	** SERGIO 18/12/2021 FINE  





   IF LEN(ALLTRIM(CON_CONTO)) < (PUB_SOTTOG -1)
      SKIP +1
      LOOP
   ENDIF

   IF CON_TIPOCO = "O"    && SCARTA CONTI ORDINARI
      =CREA_SALDI_PIANO_CONTI(V_DBASE)
      SKIP +1
      LOOP
   ENDIF

   IF CON_POSBIL  <> V_POSBIL
      SKIP +1
      LOOP
   ENDIF

   IF __STAMPA_SOLO_I_CLIENTI_FORNITORI
	   IF CON_TIPOCO  =  "C" OR CON_TIPOCO  =  "F"
       ELSE
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF

  *** SIMONE - 07/04/2009 ( ATTIVATO SU RICHIESTA SO.PR.AD. [PAOLA/LINA] )
   IF __NON_STAMPA_I_CLIENTI_FORNITORI
	   IF CON_TIPOCO  =  "C" OR CON_TIPOCO  =  "F"
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF



   V_CONTO  = CON_CONTO
   V_TIPOCO = CON_TIPOCO
   V_DESCR  = CON_DESCR
   

	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
  		V_GRSG   = SUBSTR(V_CONTO,1,(PUB_GRUPPOCF))
	ELSE
   		V_GRSG   = SUBSTR(V_CONTO,1,(PUB_SOTTOG -1))
	ENDIF
	** SERGIO 18/12/2021 FINE  


   v_seek 	 = "BIL"+V_GRSG
   v_chiave  = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      IF SUBSTR(LIBERA,1,1)=="S"
         DETTAGLI=.T.
      ELSE
         DETTAGLI=.F.
      ENDIF
   ELSE
      DETTAGLI=.F.
   ENDIF

   SELECT &V_DBASE

   V_TOTD=0
   V_TOTA=0
   FOR H=V_DAL TO V_AL
       VD="CON_DA"+STRTRAN(STR(H,2)," ","0")
       VA="CON_AV"+STRTRAN(STR(H,2)," ","0")
       V_TOTD=V_TOTD+&VD
       V_TOTA=V_TOTA+&VA

	   IF __INCLUDE_PREVISIONALE
	       VD="PRE_DA"+STRTRAN(STR(H,2)," ","0")
	       VA="PRE_AV"+STRTRAN(STR(H,2)," ","0")
	       V_TOTD=V_TOTD+&VD
	       V_TOTA=V_TOTA+&VA
       ENDIF
   NEXT

   IF OK_SALDI
      IF V_TOTD = 0 .AND. V_TOTA = 0
         SELECT &V_DBASE
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   DO SBCAGWF

   SELECT &V_DBASE
   SKIP +1

ENDDO



IF NON_EVIDENZIA_DIFFERENZE_CONTRAPPOSTE_ECONOMICI .AND. V_POSBIL = "E"

	SELECT WOPE_SB1
	GO TOP

	DO WHILE  .T.
	   IF EOF()
	      EXIT
	   ENDIF

	   IF DELETED()
		  SELECT WOPE_SB1
	      SKIP +1
	      LOOP
	   ENDIF	


		** SERGIO 18/12/2021 INIZIO
		IF PUB_CONTOSIMILCEE 

		   IF LEN(ALLTRIM(DA_CODCON)) <= (PUB_GRUPPOCF)
			  SELECT WOPE_SB1
		      SKIP +1
		      LOOP
		   ENDIF

		ELSE

		   IF LEN(ALLTRIM(DA_CODCON)) <= (PUB_SOTTOG -1)
			  SELECT WOPE_SB1
		      SKIP +1
		      LOOP
		   ENDIF

		ENDIF
		** SERGIO 18/12/2021 FINE  




	
	   SCATTER MEMVAR MEMO
	   	
	   SELECT SAVE_WOPE_SB1
	   APPEND BLANK
	   GATHER MEMVAR MEMO
	
	   SELECT WOPE_SB1
	   SKIP +1
	ENDDO

	SELECT SAVE_WOPE_SB1
	GO TOP

	DO WHILE  .T.
	   IF EOF()
	      EXIT
	   ENDIF

	   IF DELETED()
		  SELECT SAVE_WOPE_SB1
	      SKIP +1
	      LOOP
	   ENDIF	


	

		** SERGIO 18/12/2021 INIZIO
		IF PUB_CONTOSIMILCEE 

		   __CONTO  = SUBSTR(DA_CODCON,1,(PUB_GRUPPOCF))

		ELSE

		   __CONTO  = SUBSTR(DA_CODCON,1,(PUB_SOTTOG -1))

		ENDIF
		** SERGIO 18/12/2021 FINE  

	
	   SELECT WOPE_SB1
	   SET ORDER TO WOPE_SB1
	   SET NEAR ON
	   SET EXACT ON
	
	   SEEK __CONTO  			&& VERIFICO SE ESISTE IL GRUPPO/MASTRO NELLA SEZIONE : SE NO DEVO SPOSTARE ILCONTONELL'ALTRA SEZIONE

	   IF  FOUND()
		   SELECT SAVE_WOPE_SB1
		   DELETE				&& IL CONTO E' GIA' SOTTO IL SUO MASTRO PER CUI VA BENE COSI E NEL CURSORE DI SALVATAGGIO LO TOLGO
	   ELSE 	
		   SELECT SAVE_WOPE_SB1
		   REPLACE DA_TOTALE WITH DA_TOTALE * -1
		   SELECT WOPE_SB1
	   ENDIF	

	
	   SELECT SAVE_WOPE_SB1
	   SKIP +1
	ENDDO

	SELECT SAVE_WOPE_SB1
	GO TOP


	SELECT WOPE_SB2
	GO TOP

	DO WHILE  .T.
	   IF EOF()
	      EXIT
	   ENDIF

	   IF DELETED()
		  SELECT WOPE_SB2
	      SKIP +1
	      LOOP
	   ENDIF	


		** SERGIO 18/12/2021 INIZIO
		IF PUB_CONTOSIMILCEE 

		   IF LEN(ALLTRIM(AV_CODCON)) <= (PUB_GRUPPOCF)
			  SELECT WOPE_SB2
		      SKIP +1
		      LOOP
		   ENDIF

		ELSE

		   IF LEN(ALLTRIM(AV_CODCON)) <= (PUB_SOTTOG -1)
			  SELECT WOPE_SB2
		      SKIP +1
		      LOOP
		   ENDIF
		   
		ENDIF
		** SERGIO 18/12/2021 FINE  	
	
	
	   SCATTER MEMVAR MEMO
	   	
	   SELECT SWOPE_SB2
	   APPEND BLANK
	   GATHER MEMVAR MEMO
	
	   SELECT WOPE_SB2
	   SKIP +1
	ENDDO

	SELECT SWOPE_SB2
	GO TOP


	DO WHILE  .T.
	   IF EOF()
	      EXIT
	   ENDIF

	   IF DELETED()
		  SELECT SWOPE_SB2
	      SKIP +1
	      LOOP
	   ENDIF	


		** SERGIO 18/12/2021 INIZIO
		IF PUB_CONTOSIMILCEE 
		
		   __CONTO  = SUBSTR(AV_CODCON,1,PUB_GRUPPOCF)

		ELSE
		   __CONTO  = SUBSTR(AV_CODCON,1,(PUB_SOTTOG -1))
	
		ENDIF
		** SERGIO 18/12/2021 FINE 	
	
	
