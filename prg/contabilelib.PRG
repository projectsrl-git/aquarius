	RETURN
ENDIF

_CONTO_DA_CONTROLLARE = SUBSTR(_CONTO,1,AT('.',_CONTO,_NR_OCCORRENZA))  && CONTO DEL LIVELLO PRECEDENTE

IF EMPTY(_CONTO_DA_CONTROLLARE)
	RETURN
ENDIF

SELECT CONTI_CONTROLLATI
GO TOP
_SEEK = _CONTO_DA_CONTROLLARE
SEEK _SEEK
IF FOUND()
	RETURN
ENDIF

_TROVATO = .F.
_DESCR = ""
_POSBIL = "" 
_TIPOCO = ""

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cnto = "con_conto = '" + _CONTO_DA_CONTROLLARE + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cnto 
cSql = "select * from conti where " + x_cond
IF !ExecCommand(cSql,"CHECK_CONTI")
	RETURN .F.
ENDIF
SELECT CHECK_CONTI
GO TOP
IF !EOF()
	_TROVATO = .T.
	_DESCR  = CON_DESCR
	_POSBIL = CON_POSBIL 
	_TIPOCO = CON_TIPOCO
	**=> ERASMO/SERGIO - INIZIO 10/02/2023
	cSql = "UPDATE conti SET CON_PADRE = 1 where " + x_cond
	IF !ExecCommand(cSql,"UPD_CONTI")
		RETURN .F.
	ENDIF
	SELECT CHECK_CONTI
	**=> ERASMO/SERGIO - FINE 10/02/2023
ENDIF

SELECT CONTI_CONTROLLATI
APPEND BLANK
REPLACE KCONTO WITH _CONTO_DA_CONTROLLARE

IF EMPTY(ALLTRIM(_DESCR))
	REPLACE KDESCR WITH "Conto contabile: "+_CONTO_DA_CONTROLLARE
ELSE
	REPLACE KDESCR WITH _DESCR
ENDIF
REPLACE KPAT_ECO WITH _POSBIL 					&& _CON_POSBIL SERGIO 21/10/2021
REPLACE KTIPOCO  WITH _TIPOCO 					&& _CON_TIPOCO SERGIO 21/10/2021

REPLACE PRESENTE WITH _TROVATO

DO VERIFICA_CONTO_PIU_LIVELLI_SINGOLO_CONTO WITH _CONTO_DA_CONTROLLARE


ENDPROC






****************************************************************
FUNCTION SCORPRA_CODICE_CLIENTE_FORNITORE_SE_SIMILCEE
****************************************************************
* SCORPORA IL CODICE CLIENTE/FORNITORE DAL CONTO CONTABILE SE SIMILCEE
LPARAMETERS _CONTO_CONTABILE_SIMILCEE


S22SZ=STR(SELECT())


_POS_PUNTO = RAT('.',_CONTO_CONTABILE_SIMILCEE,1)							&& CERCA LA POSIZIONE DELL'ULTIMO PUNTO 
_CONTO_CLI_FOR = SUBSTR(_CONTO_CONTABILE_SIMILCEE,_POS_PUNTO + 1, 13)		&& CODICE CLIENTE/FORNITORE
_CONTO_CLI_FOR = TRC(PUB_LCL,ALLTRIM(_CONTO_CLI_FOR))						&& CODICE CLIENTE/FORNITORE


SELECT &S22SZ


RETURN _CONTO_CLI_FOR 


****************************************************************
FUNCTION DECODIFICA_TIPO_CONTO
****************************************************************
*!*	DECODIFICA IL TIPO DI CONTO
*!*	TIPOLOGIA CONTO CONTABILE
*!*	1 ATTIVO
*!*	2 PASSIVO
*!*	3 RICAVI
*!*	4 COSTI
*!*	5 CONTI D'ORDINE
*!*	6 IVA DETRAIBILE
*!*	7 IVA A DEBITO
*!*	8 CONTO TRANSITORIO

LPARAMETERS __TipoConto ,__TipoCliFor,__descrizione_conto 

S22SZ=STR(SELECT())

DO CASE


	CASE __TipoConto  = 1 		&& ATTIVO
		M.CON_TIPOCO  = "X"
		
	CASE __TipoConto  = 2 		&& PASSIVO
		M.CON_TIPOCO  = "X"

	CASE __TipoConto  = 3 		&& RICAVI
		M.CON_TIPOCO  = "X"

	CASE __TipoConto  = 4 		&& COSTI
		M.CON_TIPOCO  = "X"

	CASE __TipoConto  = 5 		&& CONTI D'ORDINE
		M.CON_TIPOCO  = "O"

	CASE __TipoConto  = 6 		&& IVA DETRAIBILE
		M.CON_TIPOCO  = "I"

	CASE __TipoConto  = 7 		&& IVA A DEBITO
		M.CON_TIPOCO  = "I"

	CASE __TipoConto  = 8 		&& CONTO TRANSITORIO
		M.CON_TIPOCO  = "X"

	OTHERWISE
		M.CON_TIPOCO  = "X"


ENDCASE

IF __TipoCliFor = "1"	&& E' UN CLIENTE
	M.CON_TIPOCO  = "C"
ENDIF
IF __TipoCliFor = "2"	&& E' UN FORNITORE
	M.CON_TIPOCO = "F"
ENDIF

IF "IVA" $ UPPER(ALLTRIM(__DESCRIZIONE_CONTO))
	M.CON_TIPOCO = "I"
ENDIF

IF "I.V.A." $ UPPER(ALLTRIM(__DESCRIZIONE_CONTO))
	M.CON_TIPOCO = "I"
ENDIF

IF "I.V.A" $ UPPER(ALLTRIM(__DESCRIZIONE_CONTO))
	M.CON_TIPOCO = "I"
ENDIF

IF "C/I.V.A" $ UPPER(ALLTRIM(__DESCRIZIONE_CONTO))
	M.CON_TIPOCO = "I"
ENDIF


SELECT &S22SZ


RETURN M.CON_TIPOCO


*************************************************************************************************************************************************************************************************
PROCEDURE SBCMLIV  && STAMPA BILANCIO PER STRUTTURA PIANO DEI CONTI MULTILIVELLO
*************************************************************************************************************************************************************************************************
LPARAMETERS V_POSBIL,V_CONINI,V_CONFIN,V_DAL,V_AL,PUB_ANNO,V_DBASE,__STAMPA_SOLO_I_CLIENTI_FORNITORI,__STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI,___ANNOP,__NON_STAMPA_I_CLIENTI_FORNITORI,__INCLUDE_PREVISIONALE,__STAMPA_CONTI_ORDINE,__OK_AAPREC

IF PCOUNT() = 6
   V_DBASE = "CONTI"
   __STAMPA_SOLO_I_CLIENTI_FORNITORI  = .F.
   __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI = .F.
   ___ANNOP = ""
   __NON_STAMPA_I_CLIENTI_FORNITORI   = .F.
   __INCLUDE_PREVISIONALE			  = .F.
   __STAMPA_CONTI_ORDINE			  = .F.
ENDIF

IF PCOUNT() = 7
   __STAMPA_SOLO_I_CLIENTI_FORNITORI  = .F.
   __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI = .F.
   ___ANNOP = ""
   __NON_STAMPA_I_CLIENTI_FORNITORI   = .F.
   __INCLUDE_PREVISIONALE			  = .F.
   __STAMPA_CONTI_ORDINE			  = .F.
ENDIF

*!*	_SEC_INI = SECONDS() &&  2025-06-05-SERGIO

**=> ERASMO - INIZIO 31/05/2022
*** CARICAMENTO BILANCIO ANNO CORRENTE
cSql=""
cNomeCursorSql=V_DBASE
x_cond = "ANNO = '" + PUB_ANNO + "'"
IF !EMPTY(V_POSBIL)
	x_cond = x_cond + " AND POSBIL = '" + V_POSBIL + "'"
ENDIF
IF !__STAMPA_CONTI_ORDINE
	x_cond = x_cond + " AND C_ORD <> 'S'"
ENDIF
IF !EMPTY(V_CONINI)
	x_cond = x_cond + " AND CONTO >= '" + V_CONINI + "'"
ENDIF
IF !EMPTY(V_CONFIN)
	x_cond = x_cond + " AND CONTO <= '" + V_CONFIN + "'"
ENDIF
IF __STAMPA_SOLO_I_CLIENTI_FORNITORI
	x_cond = x_cond + " AND CLI_FOR = 'S'"
ENDIF
TEXT TO cSql NOSHOW
	SELECT CAST(0 as bit) AS NO_STP, CAST(0 AS NUMERIC(19,2)) AS SALDOP, * FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> ORDER BY ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6
ENDTEXT
**=> ERASMO - FINE 31/05/2022
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

*!*	** 2025-06-05-SERGIO INIZIO CALCOLA I SECONDI DI ELABORAZIONE
*!*	_SEC_FIN = SECONDS()
*!*	_FASE = "FASE 08 modulo SBCMLIV caricamento bilancio da VISTA_BILANCIO_P_E_MLIV, secondi impiegati: "
*!*	=SCRIVI_CURSORE_SECOND(_FASE,_SEC_INI,_SEC_FIN)	 
*!*	** 2025-06-05-SERGIO FINE CALCOLA I SECONDI DI ELABORAZIONE


SELECT &V_DBASE
INDEX ON ALLTRIM(CONTO) TAG I_CONTO
*INDEX ON ORDINE1+ORDINE2+ORDINE3+ORDINE4 TAG I_ORDINE
INDEX ON ORDINE1+ORDINE2+ORDINE3+ORDINE4+ORDINE5+ORDINE6 TAG I_ORDINE  && ERASMO - 31/05/2022

IF __OK_AAPREC
		
	**=> ERASMO - INIZIO 31/05/2022
	*** CARICAMENTO BILANCIO ANNO PRECEDENTE
	cSql=""
	cNomeCursorSql="TMP_DETT_PAT"
	x_cond = "ANNO = '" + ALLTRIM(STR(VAL(PUB_ANNO)-1)) + "'"
	x_cond = x_cond + " AND DARE+AVERE > 0 AND POSBIL = 'P' AND C_ORD <> 'S'"
	IF !EMPTY(V_CONINI)
		x_cond = x_cond + " AND CONTO >= '" + V_CONINI + "'"
	ENDIF
	IF !EMPTY(V_CONFIN)
		x_cond = x_cond + " AND CONTO <= '" + V_CONFIN + "'"
	ENDIF
	IF __STAMPA_SOLO_I_CLIENTI_FORNITORI
		x_cond = x_cond + " AND CLI_FOR = 'S'"
	ENDIF
	TEXT TO cSql NOSHOW
		SELECT * FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> ORDER BY ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6
	ENDTEXT
	**=> ERASMO - FINE 31/05/2022
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
	SELECT TMP_DETT_PAT
	GO TOP
	SCAN
		_CONTO = ALLTRIM(CONTO)
		
*!*			IF _CONTO = '3.1.1.1152'
*!*				SET STEP ON
*!*			ENDIF
		
		_SALDOP = DARE - AVERE
		*SELECT &V_DBASE
		*REPLACE SALDOP WITH SALDOP + _SALDOP FOR LIKE(ALLTRIM(_CONTO)+'*', ALLTRIM(CONTO))
		_SEEK = ALLTRIM(_CONTO)
		SELECT &V_DBASE
		SET ORDER TO I_CONTO
		GO TOP
		SEEK _SEEK
		IF FOUND()
			SELECT &V_DBASE
			REPLACE SALDOP WITH _SALDOP
		ENDIF
	ENDSCAN
	
	EPP_UTILE_PROVVISORIO_PRECEDENTE=""
	v_seek 	 = "EPP001"     && PARAMETRO UTILE ESERCIZIO PROVVISORIO PRECEDENTE
	v_chiave = "codice"
	IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
	   SELECT CUR_PARA
	   EPP_UTILE_PROVVISORIO_PRECEDENTE=ALLTRIM(LIBERA)
	ENDIF

	EPP_PERDITA_PROVVISORIO_PRECEDENTE=""
	v_seek 	 = "EPP002"     && PARAMETRO PERDITA ESERCIZIO PROVVISORIO PRECEDENTE
	v_chiave = "codice"
	IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
	   SELECT CUR_PARA
	   EPP_PERDITA_PROVVISORIO_PRECEDENTE=ALLTRIM(LIBERA)
	ENDIF
	
	IF EMPTY(EPP_UTILE_PROVVISORIO_PRECEDENTE) AND EMPTY(EPP_PERDITA_PROVVISORIO_PRECEDENTE)
	   _seek = PUB_CODSOC
	   x_cod = "fin_codsoc = '" + _seek + "'"
	   cSql="SELECT * FROM chiusura WHERE " + x_cod
	   IF !ExecCommand(cSql,"chiusura")
		   return(.f.)
	   ENDIF
	   SELECT CHIUSURA
	   GO TOP
	   M.FIN_UTIESE = FIN_UTIESE
	   M.FIN_PERESE = FIN_PERESE
	ELSE
	   M.FIN_UTIESE = EPP_UTILE_PROVVISORIO_PRECEDENTE
	   M.FIN_PERESE = EPP_PERDITA_PROVVISORIO_PRECEDENTE
	ENDIF
		
	**=> ERASMO - INIZIO 31/05/2022
	*** CARICAMENTO RIEPILOGHI BILANCIO ANNO PRECEDENTE
	cSql=""
	cNomeCursorSql="TMP_RIEP_PAT"
	x_cond = "ANNO = '" + ALLTRIM(STR(VAL(PUB_ANNO)-1)) + "'"
	x_cond = x_cond + " AND PADRE <> '' AND LIVELLO = 2"
	IF !EMPTY(V_POSBIL)
		x_cond = x_cond + " AND POSBIL = '" + V_POSBIL + "'"
	ENDIF
	TEXT TO cSql NOSHOW
		SELECT COALESCE(SUM(DARE),0) AS TOT_DARE, COALESCE(SUM(AVERE),0) AS TOT_AVERE FROM (
			SELECT 'P' AS GRP, 1 AS ORDINE0, 'ATTIVO' AS TIPOREC, CONTO, DESCR, DARE, AVERE FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO = 1
			UNION
			SELECT 'P' AS GRP, 2 AS ORDINE0, 'PASSIVO' AS TIPOREC, CONTO, DESCR, DARE, AVERE FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO IN (2,0)
		) AS MAIN
	ENDTEXT
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
	SELECT TMP_RIEP_PAT
	GO TOP
	**=> ERASMO - FINE 31/05/2022
	
   VD_TOTALE_PREC = TOT_DARE
   VA_TOTALE_PREC = TOT_AVERE 
   *VX_TOTALE_PREC = VD_TOTALE_PREC - VA_TOTALE_PREC && SALDO PER UTILE O PERDITA ESERCIZIO DA RIPORTARE SUGLI ECONOMICI A QUADRATURA DEL SALDO DEI PATRIMONIALI ANNO PRECEDENTE
   VX_TOTALE_PREC = VA_TOTALE_PREC - VD_TOTALE_PREC  && && ERASMO - 10/10/2025
   
   _COD_CONTO = ""
   _DES_CONTO = ""
   IF VX_TOTALE_PREC > 0
  		_COD_CONTO = M.FIN_PERESE  && PERDITA D'ESERCIZIO
   ELSE
  		_COD_CONTO = M.FIN_UTIESE  && UTILE D'ESERCIZIO
   ENDIF
   
	_SEEK = ALLTRIM(_COD_CONTO)
	SELECT &V_DBASE
	SET ORDER TO I_CONTO
	GO TOP
	SEEK _SEEK
	IF FOUND()
		SELECT &V_DBASE
*!*			REPLACE DARE 		 		WITH DARE + VD_TOTALE_PREC
*!*			REPLACE AVERE 		 		WITH AVERE + VA_TOTALE_PREC 
*!*			REPLACE DARE_PADRE 	 		WITH DARE_PADRE + VD_TOTALE_PREC
*!*			REPLACE AVERE_PADRE  		WITH AVERE_PADRE + VA_TOTALE_PREC 
		**=> ERASMO - INIZIO 10/10/2025
		IF VX_TOTALE_PREC > 0
			REPLACE DARE WITH DARE + ABS(VX_TOTALE_PREC)
			REPLACE DARE_PADRE WITH DARE_PADRE + ABS(VX_TOTALE_PREC)
		ELSE
			REPLACE AVERE WITH AVERE + ABS(VX_TOTALE_PREC)
			REPLACE AVERE_PADRE WITH AVERE_PADRE + ABS(VX_TOTALE_PREC)
		ENDIF
		**=> ERASMO - FINE 10/10/2025
*!*			REPLACE DARE_SOTTOGRUPPO 	WITH DARE_SOTTOGRUPPO + VD_TOTALE_PREC
*!*			REPLACE AVERE_SOTTOGRUPPO 	WITH AVERE_SOTTOGRUPPO + VA_TOTALE_PREC 
*!*			REPLACE DARE_GRUPPO	 		WITH DARE_GRUPPO + VD_TOTALE_PREC
*!*			REPLACE AVERE_GRUPPO 		WITH AVERE_GRUPPO + VA_TOTALE_PREC 
	ENDIF

ENDIF

IF TYPE("OK_SALDI") == "L" AND OK_SALDI
	SELECT &V_DBASE
	GO TOP
	DELETE FOR DARE+AVERE <= 0
ENDIF

IF __NON_STAMPA_I_CLIENTI_FORNITORI
	SELECT &V_DBASE
	GO TOP
	REPLACE NO_STP WITH .T. FOR (TIPOCO = 'C' OR TIPOCO = 'F')
	GO TOP
ENDIF

IF __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI
	SELECT &V_DBASE
	GO TOP
	*REPLACE NO_STP WITH .T. ALL
	REPLACE NO_STP WITH .T. FOR !(PADRE <> '' AND LIVELLO = 2)  && ERASMO - 31/05/2022
	GO TOP
ENDIF

SELECT &V_DBASE
SET ORDER TO I_ORDINE
GO TOP

RETURN .T.

ENDPROC


*************************************************************************************************
PROCEDURE SBCMLIV_RIEP  && STAMPA RIEPILOGO BILANCIO PER STRUTTURA PIANO DEI CONTI MULTILIVELLO
*************************************************************************************************
*!*	LPARAMETERS V_POSBIL,V_CONINI,V_CONFIN,V_DAL,V_AL,PUB_ANNO,V_DBASE,__STAMPA_CONTI_ORDINE

*!*	*!*	_SEC_INI = SECONDS() &&  2025-06-05-SERGIO

*!*	**=> ERASMO - INIZIO 31/05/2022
*!*	*** CARICAMENTO RIEPILOGHI BILANCIO ANNO CORRENTE
*!*	cSql=""
*!*	cNomeCursorSql=V_DBASE
*!*	x_cond = "ANNO = '" + PUB_ANNO + "'"
*!*	x_cond = x_cond + " AND PADRE <> '' AND LIVELLO = 2"
*!*	IF !EMPTY(V_POSBIL)
*!*		x_cond = x_cond + " AND POSBIL = '" + V_POSBIL + "'"
*!*	ENDIF
*!*	*!*	IF !__STAMPA_CONTI_ORDINE
*!*	*!*		x_cond = x_cond + " AND TIPOCO <> 'O'"
*!*	*!*	ENDIF

*!*	TEXT TO cSql NOSHOW

*!*		SELECT 'P' AS GRP, 1 AS ORDINE0, 'ATTIVO' AS TIPOREC, CONTO, DESCR, DARE, AVERE, DARE-AVERE AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO = 1
*!*		UNION
*!*		SELECT 'P' AS GRP, 2 AS ORDINE0, 'PASSIVO' AS TIPOREC, CONTO, DESCR, DARE, AVERE, DARE-AVERE AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO IN (2,0)
*!*		UNION
*!*		SELECT 'E' AS GRP, 3 AS ORDINE0, 'RICAVI' AS TIPOREC, CONTO, DESCR, DARE, AVERE, DARE-AVERE AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO = 3
*!*		UNION
*!*		SELECT 'E' AS GRP, 4 AS ORDINE0, 'COSTI' AS TIPOREC, CONTO, DESCR, DARE, AVERE, DARE-AVERE AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO = 4
*!*		UNION
*!*		SELECT 'O' AS GRP, 5 AS ORDINE0, 'CONTI D''ORDINE' AS TIPOREC, CONTO, DESCR, DARE, AVERE, DARE-AVERE AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> AND TIPOCO = 'O'
*!*		ORDER BY ORDINE0,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6

*!*	ENDTEXT
*!*	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
*!*		return(.F.)
*!*	ENDIF
*!*	**=> ERASMO - FINE 31/05/2022

**=> ERASMO - INIZIO 10/10/2025
LPARAMETERS V_POSBIL,V_CONINI,V_CONFIN,V_DAL,V_AL,__ANNO,V_DBASE,__STAMPA_CONTI_ORDINE,__AAPREC

*!*	*** CARICAMENTO RIEPILOGHI BILANCIO ANNO CORRENTE E SE NECESSARIO AGGIUNGE I SALDI DEI PATRIMONIALI ANNO PRECEDENTE
*!*	cSql=""
*!*	cNomeCursorSql=V_DBASE
*!*	x_cond = "ANNO = '" + __ANNO + "' AND PADRE <> '' AND LIVELLO = 2"
*!*	IF !EMPTY(V_POSBIL)
*!*		x_cond = x_cond + " AND POSBIL = '" + V_POSBIL + "'"
*!*	ENDIF
*!*	p_cond = "ANNO = '" + ALLTRIM(STR(VAL(__ANNO) - 1,4,0)) + "' AND PADRE <> '' AND LIVELLO = 2"
*!*	IF !EMPTY(V_POSBIL)
*!*		p_cond = p_cond + " AND POSBIL = '" + V_POSBIL + "'"
*!*	ENDIF

*!*	IF __AAPREC

*!*		TEXT TO cSql NOSHOW

*!*			SELECT GRP, ORDINE0, TIPOREC, CONTO, DESCR,
*!*				CASE WHEN SUM(DARE-AVERE) > 0 THEN SUM(DARE-AVERE) ELSE 0 END AS DARE,
*!*				CASE WHEN SUM(DARE-AVERE) < 0 THEN ABS(SUM(DARE-AVERE)) ELSE 0 END AS AVERE,
*!*				SUM(DARE-AVERE) AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM (
*!*				SELECT 'P' AS GRP, 1 AS ORDINE0, 'ATTIVO' AS TIPOREC, CONTO, DESCR, DARE, AVERE, DARE-AVERE AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM VISTA_BILANCIO_P_E_MLIV WHERE <<p_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO = 1
*!*				UNION
*!*				SELECT 'P' AS GRP, 2 AS ORDINE0, 'PASSIVO' AS TIPOREC, CONTO, DESCR, DARE, AVERE, DARE-AVERE AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM VISTA_BILANCIO_P_E_MLIV WHERE <<p_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO IN (2,0)
*!*				UNION
*!*				SELECT 'P' AS GRP, 1 AS ORDINE0, 'ATTIVO' AS TIPOREC, CONTO, DESCR, DARE, AVERE, DARE-AVERE AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO = 1
*!*				UNION
*!*				SELECT 'P' AS GRP, 2 AS ORDINE0, 'PASSIVO' AS TIPOREC, CONTO, DESCR, DARE, AVERE, DARE-AVERE AS SALDO,ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6 FROM VISTA_BILANCIO_P_E_MLIV WHERE <<x_cond>> AND TIPOCO <> 'O' AND TIPO_CONTO IN (2,0)
*!*				) AS PAT
*!*			GROUP BY 
*!*				GRP, ORDINE0, TIPOREC, CONTO, DESCR, ORDINE1,ORDINE2,ORDINE3,ORDINE4,ORDINE5,ORDINE6
*!*			UNION
