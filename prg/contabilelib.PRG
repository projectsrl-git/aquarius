PUBLIC AUT_DES_CONTO,AUT_TIPOCO,AUT_POSBIL,AUT_CONTO,AUT_MASTRO,AUT_SOTTOG,AUT_CONTO_CLIENTE,AUT_CONTO_FORNITORE,AUT_NESSUN_GRUPPO_TROVATO

