x_data = "mov_dtreg between '" + x_dt1 + "' and '" + x_dt2 + "'"
x_cond = x_soci + " and " + x_data
Csql   = "select * from MOV_CCO where " + x_cond + " order by mov_soc,mov_dtreg,mov_conto"
IF !ExecCommand(cSql,"MOV_CCO")
   return(.f.)
ENDIF
SELECT MOV_CCO
GO TOP
QU = 0

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SELECT MOV_CCO
      SKIP +1
      LOOP
   ENDIF


*!*	   IF EMPTY(MOV_CONTABILITA_PREVISIONALE) 				&& SCARTA I MOVIMENTI NON EFFETTIVI
*!*	   ELSE
*!*	      SELECT MOV_CCO
*!*	      SKIP +1
*!*	      LOOP
*!*	   ENDIF

   IF ___INCLUDE_SALDI_PREVISIONALI
   ELSE

	   IF !EMPTY(MOV_CONTABILITA_PREVISIONALE) 				&& SCARTA I MOVIMENTI PREVISIONALI SE NON RICHIESTI
	      SELECT MOV_CONT
	      SKIP +1
	      LOOP
	   ENDIF

   ENDIF

   IF MOV_TOP = "CHI"
	  IF !F_CHIUSURA 										&& NON ELABORA I MOVIMENTI DI CHIUSURA
  	     SELECT MOV_CCO
  	     SKIP +1
	     LOOP
	  ENDIF	
   ENDIF


   IF !BETWEEN(MOV_CCO,_C_COSTODA__,_C_COSTOA__)			&& SCARTA I MOVIMENTI CONTABILI SENZA CENTRO DI COSTO	
      SELECT MOV_CCO
      SKIP +1
      LOOP
   ENDIF


   DA  = 0
   AV  = 0

   IF MOV_TMOV  = "D" .OR. MOV_TMOV  = "A"
   ELSE
 	  WAIT WINDOW "Registrazione senza D/A"+STR(MOV_NREGIS,10,0)+"<<<<<<<<<<<<"
  	  SELECT MOV_CCO
  	  SKIP +1
	  LOOP
   ENDIF

   IF MOV_TMOV  = "D"
      DA =  MOV_IMP
   ENDIF
   IF MOV_TMOV  = "A"
      AV =  MOV_IMP
   ENDIF

   XCONTO  = MOV_COPRIM
   DATAREG = MOV_DTREG
   XVALUTA = MOV_VALUTA
   XCAMBIO = MOV_CAMBIO
   XANNO   = MOV_ANNO
   XCCO    = MOV_CCO



   x_soci = "con_soc = '" + PUB_CODSOC + "'"
   x_anno = "con_anno = '" + PUB_ANNO + "'"
   x_cont = "con_conto = '" + ALLTRIM(XCONTO) + "'"
   x_cond = x_soci + " and " + x_anno + " and " + x_cont
   Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
   IF !ExecCommand(cSql,"cur_conti")
      return(.f.)
   ENDIF
   SELECT cur_conti
   GO TOP
   IF EOF()
      XDESCONTO = ""
      XTIPOCO   = "A"
      XPOSBIL   = "E"
      XCODRAG   = ""
      XDESRAG   = ""
   ELSE
      XDESCONTO = ALLTRIM(CON_DESCR)
      XTIPOCO   = CON_TIPOCO
      XPOSBIL   = CON_POSBIL
      XCODRAG   = CON_CODRAG
      XDESRAG   = CON_DESRAG
   ENDIF

   IF ___ELABORA_SOLO_ECONOMICI
	   IF XPOSBIL <> 'E'			&& SOLO ECONOMICI
	      SELECT MOV_CCO
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF


   SELECT &_DB__
   SET ORDER TO I_CCO
   V_SEEK = PUB_CODSOC+__ANNO__+ALLTRIM(XCCO)+ALLTRIM(XCONTO)
   SEEK V_SEEK
   IF FOUND()


      MESE      = SUBSTR(DATAREG,6,2)
      D_ARE     = "CON_DA"+MESE
      A_VERE    = "CON_AV"+MESE
      P_IMPD	= CON_IMP_D
      P_IMPA	= CON_IMP_A
      IF DA <> 0
         *REPLACE &D_ARE      WITH CAMBIO(XVALUTA,&D_ARE+DA,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 20/05/2011
         REPLACE &D_ARE      WITH &D_ARE + CAMBIO(XVALUTA,DA,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 09/04/2018
      ENDIF
      IF AV <> 0
         *REPLACE &A_VERE     WITH CAMBIO(XVALUTA,&A_VERE+AV,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 20/05/2011
         REPLACE &A_VERE     WITH &A_VERE + CAMBIO(XVALUTA,AV,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 09/04/2018
	  ENDIF	

   	  TDARE  = CON_DA01 + CON_DA02 + CON_DA03 + CON_DA04 + CON_DA05 + CON_DA06 + CON_DA07 + CON_DA08 + CON_DA09 + CON_DA10 + CON_DA11 + CON_DA12
   	  TAVERE = CON_AV01 + CON_AV02 + CON_AV03 + CON_AV04 + CON_AV05 + CON_AV06 + CON_AV07 + CON_AV08 + CON_AV09 + CON_AV10 + CON_AV11 + CON_AV12
	
   	  REPLACE CON_IMP_D WITH TDARE
   	  REPLACE CON_IMP_A WITH TAVERE


   ELSE

	  APPEND BLANK
	  REPLACE CON_SOC		WITH PUB_CODSOC
	  REPLACE CON_CONTO		WITH XCONTO
	  REPLACE CON_DESCR		WITH XDESCONTO
	  REPLACE CON_ANNO		WITH XANNO
	  REPLACE CON_CCO		WITH XCCO
      REPLACE CON_TIPOCO    WITH XTIPOCO
	  REPLACE CON_POSBIL    WITH XPOSBIL
	  REPLACE CON_CODRAG    WITH XCODRAG
	  REPLACE CON_DESRAG    WITH XDESRAG
	
      MESE      = SUBSTR(DATAREG,6,2)
      D_ARE     = "CON_DA"+MESE
      A_VERE    = "CON_AV"+MESE
      P_IMPD	= CON_IMP_D
      P_IMPA	= CON_IMP_A
      IF DA <> 0
         REPLACE &D_ARE      WITH CAMBIO(XVALUTA,DA,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 20/05/2011
      ENDIF
      IF AV <> 0
         REPLACE &A_VERE     WITH CAMBIO(XVALUTA,AV,XCAMBIO,(PUB_CODSOC+__ANNO__+XCONTO),.F.,10) && ERASMO - 20/05/2011
	  ENDIF	

   	  TDARE  = CON_DA01 + CON_DA02 + CON_DA03 + CON_DA04 + CON_DA05 + CON_DA06 + CON_DA07 + CON_DA08 + CON_DA09 + CON_DA10 + CON_DA11 + CON_DA12
   	  TAVERE = CON_AV01 + CON_AV02 + CON_AV03 + CON_AV04 + CON_AV05 + CON_AV06 + CON_AV07 + CON_AV08 + CON_AV09 + CON_AV10 + CON_AV11 + CON_AV12
	
   	  REPLACE CON_IMP_D WITH TDARE
   	  REPLACE CON_IMP_A WITH TAVERE
	

   ENDIF

   QU=QU+1
   WAIT WINDOW "Movimenti CENTRI DI COSTO elaborati "+STR(QU,10,0) NOWAIT

   SELECT MOV_CCO
   SKIP +1

ENDDO


SELECT &_DB__
GO TOP


SELECT &SS


RETURN

********************************************************************************************
PROCEDURE SBC300CCO  && STAMPA BILANCIO CENTRI DI COSTO A SEZIONI CONTRAPPOSTE
********************************************************************************************
PARA V_POSBIL,V_CONINI,V_CONFIN,_DATADAL__,_DATAAL__,PUB_ANNO,V_DBASE,__INCLUDE_PREVISIONALE

RELEASE V_CCO,V_CONTO,V_DESCR,V_TIPOCO,V_SALDO,V_SALDOI
PUBLIC V_CCO,V_CONTO,V_DESCR,V_TIPOCO,V_SALDO,V_SALDOI
V_CCO    = ""
V_CONTO  = ""
V_DESCR  = ""
V_TIPOCO = ""
V_SALDO  = 0
V_SALDOI = 0

V_DAL = VAL(SUBSTR(_DATADAL__,4,2))
V_AL = VAL(SUBSTR(_DATAAL__,4,2))

V_SALDOI = 0


CREATE CURSOR WOPE_SB1 (DA_CCOS C(13),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),DA_SALDOI N(20,8),DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CCOS) + ALLTRIM(DA_CODCON)  TAG WOPE_SB1 ADDITIVE

CREATE CURSOR SAVE_WOPE_SB1 (DA_CCOS C(13),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),DA_SALDOI N(20,8),DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CCOS) + ALLTRIM(DA_CODCON)  TAG IOPE_SB1 ADDITIVE

CREATE CURSOR SWOPE_SB1 (DA_CCOS C(13),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),DA_SALDOI N(20,8),DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CCOS) + ALLTRIM(DA_CODCON)  TAG SWOPE_SB1 ADDITIVE


CREATE CURSOR WOPE_SB2 (AV_CCOS C(13),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),AV_SALDOI N(20,8),AV_TIPOCO C(1))
INDEX ON ALLTRIM(AV_CCOS) + ALLTRIM(AV_CODCON)  TAG WOPE_SB2 ADDITIVE

CREATE CURSOR SWOPE_SB2  (AV_CCOS C(13),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),AV_SALDOI N(20,8),AV_TIPOCO C(1))
INDEX ON ALLTRIM(AV_CCOS) + ALLTRIM(AV_CODCON)  TAG SWOPE_SB2 ADDITIVE


CREATE CURSOR WOPE_SBC (DA_CCOS C(13),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),AV_CCOS C(13),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),ZA_SALDOI N(20,8))

CREATE CURSOR WOPE_DA (DA_CCOS C(13),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),ZA_SALDOI N(20,8))
INDEX ON ALLTRIM(DA_CODCON)  TAG WOPE_DA ADDITIVE

CREATE CURSOR WOPE_AV (AV_CCOS C(13),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),ZD_PERC N(16,2),AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZA_PERC N(16,2),ZA_SALDOI N(20,8))
INDEX ON ALLTRIM(AV_CODCON)  TAG WOPE_AV ADDITIVE


CREATE CURSOR WOPE_SBC_STAMPA (;
	DA_CODCON C(13), ;
	DA_DESCR C(40), ;
	DA_TOTALE N(20,8), ;
	ZD_PERC N(16,2), ;
	AV_CODCON C(13), ;
	AV_DESCR C(40), ;
	AV_TOTALE N(20,8), ;
	ZA_PERC N(16,2), ;
	ZA_SALDOI N(20,8))

CREATE CURSOR WOPE_SBC_STA (;
	CCOS C(13), ;
	DCCOS C(100), ;
	DA_CODCON C(13), ;
	DA_DESCR C(40), ;
	DA_TOTALE N(20,8), ;
	ZD_PERC N(16,2), ;
	AV_CODCON C(13), ;
	AV_DESCR C(40), ;
	AV_TOTALE N(20,8), ;
	ZA_PERC N(16,2), ;
	ZA_SALDOI N(20,8))
INDEX ON CCOS TAG I_CCOS ADDITIVE
INDEX ON CCOS+DA_CODCON+AV_CODCON TAG I_ORDINA ADDITIVE


SELECT &V_DBASE
HH=AFIELDS(TRANSITOxx)
CREATE CURSOR CURS_RAGGR FROM ARRAY TRANSITOxx
INDEX ON CON_ANNO + ALLTRIM(CON_CCO) + ALLTRIM(CON_CONTO)  TAG ICURS_R ADDITIVE



SET NEAR ON
SELECT &V_DBASE
SET ORDER TO CONTO
SEEK PUB_CODSOC+PUB_ANNO



DETTAGLI = .T.
PRIMOD   = .T.
PRIMOA   = .T.
V_GRSG   = ""
V_OLDD   = ""
V_OLDA   = ""

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED() .OR. CON_ANNO != PUB_ANNO
      SKIP +1
      LOOP
   ENDIF


	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,PUB_GRUPPOCF)==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF

	   IF LEN(ALLTRIM(CON_CONTO)) < PUB_GRUPPOCF
	      SKIP +1
	      LOOP
	   ENDIF
	ELSE
	   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,(PUB_SOTTOG -1))==V_GRSG
	      SKIP +1
	      LOOP
	   ENDIF

	   IF LEN(ALLTRIM(CON_CONTO)) < (PUB_SOTTOG -1)
	      SKIP +1
	      LOOP
	   ENDIF
	ENDIF
	** SERGIO 18/12/2021 FINE 


   IF CON_POSBIL  <> V_POSBIL
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   V_CONTO  = CON_CONTO
   V_CCO    = CON_CCO
   V_TIPOCO = CON_TIPOCO
   V_DESCR  = CON_DESCR

	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
	   V_GRSG   = SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
	ELSE
	   V_GRSG   = SUBSTR(V_CONTO,1,(PUB_SOTTOG -1))
	ENDIF
	** SERGIO 18/12/2021 FINE 

   v_seek 	 = "BIL"+V_GRSG
   v_chiave  = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      IF SUBSTR(LIBERA,1,1)=="S"
         DETTAGLI=.T.
      ELSE
         DETTAGLI=.F.
      ENDIF
   ELSE
      DETTAGLI=.F.
   ENDIF

   SELECT &V_DBASE
   SCATTER MEMVAR MEMO

   _SEEK =   M.CON_ANNO + ALLTRIM(M.CON_CCO) + ALLTRIM(M.CON_CONTO)
   SELECT CURS_RAGGR
   SET ORDER TO ICURS_R
   SEEK _SEEK
   IF !FOUND()
		APPEND BLANK
		GATHER MEMVAR MEMO
   ELSE

		REPLACE CON_IMP_D  WITH CON_IMP_D  + M.CON_IMP_D
		REPLACE CON_IMP_A  WITH CON_IMP_A  + M.CON_IMP_A
		REPLACE CON_DA01   WITH CON_DA01   + M.CON_DA01
		REPLACE CON_AV01   WITH CON_AV01   + M.CON_AV01
		REPLACE CON_DA02   WITH CON_DA02   + M.CON_DA02
		REPLACE CON_AV02   WITH CON_AV02   + M.CON_AV02
		REPLACE CON_DA03   WITH CON_DA03   + M.CON_DA03
		REPLACE CON_AV03   WITH CON_AV03   + M.CON_AV03
		REPLACE CON_DA04   WITH CON_DA04   + M.CON_DA04
		REPLACE CON_AV04   WITH CON_AV04   + M.CON_AV04
		REPLACE CON_DA05   WITH CON_DA05   + M.CON_DA05
		REPLACE CON_AV05   WITH CON_AV05   + M.CON_AV05
		REPLACE CON_DA06   WITH CON_DA06   + M.CON_DA06
		REPLACE CON_AV06   WITH CON_AV06   + M.CON_AV06
		REPLACE CON_DA07   WITH CON_DA07   + M.CON_DA07
		REPLACE CON_AV07   WITH CON_AV07   + M.CON_AV07
		REPLACE CON_DA08   WITH CON_DA08   + M.CON_DA08
		REPLACE CON_AV08   WITH CON_AV08   + M.CON_AV08
		REPLACE CON_DA09   WITH CON_DA09   + M.CON_DA09
		REPLACE CON_AV09   WITH CON_AV09   + M.CON_AV09
		REPLACE CON_DA10   WITH CON_DA10   + M.CON_DA10
		REPLACE CON_AV10   WITH CON_AV10   + M.CON_AV10
		REPLACE CON_DA11   WITH CON_DA11   + M.CON_DA11
		REPLACE CON_AV11   WITH CON_AV11   + M.CON_AV11
		REPLACE CON_DA12   WITH CON_DA12   + M.CON_DA12
		REPLACE CON_AV12   WITH CON_AV12   + M.CON_AV12

		REPLACE PRE_IMP_D  WITH PRE_IMP_D  + M.PRE_IMP_D
		REPLACE PRE_IMP_A  WITH PRE_IMP_A  + M.PRE_IMP_A
		REPLACE PRE_DA01   WITH PRE_DA01   + M.PRE_DA01
		REPLACE PRE_AV01   WITH PRE_AV01   + M.PRE_AV01
		REPLACE PRE_DA02   WITH PRE_DA02   + M.PRE_DA02
		REPLACE PRE_AV02   WITH PRE_AV02   + M.PRE_AV02
		REPLACE PRE_DA03   WITH PRE_DA03   + M.PRE_DA03
		REPLACE PRE_AV03   WITH PRE_AV03   + M.PRE_AV03
		REPLACE PRE_DA04   WITH PRE_DA04   + M.PRE_DA04
		REPLACE PRE_AV04   WITH PRE_AV04   + M.PRE_AV04
		REPLACE PRE_DA05   WITH PRE_DA05   + M.PRE_DA05
		REPLACE PRE_AV05   WITH PRE_AV05   + M.PRE_AV05
		REPLACE PRE_DA06   WITH PRE_DA06   + M.PRE_DA06
		REPLACE PRE_AV06   WITH PRE_AV06   + M.PRE_AV06
		REPLACE PRE_DA07   WITH PRE_DA07   + M.PRE_DA07
		REPLACE PRE_AV07   WITH PRE_AV07   + M.PRE_AV07
		REPLACE PRE_DA08   WITH PRE_DA08   + M.PRE_DA08
		REPLACE PRE_AV08   WITH PRE_AV08   + M.PRE_AV08
		REPLACE PRE_DA09   WITH PRE_DA09   + M.PRE_DA09
		REPLACE PRE_AV09   WITH PRE_AV09   + M.PRE_AV09
		REPLACE PRE_DA10   WITH PRE_DA10   + M.PRE_DA10
		REPLACE PRE_AV10   WITH PRE_AV10   + M.PRE_AV10
		REPLACE PRE_DA11   WITH PRE_DA11   + M.PRE_DA11
		REPLACE PRE_AV11   WITH PRE_AV11   + M.PRE_AV11
		REPLACE PRE_DA12   WITH PRE_DA12   + M.PRE_DA12
		REPLACE PRE_AV12   WITH PRE_AV12   + M.PRE_AV12

		REPLACE CON_SALDOI WITH CON_SALDOI + M.CON_SALDOI

   ENDIF




   SELECT &V_DBASE
   SKIP +1

ENDDO


** CREAZIONE DEI DUE CURSORI : WOPE_SB1 CONDIENE I COSTI (DARE) WOPE_SB2 CONTIENE I RICAVI (AVERE)

SELECT CURS_RAGGR
SET ORDER TO ICURS_R
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF


   V_CONTO  = CON_CONTO
   V_CCO    = CON_CCO
   V_TIPOCO = CON_TIPOCO
   V_DESCR  = CON_DESCR
   
	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
	   V_GRSG   = SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
	ELSE
	   V_GRSG   = SUBSTR(V_CONTO,1,(PUB_SOTTOG -1))
	ENDIF
	** SERGIO 18/12/2021 FINE 

   SELECT CURS_RAGGR

   V_TOTD=0
   V_TOTA=0
   FOR H=V_DAL TO V_AL
       VD="CON_DA"+STRTRAN(STR(H,2)," ","0")
       VA="CON_AV"+STRTRAN(STR(H,2)," ","0")
       V_TOTD=V_TOTD+&VD
       V_TOTA=V_TOTA+&VA

	   IF __INCLUDE_PREVISIONALE
	       VD="PRE_DA"+STRTRAN(STR(H,2)," ","0")
	       VA="PRE_AV"+STRTRAN(STR(H,2)," ","0")
	       V_TOTD=V_TOTD+&VD
	       V_TOTA=V_TOTA+&VA
       ENDIF


   NEXT

   IF OK_SALDI
      IF V_TOTD = 0 .AND. V_TOTA = 0
         SELECT CURS_RAGGR
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   DO SBCAGWF2_CCO

   SELECT CURS_RAGGR
   SKIP +1

ENDDO




SELECT SWOPE_SB1
GO TOP
DO WHILE .NOT. EOF()

  SCATTER MEMVAR MEMO
  INSERT INTO WOPE_SB1 FROM MEMVAR

  SELECT SWOPE_SB1
  SKIP +1

ENDDO

SELECT SWOPE_SB2
GO TOP
DO WHILE .NOT. EOF()

  SCATTER MEMVAR MEMO
  INSERT INTO WOPE_SB2 FROM MEMVAR


  SELECT SWOPE_SB2
  SKIP +1


ENDDO



SELECT WOPE_SB1
GO TOP

DO WHILE  .T.
   IF EOF()
      EXIT
   ENDIF


    SELECT WOPE_SB1
    IF OK_SALDI				

		** SERGIO 18/12/2021 INIZIO
		IF PUB_CONTOSIMILCEE 
		    IF LEN(ALLTRIM(DA_CODCON))  <  PUB_GRUPPOCF
		    ELSE
		    	IF DA_TOTALE = 0		&& non tratta i movimenti di dettaglio con saldo a 0
			   		SELECT WOPE_SB1
			   		SKIP +1
			   		LOOP
				ENDIF
			ENDIF
		   
		ELSE
		    IF LEN(ALLTRIM(DA_CODCON))  <  PUB_SOTTOG
		    ELSE
		    	IF DA_TOTALE = 0		&& non tratta i movimenti di dettaglio con saldo a 0
			   		SELECT WOPE_SB1
			   		SKIP +1
			   		LOOP
				ENDIF
			ENDIF
		ENDIF
		** SERGIO 18/12/2021 FINE 


	ENDIF

   SELECT WOPE_SB1
   V_CCO    = DA_CCOS
   V_CONTO  = DA_CODCON
   V_DESCR  = DA_DESCR
   V_TOTALE = DA_TOTALE

   SELECT WOPE_SBC
   APPEND BLANK
   REPLACE DA_CCOS   WITH V_CCO
   REPLACE DA_CODCON WITH V_CONTO
   REPLACE DA_DESCR  WITH V_DESCR
   REPLACE DA_TOTALE WITH V_TOTALE


   SELECT WOPE_SB1
   SKIP +1



ENDDO


SELECT WOPE_SB2
GO TOP


DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF


    SELECT WOPE_SB2
	IF OK_SALDI				

		** SERGIO 18/12/2021 INIZIO
		IF PUB_CONTOSIMILCEE 
		    IF LEN(ALLTRIM(AV_CODCON))  <  PUB_GRUPPOCF
		    ELSE
		    	IF AV_TOTALE = 0		&& non tratta i movimenti di dettaglio con saldo a 0
			   		SELECT WOPE_SB2
			   		SKIP +1
			   		LOOP
				ENDIF
			ENDIF
		ELSE
		    IF LEN(ALLTRIM(AV_CODCON))  <  PUB_SOTTOG
		    ELSE
		    	IF AV_TOTALE = 0		&& non tratta i movimenti di dettaglio con saldo a 0
			   		SELECT WOPE_SB2
			   		SKIP +1
			   		LOOP
				ENDIF
			ENDIF
		ENDIF
		** SERGIO 18/12/2021 FINE 


	ENDIF


   SELECT WOPE_SB2
   V_CCO    = AV_CCOS
   V_CONTO  = AV_CODCON
   V_DESCR  = AV_DESCR
   V_TOTALE = AV_TOTALE


   SELECT WOPE_SBC
   IF EOF()
      APPEND BLANK
   ENDIF
   REPLACE AV_CCOS   WITH V_CCO
   REPLACE AV_CODCON WITH V_CONTO
   REPLACE AV_DESCR  WITH V_DESCR
   REPLACE AV_TOTALE WITH V_TOTALE
   SKIP +1



   SELECT WOPE_SB2
   SKIP +1
ENDDO




