**************************************************************************
FUNCTION UPD_PARTITARI
**************************************************************************
LPARAMETERS _MOV_NUMPRO,_NREGIS_CHR

__VALORE_DA_RIPORTARE = ALLTRIM(_NREGIS_CHR)

cSql=""
cNomeCursorSql="MOV_CONT_CURS"
TEXT TO cSql NOSHOW

	SELECT MOV_CONTO,MOV_NUMPRO,MOV_NREGIS,MOV_CONTABILITA_PREVISIONALE
	FROM MOV_CONT
	WHERE  MOV_NUMPRO = '<<_MOV_NUMPRO>>'

ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT MOV_CONT_CURS
GO TOP

SCAN


    IF MOV_CONTABILITA_PREVISIONALE = 'P'	&& BYPASS MOVIMENTI DI CONTABILITA' PREVISIONALE
   		SELECT MOV_CONT_CURS
   		LOOP
    ENDIF

	x_soci = "con_soc = '" + PUB_CODSOC + "'"
	x_anno = "con_anno = '" + PUB_ANNO + "'"
	x_cont = "con_conto = '" + ALLTRIM(MOV_CONTO) + "'"
	x_cond = x_soci + " and " + x_anno + " and " + x_cont
	Csql= "select CON_CONTO,CON_TIPOCO from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
	IF !ExecCommand(cSql,"CONTI")
	   return(.f.)
	ENDIF
	SELECT CONTI
	GO TOP
	IF EOF()
	   CLI_FOR='X'
	ELSE
	   CLI_FOR = SUBSTR(CON_TIPOCO,1,1)
	ENDIF

    SELECT MOV_CONT_CURS

	DO CASE
		CASE CLI_FOR='C'
			=UPD_PART_CLI(_MOV_NUMPRO,NR_REGIS_CHR)	&& AGGIORNA PART_CLI IN BASE A MOV_NUMPRO
	 	CASE CLI_FOR='F'
	 		=UPD_PART_FOR(_MOV_NUMPRO,NR_REGIS_CHR)	&& AGGIORNA PART_FOR IN BASE A MOV_NUMPRO
	ENDCASE
	
	SELECT MOV_CONT_CURS

ENDSCAN


RETURN



