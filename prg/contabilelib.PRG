**********************
FUNCTION CREA_SCADENZE
**********************

__TOTALE_SCADENZA = 0

SELECT CU_TRANK
GO TOP

DO WHILE .NOT. EOF()

	SCATTER MEMVAR MEMO
	
	SELECT PERIODI
	APPEND BLANK
	REPLACE IMP_SCAD  WITH M.TK_IMP_SCAD
	REPLACE NUM_TRAN  WITH M.TK_NUM_TRAN
	REPLACE DSCAD     WITH M.TK_DSCAD 	
		
    __TOTALE_SCADENZA  = __TOTALE_SCADENZA  + IMP_SCAD

	SELECT CU_TRANK
	SKIP +1
	
ENDDO



*!*	CONTROLLO INCROCIATO CON IL TOTALE DEL DOCUMENTO E GLI IMPORTI DELLE SCADENZE : OTTENGO COMPENSO E LO SOMMO SULL'ULTIMA TRANCHE


__T_TOTALE_DOCUMENTO =  __T_IMPON  + __T_IMPOS

COMPENSO = 0
IF __TOTALE_SCADENZA  <> __T_TOTALE_DOCUMENTO

	COMPENSO = ABS(__T_TOTALE_DOCUMENTO - __TOTALE_SCADENZA)
	SELECT PERIODI
	GO BOTTOM
	REPLACE IMP_SCAD  WITH IMP_SCAD  + COMPENSO

ENDIF



*!*	RIPORTA LE DATE DI SCADENZA E IMPORTO NEL VETTORE RELATIVO ALLA GESTIONE DELLE SCADENZE DEL REPORT

RELEASE DATA            && ERASMO - 27/07/2011
RELEASE IMPORTO         && ERASMO - 27/07/2011

PUBLIC ARRAY DATA(7)
PUBLIC ARRAY IMPORTO(7)

RELEASE DESCR_SCAD			&& ERASMO - 11/06/2013
PUBLIC ARRAY DESCR_SCAD(7)	&& ERASMO - 11/06/2013


I = 0
SELECT PERIODI
GO TOP

DO WHILE (!EOF()) .AND. (I < 7)

   I = I + 1

   DATA[I]     = DSCAD
   IMPORTO[I]  = IMP_SCAD
   DESCR_SCAD[I] = ""  && ERASMO - 11/06/2013

   SELECT PERIODI

   SKIP +1

ENDDO

I = I + 1

FOR HH = I TO 7

   DATA[HH]     = SPACE(10)
   IMPORTO[HH]  = 0
   DESCR_SCAD[HH] = ""  && ERASMO - 11/06/2013

NEXT



RETURN

*********************************************************************************************
PROCEDURE FANNI_CREA_PRIMA_REGISTRAZIONE_CHIUSURA_PER_ESERCIZIO_CHIUSO
*********************************************************************************************
PARAMETERS _CONTO_BILANCIO_CHIUSURA,CONTO_UTILE_ESERCIZIO,_SALDO_DARE__,SALDO_AVERE__

* MOVIMENTO AL 31/12/XX
* =====================
* BILANCIO DI CHIUSURA



V_DTFINE = V_GGCHI + '/' + V_MMCHI + '/' + V_AACHI
V_AAPIU1 = STR((VAL(V_ANNO)+1),4,0)
V_DTINIZ = V_GGAPE + '/' + V_MMAPE + '/' + V_AAAPE

NUMEROINT = ""
DO REG_NUMRPN  && CARICO IL NUMERO INTERNO DI PRIMA NOTA

IF !ExecCommand("select * from mo_conca where 0=1","curs_moconca")
   return(.f.)
ENDIF


* 1) CREA CHI SU BLILANCIO CHIUSURA
SELECT curs_moconca
APPEND BLANK
REPLACE MOV_SOC      WITH  PUB_CODSOC
REPLACE MOV_ANNO     WITH  V_AACHI
REPLACE MOV_DTDOC    WITH  RIBALTA2(V_DTFINE)
REPLACE MOV_NDOC     WITH  '999999'
REPLACE MOV_DTREG    WITH  RIBALTA2(V_DTFINE)
REPLACE MOV_CONTO    WITH  _CONTO_BILANCIO_CHIUSURA
REPLACE MOV_TOP      WITH  'CHI'   && TOP DI CHIUSURA
REPLACE MOV_IMP      WITH  ABS(_SALDO_DARE__ - SALDO_AVERE__)
REPLACE MOV_IMPORT   WITH  ABS(_SALDO_DARE__ - SALDO_AVERE__)

IF _SALDO_DARE__ > SALDO_AVERE__
	REPLACE MOV_TMOV     WITH  'A'
    __TMOV = "A"
ENDIF
IF _SALDO_DARE__ < SALDO_AVERE__
	REPLACE MOV_TMOV     WITH  'D'
    __TMOV = "D"
ENDIF

REPLACE MOV_CONTOP   WITH  _CONTO_BILANCIO_CHIUSURA
REPLACE MOV_NUMPRO   WITH  ALLTRIM(NUMEROINT)
REPLACE MOV_DESMOV   WITH  'CHIUSURA AL '+V_DTFINE

* CREA CHI SUL CONTO CONTO UTILE ESERCIZIO
SELECT curs_moconca
APPEND BLANK
REPLACE MOV_SOC      WITH  PUB_CODSOC
REPLACE MOV_ANNO     WITH  V_AACHI
REPLACE MOV_DTDOC    WITH  RIBALTA2(V_DTFINE)
REPLACE MOV_NDOC     WITH  '999999'
REPLACE MOV_DTREG    WITH  RIBALTA2(V_DTFINE)
REPLACE MOV_CONTO    WITH  CONTO_UTILE_ESERCIZIO
REPLACE MOV_TOP      WITH  'CHI'   && TOP DI CHIUSURA
REPLACE MOV_IMP      WITH  ABS(_SALDO_DARE__ - SALDO_AVERE__)
REPLACE MOV_IMPORT   WITH  ABS(_SALDO_DARE__ - SALDO_AVERE__)

IF __TMOV = "D"
	REPLACE MOV_TMOV     WITH  'A'
ENDIF
IF __TMOV = "A"
	REPLACE MOV_TMOV     WITH  'D'
ENDIF

REPLACE MOV_CONTOP   WITH  SPACE(10)
REPLACE MOV_NUMPRO   WITH  ALLTRIM(NUMEROINT)
REPLACE MOV_DESMOV   WITH  'CHIUSURA AL '+V_DTFINE


IF !ExecRW('','mo_conca','I','','curs_moconca')
   return(.f.)
ENDIF



RETURN



