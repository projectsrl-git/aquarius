    		LOOP
   		ENDIF
 		
	  	**==>> ACCESSO AL MASTRO PER PRELEVARE DESCRIZIONE,TIPO CONTO,POSIZIONE DI BILANCIO
	   	AUT_CERCA_MASTRO=AUTOCONTROLLO_CERCA_MASTRO(AUT_MASTRO)
