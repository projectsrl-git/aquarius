DO WHILE !EOF()

   IF RECNO() > 10
	  EXIT
   ENDIF
   _WCOD="WCOD"+PADL(ALLTRIM(STR(RECNO())),2,'0')
   _SALD="M.SALDO"+PADL(ALLTRIM(STR(RECNO())),2,'0')

   VALNUMER=VAL(PADL(ALLTRIM(STR(RECNO())),2,'0'))
   IF VALNUMER > 9
	   _PERX="M.PERC"+"10"
   ELSE
	   _PERX="M.PERC"+PADL(ALLTRIM(STR(RECNO())),1,'0')
   ENDIF

   &_WCOD = MOV_CONTO
   &_SALD = MOV_IMP
   &_PERX = MOV_PERCEN
   SKIP+1
ENDDO

