******************************
FUNCTION _ELAPART
******************************
* ELABORA FATTURE A RICHIESTA IMPOSTANDO IL CAMPO SELEZIONE
* __TIPO = DATA :  ACCESSO PER DATA
* __TIPO = NUME :  ACCESSO PER DATA

PARA __TIPO,__COD

SS=STR(SELECT())

DO CASE

   CASE __TIPO = "CLI"
        x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
        x_clie = "par_codcli = '" + ALLTRIM(__COD) + "'"
        cSql = "SELECT *, PAR_NPART AS OLD_NPART, PAR_CODPAG AS OLD_CODPAG, PAR_NUMFAT AS OLD_NUMFAT FROM PART_CLI WHERE " + x_soci + " and " + x_clie + ;
        			" order by par_codsoc,PAR_ANNO,PAR_DTREG,PAR_NPROG"  && ERASMO - 05/03/2012
        IF !ExecRW(cSql,"part_cli","R")
           return
        ENDIF
		SELECT PART_CLI
		DO WHILE .T.
		   IF EOF()
		      EXIT
		   ENDIF
 		   IF DELETED()
		      SKIP +1
		      LOOP
		   ENDIF
		   **=> ERASMO - INIZIO 14/02/2012
		   IF PAR_NPROG = 100
		      SKIP +1
		      LOOP
		   ENDIF
		   **=> ERASMO - FINE 14/02/2012
 	       SCATTER MEMVAR MEMO
 	       __RC = SYS(2015)
           REPLACE PAR_SYS     WITH __RC     && NUMERO RECORD CORRENTE
           SELECT  CPART_CL
           APPEND BLANK
           GATHER MEMVAR MEMO
  	       REPLACE PAR_SYS     WITH __RC     && NUMERO RECORD CORRENTE
   		   SELECT PART_CLI
		   SKIP +1
		ENDDO
        IF !ExecRW("","part_cli","W")
           return
        ENDIF

	CASE __TIPO = "FOR"
        x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
        x_clie = "par_codcli = '" + ALLTRIM(__COD) + "'"
        cSql = "SELECT *, PAR_NPART AS OLD_NPART, PAR_CODPAG AS OLD_CODPAG, PAR_NUMFAT AS OLD_NUMFAT FROM PART_FOR WHERE " + x_soci + " and " + x_clie + ;
        			" order by par_codsoc,PAR_ANNO,PAR_DTREG,PAR_NPROG"  && ERASMO - 05/03/2012
        IF !ExecRW(cSql,"part_for","R")
           return
        ENDIF
		SELECT PART_FOR
		DO WHILE .T.
		   IF EOF()
		      EXIT
		   ENDIF
 		   IF DELETED()
		      SKIP +1
		      LOOP
		   ENDIF
		   **=> ERASMO - INIZIO 14/02/2012
		   IF PAR_NPROG = 100
		      SKIP +1
		      LOOP
		   ENDIF
		   **=> ERASMO - FINE 14/02/2012
 	       SCATTER MEMVAR MEMO
 	       __RC = SYS(2015)
           REPLACE PAR_SYS     WITH __RC     && NUMERO RECORD CORRENTE
           SELECT  CPART_FO
           APPEND BLANK
           GATHER MEMVAR MEMO
	 	   REPLACE PAR_SYS     WITH __RC     && NUMERO RECORD CORRENTE
   		   SELECT PART_FOR
		   SKIP +1
		ENDDO
        IF !ExecRW("","part_for","W")
           return
        ENDIF
ENDCASE

SELECT &SS
RETURN


