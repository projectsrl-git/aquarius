IF TYPE("_PAR_NPART") == "C"
	_SEEK_NPART = ALLTRIM(_PAR_NPART)
ELSE
	_SEEK_NPART = ALLTRIM(STR(_PAR_NPART,10,0))
ENDIF

IF EMPTY(_SEEK_NPART)
	SELECT(_ACT_SEL)
	RETURN .F.
ENDIF

*** RICERCA TABELLA AQ_RAP LEGATA (SE NON TROVO NESSUN RECORD, VUOL DIRE CHE NON E' GESTITA NESSUNA RITENUTA D'ACCONTO PER QUESTA/E PARTITA/E)
_ID_RAP = 0
