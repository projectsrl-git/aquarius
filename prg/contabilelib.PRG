** #############################################################################################
**  SBOLCCA LA REGISTRAZIONE CONTABILE PORTANDOLA DA PREVISIONALE A EFFETTIVA O IL CONTRARIO
** #############################################################################################
**
** Archivi da controaggiornare :
**
**	-	INDICE
**	-	MOV_CONT
**	-	MOV_CCO
**	-	CCOSTO
**	-	PART_CLI
**	-	PART_FOR
**	-
**	-   TIPO DI AGGIORNAMENTO :
**	-						
**	-		SE _TIPO_REGISTRAZIONE_	= 'EFFETTIVA'  GLI ARCHIVI CONTABILI PASSANO DA PREVISIONALE A EFFETTIVA
**	-		SE _TIPO_REGISTRAZIONE_	= 'PREVISIONALE'  GLI ARCHIVI CONTABILI PASSANO DA EFFETTIVA A PREVISIONALE
**	-
**	-		SE _IDUNIQUE			NOT EMPTY : ID UNIQUE E' UTILIZZATO PER ACCEDERE A MOV_CONT DIRETTAMENTE SLLA RIGA DELLA PRIMA NOTA
**	-											ALTRIMENTI TUTTA LA PRIMA NOTA VIENE CARICATA E AGGIORNATA
**	-
**	-
**	-		_TIPO_CONTO_				= 'CLIENTE' 	AGGIORNA PART_CLI
**	-		_TIPO_CONTO_				= 'FORNITORE' 	AGGIORNA PART_FOR
**  -
**  -		_CERTIFICA_REGISTRAZIONE	= "SI" , IMPOSTA IL FLAG MOV_OKTES SU INDICE CON "OK-TES"
**  -
**  -


FUNCTION PASSA_DA_PREVISIONALE_A_EFFETTIVA_O_IL_CONTRARIO
PARA _NUMPRO_,_IDUNIQUE,_TIPO_REGISTRAZIONE_,_TIPO_CONTO_,_CERTIFICA_REGISTRAZIONE



** AGGIORNAMENTO INDICE

		   	x_soci = "mov_soc = '" + PUB_CODSOC + "'"
		   	x_anno = "mov_anno = '" + PUB_ANNO + "'"
		   	x_npro = "mov_numpro = '" + ALLTRIM(_NUMPRO_) + "'"
		   	x_cond = x_soci + " and " + x_anno + " and " + x_npro
           	Csql   = "select * from indice where " + x_cond + " order by mov_soc,mov_anno,mov_numpro"
           	IF !ExecCommand(cSql,"_cINDICE")
              return(.f.)
           	ENDIF
           	SELECT _cINDICE
         	
           	IF _TIPO_REGISTRAZIONE_  = "EFFETTIVA"
				REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "
			ELSE
				REPLACE MOV_CONTABILITA_PREVISIONALE    WITH "P"
			ENDIF

			IF _CERTIFICA_REGISTRAZIONE = "SI"
				REPLACE MOV_OKTES    WITH "OK-TES"			&& REGISTRAZIONE CERTIFICATA
			ENDIF

	        IF !ExecRW('','indice','I','','_cINDICE')
	           return(.f.)
	        ENDIF


*!*	** AGGIORNAMENTO MOV_CONT

		   	x_soci = "mov_soc = '" + PUB_CODSOC + "'"
		   	x_anno = "mov_anno = '" + PUB_ANNO + "'"
		   	x_npro = "mov_numpro = '" + ALLTRIM(_NUMPRO_) + "'"
		   	x_uniq = "id_unique = '" + _IDUNIQUE + "'"

			IF empty(_IDUNIQUE)
			   	x_cond = x_soci + " and " + x_anno + " and " + x_npro
    		ELSE
			   	x_cond = x_soci + " and " + x_anno + " and " + x_npro+ " and " + x_uniq
    		ENDIF

           	Csql   = "select * from MOV_CONT where " + x_cond + " order by mov_soc,mov_anno,mov_numpro,mov_sequen"
           	IF !ExecCommand(cSql,"_cMOV_CONT")
              return(.f.)
           	ENDIF



*!*	** AGGIORNAMENTO SALDI PIANO DEI CONTI


           	SELECT _cMOV_CONT
           	GO TOP

			DO WHILE .NOT.EOF()


	           	IF _TIPO_REGISTRAZIONE_  = "EFFETTIVA"
					REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "
				ELSE
					REPLACE MOV_CONTABILITA_PREVISIONALE    WITH "P"
				ENDIF


				DATAREG	= RIBALTA2(MOV_DTREG)
				XVALUTA = MOV_VALUTA
				XCAMBIO = MOV_CAMBIO
				DA      = 0
				AV      = 0
				
				IF MOV_TMOV = 'D'
					DA  = MOV_IMP
				ELSE
					AV  = MOV_IMP
				ENDIF
					
				=AGGIORNA_PIANO_DEI_CONTI()	
		
	           	SELECT _cMOV_CONT
	           	SKIP +1
	           	
	           	
			ENDDO WHILE .NOT.EOF()

           	
           	SELECT _cMOV_CONT
           	GO TOP

	        IF !ExecRW('','mov_cont','I','','_cMOV_CONT')
	           return(.f.)
	        ENDIF




*!*	** AGGIORNAMENTO MOV_CCO

		   	x_soci = "mov_soc = '" + PUB_CODSOC + "'"
		   	x_anno = "mov_anno = '" + PUB_ANNO + "'"
		   	x_npro = "mov_numpro = '" + ALLTRIM(_NUMPRO_) + "'"
		   	x_uniq = "id_unique = '" + _IDUNIQUE + "'"
		   	x_cond = x_soci + " and " + x_anno + " and " + x_npro

           	Csql   = "select * from MOV_CCO where " + x_cond + " order by mov_soc,mov_anno,mov_numpro"
           	IF !ExecCommand(cSql,"_cMOV_CCO")
              return(.f.)
           	ENDIF

*!*	** AGGIORNAMENTO SALDI CENTI DI COSTO


           	SELECT _cMOV_CCO
           	GO TOP

			DO WHILE .NOT.EOF()

	           	IF _TIPO_REGISTRAZIONE_  = "EFFETTIVA"
					REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "
				ELSE
					REPLACE MOV_CONTABILITA_PREVISIONALE    WITH "P"
				ENDIF


				DATAREG	= RIBALTA2(MOV_DTREG)
				XVALUTA = MOV_VALUTA
				XCAMBIO = MOV_CAMBIO
				DA      = 0
				AV      = 0
				
				IF MOV_TMOV = 'D'
					DA  = MOV_IMP
				ELSE
					AV  = MOV_IMP
				ENDIF
					
					
				=AGGIORNA_CENTRI_DI_COSTO()
		
	           	SELECT _cMOV_CCO
	           	SKIP +1
	           	
	           	
			ENDDO WHILE .NOT.EOF()

           	SELECT _cMOV_CCO
           	GO TOP


	        IF !ExecRW('','mov_cco','I','','_cMOV_CCO')
	           return(.f.)
	        ENDIF






*!*	** AGGIORNAMENTO PARTITARIO FORNITORI

			IF _TIPO_CONTO_ = 'FORNITORE'

			   	x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
			   	x_npro = "par_numpro = '" + ALLTRIM(_NUMPRO_) + "'"
			   	x_cond = x_soci + " and " + x_npro

	           	Csql   = "select * from PART_FOR where " + x_cond + " order by par_codcli"
	           	IF !ExecCommand(cSql,"_cPART_FOR")
	              return(.f.)
	           	ENDIF
	           	SELECT _cPART_FOR
	           	GO TOP

	           	
	           	IF _TIPO_REGISTRAZIONE_  = "EFFETTIVA"
					REPLACE PAR_CONTABILITA_PREVISIONALE    WITH " " ALL
				ELSE
					REPLACE PAR_CONTABILITA_PREVISIONALE    WITH "P" ALL
				ENDIF

		        IF !ExecRW('','part_for','I','','_cPART_FOR')
		           return(.f.)
		        ENDIF

			ENDIF


*!*	** AGGIORNAMENTO PARTITARIO CLIENTI

			IF _TIPO_CONTO_ = 'CLIENTE'

			   	x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
			   	x_npro = "par_numpro = '" + ALLTRIM(_NUMPRO_) + "'"
			   	x_cond = x_soci + " and " + x_npro

	           	Csql   = "select * from PART_CLI where " + x_cond + " order by par_codcli"
	           	IF !ExecCommand(cSql,"_cPART_CLI")
	              return(.f.)
	           	ENDIF
	           	SELECT _cPART_CLI
	           	GO TOP

	           	
	           	IF _TIPO_REGISTRAZIONE_  = "EFFETTIVA"
					REPLACE PAR_CONTABILITA_PREVISIONALE    WITH " " ALL
				ELSE
					REPLACE PAR_CONTABILITA_PREVISIONALE    WITH "P" ALL
				ENDIF

		        IF !ExecRW('','part_cli','I','','_cPART_CLI')
		           return(.f.)
		        ENDIF

			ENDIF




RETURN(.T.)



** ######################################################################################################
**  AGGIORNA I SALDI DEL PIANO DEI CONTI AL FINE DI PASSARE DA PREVISIONALE A EFFETTIVA ED IL CONTRARIO
** ######################################################################################################
**
**


FUNCTION AGGIORNA_PIANO_DEI_CONTI


						
   	x_soci = "con_soc = '" + MOV_SOC + "'"
   	x_anno = "con_anno = '" + MOV_ANNO + "'"
   	x_cont = "con_conto = '" + MOV_CONTO + "'"
   	x_cond = x_soci + " and " + x_anno + " and " + x_cont

   	Csql   = "select * from CONTI where " + x_cond + " order by con_conto"
   	IF !ExecCommand(cSql,"_cCONTI")
      return(.f.)
   	ENDIF
   	
   	SELECT _cCONTI

   	IF _TIPO_REGISTRAZIONE_  = "EFFETTIVA"
        P_IMPA  = PRE_IMP_A
	    P_IMPD  = PRE_IMP_D
        MESE    = SUBSTR(DATAREG,4,2)
	    VAR     = "PRE_AV"+MESE
	    VAR2    = "PRE_DA"+MESE
	    REPLACE   PRE_IMP_D   WITH P_IMPD-CAMBIO(XVALUTA,DA,XCAMBIO)
	    REPLACE   PRE_IMP_A   WITH P_IMPA-CAMBIO(XVALUTA,AV,XCAMBIO)
	    REPLACE   &VAR2       WITH CAMBIO(XVALUTA,DA,XCAMBIO)-&VAR2
	    REPLACE   &VAR        WITH CAMBIO(XVALUTA,AV,XCAMBIO)-&VAR
	    P_IMPA  = CON_IMP_A
	    P_IMPD  = CON_IMP_D
        MESE    = SUBSTR(DATAREG,4,2)
	    VAR     = "CON_AV"+MESE
	    VAR2    = "CON_DA"+MESE
	    REPLACE   CON_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,DA,XCAMBIO)
	    REPLACE   CON_IMP_A   WITH P_IMPA+CAMBIO(XVALUTA,AV,XCAMBIO)
	    REPLACE   &VAR2       WITH CAMBIO(XVALUTA,DA,XCAMBIO)+&VAR2
	    REPLACE   &VAR        WITH CAMBIO(XVALUTA,AV,XCAMBIO)+&VAR
	ELSE
        P_IMPA  = PRE_IMP_A
	    P_IMPD  = PRE_IMP_D
        MESE    = SUBSTR(DATAREG,4,2)
	    VAR     = "PRE_AV"+MESE
	    VAR2    = "PRE_DA"+MESE
	    REPLACE   PRE_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,DA,XCAMBIO)
	    REPLACE   PRE_IMP_A   WITH P_IMPA+CAMBIO(XVALUTA,AV,XCAMBIO)
	    REPLACE   &VAR2       WITH CAMBIO(XVALUTA,DA,XCAMBIO)+&VAR2
	    REPLACE   &VAR        WITH CAMBIO(XVALUTA,AV,XCAMBIO)+&VAR
	    P_IMPA  = CON_IMP_A
	    P_IMPD  = CON_IMP_D
        MESE    = SUBSTR(DATAREG,4,2)
	    VAR     = "CON_AV"+MESE
	    VAR2    = "CON_DA"+MESE
	    REPLACE   CON_IMP_D   WITH P_IMPD-CAMBIO(XVALUTA,DA,XCAMBIO)
	    REPLACE   CON_IMP_A   WITH P_IMPA-CAMBIO(XVALUTA,AV,XCAMBIO)
	    REPLACE   &VAR2       WITH CAMBIO(XVALUTA,DA,XCAMBIO)-&VAR2
	    REPLACE   &VAR        WITH CAMBIO(XVALUTA,AV,XCAMBIO)-&VAR
	ENDIF


	IF !ExecRW('','conti','I','','_cCONTI')
   		return(.f.)
	ENDIF
	




RETURN(.T.)



** ######################################################################################################
**  AGGIORNA I SALDI DEI CENTRI DI COSTO AL FINE DI PASSARE DA PREVISIONALE A EFFETTIVA ED IL CONTRARIO
** ######################################################################################################
**
**


FUNCTION AGGIORNA_CENTRI_DI_COSTO




   	SELECT _cMOV_CCO

						
   	x_soci = "con_soc = '" + MOV_SOC + "'"
   	x_anno = "con_anno = '" + MOV_ANNO + "'"
   	x_cont = "con_conto = '" + MOV_CONTO + "'"
   	x_cond = x_soci + " and " + x_anno + " and " + x_cont

   	Csql   = "select * from CCOSTO where " + x_cond + " order by con_conto"
   	IF !ExecCommand(cSql,"_cCOSTO")
      return(.f.)
   	ENDIF
   	
   	SELECT _cCOSTO
	IF !EOF()

	   	IF _TIPO_REGISTRAZIONE_  = "EFFETTIVA"
		    P_IMPD  = PRE_IMP_D
	        MESE    = SUBSTR(DATAREG,4,2)
		    VAR2    = "PRE_DA"+MESE
		    REPLACE   PRE_IMP_D   WITH P_IMPD-CAMBIO(XVALUTA,DA,XCAMBIO)
		    REPLACE   &VAR2       WITH CAMBIO(XVALUTA,DA,XCAMBIO)-&VAR2
		    P_IMPD  = CON_IMP_D
	        MESE    = SUBSTR(DATAREG,4,2)
		    VAR2    = "CON_DA"+MESE
		    REPLACE   CON_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,DA,XCAMBIO)
		    REPLACE   &VAR2       WITH CAMBIO(XVALUTA,DA,XCAMBIO)+&VAR2
		ELSE
		    P_IMPD  = PRE_IMP_D
	        MESE    = SUBSTR(DATAREG,4,2)
		    VAR2    = "PRE_DA"+MESE
		    REPLACE   PRE_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,DA,XCAMBIO)
		    REPLACE   &VAR2       WITH CAMBIO(XVALUTA,DA,XCAMBIO)+&VAR2
		    P_IMPD  = CON_IMP_D
	        MESE    = SUBSTR(DATAREG,4,2)
		    VAR2    = "CON_DA"+MESE
		    REPLACE   CON_IMP_D   WITH P_IMPD-CAMBIO(XVALUTA,DA,XCAMBIO)
		    REPLACE   &VAR2       WITH CAMBIO(XVALUTA,DA,XCAMBIO)-&VAR2
		ENDIF


		IF !ExecRW('','ccosto','I','','_cCOSTO')
	   		return(.f.)
		ENDIF
		
	ENDIF



RETURN(.T.)

