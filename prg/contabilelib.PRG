**************************************************************************
PROCEDURE SBCAGWF2
**************************************************************************

V_SALDO = V_TOTD - V_TOTA

IF V_DBASE = "CONTI"
   IF V_SALDO = 0
      RETURN
   ENDIF
ENDIF

IF V_SALDO > 0
   SELECT WOPE_SB1
   APPEND BLANK
   REPLACE DA_CODCON WITH V_CONTO
   REPLACE DA_DESCR  WITH V_DESCR
   REPLACE DA_TIPOCO WITH V_TIPOCO
   REPLACE DA_TOTALE WITH ABS(V_SALDO)
   REPLACE DA_SALDOI WITH V_SALDOI
   
	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 	
	   V_OLDD=SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
	ELSE
	   V_OLDD=SUBSTR(V_CONTO,1,(PUB_SOTTOG-1))
	ENDIF
	** SERGIO 18/12/2021 FINE 

   PRIMOD=.F.
ELSE
   SELECT WOPE_SB2
   APPEND BLANK
   REPLACE AV_CODCON WITH V_CONTO
   REPLACE AV_DESCR  WITH V_DESCR
   REPLACE AV_TIPOCO WITH V_TIPOCO
   REPLACE AV_TOTALE WITH ABS(V_SALDO)
   REPLACE AV_SALDOI WITH V_SALDOI

	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 	
	   V_OLDA=SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
	ELSE
	   V_OLDA=SUBSTR(V_CONTO,1,(PUB_SOTTOG-1))
	ENDIF
	** SERGIO 18/12/2021 FINE 

   PRIMOA=.F.
ENDIF

RETURN


**************************************************************************
PROCEDURE SBCAGWF2_CCO
**************************************************************************

V_SALDO = V_TOTD - V_TOTA


IF V_DBASE = "CONTI"
   IF V_SALDO = 0
      RETURN
   ENDIF
ENDIF


IF V_SALDO > 0
   SELECT WOPE_SB1
   APPEND BLANK
   REPLACE DA_CCOS   WITH V_CCO
   REPLACE DA_CODCON WITH V_CONTO
   REPLACE DA_DESCR  WITH V_DESCR
   REPLACE DA_TIPOCO WITH V_TIPOCO
   REPLACE DA_TOTALE WITH ABS(V_SALDO)
   REPLACE DA_SALDOI WITH V_SALDOI

	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
	   V_OLDD=SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
	ELSE
	   V_OLDD=SUBSTR(V_CONTO,1,(PUB_SOTTOG-1))
	ENDIF
	** SERGIO 18/12/2021 FINE


   PRIMOD=.F.


	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
	   __CONTO  = ALLTRIM(V_CCO) + SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
	ELSE
	   __CONTO  = ALLTRIM(V_CCO) + SUBSTR(V_CONTO,1,(PUB_SOTTOG -1))
	ENDIF
	** SERGIO 18/12/2021 FINE


   =CREA_MASTRI_SWOPE_SB1(__CONTO)


ELSE


   SELECT WOPE_SB2
   APPEND BLANK
   REPLACE AV_CCOS   WITH V_CCO
   REPLACE AV_CODCON WITH V_CONTO
   REPLACE AV_DESCR  WITH V_DESCR
   REPLACE AV_TIPOCO WITH V_TIPOCO
   REPLACE AV_TOTALE WITH ABS(V_SALDO)
   REPLACE AV_SALDOI WITH V_SALDOI
   V_OLDA=SUBSTR(V_CONTO,1,(PUB_SOTTOG-1))
   PRIMOA=.F.

   __CONTO  = ALLTRIM(V_CCO) + SUBSTR(V_CONTO,1,(PUB_SOTTOG -1))
   =CREA_MASTRI_SWOPE_SB2(__CONTO)


ENDIF


RETURN

**************************************************************************
FUNCTION CREA_MASTRI_SWOPE_SB1
**************************************************************************
PARA _CONTO__


   SELECT SWOPE_SB1
   SET ORDER TO SWOPE_SB1
   SET NEAR ON
   SET EXACT ON

   SEEK _CONTO__			&& VERIFICO SE ESISTE IL GRUPPO/MASTRO NELLA SEZIONE : SE NO DEVO SPOSTARE IL CONTONELL'ALTRA SEZIONE

   IF  FOUND()

	   REPLACE DA_TOTALE WITH DA_TOTALE + ABS(V_SALDO)
	   REPLACE DA_SALDOI WITH DA_SALDOI + V_SALDOI
	
   ELSE
	   APPEND BLANK
	   REPLACE DA_CCOS   WITH V_CCO
		   
		** SERGIO 18/12/2021 INIZIO
		IF PUB_CONTOSIMILCEE 
		   REPLACE DA_CODCON WITH SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
		ELSE
		   REPLACE DA_CODCON WITH SUBSTR(V_CONTO,1,(PUB_SOTTOG -1))
		ENDIF
		** SERGIO 18/12/2021 FINE	   
	   
	   
	   REPLACE DA_DESCR  WITH V_DESCR
	   REPLACE DA_TIPOCO WITH V_TIPOCO
	   REPLACE DA_TOTALE WITH ABS(V_SALDO)
	   REPLACE DA_SALDOI WITH V_SALDOI
   ENDIF	


RETURN

**************************************************************************
FUNCTION CREA_MASTRI_SWOPE_SB2
**************************************************************************
PARA _CONTO__

   SELECT SWOPE_SB2
   SET ORDER TO SWOPE_SB2
   SET NEAR ON
   SET EXACT ON

   SEEK _CONTO__			&& VERIFICO SE ESISTE IL GRUPPO/MASTRO NELLA SEZIONE : SE NO DEVO SPOSTARE IL CONTONELL'ALTRA SEZIONE

   IF  FOUND()

	   REPLACE AV_TOTALE WITH AV_TOTALE + ABS(V_SALDO)
	   REPLACE AV_SALDOI WITH AV_SALDOI + V_SALDOI
	
   ELSE
	   APPEND BLANK
	   REPLACE AV_CCOS   WITH V_CCO

		** SERGIO 18/12/2021 INIZIO
		IF PUB_CONTOSIMILCEE 
		   REPLACE AV_CODCON WITH SUBSTR(V_CONTO,1,PUB_GRUPPOCF)
		ELSE
		   REPLACE AV_CODCON WITH SUBSTR(V_CONTO,1,(PUB_SOTTOG -1))
		ENDIF
		** SERGIO 18/12/2021 FINE	   

   
	   REPLACE AV_DESCR  WITH V_DESCR
	   REPLACE AV_TIPOCO WITH V_TIPOCO
	   REPLACE AV_TOTALE WITH ABS(V_SALDO)
	   REPLACE AV_SALDOI WITH V_SALDOI
   ENDIF	


