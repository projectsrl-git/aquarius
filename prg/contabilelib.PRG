			IF UPPER(ALLTRIM(PAR_TMOV)) == "A"
				_Saldo_part = _Saldo_part - PAR_FATT
			ENDIF
		ENDSCAN
	ENDIF
	IF _Saldo_part = 0
		_DataPagamento__ = _DataPagamento__ult
