	__SALDO07  = SALDO07
	__SALDO08  = SALDO08
	__SALDO09  = SALDO09
	__SALDO10  = SALDO10


	TOTALE_RIPARTITO = __SALDO01 + __SALDO02 + __SALDO03 + __SALDO04 + __SALDO05
	TOTALE_RIPARTITO = TOTALE_RIPARTITO + __SALDO06 + __SALDO07 + __SALDO08 + __SALDO09 + __SALDO10

	IF TOTALE_DA_RIPARTIRE <> TOTALE_RIPARTITO
