	 ID_UNIQUE              C(200), ;
	 PAR_RAGSOC 			C(40),  ;
	 PAR_NPART 				N(10,0),;
	 PAR_DTSCAD 			C(10),	;
	 PAR_CODCLI 			C(13),	;
	 PAR_CODACQ 			C(3),	;
	 PAR_COSATRATTA 		C(5),	;
	 PAR_GRADOIMPORTANZA	C(5),	;
	 PAR_FORMAPAGAMENTO		C(5),	;
	 PAR_TIPOCONTRATTO		C(5),	;
	 PAR_PRIPAGA 			C(4),	;
	 PAR_FATT				N(20,3),;
	 PAR_FATTD				N(20,3),;
	 PAR_FATTA				N(20,3),;
	 PAR_BANCA 				C(10))	



SELECT &__CURSORE_DA_ELABORARE
GO TOP

DO WHILE .NOT. EOF()

    SELECT &__CURSORE_DA_ELABORARE
	SCATTER MEMVAR

    ___CODCLI = PAR_CODCLI

    x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
    *x_codi = "for_codcli = '" + ALLTRIM(SUBSTR(___CODCLI,PUB_SOTTOG,PUB_CONTO)) + "'"
	x_codi = "for_codcli = '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(___CODCLI,RAT('.',___CODCLI,1)+1))), ALLTRIM(SUBSTR(___CODCLI,PUB_SOTTOG,PUB_CONTO))) + "'"  && SERGIO - 18/12/2021
    
    
    x_cond = x_soci + " and " + x_codi
    Csql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
    IF !ExecCommand(cSql,"u_for_an")
      return(.f.)
    ENDIF

	SELECT CUR_SALDI_FOR
