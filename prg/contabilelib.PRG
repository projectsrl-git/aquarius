***********************************
PROCEDURE AUTO_CCOST
***********************************

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(M.CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP
IF EOF()
    =MESSAGEBOX('<<AUTO_CCOST>> conto '+ALLTRIM(M.CONTO)+' non trovato',16,'*** ATTENZIONE ***')
    RETURN
ENDIF


IF !ExecCommand("select * from U_CCO_GR where 0=1","U_CCO_GR")
  return(.f.)
ENDIF
SELECT U_CCO_GR

IF !ExecCommand("select * from U_CCO_LE where 0=1","U_CCO_LE")
  return(.f.)
ENDIF

SELECT U_CCO_LE
HH=AFIELDS(TRANSITO)
CREATE CURSOR CU_CCO_LE FROM ARRAY TRANSITO
INDEX ON LEG_SEQUEN TAG SEQUEN ADDITIVE

M.DARIP = 0
IF M.DARE <> 0
   M.DARIP = M.DARE
ENDIF
IF M.AVERE <> 0
   M.DARIP = M.AVERE
ENDIF
M.RIPA     = 0
M.SALDO    = 0

v_seek	= 'TOP' + M.TOP
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   DES = DESCRI
ENDIF

IF M.CODSYS = SPACE(10) .OR. EMPTY(M.CODSYS)
   X_CODSYS = SYS(2015)
   x_soci = "leg_codsoc = '" + PUB_CODSOC + "'"
   x_ctop = "leg_codtop = '    '"
   x_cont = "leg_codcon = '" + ALLTRIM(M.CONTO) + "'"
   cSql="SELECT * FROM U_CCO_LE WHERE " + x_soci + " and " + x_ctop + " and " + x_cont + ;
                                      " order by leg_codsoc,leg_codtop,leg_codcon,leg_sequen"
   IF !ExecCommand(cSql,"U_CCO_LE")
      return(.f.)
   ENDIF
   SELECT U_CCO_LE
   GO TOP
   IF EOF()
   ELSE
      IF LEG_CODTOP = SPACE(04) .AND. LEG_CODCON = M.CONTO
         V_CODTOP = LEG_CODTOP
         V_CODCON = LEG_CODCON
         DO WHILE .T.
            IF EOF()
               EXIT
            ENDIF
            IF LEG_CODTOP = V_CODTOP .AND. LEG_CODCON = V_CODCON
            ELSE
               EXIT
            ENDIF
            SCATTER MEMVAR MEMO
            IF (M.LEG_CODCCO = SPACE(13) .OR. EMPTY(M.LEG_CODCCO)) .AND. ;
               (M.LEG_CODGRU = SPACE(10) .OR. EMPTY(M.LEG_CODGRU))
               SKIP +1
               LOOP
            ENDIF
            IF M.LEG_CODGRU = SPACE(10) .OR. EMPTY(M.LEG_CODGRU)
            ELSE
               M.LEG_CODCCO = SPACE(13)
               x_soci = "gru_codsoc = '" + PUB_CODSOC + "'"
               x_codi = "gru_codice = '" + ALLTRIM(M.LEG_CODGRU) + "'"
               cSql="SELECT * FROM U_CCO_GR WHERE " + x_soci + " and " + x_codi + ;
                                                  " order by gru_codsoc,gru_codice"
               IF !ExecCommand(cSql,"U_CCO_GR")
                  return(.f.)
               ENDIF
               SELECT U_CCO_GR
               GO TOP
               DO WHILE .T.
                  IF EOF()
                     EXIT
                  ENDIF
                  IF GRU_CODICE = M.LEG_CODGRU
                  ELSE
                     EXIT
                  ENDIF
                  M.LEG_DESGRU = GRU_DESCRI
                  M.LEG_CODCCO = GRU_CODCCO
                  M.LEG_DESCCO = GRU_DESCCO
                  M.LEG_NATURA = GRU_NATURA
                  M.LEG_PERCEN = GRU_PERCEN
                  M.LEG_VALORE = 0
                  IF M.LEG_PERCEN > 0
                     M.LEG_VALORE = ROUND(((M.DARIP * M.LEG_PERCEN) / 100),2)
                  ENDIF
                  SELECT CORPO_MOV
                  REPLACE CODSYS WITH X_CODSYS
                  REPLACE CODGRU WITH M.LEG_CODGRU
                  REPLACE CODCCO WITH M.LEG_CODCCO
                  M.CODSYS = CODSYS
                  M.CODGRU = CODGRU
                  M.CODCCO = CODCCO
                  SELECT CORPO_CCO
                  SET ORDER TO I_CORPO2
                  SEEK X_CODSYS + M.LEG_CODGRU + M.LEG_CODCCO
                  IF FOUND()
                  ELSE
                     APPEND BLANK
                     REPLACE CCO_CODSYS WITH X_CODSYS
                     REPLACE CCO_CODGRU WITH M.LEG_CODGRU
                     REPLACE CCO_DESGRU WITH M.LEG_DESGRU
                     REPLACE CCO_CODCCO WITH M.LEG_CODCCO
                     REPLACE CCO_DESCCO WITH M.LEG_DESCCO
                     REPLACE CCO_NATURA WITH M.LEG_NATURA
                     REPLACE CCO_PERCEN WITH M.LEG_PERCEN
                     REPLACE CCO_VALORE WITH M.LEG_VALORE
                  ENDIF
                  SELECT U_CCO_GR
                  SKIP +1
               ENDDO
               SELECT U_CCO_LE
               SKIP +1
               LOOP
            ENDIF
            M.LEG_VALORE = 0
            IF LEG_IMPFIS > 0
               M.LEG_VALORE = M.LEG_IMPFIS
               M.LEG_PERCEN = 0
            ENDIF
            IF M.LEG_PERCEN > 0
               M.LEG_VALORE = ROUND(((M.DARIP * M.LEG_PERCEN) / 100),2)
            ENDIF
            SELECT CORPO_MOV
            REPLACE CODSYS WITH X_CODSYS
            REPLACE CODGRU WITH M.LEG_CODGRU
            REPLACE CODCCO WITH M.LEG_CODCCO
            M.CODSYS = CODSYS
            M.CODGRU = CODGRU
            M.CODCCO = CODCCO
            SELECT CORPO_CCO
            SET ORDER TO I_CORPO2
            SEEK X_CODSYS + M.LEG_CODGRU + M.LEG_CODCCO
            IF FOUND()
            ELSE
               APPEND BLANK
               REPLACE CCO_CODSYS WITH X_CODSYS
               REPLACE CCO_CODGRU WITH M.LEG_CODGRU
               REPLACE CCO_DESGRU WITH M.LEG_DESGRU
               REPLACE CCO_CODCCO WITH M.LEG_CODCCO
               REPLACE CCO_DESCCO WITH M.LEG_DESCCO
               REPLACE CCO_NATURA WITH M.LEG_NATURA
               REPLACE CCO_PERCEN WITH M.LEG_PERCEN
               REPLACE CCO_VALORE WITH M.LEG_VALORE
            ENDIF
            SELECT U_CCO_LE
            SKIP +1
         ENDDO
      ENDIF
   ENDIF
ENDIF

