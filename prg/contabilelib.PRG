*************************************************************************
*   AGGIORNAMENTO DEI D.BASECONTI/CENTRI DI COSTO  DA PRIMANOT          *
*************************************************************************
PROCEDURE REG_CCOSTI

SELECT CORPO_MOV
SCATTER MEMVAR MEMO

SELECT CORPO_CCO
SET ORDER TO I_CORPO3
SEEK M.CODSYS + M.CODGRU + M.CODCCO

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF CCO_CODSYS = M.CODSYS .AND. ;
      CCO_MOVGRU = M.CODGRU .AND. ;
      CCO_MOVCCO = M.CODCCO
   ELSE
      EXIT
   ENDIF

   Z_NATURA = CCO_NATURA
   Z_CODGRU = CCO_CODGRU
   Z_CODCCO = CCO_CODCCO
   Z_VALORE = CCO_VALORE
   Z_PERCEN = CCO_PERCEN

   **  1 --->>>> AGGIORNA IL D.B. DEI MOVIMENTI CENTRI DI COSTO
   IF Z_VALORE <> 0
      DO REG_AGCCI
   ENDIF

   SELECT CORPO_CCO
   SKIP +1

ENDDO

RETURN


