		CASE _MESE_PLAFOND = "10"
			REPLACE IVA_OTTOBR 	WITH IVA_OTTOBR - __IMPORTO_ESENTE
		CASE _MESE_PLAFOND = "11"
			REPLACE IVA_NOVEMB 	WITH IVA_NOVEMB - __IMPORTO_ESENTE
		CASE _MESE_PLAFOND = "12"
			REPLACE IVA_DICEMB 	WITH IVA_DICEMB - __IMPORTO_ESENTE
	ENDCASE
	
   		
	SELECT CORPO_MOV_SAVE
	SKIP +1
	
ENDDO


* ####################################### CALCOLA L'IMPORTO ESENTE DA TOGLIERE DAL PLAFOND IN BASE AL CODICE IVA #######################################

__IMPORTO_ESENTE_DA_TOGLIERE = 0
SELECT CORPO_MOV
SET ORDER TO I_CORPOMOV
GO TOP

DO WHILE !EOF()

   	IF DELETED()
		SELECT CORPO_MOV
    	SKIP +1
    	LOOP
   	ENDIF

	IF ALLTRIM(IVA) = "NO"			&& SCARTA I MOVIMENTI FORNITORI
		SELECT CORPO_MOV
    	SKIP +1
    	LOOP
   	ENDIF
   	
   	IF !CERCA_IVA_PLAFOND(IVA)		&& SCARTA I MOVIMENTI IVA CHE NON ENTRANO NEL CALCOLO DEL PLAFOND RESIDUO
		SELECT CORPO_MOV
    	SKIP +1
    	LOOP
   	ENDIF

	SELECT CORPO_MOV
	__IMPORTO_ESENTE_DA_TOGLIERE = __IMPORTO_ESENTE_DA_TOGLIERE + DARE+AVERE
	
	SELECT CORPO_MOV
	SKIP +1
	
ENDDO



