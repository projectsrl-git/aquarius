_SAVE_IVA = ''
_SAVE_IMPORTO_IVA_DA_COMPENSARE = 0
_SAVE_CONTO_CONTABILE_FORNITORE = ""
_SAVE_RAGIONE_SOCIALE_FORNITORE = ""

DO WHILE .T.								&& CANCELLA TUTTA LA LISTA , INTERCETTA L'IMPORTO IVA DEL FORNITORE DA COMPENSARE

   IF EOF()
      EXIT
   ENDIF


       SELECT CORPO_MOV

	   IF IVA = "NO"
	
	    * ___________________________________>> INTERCETTA IL CODICE DEL FORNITORE DA COMPENSARE
	
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		x_cont = "con_conto = '" + ALLTRIM(CONTO) + "'"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont
		Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
		IF !ExecCommand(cSql,"cur_conti")
		   return(.f.)
		ENDIF
		SELECT cur_conti
		GO TOP
		IF EOF()
	        CL_FO  = ""
		ELSE
			CL_FO  = SUBSTR(CUR_conti.CON_TIPOCO,1,1)
	    ENDIF
	
	   SELECT CORPO_MOV
	   IF CL_FO = "F"  && VERIFICA SE CONTO FORNITORE
	   	_SAVE_CONTO_CONTABILE_FORNITORE =   ALLTRIM(CONTO)
	   ENDIF

   ELSE

*!*	     * ___________________________________>> INTERCETTA L'IMPORTO IVA DEL FORNITORE DA COMPENSARE
*!*	     _SAVE_IVA = IVA
*!*	     v_seek   = 'IVA'+ALLTRIM(_SAVE_IVA)
*!*	     v_chiave = 'codice'
*!*	     cSql="SELECT * FROM para WHERE "+V_CHIAVE+ " = ?V_SEEK"
*!*	     IF !ExecCommand(cSql,"civa_para")
*!*	        return(.f.)
*!*	     ENDIF
*!*	     SELECT CIVA_PARA
*!*	     GO TOP
*!*	     IF EOF()
*!*	        PUB_ERRORE=MESSAGEBOX('Codice iva non esistente'+CHR(13)+'in archivio parametri',64,'*** ATTENZIONE ***')
*!*	     ENDIF
*!*	     LIB       = VAL(SUBSTR(LIBERA,1,3))
*!*	     TIPOIVA   = SUBSTR(LIBERA,100,1)
*!*	     PERIVAI   = SUBSTR(LIBERA,110,3)

*!*	     _SAVE_IMPORTO_IVA_DA_COMPENSARE =  ROUND(M.TOTDOCU - (M.TOTDOCU  * 100 / (LIB+100)),2)

   ENDIF


   SELECT CORPO_MOV
   DELETE
   SKIP +1

ENDDO

_SAVE_IMPORTO_IVA_DA_COMPENSARE = M.T_IMPOSTA  && ERASMO - 01/04/2022

IF !EMPTY(_SAVE_CONTO_CONTABILE_FORNITORE) 	&& PRELEVA RAGIONE SOCIALE FORNITORE
   *V_CODFOR = SUBSTR(_SAVE_CONTO_CONTABILE_FORNITORE,PUB_SOTTOG,9)
   * 18/12/2021 SERGIO INIZIO
   IF PUB_CONTOSIMILCEE
	   V_CODFOR = SCORPRA_CODICE_CLIENTE_FORNITORE_SE_SIMILCEE(_SAVE_CONTO_CONTABILE_FORNITORE)
   ELSE
	   V_CODFOR = SUBSTR(_SAVE_CONTO_CONTABILE_FORNITORE,PUB_SOTTOG,9)
   ENDIF
   * 18/12/2021 SERGIO FINE
   
   
   x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "for_codcli = '" + ALLTRIM(V_CODFOR) + "'"
   x_cond = x_soci + " and " + x_codi
   cSql = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
   IF !ExecCommand(cSql,"CUR_FORNITORE")
      RETURN .F.
   ENDIF
   SELECT CUR_FORNITORE
   GO TOP
   IF !EOF()
      _SAVE_RAGIONE_SOCIALE_FORNITORE = FOR_RAGSOC
   ELSE
      _SAVE_RAGIONE_SOCIALE_FORNITORE = ""
   ENDIF
ENDIF


SELECT CORPO_MOV
SET ORDER TO I_CORPOMOV
GO TOP

M.SYS_PNAUTO = SYS_PNAUTO_IN_VARIAZIONE	&& SIA IN INSERIMENTO/CHE VARIAZIONE DELLA PN PADRE RIPORTO IL SYS DI LEGAME SULLA PN FIGLIA

NUMPRO_PAR   = ALLTRIM(PN_C)
NPART_PAR    = 0 && VAL(NPROT)
NPRO_PAR     = 900
NREG_PAR     = STR((VAL(NREG)+1),10,0)

M.CONTO      = _SAVE_CONTO_CONTABILE_FORNITORE
M.DESCRIC    = _SAVE_RAGIONE_SOCIALE_FORNITORE
M.TOTDOCU    = _SAVE_IMPORTO_IVA_DA_COMPENSARE
M.CECO       = SPACE(13)

M.DARE       = _SAVE_IMPORTO_IVA_DA_COMPENSARE && IMPOSTO IN DARE IL VALORE IVA DA COMPENSARE DEL FORNITORE
M.AVERE      = 0
M.NATURA     = "D"

IF NOTAC = "S"	&& VERIFICA SE IL TOP DELLA REGISTRAZIOBE ORIGINALE E' UNA NOTA DI ACCREDITO FORNITORE
	M.AVERE  = _SAVE_IMPORTO_IVA_DA_COMPENSARE && NOTA DI ACCREDITO : IMPOSTO IN AVERE IL VALORE IVA DA COMPENSARE DEL FORNITORE
	M.DARE   = 0
	M.NATURA = "A"
ENDIF
X_DESMOV     = M.DESCRIZ
X_DESMO1     = M.DESCRI1
M.T_IMPOSTA  = 0
M.IMPOSTA    = 0


IF CEE = "E" 	&& SE TIPO OPERAZIONE CEE
	M.TOP    = PUB_COMCEE
ENDIF

IF CEE = "R"	&& SE TIPO OPERAZIONE REVERSE CHARGE
	M.TOP    = PUB_FATRC
ENDIF

M.SEQUEN     = 100

M.NPARTCF    = PUB_ULTIMO_NPART  && ERASMO/SERGIO - 26/09/2018 - VALORIZZO N. PARTITA CON ULTIMO NR. PARTITA GENERATO IN APPOSITA ROUTINE


**1) CREO CONTROPARTITA FORNITORE
SELECT CORPO_MOV		
APPEND BLANK
GATHER MEMVAR MEMO



**2) CREO CONTROPARTITA COMPANSAZIONE IVA CEE
SELECT CORPO_MOV
STORE SPACE(13)  TO M.CECO
STORE 0          TO M.DARE
STORE 0          TO M.AVERE
STORE "NO"       TO M.IVA
STORE 0          TO M.IMPOSTA
STORE X_DESMOV   TO M.DESCRIZ
STORE X_DESMO1   TO M.DESCRI1
STORE XXCONTO    TO M.CONTO

M.AVERE     = _SAVE_IMPORTO_IVA_DA_COMPENSARE && IMPOSTO IN AVERE IL VALORE IVA DA COMPENSARE DELLA CONTROPARTITA
M.DARE      = 0
M.NATURA    = "A"

IF NOTAC = "S"	&& VERIFICA SE IL TOP DELLA REGISTRAZIONE ORIGINALE E' UNA NOTA DI ACCREDITO FORNITORE
	M.DARE = _SAVE_IMPORTO_IVA_DA_COMPENSARE && NOTA DI ACCREDITO : IMPOSTO IN DARE IL VALORE IVA DA COMPENSARE DEL FORNITORE
	M.AVERE  = 0
	M.NATURA = "D"
ENDIF

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(M.CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP
IF EOF()
   M.DESCRIC = ""
ELSE
   M.DESCRIC = ALLTRIM(CON_DESCR)
ENDIF

*TOTALI DI QUADRATURA DELLA PRIMA NOTA
IF M.DARE > 0
	M.T_DARE    = M.DARE
	M.T_AVERE   = M.DARE
ELSE
	M.T_AVERE   = M.AVERE
	M.T_DARE    = M.T_AVERE
ENDIF

SELECT CORPO_MOV
APPEND BLANK
M.SEQUEN = M.SEQUEN + 10
GATHER MEMVAR MEMO
GO TOP


RETURN

***************************************************
PROCEDURE REG_CANCELLA_COMPENSAZIONE_IVA_AUTOMATICA
***************************************************

*ANNULLO VECCHIA REGISTRAZIONE DI PRIMA NOTA DI COMPENSAZIONE AUTOMATICA IVA CEE
x_soci = "mov_soc = '" + PUB_CODSOC + "'"
x_anno = "mov_anno = '" + PUB_ANNO + "'"
x_nint = "MOV_PNAUTO = '" + ALLTRIM(SYS_PNAUTO_IN_VARIAZIONE) + "'"
cSql   = "SELECT * FROM mov_cont WHERE " + x_soci + " and " + x_anno + " and " + x_nint + ;
                                  " order by mov_soc,mov_anno,mov_numpro,mov_sequen"
IF !ExecCommand(cSql,"MOV_CONT_CUx")
   return(.f.)
ENDIF
SELECT MOV_CONT_CUx
GO TOP
_MOV_NUMPRO_COMPENSAZIONE_IVA = MOV_NUMPRO

SELECT MOV_CONT_CUx
GO TOP
IF EOF()
ELSE

   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF DELETED()
         SKIP +1
         LOOP
      ENDIF


      SELECT MOV_CONT_CUx

      WCONTO     = MOV_CONTO
      WMESE      = SUBSTR(MOV_DTREG,6,2)
      WDARE  	 = 0
      WAVERE 	 = 0
  	  ____DARE	 = 0
	  ____AVERE	 = 0

      IF MOV_TMOV='D'
         WDARE		=MOV_IMP
	  	 ____DARE	=MOV_IMP
      ELSE
         WAVERE		=MOV_IMP
	  	 ____AVERE	=MOV_IMP
      ENDIF

      *===>>> ANNULLO FISICO DELLA REGISTRAZIONE SU MOV_CONT DI COMPENSAZIONE IVA CEE/REVERSE CHARGE
      SELECT MOV_CONT_CUx
      _DELETE = ID_UNIQUE
      CSQL    = "DELETE FROM MOV_CONT WHERE ID_UNIQUE = ?_DELETE"
      IF !ExecCommand(CSQL,"MOV_CONT")
         RETURN (.f.)
      ENDIF

      __CON_TIPOCO = ""

      *===>>> STORNO DA DATABSES CONTI
      IF M.TOP = "CHI"
         WMESE = "12"
      ENDIF
      x_soci = "con_soc = '" + PUB_CODSOC + "'"
      x_anno = "con_anno = '" + PUB_ANNO + "'"
      x_annp = "con_anno = '" + PUB_ANNOP + "'"
      x_cont = "con_conto = '" + ALLTRIM(WCONTO) + "'"
      x_cond = x_soci + " and " + x_anno + " and " + x_cont
      x_conp = x_soci + " and " + x_annp + " and " + x_cont
      IF M.TOP = "CHI"
         Csql  = "select * from conti where " + x_conp + " order by con_soc,con_anno,con_conto"
      ELSE
         Csql  = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
      ENDIF
      IF !ExecRW(cSql,"CONTI","R")
         return(.f.)
      ENDIF
      SELECT CONTI
      IF RECCOUNT() = 0
      ELSE

          	 __CON_TIPOCO = CON_TIPOCO

	      	 IF ALLTRIM(PUB_TIPOGE) = "PREVISIONALE"
				 * CHI_EUR_ITL
				 IF M.TOP = "CHI"
			        REPLACE PRE_IMP_D WITH (PRE_IMP_D - CAMBIO(PUB_VALPRE,WDARE,PUB_CAMPRE))
		    	    REPLACE PRE_IMP_A WITH (PRE_IMP_A - CAMBIO(PUB_VALPRE,WAVERE,PUB_CAMPRE))
			        WIMPD='PRE_DA'+WMESE
		    	    WIMPA='PRE_AV'+WMESE
		            REPLACE &WIMPD    WITH &WIMPD - CAMBIO(PUB_VALPRE,WDARE,PUB_CAMPRE)
		          	REPLACE &WIMPA    WITH &WIMPA - CAMBIO(PUB_VALPRE,WAVERE,PUB_CAMPRE)
				 ELSE			
			        REPLACE PRE_IMP_D WITH (PRE_IMP_D - CAMBIO(XVALUTA,WDARE,XCAMBIO))
		    	    REPLACE PRE_IMP_A WITH (PRE_IMP_A - CAMBIO(XVALUTA,WAVERE,XCAMBIO))
			        WIMPD='PRE_DA'+WMESE
		    	    WIMPA='PRE_AV'+WMESE
		            REPLACE &WIMPD    WITH &WIMPD - CAMBIO(XVALUTA,WDARE,XCAMBIO)
		          	REPLACE &WIMPA    WITH &WIMPA - CAMBIO(XVALUTA,WAVERE,XCAMBIO)
			 	 ENDIF

 			     IF CON_TIPOCO = "C"  OR CON_TIPOCO = "F"
					 IF TI_TOP = "S"	&& FATTURA CLIENTE/FORNITORE
						 IF _NOTAC <> "S"	&& NOTA CREDITO CLIENTE/FORNITORE
						    REPLACE   PRE_FATTURA   WITH PRE_FATTURA - CAMBIO(XVALUTA,(WDARE+WAVERE),XCAMBIO)
						 ENDIF
					 ENDIF
					 IF _NOTAC = "S"	&& NOTA CREDITO CLIENTE/FORNITORE
					    REPLACE   PRE_NOTAC   WITH PRE_NOTAC - CAMBIO(XVALUTA,(WDARE+WAVERE),XCAMBIO)
					 ENDIF
 			     ENDIF


	         ELSE
	
				 * CHI_EUR_ITL
				 IF M.TOP = "CHI"
			        REPLACE CON_IMP_D WITH (CON_IMP_D - CAMBIO(PUB_VALPRE,WDARE,PUB_CAMPRE))
		    	    REPLACE CON_IMP_A WITH (CON_IMP_A - CAMBIO(PUB_VALPRE,WAVERE,PUB_CAMPRE))
			        WIMPD='CON_DA'+WMESE
		    	    WIMPA='CON_AV'+WMESE
		            REPLACE &WIMPD    WITH &WIMPD - CAMBIO(PUB_VALPRE,WDARE,PUB_CAMPRE)
		          	REPLACE &WIMPA    WITH &WIMPA - CAMBIO(PUB_VALPRE,WAVERE,PUB_CAMPRE)
				 ELSE			
			        REPLACE CON_IMP_D WITH (CON_IMP_D - CAMBIO(XVALUTA,WDARE,XCAMBIO))
		    	    REPLACE CON_IMP_A WITH (CON_IMP_A - CAMBIO(XVALUTA,WAVERE,XCAMBIO))
			        WIMPD='CON_DA'+WMESE
		    	    WIMPA='CON_AV'+WMESE
		            REPLACE &WIMPD    WITH &WIMPD - CAMBIO(XVALUTA,WDARE,XCAMBIO)
		          	REPLACE &WIMPA    WITH &WIMPA - CAMBIO(XVALUTA,WAVERE,XCAMBIO)
			 	 ENDIF

 			     IF CON_TIPOCO = "C"  OR CON_TIPOCO = "F"
					 IF TI_TOP = "S"	&& FATTURA CLIENTE/FORNITORE
						 IF _NOTAC <> "S"	&& NOTA CREDITO CLIENTE/FORNITORE
						    REPLACE   CON_FATTURA   WITH CON_FATTURA - CAMBIO(XVALUTA,(WDARE+WAVERE),XCAMBIO)
						 ENDIF
					 ENDIF
					 IF _NOTAC = "S"	&& NOTA CREDITO CLIENTE/FORNITORE
					    REPLACE   CON_NOTAC   WITH CON_NOTAC - CAMBIO(XVALUTA,(WDARE+WAVERE),XCAMBIO)
					 ENDIF
 			     ENDIF



	         ENDIF



      ENDIF
      IF !ExecRW(cSql,"CONTI","W")
         return(.f.)
      ENDIF


      SELECT MOV_CONT_CUx
      SKIP +1


   ENDDO

ENDIF




* ANNULLO VECCHIO INDICE DI PRIMA NOTA DI COMPENSAZIONE AUTOMATICA IVA CEE
_DELETE = _MOV_NUMPRO_COMPENSAZIONE_IVA
CSQL    = "DELETE FROM INDICE WHERE mov_numpro = ?_DELETE"
IF !ExecCommand(CSQL,"INDICE")
   RETURN (.f.)
ENDIF



RETURN




***************************************************
FUNCTION CALCOLA_RATEI_RISCONTI
***************************************************
LPARAMETERS __TYP_REGAUT,__SYS_PNAUTO_IN_VARIAZIONE



IF ALLTRIM(M.RAR) <> "S"				&& NON SI TRATTA DI RATEI / RISCONTI
	RETURN								&& NON SI TRATTA DI RATEI / RISCONTI
ENDIF									&& NON SI TRATTA DI RATEI / RISCONTI
IF ALLTRIM(__TYP_REGAUT) <> "RAT-RIS"	&& NON SI TRATTA DI RATEI / RISCONTI
	RETURN								&& NON SI TRATTA DI RATEI / RISCONTI
ENDIF									&& NON SI TRATTA DI RATEI / RISCONTI

** SE STO VARIANDO UNA REGISTRAZIONE CON CALCOLO RATEI / RISCONTI :
** ANNULLO TUTTE LE REGISTRAZIONI PREVISIONALI E NON ESISTENTI SU MOV_CONT PER POTERLE REINSERIRE EX NOVO

IF !EMPTY(SYS_PNAUTO_IN_VARIAZIONE)											&& SOLO SE VARIAZIONE	
	=REG_CANCELLA_REGISTRAZIONI_RATEI_RISCONTI(__SYS_PNAUTO_IN_VARIAZIONE)	&& CANCELLA REGISTRAZIONI RATEI/RISCONTI IN VARIAZIONE PER REINSERIRLE EX NOVO
	M.SYS_PNAUTO = SYS_PNAUTO_IN_VARIAZIONE									&& SOLO SE VARIAZIONE
ELSE
	M.SYS_PNAUTO = SYS(2015)				
ENDIF

SELECT CURSOR_RAR
GO TOP
IF EOF()
	RETURN										&& NON C'E' STATA CONFERMA DI CREAZIONE RATEI / RISCONTI : TERMINO LA REGISTRAZIONE
ENDIF


=DEF_AQUAREP()									&& DEFINISCE LE VARIABILI PER LA CREAZIONE DELLE PRIME NOTE


__TOP = SEEK_PARA('TOP',ALLTRIM(M.TOP),'CODICE','CODICE',"4,10","_PJ_PARA","C F")
DES   = ""
IF EMPTY(__TOP)
   =MESSAGEB("Codice Top obbligatorio",64,"*** ATTENZIONE ***")
   THISFORM.REFRESH
   RETURN
ENDIF


SELECT _pj_para
__TOP     			= UPPER(M.TOP)
DES       			= DESCRI
TP        			= SUBSTR(LIBERA,1,1)
FATTURA   			= SUBSTR(LIBERA,2,1)
VER_CONTO 			= SUBSTR(LIBERA,12,1)	&& C=CLIENTE F=FORNITORE
NATURA    			= TP
NOTACREDITO         = SUBSTR(LIBERA,11,1)


** --------------------------------- CALCOLA IL TOTALE DEGLI ESERCIZI SUCCESSIVI DA SCONTARE NELL'ESERCIZIO CORRENTE ------------------------------
__RAR_TOTALE_MOVIMENTI_ESERCIZI_NON_CORRENTE = 0
__NOTE = ""

SELECT CURSOR_RAR
GO TOP
DO WHILE .NOT. EOF()


	IF SUBSTR(RAR_DATA_FIN_COMPET,7,4) = PUB_ANNO	&& SCARTA I MOVIMENTI DI COMPETENZA NELL'ESERCIZIO CORRENTE
		SELECT CURSOR_RAR
		SKIP + 1
		LOOP
	ENDIF

	__RAR_TOTALE_MOVIMENTI_ESERCIZI_NON_CORRENTE = __RAR_TOTALE_MOVIMENTI_ESERCIZI_NON_CORRENTE + RAR_VALORE
	__NOTE = ALLTRIM(RAR_DESCRIZ)		
	
	
	SELECT CURSOR_RAR
	SKIP +1
	
ENDDO


** 1) -------------------- CREA LA PRIMA REGISTRAZIONE DI COMPETENZA DELL'ESERCIZIO IN CORSO ------------DA RATEO(D) >> ASSICURAZIONE(A)---------------------
** DA RATEO(D) -------------------------
CGE_CON_     	= M.RAR_RATEORI									&& CONTO CONTABILE
CGE_DESCO_ 		= M.RAR_DESCRAR									&& DESCRIZIONE CONTO CONTABILE
CGE_TOPX_		= PUB_RATRIS									&& TIPO OPERAZIONE RATEI/RISCONTI
CGE_COMM_		= __NOTE 										&& NOTE DESCRITTIVE
CGE_COM1_		= ""											&& NOTE DESCRITTIVE
CGE_DA_			= __RAR_TOTALE_MOVIMENTI_ESERCIZI_NON_CORRENTE 	&& IMPORTO DA RISCONTARE
CGE_AV_			= 0								
**CGE_DATAREG_	= "31/12/"+PUB_ANNO								&& DATA REGISTRAZIONE DATAREG
CGE_DATAREG_	= DATAREG										&& DATA REGISTRAZIONE : STESSA DATA DELLA FATTURA
PUB_TIPOGE_		= "PREVISIONALE"								&& REGISTRAZIONE PREVISIONALE
CGE_PNAUTO		= M.SYS_PNAUTO									&& SYS PER COLLEGAMENTO ALLE REGISTRAZIONI CREATE AUTOMATICAMENTE
CGE_REGAUT		= "RAT-RIS"										&& TIPOLOGIA REGISTRAZIONE AUTOMATICA : RATEI / RISCONTI
=VALORIZZA_RATEI_RISCONTI_DARE(CGE_CON_,CGE_DESCO_,CGE_TOPX_,CGE_COMM_,CGE_COM1_,CGE_DA_,CGE_AV_,CGE_DATAREG_,PUB_TIPOGE_)

** ASSICURAZIONE(A)---------------------
CGE_CON_     	= M.RAR_CONTROP									&& CONTO CONTABILE
CGE_DESCO_ 		= M.RAR_DESCRIC 								&& DESCRIZIONE CONTO CONTABILE
CGE_TOPX_		= PUB_RATRIS									&& TIPO OPERAZIONE RATEI/RISCONTI
CGE_COMM_		= __NOTE 										&& NOTE DESCRITTIVE
CGE_COM1_		= ""											&& NOTE DESCRITTIVE
CGE_DA_			= 0	
CGE_AV_			= __RAR_TOTALE_MOVIMENTI_ESERCIZI_NON_CORRENTE 	&& IMPORTO DA RISCONTARE							
**CGE_DATAREG_	= "31/12/"+PUB_ANNO								&& DATA REGISTRAZIONE DATAREG
CGE_DATAREG_	= DATAREG										&& DATA REGISTRAZIONE : STESSA DATA DELLA FATTURA
PUB_TIPOGE_		= "PREVISIONALE"								&& REGISTRAZIONE PREVISIONALE
CGE_PNAUTO		= M.SYS_PNAUTO									&& SYS PER COLLEGAMENTO ALLE REGISTRAZIONI CREATE AUTOMATICAMENTE
CGE_REGAUT		= "RAT-RIS"										&& TIPOLOGIA REGISTRAZIONE AUTOMATICA : RATEI / RISCONTI
=VALORIZZA_RATEI_RISCONTI_AVERE(CGE_CON_,CGE_DESCO_,CGE_TOPX_,CGE_COMM_,CGE_COM1_,CGE_DA_,CGE_AV_,CGE_DATAREG_,PUB_TIPOGE_)




** 2) -------------------- CREA LE REGISTRAZINI DI COMPETENZA DEGLI ESERCIZI SUCCESSIVI ------------DA ASSICURAZIONE(D) >> RATEO(A)---------------------

SELECT CURSOR_RAR
GO TOP
DO WHILE .NOT. EOF()


	IF SUBSTR(RAR_DATA_FIN_COMPET,7,4) = PUB_ANNO	&& SCARTA I MOVIMENTI DI COMPETENZA NELL'ESERCIZIO CORRENTE
		SELECT CURSOR_RAR
		SKIP + 1
		LOOP
	ENDIF
	
	
    SCATTER MEMVAR MEMO
	

	** DA ASSICURAZIONE(D) -------------------------
	CGE_CON_     	= M.RAR_CONTROP									&& CONTO CONTABILE
	CGE_DESCO_ 		= M.RAR_DESCRIC 								&& DESCRIZIONE CONTO CONTABILE
	CGE_TOPX_		= PUB_RATRIS									&& TIPO OPERAZIONE RATEI/RISCONTI
	CGE_COMM_		= __NOTE 										&& NOTE DESCRITTIVE
	CGE_COM1_		= ""											&& NOTE DESCRITTIVE
	CGE_DA_			= M.RAR_VALORE									&& IMPORTO DA RISCONTARE
	CGE_AV_			= 0								
    CGE_DATAREG_	= "02/01/"+SUBSTR(M.RAR_DATA_FIN_COMPET,7,4)	&& DATA REGISTRAZIONE
	PUB_TIPOGE_		= "PREVISIONALE"								&& REGISTRAZIONE PREVISIONALE
	CGE_PNAUTO		= M.SYS_PNAUTO									&& SYS PER COLLEGAMENTO ALLE REGISTRAZIONI CREATE AUTOMATICAMENTE
	CGE_REGAUT		= "RAT-RIS"										&& TIPOLOGIA REGISTRAZIONE AUTOMATICA : RATEI / RISCONTI
	=VALORIZZA_RATEI_RISCONTI_DARE(CGE_CON_,CGE_DESCO_,CGE_TOPX_,CGE_COMM_,CGE_COM1_,CGE_DA_,CGE_AV_,CGE_DATAREG_,PUB_TIPOGE_)

	** rateo(A)---------------------
	CGE_CON_     	= M.RAR_RATEORI									&& CONTO CONTABILE
	CGE_DESCO_ 		= M.RAR_DESCRAR									&& DESCRIZIONE CONTO CONTABILE
	CGE_TOPX_		= PUB_RATRIS									&& TIPO OPERAZIONE RATEI/RISCONTI
	CGE_COMM_		= __NOTE 										&& NOTE DESCRITTIVE
	CGE_COM1_		= ""											&& NOTE DESCRITTIVE
	CGE_DA_			= 0	
	CGE_AV_			= M.RAR_VALORE									&& IMPORTO DA RISCONTARE							
    CGE_DATAREG_	= "02/01/"+SUBSTR(M.RAR_DATA_FIN_COMPET,7,4)	&& DATA REGISTRAZIONE
    PUB_TIPOGE_		= "PREVISIONALE"								&& REGISTRAZIONE PREVISIONALE
	CGE_PNAUTO		= M.SYS_PNAUTO									&& SYS PER COLLEGAMENTO ALLE REGISTRAZIONI CREATE AUTOMATICAMENTE
	CGE_REGAUT		= "RAT-RIS"										&& TIPOLOGIA REGISTRAZIONE AUTOMATICA : RATEI / RISCONTI
	=VALORIZZA_RATEI_RISCONTI_AVERE(CGE_CON_,CGE_DESCO_,CGE_TOPX_,CGE_COMM_,CGE_COM1_,CGE_DA_,CGE_AV_,CGE_DATAREG_,PUB_TIPOGE_)



	SELECT CURSOR_RAR
	SKIP +1
	
ENDDO

** 3) -------------------- RIPORTA MOV_PNAUTO SULLA REGISTRAZIONE PRINCIPALE ---------------------------

x_soci = "mov_soc = '" + PUB_CODSOC + "'"
x_anno = "mov_anno = '" + PUB_ANNO + "'"
x_nint = "MOV_NUMPRO = '" + ALLTRIM(PUB_NUOVO_NUMPRO_PADRE) + "'"
cSql   = "SELECT * FROM mov_cont WHERE " + x_soci + " and " + x_anno + " and " + x_nint + ;
                                  " order by mov_soc,mov_anno,mov_numpro,mov_sequen"
IF !ExecRW(cSql,"MOV_CONT","R")
  return(.f.)
ENDIF

SELECT MOV_CONT
GO TOP
DO WHILE .NOT.EOF()
	REPLACE MOV_PNAUTO 	WITH M.SYS_PNAUTO
	REPLACE MOV_REGAUT 	WITH "RAT-RIS"
	SKIP +1
ENDDO
IF !ExecRW(cSql,"MOV_CONT","W")
  return(.f.)
ENDIF




RETURN

