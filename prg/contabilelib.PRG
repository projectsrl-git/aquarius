				   STORE FOR_CCOST4    TO M.COD04
				   STORE FOR_CCOST5    TO M.COD05
				   STORE FOR_PERCON1   TO M.PERC1
				   STORE FOR_PERCON2   TO M.PERC2
				   STORE FOR_PERCON3   TO M.PERC3
				   STORE FOR_PERCON4   TO M.PERC4
				   STORE FOR_PERCON5   TO M.PERC5

				   M.DESCCOS = ""
				   x_soci = "con_soc = '" + PUB_CODSOC + "'"
				   x_anno = "con_anno = '" + PUB_ANNO + "'"
				   x_codi = "con_conto = '" + ALLTRIM(M.CECO) + "'"
				   x_cond = x_soci + " and " + x_anno + " and " + x_codi
				   Csql   = "select * from ccosto where " + x_cond + " order by con_soc,con_anno,con_conto"
				   IF !ExecCommand(Csql,"cur_ccosto")
				      return(.f.)
				   ENDIF
				   SELECT cur_ccosto
				   IF !EOF()
				    	M.DESCCOS = CUR_CCOSTO.CON_DESCR
				   ENDIF

				   STORE 0  TO 		M.SALDO01
				   STORE 0  TO 		M.SALDO02
				   STORE 0  TO 		M.SALDO03
				   STORE 0  TO 		M.SALDO04
				   STORE 0  TO 		M.SALDO05

	                IF !EMPTY(M.COD01)			   			   			   			
						IF M.PERC1 = 0
							M.PERC1 = 100
						ENDIF
	                ENDIF
	

					IF M.PERC1 <> 0
						M.SALDO01 = ((M.DARIP * M.PERC1)/100)
					ENDIF
					IF M.PERC2 <> 0
						M.SALDO02 = ((M.DARIP * M.PERC2)/100)
					ENDIF
					IF M.PERC3 <> 0
						M.SALDO03 = ((M.DARIP * M.PERC3)/100)
					ENDIF
					IF M.PERC4 <> 0
						M.SALDO04 = ((M.DARIP * M.PERC4)/100)
					ENDIF
					IF M.PERC5 <> 0
						M.SALDO05 = ((M.DARIP * M.PERC5)/100)
					ENDIF

	                __OK_CENTRIDICOSTO = .T.

		       ENDIF

		   ENDIF PUB_CCOFOR && CENTRI DI COSTO DA ANAGRAFICA FORNITORI

		   IF PUB_CCOCLI && CENTRI DI COSTO DA ANAGRAFICA CLIENTI

		       IF USED("U_CLI_AN")
			       SELECT U_CLI_AN
			       STORE CLI_CCOST1    TO M.CECO             && PERMETTE DI AGGIORNARE I DATABASES
				   STORE CLI_CCOST1    TO M.COD01
				   STORE CLI_CCOST2    TO M.COD02
				   STORE CLI_CCOST3    TO M.COD03
				   STORE CLI_CCOST4    TO M.COD04
				   STORE CLI_CCOST5    TO M.COD05
				   STORE CLI_PERCON1   TO M.PERC1
				   STORE CLI_PERCON2   TO M.PERC2
				   STORE CLI_PERCON3   TO M.PERC3
				   STORE CLI_PERCON4   TO M.PERC4
				   STORE CLI_PERCON5   TO M.PERC5

				   M.DESCCOS = ""
				   x_soci = "con_soc = '" + PUB_CODSOC + "'"
				   x_anno = "con_anno = '" + PUB_ANNO + "'"
				   x_codi = "con_conto = '" + ALLTRIM(M.CECO) + "'"
				   x_cond = x_soci + " and " + x_anno + " and " + x_codi
				   Csql   = "select * from ccosto where " + x_cond + " order by con_soc,con_anno,con_conto"
				   IF !ExecCommand(Csql,"cur_ccosto")
				      return(.f.)
				   ENDIF
				   SELECT cur_ccosto
				   IF !EOF()
				    	M.DESCCOS = CUR_CCOSTO.CON_DESCR
				   ENDIF

				   STORE 0  TO 		M.SALDO01
				   STORE 0  TO 		M.SALDO02
				   STORE 0  TO 		M.SALDO03
				   STORE 0  TO 		M.SALDO04
				   STORE 0  TO 		M.SALDO05


	                IF !EMPTY(M.COD01)			   			   			   			
						IF M.PERC1 = 0
							M.PERC1 = 100
						ENDIF
	                ENDIF
	

					IF M.PERC1 <> 0
						M.SALDO01 = ((M.DARIP * M.PERC1)/100)
					ENDIF
					IF M.PERC2 <> 0
						M.SALDO02 = ((M.DARIP * M.PERC2)/100)
					ENDIF
					IF M.PERC3 <> 0
						M.SALDO03 = ((M.DARIP * M.PERC3)/100)
					ENDIF
					IF M.PERC4 <> 0
						M.SALDO04 = ((M.DARIP * M.PERC4)/100)
					ENDIF
					IF M.PERC5 <> 0
						M.SALDO05 = ((M.DARIP * M.PERC5)/100)
					ENDIF

	                __OK_CENTRIDICOSTO = .T.

			
			     ENDIF
			
			
		   ENDIF PUB_CCOCLI && CENTRI DI COSTO DA ANAGRAFICA CLIENTI


		   IF !__OK_CENTRIDICOSTO
			   =MESSAGEBOX('PER CORTESIA CONTROLLA LA RIPARTIZIONE DEI CENTRI DI COSTO ',16,'*** ATTENZIONE ***')
	       ENDIF

		   SELECT CORPO_MOV

	       REPLACE  CECO       WITH  M.CECO     && PERMETTE DI AGGIORNARE I DATABASES
		   REPLACE  COD01      WITH  M.COD01
		   REPLACE  COD02      WITH  M.COD02
		   REPLACE  COD03      WITH  M.COD03
		   REPLACE  COD04      WITH  M.COD04
		   REPLACE  COD05      WITH  M.COD05
		   REPLACE  PERC1      WITH  M.PERC1
		   REPLACE  PERC2      WITH  M.PERC2
		   REPLACE  PERC3      WITH  M.PERC3
		   REPLACE  PERC4      WITH  M.PERC4
		   REPLACE  PERC5      WITH  M.PERC5
		   REPLACE	SALDO01    WITH  M.SALDO01
		   REPLACE	SALDO02    WITH  M.SALDO02
		   REPLACE	SALDO03    WITH  M.SALDO03
		   REPLACE	SALDO04    WITH  M.SALDO04
		   REPLACE	SALDO05    WITH  M.SALDO05


	   ENDIF EMPTY(CECO) && SE NON E' STATO DGITATO NULLA NEL CENTRO DI COSTO
				


	   EXIT




ENDDO


SELECT CORPO_MOV
SET ORDER TO I_CORPOMOV
GO TOP


RETURN


