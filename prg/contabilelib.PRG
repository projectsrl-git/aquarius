********************************************************************
*  DETERMINA LE RIPARTIZIONI IVA PER I PARTITARI                   *
********************************************************************
PROCEDURE REG_DETIVA

SELECT CORPO_MOV
SET ORDER TO I_CORPOMOV
GO TOP

DO WHILE !EOF()

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   SELECT CORPO_MOV

   CON=CONTO

   x_soci = "con_soc = '" + PUB_CODSOC + "'"
   x_anno = "con_anno = '" + PUB_ANNO + "'"
   x_annp = "con_anno = '" + PUB_ANNOP + "'"
   x_cont = "con_conto = '" + ALLTRIM(CON) + "'"
   x_cond = x_soci + " and " + x_anno + " and " + x_cont
   x_conp = x_soci + " and " + x_annp + " and " + x_cont
   IF M.TOP = "CHI"
      Csql  = "select * from conti where " + x_conp + " order by con_soc,con_anno,con_conto"
   ELSE
      Csql  = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
   ENDIF
   IF !ExecCommand(cSql,"cur_conti")
      return(.f.)
   ENDIF
   SELECT cur_conti
   GO TOP
   IF EOF()
      PUB_ERRORE = MESSAGEBOX('Conto non trovato durante la determinazione IVA: '+ALLTRIM(CON)+CHR(13)+'durante la registrazione',64,'*** ATTENZIONE ***')
      RETURN
   ENDIF
   CLI_FOR = SUBSTR(CON_TIPOCO,1,1)

   SELECT CORPO_MOV

   COMM = DESCRIZ
   COM1 = DESCRI1
   DA   = DARE
   AV   = AVERE
   IV   = IVA
   IMP  = IMPOSTA

   * SE STO TRATTANDO UN CONTO CLIENTE OR FORNITORE MOEMORIZZO IL TOTALE
   * PER GLI ALTRI CONTI EFFETTUO UNA VERIFICA PER MEMORIZZARE I SINGOLI
   * VALORI DI IMPOSTA

   IF CLI_FOR = 'C' .OR. CLI_FOR = 'F'
      V_TOTDOC = DA+AV
   ELSE
      * ---->>>> VERIFICA IMPOSTE
      V_TROVATO = 'NO'
      V_IMPOSTA = V_IMPOSTA+IMP
      * VERIFICA SE ESISTE UNA'ALIQUOTA GIA' TRATTATA IN PRECEDENZA
      IF IV=V_CIVA1
         V_TROVATO  = 'SI'
         V_CIVA1    = IV
         V_IMPOIVA1 = V_IMPOIVA1 + (DA+AV)
         V_IMPSIVA1 = V_IMPSIVA1 + IMP
      ENDIF
      IF IV=V_CIVA2
         V_TROVATO  = 'SI'
         V_CIVA2    = IV
         V_IMPOIVA2 = V_IMPOIVA2 + (DA+AV)
         V_IMPSIVA2 = V_IMPSIVA2 + IMP
      ENDIF
      IF IV=V_CIVA3
         V_TROVATO  = 'SI'
         V_CIVA3    = IV
         V_IMPOIVA3 = V_IMPOIVA3 + (DA+AV)
         V_IMPSIVA3 = V_IMPSIVA3 + IMP
      ENDIF
      IF IV=V_CIVA4
         V_TROVATO  = 'SI'
         V_CIVA4    = IV
         V_IMPOIVA4 = V_IMPOIVA4 + (DA+AV)
         V_IMPSIVA4 = V_IMPSIVA4 + IMP
      ENDIF
      IF IV=V_CIVA5
         V_TROVATO  = 'SI'
         V_CIVA5    = IV
         V_IMPOIVA5 = V_IMPOIVA5 + (DA+AV)
         V_IMPSIVA5 = V_IMPSIVA5 + IMP
      ENDIF
      * RIVERIFICA SE DEVE CARICARE LE IMPOSTE SUL PRIMO ELEMENTO LIBERO
      IF V_CIVA1=SPACE(03) .AND. V_TROVATO='NO'
         V_TROVATO  = 'SI'
