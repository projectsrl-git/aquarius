***************************************************************************
FUNCTION carica_log_procedure_chiusura
***************************************************************************
PARA __seq,__messag,__esito,__ins_mod,__note

_SELX_ = SELECT()

IF PARAMETERS() < 5
	__note = ''
ENDIF

IF UPPER(ALLTRIM(__ins_mod)) = 'I'
   SELECT LOG_CHI_MES
   APPEND BLANK
   REPLACE L_SEQ  	WITH __seq
   REPLACE L_MSG 	WITH __messag
   REPLACE L_ESITO 	WITH __esito
   REPLACE L_NOTE 	WITH __note
ENDIF

IF UPPER(ALLTRIM(__ins_mod)) = 'M'
   SELECT LOG_CHI_MES
   IF !EMPTY(ALLTRIM(__seq))
   		REPLACE L_SEQ  	WITH __seq
   ENDIF
   IF !EMPTY(ALLTRIM(__messag))
   		REPLACE L_MSG 	WITH __messag
   ENDIF
   IF !EMPTY(ALLTRIM(__esito))
   		REPLACE L_ESITO WITH __esito
   ENDIF
   IF !EMPTY(ALLTRIM(__note))
   		REPLACE L_NOTE WITH __note
   ENDIF
ENDIF

SELECT(_SELX_)

RETURN


**************************************
PROCEDURE SELE_CLI_DA_PROCEDURA_ASC000
**************************************
PARA XXX_CONTO,XXX_NDOC



=DEF_EURO()		&& DEFINISCE IL CURSORE PER LA GESTIONE DEI PARTITARI



IF !ExecCommand("select * from PART_CLI_EA where 0=1","PART_CLI_EA")				&& RIFERIMENTI CONTABILI PER EFFETTI ATTIVI REGISTRATI
   return(.f.)
ENDIF
SELECT PART_CLI_EA




** GESTIONE FATTURE CON ACCONTI ANTICIPATI


CREATE CURSOR WORK (;
  WIDUNIQUE C(200), ;
  WANNO    C(04), ;
  WSELEZ   C(06), ;
  WCONTO   C(13), ;
  WPART    C(10), ;
  WPARTW   C(10), ;
  WNREGIS  C(06), ;
  WDTREG   C(10), ;
  WNUMFAT  C(06), ;
  WDATFAT  C(10), ;
  WDATFAK  C(10), ;
  WNUMPRO  C(10), ;
  WPROTO   N(10), ;
  WDTSCAD  C(10), ;
  WDTSCAX  C(10), ;
  WCOVAL   C(03), ;
  WIMPVRIF N(17,3), ;
  WCAMBIO  N(17,10), ;
  WIMPORTO N(17,3), ;
  WAVERE   N(17,3), ;
  WIMPITL  N(17,3), ;
  WABBUO   N(17,3), ;
  WPAGA    N(17,3), ;
  WFATAGE  C(06), ;
  WSYS_PARTI C(10), ;
  WID_UNIQUE C(250), ;
  WSCARTABOLLATO C(1), ;
  WPAGATO  N(17,3))

INDEX ON WPART+WDTSCAX                          		TAG WORK
INDEX ON RIBALTA2(WDATFAT)+WNUMFAT+WDTSCAX              TAG WORKD
INDEX ON WANNO+STR(VAL(WPARTW))                 		TAG WORKE



OK_WORK = .F.

x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
x_codi = "par_codcli = '" + ALLTRIM(XXX_CONTO) + "'"
cSql   = "SELECT * FROM PART_CLI WHERE " + x_soci + " and " + x_codi + " order by par_codsoc,par_codcli"
IF !ExecCommand(cSql,"cur_partcli")
   return(.f.)
ENDIF
SELECT CUR_PARTCLI
GO TOP
IF EOF()
   RETURN
ENDIF



DO WHILE !EOF()

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF PAR_TIPODO = 'FAT' .AND. PAR_NPROG = 100
      SKIP + 1
      LOOP
   ENDIF

   IF PAR_TIPODO = 'INC' .AND. PAR_NPROG = 100
      SKIP + 1
      LOOP
   ENDIF

   IF PAR_TIPFAT = "AR$"   && TRATTA L'ARROTONDAMENTO PRECEDENTEMENTE CREATO
      SKIP + 1
      LOOP
   ENDIF

   * VERIFICA SE LA PARTITA E' CHIUSA

   VCONTO   = PAR_CODCLI	 	&& CODICE DEL CLIENTE
   VPARTITA = PAR_NPART	 		&& PARTITA CLIETE
   VCURSORE = "VERPART"	 		&& NOME DEL CURSORE DI LAVORO
   VRAGGR   = .T.           	&& .T. RAGGRUPPA RITORNA UN RECORD CON IL SALDO DI TUTTI I MOVIMENTI DARE-AVERE
   VDIFFAR  = .F.			 	&& .T. CREA UN RECORD PER CHIUDERE LA PARTITA NEL CASO DI DIFFERENZA DOVUTA ALL'EURO DI 0,02 CENTESIMI
   VTIPO    = "C"			 	&& C= CLIENTE F= FORNITORE	



   IF EUR_PART(VTIPO,"PART_CLI",VCONTO,VPARTITA,VCURSORE,VRAGGR,VDIFFAR)  && PARTITA CHIUSA
	  SELECT CUR_PARTCLI		
      SKIP + 1
      LOOP
   ENDIF


   SELECT CUR_PARTCLI
   M.WANNO    = PAR_ANNO
   M.WSELEZ   = SPACE(06)
   M.WCONTO   = PAR_CODCLI
   M.WPART    = STR(PAR_NPART,10,0)
   M.WPARTW   = STR(PAR_NPART,10,0)
   M.WNREGIS  = PAR_NREG
   M.WNUMFAT  = PAR_NUMFAT
   M.WDATFAT  = PAR_DTFAT
   M.WDATFAK  = PAR_DTFAT
   M.WPROTO   = PAR_NPART
   M.WDTSCAD  = PAR_DTSCAD
   M.WDTSCAX  = PAR_DTSCAD
   M.WNP      = STR(PAR_NPART,10,0)
   M.WFATAGE  = PAR_NPROT
   M.WCAMBIO  = PAR_CAMBIO
   M.WCOVAL   = PAR_VALUTA
   M.WNUMPRO  = PAR_NUMPRO
   M.WDTREG   = PAR_DTREG

   IF !EMPTY(SYS_PARTI)
      M.WSYS_PARTI = SYS_PARTI
   ELSE
      M.WSYS_PARTI = SYS(2015)
   ENDIF

   M.WID_UNIQUE  = ID_UNIQUE

   IF PAR_TIPODO="FAT" .OR. PAR_TIPODO="INS"
      IF PAR_TIPFAT = "AR$"   && TRATTA L'ARROTONDAMENTO PRECEDENTEMENTE CREATO
         M.WIMPORTO = PAR_FATT
    	 M.WIMPITL  = 0
      ELSE
         IF PAR_TMOV = "A"	&&NOTA DI CREDITO
            M.WIMPORTO = (TEURO(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT))) * -1
            M.WIMPITL  = (TLIRE(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT))) * -1
         ELSE
            M.WIMPORTO = TEURO(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT))
            M.WIMPITL  = TLIRE(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT))
         ENDIF
      ENDIF
      M.WPAGATO  = 0
      M.WIMPVRIF = PAR_FATT
   ELSE
      IF PAR_TIPFAT = "AR$"   && TRATTA L'ARROTONDAMENTO PRECEDENTEMENTE CREATO
         M.WIMPORTO = PAR_FATT * -1
         M.WIMPITL  = 0
         M.WPAGATO  = 0
      ELSE
  	     IF PAR_TMOV = "D"	&&NOTA DI CREDITO
            M.WIMPORTO = (TEURO(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT)))
            M.WIMPITL  = (TLIRE(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT)))
         ELSE
	        M.WIMPORTO = (TEURO(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT)) * -1)
		    M.WIMPITL  = (TLIRE(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT))) * -1
		 ENDIF
	     M.WPAGATO  = (TLIRE(M.WCOVAL,PAR_FATT,RIBALTA2(M.WDATFAT)))
      ENDIF
      M.WIMPVRIF = PAR_FATT * -1
   ENDIF

   SELECT WORK
   SET ORDER TO WORK
   _SEEK = M.WPART+M.WDTSCAX
   SEEK _SEEK
   IF FOUND()
      REPLACE WIMPORTO WITH WIMPORTO+M.WIMPORTO
      REPLACE WIMPITL  WITH WIMPITL+M.WIMPITL
      REPLACE WPAGATO  WITH WPAGATO +M.WPAGATO
   ELSE
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE WIMPVRIF WITH WIMPVRIF+M.WIMPVRIF
      REPLACE WDATFAT  WITH RIBALTA2(M.WDATFAT)
      REPLACE WDTSCAD  WITH RIBALTA2(M.WDTSCAD)
   ENDIF

   SELECT CUR_PARTCLI
   SKIP +1

ENDDO

SELECT WORK
GO TOP


SELECT WORK
SET ORDER TO WORKE
SET FILTER TO WIMPORTO <> 0 OR WAVERE <> 0

GO TOP

OK_WORK = .F.
DO WHILE .NOT.EOF()       && VERIFICA SE EFFETTIVAMENTE ESISTE FATTURA IN LISTA

   OK_WORK = .T.           && SE HO I PAGAMENTI E NON LA FATTURA IMPORTO PAGATO > WIMPORTO

   IF WIMPORTO < 0
     REPLACE WAVERE   WITH ABS(WIMPORTO)
     REPLACE WIMPORTO WITH 0
   ENDIF

   SKIP +1
ENDDO

IF !OK_WORK
   RIT = MESSAGEBOX("Nessuna partita aperta per il cliente digitato",62,"CONFERMA")
   RETURN
ENDIF




x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(XXX_CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP
IF EOF()
   _DESCONTO = ""
ELSE
   _DESCONTO = ALLTRIM(CON_DESCR)
ENDIF


SELECT WORK
SET ORDER TO WORKD
GO TOP


NOTACREDITO = ""
FATTURA = ""
_TITOLO = "Situazione partite aperte del cliente : "+ _DESCONTO
DO FORM FORM\PRIMACLI WITH _TITOLO LINKED
REC_SELE=0





SELECT WORK
GO TOP


DO WHILE .NOT. EOF()

   IF WABBUO = 0 .AND. WPAGA = 0
      SELECT WORK
      SKIP +1
      LOOP
   ENDIF


   M.WANNO 					= WANNO
   M.CNUMFAT 				= WNUMFAT
   M.CDATFAT 				= RIBALTA2(WDATFAT)
   M.CDTSCAD 				= RIBALTA2(WDTSCAD)
   M.CPROTO  				= WPROTO
   M.WCONTO  				= WCONTO
   M.CFATAGX 				= WFATAGE
   XWABBUO   				= WABBUO
   XWPAGA    				= WPAGA
   XWAVERE                  = WAVERE
   M.WCONTO					= WCONTO
   M.WNREGIS  				= WNREGIS
   M.WPART 					= WPART
   M.WNUMPRO				= WNUMPRO
   M.WDTREG 				= WDTREG

   IF XWPAGA    <> 0
	   IF XWAVERE  = 0
	       _TOTALE_PAGATO           = _TOTALE_PAGATO + WPAGA
	   ELSE
	       _TOTALE_PAGATO           = _TOTALE_PAGATO - WPAGA			&& NOTE DI CREDITO
	   ENDIF
   ENDIF

   IF WABBUO = 999999
      XWABBUO = 0                          		&& FORZA ABBUONO A 0 SE NON DA GESTIRE
   ENDIF

   && AGGIORNA CURSORE RIFERIMENTI PARTITE EFFETTI ATTIVI

   IF WPAGA <> 0

		M.DAGGANCIO     = M.TAGGANCIO
		M.PAR_CODSOC	= PUB_CODSOC
		M.PAR_ANNO		= M.WANNO
		M.PAR_NUMPRO	= M.WNUMPRO
		M.PAR_NREG		= M.WNREGIS
		M.PAR_DTREG 	= M.WDTREG
		M.PAR_NPART		= VAL(M.WPART)
		M.PAR_DTFAT		= M.CDATFAT
*!*			M.PAR_NUMFAT	= M.CNUMFAT
		M.PAR_NUMFAT	= M.CFATAGX
		M.PAR_NPROT     = M.CFATAGX
		M.PAR_FATT		= XWPAGA
		M.PAR_DTSCAD 	= M.CDTSCAD
		M.PAR_CODCLI	= XXX_CONTO
		M.PAR_RAGSOC	= _DESCONTO
        M.SYS_PARTI     = WSYS_PARTI

        SELECT PART_CLI_EA
        APPEND BLANK
        DO PART_CLI_EA


   ENDIF


   SELECT WORK
   SKIP +1

ENDDO


RETURN

********************************************************
FUNCTION CARICA_EFFETTI_ATTIVI
********************************************************
*!*	LA FUNZIONE RITORNA :
*!*
*!*		IL TOTALE DEGLI EFFETTI ATTIVI NELLA VARIABILE  ___TOTALE_EFFETTI_ATTIVI
*!*		UN CURSORE CONTENENTE I RIFERIMENTI CONTABILI DEGLI EFFETTI ATTIVI : CURS_PART_CLI_EA
*!*		UN CURSORE CONTENENTE I RIFERIMENTI DEGLI EFFETTI ATTIVI : CURS_U_ASC_DD
*!*
*!*

PARA ___SYS_PARTI__



	IF !ExecCommand("select * from U_ASC_dd where 0=1","CUXX_U_ASC_DD")
	   return(.f.)
	ENDIF
	SELECT CUXX_U_ASC_DD
	HH=AFIELDS(TRANSITO)
	CREATE CURSOR CURS_U_ASC_DD FROM ARRAY TRANSITO

    ___TOTALE_EFFETTI_ATTIVI  = 0


	___SYS_PARTI= ___SYS_PARTI__

	x_sys_parti = "sys_parti = '" + ___SYS_PARTI + "'"
	
	cSql="SELECT * FROM PART_CLI_EA WHERE " + x_sys_parti  + ;
	                                   " order by par_codsoc,par_anno,par_npart"



    IF !ExecCommand(cSql,"CURS_PART_CLI_EA")
	   return(.f.)
	ENDIF
	
	
	SELECT CURS_PART_CLI_EA	
