   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      _COCO =SUBSTR(LIBERA,1,13)
   ELSE
      _COCO ='8050001      '     && PROVENTI VARI
   ENDIF
ELSE
   _COCO ='8010002      '     && VENDITA ITALIA PEZZI DI RICAMBIO
ENDIF

RETURN


