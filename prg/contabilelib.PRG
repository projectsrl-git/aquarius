*************************************************************************
*   AGGIORNAMENTO PARTITARIO CLIENTI                                    *
*************************************************************************
PROCEDURE CREA_PARCLI

RELEASE   V_CONPAG,V_BAE
PUBLIC    V_CONPAG,V_BAE

x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
*x_codi = "cli_codcli = '" + SUBSTR(CON,PUB_SOTTOG,PUB_CONTO) + "'"
x_codi = "cli_codcli = '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(CON,RAT('.',CON,1)+1))), ALLTRIM(SUBSTR(CON,PUB_SOTTOG,PUB_CONTO))) + "'"  && SERGIO - 18/12/2021

x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"cur_clienti")
   return(.f.)
ENDIF
SELECT cur_clienti
GO TOP
IF EOF()
   V_TELEFO  = SPACE(15)
   V_PARIVA  = SPACE(11)
   V_CONPAG  = CPA
   IF V_CONPAG  = "XXX"
      V_CONPAG  = SPACE(03)
   ENDIF
   V_BAE     = SPACE(05)
ELSE
   V_TELEFO  = CLI_TELEFO
   V_PARIVA  = CLI_PARIVA
   V_CONPAG  = CPA
   IF V_CONPAG  = "XXX"  .OR. EMPTY(V_CONPAG)
      V_CONPAG  = CLI_CONPAG
   ENDIF
   V_BAE     = CLI_BAE
ENDIF

IF !ExecCommand("select * from part_cli where 0=1","cur_partcli")
   return(.f.)
ENDIF


SELECT CUR_PARTCLI
APPEND BLANK
REC_PART=RECNO()
REPLACE PAR_CODSOC  WITH PUB_CODSOC
REPLACE PAR_ANNO    WITH PUB_ANNO
REPLACE PAR_TIPODO  WITH "FAT"
IF FATTURA='P'
   REPLACE PAR_TIPODO  WITH "PAG"
ENDIF


REPLACE PAR_DTSCAD  WITH RIBALTA2(DATASCAD)

IF FATTURA='I'    							&& INSOLUTO
   REPLACE PAR_TIPODO  WITH "FAT"			&& LO CONSIDERO COME FATTURA
ENDIF
IF FATTURA='N'
   REPLACE PAR_TIPODO  WITH "NCR"
ENDIF


REPLACE PAR_CODCLI  WITH CON
REPLACE PAR_RAGSOC  WITH DESCRIC
REPLACE PAR_DTREG   WITH RIBALTA2(DATAREG)
REPLACE PAR_DTFAT   WITH RIBALTA2(DATADOC)
REPLACE PAR_TIPFAT  WITH TOPX
REPLACE PAR_TOTIM   WITH (V_TOTDOC-V_IMPOSTA)
REPLACE PAR_TIMPOS  WITH V_IMPOSTA
REPLACE PAR_FATT    WITH V_TOTDOC
REPLACE PAR_NUMFAT  WITH NDOC
REPLACE PAR_NPROT   WITH ALLTRIM(NPROT)

IF EMPTY(NPROT)
	REPLACE PAR_NPROT   WITH ALLTRIM(SAVE_NPROT)
ENDIF


IF EMPTY(TOP_COL)
   REPLACE PAR_NPROG   WITH 100
ELSE
   REPLACE PAR_NPROG   WITH 900
ENDIF
IF PAR_TIPODO <> "FAT"  && GESTIONE INSERIMENTO DA PRIMA NOTA
   REPLACE PAR_NPROG   WITH 900
ENDIF

IF __CONTO ='I'   && APERTURA DI BILANCIO PER CLIENTI FORNITORI
   REPLACE PAR_TIPODO  WITH "PAG"
   REPLACE PAR_NPROG   WITH 900
ENDIF


REPLACE PAR_CODPAG  WITH V_CONPAG
REPLACE PAR_TEL     WITH V_TELEFO
REPLACE PAR_IVA     WITH V_PARIVA
IF EMPTY(TOP_COL)
   REPLACE PAR_NREG    WITH ALLTRIM(NREG)
ELSE
   REPLACE PAR_NREG    WITH ALLTRIM(NREG_PAR)
ENDIF


REPLACE PAR_CONTABILITA_PREVISIONALE    WITH " "


* --------  Classifica la partita -------- *
REPLACE PAR_COSATRATTA 		WITH M.___COSATRATTA
REPLACE PAR_GRADOIMPORTANZA WITH M.___GRADOIMPORTANZA
REPLACE PAR_FORMAPAGAMENTO 	WITH M.___FORMAPAGAMENTO
REPLACE PAR_TIPOCONTRATTO 	WITH M.___TIPOCONTRATTO
REPLACE PAR_CODACQ			WITH M.___CODACQ
REPLACE PAR_PRIPAGA			WITH M.___PRIPAGA
* --------  Classifica la partita -------- *


* ---------  Controllo ddt/fatture -------- *
REPLACE PAR_ANOMAX			WITH M.___xanomax
* ---------  Controllo ddt/fatture -------- *


* ------- MAX Nuovi Campi Per Euro ------- *
REPLACE PAR_CAMBIO WITH XCAMBIO
REPLACE PAR_VALUTA WITH XVALUTA
REPLACE PAR_DTVAL  WITH RIBALTA2(XDATAVAL)
* ------- MAX Nuovi Campi Per Euro ------- *

* ------- registrazione in valuta ------- *
IF PAR_VALUTA <> PUB_VALRIF
	REPLACE PAR_IMPVAL WITH PAR_FATT
ELSE
	REPLACE PAR_IMPVAL WITH 0
ENDIF
* ------- registrazione in valuta ------- *

** ------- GESTIONE EFFETTI --------**
REPLACE PAR_NUMATRI WITH M.EFF_NUMATRI
REPLACE PAR_EFFETDA WITH M.EFF_EFFETDA
REPLACE PAR_INTEPER WITH M.EFF_INTEPER
REPLACE PAR_NOTEFF  WITH M.EFF_NOTEFF
** ------- GESTIONE EFFETTI --------**

REPLACE PAR_BANCA   WITH BANCA
REPLACE PAR_NUMPRO  WITH ALLTRIM(PN_C)
REPLACE PAR_CIVA1   WITH V_CIVA1
REPLACE PAR_IMPO1   WITH V_IMPOIVA1
REPLACE PAR_IMPOS1  WITH V_IMPSIVA1
REPLACE PAR_TOT1    WITH V_IMPOIVA1+V_IMPSIVA1
REPLACE PAR_CIVA2   WITH V_CIVA2
REPLACE PAR_IMPO2   WITH V_IMPOIVA2
REPLACE PAR_IMPOS2  WITH V_IMPSIVA2
