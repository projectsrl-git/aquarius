				cSql="SELECT "+__campi__+__somma__+" FROM PART_FOR WHERE " + __condi__ +  ;
				    					                          " group by "+__campi__+" order by PAR_CODCLI"
                				    					
				    					
				IF !ExecCommand(cSql,"cur_dare")
