*************************************************************************
*   AGGIORNAMENTO DEI D.BASE C.COSTI + MOV_CCOSTO                       *
*************************************************************************
PROCEDURE CREA_CENTRI_DI_COSTO_DALLE_FATTURE_PROFESSIONISTI
PARA Z_CONTO,Z_NATURA,Z_CODGRU,Z_CODCCO,Z_VALORE,Z_PERCEN,Z_NDOC,Z_TOP,Z_IVA,Z_CAMBIO,Z_VALUTA,Z_PUBBLI,Z_CONTOP

AABBSS___    = SELECT()

**  1 --->>>> AGGIORNA IL D.B. DEI MOVIMENTI CENTRI DI COSTO

IF !ExecCommand("select * from mov_cco where 0=1","cur_movcco")
   return(.f.)
ENDIF
SELECT CUR_MOVCCO
APPEND BLANK
REPLACE MOV_COPRIM 			WITH Z_CONTO                && CONTO PRIMARIO
REPLACE MOV_CCO    			WITH Z_CODCCO
REPLACE MOV_SOC    			WITH PUB_CODSOC
REPLACE MOV_ANNO   			WITH PUB_ANNO

IF SUBSTR(DATREG,3,1) = '/'
   REPLACE MOV_DTREG  WITH RIBALTA2(DATREG)
ELSE
   REPLACE MOV_DTREG  WITH DATREG
ENDIF

REPLACE MOV_NREGIS 			WITH ALLTRIM(NREG)
REPLACE MOV_DTDOC  			WITH DTD
REPLACE MOV_NDOC   			WITH Z_NDOC
REPLACE MOV_TOP    			WITH Z_TOP
REPLACE MOV_NPROT  			WITH ALLTRIM(Z_NDOC)
REPLACE MOV_CONTO  			WITH Z_CODCCO
REPLACE MOV_IVA    			WITH Z_IVA
REPLACE MOV_IMPOST 			WITH Z_VALORE
REPLACE MOV_DESMOV 			WITH XDESF			
REPLACE MOV_DESMO1 			WITH "REGISTRAZIONE AUTOMATICA DA VENDITE"
REPLACE MOV_NUMPRO 			WITH ALLTRIM(PN_C)
REPLACE MOV_IMP    			WITH Z_VALORE
REPLACE MOV_CONTOP WITH ALLTRIM(Z_CONTOP)    && AGGANCIO CENTRO DI COSTO IN VARIAZIONE	&& ?????
REPLACE MOV_BOLLATOIVA    	WITH BOLLATOIVA
REPLACE MOV_PUBBLI          WITH Z_PUBBLI
REPLACE MOV_CONTABILITA_PREVISIONALE    WITH " "


REPLACE MOV_CAMBIO WITH Z_CAMBIO
REPLACE MOV_VALUTA WITH Z_VALUTA
REPLACE MOV_DTVAL  WITH DTD
REPLACE MOV_TMOV   WITH Z_NATURA
REPLACE MOV_CODGRU WITH Z_CODGRU
REPLACE MOV_PERCEN WITH Z_PERCEN

REPLACE MOV_COSATRATTA 		WITH ___COSATRATTA
REPLACE MOV_GRADOIMPORTANZA WITH ___GRADOIMPORTANZA
REPLACE MOV_FORMAPAGAMENTO 	WITH ___FORMAPAGAMENTO
REPLACE MOV_TIPOCONTRATTO 	WITH ___TIPOCONTRATTO
REPLACE MOV_CODACQ			WITH ___CODACQ
REPLACE MOV_PRIPAGA			WITH ___PRIPAGA


IF !ExecRW('','mov_cco','I','','CUR_MOVCCO')
   return(.f.)
ENDIF

**  2 --->>>> AGGIORNA IL D.B. DEI CENTRI DI COSTO

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_annp = "con_anno = '" + PUB_ANNOP + "'"
x_cont = "con_conto = '" + ALLTRIM(Z_CODCCO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
x_conp = x_soci + " and " + x_annp + " and " + x_cont
IF M.TOP = "CHI"
   Csql   = "select * from ccosto where " + x_conp + " order by con_soc,con_anno,con_conto"
ELSE
   Csql   = "select * from ccosto where " + x_cond + " order by con_soc,con_anno,con_conto"
ENDIF
IF !ExecRW(cSql,"CCOSTO","R")
   return(.f.)
ENDIF
SELECT CCOSTO
IF RECCOUNT() = 0
   PUB_ERRORE=MESSAGEBOX('Centro di costo inesistente : '+Z_CODCCO+CHR(13)+'durante aggiornamento reg. : '+NREG,64,'*** ATTENZIONE ***')
ELSE

   P_IMPD  = CON_IMP_D
   IF M.TOP = "CHI"
      MESE    = "12"
   ELSE
      MESE    = SUBSTR(DATREG,4,2)
   ENDIF
   VAR2    = "CON_DA"+MESE
   * CHI_EUR_ITL
   IF M.TOP = "CHI"
	  REPLACE   CON_IMP_D   WITH P_IMPD+CAMBIO(PUB_VALPRE,Z_VALORE,PUB_CAMPRE)
      REPLACE   &VAR2       WITH CAMBIO(PUB_VALPRE,Z_VALORE,PUB_CAMPRE)+&VAR2
   ELSE
      REPLACE   CON_IMP_D   WITH P_IMPD+CAMBIO(XVALUTA,Z_VALORE,XCAMBIO)
      REPLACE   &VAR2       WITH CAMBIO(XVALUTA,Z_VALORE,XCAMBIO)+&VAR2
   ENDIF

ENDIF
IF !ExecRW(cSql,"CCOSTO","W")
   return(.f.)
ENDIF



SELECT(AABBSS___)
RETURN


********************************************************************************************************
*		CERCA LA FATTURA DA ASSOCIARE ALLA NOTA DI ACCREDITO IN BASE AI DUE ULTIMI ESERCIZI CONTABILI  *
********************************************************************************************************
FUNCTION CERCA_FATTURA_CLIENTE
*PARAMETERS _codcli_
**=> ERASMO - INIZIO 06/02/2024
PARAMETERS _codcli_,_escludi_taggancio_

IF PCOUNT() >= 2
ELSE
	_taggancio_ = ""
ENDIF
**=> ERASMO - FINE 06/02/2024

XSS=STR(SELECT())

_ULTIMI_DUE_ANNI  = STR((VAL(PUB_ANNO) - 1),4,0)

x_anno   = "ord_anno   >= '" + _ULTIMI_DUE_ANNI + "'"
x_soci   = "ord_codsoc = '" + PUB_CODSOC + "'"
x_codcli = "ord_codcli = '" + _codcli_ + "'"
**=> ERASMO - INIZIO 06/02/2024
IF EMPTY(_escludi_taggancio_)
ELSE
	x_codcli = "ord_codcli = '" + _codcli_ + "' AND taggancio <> '" + _escludi_taggancio_ + "'"
ENDIF
**=> ERASMO - FINE 06/02/2024

**=> ERASMO - INIZIO 20/11/2025
*** PRIMA SBIANCO IL CAMPO SELEZIONE DI TUTTE LE FATTURE POTENZIALMENTE DA SELEZIONARE
cSql="UPDATE U_FAT_TT SET SELEZIONE = '' WHERE " + x_anno + " and " + x_soci + " and " + x_codcli
IF !ExecCommand(cSql,"UPD_U_FAT_TT")
   return(.f.)
ENDIF
**=> ERASMO - INIZIO 20/11/2025

cSql="SELECT  FATTURE.* FROM U_FAT_TT AS FATTURE INNER JOIN PARA AS PARA ON 'TOP'+FATTURE.ORD_CAUS=PARA.CODICE WHERE SUBSTRING(PARA.LIBERA,11,1)<>'S' AND " + x_anno + " and " + x_soci + " and " + x_codcli + "order by ord_codsoc,ord_anno,ord_numord"
IF !ExecRW(cSql,"U_FAT_TT_cursor","R")
   return(.f.)
ENDIF


SELECT U_FAT_TT_cursor
GO TOP
IF EOF()
   =MESSAGEBOX("Nessuna fattura da associare alla nota di accredito",16,"Attenzione")
   RETURN
ENDIF

**=> ERASMO - INIZIO 20/11/2025
*** SE PRE-SELEZIONATA IN PRECEDENZA, ASSOCIO LA FATTURA CON STESSO NR. PARTITA
IF !EMPTY(_escludi_taggancio_)
	*** ACCEDO TRAMITE PARTITARIO PERCHE' IL CAMPO ORD_NPROT CHE DOVREBBE CONTENERE IL NR.PARTITA NON SEMPRE E' ALLINEATO
	cSql="SELECT PAR_NPART,PAR_TIPFAT,PAR_NPROT,PAR_DTFAT,PAR_CODCLI,* FROM PART_CLI WHERE PAR_NPROG <> 100 AND PAR_TMOV = 'D' AND PAR_NPART IN (" + ;
			"SELECT PAR_NPART FROM PART_CLI WHERE PAR_NPROG <> 100 AND PAR_TIPFAT = '" + M.ORD_CAUS + "' AND PAR_NPROT = '" + M.ORD_NUMORD + ;
			"' AND PAR_DTFAT = '" + IIF(SUBSTR(M.ORD_DATORD,4,1)="/",M.ORD_DATORD,RIBALTA2(M.ORD_DATORD)) + "')"
	IF !ExecCommand(cSql,"TMP_PART_CLI")
	   return(.f.)
	ENDIF
	SELECT TMP_PART_CLI
	GO TOP
	IF !EOF()
		_NUMORD_FAT_LEG = PAR_NPROT
		_DATORD_FAT_LEG = PAR_DTFAT
		_RECNO_SEL = 0
		SELECT U_FAT_TT_cursor
		GO TOP
		SCAN
			IF ORD_NUMORD = _NUMORD_FAT_LEG AND ORD_DATORD = _DATORD_FAT_LEG
				REPLACE SELEZIONE WITH '==>'
				IF _RECNO_SEL = 0
					_RECNO_SEL = RECNO()
				ENDIF
			ENDIF
		ENDSCAN
		GO TOP
		IF _RECNO_SEL > 0
			GOTO _RECNO_SEL 
		ENDIF
	ENDIF
ENDIF
**=> ERASMO - FINE 20/11/2025

DO prg\browseview WITH "U_FAT_TT_cursor","Seleziona le fatture cliente da associare alla nota accredito","ORD_CAUS:top,W:4;ORD_CODCLI:codice cliente,W:10;ORD_RAGSOC:ragione sociale,W:35;ORD_DATORD:data documento,W:10;ORD_NUMORD:num.documento,W:6;ORD_VALORE:importo.,W:13;",500,700,.F.
SELECT U_FAT_TT_cursor
GO TOP

_NUMERO_RECORD_SELEZIONATI  = 0
__RITORNA_NPROT 			= 0

SELECT U_FAT_TT_cursor
GO TOP

COUNT FOR ALLTRIM(SELEZIONE) = '==>' TO _NUMERO_RECORD_SELEZIONATI
IF _NUMERO_RECORD_SELEZIONATI  > 15

			
			   DO PLAYWAV WITH "BLIP.WAV"

	 		   XDESCRI="Attenzione "
			   SET CLASSLIB TO "proj_lib.vcx" additive
			   oForm=CreateObject("MsgErr")
			   oform.edit1.Value=""+XDESCRI+CHR(13)+;
						  ""+CHR(13)+;			
						  "Puoi selezionare solo 15 fatture da legare alla nota credito"
			   oform.Show
			   RELEASE oForm
			   RETURN
			

ELSE
	
	M.ORD_NPAR01 = ''
	M.ORD_NPAR02 = ''
	M.ORD_NPAR03 = ''
	M.ORD_NPAR04 = ''
	M.ORD_NPAR05 = ''			
	M.ORD_NPAR06 = ''
	M.ORD_NPAR07 = ''
	M.ORD_NPAR08 = ''
	M.ORD_NPAR09 = ''
	M.ORD_NPAR10 = ''
	M.ORD_NPAR11 = ''
	M.ORD_NPAR12 = ''
	M.ORD_NPAR13 = ''
	M.ORD_NPAR14 = ''			
	M.ORD_NPAR15 = ''

	
	SELECT U_FAT_TT_cursor
	GO TOP

	DO WHILE .T.
	
	   IF EOF()
	      EXIT
	   ENDIF

	   IF ALLTRIM(SELEZIONE) <> '==>'
	      SELECT U_FAT_TT_cursor
	      SKIP +1
	      LOOP
	   ENDIF


            IF EMPTY(M.ORD_NPAR01)
              M.ORD_NPAR01 = ORD_NPROT
              SELECT U_FAT_TT_cursor
              SKIP +1
              LOOP
            ENDIF
            IF EMPTY(M.ORD_NPAR02)
              M.ORD_NPAR02 = ORD_NPROT
              SELECT U_FAT_TT_cursor
              SKIP +1
