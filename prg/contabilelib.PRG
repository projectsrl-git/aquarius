**********************
FUNCTION RINUM
**********************
* Funzione di RINUMERAZIONE SECONDO MODULO STAMPA DEI MANDATI
* Viene utilizzato nel report MAND001

PARA _CODICE
PRIVATE FS

FS = SELECT()

