		   REPLACE PAR_TIPODO  WITH "PAG"
		   REPLACE PAR_NPARTO  WITH _NPORI  && CONSIDERA COME NUMERO DI PARTITA ETERNO
	   ENDIF
   ENDIF

   REPLACE PAR_CODCLI  WITH CON
   REPLACE PAR_RAGSOC  WITH DESCRIC
   REPLACE PAR_DTREG   WITH RIBALTA2(DATAREG)
   REPLACE PAR_DTFAT   WITH RIBALTA2(DATADOC)
   REPLACE PAR_TIPFAT  WITH TOPX
   REPLACE PAR_TOTIM   WITH 0
   REPLACE PAR_TIMPOS  WITH 0
   REPLACE PAR_FATT    WITH M.SCA_VALSCA
   REPLACE PAR_DESMOV  WITH COMM
   REPLACE PAR_DESMO1  WITH COM1

   * --------  Gestione contabilitŕ previsionale -------- *
    IF ALLTRIM(PUB_TIPOGE) = "PREVISIONALE"
      REPLACE PAR_CONTABILITA_PREVISIONALE    WITH "P"
    ELSE
      REPLACE PAR_CONTABILITA_PREVISIONALE    WITH " "
    ENDIF
   * --------  Gestione contabilitŕ previsionale -------- *

      * --------  Blocca / sblocca registrazione previsionale -------- *
	  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIEFFETTIVA"
	      REPLACE PAR_CONTABILITA_PREVISIONALE    WITH " "
	  ENDIF
	  IF PUB_BLOCCA_SBLOCCA_PREVISIONALE="SIPREVISIONALE"
	      REPLACE PAR_CONTABILITA_PREVISIONALE    WITH "P"
	  ENDIF
      * --------  Blocca / sblocca registrazione previsionale -------- *

   * --------  Classifica la partita -------- *
   REPLACE PAR_COSATRATTA 		WITH M.___COSATRATTA
   REPLACE PAR_GRADOIMPORTANZA  WITH M.___GRADOIMPORTANZA
   REPLACE PAR_FORMAPAGAMENTO 	WITH M.___FORMAPAGAMENTO
   REPLACE PAR_TIPOCONTRATTO 	WITH M.___TIPOCONTRATTO
   REPLACE PAR_CODACQ			WITH M.___CODACQ
   REPLACE PAR_PRIPAGA			WITH M.___PRIPAGA
   * --------  Classifica la partita -------- *

   * ---------  Controllo ddt/fatture -------- *


   IF !EMPTY(M.___xanomax)									
	   REPLACE PAR_ANOMAX		WITH M.___xanomax				&& stň bloccando tutte le scadenze
	   IF __ESISTE_ALMENO_UN_BLOCCO_SU_SINGOLA_SCADENZA
		   REPLACE PAR_ANOMAX		WITH M.SCA_ANOMAX    		&& sono entrato in una singola scadenza e ho tolto il blocco
	   ENDIF
   ELSE
	   REPLACE PAR_ANOMAX		WITH M.SCA_ANOMAX 				&& stň eventualmente bloccando qualche scadenza
   ENDIF


   IF FATTURA = "S"  							&& SOLO PER FATTURE GESTISCE IL CAMPO PAR_STATO_CEE PER INTRASTAT
	  REPLACE PAR_STATO_CEE WITH M.STATO_CEE
   ELSE
	  REPLACE PAR_STATO_CEE WITH ""
   ENDIF


   * ---------  Controllo ddt/fatture -------- *


   * ------- MAX Nuovi Campi Per Euro ------- *
   REPLACE PAR_CAMBIO WITH XCAMBIO
   REPLACE PAR_VALUTA WITH XVALUTA
   REPLACE PAR_DTVAL   WITH RIBALTA2(DATA_SCAD)
   * ------- MAX Nuovi Campi Per Euro ------- *

	* ------- registrazione in valuta ------- *
	IF PAR_VALUTA <> PUB_VALRIF
		REPLACE PAR_IMPVAL WITH PAR_FATT
	ELSE
		REPLACE PAR_IMPVAL WITH 0
	ENDIF
	* ------- registrazione in valuta ------- *

   ** ------- GESTIONE EFFETTI --------**
   REPLACE PAR_NUMATRI WITH M.EFF_NUMATRI
   REPLACE PAR_EFFETDA WITH M.EFF_EFFETDA
   REPLACE PAR_INTEPER WITH M.EFF_INTEPER
   REPLACE PAR_NOTEFF  WITH M.EFF_NOTEFF
   ** ------- GESTIONE EFFETTI --------**

   REPLACE PAR_BANCA   WITH BANCA
   IF M.DARE<>0
      REPLACE PAR_TMOV WITH "D"
   ENDIF
   IF M.AVERE<>0
      REPLACE PAR_TMOV WITH "A"
   ENDIF
   REPLACE PAR_NUMFAT  WITH NDOC
   XPRG = CONTA_TRA * 100
   REPLACE PAR_NPROG   WITH XPRG + 100

   IF CLI_FOR == "C"
      REPLACE PAR_NPART WITH VAL(NDOC)
      REPLACE PAR_NPROT WITH ALLTRIM(NPROT)


	  IF FATTURA='I'
	  	 REPLACE PAR_NPART WITH _SAVE_NPART_INSOLUTI && RIPORTA IL NUMERO DI PARTITA ORIGINALE
	  	 REPLACE PAR_NPROT WITH _SAVE_NPROT_INSOLUTI && RIPORTA IL NUMERO DI DOCUMENTO ORIGINALE DELLA FATTURA
	  ENDIF



   ELSE
      *REPLACE PAR_NPART WITH PUB_NPARF
      REPLACE PAR_NPART WITH IIF(_CORPO_MOV_NPART > 0,_CORPO_MOV_NPART,PUB_NPARF)  && ERASMO - 14/02/2024
   ENDIF


  IF PAR_NPART   = 0
    _NPART__ =PRELEVANUMEROPARTITA()
    REPLACE PAR_NPART   WITH  _NPART__		&& NON E' STATA LEGATA NESSUNA PARTITA
  ENDIF

  REPLACE PAR_NUCOM  WITH M.NUCOM  && AGGIORNA IL NUMERO DELLA COMMESSA SULLA RIGA DEL PARTITARIO

  IF FATTURA='A'
     * SE STO VARIANDO UNA PRIMA NOTA DI UN EFFETTO GIA' ASSEGNATO ALLA FATTURA IL NUMERO DI PARTITA DEVE RIMANRE IL NUMERO DELLA
     * DELLA PARTITA DELLA FATTURA ALTRIMENTI GLI ASSEGNA QUELLO ORIGINALE DELLA REGISTRAZIONE PROVENIENTE DA MOV_CONT
     IF  PUB_VARPN=.T.
     	 IF PUB_NPART_GIA_ASSEGNATO_A_FATTURA <> 0
		    IF CLI_FOR == 'F'
		       REPLACE PAR_NPART        WITH PUB_NPART_GIA_ASSEGNATO_A_FATTURA
			ENDIF
   	   ENDIF PUB_NPART_GIA_ASSEGNATO_A_FATTURA
     ENDIF
   ENDIF

   REPLACE PAR_DTSCAD  WITH RIBALTA2(DATA_SCAD)
   REPLACE PAR_CODPAG  WITH V_CONPAG
   REPLACE PAR_TEL     WITH V_TELEFO
   REPLACE PAR_IVA     WITH V_PARIVA
   REPLACE PAR_NREG    WITH ALLTRIM(NREG)
   REPLACE PAR_NUMPRO  WITH ALLTRIM(PN_C)
   IF CLI_FOR == "F"
      REPLACE PAR_FATRI   WITH V_FR        && FATTURE FORNITORI IN RITARDO
   ENDIF
   REPLACE PAR_CIVA1   WITH V_CIVA1
   REPLACE PAR_IMPO1   WITH V_IMPOIVA1
   REPLACE PAR_IMPOS1  WITH V_IMPSIVA1
   REPLACE PAR_TOT1    WITH V_IMPOIVA1+V_IMPSIVA1
   REPLACE PAR_CIVA2   WITH V_CIVA2
   REPLACE PAR_IMPO2   WITH V_IMPOIVA2
   REPLACE PAR_IMPOS2  WITH V_IMPSIVA2
   REPLACE PAR_TOT2    WITH V_IMPOIVA2+V_IMPSIVA2
   REPLACE PAR_CIVA3   WITH V_CIVA3
   REPLACE PAR_IMPO3   WITH V_IMPOIVA3
   REPLACE PAR_IMPOS3  WITH V_IMPSIVA3
   REPLACE PAR_TOT3    WITH V_IMPOIVA3+V_IMPSIVA3
   REPLACE PAR_CIVA4   WITH V_CIVA4
   REPLACE PAR_IMPO4   WITH V_IMPOIVA4
   REPLACE PAR_IMPOS4  WITH V_IMPSIVA4
   REPLACE PAR_TOT4    WITH V_IMPOIVA4+V_IMPSIVA4
   REPLACE PAR_CIVA5   WITH V_CIVA5
   REPLACE PAR_IMPO5   WITH V_IMPOIVA5
   REPLACE PAR_IMPOS5  WITH V_IMPSIVA5
   REPLACE PAR_TOT5    WITH V_IMPOIVA5+V_IMPSIVA5

   IF CLI_FOR == 'F'
	   IF FATTURA = "A"
		   REPLACE PAR_TIPODO  WITH "PAG"
		   REPLACE PAR_NPARTO  WITH PAR_NPART  && CONSIDERA COME NUMERO DI PARTITA ETERNO
	   ENDIF
   ENDIF


   ** REINSERISCE IL RECORD 100 PER FATTURE,NOTE CREDITO,INSOLUTI
   IF FATTURA = "S" .OR. FATTURA = "I"
 	  IF _CREA_IL_RECORD_100
	    ** ===>>> CREA I PERIODI DI SCADENZA
	    IF CLI_FOR = 'C'
	      SELECT CUR_PARTCLI
	    ELSE
	      SELECT CUR_PARTFOR
	    ENDIF

	   	_CREA_IL_RECORD_100 = .F.
		SCATTER MEMVAR MEMO
	   	APPEND BLANK
		GATHER MEMVAR MEMO

	    REPLACE PAR_TIPODO  WITH "FAT"
	    REPLACE PAR_NPROG   WITH 100
	    REPLACE PAR_TOTIM   WITH M.SCA_VALSCA
      ENDIF		
   ENDIF FATTURA = "S" .OR. FATTURA = "I"

   SELECT CORPO_SCA
   SKIP +1

ENDDO


RETURN


********************************
FUNCTION CREA_SCADENZE_FATTURA
********************************
** CREA IL CURSORE CORPO_SCA RIPORTANDO LE TRANCHE DI SCADENZA FATTURA

