   IF PAR_TIPODO="FAT" .OR. PAR_TIPODO="INS"
      IF PAR_TIPFAT = "AR$"   && TRATTA L'ARROTONDAMENTO PRECEDENTEMENTE CREATO
	      M.WIMPORTO = PAR_FATT
    	  M.WIMPITL  = 0
    	  M.WIMPVAL  = 0
      ELSE
*!*			  IF PAR_TMOV = "D"	&&NOTA DI CREDITO
*!*		          M.WIMPORTO = (TEURO(M.WCOVAL,PAR_FATT,M.WDATFAT)) * -1
*!*	    	      M.WIMPITL  = (TLIRE(M.WCOVAL,PAR_FATT,M.WDATFAT)) * -1
*!*		          M.WIMPVAL  = (TVALUTA(M.WCOVAL,PAR_FATT,M.WDATFAT,M.WCAMBIO)) * -1
*!*	 		  ELSE				&&FATTURA EFFETTIVA
*!*		          M.WIMPORTO = TEURO(M.WCOVAL,PAR_FATT,M.WDATFAT)
*!*	    	      M.WIMPITL  = TLIRE(M.WCOVAL,PAR_FATT,M.WDATFAT)
*!*		          M.WIMPVAL  = TVALUTA(M.WCOVAL,PAR_FATT,M.WDATFAT,M.WCAMBIO)
*!*			  ENDIF
*!*			  **=> ERASMO - INIZIO 29/05/2015
*!*			  *** NON DEVE RIPESCARE IL CAMBIO DAI CAMBI GIORNALIERI, MA CONSIDERARE QUELLO CHE GIA' CONTIENE NELLA TABELLA (IL CAMPO PAR_FATT E' GIA' IN VALUTA)
