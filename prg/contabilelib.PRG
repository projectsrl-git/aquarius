   V_VALSAL = 0
ENDIF

V_VALDIV = ROUND(((M.ORD_VALORE - V_VALANT - V_VALSAL) / V_NUMTRA),2)
V_VALDIF = ROUND((V_VALDIV * V_NUMTRA),2) + V_VALANT + V_VALSAL
V_VALFIN = M.ORD_VALORE - V_VALDIF
IF V_VALSAL = 0 .AND. V_VALANT = 0
