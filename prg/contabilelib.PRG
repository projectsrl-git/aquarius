*!*	SELECT MOV_RIE
*!*	GO TOP


RETURN




************************************************
FUNCTION CALCOLO_COSTI_PERSONALE_SPESE_GENERALI
************************************************
PARA _TTOP_,_MESE_,_REG_

		
	  ** VERIFICA SE MOVIMENTO IVA PAGATA , RA PAGATA , COSTO PERSONALE PAGATO , TASSE PERSONALE PAGATE
      v_seek   = 'TOP'+ALLTRIM(_TTOP_)
      v_chiave = "codice"
      IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
         SELECT CUR_PARA
	     __TMOV   		= SUBSTR(LIBERA,33,2)
	     __SITFINAN  	= SUBSTR(LIBERA,50,1)
	  ELSE
	     __TMOV   		= ""
	     __SITFINAN  	= ""
	  ENDIF

	

      IF __SITFINAN = "N"
			RETURN(.T.)
	  ENDIF		


      SELECT MOV_CONT
 	  IF SUBSTR(MOV_TMOV,1,1)<>'D'      && SOLO LE RIGHE DI PRIMA NOTA IN DARE
			RETURN(.T.)
	  ENDIF		

 	  DO CASE
 	
 	  	CASE __TMOV   = "IV"	&& IVA PAGATA

	  	  _ERARIO = 0
          IF F_VALUTA = 1
             _ERARIO = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
          ELSE
             _ERARIO = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		  ENDIF

		  _ERARIO_MESE      = "ERARIO"+_MESE_+"P"	&& ERARIO MESE PAGATO

		  SELECT MOV_RIE
		  SET ORDER TO MOV_RIE
		  _RK = SUBSTR(RIBALTA2(_REG_),1,4)
		  SEEK _RK
		  IF FOUND()
	  	     REPLACE   &_ERARIO_MESE      WITH &_ERARIO_MESE      + _ERARIO
	  	  ELSE
			 APPEND  BLANK
	  	     REPLACE   PERIODO     WITH _RK
	  	     REPLACE   &_ERARIO_MESE      WITH _ERARIO
		  ENDIF

 	  	
 	  	
 	  	CASE __TMOV   = "RA"	&& RITENUTA ACCONTO PAGATA


	  	  _RA = 0
          IF F_VALUTA = 1
             _RA = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
          ELSE
             _RA = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		  ENDIF

		  _RA_MESE      = "RA"+_MESE_+"P"	&& RA MESE PAGATA

		  SELECT MOV_RIE
		  SET ORDER TO MOV_RIE
		  _RK = SUBSTR(RIBALTA2(_REG_),1,4)
		  SEEK _RK
		  IF FOUND()
	  	     REPLACE   &_RA_MESE      WITH &_RA_MESE      + _RA
	  	  ELSE
			 APPEND  BLANK
	  	     REPLACE   PERIODO     WITH _RK
	  	     REPLACE   &_RA_MESE      WITH _RA
		  ENDIF




 	  	CASE __TMOV   = "CP"	&& COSTO PERSONALE PAGATO

	  	  _COSTOPE= 0
          IF F_VALUTA = 1
             _COSTOPE = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
          ELSE
             _COSTOPE = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		  ENDIF

		  _COSTOPE_MESE      = "COSTOPE"+_MESE_+"P"	&& COSTO PERSONALE PAGATO

		  SELECT MOV_RIE
		  SET ORDER TO MOV_RIE
		  _RK = SUBSTR(RIBALTA2(_REG_),1,4)
		  SEEK _RK
		  IF FOUND()
	  	     REPLACE   &_COSTOPE_MESE      WITH &_COSTOPE_MESE      + _COSTOPE
	  	  ELSE
			 APPEND  BLANK
	  	     REPLACE   PERIODO     WITH _RK
	  	     REPLACE   &_COSTOPE_MESE      WITH _COSTOPE
		  ENDIF



 	  	CASE __TMOV   = "TP"	&& TASSE PERSONALE PAGATE

	  	  _TASSEPE= 0
          IF F_VALUTA = 1
             _TASSEPE = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
          ELSE
             _TASSEPE = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		  ENDIF

		  _TASSEPE_MESE      = "TASSEPE"+_MESE_+"P"	&& TASSE PERSONALE PAGATE

		  SELECT MOV_RIE
		  SET ORDER TO MOV_RIE
		  _RK = SUBSTR(RIBALTA2(_REG_),1,4)
		  SEEK _RK
		  IF FOUND()
	  	     REPLACE   &_TASSEPE_MESE      WITH &_TASSEPE_MESE      + _TASSEPE
	  	  ELSE
			 APPEND  BLANK
	  	     REPLACE   PERIODO     WITH _RK
	  	     REPLACE   &_TASSEPE_MESE      WITH _TASSEPE
		  ENDIF


 	  	CASE __TMOV   = "SG"	&& SPESE GENERALI
	  	  _SPESEGEN = 0
          IF F_VALUTA = 1
             _SPESEGEN = TLIRE(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
          ELSE
             _SPESEGEN = TEURO(MOV_VALUTA,MOV_IMP,RIBALTA2(MOV_DTDOC))
		  ENDIF

		  _SPESEGEN_MESE      = "SPESEGEN"+_MESE_+"P"	&& SPESE GENERALI MESE PAGATE

		  SELECT MOV_RIE
		  SET ORDER TO MOV_RIE
		  _RK = SUBSTR(RIBALTA2(_REG_),1,4)
		  SEEK _RK
		  IF FOUND()
	  	     REPLACE   &_SPESEGEN_MESE      WITH &_SPESEGEN_MESE      + _SPESEGEN
	  	  ELSE
			 APPEND  BLANK
	  	     REPLACE   PERIODO     WITH _RK
	  	     REPLACE   &_SPESEGEN_MESE      WITH _SPESEGEN
		  ENDIF

 	  	


		OTHERWISE		
 	
 	
 	
 	  ENDCASE
 	
 	
		


      SELECT MOV_CONT


RETURN(.T.)



********************************************
FUNCTION CERCA_MOVIMENTI_IVA
********************************************
PARA _ANNO__,_NUMPRO__
* CERCA SU MOV_CONT I MOVIMENTI IVA
* RESTITUISCE IL TOTALE IMPOSTA

__TOTALE_IMPOSTA = 0

* CICLO PER ELABORARE I MOVIMENTI APPARTENENTI DELLA PRIMA NOTA
x_soci = "mov_soc = '" + PUB_CODSOC + "'"
x_anno = "mov_anno = '" + _ANNO__ + "'"
x_codi = "mov_numpro = '" + ALLTRIM(_NUMPRO__) + "'"
*!*	cSql   = "SELECT * FROM mov_cont WHERE " + x_soci + " and " + x_anno + " and " + x_codi + ;
*!*	                                       " order by mov_soc,mov_anno,mov_conto,mov_sequen"
cSql   = "SELECT MOV_CONTO, MOV_IMP FROM mov_cont WHERE " + x_soci + " and " + x_anno + " and " + x_codi  && ERASMO - 02/04/2013
IF !ExecCommand(cSql,"PRIMA_NOTA")
   return(.f.)
ENDIF
SELECT PRIMA_NOTA
GO TOP
	
DO WHILE .T.
	
  IF EOF()
    EXIT
  ENDIF
	
  IF DELETED()
     SELECT PRIMA_NOTA
     SKIP +1
	 LOOP
  ENDIF

  ____TIPOCO = ""
  x_soci = "con_soc = '" + PUB_CODSOC + "'"
  x_anno = "con_anno = '" + PUB_ANNO + "'"
  x_cont = "con_conto = '" + ALLTRIM(MOV_CONTO) + "'"
  x_cond = x_soci + " and " + x_anno + " and " + x_cont
  *Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
  Csql   = "select CON_TIPOCO from conti where " + x_cond + " order by con_soc,con_anno,con_conto"  && ERASMO - 02/04/2013
  IF !ExecCommand(cSql,"cur_conti_")
     return(.f.)
  ENDIF
  SELECT cur_conti_
  GO TOP
  IF !EOF()

	 ____TIPOCO = CON_TIPOCO
	 IF ____TIPOCO <> 'I' 		&& SCARTA CONTI NON IVA
	 	SELECT PRIMA_NOTA
	 	SKIP + 1
	 	LOOP
	 ENDIF	

  ENDIF

  SELECT PRIMA_NOTA
  __TOTALE_IMPOSTA = __TOTALE_IMPOSTA + MOV_IMP

  SKIP +1

ENDDO WHILE .T.



RETURN(__TOTALE_IMPOSTA)


