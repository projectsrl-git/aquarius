***********************************************
FUNCTION RIPORTA_DESCRIZIONI_ANAGRAFICHE
***********************************************
PARA TIPO_ARCHIVIO

AABBSS    = SELECT()


DO CASE
	CASE TIPO_ARCHIVIO = "F"

	    x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
	    *x_anno = "par_anno = '" + PUB_ANNO + "'"
	    x_anno = "par_anno = par_anno"

	    cSql="SELECT * FROM PART_FOR WHERE " + x_soci + " and " + x_anno + ;
	                                      " order by par_codsoc,par_anno,par_numpro"
	    IF !ExecCommand(cSql,"cur_partfor")
	       return(.f.)
	    ENDIF
		
		SELECT cur_partfor
		GO TOP
		

		DO WHILE .NOT. EOF()
		
		
		   SCATTER MEMVAR MEMO
		   XX=CERCAFOR(M.PAR_CODCLI)
		
			SELECT CUR_FORNITORI
			GO TOP
			IF EOF()
			   M.PAR_CODACQ   				= SPACE(03)
			   M.PAR_COSATRATTA 			= SPACE(05)
			   M.PAR_GRADOIMPORTANZA 		= SPACE(05)
			   M.PAR_FORMAPAGAMENTO 		= SPACE(05)	
			   M.PAR_TIPOCONTRATTO 			= SPACE(05)
			   M.PAR_PRIPAGA				= SPACE(05)
			ELSE
			   M.PAR_CODACQ   				= FOR_CODACQ
			   M.PAR_COSATRATTA 			= FOR_COSATRATTA
			   M.PAR_GRADOIMPORTANZA 		= FOR_GRADOIMPORTANZA
			   M.PAR_FORMAPAGAMENTO 		= FOR_FORMAPAGAMENTO 	
			   M.PAR_TIPOCONTRATTO 			= FOR_TIPOCONTRATTO 	
			   M.PAR_PRIPAGA				= FOR_PRIPAGA

			   IF EMPTY(M.PAR_BANCA)
				  M.PAR_BANCA		=  FOR_BAE
			   ENDIF

			   IF EMPTY(M.PAR_CODPAG)
				  M.PAR_CODPAG		=  FOR_CONPAG
			   ENDIF

			ENDIF

		   IF EMPTY(M.PAR_DTFAT)
			   M.PAR_DTFAT		=CERCA_INDICE_PRIMA_NOTA(M.PAR_NUMPRO)
			   IF EMPTY(M.PAR_DTFAT)
					M.PAR_DTFAT = M.PAR_DTREG
			   ENDIF
		   ENDIF

		
		   IF EMPTY(M.PAR_DTSCAD)
			  M.PAR_DTSCAD		=  M.PAR_DTFAT
		   ENDIF

		   IF EMPTY(M.PAR_DATPAG)
			  M.PAR_DATPAG		=  M.PAR_DTSCAD
		   ENDIF

		
		   SELECT CUR_PARTFOR
           GATHER MEMVAR MEMO

		   SKIP +1

		ENDDO

		SELECT CUR_PARTFOR
		IF !ExecRW('','part_for','I','','CUR_PARTFOR')
		   return(.f.)
		ENDIF

