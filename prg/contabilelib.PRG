x_cond = x_idsc
Csql   = "SELECT * from AQ_RAP where " + x_cond + " order by ID_RAP"
IF !ExecCommand(cSql,"TMP_AQ_RAP")
   return(.f.)
ENDIF
SELECT TMP_AQ_RAP
GO TOP
IF EOF()
	SELECT(_ACT_SEL)
	RETURN .F.
ENDIF
SCAN
	_ID_RAP = ID_RAP

*!*		*** RICERCA PRIMO PAGAMENTO PRESENTE NELLA PARTITA IN LINEA
*!*		_DataPagamento__ = ""
*!*		CSQL = "SELECT * FROM " + IIF(_PAR_CF="F","PART_FOR","PART_CLI") + " WHERE PAR_NPROG <> '100' AND PAR_NPART = " + _SEEK_NPART + " ORDER BY PAR_NPROG,PAR_DTREG"
*!*		IF !ExecCommand(CSQL,"TMP_PARTITA")
*!*		   RETURN (.f.)
*!*		ENDIF
*!*		SELECT TMP_PARTITA
*!*		GO TOP
*!*		IF !EOF()
*!*			SCAN
*!*				IF PAR_TIPODO = 'PAG'
*!*					_DataPagamento__= PAR_DTREG
*!*					EXIT
*!*				ENDIF
*!*			ENDSCAN
*!*		ENDIF
	
	**=> ERASMO - INIZIO 08/09/2025
	*** RICERCA ULTIMA DATA PAGAMENTO PRESENTE NELLA PARTITA IN LINEA
	_DataPagamento__ = ""
	_DataPagamento__ult = ""
	_Saldo_part = 0
	CSQL = "SELECT * FROM " + IIF(_PAR_CF="F","PART_FOR","PART_CLI") + " WHERE PAR_NPROG <> '100' AND PAR_NPART = " + _SEEK_NPART + " ORDER BY PAR_NPROG DESC, PAR_DTREG DESC"
	IF !ExecCommand(CSQL,"TMP_PARTITA")
	   RETURN (.f.)
	ENDIF
	SELECT TMP_PARTITA
