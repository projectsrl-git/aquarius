*************************************************************
FUNCTION SCORPORA_IVA
*************************************************************
*RITORNA LE VARIABILI: M.ORD_IMPONI/M.ORD_IMPOST/M.ORD_TOTALE

LPARAMETERS _par_totale,_par_codcli

LOCAL __SWS
__SWS = SELECT()

SELECT(__SWS)

** SCORPORA L'IMPONIBILE E L'IMPOSTA DAL TOTALE 

x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
x_codi = "cli_codcli = '" + _par_codcli + "'"
x_cond = x_soci + " and " + x_codi
cSql = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"CUR_CLIENTEXX")
   RETURN .F.
ENDIF
SELECT CUR_CLIENTEXX
GO TOP
IF EOF()
   _ALRID  		= ""
   _ESENZI 		= .F.				&& CLIENTE NON IN ESENZIONE
   _CODIVA      = PUB_IVA
ELSE
   _ALRID 		= CLI_ALRID
   _CODIVA      = CLI_CODIVA
   IF !EMPTY(CLI_ALRID)
      _ESENZI = .T.			&& CLIENTE IN ESENZIONE
   ELSE
      _ALRID  = ""
      _ESENZI = .F.			&& CLIENTE NON IN ESENZIONE
   ENDIF
ENDIF

COD_IVA       = _CODIVA      
_IMPORTO_RATA = _par_totale

v_seek	= 'IVA'+COD_IVA
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   ALIQ = SUBSTR(LIBERA,1,3)
   NUM_ALIQ = VAL(ALIQ)
ELSE
   NUM_ALIQ = 0
ENDIF

IF !_ESENZI     && SOLO SE NON IN ESENZIONE
	M.IMPOSTA  = _IMPORTO_RATA  - (_IMPORTO_RATA  * 100 / (NUM_ALIQ+100))
	IF _VALUTA_ORDINE  = "ITL" .OR.  _VALUTA_ORDINE  = "LIT"
        IF M.IMPOSTA-INT(M.IMPOSTA)<>0
           M.IMPOSTA=INT(M.IMPOSTA)+1
        ENDIF
	ELSE
        M.IMPOSTA = ROUND((M.IMPOSTA),2)
	ENDIF
	M.T_IMPONIB = _IMPORTO_RATA -  M.IMPOSTA
	M.T_IMPOSTA = M.IMPOSTA
	M.T_VALORE  = _IMPORTO_RATA 
ELSE
	M.T_IMPONIB = _IMPORTO_RATA 
	M.T_IMPOSTA = 0
	M.T_VALORE  = _IMPORTO_RATA 
ENDIF


***********
M.ORD_IMPONI = M.T_IMPONIB
M.ORD_IMPOST = M.T_IMPOSTA
M.ORD_TOTALE = M.T_VALORE
************

SELECT(__SWS)


RETURN(.T.)
**=> SERGIO - FINE 30/07/2022

