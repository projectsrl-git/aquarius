IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   TOPX      = PUB_COMCEE
   CONIVAX   = CONIVA
   TCOD01    = CONTO1
   TCOD02    = CONTO2
   TCOD03    = CONTO3
   TCOD04    = CONTO4
   DES       = DESCRI
   TP        = SUBSTR(LIBERA,1,1)
   FATTURA   = SUBSTR(LIBERA,2,1)
   VER_CONTO = SUBSTR(LIBERA,12,1)
   PR_LIS    = SUBSTR(LIBERA,21,1)
   NOQUADRA  = SUBSTR(LIBERA,46,1)
   CALCIMPOS = SUBSTR(LIBERA,47,1)
   NATURA    = TP
   XXCONTO   = CONTO1
ELSE
   WAIT WINDOWS "TIPO OPERAZIONE COMPENSAZIONE IVA NON PRESENTE IN PARAMETRO TOP :"+PUB_COMCEE
   RETURN
ENDIF

DO REG_NUMRPN								&& NUMERO REGISTRAZIONE INTERNO DI PRIMA NOTA	
