****************************************************************
PROCEDURE RIGENERA_CONTI_CONTABILI_CLIENTI_FORNITORI
****************************************************************
*!*	################################################# CREA PIANO DEI CONTI DA ANAGRAFICA CLIENTI #################################################

_RISP = MESSAGEBOX("Rigenerare tutti i conti clienti/fornitori per l'anno contabile " + PUB_ANNO + " cancellando quelli attuali?",4+48,"Attenzione")
IF _RISP = 6
ELSE
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF

WAIT WINDOWS "Cancellazione attuali conti clienti/fornitori in corso..." NOWAIT

**** CANCELLAZIONE CLIENTI/FORNITORI DA PIANO DEI CONTI ATTUALE
x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_tipo = "CON_TIPOCO IN ('C','F')"
x_cond = x_soci + " and " + x_anno + " and " + x_tipo
cSql = "DELETE from conti where " + x_cond
IF !ExecCommand(cSql,"DEL_CONTI")
   RETURN .F.
ENDIF
   
   
v_seek	= 'GEN' + PUB_CODSOC
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
ELSE
   PUB_ERRORE=MESSAGEBOX('Parametro GEN'+CHR(13)+'inesistente',64,'*** ATTENZIONE ***')
   RETURN .F.
ENDIF

CCC=SUBSTR(LIBERA,1,4)

x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
x_cond = x_soci
cSql = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"CUR_CLIENTI")
   RETURN .F.
ENDIF
SELECT CUR_CLIENTI
GO TOP

CTRELAB_C = 0

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   
   WAIT WINDOWS "Generazione conto contabile Cliente " + ALLTRIM(CLI_CODCLI) + " (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT
   
   V_ER = SOTTOGEN(CLI_NAZION)
   IF !V_ER
      CC = PUB_CC
   ELSE
      CC = CCC
   ENDIF

   SELECT CUR_CLIENTI

   SCATTER MEMVAR MEMO

   IF PUB_CONTOSIMILCEE
      XXX_CODCLI = CC + ALLTRIM(STR(VAL(M.CLI_CODCLI)))  && TOGLIE GLI 0 NON SIGNIFICATIVI IN QUANTO IL CLIENTE NEL PIANO DEI CONTI E' MEMORIZZATO SENZA ZERI
   ELSE
      XXX_CODCLI = CC + ALLTRIM(M.CLI_CODCLI)
   ENDI
   x_soci = "con_soc = '" + PUB_CODSOC + "'"
   x_anno = "con_anno = '" + PUB_ANNO + "'"
   x_cont = "con_conto = '" + XXX_CODCLI + "'"
   x_cond = x_soci + " and " + x_anno + " and " + x_cont
   cSql = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
   IF !ExecRW(cSql,"CONTI","R")
      RETURN .F.
   ENDIF
   SELECT CONTI
   GO TOP
   IF EOF()
	  SELECT curs_CONTI
	  APPEND BLANK
	  REPLACE CON_SOC    WITH PUB_CODSOC
	  REPLACE CON_ANNO   WITH PUB_ANNO
	  REPLACE CON_CONTO  WITH XXX_CODCLI
	  REPLACE CON_DESCR  WITH M.CLI_RAGSOC
	  REPLACE CON_TIPOCO WITH 'C'
	  REPLACE CON_POSBIL WITH 'P'
	  REPLACE CON_TIPO_CONTO WITH '1'
	  CTRELAB_C = CTRELAB_C + 1
   ENDIF
   IF !ExecRW(cSql,"CONTI","W")
      RETURN .F.
   ENDIF

   SELECT CUR_CLIENTI
   SKIP +1

ENDDO

*!*	################################################# CREA PIANO DEI CONTI DA ANAGRAFICA FORNITORI #################################################

v_seek	= 'GEN' + PUB_CODSOC
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
ELSE
   PUB_ERRORE=MESSAGEBOX('Parametro GEN'+CHR(13)+'inesistente',64,'*** ATTENZIONE ***')
   RETURN .F.
ENDIF

FFF=SUBSTR(LIBERA,18,4)

x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
x_cond = x_soci
cSql = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
IF !ExecCommand(cSql,"CUR_FORNITORI")
   RETURN .F.
ENDIF
SELECT CUR_FORNITORI
GO TOP

CTRELAB_F = 0

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   
   WAIT WINDOWS "Generazione conto contabile Fornitore " + ALLTRIM(FOR_CODCLI) + " (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT
   
	V_ER = SOTTOGEN(FOR_NAZION)
	IF !V_ER
	    FF = PUB_FF
	ELSE
	    FF = FFF
	ENDIF

   SELECT CUR_FORNITORI


   SCATTER MEMVAR MEMO
   
   IF PUB_CONTOSIMILCEE
      XXX_CODFOR = FF + ALLTRIM(STR(VAL(M.FOR_CODCLI)))  && TOGLIE GLI 0 NON SIGNIFICATIVI IN QUANTO IL FORNITORE NEL PIANO DEI CONTI E' MEMORIZZATO SENZA ZERI
   ELSE
      XXX_CODFOR = FF + ALLTRIM(M.FOR_CODCLI)
   ENDIF
   x_soci = "con_soc = '" + PUB_CODSOC + "'"
   x_anno = "con_anno = '" + PUB_ANNO + "'"
   x_cont = "con_conto = '" + XXX_CODFOR + "'"
   x_cond = x_soci + " and " + x_anno + " and " + x_cont
   cSql = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
   IF !ExecRW(cSql,"CONTI","R")
      RETURN .F.
   ENDIF
   SELECT CONTI
   GO TOP
   IF EOF()
	  SELECT curs_CONTI
	  APPEND BLANK
	  REPLACE CON_SOC    WITH PUB_CODSOC
	  REPLACE CON_ANNO   WITH PUB_ANNO
	  REPLACE CON_CONTO  WITH XXX_CODFOR
	  REPLACE CON_DESCR  WITH M.FOR_RAGSOC
	  REPLACE CON_TIPOCO WITH 'F'
	  REPLACE CON_POSBIL WITH 'P'
	  REPLACE CON_TIPO_CONTO WITH '2'
	  CTRELAB_F = CTRELAB_F + 1
   ENDIF
   IF !ExecRW(cSql,"CONTI","W")
      RETURN .F.
   ENDIF

   SELECT CUR_FORNITORI
   SKIP +1

ENDDO

MESSAGEBOX("Operazione effettuata" + REPLICATE(CHR(13),2) + ;
	"Totale conti Clienti inseriti: " + ALLTRIM(STR(CTRELAB_C,10,0)) + CHR(13) + ;
	"Totale conti Fornitori inseriti: " + ALLTRIM(STR(CTRELAB_F,10,0)),64,"Informazione")

RETURN
