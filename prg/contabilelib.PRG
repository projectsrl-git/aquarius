    REPLACE CON_PADRE  WITH .T. && ERASMO/SERGIO - 10/02/2023

	SELECT &_CURSORE_
	SKIP +1
	
ENDDO



SELECT curs_CONTI_MULTI
GO TOP
IF !EOF()
	****** AGGIORNA TABELLA CONTI SQL
	IF !ExecRW('','CONTI','I','','curs_CONTI_MULTI')
	   return(.f.)
	ENDIF
ENDIF	 



SELECT &S2SZ


RETURN .T.



