*!***************************************************************
FUNCTION TRASFORMA_CODICE_CONTO_CONTABILE
*!***************************************************************
*!*	_TIPO_TRASFORMAZIONE = CODICE_CLI_FOR    / TOGLIE GLI 0 NON SIGNIFICATIVI
*!*	_TIPO_TRASFORMAZIONE = CODICE_SIMILCEE   / CODICE NEL FORMATO SIMILE A QUELLA CEE 2.1.2.4. .....
LPARAMETERS _TIPO_TRASFORMAZIONE,_CONTO_DA_TRASFORMARE


LOCAL _CONTO_TRASFORMATO
_CONTO_TRASFORMATO = ""


SSZ=STR(SELECT())


DO CASE 

	CASE _TIPO_TRASFORMAZIONE = "CODICE_CLI_FOR"								&& TOGLIE GLI 0 NON SIGNIFICATIVI
	
	
		IF PUB_CONTOSIMILCEE 
			_CONTO_TRASFORMATO = ALLTRIM(STR(VAL(_CONTO_DA_TRASFORMARE),10,0))	&& TOGLIE GLI 0 NON SIGNIFICATIVI IN QUANTO IL CLIENTE NEL PIANO DEI CONTI E' MEMORIZZATO SENZA ZERI
		ELSE
			_CONTO_TRASFORMATO = _CONTO_DA_TRASFORMARE							&& RIMANE INALTERATA LA GESTIONE
		ENDIF
			
	
	CASE _TIPO_TRASFORMAZIONE = "CODICE_SIMILCEE"								&& TRASFORMA IL CODICE STANDARD IN CODICE SIMIL CEE
	
	
		 

		CERCA_PUNTO = AT('.',_CONTO_DA_TRASFORMARE)
		IF CERCA_PUNTO > 0
			_CONTO_TRASFORMATO = _CONTO_DA_TRASFORMARE							&& NON EFFETTUA LA CONVERSIONE IN QUANTO GIA' E' UN SIMILCEE
			SELECT &SSZ
			RETURN(_CONTO_TRASFORMATO)
		ENDIF
			
	
	
		*!*	001002002011002   	CONTO STANDARD CON MASTRO DI 3 CIFRE
		*!*	1.2.2.11.2.			CONTO SIMILCEE CON MASTRO TRASFORMATO A 2 CIFRE
		*!*	001020				CASISTICHE PARTICOLARI
		*!*	1.20.				CASISTICHE PARTICOLARI
		
		
		_LEN_CONTO = LEN(ALLTRIM(_CONTO_DA_TRASFORMARE))
		_GRUPPI_SOTTO_CODICI = _LEN_CONTO / 3
		
		IF _GRUPPI_SOTTO_CODICI = 0
			_CONTO_TRASFORMATO = ""									&& CODICE DA VERIFICARE
			SELECT &SSZ
			RETURN(_CONTO_TRASFORMATO)
		ENDIF
		
		
		_CONTO_TRASFORMATO = ""	
		_INDICE = 1
       	FOR JK=1 TO _GRUPPI_SOTTO_CODICI 

			_CODICE_PARZIALE 	= SUBSTR(_CONTO_DA_TRASFORMARE,_INDICE,3)
			
			_CODICE_PARZIALE1   = ""
			_CODICE_PARZIALE2   = ""
			_CODICE_PARZIALE3   = ""
			_TROVATO            = .F.      
			
			IF VAL(SUBSTR(_CODICE_PARZIALE,1,1)) <> 0 
				_CODICE_PARZIALE1 = SUBSTR(_CODICE_PARZIALE,1,3)
				_TROVATO = .T.
			ELSE
				_CODICE_PARZIALE1 = ""
			ENDIF

			IF !_TROVATO 
				IF VAL(SUBSTR(_CODICE_PARZIALE,2,1)) <> 0 
					_CODICE_PARZIALE2 = SUBSTR(_CODICE_PARZIALE,2,2)
					_TROVATO = .T.
				ELSE
					_CODICE_PARZIALE2 = ""
				ENDIF
			ENDIF

			IF !_TROVATO 
				IF VAL(SUBSTR(_CODICE_PARZIALE,3,1)) <> 0 
					_CODICE_PARZIALE3 = SUBSTR(_CODICE_PARZIALE,3,1)
					_TROVATO = .T.
				ELSE
					_CODICE_PARZIALE3 = ""
				ENDIF
			ENDIF

			_CODICE_PARZIALE    = _CODICE_PARZIALE1 + _CODICE_PARZIALE2 + _CODICE_PARZIALE3

			_CODICE_PARZIALE 	= _CODICE_PARZIALE + "."					&& AGGIUNGE IL .
			_CONTO_TRASFORMATO 	= _CONTO_TRASFORMATO +_CODICE_PARZIALE 		&& COMPONE IL CODICE

			
			_INDICE = _INDICE +3
			
       	NEXT
		
			

ENDCASE





SELECT &SSZ


RETURN(_CONTO_TRASFORMATO)

****************************************************************
FUNCTION CREA_CONTROLLA_STRUTTURA_PIANO_CONTI_MULTILIVELLO
****************************************************************
* _AGGIORNA_DATABASE = .T. AGGIORNA IL DATABASE
*LPARAMETERS _AGGIORNA_DATABASE,_NO_MSG_OK
LPARAMETERS _AGGIORNA_DATABASE,_NO_MSG_OK,_AGG_PADRE,_AGG_CODPADRE  && ERASMO - 09/05/2025
SSZ=STR(SELECT())

**=> ERASMO - INIZIO 09/05/2025
IF PCOUNT() >= 2
ELSE
	_NO_MSG_OK = .F.
ENDIF

IF PCOUNT() >= 3
ELSE
	_AGG_PADRE = .F.
ENDIF

IF PCOUNT() >= 4
ELSE
	_AGG_CODPADRE = .F.
ENDIF
**=> ERASMO - FINE 09/05/2025

CREATE CURSOR CONTI_CONTROLLATI (KCONTO C(16), KDESCR C(100), KPAT_ECO C(1), KTIPOCO C(1), PRESENTE L)
INDEX ON KCONTO TAG I_KCONTO 


*** ELENCO COMPLETO DEI CONTI
x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cond = x_soci + " and " + x_anno
cSql = "select * from conti where " + x_cond + " order by con_conto"
IF !ExecCommand(cSql,"CUR_CONTI")
	RETURN .F.
ENDIF
SELECT CUR_CONTI
INDEX ON CON_CONTO TAG I_CONTO
GO TOP

SCAN
	
	_RECNO = RECNO()
	
	SCATTER MEMVAR MEMO
	
	DO VERIFICA_CONTO_PIU_LIVELLI WITH ALLTRIM(M.CON_CONTO)  && INNESCO DELLA PROCEDURA RICORSIVA
		
	SELECT CUR_CONTI
	GOTO _RECNO
	
	**=> ERASMO - INIZIO 09/05/2025
	SELECT CUR_CONTI
	SCATTER MEMVAR MEMO
	_OLD_CON_PADRE = M.CON_PADRE
	IF _AGGIORNA_DATABASE AND _AGG_PADRE
		*** VERIFICO E AGGIORNO IL FLAG CON_PADRE
		
		IF IS_GRUPPO_CONTI(M.CON_CONTO)
		  	M.CON_PADRE = .T.		&& CONTO PADRE (GRUPPO/SOTTOGRUPPO)
		ELSE
			M.CON_PADRE = .F.		&& CONTO ELEMENTARE
		ENDIF
	
		IF M.CON_PADRE = _OLD_CON_PADRE
		ELSE
			SELECT CUR_CONTI
			REPLACE CON_PADRE WITH M.CON_PADRE
			
			x_soci = "con_soc = '" + PUB_CODSOC + "'"
			x_anno = "con_anno = '" + M.CON_ANNO + "'"
			x_cont = "con_conto = '" + M.CON_CONTO + "'"
			x_cond = x_soci + " and " + x_anno + " and " + x_cont 
			xSql = "UPDATE conti SET CON_PADRE = " + IIF(M.CON_PADRE,"1","0") + " where " + x_cond
			IF !ExecCommand(xSql,"UPD_CONTI")
				RETURN .F.
			ENDIF
		ENDIF	
	ENDIF

	SELECT CUR_CONTI
	SCATTER MEMVAR MEMO	
	_OLD_CON_CODPADRE = M.CON_CODPADRE
	IF _AGGIORNA_DATABASE AND _AGG_CODPADRE
		*** VERIFICO E AGGIORNO IL CAMPO CON_CODPADRE
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + M.CON_ANNO + "'"
		x_cont = "RTRIM(CON_CONTO) <> '" + M.CON_CONTO + "' AND '" + M.CON_CONTO + "' LIKE RTRIM(CON_CONTO)+'%' AND RIGHT(RTRIM(CON_CONTO),1) = '.'"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont 
		xSql = "SELECT TOP 1 CON_CONTO FROM CONTI WHERE " + x_cond + " ORDER BY CON_CONTO DESC"		 
		IF !ExecCommand(xSql,"CHK_CONTI")
			RETURN .F.
		ENDIF
		SELECT CHK_CONTI
		GO TOP
		IF !EOF()
			M.CON_CODPADRE = ALLTRIM(CON_CONTO)
		ELSE
			M.CON_CODPADRE = ""
		ENDIF
		
		IF M.CON_CODPADRE = _OLD_CON_CODPADRE
		ELSE
			SELECT CUR_CONTI
			REPLACE CON_CODPADRE WITH M.CON_CODPADRE
			
			x_soci = "con_soc = '" + PUB_CODSOC + "'"
			x_anno = "con_anno = '" + M.CON_ANNO + "'"
			x_cont = "con_conto = '" + M.CON_CONTO + "'"
			x_cond = x_soci + " and " + x_anno + " and " + x_cont 
			xSql = "UPDATE conti SET CON_CODPADRE = '" + M.CON_CODPADRE + "' where " + x_cond
			IF !ExecCommand(xSql,"UPD_CONTI")
				RETURN .F.
			ENDIF
		ENDIF
	ENDIF
	**=> ERASMO - FINE 09/05/2025
  
ENDSCAN

SELECT CONTI_CONTROLLATI
SET FILTER TO !PRESENTE  && FILTRO PER I SOLI CONTI PADRE NON PRESENTI E DA INSERIRE
GO TOP
IF EOF()
	IF _NO_MSG_OK
	ELSE
		MESSAGEBOX("STRUTTURA PIANO DEI CONTI CORRETTA",64,"INFORMAZIONE")
	ENDIF
ELSE
	DO prg\browseview WITH "CONTI_CONTROLLATI","Elenco conti livelli superiori mancanti",;
	                       "KCONTO:Cod. Conto,W:20;KDESCR:Descrizione,W:45;",300,500,.F.,.T.
	IF _AGGIORNA_DATABASE
		IF !INSERISCE_CONTI_MULTILIVELLO_MANCANTI("CONTI_CONTROLLATI")
		ELSE
			MESSAGEBOX("Conti mancanti inseriti correttamente",64,"Informazione")
		ENDIF
	ENDIF
ENDIF


SELECT &SSZ


RETURN .T.





***********************************************************************************************
*** PROCEDURA RICORSIVA (CHE RICHIAMA SE STESSA) PER LA VERIFICA DELL'ESISTENZA DEI CONTI PADRE
***********************************************************************************************
PROCEDURE VERIFICA_CONTO_PIU_LIVELLI
***********************************************************************************************
LPARAMETERS _PAR_CONTO

_CONTO = _PAR_CONTO
_NR_PUNTI = OCCURS('.',_CONTO)
_NR_OCCORRENZA = 0
IF RIGHT(_CONTO,1) = '.'  && SE L'ULTIMO CARATTERE E' UN PUNTO
	_NR_OCCORRENZA = _NR_PUNTI - 1
ELSE
	_NR_OCCORRENZA = _NR_PUNTI
ENDIF

IF _NR_OCCORRENZA = 0  && SE IL CONTO PASSATO NON HA CONTI PADRE, ALLORA E' UN MASTRO QUINDI NON CONTINUO CON IL CONTROLLO
	RETURN
ENDIF

_CONTO_DA_CONTROLLARE = SUBSTR(_CONTO,1,AT('.',_CONTO,_NR_OCCORRENZA))  && CONTO DEL LIVELLO PRECEDENTE

IF EMPTY(_CONTO_DA_CONTROLLARE)
	RETURN
ENDIF

SELECT CONTI_CONTROLLATI
GO TOP
_SEEK = _CONTO_DA_CONTROLLARE
SEEK _SEEK
IF FOUND()
	RETURN
ENDIF

_TROVATO = .F.
_DESCR = ""
SELECT CUR_CONTI
GO TOP
SEEK _SEEK
IF FOUND()
	_TROVATO = .T.
	_DESCR = CON_DESCR
ENDIF

SELECT CONTI_CONTROLLATI
APPEND BLANK
REPLACE KCONTO WITH _CONTO_DA_CONTROLLARE

IF EMPTY(ALLTRIM(_DESCR))
	REPLACE KDESCR WITH "Conto contabile: "+_CONTO_DA_CONTROLLARE
ELSE
	REPLACE KDESCR WITH _DESCR
ENDIF
REPLACE KPAT_ECO WITH M.CON_POSBIL 
REPLACE KTIPOCO  WITH M.CON_TIPOCO

REPLACE PRESENTE WITH _TROVATO

DO VERIFICA_CONTO_PIU_LIVELLI WITH _CONTO_DA_CONTROLLARE


ENDPROC



