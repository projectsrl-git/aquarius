***********************************************************************************
PROCEDURE COD_PAGAM
***********************************************************************************

x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(M.CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"conti")
   return(.f.)
ENDIF
SELECT conti
GO TOP
IF EOF()
   CLI_FOR='X'
ELSE
   CLI_FOR = SUBSTR(CON_TIPOCO,1,1)
ENDIF


IF EMPTY(CPA) && SE NON GESTITA DA UTENTE FORZO SEMPRE QUELLA DI ANAGRAFICA
  CPA='XXX'
ENDIF


___FLAG_POSALL = .F.		&& posticipi per tutto l'anno
___CLIENTE     = ""			&& posticipi per tutto l'anno


IF CLI_FOR='C'
   x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
   *x_codi = "cli_codcli = '" + ALLTRIM(SUBSTR(M.CONTO,PUB_SOTTOG,PUB_CONTO)) + "'"
   x_codi = "cli_codcli = '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(M.CONTO,RAT('.',M.CONTO,1)+1))), ALLTRIM(SUBSTR(M.CONTO,PUB_SOTTOG,PUB_CONTO))) + "'"  && ERASMO - 16/12/2021
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
   IF !ExecCommand(cSql,"u_cli_an")
      return(.f.)
   ENDIF
   SELECT u_cli_an
   GO TOP
   IF EOF()
      CPA       = 'XXX'
   ELSE

      IF MODIFICA_CONDIZIONI_PAGAMENTO
      	CPA       = CLI_CONPAG
      ENDIF

      F_CPA     = .T.
      PUBLIC VET_DAL[2],VET_AL[2],VET_DAY[2]
      VET_DAL[1]= CLI_BDAL
      VET_DAL[2]= CLI_B2DAL
      VET_AL[1] = CLI_BAL
      VET_AL[2] = CLI_B2AL
      VET_DAY[1]= CLI_GG1
      VET_DAY[2]= CLI_GG2
      ___FLAG_POSALL = CLI_POSALL											&& posticipi per tutto l'anno
      *___CLIENTE     = ALLTRIM(SUBSTR(M.CONTO,PUB_SOTTOG,PUB_CONTO))		&& posticipi per tutto l'anno
 	  * 18/12/2021 SERGIO INIZIO
 	  IF PUB_CONTOSIMILCEE
		   ___CLIENTE     = SCORPRA_CODICE_CLIENTE_FORNITORE_SE_SIMILCEE(M.CONTO)
	  ELSE
		   ___CLIENTE     = ALLTRIM(SUBSTR(M.CONTO,PUB_SOTTOG,PUB_CONTO))		&& posticipi per tutto l'anno
	  ENDIF
 	  * 18/12/2021 SERGIO FINE
      
   ENDIF
ENDIF


IF CLI_FOR='F'
   x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
   *x_codi = "for_codcli = '" + ALLTRIM(SUBSTR(M.CONTO,PUB_SOTTOG,PUB_CONTO)) + "'"
   x_codi = "for_codcli = '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(M.CONTO,RAT('.',M.CONTO,1)+1))), ALLTRIM(SUBSTR(M.CONTO,PUB_SOTTOG,PUB_CONTO))) + "'"  && ERASMO - 16/12/2021
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
   IF !ExecCommand(cSql,"u_for_an")
      return(.f.)
   ENDIF
   SELECT u_for_an
   GO TOP
   IF EOF()
      CPA       = 'XXX'
   ELSE

      IF MODIFICA_CONDIZIONI_PAGAMENTO
         CPA       = FOR_CONPAG
      ENDIF

      F_CPA     = .T.
      PUBLIC VET_DAL[2],VET_AL[2],VET_DAY[2]
      VET_DAL[1]= "0000"
      VET_DAL[2]= "0000"
      VET_AL[1] = "0000"
      VET_AL[2] = "0000"
      VET_DAY[1]= "0000"
      VET_DAY[2]= "0000"
   ENDIF
ENDIF


IF CPA<>'XXX'

   v_SEEK = "CPA"+CPA
   IF seek_std('PARA',v_seek,'CODICE','CPA_PARA')
      SELECT CPA_PARA
      DESPAG = DESCRI
   ELSE
      DESPAG = "**********"
   ENDIF

   DATA_SCAD = SPACE(10)
   V_CONPAG  = CPA
   V_TUTTO   = TRANCHE("PARA",V_CONPAG,RIBALTA2(DATADOC),DA+AV,VET_DAL,VET_AL,VET_DAY,PUB_VALRIF,___FLAG_POSALL,___CLIENTE) && posticipi per tutto l'anno

   DO SCADULT     && RICERCA ULTIMA DATA SCADENZA
   DATASCAD  = DATA_SCAD

ENDIF


RETURN


***********************************************************************************
PROCEDURE VERCONTO
***********************************************************************************
* VERIFICA SE DURANTE UN MOVIMENTO DI RETTIFICA CON TOP "CHI" IL CONTO CONTABILE ESISTE
* SIA SU ANNO CORRENTE (PER L'ANNO PRECEDENTE DEVE PER FORZA ESISTERE IN QUANTO VIENE
* FATTA LA SEEK E MOSTRATO HELP
* SE NON ESISTE LO CREA PRENDENDOLO DALL'ANNO PRECEDENTE

SS=STR(SELECT())

* ->> ACCESSO SU ANNO PRECEDENTE PER PRELIEVO CAMPI
* ---------------------------------------------------
x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNOP + "'"
x_cont = "con_conto = '" + ALLTRIM(M.CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"tmp_conti")
   return(.f.)
ENDIF
SELECT tmp_conti
GO TOP
IF EOF()
   =MESSAGEBOX('Non esiste il conto'+M.CONTO+CHR(13)+'su esercizio :'+PUB_ANNOP,16,'*** ATTENZIONE ***')
   SELECT &SS
   RETURN
ENDIF
SCATTER MEMVAR

* -->> ACCESSO SU ANNO CORRENTE PER VERIFICA
* ------------------------------------------------
x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(M.CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"tmp_conti")
   return(.f.)
ENDIF
SELECT tmp_conti
GO TOP
IF EOF()
   =MESSAGEBOX('Conto :'+M.CONTO+CHR(13)+'su esercizio :'+PUB_ANNO+CHR(13)+'creato automaticamente',64,'*** ATTENZIONE ***')
   IF !ExecRW("select * from conti where 0=1","conti","R")
 	  return(.f.)
   ENDIF
   SELECT CONTI
   append blank
   GATHER MEMVAR
   IF !ExecRW("","conti","W")
	  return(.f.)
   ENDIF
ENDIF

SELECT &SS
RETURN


*****************************************************************************
PROCEDURE AUT_LANA  &&  CONTROPARTITE DA ANAG./TOP         CON  IMPORTI *****
*****************************************************************************
* DIGITO IMPORTO TOTALE DOCUMENTO
* CARICO SUBITO NELLA LISTA I CONTI INDICATI DA ANAGRAFICA CLI/FOR

IF PR_TOP1 && CARICA LA LISTA SOLO SE NON  E' GIA' STATO FATTO
   RETURN
ENDIF
PR_TOP1 = .T.

IF (PUB_VARPN=.T.) .OR. (PUB_ANNPN=.T.)
ELSE
   =SEEK_PARA('TOP',ALLTRIM(M.TOP),'CODICE','CODICE','4,10','TOP_PARA')
   DES       = top_para.DESCRI
   TP        = SUBSTR(top_para.LIBERA,1,1)
   XNATU     = TP
   CONIVAX   = top_para.CONIVA
   TCOD01    = top_para.CONTO1
   TCOD02    = top_para.CONTO2
   TCOD03    = top_para.CONTO3
   TCOD04    = top_para.CONTO4
   * VERIFICA SE LA LISTA E' PIENA
   CTR = 0
   SELECT CORPO_MOV
   SET ORDER TO I_CORPOMOV
   GO TOP
   DO WHILE .NOT.EOF()
      IF DELETED()
         SKIP +1
         LOOP
      ENDIF
      CTR = CTR+1
      SKIP +1
   ENDDO
   IF CTR  = 0          && CARICA LA LISTA DA TOP DOPO FORZATURA PRIMO CONTO ANAGRAFICO
      M.SEQUEN = 10
      DO AUT_PRNO
   ENDIF
   SELECT CORPO_MOV
   SET ORDER TO I_CORPOMOV
   GO TOP
   SCATTER MEMVAR
   IF XNATU    = "D"
      STORE M.TOTDOCU    TO M.DARE
      STORE 0            TO M.AVERE
   ELSE
      STORE M.TOTDOCU    TO M.AVERE
      STORE 0            TO M.DARE
   ENDIF
   GATHER MEMVAR MEMO
   SKIP +1
   IF !EOF()
      SCATTER MEMVAR
      IF XNATU    = "D"
         STORE M.TOTDOCU    TO M.AVERE
         STORE 0            TO M.DARE
      ELSE
         STORE M.TOTDOCU    TO M.DARE
         STORE 0            TO M.AVERE
      ENDIF
      GATHER MEMVAR MEMO
   ENDIF
   GO TOP
ENDIF

STORE SPACE(13)      TO M.CECO
STORE 0              TO M.DARE
STORE 0              TO M.AVERE
STORE SPACE(03)      TO M.IVA
STORE 0              TO M.IMPOSTA
STORE SPACE(25)  	 TO M.DESCRIZ
STORE SPACE(25)  	 TO M.DESCRI1
STORE SPACE(13)  	 TO M.CONTO

RETURN


*****************************************************************************
PROCEDURE AUT_LISTA  &&  CONTROPARTITE DA TIPO OPERAZIONE  CON  IMPORTI *****
*****************************************************************************
* DIGITO IMPORTO TOTALE DOCUMENTO
* CARICO SUBITO NELLA LISTA I CONTI INDICATI NEL PARAMETRO TOP



IF (PUB_VARPN=.T.) .OR. (PUB_ANNPN=.T.)
ELSE
   v_seek   = 'TOP'+ALLTRIM(M.TOP)
   v_chiave = 'codice'
   cSql="SELECT * FROM para WHERE "+V_CHIAVE+ " = ?V_SEEK"
   IF !ExecCommand(cSql,"top_para")
      return(.f.)
   ENDIF
   SELECT TOP_PARA
   GO TOP
   IF EOF()
   ELSE
      DES       = DESCRI
      TP        = SUBSTR(LIBERA,1,1)
      XNATU     = TP
      CONIVAX   = CONIVA
      TCOD01    = CONTO1
      TCOD02    = CONTO2
      TCOD03    = CONTO3
      TCOD04    = CONTO4
   ENDIF
   * VERIFICA SE LA LISTA E' PIENA
   CTR = 0
   SELECT CORPO_MOV
   SET ORDER TO I_CORPOMOV
   GO TOP
   DO WHILE .NOT.EOF()
      IF DELETED()
         SKIP +1
         LOOP
      ENDIF
      CTR = CTR+1
      SKIP +1
   ENDDO
   IF CTR  = 0          && CARICA LA LISTA DA TOP
      M.SEQUEN = 10
      DO AUT_PRNO
   ENDIF
   SELECT CORPO_MOV
   SET ORDER TO I_CORPOMOV
   GO TOP
   SCATTER MEMVAR
   IF XNATU    = "D"
	  STORE M.TOTDOCU    TO M.DARE
      STORE 0            TO M.AVERE
      STORE "NO"         TO M.IVA
   ELSE
      STORE M.TOTDOCU    TO M.AVERE
      STORE 0            TO M.DARE
      STORE "NO"         TO M.IVA
   ENDIF
   GATHER MEMVAR MEMO
   SKIP +1
   IF !EOF()
      SCATTER MEMVAR
      IF XNATU    = "D"
         STORE M.TOTDOCU    TO M.AVERE
         STORE 0            TO M.DARE
       	 STORE "NO"         TO M.IVA
      ELSE
         STORE M.TOTDOCU    TO M.DARE
         STORE 0            TO M.AVERE
       	 STORE "NO"         TO M.IVA
      ENDIF
      GATHER MEMVAR MEMO
   ENDIF
   GO TOP
ENDIF

STORE SPACE(13)      TO M.CECO
STORE 0              TO M.DARE
STORE 0              TO M.AVERE
STORE SPACE(03)      TO M.IVA
STORE 0              TO M.IMPOSTA
STORE SPACE(25) 	 TO M.DESCRIZ
STORE SPACE(25)  	 TO M.DESCRI1
STORE SPACE(13)  	 TO M.CONTO

RETURN


