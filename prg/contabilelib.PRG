_R_ImportoPrevidenza = 0
_R_ImportoBolli = 0
_R_SoggettoIVA = 0
_R_NonSoggettoIVA = 0
_R_ImportoIVA = 0
_R_QuotaINPS_Percipiente = 0
_R_INPS_Totale = 0
_R_QuotaINPS_Committente = 0
