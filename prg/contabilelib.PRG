** 30/06/2023 SERGIO INIZIO: CREA I CURSORI DELLE FATTURE CLIENTI/FORNITORI CON IL DETTAGLIO IVA
********************************************
FUNCTION CREA_MOVIMENTI_IVA
********************************************
PARA _ANNO__,_NUMPRO__,_TIPOCF__
* CERCA SU MOV_CONT I MOVIMENTI IVA

* CICLO PER ELABORARE I MOVIMENTI APPARTENENTI DELLA PRIMA NOTA
x_soci = "mov_soc = '" + PUB_CODSOC + "'"
x_anno = "mov_anno = '" + _ANNO__ + "'"
x_codi = "mov_numpro = '" + ALLTRIM(_NUMPRO__) + "'"
*cSql   = "SELECT MOV_CONTO, MOV_IMP,MOV_IMPOST,MOV_IVA FROM mov_cont WHERE " + x_soci + " and " + x_anno + " and " + x_codi 
cSql   = "SELECT MOV_CONTO, MOV_IMP,MOV_IMPOST,MOV_IVA,MOV_TMOV FROM mov_cont WHERE " + x_soci + " and " + x_anno + " and " + x_codi  && ERASMO - 13/03/2025
IF !ExecCommand(cSql,"PRIMA_NOTA")
   return(.f.)
ENDIF
SELECT PRIMA_NOTA
GO TOP
	
DO WHILE .T.
	
  IF EOF()
    EXIT
  ENDIF
	
  IF DELETED()
     SELECT PRIMA_NOTA
     SKIP +1
	 LOOP
  ENDIF


  IF MOV_IVA = 'NO' 		&& SCARTA CONTI CLIENTI/FORNITORI
 	SELECT PRIMA_NOTA
 	SKIP + 1
 	LOOP
  ENDIF	
  
  ____TIPOCO = ""
  x_soci = "con_soc = '" + PUB_CODSOC + "'"
  x_anno = "con_anno = '" + PUB_ANNO + "'"
  x_cont = "con_conto = '" + ALLTRIM(MOV_CONTO) + "'"
  x_cond = x_soci + " and " + x_anno + " and " + x_cont
  Csql   = "select CON_TIPOCO from conti where " + x_cond + " order by con_soc,con_anno,con_conto"  
  IF !ExecCommand(cSql,"cur_conti_")
     return(.f.)
  ENDIF
  SELECT cur_conti_
  GO TOP
  IF !EOF()

	 ____TIPOCO = CON_TIPOCO
	 IF ____TIPOCO = 'I' 		&& SCARTA CONTI IVA
	 	SELECT PRIMA_NOTA
	 	SKIP + 1
	 	LOOP
	 ENDIF	

  ENDIF

  SELECT PRIMA_NOTA
  SCATTER MEMVAR MEMO

  __TIMPONIBILE_ = M.MOV_IMP
  __TIMPOSTA_    = M.MOV_IMPOST  
  
  IF _TIPOCF__ = 'C'	&& FATTURA CLIENTE
  
    **=> ERASMO - INIZIO 13/03/2025
    IF M.MOV_TMOV = "D"
		__TIMPONIBILE_ = __TIMPONIBILE_ * -1
		__TIMPOSTA_    = __TIMPOSTA_ * -1
    ENDIF
    **=> ERASMO - FINE 13/03/2025
  	
  	SELECT FAT_CLI_IVA 
  	APPEND BLANK
  	GATHER MEMVAR MEMO
  	REPLACE MOV_AAMM		WITH XX_AAMM
    REPLACE MOV_CONTO       WITH XX_CONTO  	
  	REPLACE MOV_RAGSOC		WITH XX_RAGSOC
  	REPLACE MOV_INCPAG		WITH TOTINPA 
    REPLACE MOV_IMPOSTA		WITH __TIMPOSTA_    
    REPLACE MOV_IMPONIBILE	WITH __TIMPONIBILE_ 
    
    _IVA_IMP = _IVA_IMP + __TIMPONIBILE_ 

 
  ENDIF
  
  
  IF _TIPOCF__ = 'F'	&& FATTURA FORNITORE
  
    **=> ERASMO - INIZIO 13/03/2025
    IF M.MOV_TMOV = "A"
		__TIMPONIBILE_ = __TIMPONIBILE_ * -1
		__TIMPOSTA_    = __TIMPOSTA_ * -1
    ENDIF
    **=> ERASMO - FINE 13/03/2025
  	
  	SELECT FAT_FOR_IVA 
  	APPEND BLANK
  	GATHER MEMVAR MEMO
  	REPLACE MOV_AAMM		WITH XX_AAMM
    REPLACE MOV_CONTO       WITH XX_CONTO
    REPLACE MOV_RAGSOC		WITH XX_RAGSOC
  	REPLACE MOV_INCPAG		WITH TOTINPA 
    REPLACE MOV_IMPOSTA		WITH __TIMPOSTA_    
    REPLACE MOV_IMPONIBILE	WITH __TIMPONIBILE_ 

  
  ENDIF  

 
  SELECT PRIMA_NOTA
  SKIP +1

ENDDO WHILE .T.



RETURN(.T.)
** 30/06/2023 SERGIO FINE: CREA I CURSORI DELLE FATTURE CLIENTI/FORNITORI CON IL DETTAGLIO IVA



