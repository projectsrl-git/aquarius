   SELECT CUR_PARA
   NOTAC	= SUBSTR(LIBERA,11,1)
   CEE      = SUBSTR(LIBERA,23,1)
ELSE
   NOTAC	= " "
   CEE      = ""
ENDIF

IF CEE = "E" OR CEE = "R"	&& SE TIPO OPERAZIONE NON CEE/REVERSE CHARGE NON CREA NESSUNA COMPENSAZIONE
ELSE
   RETURN
ENDIF


v_seek	 = 'TOP'+ALLTRIM(PUB_COMCEE)	&& TOP GESTIONE COMPENSAZIONE IVA CEE
