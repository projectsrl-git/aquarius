*************************************************************************
*  			 CONTROAGGIORNA ARCHIVI AMMORTAMENTO BENI AZIENDALI         *
*************************************************************************

PROCEDURE REG_AMMORT
AXABBSZ    = SELECT()




**===>>>  CASO DI VARIAZIONE PN  <<<===
IF PUB_VARPN=.T.
	=REG_CANCELLA_CU_AMM_TT_DD()
ENDIF



SELECT CU_BEN_DD
GO TOP


DO WHILE .NOT. EOF()			&& ELABORA GLI ARTICOLI DA AMMORTIZZARE RIPORTANDO PER OGNI BENE IL TAGGANCIO

    IF DELETED()
		SELECT CU_BEN_DD
		SKIP +1
		LOOP
	ENDIF

	V_AGGANCIO=ALLTRIM(STR(NEWPROG('NUMAMM'),10))		&& PRELEVA L'UNCINO CHE LEGA U_AMM_TT A U_AMM_DD	

	SELECT CU_BEN_DD
    REPLACE DAGGANCIO  WITH V_AGGANCIO

	SCATTER MEMVAR MEMO
	____SYSRIGA = M.ORD_SYSRIGA

	_NUCESP = 0					&& NUMERO CESPITE AZIENDALE

	=REG_AGGIORNA_CU_AMM_TT()

	=REG_AGGIORNA_U_ART_PR("AGGIORNA",M.ORD_CDARTI,M.ORD_CODPRI,M.ORD_VALORE,M.ORD_DTUTIL)	


	SELECT CU_AMM_DD
    GO TOP
    DO WHILE .NOT. EOF()

	    IF DELETED()
	 		SELECT CU_AMM_DD
	 		SKIP +1
			LOOP
		ENDIF


	    IF ALLTRIM(____SYSRIGA) <> ALLTRIM(ORD_SYSRIGA)
	 		SELECT CU_AMM_DD
	 		SKIP +1
			LOOP
		ENDIF

	    REPLACE DAGGANCIO  WITH V_AGGANCIO   	&& RIPORTA UNCINO SU U_AMM_DD
		REPLACE ORD_NUCESP WITH _NUCESP			&& RIPORTA IL NUMERO DEL CESPITE SUI DETTAGLI
 		
 		SELECT CU_AMM_DD
 		SKIP +1

	ENDDO


	SELECT CU_BEN_DD
	SKIP +1	

ENDDO



=REG_CREA_U_AMM_TT_DD()	





SELECT(AXABBSZ)
RETURN

*********************************************************************
*  			 CREA LA TESTATA DEL BENE DA AMMORTIZZARE               *
*********************************************************************
FUNCTION REG_AGGIORNA_CU_AMM_TT

AXABBS_Z    = SELECT()


		*==>> PRELEVA IL NUMERO DEL CESPITE AZIENDALE
   	     v_seek  = 'NUMBEA'+PUB_CODSOC
         v_chiave= "codice"
         cSql="select * from para where " + v_chiave + " = '" + v_seek + "'"
         IF !ExecRW(cSql,"PARA","R")
            return(.f.)
         ENDIF
         SELECT PARA
         GO TOP
         IF !EOF()
		    V2=VAL(SUBSTR(LIBERA,1,7)) + 1
	        REPLACE LIBERA WITH SUBSTR(STR(V2,7,0),1,7)
		    _NUCESP = VAL(ALLTRIM(SUBSTR(STR(V2,7,0),1,7)))
		 ELSE
		    RIT = MSGBOX('Parametro numero cespiti non trovato','ATTENZIONE',31)
		    _NUCESP = 0
		 ENDIF
         IF !ExecRW(cSql,"PARA","W")
            return(.f.)
         ENDIF


		 M.SELEZIONE  = SPACE(10)
		 M.TAGGANCIO  = ALLTRIM(V_AGGANCIO)
		 M.ORD_CDARTI = M.ORD_CODART
		 M.ORD_DSARTI = M.ORD_DESART
		 M.ORD_CODSOC = PUB_CODSOC
		 M.TNUMERO    = ALLTRIM(NDOC)
		 M.ORD_VALUTA = XVALUTA
		 M.ORD_CAMBIO = XCAMBIO
		 M.ORD_DATORD = RIBALTA2(____DATADOC)
		 M.ORD_NUMORD = ALLTRIM(NDOC)
		 M.ORD_CODCLI = ____CODCLI
		 M.ORD_RAGSOC = ____RAGSOC
		 M.ORD_INDIRI = ____INDIRI
		 M.ORD_CAP    = ____CAP
		 M.ORD_LOCALI = ____LOCALI
		 M.ORD_PARIVA = ____PARIVA
		 M.ORD_CAUS   = ____TOP
		 M.ORD_CPA    = ____CPA
		 M.ORD_BANCA  = ____BANCA
		 M.ORD_CODNAZ = ____CODNAZ
		
		 M.ORD_DTCONS = RIBALTA2(____DATASCAD)
		 M.ORD_DTSCAD = RIBALTA2(____DATASCAD)
		 M.ORD_CGE    = .F.
		 M.ORD_ANNO   = SUBSTR(M.ORD_DATORD,1,4)

         M.ORD_NUMPRO = ALLTRIM(PN_C)
         M.ORD_NUCESP = _NUCESP
	
		 SELECT CU_AMM_TT
		 APPEND BLANK
		 DO U_AMM_TT
		 REPLACE TAGGANCIO  WITH V_AGGANCIO
		 REPLACE ORD_CHIUSO WITH .F.
		 REPLACE ORD_CDARTI WITH M.ORD_CODART
		 REPLACE ORD_DSARTI WITH M.ORD_DESART

SELECT(AXABBS_Z)

RETURN

