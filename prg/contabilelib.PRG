  WIMPORTO N(17,3), ;
  WIMPITL  N(17,3), ;
  WABBUO   N(17,3), ;
  WPAGA    N(17,3), ;
  WFATAGE  C(06), ;
  WPAGATO  N(17,3))

INDEX ON WPART+WDTSCAX                          TAG WORK
