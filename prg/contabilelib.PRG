Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(cSql,"cur_conti")
   return(.f.)
ENDIF
SELECT cur_conti
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP
      LOOP
   ENDIF



   __CON_SOC    = CON_SOC
   __CON_ANNO   = __ANNO__
   __CON_CONTO  = CON_CONTO
   __CON_DESCR  = CON_DESCR
   __CON_TIPOCO = CON_TIPOCO
   __CON_PARIVA = CON_PARIVA
   __CON_POSBIL = CON_POSBIL


   SELECT &_DB__
   SET ORDER TO CONTO
   V_SEEK = PUB_CODSOC+__ANNO__+ALLTRIM(__CON_CONTO)
   SEEK V_SEEK
   IF !FOUND()

	   SELECT &_DB__
	   APPEND BLANK

       REPLACE CON_SOC    WITH  __CON_SOC
       REPLACE CON_ANNO   WITH  __ANNO__
  	   REPLACE CON_CONTO  WITH  __CON_CONTO
  	   REPLACE CON_DESCR  WITH  __CON_DESCR
  	   REPLACE CON_TIPOCO WITH  __CON_TIPOCO
       REPLACE CON_PARIVA WITH  __CON_PARIVA
       REPLACE CON_POSBIL WITH  __CON_POSBIL




	   REPLACE CON_IMP_D  WITH 0
	   REPLACE CON_IMP_A  WITH 0


	   __MESE 		= 1
	   __FINE_MESE 	= 12
	
	   DO WHILE .T.
	
	      IF __MESE > __FINE_MESE
	         EXIT
	      ENDIF
	
	      V_MM = STR(__MESE,2,0)
	      IF LEN(ALLTRIM(V_MM)) = 2
	      ELSE
	         V_MM = '0' + ALLTRIM(V_MM)
	      ENDIF

		  REPLACE CON_DA&V_MM WITH 0
		  REPLACE CON_AV&V_MM WITH 0

	      __MESE = __MESE +1
	
	   ENDDO


   ENDIF


   SELECT CUR_CONTI
   SKIP +1

ENDDO



PERDAL = RIBALTA2(DATADAL)
PERAL  = RIBALTA2(DATAAL)



x_soci = "mov_soc = '" + PUB_CODSOC + "'"
x_dt1  = PERDAL
x_dt2  = PERAL
