**********************************************
PROCEDURE SITINCAS
**********************************************
PUBLIC DATADA,DATAAL,_DATADAL,_DATADA

DATADA   = V_ANNO+"/01/01"
DATAAL   = V_ANNO+"/12/31"
D_ANNO   = VAL(V_ANNO) - 3
X_ANNO   = STR(D_ANNO,4,0)
XDATADA  = X_ANNO+"/01/01"
XDATAAL  = V_ANNO+"/12/31"
_DATADAL = RIBALTA2(XDATADA)
_DATAAL  = RIBALTA2(XDATAAL)
	
**==> Da questa routine esco con un cursore contenente il saldo delle sole partite aperte per il cliente selezionato
**==> e per il periodo dal/al digitato (-3 ANNI / data di registrazione)

IF EMPTY(COD) .OR. COD = SPACE(13)
   C_TUTTI = 1
ELSE
   C_TUTTI = 2
ENDIF

ZZCOD = SUBSTR(M.COD,5,9)

DO EUR_PAPC WITH 'C','PAR_CODCLI',ZZCOD,ZZCOD,C_TUTTI

SELECT PART_EUR
GO TOP

**==> Creazione cursore

CREATE CURSOR XSCADEN ;
			  (W_DTSCA C(10),      W_NPROG   N(05,0),  W_ANNO C(4),        W_NPART   N(10,0), ;
			   WC_NFAT C(6),       WC_DTFAT C(10),     WC_RAGSOC C(35),    WC_TOTFAT N(17,3), ;
			   WC_TOTRAT N(17,3),  WC_TOTPAG N(17,3),  WC_TODAPG N(17,3),  WC_TOTINS N(17,3), ;
			   WC_CAMBIO N(17,10), WC_VALUTA C(3))

SELECT XSCADEN
INDEX ON W_DTSCA+WC_NFAT+WC_RAGSOC 					TAG  CLI
INDEX ON W_ANNO+STR(W_NPART,10,0)+STR(W_NPROG,5,0) 	TAG  PRO
INDEX ON STR(W_NPART,10,0)+STR(W_NPROG,5,0) 		TAG  PRN

SELECT PART_EUR
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   **==> by-passo le partite a zero
*!*	   IF T_ITL <> 0 .AND. T_EUR <> 0
   IF T_EUR <> 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR

   **==> Ricerco sul partitario la fattura con valore totale documento
   V_100 = 100

   x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
   x_anno = "par_anno = '" + SUBSTR(M.DTREG,7,4) + "'"
   x_npar = "par_npart = " + ALLTRIM(STR(M.NPART,10,0))
   x_npro = "par_nprog = " + ALLTRIM(STR(V_100,5,0))
   x_cond = x_soci + " and " + x_anno + " and " + x_npar + " and " + x_npro
   cSql="SELECT * FROM PART_CLI WHERE " + x_cond + ;
                                      " order by par_codsoc,par_anno,par_npart,par_nprog"

   IF !ExecCommand(cSql,"cur_partcli")
      return(.f.)
   ENDIF
   SELECT CUR_PARTCLI
   GO TOP

   IF !EOF()
      IF PAR_TIPODO = 'FAT'
      ELSE
         SELECT PART_EUR
         SKIP +1
         LOOP
      ENDIF
   ELSE
      SELECT PART_EUR
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR

   **==> Scrivo la fattura con valore totale documento sul cursore
   SELECT XSCADEN
   APPEND BLANK
   REPLACE W_ANNO    WITH M.PAR_ANNO
   REPLACE W_NPART   WITH M.PAR_NPART
   REPLACE W_DTSCA   WITH M.PAR_DTSCAD
   REPLACE W_NPROG   WITH M.PAR_NPROG
   REPLACE WC_NFAT   WITH M.PAR_NUMFAT
   REPLACE WC_DTFAT  WITH M.PAR_DTFAT
   REPLACE WC_RAGSOC WITH M.PAR_RAGSOC
   IF F_VALUTA = 1
      REPLACE WC_TOTFAT WITH TLIRE(M.PAR_VALUTA,M.PAR_FATT,RIBALTA2(M.PAR_DTFAT))
   ELSE
      REPLACE WC_TOTFAT WITH TEURO(M.PAR_VALUTA,M.PAR_FATT,RIBALTA2(M.PAR_DTFAT))
   ENDIF
   REPLACE WC_TOTRAT WITH 0
   REPLACE WC_TOTPAG WITH 0
   REPLACE WC_TODAPG WITH WC_TOTFAT
   REPLACE WC_TOTINS WITH 0
   REPLACE WC_CAMBIO WITH M.PAR_CAMBIO
   REPLACE WC_VALUTA WITH M.PAR_VALUTA

   **==> loop su partitario a livello di numero partita
   x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
   x_clie = "par_codcli = '" + ALLTRIM(M.PAR_CODCLI) + "'"
   x_npar = "par_npart = " + ALLTRIM(STR(M.NPART,10,0))
   x_cond = x_soci + " and " + x_clie + " and " + x_npar
   cSql="SELECT * FROM PART_CLI WHERE " + x_cond + ;
                                      " order by par_codsoc,par_codcli,par_npart"
   IF !ExecCommand(cSql,"cur_partcli")
      return(.f.)
   ENDIF
   SELECT CUR_PARTCLI
   GO TOP

   IF !EOF()

      DO WHILE .T.

         IF EOF()
            EXIT
         ENDIF

         IF PAR_NPROG = 100
            SKIP +1
            LOOP
         ENDIF

         V_DTSCA  = PAR_DTSCAD
         V_NPROG  = PAR_NPROG
         V_NUMFAT = PAR_NUMFAT
         V_DTFAT  = PAR_DTFAT
         V_RAGSOC = PAR_RAGSOC
         V_CAMBIO = PAR_CAMBIO
         V_VALUTA = PAR_VALUTA
         V_FATT   = PAR_FATT
         V_TIPODO = PAR_TIPODO
         V_ANNI   = PAR_ANNO
         V_NPART  = PAR_NPART

         **==> Gestione della rata da pagare

         IF V_TIPODO = 'FAT'
            SELECT XSCADEN
            APPEND BLANK
            REPLACE W_ANNO    WITH V_ANNI
            REPLACE W_NPART   WITH V_NPART
            REPLACE W_DTSCA   WITH V_DTSCA
            REPLACE W_NPROG   WITH V_NPROG
            REPLACE WC_NFAT   WITH V_NUMFAT
            REPLACE WC_DTFAT  WITH V_DTFAT
            REPLACE WC_RAGSOC WITH V_RAGSOC
            REPLACE WC_CAMBIO WITH V_CAMBIO
            REPLACE WC_VALUTA WITH V_VALUTA
            REPLACE WC_TOTFAT WITH 0
            IF F_VALUTA = 1
               REPLACE WC_TOTRAT WITH TLIRE(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
            ELSE
               REPLACE WC_TOTRAT WITH TEURO(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
            ENDIF
            REPLACE WC_TOTPAG WITH 0
            REPLACE WC_TODAPG WITH WC_TOTRAT
            REPLACE WC_TOTINS WITH 0
         ENDIF

         **==> Gestione del pagamento

         IF V_TIPODO = 'PAG'
            V_100 = 100
            SELECT XSCADEN
            SET ORDER TO PRN
            SEEK STR(V_NPART,10,0)+STR(V_100,5,0)
            IF FOUND()
               DO WHILE .T.
                  IF EOF()
                     EXIT
                  ENDIF
                  IF W_NPART = V_NPART
                  ELSE
                     SKIP +1
                     LOOP
                  ENDIF
                  IF W_NPROG = 100 .OR. W_DTSCA = V_DTSCA
                  ELSE
                     SKIP +1
                     LOOP
                  ENDIF
                  IF F_VALUTA = 1
                     REPLACE WC_TODAPG WITH WC_TODAPG - TLIRE(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
                     REPLACE WC_TOTPAG WITH TLIRE(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
                  ELSE
                     REPLACE WC_TODAPG WITH WC_TODAPG - TEURO(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
                     REPLACE WC_TOTPAG WITH TEURO(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
                  ENDIF
                  SKIP +1
               ENDDO
            ENDIF
         ENDIF

         SELECT CUR_PARTCLI
         SKIP +1

      ENDDO

   ENDIF

   SELECT PART_EUR
   SKIP +1

ENDDO

SELECT XSCADEN
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF W_DTSCA >= DATADA
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF W_DTSCA <= DATAAL
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF W_NPROG = 100
      SKIP +1
      LOOP
   ENDIF

   IF WC_TODAPG > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IMPA    = WC_TODAPG
   DTSCA   = W_DTSCA

   MESE    = SUBSTR(W_DTSCA,6,2)

   _AVERE  = "CON_AV"+MESE+"C"
   _DARE   = "CON_DA"+MESE+"C"

   SELECT MOV_RIE
   SET ORDER TO MOV_RIE
   _RK = SUBSTR(DTSCA,1,4)

   SEEK _RK

   IF FOUND()
      REPLACE   &_AVERE     WITH &_AVERE + IMPA
   ELSE
      APPEND  BLANK
  	  REPLACE   PERIODO     WITH _RK
      REPLACE   &_AVERE     WITH IMPA
      REPLACE   &_DARE      WITH 0
   ENDIF

   SELECT XSCADEN
   SKIP +1

ENDDO

SELECT XSCADEN
USE

SELECT PART_EUR
USE

RETURN


***********************************************
PROCEDURE SITPAGAM
***********************************************


DATADA   = V_ANNO+"/01/01"
DATAAL   = V_ANNO+"/12/31"
D_ANNO   = VAL(V_ANNO) - 3
X_ANNO   = STR(D_ANNO,4,0)
XDATADA  = X_ANNO+"/01/01"
XDATAAL  = V_ANNO+"/12/31"
_DATADAL = RIBALTA2(XDATADA)
_DATAAL  = RIBALTA2(XDATAAL)
	
**==> Da questa routine esco con un cursore contenente il saldo delle sole partite aperte per il fornitore selezionato
**==> e per il periodo dal/al digitato (-3 ANNI / data di registrazione)

IF EMPTY(COD) .OR. COD = SPACE(13)
   C_TUTTI = 1
ELSE
   C_TUTTI = 2
ENDIF

ZZCOD = SUBSTR(M.COD,5,9)

DO EUR_PAPF WITH 'F','PAR_CODCLI',ZZCOD,ZZCOD,C_TUTTI

SELECT PART_EUR
GO TOP

**==> Creazione cursore

CREATE CURSOR XSCADEN ;
			  (W_DTSCA C(10),      W_NPROG   N(05,0),  W_ANNO C(4),        W_NPART   N(10,0), ;
			   WC_NFAT C(6),       WC_DTFAT C(10),     WC_RAGSOC C(35),    WC_TOTFAT N(17,3), ;
			   WC_TOTRAT N(17,3),  WC_TOTPAG N(17,3),  WC_TODAPG N(17,3),  WC_TOTINS N(17,3), ;
			   WC_CAMBIO N(17,10), WC_VALUTA C(3))

SELECT XSCADEN
INDEX ON W_DTSCA+WC_NFAT+WC_RAGSOC 					TAG  CLI
INDEX ON W_ANNO+STR(W_NPART,10,0)+STR(W_NPROG,5,0) 	TAG  PRO
INDEX ON STR(W_NPART,10,0)+STR(W_NPROG,5,0) 		TAG  PRN

SELECT PART_EUR
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   **==> by-passo le partite a zero
*!*	   IF T_ITL <> 0 .AND. T_EUR <> 0
   IF T_EUR <> 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR

   **==> Ricerco sul partitario la fattura con valore totale documento
   V_100 = 100

   x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
   x_anno = "par_anno = '" + SUBSTR(M.DTREG,7,4) + "'"
   x_npar = "par_npart = " + ALLTRIM(STR(M.NPART,10,0))
   x_npro = "par_nprog = " + ALLTRIM(STR(V_100,5,0))
   x_cond = x_soci + " and " + x_anno + " and " + x_npar + " and " + x_npro
   cSql="SELECT * FROM PART_FOR WHERE " + x_cond + ;
                                      " order by par_codsoc,par_anno,par_npart,par_nprog"
   IF !ExecCommand(cSql,"cur_partfor")
      return(.f.)
   ENDIF
   SELECT CUR_PARTFOR
   GO TOP

   IF !EOF()
      IF PAR_TIPODO = 'FAT'
      ELSE
         SELECT PART_EUR
         SKIP +1
         LOOP
      ENDIF
   ELSE
      SELECT PART_EUR
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR

   **==> Scrivo la fattura con valore totale documento sul cursore
   SELECT XSCADEN
   APPEND BLANK

   REPLACE W_ANNO    WITH M.PAR_ANNO
   REPLACE W_NPART   WITH M.PAR_NPART
   REPLACE W_DTSCA   WITH M.PAR_DTSCAD
   REPLACE W_NPROG   WITH M.PAR_NPROG
   REPLACE WC_NFAT   WITH M.PAR_NUMFAT
   REPLACE WC_DTFAT  WITH M.PAR_DTFAT
   REPLACE WC_RAGSOC WITH M.PAR_RAGSOC
   IF F_VALUTA = 1
      REPLACE WC_TOTFAT WITH TLIRE(M.PAR_VALUTA,M.PAR_FATT,RIBALTA2(M.PAR_DTFAT))
   ELSE
      REPLACE WC_TOTFAT WITH TEURO(M.PAR_VALUTA,M.PAR_FATT,RIBALTA2(M.PAR_DTFAT))
   ENDIF
   REPLACE WC_TOTRAT WITH 0
   REPLACE WC_TOTPAG WITH 0
   REPLACE WC_TODAPG WITH WC_TOTFAT
   REPLACE WC_TOTINS WITH 0
   REPLACE WC_CAMBIO WITH M.PAR_CAMBIO
   REPLACE WC_VALUTA WITH M.PAR_VALUTA

   **==> loop su partitario a livello di numero partita
   x_soci = "par_codsoc = '" + PUB_CODSOC + "'"
   x_clie = "par_codcli = '" + ALLTRIM(M.PAR_CODCLI) + "'"
   x_npar = "par_npart = " + ALLTRIM(STR(M.NPART,10,0))
   x_cond = x_soci + " and " + x_clie + " and " + x_npar
   cSql="SELECT * FROM PART_FOR WHERE " + x_cond + ;
                                      " order by par_codsoc,par_codcli,par_npart"
   IF !ExecCommand(cSql,"cur_partfor")
      return(.f.)
   ENDIF
   SELECT CUR_PARTFOR
   GO TOP

   IF !EOF()

      DO WHILE .T.

         IF EOF()
            EXIT
         ENDIF

         IF PAR_NPROG = 100
            SKIP +1
            LOOP
         ENDIF

         V_DTSCA  = PAR_DTSCAD
         V_NPROG  = PAR_NPROG
         V_NUMFAT = PAR_NUMFAT
         V_DTFAT  = PAR_DTFAT
         V_RAGSOC = PAR_RAGSOC
         V_CAMBIO = PAR_CAMBIO
         V_VALUTA = PAR_VALUTA
         V_FATT   = PAR_FATT
         V_TIPODO = PAR_TIPODO
         V_ANNI   = PAR_ANNO
         V_NPART  = PAR_NPART

         **==> Gestione della rata da pagare

         IF V_TIPODO = 'FAT'
            SELECT XSCADEN
            APPEND BLANK
            REPLACE W_ANNO    WITH V_ANNI
            REPLACE W_NPART   WITH V_NPART
            REPLACE W_DTSCA   WITH V_DTSCA
            REPLACE W_NPROG   WITH V_NPROG
            REPLACE WC_NFAT   WITH V_NUMFAT
            REPLACE WC_DTFAT  WITH V_DTFAT
            REPLACE WC_RAGSOC WITH V_RAGSOC
            REPLACE WC_CAMBIO WITH V_CAMBIO
            REPLACE WC_VALUTA WITH V_VALUTA
            REPLACE WC_TOTFAT WITH 0
            IF F_VALUTA = 1
               REPLACE WC_TOTRAT WITH TLIRE(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
            ELSE
               REPLACE WC_TOTRAT WITH TEURO(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
            ENDIF
            REPLACE WC_TOTPAG WITH 0
            REPLACE WC_TODAPG WITH WC_TOTRAT
            REPLACE WC_TOTINS WITH 0
         ENDIF

         **==> Gestione del pagamento

         IF V_TIPODO = 'PAG'
            V_100 = 100
            SELECT XSCADEN
            SET ORDER TO PRN
            SEEK STR(V_NPART,10,0)+STR(V_100,5,0)
            IF FOUND()
               DO WHILE .T.
                  IF EOF()
                     EXIT
                  ENDIF
                  IF W_NPART = V_NPART
                  ELSE
                     SKIP +1
                     LOOP
                  ENDIF
                  IF W_NPROG = 100 .OR. W_DTSCA = V_DTSCA
                  ELSE
                     SKIP +1
                     LOOP
                  ENDIF
                  IF F_VALUTA = 1
                     REPLACE WC_TODAPG WITH WC_TODAPG - TLIRE(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
                     REPLACE WC_TOTPAG WITH TLIRE(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
                  ELSE
                     REPLACE WC_TODAPG WITH WC_TODAPG - TEURO(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
                     REPLACE WC_TOTPAG WITH TEURO(V_VALUTA,V_FATT,RIBALTA2(V_DTFAT))
                  ENDIF
                  SKIP +1
               ENDDO
            ENDIF
         ENDIF

         SELECT CUR_PARTFOR
         SKIP +1

      ENDDO

   ENDIF

   SELECT PART_EUR
   SKIP +1

ENDDO

SELECT XSCADEN
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF W_DTSCA >= DATADA
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF W_DTSCA <= DATAAL
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF W_NPROG = 100
      SKIP +1
      LOOP
   ENDIF

   IF WC_TODAPG > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IMPA    = WC_TODAPG
   DTSCA   = W_DTSCA

   MESE    = SUBSTR(W_DTSCA,6,2)

   _AVERE  = "CON_AV"+MESE+"F"
   _DARE   = "CON_DA"+MESE+"F"

   SELECT MOV_RIE
   SET ORDER TO MOV_RIE
   _RK = SUBSTR(DTSCA,1,4)

   SEEK _RK

   IF FOUND()
      REPLACE   &_DARE     WITH &_DARE + IMPA
   ELSE
      APPEND  BLANK
  	  REPLACE   PERIODO     WITH _RK
      REPLACE   &_DARE      WITH IMPA
      REPLACE   &_AVERE     WITH 0
   ENDIF

   SELECT XSCADEN
   SKIP +1

ENDDO

SELECT XSCADEN
USE

SELECT PART_EUR
USE

RETURN


