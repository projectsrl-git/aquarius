***************************************************************************************
*  			 AGGIORNA DATI PLAFOND DEL FORNITORE - RICALCOLA PLAFOND RESIDUO          *
***************************************************************************************
PROCEDURE REG_PLAFOND_FORNITORI

IF !PUB_PLAFACQF 		&& AGGIORNA SOLO ESCLUSIVAMENTE SE E' GESTITO IL PLAFOND IVA  DEL FORNITORE NEI PARAMETRI AZIENDALI
	RETURN
ENDIF


IF FATTURA <> "S"  		&& TRATTA SOLO LE FATTURE DI ACQUISTO
	RETURN
ENDIF

IF VER_CONTO <> "F"   	&& TRATTA SOLO I FORNITORI
	RETURN
ENDIF

_CODICE_FORNITORE = ALLTRIM(PUB_CONTO_FORNITORE)

IF EMPTY(_CODICE_FORNITORE)
	RETURN
ENDIF

AXFORNIPLAF = SELECT()

x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
x_codf = "for_codcli = '" + _CODICE_FORNITORE + "'"			
x_cond = x_soci + " and " + x_codf
CSQL   = "select * from U_FOR_AN where " + x_cond + " order by for_codsoc,for_codcli"
IF !ExecCommand(cSql,"U_FOR_AN_CU")
    return(.f.)
ENDIF

SELECT U_FOR_AN_CU
IF !EOF()
   IVA_ESE__ = FOR_ALRID
   _DESCRIZIONE_FORNITORE = ALLTRIM(FOR_RAGSOC)  && ERASMO - 26/10/2022
ELSE
   IVA_ESE__ = ""
   _DESCRIZIONE_FORNITORE = ""  && ERASMO - 26/10/2022
ENDIF

*!*	IF !EMPTY(IVA_ESE__)		&& se fornitore non in esenzione non effettua nessuna attivitŕ
*!*	ELSE
*!*		RETURN
*!*	ENDIF
&& ERASMO - 28/03/2017 - ASTERISCATO TEST DI ESCLUSIONE DAL RICALCOLO PLAFOND IN QUANTO VALE IL CODICE IVA PRESENTE SUL MOVIMENTO CONTABILE, NON SULL'ANAGRAFICA DEL FORNITORE

**=> ERASMO/SERGIO - INIZIO 23/10/2017
_ANNO_PLAFOND = PUB_ANNO
IF PUB_PLADFA
	SELECT CORPO_MOV_SAVE
	SET ORDER TO I_SEQUEN
	GO TOP
	IF !EOF()
		_ANNO_PLAFOND = SUBSTR(DTDOCUM,7,4)	&& DATA DOCUMENTO DELLA PRIMA NOTA ORIGINALE
	ELSE
		_ANNO_PLAFOND = SUBSTR(DATADOC,7,4)	&& DATA DOCUMENTO DELLA PRIMA NOTA ORIGINALE
	ENDIF
ENDIF
**=> ERASMO/SERGIO - FINE 23/10/2017

**=> ERASMO - INIZIO 26/10/2022
*** ESCO DALLA PROCEDURA SE NON C'E' NESSUN CODICE IVA DEDICATO AL CALCOLO DEL PLAFOND IVA FORNITORI
_lCalcPlaf = .F.
SELECT CORPO_MOV_SAVE
GO TOP
SCAN
   	IF CERCA_IVA_PLAFOND(IVA)
		_lCalcPlaf = .T.
   	ENDIF
ENDSCAN

SELECT CORPO_MOV
GO TOP
SCAN
   	IF CERCA_IVA_PLAFOND(IVA)
		_lCalcPlaf = .T.
   	ENDIF
ENDSCAN

IF !_lCalcPlaf
	RETURN
ENDIF
**=> ERASMO - FINE 26/10/2022

x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
*x_anno = "iva_anno = " + PUB_ANNO
*x_anno = "iva_anno = " + _ANNO_PLAFOND  && ERASMO/SERGIO - 23/10/2017
x_anno = "iva_anno = '" + _ANNO_PLAFOND + "'"  && ERASMO - 19/01/2024
x_codf = "iva_codfor = '" + _CODICE_FORNITORE + "'"			
x_cond = x_soci + " and " + x_anno + " and " + x_codf
CSQL   = "select * from U_IVA_FE where " + x_cond + " order by iva_codsoc,iva_anno"
IF !ExecRW(cSql,"U_IVA_FE","R")
  return(.f.)
ENDIF

SELECT U_IVA_FE
IF EOF()

	** 20/07/2022 SERGIO INIZIO: GESTIONE PLAFOND IVA FORNITORI PROFESSIONISTI
 	*_cMsg = "ATTENZIONE" + CHR(13) + CHR(13) + "Aggiornare il plafond iva DEL FORNITORE in esenzione iva" + CHR(13) + "utilizzare la procedura presente in ANAGRAFICA FORNITORI(cartella IVA)" + CHR(13) + "Fare click su OK per continuare"
 	_cMsg = "ATTENZIONE" + CHR(13) + CHR(13) + "Aggiornare il plafond iva DEL FORNITORE in esenzione iva: " + _DESCRIZIONE_FORNITORE + CHR(13) + "utilizzare la procedura presente in ANAGRAFICA FORNITORI(cartella IVA)" + CHR(13) + "Fare click su OK per continuare"
	** 20/07/2022 SERGIO FINE: GESTIONE PLAFOND IVA FORNITORI PROFESSIONISTI
	
	DO MESSAGGIO_STILE_WIN8 WITH _cMsg

	APPEND BLANK
	REPLACE IVA_CODSOC 	WITH PUB_CODSOC
	REPLACE IVA_ANNO   	WITH VAL(PUB_ANNO)
	*REPLACE IVA_PLAFOND	WITH 500000			&& PLAFOND INDICATIVO DI PARTENZA
	REPLACE IVA_CODFOR	WITH _CODICE_FORNITORE 		&& ERASMO - 26/10/2022
	REPLACE IVA_DESFOR	WITH _DESCRIZIONE_FORNITORE	&& ERASMO - 26/10/2022
ENDIF


SCATTER MEMVAR MEMO



* ####################################### TOGLIE L'IMPONIBILE ESENTE ORIGINALE DELLA PRIMA NOTA DI PARTENZA #######################################
SELECT CORPO_MOV_SAVE
SET ORDER TO I_SEQUEN
GO TOP

DO WHILE !EOF()

   	IF DELETED()
		SELECT CORPO_MOV_SAVE
    	SKIP +1
    	LOOP
   	ENDIF

	IF ALLTRIM(IVA) = "NO"			&& SCARTA I MOVIMENTI FORNITORI
		SELECT CORPO_MOV_SAVE
    	SKIP +1
    	LOOP
   	ENDIF
  	
   	IF !CERCA_IVA_PLAFOND(IVA)		&& SCARTA I MOVIMENTI IVA CHE NON ENTRANO NEL CALCOLO DEL PLAFOND RESIDUO
		SELECT CORPO_MOV_SAVE
    	SKIP +1
    	LOOP
   	ENDIF
	
	SELECT CORPO_MOV_SAVE
	__IMPORTO_ESENTE = DARE+AVERE
	
	IF _NOTAC = "S"	&& NOTA CREDITO FORNITORE				&& 2016/02/15 SERGIO
		__IMPORTO_ESENTE = __IMPORTO_ESENTE  * -1			&& 2016/02/15 SERGIO
	ENDIF													&& 2016/02/15 SERGIO
	
