				IF !EMPTY(ALLTRIM(_C_FORNITORE))
					_CLI_FOR = UPPER(SUBSTR(TMP_FORNITORI.CON_TIPOCO,1,1))
					IF _CLI_FOR == "F"
						SELECT CORPO_MOV
						GO TOP
						SCAN
							IF ALLTRIM(CONTO) = _CONTO_SET_ANT_FORN
								REPLACE __NUCOM WITH "Forn. " + ALLTRIM(_C_FORNITORE)
							ENDIF
						ENDSCAN
						MESSAGEBOX("Fornitore " + ALLTRIM(_C_FORNITORE) + " impostato",64,"Informazione")
					ELSE
						MESSAGEBOX("Il conto selezionato non č un conto di tipo Fornitore",48,"Informazione")
						MESSAGEBOX("Fornitore non impostato",48,"Informazione")
					ENDIF
				ELSE
					MESSAGEBOX("Fornitore non impostato",48,"Informazione")
				ENDIF
			ELSE
				MESSAGEBOX("Fornitore non impostato",48,"Informazione")
			ENDIF
		ENDIF
	ENDIF  && ERASMO - 08/04/2024
ENDIF

