	SUM PAR_FATT TO ___TOTALE_EFFETTI_ATTIVI


	SELECT CURS_PART_CLI_EA
	GO TOP
	DO WHILE .NOT.EOF()
	
		XAGGANCIO = DAGGANCIO
		x_aggancio = "daggancio = '" + XAGGANCIO + "'"
		
		cSql="SELECT * FROM U_ASC_DD WHERE " + x_aggancio + ;
		                                   " order by daggancio"


	    IF !ExecCommand(cSql,"CX_U_ASC_DD")
		   return(.f.)
		ENDIF
		
		SELECT CX_U_ASC_DD
		DO WHILE .NOT. EOF()		&& UNA FATTURA PUO' AVERE PIU' EFFETTI ATTIVI : MI COSTRUISCO IL CURSORE CON I DETTAGLI DI PIU' EFFETTI
		
		
			SCATTER MEMVAR MEMO
			SELECT CURS_U_ASC_DD
			APPEND BLANK
			GATHER MEMVAR MEMO
		
		
		
			SELECT CX_U_ASC_DD	
			SKIP +1	
		
		
		ENDDO
		

		SELECT CURS_PART_CLI_EA	
		SKIP +1	
		
	ENDDO
	
	SELECT CURS_PART_CLI_EA
	GO TOP	




RETURN



