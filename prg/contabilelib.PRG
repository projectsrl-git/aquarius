			   SKIP +1
			   LOOP
         ELSE
			IF SUBSTR(CON_TIPOCO,1,1) = "C" OR  SUBSTR(CON_TIPOCO,1,1) = "F"
			   SELECT CORPO_MOV
			   SKIP +1
			   LOOP
			ENDIF
	     ENDIF

        SELECT CORPO_MOV

 	    M.DARIP = 0
 	
		IF DARE <> 0
		   M.DARIP = DARE
		ENDIF
		IF AVERE <> 0
		   M.DARIP = AVERE
		ENDIF

	*--> PRELIEVO DEI  CENTRI DI COSTO DA PIANO DEI CONTI O DA ANAGRAFICA CLIENTE O FORNITORE SOLO SE IN INSERIMENTO

	   IF EMPTY(CECO) && SE NON E' STATO DGITATO NULLA NEL CENTRO DI COSTO


		   IF PUB_CCOPDC && CENTRI DI COSTO DA PIANO DEI CONTI

				   STORE ___conti.CON_CCO     		TO M.CECO             && PERMETTE DI AGGIORNARE I DATABASES
				   STORE ___conti.CON_CCO     		TO M.COD01
				   STORE ___conti.CON_CCO1    		TO M.COD02
				   STORE ___conti.CON_CCO2    		TO M.COD03
				   STORE ___conti.CON_CCO3    		TO M.COD04
				   STORE ___conti.CON_CCO4    		TO M.COD05
