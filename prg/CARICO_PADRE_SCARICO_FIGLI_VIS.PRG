
gcFile = GETFILE('XLSX', '', 'Seleziona', 0, 'Seleziona il file da importare')

IF EMPTY(gcFile)
	MESSAGEBOX("Nessun file selezionato",64,"Informazione")
	RETURN
ENDIF

_cFileName = ALLTRIM(gcFile)


IF EMPTY(_cFileName)
	MESSAGEBOX("Nessun file sorgente selezionato",64,"Informazione")
	RETURN .F.
ENDIF

gnErrFile = FOPEN(_cFileName,12)
IF gnErrFile < 0  && Check for error opening file
   MESSAGEBOX("File giŕ aperto da un altro programma." + CHR(13) + CHR(13) + ;
              "Chiudere il file prima di proseguire",16,"Attenzione")
   RETURN .F.
ENDIF
=FCLOSE(gnErrFile)


_ACT_FILENAME = ALLTRIM(_cFileName)

_cTabSource = "XLS_PADRI_FIGLI_VIS"
IF USED(_cTabSource)
	SELECT &_cTabSource
	USE
ENDIF
_OK_CURSORE = XLS_TO_VFP_CURSOR(_ACT_FILENAME,_cTabSource)

IF !_OK_CURSORE
	RETURN .F.
ENDIF

_nIniRowNr = 2

_CONTA_PIU = 0
_CONTA_MENO = 0

_COD_PADRE_PREC = ""
_SYSMAG_COD_PADRE_PREC = ""
_NUMEROPROT_PREC = ""
_DATAPROT_PREC = ""
_W_COSTO_FIGLI = 0
_cTrackingString = ""

_NRIGA = 0
SELECT &_cTabSource
GO TOP
SCAN
	
	_NRIGA = _NRIGA + 1
	
	IF _NRIGA < _nIniRowNr
		LOOP
	ENDIF
	
	WAIT WINDOWS "Elaborazione file " + ALLTRIM(JUSTFNAME(_ACT_FILENAME)) + " - riga " + ALLTRIM(STR(RECNO())) + " di " + ALLTRIM(STR(RECCOUNT())) + " ..." NOWAIT
	
	_NUMEROPROT = ""	&& COLONNA "G"
	_DATAPROT = ""		&& COLONNA "H"
	_C_F = ""			&& COLONNA "I"
	_CLI_FOR = ""		&& COLONNA "J"
	_RAGIONESOC = ""	&& COLONNA "K"
	_CENTRCOSTO = ""	&& COLONNA "M"
	_COD_PADRE = ""		&& COLONNA "N"
	_SEGNO_MOV = ""		&& COLONNA "O"
	_ARTICOLO = ""		&& COLONNA "P"
	_DESARTICOL = ""	&& COLONNA "Q"
	_QUANTITA = 0		&& COLONNA "R"
	_NOTE = ""			&& COLONNA "T"
	
	SCATTER MEMVAR
	
	IF !EMPTY(M.G)
		_NUMEROPROT = 'X'+SUBSTR(M.G,3,6)
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.H)
		_DATAPROT = SUBSTR(M.H,1,4) + "/" + SUBSTR(M.H,5,2) + "/" + SUBSTR(M.H,7,2)
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.I)
		_C_F = ALLTRIM(M.I)
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.J)
		_CLI_FOR = ALLTRIM(M.J)
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.K)
		_RAGIONESOC = ALLTRIM(M.K)
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.M)
		_CENTRCOSTO = ALLTRIM(M.M)
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.N)
		_COD_PADRE = ALLTRIM(M.N)
		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "ART_CODPRI = '" + _COD_PADRE + "'"
		x_cond = x_soci + " and " + x_codi 
		cSql   = "SELECT ART_CODPRI FROM U_ART_PR WHERE " + x_cond
		IF !ExecCommand(cSql,"TMP_U_ART_PR")
			return(.f.)
		ENDIF
		SELECT TMP_U_ART_PR
		GO TOP
		IF EOF()
			MESSAGEBOX("Codice padre " + ALLTRIM(_COD_PADRE) + " non trovato in anagrafica" + REPLICATE(CHR(13),2) + "La riga verrŕ ignorata",48,"Attenzione")
			SELECT &_cTabSource
			SKIP +1
			LOOP
		ENDIF
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.O)
		_SEGNO_MOV = ALLTRIM(M.O)
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.P)
		_ARTICOLO = ALLTRIM(M.P)
		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "ART_CODPRI = '" + _ARTICOLO + "'"
		x_cond = x_soci + " and " + x_codi 
		cSql   = "SELECT ART_CODPRI FROM U_ART_PR WHERE " + x_cond
		IF !ExecCommand(cSql,"TMP_U_ART_PR")
			return(.f.)
		ENDIF
		SELECT TMP_U_ART_PR
		GO TOP
		IF EOF() AND "-" $ _SEGNO_MOV
			MESSAGEBOX("Codice articolo " + ALLTRIM(_ARTICOLO) + " non trovato in anagrafica" + REPLICATE(CHR(13),2) + "La riga verrŕ ignorata",48,"Attenzione")
			SELECT &_cTabSource
			SKIP +1
			LOOP
		ENDIF
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.Q)
		_DESARTICOL = ALLTRIM(M.Q)
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF
	
	IF !EMPTY(M.R)
		_QUANTITA = VAL(M.R)
	ELSE
		SELECT &_cTabSource
		SKIP +1
		LOOP
	ENDIF

	IF !EMPTY(M.T)
		_NOTE = ALLTRIM(M.T)
	ENDIF
	
	*** UPDATE COSTO E STRINGA DI TRACCIABILITA' SU MOVIMENTO E GIACENZA PADRE PRECEDENTEMENTE CARICATA
	IF _W_COSTO_FIGLI > 0 AND _SYSMAG_COD_PADRE_PREC <> ""
		IF UPPER(ALLTRIM(_COD_PADRE_PREC))+_NUMEROPROT_PREC+_DATAPROT_PREC <> UPPER(ALLTRIM(_COD_PADRE))+_NUMEROPROT+_DATAPROT
			
			x_lsys = "MOV_LEGSYS = '" + _SYSMAG_COD_PADRE_PREC + "'"
			x_cond = x_lsys
			cSql   = "UPDATE U_MAG_MO SET MOV_TRCKNG = '" + _cTrackingString + "', MOV_VALACQ = " + STRTRAN(STR(_W_COSTO_FIGLI,19,6),",",".") + ", MOV_PREACQ = (" + STRTRAN(STR(_W_COSTO_FIGLI,19,6),",",".") + "/MOV_QTAMOV) WHERE " + x_cond
			IF !ExecCommand(cSql,"UPD_MAG_MO")
				return(.f.)
			ENDIF
			
			x_lsys = "MAG_LEGSYS = '" + _SYSMAG_COD_PADRE_PREC + "'"
			x_cond = x_lsys
			cSql   = "UPDATE U_MAG_GG SET MAG_PRZCON = (" + STRTRAN(STR(_W_COSTO_FIGLI,19,6),",",".") + "/MAG_GIACEN) WHERE " + x_cond
			IF !ExecCommand(cSql,"UPD_MAG_GG")
				return(.f.)
			ENDIF
			
			_COD_PADRE_PREC = ""
			_SYSMAG_COD_PADRE_PREC = ""
			_NUMEROPROT_PREC = ""
			_DATAPROT_PREC = ""
			_W_COSTO_FIGLI = 0
			_cTrackingString = ""
			
		ENDIF
	ENDIF
	
	*** CARICO CODICE PADRE O CODICE DI VENDITA CON RIFERIMENTI DDT DI CONTO VISIONE
	IF "+" $ _SEGNO_MOV
		
		IF USED("CU_BFO_DD")
			SELECT CU_BFO_DD
			USE
		ENDIF
		IF !ExecCommand("select SPACE(10) AS ORD_SERIAL, * from u_bfo_dd where 0=1","CU_BFO_DD")
		   return(.f.)
		ENDIF
		SELECT CU_BFO_DD
		INDEX ON ORD_SEQUEN TAG SEQUEN ADDITIVE
		
		*** RIPULISCO EVENTUALE CURSORE SPORCO IN LINEA (DA NON GESTIRE)
		*** IN QUANTO IL S/N LO GESTISCO DIRETTAMENTE A LIVELLO DI DETTAGLIO CU_BFO_DD
		IF USED("CU_BFO_SN")
			SELECT CU_BFO_SN
			USE
		ENDIF

		*** RICERCA TIPOLOGIA DI SERIAL NUMBER DEL CODICE DI VENDITA
		_X_QUANTI_ART_VENDITA = _QUANTITA
		_X_CODMAT = ""
		_CODTSN = ""
		_LINEA = ""
		_TIPO_MASK = "****"
		_LET_CONTATORE = ""
		_NUM_CONTATORE = ""
		_RICHIEDE_SERIAL = .F.
		_UMMAGA = ""
		_DESCR = ""

		x_soci = "U_ART_AN.ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "U_ART_AN.ART_CODPRI = '" + _COD_PADRE + "'"
		x_cond = x_soci + " and " + x_codi 
		cSql   = "SELECT U_ART_AN.ART_CODTSN, U_ART_PR.ART_LINEA, U_ART_PR.ART_DESCR, U_ART_PR.ART_CODMAT, U_ART_PR.ART_UMMAGA, COALESCE(PARA.LIBERA,'') AS TIPO_MASK, " + CHR(13) + ;
		         "COALESCE(PARA.CODPGO,'') AS LET_CONTATORE, COALESCE(PARA.DESIVA,'') AS NUM_CONTATORE, COALESCE(PARA.ITALIANO,'') AS MESSAGGIO FROM U_ART_AN " + CHR(13) + ;
		         "LEFT OUTER JOIN U_ART_PR ON U_ART_PR.ART_CODSOC = U_ART_AN.ART_CODSOC AND U_ART_PR.ART_CODPRI = U_ART_AN.ART_CODPRI " + CHR(13) + ;
		         "LEFT OUTER JOIN PARA ON PARA.CODICE = 'TSN'+U_ART_AN.ART_CODTSN WHERE " + x_cond
		IF !ExecCommand(cSql,"TMP_U_ART_PR")
			return(.f.)
		ENDIF
		SELECT TMP_U_ART_PR
		GO TOP
		IF !EOF()
			_X_CODMAT = ART_CODMAT
			_UMMAGA = ART_UMMAGA
			_DESCR = ART_DESCR
			IF EMPTY(ART_CODTSN)
				*WAIT CLEAR
				*MESSAGEBOX("Tipo Serial Number non definito per l'articolo " + ALLTRIM(_SER_ANAART),16,"Attenzione")
				*RETURN 0
			ELSE
				_CODTSN = ALLTRIM(ART_CODTSN)
				_LINEA = ALLTRIM(ART_LINEA)
				_TIPO_MASK = ALLTRIM(TIPO_MASK)
				_LET_CONTATORE = ALLTRIM(LET_CONTATORE)
				_NUM_CONTATORE = ALLTRIM(NUM_CONTATORE)
				
				IF "RICHIEDE_SERIAL=SI" $ MESSAGGIO
					_RICHIEDE_SERIAL = .T.
				ELSE
					_RICHIEDE_SERIAL = .F.
				ENDIF
			ENDIF
		ELSE
			WAIT CLEAR
			MESSAGEBOX("Articolo " + ALLTRIM(_COD_PADRE) + " non trovato in anagrafica",16,"Attenzione")
			SELECT &_cTabSource
			LOOP
		ENDIF
		
		
		_SN_LOT = ""
		
		SELECT CU_BFO_DD
		APPEND BLANK
		REPLACE DAGGANCIO  WITH '1111111111'
		REPLACE ORD_CODART WITH _COD_PADRE
		REPLACE ORD_NUMBOB WITH 0
		REPLACE ORD_UM     WITH _UMMAGA
		REPLACE ORD_IVA    WITH ""
		REPLACE ORD_DESART WITH _DESCR
		REPLACE ORD_MAGA   WITH "VIS"
		REPLACE ORD_QTAORD WITH _QUANTITA
		REPLACE ORD_SC1    WITH 0
		REPLACE ORD_SC2    WITH 0
		REPLACE ORD_SC3    WITH 0
		REPLACE ORD_DATCON WITH RIBALTA2(DTOC(DATE()))
		REPLACE ORD_CODSYS WITH SYS(2015)
		REPLACE ORS_CODCLI WITH _CLI_FOR
		REPLACE ORS_RAGSOC WITH _RAGIONESOC
		REPLACE ORS_NUMORD WITH ALLTRIM(_NUMEROPROT)
		REPLACE ORS_DATORD WITH _DATAPROT
		REPLACE ORS_VALUTA WITH PUB_VALU
		REPLACE ORD_SEQUEN WITH 0
		REPLACE ORD_LEGAME WITH '1111111111'
		REPLACE ORD_LEGSYS WITH SYS(2015)
		REPLACE ORD_FLGMOD WITH 'I'
		REPLACE ORS_NUMIDE WITH ""
		REPLACE ORS_ANNO   WITH SUBSTR(ORS_DATORD,1,4)
		REPLACE ORD_LEGASY WITH SYS(2015)
		REPLACE ORD_SALCON WITH 'S'
		REPLACE ORD_DTASCA WITH RIBALTA2(DETERMINA_SCADENZA_DEFAULT(_COD_PADRE,ORS_DATORD))
		REPLACE ORD_QTAML  WITH 0
		REPLACE ORD_QTAMQ  WITH 0
		REPLACE ORD_QTAKG  WITH 0
		*REPLACE ORD_QTAMC  WITH M.QTAMCPROD 
		REPLACE ORD_QTAML1 WITH 0
		REPLACE ORD_QTAMQ1 WITH 0
		REPLACE ORD_QTAKG1 WITH 0
		REPLACE ORD_ALTEZZ WITH 0
		REPLACE ORD_LUNGHE WITH 0
		REPLACE ORD_SPESSO WITH 0
		REPLACE ORD_CODMAT WITH _X_CODMAT 
		REPLACE ORD_CODCOL WITH "" 
		REPLACE ORD_DESMAT WITH ""
		REPLACE ORD_FILA_X WITH "" 
		REPLACE ORD_PIAN_X WITH ""
		REPLACE ORD_UBIC_X WITH ""
		REPLACE ORD_FILA_N WITH 0
		REPLACE ORD_PIAN_N WITH 0
		REPLACE ORD_UBIC_N WITH 0
		REPLACE ORD_SYSMAG WITH SYS(2015)
		REPLACE ORD_CLIENT WITH ""
		*REPLACE ORD_SERIAL WITH M.SERIAL
		*REPLACE ORD_SERIAL WITH ""
		REPLACE ORS_NLOTFO WITH ""
		REPLACE ORD_PREZZO WITH 0
		REPLACE ORD_PRZNET WITH 0
		REPLACE ORD_NOTEBO WITH ALLTRIM(_NOTE)
		
		_COD_PADRE_PREC = _COD_PADRE
		_SYSMAG_COD_PADRE_PREC = ORD_SYSMAG
		_NUMEROPROT_PREC = _NUMEROPROT
		_DATAPROT_PREC = _DATAPROT
		_W_COSTO_FIGLI = 0
		_cTrackingString = ""
		

		SELECT CU_BFO_DD
		GO TOP
		SCATTER MEMVAR MEMO

		*M.ORD_CAUS = IIF(!EMPTY(PUB_CAPPDMSPED),ALLTRIM(PUB_CAPPDMSPED),"CAP")
		M.ORD_CAUS = "VR+"  && CAUSALE NEUTRA DEDICATA (PER NON MODIFICARE I DATI DI ULTIMO CARICO IN ANAGRAFICA ARTICOLI)
		M.ORD_NUMORD = M.ORS_NUMORD
		M.ORD_DATORD = M.ORS_DATORD
		M.ORD_CODCLI = M.ORS_CODCLI
		M.ORD_RAGSOC = M.ORS_RAGSOC
		M.ORD_CODACQ = M.ORS_CODACQ
		M.ORD_VALUTA = M.ORS_VALUTA
		M.ORD_NUMIDE = AQM_NEW_NUMIDE()
		M.ORD_CODBUN = ""

		SELECT CU_BFO_DD
		GO TOP

		XXY_CODINT = ""
		XXY_NRLINT = 0
		XXY_UNIQUE = ""
		=AQM_GESTIONE_CARICHI_BFO()
		*_W_CODINT = XXY_CODINT
		_W_MAG_UNIQUE = XXY_UNIQUE
		
		x_lsys = "MOV_LEGSYS = '" + _SYSMAG_COD_PADRE_PREC + "'"
		x_cond = x_lsys
		cSql   = "UPDATE U_MAG_MO SET MOV_CODBUN = '" + _CENTRCOSTO + "' WHERE " + x_cond
		IF !ExecCommand(cSql,"UPD_MAG_MO")
			return(.f.)
		ENDIF
		
		_CONTA_PIU = _CONTA_PIU + 1

	ENDIF
	
	
	*** SCARICO FIGLI CON RIFERIMENTI DDT DI CONTO VISIONE
	IF "-" $ _SEGNO_MOV
		
		IF USED("CU_MAG_GM")
		   SELECT CU_MAG_GM
		   USE
		ENDIF
		
		_X_QTA_DA_SCAR = _QUANTITA
		
		_x_qtasca = 0
		
		x_arti = "MAG_ANAART = '" + _ARTICOLO + "'"
		x_data = "MAG_DATAGG = '2015/01/12'"
		x_maga = "MAG_CODMAG = 'VIS'"
		x_sern = "1=1"
		x_giac = "MAG_GIACEN > 0"
		x_forn = "1=1"
		x_cond = x_arti + " and " + x_data + " and " + x_maga + " and " + x_sern + " and " + x_giac + " and " + x_forn 
		cSql   = "select MAG_GIACEN AS MAG_GIAMAX, U_ART_PR.ART_UMMAGA AS MAG_UMMAGA, u_mag_gg.* from u_mag_gg " + ;
		         "LEFT OUTER JOIN U_ART_PR ON U_MAG_GG.MAG_ANAART = U_ART_PR.ART_CODPRI where " + x_cond + " order by mag_datagg,mag_oracar,mag_codart"
		IF !ExecCommand(cSql,'CU_MAG_GM')
		   return(.f.)
		ENDIF
		SELECT CU_MAG_GM
		GO TOP
		IF !EOF()
			
			DO WHILE !EOF()
				
				_Y_GIA_DA_SCA = 0
				
				IF MAG_GIAMAX >= _X_QTA_DA_SCAR
					_Y_GIA_DA_SCA = _X_QTA_DA_SCAR
				ELSE
					_Y_GIA_DA_SCA = MAG_GIAMAX
				ENDIF
				
				SELECT CU_MAG_GM
				REPLACE MAG_GIACEN WITH _Y_GIA_DA_SCA

				SCATTER MEMVAR MEMO
				
				LOCAL cLegame
				cLegame = M.MAG_LEGAME

				*** VALORIZZAZIONE VARIABILI CHE DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA (LA QUANTITA' DA SCARICARE E' CONTENUTA IN CU_MAG_GM.MAG_GIACEN)
				=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
				=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
				*** VALORIZZAZIONE VARIABILI CHE NON DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA
				AQM_DTDOCU = _DATAPROT
				AQM_NUMDOC = ALLTRIM(_NUMEROPROT)
				AQM_CODCLI = _CLI_FOR
				AQM_DESCLI = _RAGIONESOC
				*AQM_TOP    = IIF(!EMPTY(PUB_SCPPDMSPED),ALLTRIM(PUB_SCPPDMSPED),"SCP")
				AQM_TOP    = "VR-"  && CAUSALE NEUTRA DEDICATA (PER NON MODIFICARE I DATI DI ULTIMO CARICO IN ANAGRAFICA ARTICOLI)
				AQM_DTREGI = _DATAPROT
				AQM_VALUTA = PUB_VALU
				AQM_COORD  = ""
				AQM_UM     = M.MAG_UMMAGA
				AQM_PREVEN = 0
				AQM_IVAVEN = ""
				AQM_NOTE   = _NOTE
				
				*** SCARICO SEMPRE LA GIACENZA E L'IMPEGNATO
				_OK_SCAR = AQM_SCARICA_MAGAZZINO(.F.)
				
				IF _OK_SCAR
					_x_qtasca = _x_qtasca + _Y_GIA_DA_SCA 
					_cTrackingString = ALLTRIM(_cTrackingString) + IIF(EMPTY(_cTrackingString),"",";") + cLegame
					_W_COSTO_FIGLI = _W_COSTO_FIGLI + M.MAG_GIACEN * M.MAG_PRZCON
				ELSE
					MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze",16,"Attenzione")
					SELECT CU_MAG_GM
					SKIP +1
					LOOP
				ENDIF
				
				_X_QTA_DA_SCAR = _X_QTA_DA_SCAR - _Y_GIA_DA_SCA 
				
				IF _X_QTA_DA_SCAR > 0
				ELSE
					EXIT
				ENDIF

				SELECT CU_MAG_GM
				SKIP +1
			ENDDO
			
			_CONTA_MENO = _CONTA_MENO + 1
			
		ENDIF
	ENDIF
	
ENDSCAN


*** UPDATE COSTO E STRINGA DI TRACCIABILITA' SU MOVIMENTO E GIACENZA PADRE PRECEDENTEMENTE CARICATA
IF _W_COSTO_FIGLI > 0 AND _SYSMAG_COD_PADRE_PREC <> ""
	x_lsys = "MOV_LEGSYS = '" + _SYSMAG_COD_PADRE_PREC + "'"
	x_cond = x_lsys
	cSql   = "UPDATE U_MAG_MO SET MOV_TRCKNG = '" + _cTrackingString + "', MOV_VALACQ = " + STRTRAN(STR(_W_COSTO_FIGLI,19,6),",",".") + ", MOV_PREACQ = (" + STRTRAN(STR(_W_COSTO_FIGLI,19,6),",",".") + "/MOV_QTAMOV) WHERE " + x_cond
	IF !ExecCommand(cSql,"UPD_MAG_MO")
		return(.f.)
	ENDIF
	
	x_lsys = "MAG_LEGSYS = '" + _SYSMAG_COD_PADRE_PREC + "'"
	x_cond = x_lsys
	cSql   = "UPDATE U_MAG_GG SET MAG_PRZCON = (" + STRTRAN(STR(_W_COSTO_FIGLI,19,6),",",".") + "/MAG_GIACEN) WHERE " + x_cond
	IF !ExecCommand(cSql,"UPD_MAG_GG")
		return(.f.)
	ENDIF
			
	_COD_PADRE_PREC = ""
	_SYSMAG_COD_PADRE_PREC = ""
	_NUMEROPROT_PREC = ""
	_DATAPROT_PREC = ""
	_W_COSTO_FIGLI = 0
	_cTrackingString = ""
ENDIF

SELECT &_cTabSource
USE


WAIT CLEAR 

IF (_CONTA_PIU + _CONTA_MENO) > 0
	MESSAGEBOX("Totale giacenze caricate: " + ALLTRIM(STR(_CONTA_PIU)) + REPLICATE(CHR(13),2) + "Totale giacenze scaricate: " + ALLTRIM(STR(_CONTA_MENO)),64,"Informazione")
ELSE
	MESSAGEBOX("Nessuna giacenza trasformata",64,"Informazione")
	RETURN .F.
ENDIF
