SET PROCEDURE TO PRG\BILANCIO_LIB ADDITIVE

LOCAL V_CDC , _FLAG_SALDI_A_ZERO


V_CDC="ADV"
_FLAG_SALDI_A_ZERO=.F.

WAIT WINDOW "********** BILANCIO PER CENTRO DI COSTO: "+V_CDC + " - SENZA SALDI A ZERO "

BILANCIO_PER_CENTRO_DI_COSTO(V_CDC,_FLAG_SALDI_A_ZERO)


SELECT CU_CONTI
GO TOP
BROWSE NORMAL


V_CDC=""
_FLAG_SALDI_A_ZERO=.F.
WAIT WINDOW "********** BILANCIO COMPLETO - SENZA SALDI A ZERO "
BILANCIO_DI_ESERCIZIO(_FLAG_SALDI_A_ZERO)

SELECT CU_CONTI
GO TOP
BROWSE NORMAL

WAIT WINDOW ;
	"ATTIVITA: "+STR(BILANCIO_ATTIVITA ) +CHR(13)+;
	"PASSIVITA: "+STR(BILANCIO_PASSIVITA) +CHR(13)+;
	"RISULTATO ESERCIZIO (PATRIMONIALI): "+STR(BILANCIO_RISULTATO_PATRIMONIALI) +CHR(13)+;
	CHR(13)+CHR(13)+;
	"COSTI: "+STR(BILANCIO_COSTI) +CHR(13)+;
	"RICAVI: "+STR(BILANCIO_RICAVI) +CHR(13)+;
	"RISULTATO ESERCIZIO (ECONOMICI): "+STR(BILANCIO_RISULTATO_ECONOMICI) +CHR(13)+;
	CHR(13)+CHR(13)+;
	"SALDO BILANCIO: "+STR(BILANCIO_SALDO) 
	


V_CDC="ADV"
_FLAG_SALDI_A_ZERO=.T.
WAIT WINDOW "********** BILANCIO PER CENTRO DI COSTO: "+V_CDC + " - CON SALDI A ZERO "
BILANCIO_PER_CENTRO_DI_COSTO(V_CDC,_FLAG_SALDI_A_ZERO)

SELECT CU_CONTI
GO TOP
BROWSE NORMAL


V_CDC=""
_FLAG_SALDI_A_ZERO=.T.
WAIT WINDOW "********** BILANCIO COMPLETO - CON SALDI A ZERO "
BILANCIO_DI_ESERCIZIO(_FLAG_SALDI_A_ZERO)

SELECT CU_CONTI
GO TOP
BROWSE NORMAL

WAIT WINDOW ;
	"ATTIVITA: "+STR(BILANCIO_ATTIVITA ) +CHR(13)+;
	"PASSIVITA: "+STR(BILANCIO_PASSIVITA) +CHR(13)+;
	"RISULTATO ESERCIZIO (PATRIMONIALI): "+STR(BILANCIO_RISULTATO_PATRIMONIALI) +CHR(13)+;
	CHR(13)+CHR(13)+;
	"COSTI: "+STR(BILANCIO_COSTI) +CHR(13)+;
	"RICAVI: "+STR(BILANCIO_RICAVI) +CHR(13)+;
	"RISULTATO ESERCIZIO (ECONOMICI): "+STR(BILANCIO_RISULTATO_ECONOMICI) +CHR(13)+;
	CHR(13)+CHR(13)+;
	"SALDO BILANCIO: "+STR(BILANCIO_SALDO) 


