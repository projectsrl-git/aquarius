*************************************************************************************************
PROCEDURE SCARICA_CAMBI_GIORNALIERI_DAL_AL       && SCARICA DAL SITO BANCA ITALIA I CAMBI GIORNALIERI
*************************************************************************************************
PARAMETERS V_DATA_DOWNLOAD_DAL,V_DATA_DOWNLOAD_AL

LOCAL _DATA_VALUTA_DA_SCARICARE,_DATA_FINALE, _DATA_VALUTA_PER_TENTATIVO,;
	_CONTA_DATE_SCARICATE,_TENTATIVI_DOWNLOAD_PREGRESSO,_MAX_TENTATIVI_DOWNLOAD_PREGRESSO
  

_MAX_TENTATIVI_DOWNLOAD_PREGRESSO = 10

*** NON CONSIDERO L'ULTIMO CAMBIO VALIDO MA SOLO QUELLO EFFETTIVO DEL GIORNO
*** SE PRESENTE
IF !PUB_ULTCAM
	_MAX_TENTATIVI_DOWNLOAD_PREGRESSO = 1
ENDIF

	
_CONTA_DATE_SCARICATE=0

_DATA_VALUTA_DA_SCARICARE=CTOD(V_DATA_DOWNLOAD_DAL)
_DATA_FINALE=CTOD(V_DATA_DOWNLOAD_AL)

DO WHILE _DATA_VALUTA_DA_SCARICARE<= _DATA_FINALE

	_TENTATIVI_DOWNLOAD_PREGRESSO=1
	_DATA_VALUTA_PER_TENTATIVO=_DATA_VALUTA_DA_SCARICARE
	
	*** CERCO IL CAMBIO DELLA DATA IMPOSTATA MA SE NON LO TROVO
	*** VADO INDIETRO DI UN GIORNO PER UN MASSIMO DI DIECI VOLTE
	*** ATTENZIONE: SE NON E' PREVISTA QUESTA OPZIONE (PUB_ULTCAM =0) => _MAX_TENTATIVI_DOWNLOAD_PREGRESSO =1
	
	DO WHILE _TENTATIVI_DOWNLOAD_PREGRESSO<=_MAX_TENTATIVI_DOWNLOAD_PREGRESSO 

		_STR_DATA=DTOC(_DATA_VALUTA_PER_TENTATIVO)

		V_GIORNO 	= SUBSTR(_STR_DATA,1,2)
		V_MESE 		= SUBSTR(_STR_DATA,4,2)
		V_ANNO 		= SUBSTR(_STR_DATA,7,4)

		IF SCARICA_CAMBI_GIORNALIERI(V_ANNO,V_MESE,V_GIORNO , DTOC(_DATA_VALUTA_DA_SCARICARE))
			_CONTA_DATE_SCARICATE=_CONTA_DATE_SCARICATE+1
			EXIT
		ENDIF
		
		*** SE NON TROVO NESSUN CAMBIO CERCO IL CAMBIO DEL GIORNO PRECEDENTE
		_DATA_VALUTA_PER_TENTATIVO=_DATA_VALUTA_PER_TENTATIVO-1
		_TENTATIVI_DOWNLOAD_PREGRESSO = _TENTATIVI_DOWNLOAD_PREGRESSO+1
	
	ENDDO
	
	*** AGGIORNO LA DATA DA SCARICARE AL GIORNO SUCCESSIVO
	_DATA_VALUTA_DA_SCARICARE=_DATA_VALUTA_DA_SCARICARE+1
	
ENDDO

RETURN _CONTA_DATE_SCARICATE


*************************************************************************************************
PROCEDURE SCARICA_CAMBI_GIORNALIERI       && SCARICA DAL SITO BANCA ITALIA I CAMBI GIORNALIERI
*************************************************************************************************
PARAMETERS V_ANNO,V_MESE,V_GIORNO,V_DATA_VALUTA_DA_AGGIORNARE


*LOCAL loRequest, lcUrl, lcFilename,V_MESSAGGIO_ERRORE_NO_CAMBIO,V_LEN_NO_CAMBIO,V_DATA_AAAAMMGG,V_DATA_CAMBIO,_FLAG_ESITO
LOCAL loRequest, lcUrl, lcFilename,V_MESSAGGIO_ERRORE_NO_CAMBIO,V_LEN_NO_CAMBIO,V_DATA_AAAAMMGG,V_DATA_CAMBIO  && ERASMO - 04/04/2025

_FLAG_ESITO=.F.

V_MESSAGGIO_ERRORE_NO_CAMBIO = "ATTENZIONE! Non ci sono valori di cambio per i dati inseriti"
*V_LEN_NO_CAMBIO = 61
V_LEN_NO_CAMBIO = 95  && ERASMO - 23/11/2017

V_DATA_AAAAMMGG=V_ANNO+V_MESE+V_GIORNO

IF PCOUNT()=3 OR EMPTY(V_DATA_VALUTA_DA_AGGIORNARE)
	V_DATA_CAMBIO = V_ANNO+"/"+V_MESE+"/"+V_GIORNO
ELSE
	V_DATA_CAMBIO = RIBALTA2(V_DATA_VALUTA_DA_AGGIORNARE)
ENDIF

*!*	lcUrl = "http://cambi.bancaditalia.it/cambi/QueryOneDateAllCur?lang=ita&rate=0&initDay="+V_GIORNO+"&initMonth="+V_MESE+"&initYear="+V_ANNO+"&refCur=euro&R1=csv"
*!*	lcFilename = SYS(5)+SYS(2003)+"\CAMBI_"+V_DATA_AAAAMMGG+SYS(2015)+".TXT"

**=> ERASMO - INIZIO 23/11/2017
lcUrl = "https://tassidicambio.bancaditalia.it/terzevalute-wf-web/rest/v1.0/dailyRates?referenceDate="+V_ANNO+"-"+V_MESE+"-"+V_GIORNO+"&currencyIsoCode=EUR"
lcFilename = SYS(5)+SYS(2003)+"\CAMBI_"+V_DATA_AAAAMMGG+SYS(2015)+".CSV"
**=> ERASMO - FINE 23/11/2017

loRequest = Createobject('MsXml2.XmlHttp')
loRequest.Open("GET",lcUrl,.F.)
loRequest.setRequestHeader("Accept","text/csv")  && ERASMO - 23/11/2017
loRequest.Send()


IF LEN(loRequest.ResponseBody)<=V_LEN_NO_CAMBIO 
	WAIT WINDOW V_MESSAGGIO_ERRORE_NO_CAMBIO +" per data "+RIBALTA2(V_DATA_CAMBIO) NOWAIT
	RETURN _FLAG_ESITO
ENDIF

STRTOFILE(loRequest.ResponseBody,lcFilename)

**=> ERASMO - INIZIO 04/04/2025
CREATE CURSOR file_cambio (Paese C(100),Valuta C(10),Codice_ISO C(10),Codice_UIC C(10),Quotazione C(20),Convenzione_cambio C(100), Data_riferimento_CET C(10))
SELECT file_cambio
APPEND FROM &lcFilename TYPE CSV

SELECT file_cambio
DELETE FOR EMPTY(ALLTRIM(Paese)) OR SUBSTR(ALLTRIM(Paese),1,1) == "#"  && RIGHE FILE CSV VUOTE O COMMENTI/DISCLAIMER
GO TOP
IF EOF()
	WAIT WINDOW V_MESSAGGIO_ERRORE_NO_CAMBIO +" per data "+RIBALTA2(V_DATA_CAMBIO) NOWAIT
	RETURN _FLAG_ESITO
ENDIF
**=> ERASMO - FINE 04/04/2025

WAIT WINDOW "Archivio cambio scaricato correttamente per data "+RIBALTA2(V_DATA_CAMBIO) NOWAIT

DO UPDATE_U_VVA_CH WITH lcFilename, V_DATA_CAMBIO 

WAIT WINDOW "Archivio valute aggiornato correttamente per data "+RIBALTA2(V_DATA_CAMBIO) NOWAIT

*_FLAG_ESITO=.T.

DELETE FILE &lcFilename 

RETURN _FLAG_ESITO


*************************************************************************************************
PROCEDURE UPDATE_U_VVA_CH       && AGGIORNA LA TABELLA U_VVA_CH
*************************************************************************************************
PARAMETERS _FILENAME,_DATA_CAMBIO

LOCAL _CONTA_CAMBI_SCARICATI,_V_CONTA  

*** CREA CURSORE DI CONTROLLO PER IL PARAMETRO VALUTE
*!*	cSql = "SELECT CODICE FROM PARA WHERE SUBSTRING(CODICE,1,3)='VVA' "
*!*	IF !ExecCommand(cSql,"_CONTROLLA_PARA")
*!*	   return(.f.)
*!*	ENDIF
*!*	SELECT _CONTROLLA_PARA
*!*	INDEX ON CODICE TAG CODICE
**=> ERASMO - INIZIO 24/09/2014
cSql = "SELECT CODICE, DESCRI, DESIVA FROM PARA WHERE SUBSTRING(CODICE,1,3)='VVA' "
IF !ExecCommand(cSql,"_CONTROLLA_PARA")
   return(.f.)
ENDIF
SELECT _CONTROLLA_PARA
INDEX ON CODICE TAG CODICE
INDEX ON SUBSTR(DESIVA,1,3) TAG C_INTERNAZ
**=> ERASMO - FINE 24/09/2014

*** DEFINIZIONE CURSORE DI APPOGGIO
cSql = "Select * from U_VVA_CH where VVA_DATA='"+_DATA_CAMBIO+"'"
IF !ExecCommand(cSql,"CU_VVA_CH")
   return(.f.)
ENDIF
SELECT CU_VVA_CH
INDEX ON VVA_DATA+VVA_CODVAL  TAG VALUTA


*** ACQUISIZIONE DEI DATI DAL FILE DELLA BANCA ITALIA 
*!*	CREATE CURSOR file_cambio (RIGA C(254))
*!*	SELECT file_cambio 
*!*	APPEND FROM &_FILENAME SDF 
*!*	**=> ERASMO - INIZIO 23/11/2017
*!*	CREATE CURSOR file_cambio (Paese C(100),Valuta C(10),Codice_ISO C(10),Codice_UIC C(10),Quotazione C(20),Convenzione_cambio C(100), Data_riferimento_CET C(10))
*!*	SELECT file_cambio
*!*	APPEND FROM &_FILENAME TYPE CSV
*!*	**=> ERASMO - FINE 23/11/2017

cSql = "Select * from U_VVA_CH where 1=0"
IF !ExecCommand(cSql,"CUR_VVA_CH")
   return(.f.)
ENDIF
SELECT CUR_VVA_CH

SELECT file_cambio 
GO TOP

_CONTA_CAMBI=0

DO WHILE !EOF()

*!*		__STRINGA_DA_SALTARE="Quotazioni"
*!*		IF SUBSTR(RIGA,1,LEN(__STRINGA_DA_SALTARE)) = __STRINGA_DA_SALTARE
*!*			SELECT file_cambio 
*!*			SKIP
*!*			LOOP
*!*		ENDIF

*!*		__STRINGA_DA_SALTARE='""'
*!*		IF SUBSTR(RIGA,1,LEN(__STRINGA_DA_SALTARE)) = __STRINGA_DA_SALTARE
*!*			SELECT file_cambio 
*!*			SKIP
*!*			LOOP
*!*		ENDIF
*!*		
*!*		__STRINGA_DA_SALTARE="Paese,Valuta,Codice ISO,Codice UIC,Quotazione,Convenzione di cambio,Nota"
*!*		IF SUBSTR(RIGA,1,LEN(__STRINGA_DA_SALTARE)) = __STRINGA_DA_SALTARE
*!*			SELECT file_cambio 
*!*			SKIP
*!*			LOOP
*!*		ENDIF
*!*		
*!*		_CODSOC=PUB_CODSOC
*!*		_NOMVAL=SUBSTR(RIGA, AT(",",RIGA,1)+1,AT(",",RIGA,2)-AT(",",RIGA,1)-1)
*!*		_CODVAL=SUBSTR(RIGA, AT(",",RIGA,2)+1,AT(",",RIGA,3)-AT(",",RIGA,2)-1)
*!*		_DATA  =_DATA_CAMBIO
*!*		_CHANGE=1/VAL(STRTRAN(SUBSTR(RIGA, AT(",",RIGA,4)+1,AT(",",RIGA,5)-AT(",",RIGA,4)-1),".",","))
	
*!*		**=> ERASMO - INIZIO 08/02/2018
*!*		IF Quotazione = "N.D." OR EMPTY(Quotazione) OR VAL(STRTRAN(Quotazione,".",",")) <=0
*!*			WAIT WINDOW "VALUTA "+ALLTRIM(_CODVAL)+" ("+ALLTRIM(_NOMVAL)+") NON DISPONIBILE PER IL GIORNO " + RIBALTA2(Data_riferimento_CET) TIMEOUT 3
*!*			SELECT file_cambio 
*!*			SKIP
*!*			LOOP
*!*		ENDIF
*!*		**=> ERASMO - FINE 08/02/2018

*!*		**=> ERASMO - INIZIO 02/04/2025
*!*		SELECT file_cambio
*!*		IF EMPTY(ALLTRIM(Paese)) OR SUBSTR(ALLTRIM(Paese),1,1) == "#"  && SKIP RIGHE FILE CSV VUOTE O COMMENTI DISCLAIMER
*!*			SKIP
*!*			LOOP
*!*		ENDIF
*!*		**=> ERASMO - FINE 02/04/2025
	
	**=> ERASMO - INIZIO 23/11/2017
	_CODSOC=PUB_CODSOC
	_NOMVAL=ALLTRIM(Valuta)
	_CODVAL=ALLTRIM(Codice_ISO)
	_DATA  =_DATA_CAMBIO
	_CHANGE=1/VAL(STRTRAN(Quotazione,".",","))
	**=> ERASMO - FINE 23/11/2017
	
	**=> ERASMO - INIZIO 01/04/2025
	*** SPOSTATO PORZIONE DI CODICE SOTTO LA VALORIZZAZIONE DI "_CODVAL" E "_NOMVAL"
	IF Quotazione = "N.D." OR EMPTY(Quotazione) OR VAL(STRTRAN(Quotazione,".",",")) <=0
		WAIT WINDOW "VALUTA "+ALLTRIM(_CODVAL)+" ("+ALLTRIM(_NOMVAL)+") NON DISPONIBILE PER IL GIORNO " + RIBALTA2(Data_riferimento_CET) TIMEOUT 3
		SELECT file_cambio 
		SKIP
		LOOP
	ENDIF
	**=> ERASMO - FINE 01/04/2025
		
	*** CONTROLLO FORMATO VALUTA
	IF LEN(ALLTRIM(_CODVAL))<>3
		WAIT WINDOW "FORMATO VALUTA "+ALLTRIM(_CODVAL)+" ("+ALLTRIM(_NOMVAL)+") NON VALIDO"	&&NOWAIT
		SELECT file_cambio 
		SKIP
		LOOP
	ENDIF
	
	**=> ERASMO - INIZIO 24/09/2014
	*** CERCO CORRISPONDENZA CON CODICE VALUTA INTERNAZIONALE (SE CODIFICATO NEL CAMPO Tipologia = 'PARA.DESIVA')
	_AGGIORNA_CODVAL_AQUARIUS = .F.
	_CODVAL_AQUARIUS = ""
	_NOMVAL_AQUARIUS = ""
	SELECT _CONTROLLA_PARA
	SET ORDER TO C_INTERNAZ
	SEEK ALLTRIM(_CODVAL)
	IF FOUND()
		_CODVAL_AQUARIUS = SUBSTR(CODICE,4,3)
		_NOMVAL_AQUARIUS = ALLTRIM(DESCRI)
		IF !EMPTY(_CODVAL_AQUARIUS)
			_AGGIORNA_CODVAL_AQUARIUS = .T.
		ENDIF
	ENDIF
	**=> ERASMO - FINE 24/09/2014
	
	AGGIUNGI_PARAMETRO_VALUTA_SE_NON_PRESENTE(_CODVAL,_NOMVAL)
		
	SELECT CUR_VVA_CH
	APPEND BLANK
	
	REPLACE VVA_CODSOC WITH _CODSOC
	REPLACE VVA_NOMVAL WITH _NOMVAL
	REPLACE VVA_CODVAL WITH _CODVAL
	REPLACE VVA_DATA   WITH _DATA  
	REPLACE VVA_CHANGE WITH _CHANGE
	
	_CONTA_CAMBI=_CONTA_CAMBI+1
	
	**=> ERASMO - INIZIO 24/09/2014
	IF _AGGIORNA_CODVAL_AQUARIUS
		SELECT CUR_VVA_CH
		APPEND BLANK
		REPLACE VVA_CODSOC WITH _CODSOC
		REPLACE VVA_NOMVAL WITH _NOMVAL_AQUARIUS
		REPLACE VVA_CODVAL WITH _CODVAL_AQUARIUS
		REPLACE VVA_DATA   WITH _DATA  
		REPLACE VVA_CHANGE WITH _CHANGE		
		_CONTA_CAMBI=_CONTA_CAMBI+1
	ENDIF
	**=> ERASMO - FINE 24/09/2014
	
	SELECT file_cambio 
	SKIP

ENDDO

*** AGGIUNGO IL CAMBIO DELLA VALUTA EUR = 1,00 
IF _CONTA_CAMBI>0
	SELECT CUR_VVA_CH
	APPEND BLANK
	
	REPLACE VVA_CODSOC WITH _CODSOC
	REPLACE VVA_NOMVAL WITH "EURO"
	REPLACE VVA_CODVAL WITH "EUR"
	REPLACE VVA_DATA   WITH _DATA  
	REPLACE VVA_CHANGE WITH 1
ENDIF



_V_CONTA = 0
_V_CONTA_SKIP = 0  && ERASMO - 04/04/2025

*** LOOP DI SCRITTURA DATI
SELECT CUR_VVA_CH
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO
   
   WAIT WINDOWS "Conversione Riga dell'Anagrafica valute " + ALLTRIM(STR(RECNO(),6,0)) + " di " + ALLTRIM(STR(RECCOUNT(),6,0)) + ;
                " in corso...  -  Prego Attendere" NOWAIT   

   
   SELECT CU_VVA_CH
   SET ORDER TO VALUTA
   SEEK M.VVA_DATA+M.VVA_CODVAL 
   IF FOUND()
	   _V_CONTA_SKIP = _V_CONTA_SKIP + 1  && ERASMO - 04/04/2025
	   SELECT CUR_VVA_CH
	   SKIP +1   
	   LOOP
   ENDIF
   
   APPEND BLANK
   DO U_VVA_CH
   
   _V_CONTA  = _V_CONTA + 1
   
   SELECT CUR_VVA_CH
   SKIP +1

ENDDO


*** SCRITTURA DEI DATI SUL DB SQL
IF _V_CONTA > 0

	*** CANCELLAZIONE DEI RECORD DELLA TABELLA U_VVA_CH SQL
	WAIT WINDOWS "Cancellazione vecchia Anagrafica valute...  -  Prego Attendere" NOWAIT
	cSql = "delete from U_VVA_CH where VVA_DATA='"+_DATA_CAMBIO+"'"
	IF !ExecCommand(cSql,"CANC_VVA_CH")
	   return(.f.)
	ENDIF

	WAIT WINDOWS "Scrittura archivio dell'Anagrafica valute sul DataBase In Corso... -- Prego Attendere --" nowait  
	IF !ExecRW('','u_vva_ch','I','','CU_VVA_CH')
		return(.f.)
	ENDIF
	
ENDIF

**=> ERASMO - INIZIO 04/04/2025
IF _V_CONTA + _V_CONTA_SKIP > 0
	_FLAG_ESITO = .T.
ENDIF
**=> ERASMO - FINE 04/04/2025

RETURN


*************************************************************************************************
PROCEDURE AGGIUNGI_PARAMETRO_VALUTA_SE_NON_PRESENTE 	&& AGGIORNA LA TABELLA PARA
*************************************************************************************************
PARAMETERS _CODVAL,_NOMVAL

LOCAL _SALVA_SELECT

_SALVA_SELECT=STR(SELECT())

SELECT _CONTROLLA_PARA
SET ORDER TO CODICE
SEEK 'VVA'+ALLTRIM(_CODVAL)

IF FOUND()
	SELECT &_SALVA_SELECT
	RETURN
ENDIF

cSql = "INSERT INTO PARA (CODICE,DESCRI) VALUES ('VVA"+_CODVAL+"','"+UPPER(ALLTRIM(_NOMVAL))+"') "
IF !ExecCommand(cSql,"_TEMP_PARA")
   return(.f.)
ENDIF


SELECT &_SALVA_SELECT
RETURN

