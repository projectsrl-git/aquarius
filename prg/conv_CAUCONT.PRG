GO TOP

DO WHILE .T.

   IF EOF()
      DO VERIFICA_CAUSALE
      EXIT
   ENDIF

   IF SUBSTR(TRA_RECORD,1,11) <> SPACE(11)
      IF SUBSTR(TRA_RECORD,5,7) = SPACE(7)
         IF V_PRIMO
            V_PRIMO  = .F.
            M.CAU_CODICE = ALLTRIM(SUBSTR(TRA_RECORD,1,4))
            M.PAR_CODICE = ALLTRIM(SUBSTR(TRA_RECORD,1,1)) + ALLTRIM(SUBSTR(TRA_RECORD,3,2)) 
            M.CAU_DESCRI = ALLTRIM(SUBSTR(TRA_RECORD,12,50))
         ELSE
            DO VERIFICA_CAUSALE
            SELECT TRANSITO
            M.CAU_CODICE = ALLTRIM(SUBSTR(TRA_RECORD,1,4))
            M.PAR_CODICE = ALLTRIM(SUBSTR(TRA_RECORD,1,1)) + ALLTRIM(SUBSTR(TRA_RECORD,3,2)) 
            M.CAU_DESCRI = ALLTRIM(SUBSTR(TRA_RECORD,12,50))
         ENDIF
         SKIP +1
      ENDIF
   ENDIF

