WAIT WINDOWS "Elaborazione in corso, attendere prego ......" nowait

_cTpcoList = ""
IF FLAG_FATCL = 1
	_cTpcoList = IIF(EMPTY(_cTpcoList),"",",") + "'C'"
ENDIF
IF FLAG_FATFO = 1
	_cTpcoList = IIF(EMPTY(_cTpcoList),"",",") + "'F'"
ENDIF

DATA_DA =  RIBALTA2(DATADAL)
DATA_A  =  RIBALTA2(DATAAL)

x_soci = "mov_soc = '" + PUB_CODSOC + "'"
*x_anno = "mov_anno = '" + ANNODAL + "'"
x_anno = "mov_anno = mov_anno"  && ERASMO - 04/03/2019
x_data = "mov_dtdoc between '" + DATA_DA + "' and '" + DATA_A + "'"
**=> ERASMO - INIZIO 26/03/2025
IF FLAG_FATFO = 1 AND FLAG_FATTURATO_FORNITORI_PER_DATA_COMPETENZA
	DO CASE
		CASE V_MESE = "01"  && GENNAIO
			_DATA_DA_MESE_SUCC = SUBSTR(DATA_A,1,4) + "/" + PADL(ALLTRIM(STR(VAL(SUBSTR(DATA_A,6,4))+1,2,0)),2,'0') + "/01"
			_DATA_A_MESE_SUCC = SUBSTR(DATA_A,1,4) + "/" + PADL(ALLTRIM(STR(VAL(SUBSTR(DATA_A,6,4))+1,2,0)),2,'0') + "/15"
			x_data = "((mov_dtreg between '" + DATA_DA + "' and '" + DATA_A + "') or ((mov_dtreg between '" + _DATA_DA_MESE_SUCC + "' and '" + _DATA_A_MESE_SUCC + "') and (mov_dtdoc <= '" + DATA_A + "')))"
			
		CASE V_MESE = "12"  && DICEMBRE
			_DATA_A_MESE_PREC = RIBALTA2(DATA_FINE_MESE_PRECEDENTE(RIBALTA2(DATA_A)))
			x_data = "((mov_dtreg between '" + DATA_DA + "' and '" + DATA_A + "') and not((mov_dtreg between '" + DATA_DA + "' and '" + SUBSTR(DATA_DA,1,8) + "15') and (mov_dtdoc <= '" + _DATA_A_MESE_PREC + "')))"
		
		OTHERWISE  && TUTTI GLI ALTRI MESI DELL'ANNO
			_DATA_A_MESE_PREC = RIBALTA2(DATA_FINE_MESE_PRECEDENTE(RIBALTA2(DATA_A)))
			_DATA_DA_MESE_SUCC = SUBSTR(DATA_A,1,4) + "/" + PADL(ALLTRIM(STR(VAL(SUBSTR(DATA_A,6,4))+1,2,0)),2,'0') + "/01"
			_DATA_A_MESE_SUCC = SUBSTR(DATA_A,1,4) + "/" + PADL(ALLTRIM(STR(VAL(SUBSTR(DATA_A,6,4))+1,2,0)),2,'0') + "/15"
			x_data = "(((mov_dtreg between '" + DATA_DA + "' and '" + DATA_A + "') and not((mov_dtreg between '" + DATA_DA + "' and '" + SUBSTR(DATA_DA,1,8) + "15') and (mov_dtdoc <= '" + _DATA_A_MESE_PREC + "'))) or " + ;
				"((mov_dtreg between '" + _DATA_DA_MESE_SUCC + "' and '" + _DATA_A_MESE_SUCC + "') and (mov_dtdoc <= '" + DATA_A + "')))"
	ENDCASE
ENDIF
**=> ERASMO - FINE 26/03/2025
x_tpco = "con_tipoco in (&_cTpcoList)"
x_topf = "SUBSTRING(libera,2,1) = 'S'"
x_cond = x_soci + " and " + x_anno + " and " + x_data + " and " + x_tpco + " and " + x_topf 
IF !EMPTY(CONTO_FORNITORE)
	x_forn = "mov_conto = '" + CONTO_FORNITORE + "'"
	x_cond = x_cond + " and " + x_forn 
ENDIF
cSql   = "SELECT mov_cont.*, conti.con_descr, conti.con_tipoco, COALESCE(para.libera,'') AS libera FROM mov_cont " + ;
         "LEFT OUTER JOIN conti on conti.con_soc = &PUB_CODSOC and conti.con_anno = mov_cont.mov_anno and conti.con_conto = mov_cont.mov_conto " + ;
         "LEFT OUTER JOIN para on para.codice = 'TOP'+mov_cont.mov_top " + ;
         "WHERE " + x_cond + ;
         "order by mov_soc,mov_anno,mov_dtdoc,mov_numpro"
IF !ExecCommand(cSql,"MOV_CONT")
   return(.f.)
ENDIF
SELECT MOV_CONT
GO TOP
CTRELAB = 0

DO WHILE .T.       && CARICA I RECORD PRINCIPALI DI FATTURAZIONE
   
   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
  
   WAIT WINDOWS "Elaborazione movimenti contabili (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 

   SELECT MOV_CONT


   XX_CONTO = MOV_CONTO
   XX_ANNO  = SUBSTR(MOV_DTDOC,1,4)  	&& ERASMO 04/03/2019
   XX_NUMPRO= MOV_NUMPRO				&& SERGIO 07/07/2022
   XX_IMP   = MOV_IMP					&& SERGIO 07/07/2022
   XX_TMOV  = MOV_TMOV					&& SERGIO 07/07/2022
   XX_NREGI = MOV_NREGIS  				
   XX_TOP   = MOV_TOP
   XX_AAMM  = XX_ANNO + SUBSTR(MOV_DTDOC,6,2)
   XX_NPART = VAL(MOV_NDOC)
   XX_NPROT = VAL(MOV_NPROT) 
   XX_DTDOC = MOV_DTDOC
   
   XX_RAGSOC = CON_DESCR
   XX_TIPOCO = CON_TIPOCO
   
   FAT    = SUBSTR(LIBERA,2,1)
   NOTAC  = SUBSTR(LIBERA,11,1)


   SELECT MOV_CONT
   SCATTER MEMVAR MEMO	    && Salva i vecchi valori

   IF F_VALUTA = 1
      M.MOV_IMP = TLIRE(M.MOV_VALUTA,M.MOV_IMP,RIBALTA2(M.MOV_DTDOC))
   ENDIF
   IF F_VALUTA = 2
      M.MOV_IMP = TEURO(M.MOV_VALUTA,M.MOV_IMP,RIBALTA2(M.MOV_DTDOC))
   ENDIF
    
   IF NOTAC = "S"		&& NOTE ACCREDITO
      M.MOV_IMP = M.MOV_IMP * -1
   ENDIF
   
   **=> ERASMO - INIZIO 04/03/2019
   IF ALLTRIM(M.MOV_VALUTA) = ALLTRIM(PUB_VALRIF)
   ELSE
      M.MOV_IMP = CAMBIO(M.MOV_VALUTA,M.MOV_IMP,M.MOV_CAMBIO)
   ENDIF
   **=> ERASMO - FINE 04/03/2019

   IF XX_TIPOCO = "C" 	&& ########################################## GESTIONE CLIENTI #############################################
      _ARCHI  = "PART_CLI"
	  _COCLFO = XX_CONTO
	  _NPART  = XX_NPART
      _TIPODO ="PAG"
      _ANNO   = XX_ANNO
      _DTDOC  = XX_DTDOC
      TOTINPA = 0
      
	  _TIMPOSTA=CERCA_MOVIMENTI_IVA(XX_ANNO,XX_NUMPRO)			&& 07/07/2022 SERGIO RICALCOLA IMPOSTA PER OTTENERE L'IMPONIBILE
	  
	  IF XX_TMOV  = "D"	&& TRATTASI DI FATTURA
	  	_TIMPONIBILE_ = XX_IMP - _TIMPOSTA
	  	_TIMPOSTA_    = _TIMPOSTA 
	  ELSE				&& TRATTASI DI NOTA DI ACCREDITO
	  	_TIMPONIBILE_ = (XX_IMP - _TIMPOSTA) * -1 	
	  	_TIMPOSTA_    = _TIMPOSTA * -1
	  ENDIF
      
      
      SELECT FAT_CLI
	  APPEND BLANK
	  GATHER MEMVAR MEMO		&& Salva le modifiche
	  REPLACE MOV_AAMM			WITH XX_AAMM
	  REPLACE MOV_RAGSOC		WITH XX_RAGSOC
  	  REPLACE MOV_INCPAG		WITH TOTINPA
  	  
  	  ** 07/07/2022 SERGIO INIZIO: RECUPERA IMPONIBILE
   	  REPLACE MOV_IMPOSTA		WITH _TIMPOSTA_    
  	  REPLACE MOV_IMPONIBILE	WITH _TIMPONIBILE_ 
  	  ** 07/07/2022 SERGIO FINE: RECUPERA IMPONIBILE    	  
  	  

  	  ** 30/06/2023 SERGIO INIZIO
  	  *=CREA_MOVIMENTI_IVA(XX_ANNO,XX_NUMPRO,'C')
  	  ** 30/06/2023 SERGIO FINE  
  	    	  
  	  
      *=> GESTIONE RIEPILOGO X CLIENTE
      SELECT RIE_CLI
	  SET ORDER TO RAGSOC 
      SEEK XX_RAGSOC + XX_AAMM 
      IF FOUND()
      ELSE
    	 APPEND BLANK
		 GATHER MEMVAR MEMO		&& Salva le modifiche
    	 REPLACE MOV_AAMM		WITH XX_AAMM
	     REPLACE MOV_RAGSOC	WITH XX_RAGSOC
         REPLACE MOV_IMP       WITH 0
         REPLACE MOV_INCPAG    WITH 0
	  ENDIF
      REPLACE MOV_IMP           WITH MOV_IMP + M.MOV_IMP
  	  REPLACE MOV_INCPAG		WITH MOV_INCPAG + TOTINPA
      *=> GESTIONE RIEPILOGO X CLIENTE ORIZZONTALE
      SELECT RIE_CLIO
	  SET ORDER TO RAGSOC 
      SEEK XX_RAGSOC  
      IF FOUND()
      ELSE
         APPEND BLANK
    	 REPLACE MOV_ANNO		WITH SUBSTR(XX_AAMM,1,4)
	     REPLACE MOV_RAGSOC	WITH XX_RAGSOC
         REPLACE MOV_IMP01     WITH 0
         REPLACE MOV_INPA01    WITH 0
         REPLACE MOV_IMP02     WITH 0
         REPLACE MOV_INPA02    WITH 0
         REPLACE MOV_IMP03     WITH 0
         REPLACE MOV_INPA03    WITH 0
         REPLACE MOV_IMP04     WITH 0
         REPLACE MOV_INPA04    WITH 0
         REPLACE MOV_IMP05     WITH 0
         REPLACE MOV_INPA05    WITH 0
         REPLACE MOV_IMP06     WITH 0
         REPLACE MOV_INPA06    WITH 0
         REPLACE MOV_IMP07     WITH 0
         REPLACE MOV_INPA07    WITH 0
         REPLACE MOV_IMP08     WITH 0
         REPLACE MOV_INPA08    WITH 0
         REPLACE MOV_IMP09     WITH 0
         REPLACE MOV_INPA09    WITH 0
         REPLACE MOV_IMP10     WITH 0
         REPLACE MOV_INPA10    WITH 0
         REPLACE MOV_IMP11     WITH 0
         REPLACE MOV_INPA11    WITH 0
         REPLACE MOV_IMP12     WITH 0
         REPLACE MOV_INPA12    WITH 0
	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 1
         REPLACE MOV_IMP01      WITH MOV_IMP01 + M.MOV_IMP
  	     REPLACE MOV_INPA01		WITH MOV_INPA01 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 2
         REPLACE MOV_IMP02      WITH MOV_IMP02 + M.MOV_IMP
  	     REPLACE MOV_INPA02		WITH MOV_INPA02 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 3
         REPLACE MOV_IMP03      WITH MOV_IMP03 + M.MOV_IMP
  	     REPLACE MOV_INPA03		WITH MOV_INPA03 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 4
         REPLACE MOV_IMP04      WITH MOV_IMP04 + M.MOV_IMP
  	     REPLACE MOV_INPA04		WITH MOV_INPA04 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 5
         REPLACE MOV_IMP05      WITH MOV_IMP05 + M.MOV_IMP
  	     REPLACE MOV_INPA05		WITH MOV_INPA05 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 6
         REPLACE MOV_IMP06      WITH MOV_IMP06 + M.MOV_IMP
  	     REPLACE MOV_INPA06		WITH MOV_INPA06 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 7
         REPLACE MOV_IMP07      WITH MOV_IMP07 + M.MOV_IMP
  	     REPLACE MOV_INPA07		WITH MOV_INPA07 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 8
         REPLACE MOV_IMP08      WITH MOV_IMP08 + M.MOV_IMP
  	     REPLACE MOV_INPA08		WITH MOV_INPA08 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 9
         REPLACE MOV_IMP09      WITH MOV_IMP09 + M.MOV_IMP
  	     REPLACE MOV_INPA09		WITH MOV_INPA09 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 10
         REPLACE MOV_IMP10      WITH MOV_IMP10 + M.MOV_IMP
  	     REPLACE MOV_INPA10		WITH MOV_INPA10 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 11
         REPLACE MOV_IMP11      WITH MOV_IMP11 + M.MOV_IMP
  	     REPLACE MOV_INPA11		WITH MOV_INPA11 + TOTINPA
  	  ENDIF
	  IF VAL(SUBSTR(XX_AAMM,5,2)) = 12
         REPLACE MOV_IMP12      WITH MOV_IMP12 + M.MOV_IMP
  	     REPLACE MOV_INPA12		WITH MOV_INPA12 + TOTINPA
  	  ENDIF
      REPLACE MOV_IMP13         WITH MOV_IMP01 + MOV_IMP02 + MOV_IMP03 + MOV_IMP04 + MOV_IMP05 + MOV_IMP06 + ;
                                     MOV_IMP07 + MOV_IMP08 + MOV_IMP09 + MOV_IMP10 + MOV_IMP11 + MOV_IMP12
      REPLACE MOV_INPA13	   	 WITH MOV_INPA01 + MOV_INPA02 + MOV_INPA03 + MOV_INPA04 + MOV_INPA05 + MOV_INPA06 + ;
                                     MOV_INPA07 + MOV_INPA08 + MOV_INPA09 + MOV_INPA10 + MOV_INPA11 + MOV_INPA12 
      _OLD_IMP = M.MOV_IMP
      _IVA_IMP = 0
      =CREA_MOVIMENTI_IVA(XX_ANNO,XX_NUMPRO,'C')  && ERASMO - 07/03/2025
   ENDIF 

   IF XX_TIPOCO = "F"   && ########################################## GESTIONE FORNITORI #########################################################
      _ARCHI  = "PART_FOR"
	  _COCLFO = XX_CONTO
	  _NPART  = XX_NPROT
      _TIPODO ="PAG"
      _ANNO   = XX_ANNO
      _DTDOC  = XX_DTDOC
      
      TOTINPA = 0
      
	  _TIMPOSTA=CERCA_MOVIMENTI_IVA(XX_ANNO,XX_NUMPRO)			&& 07/07/2022 SERGIO RICALCOLA IMPOSTA PER OTTENERE L'IMPONIBILE
	  
	  IF XX_TMOV  = "A"	&& TRATTASI DI FATTURA
	  	_TIMPONIBILE_ = XX_IMP - _TIMPOSTA
	  	_TIMPOSTA_    = _TIMPOSTA 
	  ELSE				&& TRATTASI DI NOTA DI ACCREDITO
	  	_TIMPONIBILE_ = (XX_IMP - _TIMPOSTA) * -1 	
	  	_TIMPOSTA_    = _TIMPOSTA * -1
	  ENDIF
	  
	  SELECT FAT_FOR
	  APPEND BLANK
	  GATHER MEMVAR MEMO		&& Salva le modifiche
	  REPLACE MOV_AAMM			WITH XX_AAMM
	  REPLACE MOV_RAGSOC		WITH XX_RAGSOC
  	  REPLACE MOV_INCPAG		WITH TOTINPA
  	  
  	  ** 07/07/2022 SERGIO INIZIO: RECUPERA IMPONIBILE
   	  REPLACE MOV_IMPOSTA		WITH _TIMPOSTA_    
  	  REPLACE MOV_IMPONIBILE	WITH _TIMPONIBILE_ 
  	  ** 07/07/2022 SERGIO FINE: RECUPERA IMPONIBILE
  	  
  	  
  	  ** 30/06/2023 SERGIO INIZIO
  	  *=CREA_MOVIMENTI_IVA(XX_ANNO,XX_NUMPRO,'F')
  	  ** 30/06/2023 SERGIO FINE  	  
 
    	  
      *=> GESTIONE RIEPILOGO X FORNITORE
      SELECT RIE_FOR
	  SET ORDER TO RAGSOC 
      SEEK XX_RAGSOC + XX_AAMM 
      IF FOUND()
      ELSE
         APPEND BLANK
	     GATHER MEMVAR MEMO		&& Salva le modifiche
         REPLACE MOV_AAMM		WITH XX_AAMM
	     REPLACE MOV_RAGSOC	WITH XX_RAGSOC
         REPLACE MOV_IMP       WITH 0
         REPLACE MOV_INCPAG    WITH 0
	  ENDIF
      REPLACE MOV_IMP           WITH MOV_IMP + M.MOV_IMP
  	  REPLACE MOV_INCPAG		WITH MOV_INCPAG + TOTINPA
      *=> GESTIONE RIEPILOGO X CLIENTE ORIZZONTALE
 	  SELECT RIE_FORO
	  SET ORDER TO RAGSOC 
      SEEK XX_RAGSOC  
      IF FOUND()
      ELSE
    	 APPEND BLANK
    	 REPLACE MOV_ANNO		WITH SUBSTR(XX_AAMM,1,4)
	     REPLACE MOV_RAGSOC	WITH XX_RAGSOC
         REPLACE MOV_IMP01     WITH 0
         REPLACE MOV_INPA01    WITH 0
         REPLACE MOV_IMP02     WITH 0
         REPLACE MOV_INPA02    WITH 0
         REPLACE MOV_IMP03     WITH 0
         REPLACE MOV_INPA03    WITH 0
         REPLACE MOV_IMP04     WITH 0
         REPLACE MOV_INPA04    WITH 0
         REPLACE MOV_IMP05     WITH 0
         REPLACE MOV_INPA05    WITH 0
         REPLACE MOV_IMP06     WITH 0
