INDEX ON MOV_IVA + MOV_CONTO 		 					TAG IVACON

CREATE CURSOR FAT_FOR_IVA FROM ARRAY TRANSIVC
SELECT FAT_FOR_IVA 
INDEX ON MOV_AAMM + MOV_RAGSOC + STR(VAL(MOV_NDOC)) 	TAG RAGSOC 
INDEX ON MOV_AAMM + STR(MOV_IMP)		 				TAG TOTFAT 
INDEX ON MOV_AAMM + STR(MOV_INCPAG)	 					TAG TOTINPA 
INDEX ON MOV_IVA + MOV_CONTO 		 					TAG IVACON
** 30/06/2023 SERGIO FINE


*==> CURSORI PER RIEPILOGHI IN FORMATO ORIZZONTALE

CREATE CURSOR RIE_CLIO;
       (MOV_RAGSOC C(40),  MOV_ANNO C(04),     MOV_IMP01 N(17,3), MOV_INPA01 N(17,3), ;
        MOV_IMP02 N(17,3), MOV_INPA02 N(17,3), MOV_IMP03 N(17,3), MOV_INPA03 N(17,3), ;
        MOV_IMP04 N(17,3), MOV_INPA04 N(17,3), MOV_IMP05 N(17,3), MOV_INPA05 N(17,3), ;
        MOV_IMP06 N(17,3), MOV_INPA06 N(17,3), MOV_IMP07 N(17,3), MOV_INPA07 N(17,3), ;
        MOV_IMP08 N(17,3), MOV_INPA08 N(17,3), MOV_IMP09 N(17,3), MOV_INPA09 N(17,3), ;
        MOV_IMP10 N(17,3), MOV_INPA10 N(17,3), MOV_IMP11 N(17,3), MOV_INPA11 N(17,3), ;
        MOV_IMP12 N(17,3), MOV_INPA12 N(17,3), MOV_IMP13 N(17,3), MOV_INPA13 N(17,3))
INDEX ON MOV_IMP13 	desc				 				TAG IMP13  
INDEX ON MOV_RAGSOC 						 			TAG RAGSOC 

CREATE CURSOR RIE_FORO;
       (MOV_RAGSOC C(40),  MOV_ANNO C(04),     MOV_IMP01 N(17,3), MOV_INPA01 N(17,3), ;
        MOV_IMP02 N(17,3), MOV_INPA02 N(17,3), MOV_IMP03 N(17,3), MOV_INPA03 N(17,3), ;
        MOV_IMP04 N(17,3), MOV_INPA04 N(17,3), MOV_IMP05 N(17,3), MOV_INPA05 N(17,3), ;
        MOV_IMP06 N(17,3), MOV_INPA06 N(17,3), MOV_IMP07 N(17,3), MOV_INPA07 N(17,3), ;
        MOV_IMP08 N(17,3), MOV_INPA08 N(17,3), MOV_IMP09 N(17,3), MOV_INPA09 N(17,3), ;
        MOV_IMP10 N(17,3), MOV_INPA10 N(17,3), MOV_IMP11 N(17,3), MOV_INPA11 N(17,3), ;
        MOV_IMP12 N(17,3), MOV_INPA12 N(17,3), MOV_IMP13 N(17,3), MOV_INPA13 N(17,3))
INDEX ON MOV_IMP13 	desc				 				TAG IMP13  
INDEX ON MOV_RAGSOC 						 			TAG RAGSOC 

