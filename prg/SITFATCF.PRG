IF !ExecCommand("select CAST(0 AS NUMERIC(17,3)) AS MOV_IMPONIBILE,CAST(0 AS NUMERIC(17,3)) AS MOV_IMPOSTA,'   ' AS MOV_IVA,CAST(0 AS NUMERIC(17,3)) AS MOV_INCPAG, CAST('' AS VARCHAR(6)) AS MOV_AAMM, CAST('' AS VARCHAR(40)) AS MOV_RAGSOC, * from mov_cont where 0=1","mov_cont")  && ERASMO - 07/10/2013
   return(.f.)
