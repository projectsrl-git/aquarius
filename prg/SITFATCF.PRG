SELECT MOV_CONT
HH=AFIELDS(TRANSIVC)
CREATE CURSOR FAT_CLI FROM ARRAY TRANSIVC

SELECT FAT_CLI
INDEX ON MOV_AAMM + MOV_RAGSOC + STR(VAL(MOV_NDOC)) 	TAG RAGSOC 
INDEX ON MOV_AAMM + STR(MOV_IMP)		 				TAG TOTFAT 
INDEX ON MOV_AAMM + STR(MOV_INCPAG)	 					TAG TOTINPA 

CREATE CURSOR FAT_FOR FROM ARRAY TRANSIVC
SELECT FAT_FOR
INDEX ON MOV_AAMM + MOV_RAGSOC + STR(VAL(MOV_NDOC)) 	TAG RAGSOC 
INDEX ON MOV_AAMM + STR(MOV_IMP)		 				TAG TOTFAT 
INDEX ON MOV_AAMM + STR(MOV_INCPAG)	 					TAG TOTINPA 

*==> CURSORI PER RIEPILOGHI IN FORMATO VERTICALE

CREATE CURSOR RIE_CLI FROM ARRAY TRANSIVC
SELECT RIE_CLI
INDEX ON MOV_RAGSOC + MOV_AAMM						 	TAG RAGSOC 
INDEX ON MOV_RAGSOC + MOV_AAMM + STR(MOV_IMP)			TAG TOTFAT 
INDEX ON MOV_RAGSOC + MOV_AAMM + STR(MOV_INCPAG)		TAG TOTINPA 

CREATE CURSOR RIE_FOR FROM ARRAY TRANSIVC
SELECT RIE_FOR
INDEX ON MOV_RAGSOC + MOV_AAMM						 	TAG RAGSOC 
INDEX ON MOV_RAGSOC + MOV_AAMM + STR(MOV_IMP)			TAG TOTFAT 
INDEX ON MOV_RAGSOC + MOV_AAMM + STR(MOV_INCPAG)		TAG TOTINPA 

** 30/06/2023 SERGIO INIZIO
CREATE CURSOR FAT_CLI_IVA FROM ARRAY TRANSIVC
SELECT FAT_CLI_IVA 
INDEX ON MOV_AAMM + MOV_RAGSOC + STR(VAL(MOV_NDOC)) 	TAG RAGSOC 
INDEX ON MOV_AAMM + STR(MOV_IMP)		 				TAG TOTFAT 
