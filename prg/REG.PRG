* TASTO F7 REGISTRA INSERIMENTO / VARIAZIONE

IF ALLTRIM(PUB_PRG)=""
  ON KEY LABEL F2 ZTB.PRIMO.CLICK()
  ON KEY LABEL F3 ZTB.PRECEDENTE.CLICK()
  ON KEY LABEL F4 ZTB.SUCCESSIVO.CLICK()
  ON KEY LABEL F5 ZTB.ULTIMO.CLICK()
  ON KEY LABEL F6 DO NEW
  ON KEY LABEL F7 DO REG
  ON KEY LABEL F8 ZTB.ELIMINA.CLICK()
  ON KEY LABEL F9 DO NULLO
  ON KEY LABEL F10 ZTB.TERMINA.CLICK()
  ZTB.REGISTRA.CLICK()
ELSE
  ON KEY LABEL F2 ZTB.PRIMO.CLICK()
  ON KEY LABEL F3 ZTB.PRECEDENTE.CLICK()
  ON KEY LABEL F4 ZTB.SUCCESSIVO.CLICK()
  ON KEY LABEL F5 ZTB.ULTIMO.CLICK()
  ON KEY LABEL F6 DO NEW
  ON KEY LABEL F7 DO REG
  ON KEY LABEL F8 ZTB.ELIMINA.CLICK()
  ON KEY LABEL F9 DO NULLO
  ON KEY LABEL F10 ZTB.TERMINA.CLICK()
  IF SUBSTR(&PUB_PRG,1,1) = "="
    _CA=SUBSTR(&PUB_PRG,2,(LEN(&PUB_PRG)-1)
    ZTB.FORMCORRENTE.&_CA
  ELSE
    DO &PUB_PRG
  ENDIF  
  ZTB.PULISCI()
ENDIF


