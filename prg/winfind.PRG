#REGION 1
PROCEDURE APRIDBF
****************************************************************
PARAMETERS V_NOMEDBF
*IF !FILE(V_NOMEDBF)
*   WAIT WINDOW "PORCO CANE NON TROVO FILE"
*   RETURN
*ENDIF
V_NOMEDBF=SUBSTR(V_NOMEDBF,1,AT(".",V_NOMEDBF)-1)

IF !USED(V_NOMEDBF)
   USE &V_NOMEDBF IN 0 AGAIN
ENDIF
SELECT &V_NOMEDBF
SET FILTER TO
SET ORDER TO
GO TOP
V_SELECT=SELECT()

STORE SPACE(30) TO A_DESCAM
STORE SPACE(30) TO A_DESORD
STORE SPACE(80) TO A_DESCON
P_DESCAM=0                            && PUNTATORE DESCRIZIONI
P_DESORD=0                            && PUNTATORE ORDINAMENTO
P_DESCON=0                            && PUNTATORE CONDIZIONI
X_MAXCAM=AFIELDS(X_CAMPI)
V_CNTCAM=0
FOR H=1 TO X_MAXCAM
   IF X_CAMPI[H,2] $ "CN"
      V_CNTCAM=V_CNTCAM+1
   ENDIF
NEXT
V_MAXCAM=0
PUBLIC A_CAMPI[V_CNTCAM,4]
FOR H=1 TO X_MAXCAM
   IF X_CAMPI[H,2] $ "CN"
      V_MAXCAM=V_MAXCAM+1
      A_CAMPI[V_MAXCAM,1]=X_CAMPI[H,1]
      A_CAMPI[V_MAXCAM,2]=X_CAMPI[H,2]
      A_CAMPI[V_MAXCAM,3]=X_CAMPI[H,3]
      A_CAMPI[V_MAXCAM,4]=X_CAMPI[H,4]
   ENDIF
NEXT

POP01=1
POP02=1
POP03=1
OPZ01=1
CAS01=0
ELE01=1
ELE02=1
ELE03=1
RETURN


***********************************************************************
PROCEDURE SETTAOPER
***********************************************************************
IF A_CAMPI[POP03,2]=="C"
  PUBLIC A_OPERATORI[8]
  A_OPERATORI[1]="="
  A_OPERATORI[2]=">"
  A_OPERATORI[3]="<"
  A_OPERATORI[4]=">="
  A_OPERATORI[5]="<="
  A_OPERATORI[6]="<>"
  A_OPERATORI[7]="=="
  A_OPERATORI[8]="$"
ELSE
  PUBLIC A_OPERATORI[6]
  A_OPERATORI[1]="="
  A_OPERATORI[2]=">"
  A_OPERATORI[3]="<"
  A_OPERATORI[4]=">="
  A_OPERATORI[5]="<="
  A_OPERATORI[6]="<>"
ENDIF
PO04=1
SHOW GETS
RETURN

****************************************************************
FUNCTION CREACURSORE
****************************************************************
IF P_DESCAM=0
   WAIT WINDOW "Non sono stati Specificati Campi !"
   _CUROBJ=OBJNUM(POP01)
   RETURN(.F.)
ENDIF
V_CURCAM=""
FOR H=1 TO P_DESCAM
   V_CURCAM=V_CURCAM+ALLTRIM(SUBSTR(A_DESCAM[H],1,10))+","
NEXT
V_CURCAM=SUBSTR(V_CURCAM,1,LEN(V_CURCAM)-1)
** WAIT WINDOW V_CURCAM

V_CURORD=""
FOR H=1 TO P_DESORD
    V_CURORD=V_CURORD+ALLTRIM(SUBSTR(A_DESORD[H],1,10))+IIF("Decrescente" $ A_DESORD[H]," DESC,"," ASC,")
NEXT
V_CURORD=SUBSTR(V_CURORD,1,LEN(V_CURORD)-1)
*** WAIT WINDOW V_CURORD

V_CURCON="("
FOR H=1 TO P_DESCON
    IF ".OR." $ A_DESCON[H]
       LOOP
    ENDIF
    FL_CON=.F.
    IF H+1 <= P_DESCON
       IF ".OR." $ A_DESCON[H+1]
          FL_CON=.T.
       ENDIF
    ENDIF
    V_CURCON=V_CURCON+ALLTRIM(A_DESCON[H])+IIF(FL_CON,") OR ("," AND  ")
NEXT
V_CURCON=SUBSTR(V_CURCON,1,LEN(V_CURCON)-6)+")"

F_SOCI = .F.
FOR _SP= 1 TO V_MAXCAM
   IF A_CAMPI[_SP,1]='SOCIETA'
     F_SOCI = .T.
     EXIT
   ENDIF
NEXT
IF PUB_CODSOC='999'
  F_SOCI = .F.
ENDIF

IF LEN(V_CURCON)=1
  IF F_SOCI
   V_CURCON="SOCIETA=PUB_CODSOC "
  ELSE
   V_CURCON=""
  ENDIF
ELSE
  IF F_SOCI
   V_CURCON="SOCIETA=PUB_CODSOC .AND. ("+ V_CURCON+")"
  ELSE
  ** V_CURCON=V_CURCON
  ENDIF
ENDIF

***WAIT WINDOW V_CURCON

IF LEN(V_CURCON) = 0
   V_CURCON="1=1"
ENDIF

IF LEN(V_CURORD) > 0
   V_CURCON=V_CURCON+" ORDER BY "+V_CURORD
ENDIF

SELECT &V_CURCAM;
  FROM  (ALIAS(V_SELECT));
  WHERE &V_CURCON ;
  INTO CURSOR WINFIND

RETURN(.T.)

