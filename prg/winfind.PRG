*       * Object Type:         Push Button                        
*       * Snippet Number:      7                                  
*       *                                                         
*       *********************************************************
*
FUNCTION _r490mwm4x     &&  BUT04 VALID
#REGION 1
DO CASE
   CASE BUT04=1
      V_CONDIZ=""
      DO CASE
         CASE A_CAMPI[POP03,2]=="C"
              V_CONDIZ='"'+ALLTRIM(V_ESEMPIO)+'"'
         CASE A_CAMPI[POP03,2]=="N"
**              V_CONDIZ=ALLTRIM(STR(VAL(V_ESEMPIO),13,2))
              V_CONDIZ=ALLTRIM(STR(VAL(V_ESEMPIO),13))
         OTHERWISE
            WAIT WINDOW "Questo Tipo di campo non"+CHR(13)+;
                        "č utilizzabile nelle ricerche !"
            _CUROBJ=OBJNUM(POP03)
            RETURN
      ENDCASE
      P_DESCON=P_DESCON+1
      A_DESCON[P_DESCON]=A_CAMPI[POP03,1]+" "+A_OPERATORI[POP04]+" "+V_CONDIZ
      V_ESEMPIO=""
      _CUROBJ=OBJNUM(POP03)
      SHOW GETS
   CASE BUT04=2
       IF ELE03 > P_DESCON
          RETURN
       ENDIF
       P_DESCON=P_DESCON-1
       =ADEL(A_DESCON,ELE03)
       SHOW GETS
   CASE BUT04=3
       IF ELE03=1
          RETURN
       ENDIF
       V_TEMP=A_DESCON[ELE03]
       =ADEL(A_DESCON,ELE03)
       =AINS(A_DESCON,ELE03-1)
       A_DESCON[ELE03-1]=V_TEMP
       ELE03=ELE03-1
       SHOW GETS
   CASE BUT04=4
       IF ELE03 > P_DESCON-1
          RETURN
       ENDIF
       V_TEMP=A_DESCON[ELE03]
       =ADEL(A_DESCON,ELE03)
       =AINS(A_DESCON,ELE03+1)
       A_DESCON[ELE03+1]=V_TEMP
       ELE03=ELE03+1
       SHOW GETS
   CASE BUT04=5
      P_DESCON=P_DESCON+1
      A_DESCON[P_DESCON]=".OR."
      SHOW GETS
ENDCASE

*       *********************************************************
*       *                                                         
*       * _R490MWM81           BUT05 VALID                        
*       *                                                         
*       * Function Origin:                                        
*       *                                                         
*       * From Platform:       Windows                            
*       * From Screen:         WINFIND,     Record Number:   35   
*       * Variable:            BUT05                              
*       * Called By:           VALID Clause                       
*       * Object Type:         Push Button                        
*       * Snippet Number:      8                                  
*       *                                                         
*       *********************************************************
*
FUNCTION _r490mwm81     &&  BUT05 VALID
#REGION 1
DO CASE
   CASE BUT05=1
       V_NOMEFILE=GETFILE("ZWF","Carica Impostazione")
       IF V_NOMEFILE==""
          RETURN
       ENDIF
       IF FILE(V_TEMPREPO)
          ERASE (V_TEMPREPO)
       ENDIF
       IF FILE(V_TEMPREPT)
          ERASE (V_TEMPREPT)
       ENDIF
       OLD_CODSOC=PUB_CODSOC
       RESTORE FROM (V_NOMEFILE) ADDITIVE
       PUB_CODSOC=OLD_CODSOC
       RELEASE OLD_CODSOC
       V_XX=A_TABELLE[POP05,1]
       V_XX=SUBSTR(V_XX,1,AT(".",V_XX)-1)
       IF !USED(V_XX)
          USE &V_XX IN 0 AGAIN
       ENDIF
       SELECT &V_XX
       SET FILTER TO
       SET ORDER TO
       GO TOP
       V_SELECT=SELECT()
       IF OPZ01=2
	      SHOW GET BUT06 ENABLE
	   ELSE
          SHOW GET BUT06 DISABLE
       ENDIF
       IF OPZ01=1
          SHOW GET V_DESCRI ENABLE
       ELSE
          SHOW GET V_DESCRI DISABLE
       ENDIF
       SHOW GETS
   CASE BUT05=2
       IF P_DESCAM=0
          WAIT WINDOW "NON C'E' NIENTE DA SALVARE !!"
          RETURN
       ENDIF
       V_NOMEFILE=PUTFILE("Salva Impostazioni","","ZWF")
       IF V_NOMEFILE==""
          RETURN
       ENDIF
       SAVE TO (V_NOMEFILE)
       IF FILE(V_TEMPREPO)
           RENAME (V_TEMPREPO) TO (V_NOMEREPO+".FRX")
       ENDIF
       IF FILE(V_TEMPREPT)
           RENAME (V_TEMPREPT) TO (V_NOMEREPT+".FRT")
       ENDIF
   CASE BUT05=3
       IF !CREACURSORE()
          RETURN
       ENDIF
       DO CASE
          CASE OPZ01=1   && BROWSE
              B_CAMPI=""
              FOR H=1 TO P_DESCAM
                  W_CAMPO=ALLTRIM(SUBSTR(A_DESCAM[H],1,10))
                  W_DESCR=ALLTRIM(SUBSTR(A_DESCAM[H],15))
                  B_CAMPI=B_CAMPI+W_CAMPO+":H='"+W_DESCR+"',"
              NEXT
              B_CAMPI=SUBSTR(B_CAMPI,1,LEN(B_CAMPI)-1)
**              WAIT WINDOW B_CAMPI
              DEFINE WINDOW WFBROWSE;
                IN SCREEN;
                FROM 0,0 TO SROWS()-5,SCOLS()-5;
                CLOSE;
                GROW;
                DOUBLE;
                FLOAT;
                FONT "Courier New",8
                MOVE WINDOW WFBROWSE CENTER
              IF LEN(B_CAMPI) < 2000
                 B_RESTO="TITLE [Elenco Dati Richiesti] FIELDS "+B_CAMPI
              ELSE
                 B_RESTO="TITLE [Elenco Dati Richiesti]"
              ENDIF
              BROWSE &B_RESTO;
                 WINDOW WFBROWSE;
                 NOREFRESH;
                 NOMENU;
                 NOEDIT;
                 NODELETE;
                 NOAPPEND;
                 NOLINK;
                 REST;
                 COLOR ,,,,,,W/*R
              RELEASE WINDOW WFBROWSE
          CASE OPZ01=2   && REPORT
              IF FILE(V_NOMEREPO+".FRX")
                 DO PRG\MENUSTA WITH "WINFIND",.T.,.T.,"XXX",V_NOMEFRT,V_NOMEFRT
              ELSE
                 IF !FILE(V_TEMPREPO)
                    CREATE REPORT (V_TEMPREPO) FROM WINFIND COLUMN
                 ENDIF
                 DO PRG\MENUSTA WITH "WINFIND",.T.,.T.,"XXX",V_NOMEFRT,V_NOMEFRT
              ENDIF
          CASE OPZ01=3   && GRAFICO
              DO (_GENGRAPH)
          CASE OPZ01=4   && FILE
              DO PRG\WINTFIL
       ENDCASE
   CASE BUT05=4
      IF FILE(V_TEMPREPO)
         ERASE (V_TEMPREPO)
      ENDIF
      IF FILE(V_TEMPREPT)
         ERASE (V_TEMPREPT)
      ENDIF
      CLEAR READ
ENDCASE

