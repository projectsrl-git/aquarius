#REGION 1
DO CASE
   CASE BUT01=1
        IF EMPTY(V_DESCRI)
           V_DESCRI=A_CAMPI[POP01,1]
        ENDIF
        IF P_DESCAM+1 > 186
           RETURN
        ENDIF
        P_DESCAM=P_DESCAM+1
