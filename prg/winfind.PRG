           RETURN
        ENDIF
        P_DESCAM=P_DESCAM-1
        =ADEL(A_DESCAM,ELE01)
        SHOW GETS
   CASE BUT01=3
        FOR H=1 TO  V_MAXCAM
           IF P_DESCAM+1 > 186
              RETURN
           ENDIF
           P_DESCAM=P_DESCAM+1
           A_DESCAM[P_DESCAM]=PADR(A_CAMPI[H,1],10)+" == "+A_CAMPI[H,1]
        NEXT
        SHOW GETS
ENDCASE

