* CREA IL CALENDARIO DELLE ELABORAZIONI GIORNALIERE

SS=STR(SELECT())

DT_INI = "01/01/"+PUB_ANNO

FOR H= 1 TO 365

	IF SUBSTR(DT_INI,1,6) = "01/01/"
    	DT_SOLA = DTOC(CTOD(DT_INI))
	    DT_ELAB = "31/12/"+PUB_ANNOP
	ELSE
	    DT_SOLA = DTOC(CTOD(DT_INI))
    	DT_ELAB = DTOC(CTOD(DT_INI) -1)
	ENDIF
	
    IF RIBALTA2(DT_INI) < RIBALTA2(DATADAL)
   	   LOOP
    ENDIF   

    IF RIBALTA2(DT_INI) > RIBALTA2(DATAAL)
       LOOP
    ENDIF   

	=AQUACALE(DT_SOLA,DT_ELAB) 

    DT_INI = DTOC(CTOD(DT_INI) + 1)


NEXT

SELECT &SS