
PARAMETERS _par_clifor

IF PCOUNT() = 0
	MESSAGEBOX("Parametri insufficienti",48,"Attenzione")
ENDIF

IF _par_clifor = "CLI" OR _par_clifor = "FOR"
ELSE
	MESSAGEBOX("Accetta solo parametro 'CLI' oppure 'FOR'",48,"Attenzione")
	RETURN .F.
ENDIF

_DESCR_CLI_FOR = IIF(_par_clifor = 'CLI',"CLIENTI",IIF(_par_clifor = 'FOR',"FORNITORI",""))

_C_ANNO = PJ_INPUTBOX("Inserire l'anno di riferimento","Selezione anno di riferimento",ALLTRIM(STR(VAL(PUB_ANNO) - 1)))
*!*	IF EMPTY(_C_ANNO)
*!*		MESSAGEBOX("Operazione abbandonata",64,"Informazione")
*!*		RETURN .F.
*!*	ENDIF

IF EMPTY(_C_ANNO)
	_RISP = MESSAGEBOX("Omettendo l'anno di riferimento, verranno estratti tutti i " + _DESCR_CLI_FOR + " indipendentemente dall'anno di movimentazione" + REPLICATE(CHR(13),2) + ;
				"Continuare ugualmente?",4+32,"Attenzione")
	IF _RISP <> 6
		RETURN .F.
	ENDIF
ELSE
	IF VAL(_C_ANNO) > 0
	ELSE
		MESSAGEBOX("Anno di riferimento non valido",16,"Attenzione")
		RETURN .F.
	ENDIF
ENDIF

_RISP = MESSAGEBOX("Estrarre in excel i dati legali dall'anagrafica " + _DESCR_CLI_FOR + " ?" + REPLICATE(CHR(13),2) + ;
			"N.B.: L'estrazione potrebbe durare alcuni minuti",4+32,"Attenzione")
IF _RISP <> 6
	RETURN .F.
ENDIF

WAIT WINDOWS "Estrazione dati in corso..." NOWAIT

DO CASE
	
	CASE ALLTRIM(_par_clifor) == "CLI"
		x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
		x_anno = IIF(!EMPTY(_C_ANNO),"cli_codcli IN (SELECT ORD_CODCLI FROM U_FAT_TT WHERE ORD_ANNO = '" + ALLTRIM(_C_ANNO) + "')","1=1")
		x_cond = x_soci + " and " + x_anno 
		cSql   = ""
		TEXT TO cSql NOSHOW
			SELECT 
				CLI_CODCLI AS CODICE,
				CLI_RAGSOC AS RAG_SOCIALE_ANAGR,
				CASE CLI_RECCAT WHEN 1 THEN 'GIURIDICA' WHEN 2 THEN 'FISICA' ELSE 'NON CONFIGURATO' END AS TIPO_PERSONA,
				'' AS DATI_PERS_GIURIDICA,
				CLI_RAGLEG AS PG_RAG_SOCIALE,
				CLI_RGLEG2 AS PG_ULTER_RAG_SOC,
				CLI_INDLEG AS PG_INDIRIZZO,
				CLI_LOCLEG AS PG_LOCALITA,
				CLI_PROLEG AS PG_PROVINCIA,
				CLI_CAPLEG AS PG_CAP,
				CLI_NAZLEG AS PG_COD_NAZIONE,
				CLI_PIVALG AS PG_PARTITA_IVA,
				CLI_CFISLG AS PG_COD_FISCALE,
				CLI_IVCELG AS PG_IVA_CEE_EXTRA_CEE,
				CLI_ESTNAZ AS PG_COD_STATO_ESTERO_PER_AG_ENTRATE,
				COALESCE(PG_NU.DESCRI,'') AS PG_DES_STATO_ESTERO_PER_AG_ENTRATE,
				'' AS DATI_PERS_FISICA,
				CLI_RECCOG AS PF_COGNOME,
				CLI_RECNOM AS PF_NOME,
				CLI_RECCDF AS PF_COD_FISCALE,
				CLI_RECTIP AS PF_TIPO_SOGGETTO,
				CLI_RECDES AS PF_DES_TIPO_SOGGETTO,
				CLI_ESTNAS AS PF_DATA_NASCITA,
				CLI_ESTCOM AS PF_COMUNE_O_STATO_EST_NASCITA,
				CLI_PRONAS AS PF_PROVINCIA_NASCITA,
				CLI_ESTDOM AS PG_COD_STATO_ESTERO_PER_AG_ENTRATE,
				COALESCE(PF_NU.DESCRI,'') AS PF_DES_STATO_ESTERO_PER_AG_ENTRATE
			FROM U_CLI_AN
			LEFT OUTER JOIN NAZIONI_UNICO AS PG_NU ON CLI_ESTNAZ = PG_NU.CODICE
			LEFT OUTER JOIN NAZIONI_UNICO AS PF_NU ON CLI_ESTDOM = PF_NU.CODICE
			WHERE <<x_cond>>
			ORDER BY CLI_CODCLI
		ENDTEXT
	
	CASE ALLTRIM(_par_clifor) == "FOR"
		x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
		x_anno = IIF(!EMPTY(_C_ANNO),"for_codcli IN (SELECT IVF_CODCLI FROM U_IVF_CL WHERE IVF_ANNO = '" + ALLTRIM(_C_ANNO) + "')","1=1")
		x_cond = x_soci + " and " + x_anno 
		cSql   = ""
		TEXT TO cSql NOSHOW
			SELECT 
				FOR_CODCLI AS CODICE,
				FOR_RAGSOC AS RAG_SOCIALE_ANAGR,
				CASE FOR_RECCAT WHEN 1 THEN 'GIURIDICA' WHEN 2 THEN 'FISICA' ELSE 'NON CONFIGURATO' END AS TIPO_PERSONA,
				'' AS DATI_PERS_GIURIDICA,
				FOR_RAGLEG AS PG_RAG_SOCIALE,
				FOR_RGLEG2 AS PG_ULTER_RAG_SOC,
				FOR_INDLEG AS PG_INDIRIZZO,
				FOR_LOCLEG AS PG_LOCALITA,
				FOR_PROLEG AS PG_PROVINCIA,
				FOR_CAPLEG AS PG_CAP,
				FOR_NAZLEG AS PG_COD_NAZIONE,
				FOR_PIVALG AS PG_PARTITA_IVA,
				FOR_CFISLG AS PG_COD_FISCALE,
				FOR_IVCELG AS PG_IVA_CEE_EXTRA_CEE,
				FOR_ESTNAZ AS PG_COD_STATO_ESTERO_PER_AG_ENTRATE,
				COALESCE(PG_NU.DESCRI,'') AS PG_DES_STATO_ESTERO_PER_AG_ENTRATE,
				'' AS DATI_PERS_FISICA,
				FOR_RECCOG AS PF_COGNOME,
				FOR_RECNOM AS PF_NOME,
				FOR_ESTNAS AS PF_DATA_NASCITA,
				FOR_ESTCOM AS PF_COMUNE_O_STATO_EST_NASCITA,
				FOR_PRONAS AS PF_PROVINCIA_NASCITA,
				FOR_ESTDOM AS PG_COD_STATO_ESTERO_PER_AG_ENTRATE,
				COALESCE(PF_NU.DESCRI,'') AS PF_DES_STATO_ESTERO_PER_AG_ENTRATE
			FROM U_FOR_AN
			LEFT OUTER JOIN NAZIONI_UNICO AS PG_NU ON FOR_ESTNAZ = PG_NU.CODICE
			LEFT OUTER JOIN NAZIONI_UNICO AS PF_NU ON FOR_ESTDOM = PF_NU.CODICE
			WHERE <<x_cond>>
			ORDER BY FOR_CODCLI
		ENDTEXT

ENDCASE

IF !ExecPreparedCommand(cSql,"CUR_EXCEL")
   RETURN .F.
ENDIF
SELECT CUR_EXCEL
GO TOP

WAIT CLEAR

SELECT CUR_EXCEL
GO TOP
IF EOF()
	MESSAGEBOX("Nessun cliente/fornitore estratto",48,"Attenzione")
ELSE
	_TITOLO_EXCEL1 =  "ESTRAZIONE DATI LEGALI " + ALLTRIM(_DESCR_CLI_FOR)
	_TITOLO_EXCEL2 =  "DATA ESTRAZIONE: " + DTOC(DATE())
	_TITOLO_EXCEL3 =  "ORA ESTRAZIONE: " + TIME()
	DO ESTRXLS WITH "CUR_EXCEL",_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,.F.
ENDIF

MESSAGEBOX("Fine estrazione",64,"Informazione")

RETURN

