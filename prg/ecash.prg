   CASE PUB_TIPCAS = '1'
        SET PROCEDURE TO prg\MWCRLIB ADDITIVE
        V_ERR = ApriConnessione(1)
        *IF !V_ERR
            *   V_TESTO = "Impossibile comunicare col misuratore fiscale"
            *   V_FORM  = "DO FORM FORM\MESSAGE_ECASH WITH '" + V_TESTO + "'"
        *   SEGNALA ERRORE CON DESIDERI CONTINUARE UGUALMENTE
        *ENDIF

   CASE PUB_TIPCAS = '2'
        SET PROCEDURE TO prg\EPSONLIB ADDITIVE

   CASE PUB_TIPCAS = '3'
        SET PROCEDURE TO prg\OLIVETTILIB ADDITIVE
        V_ERR = ApriConnessione(1)

ENDCASE   

PUB_CODCAS  = P_CASSA

RELEASE QQR_CODPDV,QQR_DESPDV,QQR_CODCAS,QQR_DESCAS,QQR_TIPCAS,QQR_DESTIP,QQR_AMGINI,QQR_DATINI, ;
        QQR_ORAINI,QQR_PROINI,QQR_AMGFIN,QQR_DATFIN,QQR_ORAFIN,QQR_PROFIN,QQR_PROTOT
PUBLIC  QQR_CODPDV,QQR_DESPDV,QQR_CODCAS,QQR_DESCAS,QQR_TIPCAS,QQR_DESTIP,QQR_AMGINI,QQR_DATINI, ;
        QQR_ORAINI,QQR_PROINI,QQR_AMGFIN,QQR_DATFIN,QQR_ORAFIN,QQR_PROFIN,QQR_PROTOT
QQR_CODPDV = SPACE(10)
QQR_DESPDV = SPACE(50)
QQR_CODCAS = SPACE(03)
QQR_DESCAS = SPACE(10)
QQR_TIPCAS = SPACE(01)
QQR_DESTIP = SPACE(20)
QQR_AMGINI = SPACE(10)
QQR_DATINI = SPACE(10)
QQR_ORAINI = SPACE(08)
QQR_PROINI = 0
QQR_AMGFIN = SPACE(10)
QQR_DATFIN = SPACE(10)
QQR_ORAFIN = SPACE(08)
QQR_PROFIN = 0
QQQ_PROTOT = 0

QQR_CODPDV = PUB_CODBUN
x_cond     = "pdv_codice = '" + ALLTRIM(QQR_CODPDV) + "'"
Csql       = "select * from u_pdv_an where " + x_cond
IF !ExecCommand(Csql,"CU_PDV_AN")
   return(.f.)
ENDIF
SELECT CU_PDV_AN
GO TOP
IF EOF()
   QQR_DESPDV = SPACE(10)
ELSE
   QQR_DESPDV = PDV_DESCRI
ENDIF

QQR_CODCAS = PUB_CODCAS
v_seek     = 'NUMNRC' + QQR_CODCAS
v_chiave   = "codice"
cSql       = "select * from para where " + v_chiave + " = '" + v_seek + "'"
IF !ExecCommand(cSql,"PARA")
   return(.f.)
ENDIF
SELECT PARA
IF RECCOUNT() <> 0
   QQR_DESCAS = DESCRI
   QQR_PROINI = VAL(ALLTRIM(SUBSTR(LIBERA,1,7)))
ELSE
   QQR_DESCAS = SPACE(50)
   QQR_PROINI = 0
ENDIF

QQR_TIPCAS = PUB_TIPCAS
IF QQR_TIPCAS = '0'
   QQR_DESTIP = 'Nessuna cassa'
ENDIF
IF QQR_TIPCAS = '1'
   QQR_DESTIP = 'Cassa Mwcr'
ENDIF
IF QQR_TIPCAS = '2'
   QQR_DESTIP = 'Cassa Epson'
ENDIF
IF QQR_TIPCAS = '3'
   QQR_DESTIP = 'Cassa Olivetti'
ENDIF

QQR_DATINI = DTOC(DATE())
QQR_ORAINI = TIME()

v_cond = "codice like 'NUMNRC%'"
cSql   = "select * from para where " + v_cond
IF !ExecCommand(cSql,"PARA")
   return(.f.)
ENDIF
SELECT PARA
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF ALLTRIM(DESIVA) = 'CASSA'
   ELSE
      SKIP +1
      LOOP
   ENDIF
   XW_CODCAS = SUBSTR(CODICE,7,3)
   XW_DESCAS = DESCRI
   x_soci = "mon_codsoc = '" + PUB_CODSOC + "'"
   x_cpdv = "mon_codpdv = '" + ALLTRIM(QQR_CODPDV) + "'"
   x_cass = "mon_codcas = '" + ALLTRIM(XW_CODCAS) + "'"
   x_data = "mon_amgini = '" + RIBALTA2(DTOC(DATE())) + "'"
   x_cond = x_soci + " and " + x_cpdv + " and " + x_cass + " and " + x_data
   Csql   = "select * from u_mon_ca where " + x_cond
   IF !ExecRW(Csql,"U_MON_CA","R")
      return(.f.)
   ENDIF
   SELECT U_MON_CA
   IF EOF()
      APPEND BLANK
      REPLACE MON_CODSOC WITH PUB_CODSOC
      REPLACE MON_CODPDV WITH QQR_CODPDV
      REPLACE MON_DESPDV WITH QQR_DESPDV
      REPLACE MON_CODCAS WITH XW_CODCAS
      REPLACE MON_DESCAS WITH XW_DESCAS
      REPLACE MON_TIPCAS WITH QQR_TIPCAS
      REPLACE MON_DESTIP WITH QQR_DESTIP
      REPLACE MON_AMGINI WITH RIBALTA2(QQR_DATINI)
      REPLACE MON_DATINI WITH QQR_DATINI
      REPLACE MON_ORAINI WITH SPACE(08)
      REPLACE MON_PROINI WITH 0
      REPLACE MON_AMGFIN WITH SPACE(10)
      REPLACE MON_DATFIN WITH SPACE(10)
      REPLACE MON_ORAFIN WITH SPACE(08)
      REPLACE MON_PROFIN WITH 0
      REPLACE MON_PROTOT WITH 0
      REPLACE MON_FLGTRA WITH .F.
   ENDIF
   IF !ExecRW(Csql,"U_MON_CA","W")
      return(.f.)
   ENDIF
   SELECT PARA
   SKIP +1
ENDDO

x_soci = "mon_codsoc = '" + PUB_CODSOC + "'"
x_cpdv = "mon_codpdv = '" + ALLTRIM(QQR_CODPDV) + "'"
x_cass = "mon_codcas = '" + ALLTRIM(PUB_CODCAS) + "'"
x_data = "mon_amgini = '" + RIBALTA2(DTOC(DATE())) + "'"
x_ora1 = "mon_oraini = '" + SPACE(08) + "'"
x_cond = x_soci + " and " + x_cpdv + " and " + x_cass + " and " + x_data + " and " + x_ora1
Csql   = "select * from u_mon_ca where " + x_cond
IF !ExecRW(Csql,"U_MON_CA","R")
   return(.f.)
ENDIF
SELECT U_MON_CA
GO TOP
IF EOF()
   APPEND BLANK
ENDIF
REPLACE MON_CODSOC WITH PUB_CODSOC
REPLACE MON_CODPDV WITH QQR_CODPDV
REPLACE MON_DESPDV WITH QQR_DESPDV
REPLACE MON_CODCAS WITH QQR_CODCAS
REPLACE MON_DESCAS WITH QQR_DESCAS
REPLACE MON_TIPCAS WITH QQR_TIPCAS
REPLACE MON_DESTIP WITH QQR_DESTIP
REPLACE MON_AMGINI WITH RIBALTA2(QQR_DATINI)
REPLACE MON_DATINI WITH QQR_DATINI
REPLACE MON_ORAINI WITH QQR_ORAINI
REPLACE MON_PROINI WITH QQR_PROINI
REPLACE MON_AMGFIN WITH SPACE(10)
REPLACE MON_DATFIN WITH SPACE(10)
REPLACE MON_ORAFIN WITH SPACE(08)
REPLACE MON_PROFIN WITH 0
REPLACE MON_PROTOT WITH 0
REPLACE MON_FLGTRA WITH .F.
IF !ExecRW(Csql,"U_MON_CA","W")
   return(.f.)
ENDIF

