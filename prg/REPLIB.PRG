PROCEDURE RTRIM_VARCHAR_FIELDS
************************************************************************
LOCAL _I,_NOME_VAR_M
=AFIELDS(_A_STRUCTURE)
FOR _I=1 TO ALEN(_A_STRUCTURE,1)
	IF ALLTRIM(_A_STRUCTURE(_I,2)) = "V"
		_NOME_VAR_M = "M."+ALLTRIM(_A_STRUCTURE(_I,1))
		IF TYPE(_NOME_VAR_M) = "C"
			&_NOME_VAR_M = RTRIM(&_NOME_VAR_M)
		ENDIF
	ENDIF
ENDFOR
RELEASE _A_STRUCTURE,_I,_NOME_VAR_M
ENDPROC
