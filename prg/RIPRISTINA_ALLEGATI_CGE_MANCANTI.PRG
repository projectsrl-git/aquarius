
WAIT CLEAR

_RISP = MESSAGEBOX("Utility di ripristino files mancanti CGE (Allegati fatt. forn. XML)" + REPLICATE(CHR(13),2) + ;
	"Continuare con la verifica dei files mancanti fisicamente?",4+32+256,"Attenzione")
IF _RISP = 6
ELSE
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .T.
ENDIF

*!*	PRELEVA LA DIRECTORY OVE MEMORIZZARE I FILE PDF
_V_DIRECTORY_FILE_XML = ""
v_seek	  = 'ALLCGE'
v_chiave  = "codice"
cSql="select * from para where " + v_chiave + " = '" + v_seek + "'"
IF !ExecRW(cSql,"PARA","R")
   return(.f.)
ENDIF
SELECT PARA
IF RECCOUNT() = 0
   _V_DIRECTORY_FILE_XML  = "\DOC_AQUARIUS\FATTURE_ELETTRONICHE_FORNITORI"
   APPEND BLANK
   REPLACE CODICE WITH 'ALLCGE'
   REPLACE DESCRI WITH _V_DIRECTORY_FILE_XML
   REPLACE LIBERA WITH ALLTRIM(_V_DIRECTORY_FILE_XML)
   IF !ExecRW(cSql,"PARA","W")
	  return(.f.)
   ENDIF
ELSE
	_V_DIRECTORY_FILE_XML = ALLTRIM(LIBERA)
ENDIF

DO CASE
	CASE SUBSTR(_V_DIRECTORY_FILE_XML,1,2) = "\\"	&& PERCORSO SU SERVER DIVERSO
		_V_DIRECTORY_FILE_XML = _V_DIRECTORY_FILE_XML

	CASE !EMPTY(JUSTDRIVE(_V_DIRECTORY_FILE_XML))	&& PERCORSO FISSO
		_V_DIRECTORY_FILE_XML = _V_DIRECTORY_FILE_XML
	
	OTHERWISE								&& PERCORSO RELATIVO RISPETTO ALLA DIRECTORY DI LAVORO DI AQUARIUS (CARTELLA SUPERIORE)
		_cWorkDir = SYS(5) + SYS(2003)
		_V_DIRECTORY_FILE_XML= SUBSTR(_cWorkDir,1,RAT('\',_cWorkDir,1)-1) + _V_DIRECTORY_FILE_XML
ENDCASE


WAIT WINDOWS "Lettura files in corso..." NOWAIT

CSQL = 	"SELECT SPACE(10) AS SELEZIONE,INDICE.MOV_DTDOC,INDICE.MOV_NDOC,INDICE.MOV_DTREG,INDICE.MOV_NREGIS,INDICE.MOV_CONTO, " + ;
		"SUBSTRING(('"+_V_DIRECTORY_FILE_XML+"\ALLEGATI\'+RTRIM(ATTACHMENTS.FILENAME)),1,254) AS FULLPATH,ATTACHMENTS.* FROM ATTACHMENTS " + ;
		"RIGHT JOIN INDICE ON ATTACHMENTS.IDDOCUMENTO = INDICE.MOV_SYSDOC " + ;
		"WHERE ATTACHMENTS.TIPO = 'CGE'"
IF !ExecCommand(CSQL,"SEL_ATTACHMENTS_CGE")
   return
ENDIF
SELECT SEL_ATTACHMENTS_CGE
GO TOP
SCAN
	IF FILE(FULLPATH,1)
		DELETE
	ENDIF
ENDSCAN

WAIT CLEAR

SELECT SEL_ATTACHMENTS_CGE
GO TOP
IF EOF()
	MESSAGEBOX("Nessun file CGE mancante",64,"Informazione")
	RETURN .T.
ENDIF

DO prg\browseview WITH "SEL_ATTACHMENTS_CGE","Selezione files mancanti fisicamente da ripristinare","MOV_DTDOC:Data doc.,W:10;MOV_NDOC:N.doc.,W:10;MOV_DTREG:Data reg.,W:10;MOV_NREGIS:N.reg.,W:10;MOV_CONTO:Conto,W:10;" + ;
	"FULLPATH:Nome file completo,W:120;",800,1200,.T.,.F.
IF NumeroRecordLetti = 0
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF

_StyleSheetName = "FoglioStileFatturaXML.xsl"
_StyleSheetFileName = _V_DIRECTORY_FILE_XML+"\ALLEGATI\" + _StyleSheetName
IF !FILE(_StyleSheetFileName)
	_RISP = MESSAGEBOX("Foglio di stile " + _StyleSheetFileName + " non disponibile" + REPLICATE(CHR(13),2) + "Continuare ugualmente?",4+32+256,"Attenzione")
	IF _RISP <> 6
		RETURN .F.
	ENDIF
ENDIF

gcDir = GETDIR("", "", "Selezionare la Directory da cui prelevare i files da ripristinare")
IF EMPTY(gcDir)
	MESSAGEBOX("Nessuna directory selezionata",64,"Informazione")
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN
ENDIF

_V_DIR_SOURCE = ALLTRIM(gcDir)

_RISP = MESSAGEBOX("Proseguire con il ripristino dei files mancanti CGE selezionati?",4+32+256,"Attenzione")
IF _RISP = 6
ELSE
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .T.
ENDIF

WAIT WINDOWS "Estrazione eventuali files integrati nella directory sorgente delle fatture elettroniche XML in corso..." NOWAIT

SELECT SEL_ATTACHMENTS_CGE
GO TOP
SCAN
	IF SELEZIONE = "==>"
	ELSE
		LOOP
	ENDIF
	
	__PREFISSO_FILE_ALLEGATO = IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(MOV_CONTO,RAT('.',MOV_CONTO,1)+1))), ALLTRIM(SUBSTR(MOV_CONTO,PUB_SOTTOG,PUB_CONTO))) + "-" + STRTRAN(MOV_DTDOC,'/','') + "_"

	_cSOURCE_FILE = ""
	_cSOURCE_FILE_CON_PREFISSO = _V_DIR_SOURCE + ALLTRIM(JUSTFNAME(FULLPATH))
	IF FILE(_cSOURCE_FILE_CON_PREFISSO,1)
		_cSOURCE_FILE = _cSOURCE_FILE_CON_PREFISSO
	ELSE
		_cSOURCE_FILE_SENZA_PREFISSO = _V_DIR_SOURCE + SUBSTR(JUSTFNAME(FULLPATH),PUB_LCL+11)
		IF FILE(_cSOURCE_FILE_SENZA_PREFISSO,1)
			_cSOURCE_FILE = _cSOURCE_FILE_SENZA_PREFISSO
		ENDIF
	ENDIF

	IF !EMPTY(_cSOURCE_FILE) AND FILE(_cSOURCE_FILE,1)
		_tipo_file_fattura_eletronica_xml = .F.
		_FILE_XML = ""
		IF UPPER(RIGHT(_cSOURCE_FILE,4)) = ".XML"
			_FILE_XML = FILETOSTR(ALLTRIM(_cSOURCE_FILE))
			IF "<FatturaElettronicaHeader>" $ _FILE_XML
				_tipo_file_fattura_eletronica_xml = .T.
			ENDIF
		ENDIF
		IF _tipo_file_fattura_eletronica_xml
			
			*** VERIFICO SE ESISTONO ALLEGATI INTEGRATI NELLA FATTURA ELETTRONICA, SE SI NE VERIFICO L'ESISTENZA IN TABELLA ATTACHMENTS, E SOLO IN TAL CASO LI RIPRISTINO
			_nr_allegati = OCCURS("<Attachment>",_FILE_XML)
			IF _nr_allegati > 0
				CREATE CURSOR SEL_ATTACHMENT (SELEZIONE C(10), NR_ALLEGATO N(10,0), NOME_ATTACHMENT C(254))
				FOR _i = 1 TO _nr_allegati
					_NOME_ATTACHMENT = STREXTRACT(_FILE_XML,'<NomeAttachment>','</NomeAttachment>',_i)
					_NOME_ATTACHMENT = __PREFISSO_FILE_ALLEGATO + TOGLI_CARATTERI_SPECIALI(ALLTRIM(_NOME_ATTACHMENT),.T.)
					SELECT SEL_ATTACHMENT
					APPEND BLANK
					REPLACE NR_ALLEGATO WITH _i
					REPLACE NOME_ATTACHMENT WITH _NOME_ATTACHMENT
					REPLACE SELEZIONE WITH "==>"
				ENDFOR
				
				SELECT SEL_ATTACHMENT
				GO TOP
				SCAN
					IF SELEZIONE = "==>"
						_ATTACHMENT = STREXTRACT(_FILE_XML,'<Attachment>','</Attachment>',NR_ALLEGATO)
						_NOME_ATTACHMENT = ALLTRIM(NOME_ATTACHMENT)
						_TEMP_NOME_ATTACHMENT = _V_DIR_SOURCE + _NOME_ATTACHMENT
						IF !FILE(_TEMP_NOME_ATTACHMENT,1)  && CREO FILE SOLO SE NON ESISTE GIA'
							STRTOFILE(STRCONV(_ATTACHMENT,14),_TEMP_NOME_ATTACHMENT,0)
						ENDIF
					ENDIF
				ENDSCAN	
			ENDIF	
		ENDIF
	ENDIF
ENDSCAN

_TOT_FILES_DA_RIPRISTINARE = 0
_TOT_FILES_RIPRISTINATI = 0
_TOT_FILES_DA_RIPRISTINARE_NON_TROVATI = 0

WAIT WINDOWS "Ripristino files in corso..." NOWAIT

SELECT SEL_ATTACHMENTS_CGE
GO TOP
SCAN
	IF SELEZIONE = "==>"
	ELSE
		LOOP
	ENDIF
	
	_TOT_FILES_DA_RIPRISTINARE = _TOT_FILES_DA_RIPRISTINARE + 1
	
	__PREFISSO_FILE_ALLEGATO = IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(MOV_CONTO,RAT('.',MOV_CONTO,1)+1))), ALLTRIM(SUBSTR(MOV_CONTO,PUB_SOTTOG,PUB_CONTO))) + "-" + STRTRAN(MOV_DTDOC,'/','') + "_"
	
	_cSOURCE_FILE = ""
	_cSOURCE_FILE_CON_PREFISSO = _V_DIR_SOURCE + ALLTRIM(JUSTFNAME(FULLPATH))
	IF FILE(_cSOURCE_FILE_CON_PREFISSO,1)
		_cSOURCE_FILE = _cSOURCE_FILE_CON_PREFISSO
	ELSE
		_cSOURCE_FILE_SENZA_PREFISSO = _V_DIR_SOURCE + SUBSTR(JUSTFNAME(FULLPATH),PUB_LCL+11)
		IF FILE(_cSOURCE_FILE_SENZA_PREFISSO,1)
			_cSOURCE_FILE = _cSOURCE_FILE_SENZA_PREFISSO
		ENDIF
	ENDIF
	
	IF !EMPTY(_cSOURCE_FILE) AND FILE(_cSOURCE_FILE,1)
		_tipo_file_fattura_eletronica_xml = .F.
		_FILE_XML = ""
		IF UPPER(RIGHT(_cSOURCE_FILE,4)) = ".XML"
			_FILE_XML = FILETOSTR(ALLTRIM(_cSOURCE_FILE))
			IF "<FatturaElettronicaHeader>" $ _FILE_XML
				_tipo_file_fattura_eletronica_xml = .T.
			ENDIF
		ENDIF
		IF _tipo_file_fattura_eletronica_xml
			_NEW_FILE_XML = ""
			IF FILE(_StyleSheetFileName,1)
				*** VERIFICO SE ESISTE GIA' UN FOGLIO DI STILE DEFINITO E IN TAL CASO LO ELIMINO
				IF "<?xml-stylesheet" $ _FILE_XML
					_TMP_FILE_XML1 = SUBSTR(_FILE_XML,1,AT("<?xml-stylesheet",_FILE_XML,1) - 1)
					_TMP_FILE_XML = SUBSTR(_FILE_XML,AT("<?xml-stylesheet",_FILE_XML,1))
					_TMP_FILE_XML2 = SUBSTR(_TMP_FILE_XML,AT(">",_TMP_FILE_XML,1) + 1)
					_FILE_XML = _TMP_FILE_XML1 + _TMP_FILE_XML2
				ENDIF
				*** AGGIUNGO AL FILE L'INDICAZIONE DEL FOGLIO DI STILE (SE PRESENTE SULLA DIRECTORY PRINCIPALE DI AQUARIUS)
				_NEW_FILE_XML = ""
				_posFin1stTag = AT(">",_FILE_XML,1)
				_posIni2ndTag = AT("<",_FILE_XML,2)
				_NEW_FILE_XML = ALLTRIM(SUBSTR(_FILE_XML,1,_posFin1stTag) + '<?xml-stylesheet type="text/xsl" href="' + ALLTRIM(_StyleSheetName) + '"?>' + SUBSTR(_FILE_XML,_posIni2ndTag))
				_NEW_FILE_XML = STRTRAN(_NEW_FILE_XML,">"+CHR(13)+CHR(10),">")
			ELSE
				_NEW_FILE_XML = _FILE_XML
			ENDIF
			STRTOFILE(_NEW_FILE_XML,ALLTRIM(FULLPATH),0)
		ELSE
			_cmd = "COPY FILE '" + _cSOURCE_FILE + "' TO '" + ALLTRIM(FULLPATH)+ "'"
			&_cmd		
		ENDIF

		_TOT_FILES_RIPRISTINATI = _TOT_FILES_RIPRISTINATI + 1
	ENDIF
ENDSCAN

WAIT CLEAR

MESSAGEBOX("Operazione terminata" + REPLICATE(CHR(13),2) + ;
	"Totale files selezionati da ripristinare: " + ALLTRIM(STR(_TOT_FILES_DA_RIPRISTINARE,10,0)) + CHR(13) + ;
	"Totale files ripristinati: " + ALLTRIM(STR(_TOT_FILES_RIPRISTINATI,10,0)) + CHR(13) + ;
	"Totale files da ripristinare non trovati: " + ALLTRIM(STR(_TOT_FILES_DA_RIPRISTINARE_NON_TROVATI,10,0)),64,"Informazione")

RETURN
