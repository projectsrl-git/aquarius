*!*	*** INIZIO AGGIORNAMENTO PREZZO STANDARD COMPONENTI DI.BA.
*!*	cSql=""     
*!*	cNomeCursorSql="CU_NEW_PREZZI"
*!*	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
*!*		
*!*		SELECT DISTINCT
*!*			U_DIS_DD.DIS_CODART,
*!*			PR.ART_DESCR,
*!*			ROUND(COALESCE(COALESCE((SELECT SUM(MOV_PREACQ*MOV_QTAMOV*MOV_CAMBIO) / SUM(MOV_QTAMOV) FROM (
*!*				SELECT MOV_PREACQ,MOV_QTAMOV,(CASE MOV_VALUTA WHEN 'EUR' THEN 1 ELSE COALESCE((SELECT TOP 1 VVA_CHANGE FROM U_VVA_CH WHERE VVA_CODVAL = U_MAG_MO.MOV_VALUTA AND VVA_DATA <= U_MAG_MO.MOV_DTDOCU ORDER BY VVA_DATA DESC),1) END) AS MOV_CAMBIO
*!*				FROM U_MAG_MO WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = U_DIS_DD.DIS_CODART AND MOV_DTREGI >= convert(varchar, DATEADD(month, - <<ALLTRIM(STR(V_NR_MESI,10,0))>>, GETDATE()), 111)
*!*				) AS TM
*!*			), PR.ART_ULPCAR), PR.ART_PRZCOS),6) AS PRZ_ACQ_MED_POND,
*!*			ROUND(COALESCE(COALESCE((SELECT TOP 1 MOV_PREACQ*(CASE MOV_VALUTA WHEN 'EUR' THEN 1 ELSE COALESCE((SELECT TOP 1 VVA_CHANGE FROM U_VVA_CH WHERE VVA_CODVAL = MOV_VALUTA AND VVA_DATA <= MOV_DTDOCU ORDER BY VVA_DATA DESC),1) END) 
*!*				FROM U_MAG_MO LEFT OUTER JOIN U_BFO_DD ON ORD_SYSMAG = MOV_LEGSYS WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = U_DIS_DD.DIS_CODART 
*!*				ORDER BY MOV_DTREGI+COALESCE(ORS_DATORC,'')+COALESCE(ORS_NUMORC,'') DESC),PR.ART_ULPCAR), PR.ART_COSMAT),6) AS PRZ_ACQ_ULT_CAR,
*!*			PR.ART_PRZCOS,
*!*			PR.ART_ULPCAR,
*!*			PR.ART_COSMAT,
*!*			PR.ART_COSLAI,
*!*			PR.ART_COSLAE,
*!*			PR.ART_COSATR,
*!*			(SELECT COUNT(*) FROM U_MAG_MO WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = U_DIS_DD.DIS_CODART AND MOV_DTREGI >= convert(varchar, DATEADD(month, - <<ALLTRIM(STR(V_NR_MESI,10,0))>>, GETDATE()), 111)) AS TOT_CARICHI,
*!*			COALESCE((SELECT TOP 1 MOV_DTREGI FROM U_MAG_MO WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = U_DIS_DD.DIS_CODART ORDER BY MOV_DTREGI DESC),'') AS DT_ULTCAR,
*!*			CAST(0 AS NUMERIC(19,6)) AS NEW_PRZCOS
*!*		FROM U_DIS_DD 
*!*		LEFT OUTER JOIN U_ART_PR AS PR ON PR.ART_CODPRI = U_DIS_DD.DIS_CODART
*!*		WHERE 
*!*			U_DIS_DD.DIS_CODART NOT IN (SELECT DIT_GRUPPO FROM U_DIS_TT)
*!*			AND PR.ART_NONMOV = 0
*!*		GROUP BY
*!*			U_DIS_DD.DIS_CODART,
*!*			PR.ART_DESCR,
*!*			PR.ART_PRZCOS,
*!*			PR.ART_ULPCAR,
*!*			PR.ART_COSMAT,
*!*			PR.ART_COSLAI,
*!*			PR.ART_COSLAE,
*!*			PR.ART_COSATR
*!*		ORDER BY U_DIS_DD.DIS_CODART

*!*	ENDTEXT					&& FINE SCRITTURA QUERY

**=> ERASMO - INIZIO 01/09/2022
*** INIZIO AGGIORNAMENTO PREZZO STANDARD ARTICOLI DI ACQUISTO
cSql=""     
cNomeCursorSql="CU_NEW_PREZZI"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
	SELECT DISTINCT
		U_DIS_DD.DIS_CODART,
		PR.ART_CODPRI,
		PR.ART_DESCR,
		ROUND(COALESCE(COALESCE((SELECT SUM(MOV_PREACQ*MOV_QTAMOV*MOV_CAMBIO) / SUM(MOV_QTAMOV) FROM (
			SELECT MOV_PREACQ,MOV_QTAMOV,(CASE MOV_VALUTA WHEN 'EUR' THEN 1 ELSE COALESCE((SELECT TOP 1 VVA_CHANGE FROM U_VVA_CH WHERE VVA_CODVAL = U_MAG_MO.MOV_VALUTA AND VVA_DATA <= U_MAG_MO.MOV_DTDOCU ORDER BY VVA_DATA DESC),1) END) AS MOV_CAMBIO
			FROM U_MAG_MO WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = PR.ART_CODPRI AND MOV_DTREGI >= convert(varchar, DATEADD(month, - <<ALLTRIM(STR(V_NR_MESI,10,0))>>, GETDATE()), 111)
			AND MOV_PRSPOT = 0  -- ERASMO - 26/02/2025
			) AS TM
		), PR.ART_ULPCAR), PR.ART_PRZCOS),6) AS PRZ_ACQ_MED_POND,
		ROUND(COALESCE(COALESCE((SELECT TOP 1 MOV_PREACQ*(CASE MOV_VALUTA WHEN 'EUR' THEN 1 ELSE COALESCE((SELECT TOP 1 VVA_CHANGE FROM U_VVA_CH WHERE VVA_CODVAL = MOV_VALUTA AND VVA_DATA <= MOV_DTDOCU ORDER BY VVA_DATA DESC),1) END) 
			FROM U_MAG_MO LEFT OUTER JOIN U_BFO_DD ON ORD_SYSMAG = MOV_LEGSYS WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = PR.ART_CODPRI 
			AND MOV_PRSPOT = 0  -- ERASMO - 26/02/2025
			ORDER BY MOV_DTREGI+COALESCE(ORS_DATORC,'')+COALESCE(ORS_NUMORC,'') DESC),PR.ART_ULPCAR), PR.ART_COSMAT),6) AS PRZ_ACQ_ULT_CAR,
		PR.ART_PRZCOS,
		PR.ART_ULPCAR,
		PR.ART_COSMAT,
		PR.ART_COSLAI,
		PR.ART_COSLAE,
		PR.ART_COSATR,
		(SELECT COUNT(*) FROM U_MAG_MO WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = PR.ART_CODPRI AND MOV_DTREGI >= convert(varchar, DATEADD(month, - <<ALLTRIM(STR(V_NR_MESI,10,0))>>, GETDATE()), 111)) AS TOT_CARICHI,
		COALESCE((SELECT TOP 1 MOV_DTREGI FROM U_MAG_MO WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = PR.ART_CODPRI ORDER BY MOV_DTREGI DESC),'') AS DT_ULTCAR,
		CAST(0 AS NUMERIC(19,6)) AS NEW_PRZCOS
	FROM U_ART_PR AS PR
	LEFT OUTER JOIN U_DIS_DD ON PR.ART_CODPRI = U_DIS_DD.DIS_CODART
	WHERE 
		PR.ART_CODPRI NOT IN (SELECT DIT_GRUPPO FROM U_DIS_TT)
		AND PR.ART_NONMOV = 0
		AND PR.ART_TIPART = 'A'
		AND PR.ART_OBSOL <> 'S'
	GROUP BY
		U_DIS_DD.DIS_CODART,
		PR.ART_CODPRI,
		PR.ART_DESCR,
		PR.ART_PRZCOS,
		PR.ART_ULPCAR,
		PR.ART_COSMAT,
		PR.ART_COSLAI,
		PR.ART_COSLAE,
		PR.ART_COSATR
	ORDER BY PR.ART_CODPRI
ENDTEXT					&& FINE SCRITTURA QUERY
**=> ERASMO - FINE 01/09/2022

**=> ERASMO - INIZIO 17/02/2023
IF !EMPTY(_DATA_AL)
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
		SELECT DISTINCT
			U_DIS_DD.DIS_CODART,
			PR.ART_CODPRI,
			PR.ART_DESCR,
			ROUND(COALESCE(COALESCE((SELECT SUM(MOV_PREACQ*MOV_QTAMOV*MOV_CAMBIO) / SUM(MOV_QTAMOV) FROM (
				SELECT MOV_PREACQ,MOV_QTAMOV,(CASE MOV_VALUTA WHEN 'EUR' THEN 1 ELSE COALESCE((SELECT TOP 1 VVA_CHANGE FROM U_VVA_CH WHERE VVA_CODVAL = U_MAG_MO.MOV_VALUTA AND VVA_DATA <= U_MAG_MO.MOV_DTDOCU ORDER BY VVA_DATA DESC),1) END) AS MOV_CAMBIO
				FROM U_MAG_MO WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = PR.ART_CODPRI AND 
					MOV_DTREGI >= convert(varchar, DATEADD(month, - <<ALLTRIM(STR(V_NR_MESI,10,0))>>, CONVERT(DATETIME,'<<RIBALTA2(_DATA_AL)>>',111)), 111) AND MOV_DTREGI <= '<<RIBALTA2(_DATA_AL)>>'
					AND MOV_PRSPOT = 0  -- ERASMO - 26/02/2025
				) AS TM
			), PR.ART_ULPCAR), PR.ART_PRZCOS),6) AS PRZ_ACQ_MED_POND,
			ROUND(COALESCE(COALESCE((SELECT TOP 1 MOV_PREACQ*(CASE MOV_VALUTA WHEN 'EUR' THEN 1 ELSE COALESCE((SELECT TOP 1 VVA_CHANGE FROM U_VVA_CH WHERE VVA_CODVAL = MOV_VALUTA AND VVA_DATA <= MOV_DTDOCU ORDER BY VVA_DATA DESC),1) END) 
				FROM U_MAG_MO LEFT OUTER JOIN U_BFO_DD ON ORD_SYSMAG = MOV_LEGSYS WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = PR.ART_CODPRI 
				AND MOV_PRSPOT = 0  -- ERASMO - 26/02/2025
				ORDER BY MOV_DTREGI+COALESCE(ORS_DATORC,'')+COALESCE(ORS_NUMORC,'') DESC),PR.ART_ULPCAR), PR.ART_COSMAT),6) AS PRZ_ACQ_ULT_CAR,
			PR.ART_PRZCOS,
			PR.ART_ULPCAR,
			PR.ART_COSMAT,
			PR.ART_COSLAI,
			PR.ART_COSLAE,
			PR.ART_COSATR,
			(SELECT COUNT(*) FROM U_MAG_MO WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = PR.ART_CODPRI
				AND MOV_PRSPOT = 0  -- ERASMO - 26/02/2025
				AND MOV_DTREGI >= convert(varchar, DATEADD(month, - <<ALLTRIM(STR(V_NR_MESI,10,0))>>, CONVERT(DATETIME,'<<RIBALTA2(_DATA_AL)>>',111)), 111) AND MOV_DTREGI <= '<<RIBALTA2(_DATA_AL)>>') AS TOT_CARICHI,
			COALESCE((SELECT TOP 1 MOV_DTREGI FROM U_MAG_MO WHERE MOV_TOP = (SELECT AZI_BFO FROM U_AZI_AN) AND MOV_ANAART = PR.ART_CODPRI 
			AND MOV_PRSPOT = 0  -- ERASMO - 26/02/2025
			ORDER BY MOV_DTREGI DESC),'') AS DT_ULTCAR,
			CAST(0 AS NUMERIC(19,6)) AS NEW_PRZCOS
		FROM U_ART_PR AS PR
		LEFT OUTER JOIN U_DIS_DD ON PR.ART_CODPRI = U_DIS_DD.DIS_CODART
		WHERE 
			PR.ART_CODPRI NOT IN (SELECT DIT_GRUPPO FROM U_DIS_TT)
			AND PR.ART_NONMOV = 0
			AND PR.ART_TIPART = 'A'
			AND PR.ART_OBSOL <> 'S'
		GROUP BY
			U_DIS_DD.DIS_CODART,
			PR.ART_CODPRI,
			PR.ART_DESCR,
			PR.ART_PRZCOS,
			PR.ART_ULPCAR,
			PR.ART_COSMAT,
			PR.ART_COSLAI,
			PR.ART_COSLAE,
			PR.ART_COSATR
		ORDER BY PR.ART_CODPRI
	ENDTEXT					&& FINE SCRITTURA QUERY
ENDIF
**=> ERASMO - FINE 17/02/2023

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

WAIT WINDOWS "Aggiornamento anagrafica articoli in corso..." NOWAIT

SELECT CU_NEW_PREZZI
GO TOP
SCAN

	WAIT WINDOWS "Elaborazione articolo " + ALLTRIM(ART_CODPRI) + " in corso..." NOWAIT  && ERASMO - 21/11/2022

	_NEW_COSMAT = IIF(V_NR_MESI<=0,PRZ_ACQ_ULT_CAR,PRZ_ACQ_MED_POND)
	_NEW_PRZCOS = _NEW_COSMAT + ART_COSLAI + ART_COSLAE + ART_COSATR
	
	IF _NEW_PRZCOS > 0
	ELSE
		DELETE
		LOOP
	ENDIF
	
	IF ART_PRZCOS = _NEW_PRZCOS
		DELETE
		LOOP
	ENDIF
	
	REPLACE NEW_PRZCOS WITH _NEW_PRZCOS
	
	*_cCODART = DIS_CODART
	_cCODART = ART_CODPRI  && ERASMO - 21/11/2022
	_c_NEW_PRZCOS = STRTRAN(ALLTRIM(STR(_NEW_PRZCOS,17,6)),",",".")
	_c_NEW_COSMAT = STRTRAN(ALLTRIM(STR(_NEW_COSMAT,17,6)),",",".")
	
	Usql = "UPDATE U_ART_PR SET ART_PRZCOS = " + _c_NEW_PRZCOS + ", ART_COSMAT = " + _c_NEW_COSMAT + " WHERE ART_CODPRI = '" + ALLTRIM(_cCODART) + "'"
	IF !ExecCommand(Usql,"UPD_ART_PR")
	   return(.f.)
	ENDIF
ENDSCAN
