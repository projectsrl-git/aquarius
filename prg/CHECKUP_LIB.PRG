*** CHECKUP FATTURE
cSql=""     
cNomeCursorSql="CHECK_FATTURE"

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

SELECT	
	ORD_DATORD,
	COUNT(*) AS QUANTE_FATTURE, 
	SUM(ORD_VALORE) AS AQ_FC_VALOR ,
	SUM(ORD_QTANR) AS AQ_FC_QTANR,
	SUM(ORD_QTAKG) AS AQ_FC_QTAKG,
	SUM(ORD_QTAMC) AS AQ_FC_QTAMC,
	SUM(ORD_QTAMQ) AS AQ_FC_QTAMQ,
	SUM(ORD_QTAML) AS AQ_FC_QTAML 
FROM(
	SELECT 
		ORD_NUMORD,
		ORD_DATORD,
		TT.ORD_VALORE ,
		SUM(ORD_NUMBOB) AS ORD_QTANR,
		SUM(ORD_QTAKG) AS ORD_QTAKG,
		SUM(ORD_QTAMC) AS ORD_QTAMC,
		SUM(ORD_QTAMQ) AS ORD_QTAMQ,
		SUM(ORD_QTAML) AS ORD_QTAML 
	FROM U_FAT_TT AS TT
	LEFT OUTER JOIN U_FAT_DD AS DD
	ON TT.TAGGANCIO=DD.DAGGANCIO AND ORD_CODART <>'' AND ORD_DESART<>'*** COMMENTO ***'
	GROUP BY ORD_DATORD,TAGGANCIO ,ORD_NUMORD,TT.ORD_VALORE ) AS T1
WHERE ORD_DATORD='<<_DATA_CHECKUP>>'
GROUP BY ORD_DATORD
ORDER BY ORD_DATORD 

	
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF




*** AGGIORNO TABELLA AQUARIUS

cSql      = "SELECT * FROM AQUARIUS WHERE AQ_DATA = '"+_DATA_CHECKUP+"' "
IF !ExecRW(cSql,"AQUARIUS","R")
	RETURN(.F.)
ENDIF


SELECT AQUARIUS
IF EOF()
	APPEND BLANK
	REPLACE AQ_DATA WITH _DATA_CHECKUP
ENDIF

SELECT CHECK_ORDINI
IF !EOF()
	SCATTER MEMVAR
	SELECT AQUARIUS
	GATHER MEMVAR
ENDIF


SELECT CHECK_DDT
IF !EOF()
	SCATTER MEMVAR
	SELECT AQUARIUS
	GATHER MEMVAR
ENDIF


SELECT CHECK_FATTURE
IF !EOF()
	SCATTER MEMVAR
	SELECT AQUARIUS
	GATHER MEMVAR
ENDIF

IF !ExecRW(cSql,"AQUARIUS","W")
	RETURN(.F.)
ENDIF	




*** CHECK GIORNALIERO DOPO AGGIORNAMENTO
cSql=""     
cNomeCursorSql="CHECK_GIORNALIERO"

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

SELECT * FROM AQUARIUS WHERE AQ_DATA = '<<_DATA_CHECKUP>>'
	
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT CHECK_GIORNALIERO
IF !EOF()
	BROWSE NORMAL
ENDIF
