*********************************************
PROCEDURE CHECKUP_GIORNALIERO 
*********************************************

LPARAMETERS _P_DATA_CKECKUP

LOCAL _DATA_CHECKUP

IF PCOUNT()<1
	_DATA_CHECKUP = RIBALTA2(DTOC(DATE()))
ELSE
	_DATA_CHECKUP = RIBALTA2(_P_DATA_CKECKUP)
ENDIF


*** CHECKUP ORDINI
cSql=""     
cNomeCursorSql="CHECK_ORDINI"

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

SELECT	
	ORD_DATORD,
	COUNT(*) AS QUANTI_ORDINI, 
	SUM(ORD_VALORE) AS AQ_OC_VALOR ,
	SUM(ORD_QTANR) AS AQ_OC_QTANR,
	SUM(ORD_QTAKG) AS AQ_OC_QTAKG,
	SUM(ORD_QTAMC) AS AQ_OC_QTAMC,
	SUM(ORD_QTAMQ) AS AQ_OC_QTAMQ,
	SUM(ORD_QTAML) AS AQ_OC_QTAML 
FROM(
	SELECT 
		ORD_NUMORD,
		ORD_DATORD,
		TT.ORD_VALORE ,
		SUM(ORD_NUMBOB) AS ORD_QTANR,
		SUM(ORD_QTAKG) AS ORD_QTAKG,
		SUM(ORD_QTAMC) AS ORD_QTAMC,
		SUM(ORD_QTAMQ) AS ORD_QTAMQ,
		SUM(ORD_QTAML) AS ORD_QTAML 
	FROM U_ORD_TT AS TT
	LEFT OUTER JOIN U_ORD_DD AS DD
	ON TT.TAGGANCIO=DD.DAGGANCIO AND ORD_CODART <>'' AND ORD_DESART<>'*** COMMENTO ***'
	GROUP BY ORD_DATORD,TAGGANCIO ,ORD_NUMORD,TT.ORD_VALORE ) AS T1
WHERE ORD_DATORD='<<_DATA_CHECKUP>>'
GROUP BY ORD_DATORD
ORDER BY ORD_DATORD 
	
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF



