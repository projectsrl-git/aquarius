************************************
* ASSISTENZA TECNICA PROJECT
************************************

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO
PUBLIC V_TITOLO

V_TITOLO	= "Assistenza tecnica "

WAIT WINDOWS "ESEGUE PROGRAMMA ASSISTENZA TECNICA" TIMEOUT 3

*** REPORT RIEPILOGO
cSql=""     
cNomeCursorSql="CU_ASSISTENZA"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

SELECT 
        MOV_CONTO,
		(SELECT CON_DESCR FROM CONTI WHERE CON_ANNO=MOV.MOV_ANNO AND  CON_CONTO=MOV.MOV_CONTO) AS DESCRIZIONE_CONTO,
		MOV_NREGIS, 
		MOV_DTREG,
		MOV_NDOC,
		MOV_DTDOC,
	    MOV_TOP,
		MOV_TMOV,
		MOV_IMP
		FROM MOV_CONT AS MOV
	LEFT OUTER JOIN PARA AS PARA1
	ON 'TOP'+MOV.MOV_TOP = PARA1.CODICE
	WHERE MOV_DTREG BETWEEN 
		--convert(varchar, year(GETDATE()), 111)+'/'+
		--IIF (len((convert(varchar, month(GETDATE()), 111)))=1, '0'+convert(varchar, month(GETDATE()), 111), 
		--convert(varchar, month(GETDATE()), 111)) +'/01'
		convert(varchar, DATEADD(day, -1, GETDATE()), 111)
	AND
	convert(varchar, GETDATE(), 111)
	AND MOV_CONTO IN (SELECT (CAST(ITALIANO AS varchar)) FROM PARA WHERE CODICE LIKE 'CONFOR%')
	AND (SUBSTRING(PARA1.LIBERA,2,1)='S' OR SUBSTRING(PARA1.LIBERA,2,1)='P')


ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


SELECT CU_ASSISTENZA

_PDF_REPORT_ 		=ALLTRIM(CERCAREPO("XXX","ASSISTENZA_TECNICA_PROJECT","ASSISTENZA_TECNICA_PROJECT.FRX"))
_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "CU_ASSISTENZA"

IF !EMPTY(_PDF_SUBDIR_ )
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
