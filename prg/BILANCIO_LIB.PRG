			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA12,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV12,
			SUM(DARE_PREV) AS PRE_IMP_D,
