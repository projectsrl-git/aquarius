**************************************************************************
PROCEDURE BILANCIO_CARICA_PRIMA_NOTA
**************************************************************************
LPARAMETERS _PAR_ANNO_INIZIALE,_PAR_MESE_INIZIALE ,_PAR_ANNO_FINALE,_PAR_MESE_FINALE ,_CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI,__ESCLUDE_RATEI_RISCONTI 

LOCAL _V_DARE,_V_AVERE ,_V_MESE_INIZIALE ,_V_MESE_FINALE,_CALBIL_MOVIMENTI_CONTABILI_ELABORATI 

_V_MESE_INIZIALE = PADL(ALLTRIM(STR(_PAR_MESE_INIZIALE ,2,0)),2,"0")     
_V_MESE_FINALE   = PADL(ALLTRIM(STR(_PAR_MESE_FINALE ,2,0)),2,"0")  

WAIT WINDOW "Caricamento movimenti contabili in corso esercizio contabile "+PUB_ANNO+" attendere prego..."  NOWAIT  

&& NON TRATTA I MOVIMENTI DI CHIUSURA
X_COND_CHIUSURA =" AND MOV_TOP <> 'CHI' "

**=> ERASMO - INIZIO 15/05/2026
_TOP_CHI_IMP = TOP_CHIUSURA_MOVIMENTI_CONTABILI_IMPORTATI()
IF !EMPTY(_TOP_CHI_IMP)
	X_COND_CHIUSURA = X_COND_CHIUSURA + " AND MOV_TOP <> '" + _TOP_CHI_IMP + "' "
ENDIF
**=> ERASMO - FINE 15/05/2026

cSql=""     
cNomeCursorSql="BIL_MOV_CONT"

**=> ERASMO - INIZIO 29/01/2020
_GG_AL = "31"
IF TYPE("PUB_GIORNO_AL_NON_FINE_MESE_BILANCIO_VERIFICA") == 'C'
	IF !EMPTY(PUB_GIORNO_AL_NON_FINE_MESE_BILANCIO_VERIFICA)
		_GG_AL = PADL(PUB_GIORNO_AL_NON_FINE_MESE_BILANCIO_VERIFICA,2,"0")
	ENDIF
ENDIF
**=> ERASMO - FINE 29/01/2020

TEXT TO cSql NOSHOW

SELECT 
	MOV_SOC,
	MOV_ANNO,
	MOV_CONTO,
	MOV_NREGIS, 
	MOV_DTREG ,
	MOV_IMP,
	MOV_TMOV,
	MOV_VALUTA,
	MOV_CAMBIO,
	MOV_REGAUT,
	MOV_CONTABILITA_PREVISIONALE 
FROM MOV_CONT 
WHERE MOV_SOC='<<PUB_CODSOC>>' 
AND MOV_DTREG BETWEEN '<<_PAR_ANNO_INIZIALE>>/<<_V_MESE_INIZIALE>>/01' AND '<<_PAR_ANNO_FINALE>>/<<_V_MESE_FINALE>>/<<_GG_AL>>' <<X_COND_CHIUSURA>>

ENDTEXT

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF	

_CALBIL_MOVIMENTI_CONTABILI_ELABORATI =0

SELECT BIL_MOV_CONT
GO TOP

DO WHILE !EOF()
  
	_V_DARE  = 0
	_V_AVERE  = 0

	IF MOV_TMOV  = "D" .OR. MOV_TMOV  = "A"
	ELSE
	WAIT WINDOW "Registrazione senza D/A"+STR(MOV_NREGIS,10,0)+"<<<<<<<<<<<<"
		SELECT BIL_MOV_CONT
		SKIP +1
		LOOP
	ENDIF

    SELECT BIL_MOV_CONT
    
    IF PUB_VALRIF ='EUR' AND MOV_VALUTA ='EUR'
		_V_VALORE= MOV_IMP
	ELSE
		_V_VALORE=CAMBIO(MOV_VALUTA,MOV_IMP,MOV_CAMBIO,(MOV_SOC+MOV_ANNO+MOV_CONTO),.F.,10) 
	ENDIF
	
	DO CASE
	
		CASE MOV_TMOV  = "D"
			_V_DARE =   _V_VALORE
			
		CASE MOV_TMOV  = "A"
			_V_AVERE =  _V_VALORE

	ENDCASE

    SELECT BIL_MOV_CONT
 
	_V_CONTO 	= MOV_CONTO 
	_V_DATAREG	= MOV_DTREG 
 
	IF MOV_CONTABILITA_PREVISIONALE = 'P'  		

	    IF __ESCLUDE_RATEI_RISCONTI 
	    	IF ALLTRIM(MOV_REGAUT) <> "RAT-RIS"
				DO BILANCIO_RICALCOLA_PREVISIONALI WITH _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG
			ENDIF
	    ELSE
			IF _CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI   		
				DO BILANCIO_RICALCOLA_PREVISIONALI WITH _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG
			ENDIF
		ENDIF

	ELSE
		DO BILANCIO_RICALCOLA_EFFETTIVI WITH _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG
	ENDIF 

	_CALBIL_MOVIMENTI_CONTABILI_ELABORATI = _CALBIL_MOVIMENTI_CONTABILI_ELABORATI + 1

	SELECT BIL_MOV_CONT
	SKIP +1
   
ENDDO



RETURN




**************************************************************************
PROCEDURE BILANCIO_RICALCOLA_EFFETTIVI
**************************************************************************
LPARAMETERS _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG

LOCAL _FLAG_PREVISIONALE

_FLAG_PREVISIONALE = .F.

DO BILANCIO_AGGIORNA_SINGOLO_MESE WITH _V_CONTO,_FLAG_PREVISIONALE,_V_DARE,_V_AVERE ,_V_DATAREG



**************************************************************************
PROCEDURE BILANCIO_RICALCOLA_PREVISIONALI
**************************************************************************
LPARAMETERS _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG

LOCAL _FLAG_PREVISIONALE

_FLAG_PREVISIONALE = .T.

DO BILANCIO_AGGIORNA_SINGOLO_MESE WITH _V_CONTO,_FLAG_PREVISIONALE,_V_DARE,_V_AVERE ,_V_DATAREG



**************************************************************************
PROCEDURE BILANCIO_AGGIORNA_SINGOLO_MESE
**************************************************************************
LPARAMETERS _V_CONTO,_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG

*!* AGGIORNA SALDO CONTO DI TIPO ELEMENTARE SU CU_CONTI
DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI  WITH _V_CONTO,_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG

*!*	*!* AGGIORNA SALDO CONTO DI TIPO SOTTOGRUPPO SU CU_CONTI
*!*	DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI  WITH ALLTRIM(SUBSTR(_V_CONTO,1,PUB_SOTTOG-1)),_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG

*!*	*!* AGGIORNA SALDO CONTO DI TIPO MASTRO SU CU_CONTI
*!*	DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI  WITH ALLTRIM(SUBSTR(_V_CONTO,1,PUB_MASTRO-1)),_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG

**=> ERASMO - INIZIO 26/10/2021
IF !PUB_CONTOSIMILCEE
	*!* AGGIORNA SALDO CONTO DI TIPO SOTTOGRUPPO SU CU_CONTI
	DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI  WITH ALLTRIM(SUBSTR(_V_CONTO,1,PUB_SOTTOG-1)),_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG

	*!* AGGIORNA SALDO CONTO DI TIPO MASTRO SU CU_CONTI
	DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI  WITH ALLTRIM(SUBSTR(_V_CONTO,1,PUB_MASTRO-1)),_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG
ELSE
	*!* INNESCA LA PROCEDURA RICORSIVA DI AGGIORNAMENTO SALDO DEGLI N LIVELLI SUPERIORI SU CU_CONTI
	DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI_LIVELLO_SUPERIORE WITH _V_CONTO,_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG
ENDIF
**=> ERASMO - INIZIO 26/10/2021


**************************************************************************
PROCEDURE BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI  
**************************************************************************
LPARAMETERS _V_CONTO,_V_FLAG_PREVISIONALE,_V_DARE ,_V_AVERE ,_V_DATAREG

LOCAL ___SEEK ,MESEXX ,_SAVE_SEL  

_SAVE_SEL  =SELECT()

SELECT CU_CONTI  
SET ORDER TO I_CONTO
___SEEK = PUB_CODSOC+PUB_ANNO+ALLTRIM(_V_CONTO)
SEEK ___SEEK 

IF !FOUND()
    WAIT WINDOW "Ricalcola bilancio - Conto inesistente :"+___SEEK 
    SELECT(_SAVE_SEL)
    RETURN 
ENDIF
	
MESEXX   = SUBSTR(_V_DATAREG,6,2)

IF _V_FLAG_PREVISIONALE
*** AGGIORNAMENTO SINGOLO MESE PREVISIONALE
	D_ARE    = "PRE_DA"+MESEXX
	A_VERE   = "PRE_AV"+MESEXX
	P_IMPD   = "PRE_IMP_D"
	P_IMPA   = "PRE_IMP_A"
ELSE
*** AGGIORNAMENTO SINGOLO MESE EFFETTIVO
	D_ARE    = "CON_DA"+MESEXX
	A_VERE   = "CON_AV"+MESEXX
	P_IMPD   = "CON_IMP_D"
	P_IMPA   = "CON_IMP_A"
ENDIF

_V_DARE= ROUND(_V_DARE,2)

_V_AVERE= ROUND(_V_AVERE,2)

IF _V_DARE<> 0
   REPLACE &D_ARE      	WITH &D_ARE		+_V_DARE && SINGOLO MESE
   REPLACE &P_IMPD   	WITH &P_IMPD	+_V_DARE && TOTALE
ENDIF

IF _V_AVERE<> 0
   REPLACE &A_VERE     	WITH &A_VERE	+_V_AVERE && SINGOLO MESE
   REPLACE &P_IMPA		WITH &P_IMPA 	+_V_AVERE && TOTALE
ENDIF	 
	
	
SELECT(_SAVE_SEL)
RETURN 	



**=> ERASMO - INIZIO 26/10/2021
**************************************************************************
PROCEDURE BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI_LIVELLO_SUPERIORE
**************************************************************************
LPARAMETERS _V_CONTO,_V_FLAG_PREVISIONALE,_V_DARE ,_V_AVERE ,_V_DATAREG

LOCAL ___SEEK ,MESEXX ,_SAVE_SEL  

_SAVE_SEL  =SELECT()


*** COMPONGO IL CONTO DEL LIVELLO SUPERIORE
_CONTO = ALLTRIM(_V_CONTO)
_NR_PUNTI = OCCURS('.',_CONTO)
_NR_OCCORRENZA = 0
IF RIGHT(_CONTO,1) = '.'  && SE L'ULTIMO CARATTERE E' UN PUNTO
	_NR_OCCORRENZA = _NR_PUNTI - 1
ELSE
	_NR_OCCORRENZA = _NR_PUNTI
ENDIF

IF _NR_OCCORRENZA = 0  && SE IL CONTO PASSATO NON HA CONTI PADRE, ALLORA E' UN MASTRO QUINDI NON CONTINUO CON L'AGGIORNAMENTO
	RETURN
ENDIF

_CONTO_DA_AGGIORNARE = SUBSTR(_CONTO,1,AT('.',_CONTO,_NR_OCCORRENZA))  && CONTO DEL LIVELLO SUPERIORE

IF EMPTY(_CONTO_DA_AGGIORNARE)
	RETURN
ENDIF



SELECT CU_CONTI  
SET ORDER TO I_CONTO
___SEEK = PUB_CODSOC+PUB_ANNO+ALLTRIM(_CONTO_DA_AGGIORNARE)
SEEK ___SEEK 

IF !FOUND()
    WAIT WINDOW "Ricalcola bilancio - Conto inesistente :"+___SEEK 
    SELECT(_SAVE_SEL)
    RETURN 
ENDIF
	
MESEXX   = SUBSTR(_V_DATAREG,6,2)

IF _V_FLAG_PREVISIONALE
*** AGGIORNAMENTO SINGOLO MESE PREVISIONALE
	D_ARE    = "PRE_DA"+MESEXX
	A_VERE   = "PRE_AV"+MESEXX
	P_IMPD   = "PRE_IMP_D"
	P_IMPA   = "PRE_IMP_A"
ELSE
*** AGGIORNAMENTO SINGOLO MESE EFFETTIVO
	D_ARE    = "CON_DA"+MESEXX
	A_VERE   = "CON_AV"+MESEXX
	P_IMPD   = "CON_IMP_D"
	P_IMPA   = "CON_IMP_A"
ENDIF

_V_DARE= ROUND(_V_DARE,2)

_V_AVERE= ROUND(_V_AVERE,2)

IF _V_DARE<> 0
   REPLACE &D_ARE      	WITH &D_ARE		+_V_DARE && SINGOLO MESE
   REPLACE &P_IMPD   	WITH &P_IMPD	+_V_DARE && TOTALE
ENDIF

IF _V_AVERE<> 0
   REPLACE &A_VERE     	WITH &A_VERE	+_V_AVERE && SINGOLO MESE
   REPLACE &P_IMPA		WITH &P_IMPA 	+_V_AVERE && TOTALE
ENDIF	 

SELECT(_SAVE_SEL)

DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI_LIVELLO_SUPERIORE WITH _CONTO_DA_AGGIORNARE,_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG

RETURN

ENDPROC
