* PROCEDURA DI SUPPORTO AL CALCOLO DEL BILANCIO
* COPIA IL CURSORE CU_BILANCIO IN UN CURSORE CU_CONTI CHE HA CON LA STESSA STRUTTURA
* DELLA TABELLA CONTI
*********************************************************************************************
RELEASE PAT_DARE	,;
	PAT_AVERE   ,;
