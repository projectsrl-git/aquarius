		ELSE
			LOOP
		ENDIF
	ENDIF
	
	X_SOCI = "CON_SOC = '" + PUB_CODSOC + "'"
	X_ANNO = "CON_ANNO = '" + M.CON_ANNO + "'"
	X_CONT = "CON_CONTO = '" + M.CON_CONTO + "'"
