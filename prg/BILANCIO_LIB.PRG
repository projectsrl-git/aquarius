*!*	   		REPLACE PRE_IMP_A WITH M.PRE_IMP_A
*!*		ENDIF		
*!*		
*!*		SELECT CONTI
*!*		SKIP 
*!*		
*!*	ENDDO

**=> ERASMO - INIZIO 09/05/2025
***************************************************************************************
*** AGGIORNAMENTO TABELLA SQL CONTI CURSORE DI LAVORO CU_CONTI (SOLO CONTI VALORIZZATI)
***************************************************************************************
SELECT CU_CONTI
GO TOP
SCAN
	SCATTER MEMVAR MEMO
	
	IF M.CON_IMP_D <> 0 OR M.CON_IMP_A <> 0
	ELSE
	    IF _CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI
	   		IF M.PRE_IMP_D <> 0 OR M.PRE_IMP_A <> 0
