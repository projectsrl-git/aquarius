			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA12,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV12
		FROM (SELECT 
				SUBSTRING(MOV_CONTO,1,<<PUB_SOTTOG-1>>) AS CONTO,
				MOV_ANNO AS ANNO,
				SUBSTRING(MOV_DTREG,6,2) AS MESE,
				SUM((CASE WHEN MOV_TMOV ='D' AND MOV_CONTABILITA_PREVISIONALE<>'P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS DARE,
				SUM((CASE WHEN MOV_TMOV ='A' AND MOV_CONTABILITA_PREVISIONALE<>'P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS AVERE,
