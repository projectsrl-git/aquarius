	*CSQL   = "SELECT * FROM CONTI WHERE " + X_COND
	CUPD   = ""
	
	FOR _CALBIL_MESE = _PAR_MESE_INIZIALE TO _PAR_MESE_FINALE 
	    
	    V_MM = PADL(ALLTRIM(STR(_CALBIL_MESE,2,0)),2,"0")
	    CUPD = CUPD + IIF(EMPTY(CUPD),"",",") + " CON_DA"+V_MM + " = " + STRTRAN(STR(M.CON_DA&V_MM,19,2),",",".")
	    CUPD = CUPD + IIF(EMPTY(CUPD),"",",") + " CON_AV"+V_MM + " = " + STRTRAN(STR(M.CON_AV&V_MM,19,2),",",".")

	    IF _CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI
		    CUPD = CUPD + IIF(EMPTY(CUPD),"",",") + " PRE_DA"+V_MM + " = " + STRTRAN(STR(M.PRE_DA&V_MM,19,2),",",".")
		    CUPD = CUPD + IIF(EMPTY(CUPD),"",",") + " PRE_AV"+V_MM + " = " + STRTRAN(STR(M.PRE_AV&V_MM,19,2),",",".")
		ENDIF

	NEXT
	
    CUPD = CUPD + IIF(EMPTY(CUPD),"",",") + " CON_IMP_D = " + STRTRAN(STR(M.CON_IMP_D,19,2),",",".")
    CUPD = CUPD + IIF(EMPTY(CUPD),"",",") + " CON_IMP_A = " + STRTRAN(STR(M.CON_IMP_A,19,2),",",".")

    IF _CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI
		CUPD = CUPD + IIF(EMPTY(CUPD),"",",") + " PRE_IMP_D = " + STRTRAN(STR(M.PRE_IMP_D,19,2),",",".")
		CUPD = CUPD + IIF(EMPTY(CUPD),"",",") + " PRE_IMP_A = " + STRTRAN(STR(M.PRE_IMP_A,19,2),",",".")
	ENDIF
	
	CSQL = "UPDATE CONTI SET " + CUPD + " WHERE " + X_COND
	IF !ExecCommand(cSql,"UPD_CONTI")
	   RETURN(.F.)
	ENDIF
ENDSCAN
