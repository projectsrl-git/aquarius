			FROM MOV_CONT 
			WHERE 
				MOV_ANNO='<<PUB_ANNO>>' AND MOV_TOP <> 'CHI' 
				<<_WHERE_CONDITION_CDC>>
			GROUP BY 
				SUBSTRING(MOV_CONTO,1,<<PUB_SOTTOG-1>>),
				MOV_ANNO,
				SUBSTRING(MOV_DTREG,6,2) ) AS T1 
		GROUP BY ANNO,CONTO) AS T2
ON 
	CONTI.CON_CONTO = T2.CONTO 
	AND CONTI.CON_ANNO = T2.ANNO 
WHERE LEN(CONTI.CON_CONTO)=<<PUB_SOTTOG-1>>	
) AS T3
