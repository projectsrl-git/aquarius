                                                                             AND LEN(CON_CONTO)<= <<PUB_SOTTOG-1>> )
        GROUP BY CON_SOC,CON_ANNO,SUBSTRING(CON_CONTO,1,<<PUB_SOTTOG>>-1),CON_POSBIL

ENDTEXT                                 && FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
