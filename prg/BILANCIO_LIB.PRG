PROCEDURE VERIFICA_ESISTENZA_GRUPPI_SOTTOGRUPPI_SU_CURSORE_CONTI
**************************************************************************


**  VERIFICA/AGGIORNA GRUPPI

cSql=""    
cNomeCursorSql="_TEMP" 

TEXT TO cSql NOSHOW      && INIZIO SCRITTURA QUERY

INSERT INTO CONTI (CON_SOC,CON_ANNO,CON_CONTO,CON_DESCR,CON_TIPOCO,CON_POSBIL)
SELECT
        CON_SOC,
        CON_ANNO,
        SUBSTRING(CON_CONTO,1,<<PUB_MASTRO>>-1) AS CON_CONTO,
        'GRUPPO CONTABILE' AS CON_DESCR,
        'X' AS CON_TIPOCO,
        CON_POSBIL
FROM CONTI AS CO
WHERE CON_ANNO='<<PUB_ANNO>>'
        AND LEN(CON_CONTO)>=<<PUB_MASTRO>>
        AND SUBSTRING(CON_CONTO,1,<<PUB_MASTRO>>-1) NOT IN (SELECT CON_CONTO FROM CONTI
                                                                             WHERE CON_ANNO='<<PUB_ANNO>>'
                                                                             AND LEN(CON_CONTO)<= <<PUB_MASTRO-1>> )
        GROUP BY CON_SOC,CON_ANNO,SUBSTRING(CON_CONTO,1,<<PUB_MASTRO>>-1),CON_POSBIL

ENDTEXT                                 && FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
        return(.f.)
ENDIF

** VERIFICA AGGIORNA SOTTOGRUPPI

cSql=""    
cNomeCursorSql="_TEMP" 

TEXT TO cSql NOSHOW      && INIZIO SCRITTURA QUERY

INSERT INTO CONTI (CON_SOC,CON_ANNO,CON_CONTO,CON_DESCR,CON_TIPOCO,CON_POSBIL)
SELECT
        CON_SOC,
