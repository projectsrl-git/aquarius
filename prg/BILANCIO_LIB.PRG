LOCAL _ROUND_DECIMAL,_REPLACE,_MESE_STRING,_SALDO_PARZIALE

*** ARROTONDO A 2 DECIMALI GLI IMPORTI IN CENTESIMI
_ROUND_DECIMAL=ALLTRIM(STR(2))
	

*** FACCIO UNA SELECT SENZA RIGHE SU CONTI PER RICAVARE LA STRUTTURA COMPLETA DELLA TABELLA

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
	SELECT * FROM CONTI WHERE 1=0
	
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"CU_CONTI")
	return(.F.)
ENDIF

PAT_DARE    = 0
PAT_AVERE   = 0
PAT_SALDO   = 0

ECO_DARE    = 0
ECO_AVERE   = 0
ECO_SALDO   = 0

TOT_DARE	= 0
TOT_AVERE	= 0
TOT_SALDO	= 0

BILANCIO_ATTIVITA =0 
BILANCIO_PASSIVITA=0
BILANCIO_RISULTATO_ECONOMICI=0
BILANCIO_COSTI=0
BILANCIO_RICAVI=0
BILANCIO_RISULTATO_PATRIMONIALI=0
BILANCIO_SALDO=0


SELECT CU_BILANCIO
GO TOP
DO WHILE !EOF()
	
	SCATTER MEMVAR MEMO
	
	SELECT CU_CONTI
	
	APPEND BLANK 
	GATHER MEMVAR MEMO
	REPLACE CON_SOC WITH PUB_CODSOC

	_REPLACE=""	
	_REPLACE="REPLACE CON_IMP_D WITH ROUND(CON_IMP_D,"+_ROUND_DECIMAL+")"
	&_REPLACE

	_REPLACE=""	
	_REPLACE="REPLACE CON_IMP_A WITH ROUND(CON_IMP_A,"+_ROUND_DECIMAL+")"
	&_REPLACE
	
	_REPLACE=""	
	_REPLACE="REPLACE PRE_IMP_D WITH ROUND(PRE_IMP_D,"+_ROUND_DECIMAL+")"
	&_REPLACE
	
	_REPLACE=""	
	_REPLACE="REPLACE PRE_IMP_A WITH ROUND(PRE_IMP_A,"+_ROUND_DECIMAL+")"
	&_REPLACE

	FOR I=1 TO 12
		_MESE_STRING=PADL(ALLTRIM(STR(I)),2,"0")
		
		_REPLACE=""	
		_REPLACE="REPLACE CON_DA"+_MESE_STRING+" WITH ROUND(CON_DA"+_MESE_STRING+","+_ROUND_DECIMAL+")"
		&_REPLACE
		
		_REPLACE=""	
		_REPLACE="REPLACE CON_AV"+_MESE_STRING+" WITH ROUND(CON_AV"+_MESE_STRING+","+_ROUND_DECIMAL+")"
		&_REPLACE
		
		_REPLACE=""	
		_REPLACE="REPLACE PRE_DA"+_MESE_STRING+" WITH ROUND(PRE_DA"+_MESE_STRING+","+_ROUND_DECIMAL+")"
		&_REPLACE
		
		_REPLACE=""	
		_REPLACE="REPLACE PRE_AV"+_MESE_STRING+" WITH ROUND(PRE_AV"+_MESE_STRING+","+_ROUND_DECIMAL+")"
		&_REPLACE
	NEXT
	
	
	_SALDO_PARZIALE=0
	
	_SALDO_PARZIALE = CON_IMP_D - CON_IMP_A 
	
	IF LEN(ALLTRIM(CON_CONTO))>=PUB_SOTTOG 
		DO CASE 
			CASE CON_POSBIL='P'
				PAT_DARE 	= PAT_DARE 	+CON_IMP_D 
				PAT_AVERE   = PAT_AVERE	+CON_IMP_A 
				
				IF _SALDO_PARZIALE  >=0 
					BILANCIO_ATTIVITA = BILANCIO_ATTIVITA +_SALDO_PARZIALE 
				ELSE
					BILANCIO_PASSIVITA= BILANCIO_PASSIVITA - _SALDO_PARZIALE 
				ENDIF
				
			CASE CON_POSBIL='E'
				ECO_DARE    = ECO_DARE 	+CON_IMP_D 
				ECO_AVERE   = ECO_AVERE +CON_IMP_A 
				
				IF _SALDO_PARZIALE  >=0 
					BILANCIO_COSTI= BILANCIO_COSTI +_SALDO_PARZIALE 
				ELSE
					BILANCIO_RICAVI= BILANCIO_RICAVI -_SALDO_PARZIALE 
				ENDIF
		ENDCASE
	ENDIF	
	
	
	SELECT CU_BILANCIO
	SKIP
	
ENDDO

SELECT CU_BILANCIO
USE

SELECT CU_CONTI
GO TOP
 

PAT_DARE 	= ROUND(PAT_DARE,2)
PAT_AVERE 	= ROUND(PAT_AVERE ,2)
ECO_DARE  	= ROUND(ECO_DARE  ,2)
ECO_AVERE   = ROUND(ECO_AVERE   ,2)

BILANCIO_ATTIVITA 	= ROUND(BILANCIO_ATTIVITA ,2)
BILANCIO_PASSIVITA 	= ROUND(BILANCIO_PASSIVITA ,2)
BILANCIO_COSTI		= ROUND(BILANCIO_COSTI,2)
BILANCIO_RICAVI 	= ROUND(BILANCIO_RICAVI ,2)

PAT_SALDO   = PAT_DARE - PAT_AVERE

ECO_SALDO   = ECO_DARE - ECO_AVERE   

TOT_SALDO   = PAT_SALDO   + ECO_SALDO   


*** FAB - 17/08/2014 ARROTONDAMENTO DEI CENTESIMI
***
*** SE HO UNO SBILANCIO MINORE DI +/- 10 CENT. FACCIO UN UPDATE DELLO SBILANCIO SU
*** 1) IL CONTO IMPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
*** 2) SE 1) NON ESISTE SU PARA OPPURE ESISTE SU PARA MA NON SU CONTI, ALLORA FACCIO UN UPDATE SUL PRIMO CONTO CHE TROVO SULL'ANNO E RICALCOLO I SALDI

IF TOT_SALDO<>0 AND ABS(TOT_SALDO) < 0.10

	_MESE_DA_AGGIORNARE="01"

	_strdelta = ALLTRIM(STRTRAN(STR(TOT_SALDO,20,2),',','.'))
	
	*** CERCO IL CONTO INPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
	
	Csql   = "SELECT * FROM PARA WHERE CODICE='CAA"+PUB_ANNO+"'"
	IF !ExecCommand(Csql,"UPD_CONTI")
	   return(.f.)
	ENDIF	
	
	SELECT UPD_CONTI
	
	_CONTO_ARROTONDAMENTI = ""
	_CONTO_ARROTONDAMENTI_PAT_ECO = "E"
	
	IF !EOF()
		_CONTO_ARROTONDAMENTI = ALLTRIM(LIBERA)
	ENDIF
	
	*** IL CONTO PER GLI ARROTONDAMENTI E' IMPOSTATO SU PARA
	*** ORA LO CERCO SU CONTI
	
	Csql   = "SELECT CON_CONTO,CON_POSBIL FROM CONTI WHERE CON_CONTO='"+_CONTO_ARROTONDAMENTI+"' AND CON_ANNO='"+PUB_ANNO+"' " 
	IF !ExecCommand(Csql,"UPD_CONTI")
	   return(.f.)
	ENDIF	
	
	SELECT UPD_CONTI
	IF EOF()
		_CONTO_ARROTONDAMENTI = ""
	ELSE
		_CONTO_ARROTONDAMENTI_PAT_ECO = CON_POSBIL	
	ENDIF	
	
	IF !EMPTY(_CONTO_ARROTONDAMENTI )
		*** FACCIO UN UPDATE SUL CONTO IMPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		Csql   = "UPDATE CU_CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO='" +_CONTO_ARROTONDAMENTI  + "' AND " + x_anno
		
		_MASTRO_CONTO_ARROTONDAMENTI = SUBSTR(ALLTRIM(_CONTO_ARROTONDAMENTI ),1,PUB_SOTTOG-1)
		*** FACCIO UN UPDATE SUL MASTRO DEL CONTO IMPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		Csql_MASTRO   = "UPDATE CU_CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO='" +_MASTRO_CONTO_ARROTONDAMENTI   + "' AND " + x_anno
	ELSE
		*** FACCIO UN UPDATE SUL PRIMO CONTO CHE TROVO SULL'ANNO E RICALCOLO I SALDI
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		x_cont = "LEN(CON_CONTO) >= "+ ALLTRIM(STR(PUB_SOTTOG))
		x_pbil = "CON_POSBIL = 'E'"
		x_cimp = "CON_IMP_D <> CON_IMP_A"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont + " and " + x_pbil + " and " + x_cimp 
		Csql   = "UPDATE CU_CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO IN " + ;
				"(SELECT TOP 1 CON_CONTO FROM CU_CONTI WHERE " + x_cond + " ORDER BY CON_CONTO ) AND " + x_anno
				
				
		*** FACCIO UN UPDATE SUL  PRIMO MASTRO CHE TROVO SULL'ANNO E RICALCOLO I SALDI
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		x_cont = "LEN(CON_CONTO) = "+ ALLTRIM(STR(PUB_SOTTOG-1))
		x_pbil = "CON_POSBIL = 'E'"
		x_cimp = "CON_IMP_D <> CON_IMP_A"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont + " and " + x_pbil + " and " + x_cimp 
		Csql_MASTRO   = "UPDATE CU_CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO IN " + ;
				"(SELECT TOP 1 CON_CONTO FROM CU_CONTI WHERE " + x_cond + " ORDER BY CON_CONTO ) AND " + x_anno
	
	ENDIF 	
	
	&Csql
	&Csql_MASTRO
	
	DO CASE
		CASE _CONTO_ARROTONDAMENTI_PAT_ECO ="P"
		
			PAT_DARE = PAT_DARE - TOT_SALDO 

			BILANCIO_ATTIVITA = BILANCIO_ATTIVITA - TOT_SALDO 
			
		CASE _CONTO_ARROTONDAMENTI_PAT_ECO ="E"
		
			ECO_DARE = ECO_DARE - TOT_SALDO 
			
			BILANCIO_COSTI = BILANCIO_COSTI - TOT_SALDO 
	ENDCASE
	
	PAT_SALDO   = PAT_DARE - PAT_AVERE

	ECO_SALDO   = ECO_DARE - ECO_AVERE   

	TOT_SALDO   = PAT_SALDO   + ECO_SALDO   	

	
ENDIF

BILANCIO_RISULTATO_PATRIMONIALI	=BILANCIO_ATTIVITA 	- 	BILANCIO_PASSIVITA

BILANCIO_RISULTATO_ECONOMICI	=BILANCIO_COSTI		-	BILANCIO_RICAVI

BILANCIO_SALDO=ABS(BILANCIO_RISULTATO_PATRIMONIALI)	- ABS( BILANCIO_RISULTATO_ECONOMICI	)

SELECT CU_CONTI
GO TOP

RETURN


