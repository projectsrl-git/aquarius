		x_csys = "ord_codsys = '" + M.ORD_LEGASY + "'"
		x_cond = x_agga + " and " + x_csys
		cSql   = "SELECT * FROM U_ORF_DD WHERE " + x_cond
		IF !ExecRW(cSql,"U_ORF_DD","R")
			return(.f.)
		ENDIF 
		SELECT U_ORF_DD
		GO TOP
		IF EOF()
		ELSE
			REPLACE ORD_QTAEV WITH ORD_QTAEV + M.ORD_QTAORD
			IF M.ORD_SALCON = 'S'
				REPLACE ORD_CHIUSO WITH .T.
			ELSE
				REPLACE ORD_CHIUSO WITH .F.
			ENDIF
			REPLACE ORD_SALCON WITH M.ORD_SALCON
		ENDIF
		IF !ExecRW(cSql,"U_ORF_DD","W")
			return(.f.)
		ENDIF
		
		x_agga = "daggancio = '" + M.ORD_LEGAME + "'"
		x_cond = x_agga
		cSql	= "SELECT ORD_QTAEV,ORD_QTAORD,ORD_CHIUSO FROM U_ORF_DD WHERE " + x_cond
		IF !ExecCommand(cSql,"TMP_ORF_DD")
			return(.f.)
		ENDIF 
		V_OPEN = .F.
		SELECT TMP_ORF_DD
		GO TOP
		DO WHILE .T.
			IF EOF()
				EXIT
			ENDIF
			IF ORD_QTAEV < ORD_QTAORD 
				IF ORD_CHIUSO
				ELSE
					V_OPEN = .T.
					EXIT
				ENDIF
			ENDIF
			SKIP +1
		ENDDO
		x_agga = "taggancio = '" + M.ORD_LEGAME + "'"
		x_cond = x_agga 
		cSql	= "SELECT * FROM U_ORF_TT WHERE " + x_cond
		IF !ExecRW(cSql,"U_ORF_TT","R")
			return(.f.) 
		ENDIF 
		SELECT U_ORF_TT
		GO TOP
		IF EOF()
		ELSE
			IF V_OPEN
				REPLACE ORD_CHIUSO WITH .F.
			ELSE
				REPLACE ORD_CHIUSO WITH .T.
			ENDIF
		ENDIF
		IF !ExecRW(cSql,"U_ORF_TT","W")
			return(.f.)
		ENDIF
		
		SELECT CX_BFO_DD
		SCATTER MEMVAR
		
		VV_DAGGANCIO = M.DAGGANCIO
		VV_DLEGAME	= M.ORD_LEGASY

		x_agga = "daggancio = '" + M.DAGGANCIO + "'"
		x_aggo = "ord_aggorf = '" + M.ORD_LEGAME + "'"
		x_syso = "ord_sysorf = '" + M.ORD_LEGASY + "'"
		x_cond = x_agga + " and " + x_aggo + " and " + x_syso 
		cSql   = "select * from u_bfo_dl where " + x_cond
		IF !ExecCommand(cSql,"CX_BFO_DL")
			return(.f.)
		ENDIF
		SELECT CX_BFO_DL
		GO TOP
		SCAN
			SCATTER MEMVAR
				
			x_lega = "dlegame = '" + M.DLEGAME + "'"
			x_agga = "daggancio = '" + M.ORD_AGGORF + "'"
			x_csys = "ord_codsys = '" + M.ORD_CODORF + "'"
			x_cond = x_lega + " and " + x_agga + " and " + x_csys
			cSql	= "select * from u_orf_dl where " + x_cond
			IF !ExecRW(cSql,"U_ORF_DL","R")
				return(.f.)
			ENDIF
			SELECT U_ORF_DL
			GO TOP
			IF EOF()
			ELSE
				IF ORD_UM = 'KG'
					V_QTACTRL = ORD_QTAKG
				ELSE
					V_QTACTRL = ORD_QTAMQ
				ENDIF
				IF V_QTACTRL > 0
					REPLACE ORD_QTAKGE WITH ORD_QTAKGE + M.ORD_QTAKG
					REPLACE ORD_QTAMQE WITH ORD_QTAMQE + M.ORD_QTAMQ
					REPLACE ORD_QTAMLE WITH ORD_QTAMLE + M.ORD_QTAML
				ENDIF
				REPLACE ORD_SALCON WITH M.ORD_SALCON
				IF M.ORD_SALCON = 'S'
					REPLACE ORD_CHIUSO WITH .T.
				ELSE
