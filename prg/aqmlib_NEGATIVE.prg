**********************************
FUNCTION AQM_RICARICA_IL_MAGAZZINO
**********************************

LPARAMETERS _cCursorName

IF PCOUNT() > 0
ELSE
	_cCursorName = "CU_BOL_DD"
ENDIF

*!*	(+++++) CREA IL MOVIMENTO DI RI CARICO PER LA QUANTITA' IN PRECEDENZA MOVIMENTATA SU U_MAG_MO
*!*	(+++++) SOMMA LA QUANTITA' IN PRECEDENZA MOVIMENTATA SU U_MAG_GG
*!*	(+++++) SE U_MAG_GG NON ESISTE LO RICREA

_SEL_CURSOR=SELECT()

RELEASE LOCAL_CODSYS_RIGA_DDT								&& DEFINITA PER SICUREZZA SOLO IN QUESTO PUNTO : LA ROUTIN AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI
PUBLIC LOCAL_CODSYS_RIGA_DDT								&& VIENE CHIAMATA DIVERSE VOLTE PER CUI PERDO LA VARIABILE
LOCAL_CODSYS_RIGA_DDT= ""


=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

ORD_SYSMAG_RIGENERATO 	= SYS(2015)							&& POSSO GESTIRE PIU RECORD U_MAG_MO , IL LEGSYS RIGENERATO DEVE ESSERE UNICO
AQM_LEGSYS				= ORD_SYSMAG_RIGENERATO 			&& SER-01 RIGENERA ORD_SYSMAG PER LEGARE LA RIGA DDT AL NUOVO U_MAG_MO CHE CREO

SELECT &_cCursorName
LOCAL_CODSYS_RIGA_DDT		= ORD_CODSYS
LOCAL_LEGSYS 				= ORD_SYSMAG
LOCAL_QTAORD 				= ORD_QTAORD
LOCAL_QTAMQ  				= ORD_QTAMQ
LOCAL_QTAKG  				= ORD_QTAKG
LOCAL_QTAML  				= ORD_QTAML
LOCAL_QTAMC  				= ORD_QTAMC  && ERASMO - 13/06/2012
LOCAL_CAUS_DDT				= ORD_CAUS	
LOCAL_MAGA_DDT				= ORD_MAGA	

*!*	_e_cond = "mov_legsys = '" + LOCAL_LEGSYS + "'"	
*!*	Csql        = "select * from u_mag_mo where " + _e_cond + " order by mov_codart"
*!*	IF !ExecCommand(cSql,"LOCAL_U_MAG_MO")
*!*		return(.f.)
*!*	ENDIF
x_lsys  = "mov_legsys = '" + LOCAL_LEGSYS + "'"
*x_cmag  = "mov_codmag = '" + LOCAL_MAGA_DDT + "'"
*_e_cond = x_lsys + " and " + x_cmag
_e_cond = x_lsys  && ERASMO - 09/07/2012
Csql    = "select * from u_mag_mo where " + _e_cond + " order by mov_codart"
IF !ExecCommand(cSql,"LOCAL_U_MAG_MO")
	return(.f.)
ENDIF

SELECT LOCAL_U_MAG_MO
GO TOP       

*!*	IF EOF()	&& NON PU0' ESISTERE QUESTO CASO SONO IN MODIFICA DELLA DDT
*!*	    SELECT(_SEL_CURSOR)
*!*		RETURN(.T.)
*!*	ENDIF



DO WHILE .NOT. EOF()
	
	SELECT LOCAL_U_MAG_MO
	
	DO AQM_CONTRASSEGNA_MOVIMENTO_DOCMOD WITH MOV_UNIQUE
	
	AQM_QTAMOV_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = MOV_QTAMOV 
	*AQM_QTAMQ_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  = MOV_QTAMQ  
	*AQM_QTAKG_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  = MOV_QTAKG  	
	*AQM_QTAML_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  = MOV_QTAML  
	**=> ERASMO - INIZIO 13/06/2012
	AQM_QTAMQ_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = MOV_QTAMQ  
	AQM_QTAKG_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = MOV_QTAKG  	
	AQM_QTAML_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = MOV_QTAML  
	AQM_QTAMC_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = MOV_QTAMC  
	**=> ERASMO - FINE 13/06/2012


	*!*	___________________________________________________________________________________________________________ RICARICA VECCHIA GIACENZA  ### PIU-PIU-PIU ###

	SELECT LOCAL_U_MAG_MO
	SCATTER MEMVAR MEMO
	M.ID_UNIQUE = ""
	LOCAL_LEGAME = M.MOV_LEGAME														&& SYS DI AGGANCIO A U_MAG_GG		
	M.MOV_TOP 	=	 PUB_MPIU														&& SOSTITUISCO IL TOP IN QUANTO STO RICARICANDO LA VECCHIA GIACENZA

	=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
	=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_MOVIMENTO_MAGAZZINO")		
    AQM_SAVE_LEGSYS 		= ""
    LOCAL_IDUNIQUE			= ""
 	LOCAL_DATAOGGI   		= RIBALTA2(DTOC(DATE()))
 
	ORIGINALE_AQM_GIACEN 	= AQM_GIACEN											&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE									
	ORIGINALE_AQM_QTAKG  	= AQM_QTAKG												&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE						
	ORIGINALE_AQM_QTAMQ  	= AQM_QTAMQ												&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE															
	ORIGINALE_AQM_QTAML  	= AQM_QTAML												&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE									
	ORIGINALE_AQM_QTAMC  	= AQM_QTAMC  && ERASMO - 13/06/2012

	ORIGINALE_AQM_LEGAME	= AQM_LEGAME											&& ORIGINALE DA MOVIMENTO DI CARICO
	ORIGINALE_AQM_NUMIDE 	= AQM_NUMIDE											&& ORIGINALE DA MOVIMENTO DI CARICO
    ORIGINALE_AQM_PREACQ    = AQM_PREACQ											&& ORIGINALE DA MOVIMENTO DI CARICO


	=ACCESSO_PARAMETRO_TOP()														&& ACCESSI ANAGRAFICI
	=ACCESSO_ANAGRAFICA_FORNITORE()
	=ACCESSO_ANAGRAFICA_CLIENTE()
	=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)
 
    *AQM_LEGSYS				= SYS(2015)									 			&& LEGSYS SUL MOVIMENTO DI CARICO AUTOMATICO DEVE ESSERE DIVERSO DAL LEGSYS DELLA RIGA DDT ALTRIMENTI AL GIRO SUCCESSIVO LO RISOMMA

    LOCAL_MOVIMENTO = "CREA-MOVIMENTO"							
	=AQM_CREA_U_MAG_MO(LOCAL_MOVIMENTO,.T.)												&& CREA IL MOVIMENTO DI RICARICO DELLA QUANTITA ORIGNALE DELLA DDT
    
    *** RIGA SEGUENTE ASTERISCATA: LA GIACENZA CHE RICARICO, SE DEVE ESSERE CREATA EX-NOVO DEVE AVERE LO STESSO LEGSYS DEL MOVIMENTO DI RICARICO APPENA EFFETTUATO
    *AQM_LEGSYS				= ORD_SYSMAG_RIGENERATO 								&& SER-01 RIGENERA ORD_SYSMAG PER LEGARE LA RIGA DDT AL NUOVO U_MAG_MO CHE CREO



 	_e_cond = "mag_legame = '" + LOCAL_LEGAME + "'"	
	Csql    = "select * from u_mag_gg where " + _e_cond + " order by mag_codart"
	IF !ExecRW(Csql,"u_mag_gg","R")
		   return(.f.)
	ENDIF

    SELECT U_MAG_GG
    IF !EOF()

		_FUNZIONE  				= "AGGIORNA-U-MAG-GG"								&& AGGIORNA U_MAG_GG SOMMANDO LE QUANTITA' CHE DEVO RICARICARE
		
    	AQM_SAVE_LEGSYS  	= MAG_LEGSYS											&& LEGA IL MOVIMENTO U_MAG_MO ALLA DDT U_BOL_DD 
    	LOCAL_IDUNIQUE		= ID_UNIQUE
		AQM_GIACEN  		= AQM_QTAMOV_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT 
		*AQM_QTAMQ			= AQM_QTAMQ_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		*AQM_QTAKG			= AQM_QTAKG_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		*AQM_QTAML			= AQM_QTAML_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		**=> ERASMO - INIZIO 13/06/2012
		AQM_QTAMQ = AQM_QTAMQ_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		AQM_QTAKG = AQM_QTAKG_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		AQM_QTAML = AQM_QTAML_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		AQM_QTAMC = AQM_QTAMC_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		**=> ERASMO - FINE 13/06/2012
    	
    	=AQM_SOMMA()

		IF !ExecRW(cSql,"U_MAG_GG","W")												&& RICARICA LA GIACENZA SU U_MAG_GG	CON LA QUANTITA' IN PRECEDENZA MOVIMENTATA									
		   return(.f.)
		ENDIF

	ELSE

 
 		**!*	___________________________________________________________________________________________________________ CREA SOLO U_MAG_GG SE NON ESISTE
		*_FUNZIONE  				= "CREA-U-MAG-GG"										&& CREA U_MAG_GG SOMMANDO LE QUANTITA' CHE DEVO RICARICARE
    	*AQM_SAVE_LEGSYS  		= AQM_LEGSYS											&& LEGA IL MOVIMENTO U_MAG_MO ALLA DDT U_BOL_DD  
		*_IMPEGNI   				= "NON-AGGIORNA-IMPEGNI"								&& NON AGGIORNA GLI IMPEGNI DI MAGAZZINO-PRENOTATO
		*_MOVIMENTO 				= "NON-CREA-MOVIMENTO"									&& NON CREA U_MAG_MO
		*_IDUNIQUE  				= LOCAL_IDUNIQUE										&& AGGANCIO AL RECORD DI MAGAZZINO PER L'AGGIORNAMENTO
		*_SEGNO     				= "+"													&& MOVIMENTO DI CARICO
		*AQM_GIACEN  			= AQM_QTAMOV_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT 	&& QTA DDT DA RICARICARE
		**AQM_QTAMQ				= AQM_QTAMQ_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  	&& QTA DDT DA RICARICARE
		**AQM_QTAKG				= AQM_QTAKG_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  	&& QTA DDT DA RICARICARE
		**AQM_QTAML				= AQM_QTAML_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  	&& QTA DDT DA RICARICARE 
		*AQM_TOP					= PUB_MPIU												&& CAUSALE DI RICARICO MAGAZZINO   
		*ORIGINALE_AQM_CODFOR	= AQM_CODFOR
		*ORIGINALE_AQM_DESFOR 	= AQM_DESFOR
		*ORIGINALE_AQM_GIACEN  	= AQM_QTAMOV_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT 
		**ORIGINALE_AQM_QTAMQ   	= AQM_QTAMQ_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		**ORIGINALE_AQM_QTAKG		= AQM_QTAKG_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		**ORIGINALE_AQM_QTAML		= AQM_QTAML_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  	
		*ORIGINALE_AQM_SC1		= AQM_SC1
		*ORIGINALE_AQM_SC2		= AQM_SC2
		*ORIGINALE_AQM_SC3		= AQM_SC3
		*ORIGINALE_AQM_SC4		= 0
		*ORIGINALE_AQM_SC5		= 0
		*ORIGINALE_AQM_PREACQ 	= AQM_PREACQ						
		*ORIGINALE_AQM_LEGAME	= AQM_LEGAME					
		*ORIGINALE_AQM_NUMIDE 	= AQM_NUMIDE
		*AQM_VALUTA  			= PUB_VALRIF
		
		*=AQM_MAGACS(_FUNZIONE,_IMPEGNI,_MOVIMENTO,_IDUNIQUE,_SEGNO)					&& CREA IL MAGAZZINO E SE RICHIESTO IL MOVIMENTO DI C/S
		
		
		AQM_GIACEN = AQM_QTAMOV_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT
		**=> ERASMO - INIZIO 13/06/2012
		AQM_QTAMQ = AQM_QTAMQ_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		AQM_QTAKG = AQM_QTAKG_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		AQM_QTAML = AQM_QTAML_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		AQM_QTAMC = AQM_QTAMC_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
		**=> ERASMO - FINE 13/06/2012
		=AQM_CREA()
		
		IF !ExecRW(cSql,"U_MAG_GG","W")													&& RICARICA LA GIACENZA SU U_MAG_GG	CON LA QUANTITA' IN PRECEDENZA MOVIMENTATA									
		   return(.f.)
		ENDIF
		
    ENDIF
   

	SELECT LOCAL_U_MAG_MO
	SKIP +1

ENDDO WHILE .NOT. EOF()

SELECT(_SEL_CURSOR)

RETURN(.T.)



*!*	******************************
*!*	FUNCTION AQM_MAGACS
*!*	******************************
*!*	*!*	 
*!*	*!*	 
*!*	*!*	 __fUNZIONE		: "CREA-U-MAG-GG" : CREA U_MAG_GG ALTRIMENTI CARICA/SCARICA LA GIACENZA
*!*	*!*	 				: "NON-AGGIORNA-U-MAG-GG" : NON EFFETTUA NESSUN AGGIORNAMENTO SU U_MAG_GG
*!*	*!*	 
*!*	*!*	 __iMPEGNI		: "AGGIORNA-IMPEGNI" : AGGIORNA SOMMANDO O SOTTRAENDO LA QUANTITA' IMPEGNATA   
*!*	*!*	
*!*	*!*  __mOVIMENTO    : "CREA-MOVIMENTO"   : CREA IL MOVIMENTO DI MAGAZZINO IN U_MAG_MO
*!*	*!*	
*!*	*!*	GESTIRE PRIMA DEL RICHIAMO LA VALORIZZAZIONE DELLE VARIABILI CON LA FUNZIONE : 		=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()
*!*	*!*	 
*!*	*!*	 

*!*	PARAMETERS __fUNZIONE,__iMPEGNI,__mOVIMENTO,__idUNIQUE,__sEGNO
*!*	  
*!*	SSCARICOS=STR(SELECT())

*!*	*!*	____________________________________________________________________________________________________________________ GESTIONE VARIABILI LOCALI

*!*	LOCAL_AQM_IMPEGNI =  __iMPEGNI  
*!*	LOCAL_MOVIMENTO   = __mOVIMENTO 
*!*	*!*	____________________________________________________________________________________________________________________ ACCESSI ANAGRAFICI

*!*	=ACCESSO_PARAMETRO_TOP()
*!*	=ACCESSO_ANAGRAFICA_FORNITORE()
*!*	=ACCESSO_ANAGRAFICA_CLIENTE()
*!*	=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)

*!*	*!*	____________________________________________________________________________________________________________________ AGGIORNA GIACENZE

*!*	IF __fUNZIONE  = "NON-AGGIORNA-U-MAG-GG"
*!*	ELSE
*!*		IF __fUNZIONE  = "CREA-U-MAG-GG"
*!*			Csql = "select * from u_mag_gg where 1=0"
*!*			IF !ExecRW(Csql,"u_mag_gg","R")
*!*				return(.f.)
*!*			ENDIF
*!*			=AQM_CREA()
*!*		ELSE
*!*			_e_cond = "id_unique = '" + __idUNIQUE + "'"	
