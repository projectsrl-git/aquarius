			=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
			=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_MOVIMENTO_MAGAZZINO")		
		    AQM_SAVE_LEGSYS 		= ""
		    LOCAL_IDUNIQUE			= ""
		 	LOCAL_DATAOGGI   		= RIBALTA2(DTOC(DATE()))
			ORIGINALE_AQM_GIACEN 	= AQM_GIACEN											&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE									
			ORIGINALE_AQM_QTAKG  	= AQM_QTAKG												&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE						
			ORIGINALE_AQM_QTAMQ  	= AQM_QTAMQ												&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE															
			ORIGINALE_AQM_QTAML  	= AQM_QTAML												&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE									
			ORIGINALE_AQM_QTAMC  	= AQM_QTAMC  && ERASMO - 13/06/2012
			ORIGINALE_AQM_LEGAME	= AQM_LEGAME											&& ORIGINALE DA MOVIMENTO DI CARICO
			ORIGINALE_AQM_NUMIDE 	= AQM_NUMIDE											&& ORIGINALE DA MOVIMENTO DI CARICO
		    ORIGINALE_AQM_PREACQ    = AQM_PREACQ											&& ORIGINALE DA MOVIMENTO DI CARICO
		    
		    AQM_UNIQUE = _YY_SYSCTL  && IN CASO DI GENERAZIONE NUOVO RECORD DI GIACENZA, QUESTO CAMPO DEVE RIMANERE QUELLO DI RIFERIMENTO SIA DEL BFO CHE DELL'ORF
