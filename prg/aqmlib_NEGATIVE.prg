**********************************
FUNCTION AQM_SCARICA_MAGAZZINO_DDT
**********************************

SET STEP ON 

_SEL=SELECT()

_OK_SCARICA_MAGAZZINO = .F.

_ww_codsoc = aqm_codsoc 
_ww_anaart = aqm_anaart 
_ww_codmag = aqm_codmag 
_ww_prenot = .T.  && PARAMETRO PER SCARICARE SOLO GIACENZE NON PRENOTATE
_ww_codint = ""
_ww_altezz = aqm_altezz 
_ww_lunghe = aqm_lunghe 
_ww_fila_x = ""
_ww_pian_x = ""
_ww_ubic_x = ""
_giac_disp = AQM_RILEVA_GIACENZE_DISPONIBILI(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x)

IF M.ORD_FLGMOD = 'M' .AND. TYPE("_OLD_LEGSYS") == 'C'  && SE STO MODIFICANDO LA DDT FACCIO IN MODO DA SCARICARE CON PRECEDENZA LE GIACENZE APPENA RICARICATE
	SS=SELECT()
	_x_lsys = "mag_legsys = '" + _OLD_LEGSYS + "'"  && CAMPO DI LEGAME CON LE GIACENZE APPENA RICARICATE
	_x_soci = "mag_codsoc = '" + _ww_codsoc + "'"
	_x_data = "mag_datagg <> ''"
	_x_codi = "mag_anaart = '" + ALLTRIM(_ww_anaart) + "'"
	_x_maga = "mag_codmag = '" + ALLTRIM(_ww_codmag) + "'"
	_x_pren = IIF(_ww_prenot = .F.,"1=1","mag_prenot = 0")

	
	IF PUB_GIANEG 		&& 2012-09-05 SERGIO: ELABORA ANCHE LE GIACENZE NEGATIVE PRESENTI SU U_MAG_GG
		_x_disp = "1=1"		
	ELSE
		_x_disp = "(mag_giacen - mag_qtaimp) > 0"
	ENDIF
	
	
	_x_cint = IIF(EMPTY(_ww_codint),"1=1","mag_codart = '" + ALLTRIM(_ww_codint) + "'")
	_x_alte = IIF(_ww_altezz <= 0,"1=1","mag_altezz = " + ALLTRIM(STR(_ww_altezz,7,0)))
	_x_lung = IIF(_ww_lunghe <= 0,"1=1","mag_lunghe = " + ALLTRIM(STR(_ww_lunghe,8,0)))
	_x_fila = IIF(EMPTY(_ww_fila_x),"1=1","mag_fila_x = '" + ALLTRIM(_ww_fila_x) + "'")
	_x_pian = IIF(EMPTY(_ww_pian_x),"1=1","mag_pian_x = '" + ALLTRIM(_ww_pian_x) + "'")
	_x_ubic = IIF(EMPTY(_ww_ubic_x),"1=1","mag_ubic_x = '" + ALLTRIM(_ww_ubic_x) + "'")
	_x_cond = _x_lsys + " and " + _x_soci + " and " + _x_data + " and " + _x_codi + " and " + _x_maga + " and " + _x_pren + " and " + _x_disp + " and " + ;
	          _x_cint + " and " + _x_alte + " and " + _x_lung + " and " + _x_fila + " and " + _x_pian + " and " + _x_ubic
	_x_cond = STRTRAN(_x_cond," and 1=1","")
	Csql    = "select MAG_DATAGG,MAG_CODART,MAG_UNIQUE from u_mag_gg where " + _x_cond + " order by mag_datagg,mag_oracar,mag_codart"
	IF !ExecCommand(cSql,"PREFER_U_MAG_GG")
	   return(.f.)
	ENDIF
	SELECT PREFER_U_MAG_GG
	GO TOP
	IF EOF()
	ELSE
		UPDATE LOCAL_U_MAG_GG SET SELEZIONE = 'Z'
		SELECT PREFER_U_MAG_GG
		GO TOP
		SCAN
			_UNIQUE = MAG_UNIQUE
			UPDATE LOCAL_U_MAG_GG SET SELEZIONE = 'A' WHERE MAG_UNIQUE == _UNIQUE
		ENDSCAN
		SELECT LOCAL_U_MAG_GG 
		INDEX ON SELEZIONE+MAG_DATAGG+MAG_ORACAR+MAG_CODART TAG I_PREFER
		SET ORDER TO I_PREFER  && ORDINO IL CURSORE DELLE GIACENZE DA SCARICARE DALLA 'A' ALLA 'Z' IN MODO CHE ABBIANO LA PRECEDENZA LE GIACENZE APPENA RICARICATE
		GO TOP
	ENDIF
	SELECT(SS)
ENDIF

SELECT LOCAL_U_MAG_GG
GO TOP       
IF !EOF()	

	=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

	*** DEFINIZIONE VARIABILI LOCALI DI GESTIONE 
	LOCAL_AQM_GIACEN = AQM_GIACEN
	*LOCAL_AQM_QTAKG  = AQM_QTAKG
	*LOCAL_AQM_QTAMQ  = AQM_QTAMQ
	*LOCAL_AQM_QTAML  = AQM_QTAML
	**=> ERASMO - INIZIO 13/06/2012
	LOCAL_AQM_QTAKG  = AQM_QTAKG
	LOCAL_AQM_QTAMQ  = AQM_QTAMQ
	LOCAL_AQM_QTAML  = AQM_QTAML
	LOCAL_AQM_QTAMC  = AQM_QTAMC
	**=> ERASMO - FINE 13/06/2012
	
	IF _giac_disp >= LOCAL_AQM_GIACEN
	
		LOCAL_DATAOGGI   = RIBALTA2(DTOC(DATE()))

		*** ACCESSI ANAGRAFICI
		=ACCESSO_PARAMETRO_TOP()
		=ACCESSO_ANAGRAFICA_FORNITORE()
		=ACCESSO_ANAGRAFICA_CLIENTE()
		=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)

		_Y_SCAR = AQM_SCARICA_GIACENZA()  && SCARICA LA GIACENZA DA U_MAG_GG
		IF _Y_SCAR
			_OK_SCARICA_MAGAZZINO = .T.
		ENDIF
	
	ELSE
		
		IF PUB_CTRGIA
			MESSAGEBOX("Giacenza non disponibile",16,"Attenzione")
		ELSE
			
			*** SCARICO ALMENO LA GIACENZA DISPONIBILE ANCHE SE NON COPRE TUTTA LA QUANTITA' DA SCARICARE
			
			LOCAL_DATAOGGI   = RIBALTA2(DTOC(DATE()))
			=ACCESSO_PARAMETRO_TOP()
			=ACCESSO_ANAGRAFICA_FORNITORE()
			=ACCESSO_ANAGRAFICA_CLIENTE()
			=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)

			_Y_SCAR = AQM_SCARICA_GIACENZA()  && SCARICA LA GIACENZA DA U_MAG_GG
			IF _Y_SCAR
				_OK_SCARICA_MAGAZZINO = .T.
			ENDIF

		ENDIF
		
	ENDIF
	
ELSE 																		&& NON ESISTE GIACENZA O LA GIACENZA E' GIA' IMPEGNATA							
*SERGIOX?	
	IF PUB_CTRGIA
		MESSAGEBOX("Giacenza non disponibile",16,"Attenzione")
	ELSE
		=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()
		LOCAL_AQM_GIACEN = AQM_GIACEN
		DO AQM_SCARICA_MAGAZZINO_SOLO_MOVIMENTI
		_OK_SCARICA_MAGAZZINO = .T.
	ENDIF

ENDIF

SELECT(_SEL)

RETURN _OK_SCARICA_MAGAZZINO


*****************************
FUNCTION AQM_SCARICA_GIACENZA
*****************************
**=> ERASMO - INIZIO 16/07/2012
LPARAMETERS _par_scarica_impegnato
IF PCOUNT() = 0
	_par_scarica_impegnato = .F.
ENDIF
**=> ERASMO - FINE 16/07/2012

_OK_SCARICA_GIACENZA = .F.

SELECT LOCAL_U_MAG_GG
GO TOP  

DO WHILE .NOT. EOF()

    SELECT LOCAL_U_MAG_GG


    ___ID_UNIQUE  = ID_UNIQUE 
    

	IF PUB_GIANEG 									&& 2012-09-05 SERGIO: ELABORA ANCHE LE GIACENZE NEGATIVE PRESENTI SU U_MAG_GG
	ELSE
	    IF LOCAL_AQM_GIACEN > 0						&& LUPPA SINO A CHE NON HA TOLTO TUTTA LA QTA MOVIMENTATA DI RECORD DI U_MAG_GG
	    ELSE 
	      EXIT
	    ENDIF    
	ENDIF


    
	_e_cond = "id_unique = '" + ___ID_UNIQUE + "'"	
	Csql    = "select * from u_mag_gg where " + _e_cond + " order by mag_codart"
	IF !ExecRW(Csql,"u_mag_gg","R")
		   return(.f.)
	ENDIF

    SELECT U_MAG_GG
    IF !EOF()
    
     	*___DISPONIBILE 	= MAG_GIACEN - MAG_QTAIMP
		**=> ERASMO - INIZIO 16/07/2012
		IF _par_scarica_impegnato
			___DISPONIBILE 	= MAG_GIACEN
		ELSE
			___DISPONIBILE 	= MAG_GIACEN - MAG_QTAIMP
		ENDIF
		**=> ERASMO - FINE 16/07/2012
        
		*AQM_QTAKG  = MAG_QTAKG
		*AQM_QTAMQ  = MAG_QTAMQ
		*AQM_QTAML  = MAG_QTAML
		*AQM_NRDBOB = MAG_NRDBOB
		
		AQM_CDAFOR = MAG_CDAFOR
		AQM_OINFOR = MAG_OINFOR
		AQM_PINFOR = MAG_PINFOR
		AQM_DTPFOR = MAG_DTPFOR
		AQM_TRAFOR = MAG_TRAFOR
		AQM_NBAFOR = MAG_NBAFOR
		AQM_BDAFOR = MAG_BDAFOR
		AQM_BALFOR = MAG_BALFOR
		AQM_PNKFOR = MAG_PNKFOR
    
	    *IF ___DISPONIBILE => LOCAL_AQM_GIACEN 
	    *IF ___DISPONIBILE > LOCAL_AQM_GIACEN 
	    IF ___DISPONIBILE >= LOCAL_AQM_GIACEN  && ERASMO - 25/06/2012
	    
	      REPLACE MAG_GIACEN WITH MAG_GIACEN - LOCAL_AQM_GIACEN 
	      
	      **=> ERASMO - INIZIO 16/07/2012
	      IF _par_scarica_impegnato
	      	REPLACE MAG_QTAIMP WITH MAG_QTAIMP - LOCAL_AQM_GIACEN 
	      	IF MAG_QTAIMP < 0
	      		REPLACE MAG_QTAIMP WITH 0
	      	ENDIF
	      ENDIF
	      **=> ERASMO - FINE 16/07/2012

	      *REPLACE MAG_QTAKG  WITH MAG_QTAKG  - LOCAL_AQM_QTAKG
	      *REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  - LOCAL_AQM_QTAMQ
	      *REPLACE MAG_QTAML  WITH MAG_QTAML  - LOCAL_AQM_QTAML
	      
			*** RESETTO E VALORIZZO LE QTA NELLE VARIE UNITA' DI MISURA SULLA RIGA DI GIACENZA
			REPLACE MAG_QTAMQ WITH 0
			REPLACE MAG_QTAML WITH 0
			REPLACE MAG_QTAKG WITH 0
			REPLACE MAG_QTAMC WITH 0  && ERASMO - 13/06/2012
			
			_X_UMMAGA = AQM_TROVA_UMMAGA(AQM_ANAART)
			DO CASE
				CASE ALLTRIM(_X_UMMAGA) == "KG"
					REPLACE MAG_QTAKG WITH MAG_GIACEN
				CASE ALLTRIM(_X_UMMAGA) == "MQ"
					REPLACE MAG_QTAMQ WITH MAG_GIACEN
					** SERGIO : PUZZA ?????????????????????????????????????????????????????????????
					**REPLACE MAG_LUNGHE WITH TROVA_ML_DA_MQ(MAG_ALTEZZ,MAG_QTAMQ)
				CASE ALLTRIM(_X_UMMAGA) == "ML"
					REPLACE MAG_QTAML WITH MAG_GIACEN
					** SERGIO : PUZZA ?????????????????????????????????????????????????????????????
					**REPLACE MAG_LUNGHE WITH MAG_GIACEN
				**=> ERASMO - INIZIO 13/06/2012
				CASE ALLTRIM(_X_UMMAGA) == "MC"
					REPLACE MAG_QTAMC WITH MAG_GIACEN
				**=> ERASMO - FINE 13/06/2012
				
			ENDCASE
			
			X_TIPO = CERCATIPO(MAG_ANAART)
			IF X_TIPO = '1'  && BOBINE
				IF MAG_QTAMQ <= 0
					REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_LUNGHE,1)
				ENDIF
				IF MAG_QTAML <= 0
					REPLACE MAG_QTAML WITH TROVA_ML_DA_LU(MAG_LUNGHE,1)
				ENDIF
				IF MAG_QTAKG <= 0
					REPLACE MAG_QTAKG WITH TROVA_KG_DA_MQ(MAG_ANAART,MAG_SPESSO,MAG_QTAMQ,1)
				ENDIF
			ENDIF
			
			IF X_TIPO = '3'  && MANICOTTI
				IF ALLTRIM(_X_UMMAGA) == "NR"
					REPLACE MAG_QTAML WITH MAG_GIACEN * MAG_ALTEZZ / 1000
				ENDIF
			ENDIF
			
			**=> ERASMO - INIZIO 13/06/2012
			IF X_TIPO = '6'  && PANNELLI TRUCIOLARI
				X_QTANR = 0
				DO CASE
					CASE ALLTRIM(_X_UMMAGA) == "MQ"
						X_QTANR = TROVA_NR_DA_MQ_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN)
					CASE ALLTRIM(_X_UMMAGA) == "MC"
						X_QTANR = TROVA_NR_DA_MC_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN,MAG_SPESSO)
				ENDCASE
				REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,X_QTANR)
				REPLACE MAG_QTAML WITH TROVA_ML_DA_LU(MAG_LUNGHE,X_QTANR)
				REPLACE MAG_QTAKG WITH 0
				REPLACE MAG_QTAMC WITH TROVA_MC_DA_AL_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,X_QTANR,MAG_SPESSO) 
			ENDIF
			**=> ERASMO - FINE 13/06/2012
			
			**=> ERASMO - INIZIO 02/03/2012
			IF X_TIPO = '8'  && CARTE IMPREGNATE
				IF ALLTRIM(_X_UMMAGA) == "NR"
					REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN)
				ENDIF
			ENDIF
			**=> ERASMO - FINE 02/03/2012
					
	      *!*	_________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 
	      
    
	      ORIGINALE_AQM_GIACEN   = LOCAL_AQM_GIACEN 
	      ORIGINALE_AQM_QTAKG    = LOCAL_AQM_QTAKG  
	      ORIGINALE_AQM_QTAMQ    = LOCAL_AQM_QTAMQ
	      ORIGINALE_AQM_QTAML    = LOCAL_AQM_QTAML 
