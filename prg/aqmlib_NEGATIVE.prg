	cSql   = "SELECT * FROM U_BFO_DD WHERE " + x_cond + " order by daggancio"
	IF !ExecCommand(cSql,"CX_BFO_DD")
		return(.f.)
	ENDIF
	SELECT CX_BFO_DD
	GO TOP
	SCAN
		
		SCATTER MEMVAR
