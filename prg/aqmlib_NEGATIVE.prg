***********************************************
PROCEDURE AQM_RICALCOLA_EVASIONE_ORDINI_CLIENTI
***********************************************

LPARAMETERS _par_nomecur

SS=SELECT()

*** RICALCOLO DELLE QUANTITA' EVASE NEGLI ORDINI CLIENTI COINVOLTI
SELECT &_par_nomecur
SET FILTER TO
GO TOP
SCAN
	
	IF "*** COMMENTO ***" $ ORD_DESART
		LOOP
	ENDIF
	
	*** ANNULLO LE QUANTITA' EVASE SU TUTTI I DETTAGLI ORDINI CLIENTI LEGATI
	SCATTER MEMVAR
	_X_DAGGANCIO = ""  && ERASMO - 09/07/2012
	x_lsys = "ord_legsys = '" + M.ORD_LEGSYS + "'"
	x_cond = x_lsys
	cSql   = "SELECT * FROM U_ORD_DD WHERE " + x_cond
	IF !ExecRW(cSql,"U_ORD_DD","R")
		return(.f.)
	ENDIF 
	SELECT U_ORD_DD
	GO TOP
	IF EOF()
	ELSE
		REPLACE ORD_QTAEV WITH 0
		REPLACE ORD_NUMBOE WITH 0	&& ERASMO - 15/12/2011
		REPLACE ORD_QTAKGE WITH 0	&& ERASMO - 15/12/2011
		REPLACE ORD_QTAMQE WITH 0	&& ERASMO - 15/12/2011
		REPLACE ORD_QTAMLE WITH 0	&& ERASMO - 15/12/2011
		REPLACE ORD_QTAMCE WITH 0	&& ERASMO - 15/12/2011
		REPLACE ORD_SALCON WITH ""
		REPLACE ORD_CHIUSO WITH .F.
		
		_X_DAGGANCIO = DAGGANCIO  && ERASMO - 09/07/2012
		
	ENDIF
	IF !ExecRW(cSql,"U_ORD_DD","W")
		return(.f.)
	ENDIF
	
	**=> ERASMO - INIZIO 09/07/2012
	IF !EMPTY(_X_DAGGANCIO)
		x_agga = "daggancio = '" + _X_DAGGANCIO + "'"
		x_cond = x_agga
		cSql	= "SELECT ORD_QTAEV,ORD_QTAORD,ORD_CHIUSO FROM U_ORD_DD WHERE " + x_cond
		IF !ExecCommand(cSql,"TMP_ORD_DD")
			return(.f.)
		ENDIF 
		V_OPEN = .F.
		SELECT TMP_ORD_DD
		GO TOP
		DO WHILE .T.
			IF EOF()
				EXIT
			ENDIF
			IF ORD_QTAEV < ORD_QTAORD 
				IF ORD_CHIUSO
				ELSE
					V_OPEN = .T.
					EXIT
				ENDIF
			ENDIF
			SKIP +1
		ENDDO
		x_agga = "taggancio = '" + _X_DAGGANCIO + "'"
		x_cond = x_agga 
		cSql	= "SELECT * FROM U_ORD_TT WHERE " + x_cond
		IF !ExecRW(cSql,"U_ORD_TT","R")
			return(.f.) 
		ENDIF 
		SELECT U_ORD_TT
		GO TOP
		IF EOF()
		ELSE
			IF V_OPEN
				REPLACE ORD_CHIUSO WITH .F.
			ELSE
				REPLACE ORD_CHIUSO WITH .T.
			ENDIF
		ENDIF
		IF !ExecRW(cSql,"U_ORD_TT","W")
			return(.f.)
		ENDIF
	ENDIF
	**=> ERASMO - FINE 09/07/2012
	
	
	*** RICALCOLO LE QUANTITA' EVASE SU TUTTI I DETTAGLI ORDINI CLIENTI LEGATI COINVOLGENDO EVENTUALI ALTRE DDT CLIENTI PRESENTI SUL DB
	SELECT &_par_nomecur
	x_lsys = "ord_legsys = '" + ORD_LEGSYS + "'"
	x_comm = "ORD_DESART <> '*** COMMENTO ***'"
	x_cond = x_lsys + " and " + x_comm
	cSql   = "SELECT * FROM U_BOL_DD WHERE " + x_cond + " order by daggancio"
	IF !ExecCommand(cSql,"CX_BOL_DD")
		return(.f.)
	ENDIF
	SELECT CX_BOL_DD
	GO TOP
	SCAN
		
		SCATTER MEMVAR
		_X_DAGGANCIO = ''
		x_lsys = "ord_legsys = '" + M.ORD_LEGSYS + "'"
		x_cond = x_lsys
		cSql   = "SELECT * FROM U_ORD_DD WHERE " + x_cond
		IF !ExecRW(cSql,"U_ORD_DD","R")
			return(.f.)
		ENDIF 
		SELECT U_ORD_DD
		GO TOP
		IF EOF()
		ELSE
			_X_DAGGANCIO = DAGGANCIO
			REPLACE ORD_QTAEV WITH ORD_QTAEV + M.ORD_QTAORD
			REPLACE ORD_NUMBOE WITH ORD_NUMBOE + M.ORD_NUMBOB	&& ERASMO - 15/12/2011
			REPLACE ORD_QTAKGE WITH ORD_QTAKGE + M.ORD_QTAKG	&& ERASMO - 15/12/2011
			REPLACE ORD_QTAMQE WITH ORD_QTAMQE + M.ORD_QTAMQ	&& ERASMO - 15/12/2011
			REPLACE ORD_QTAMLE WITH ORD_QTAMLE + M.ORD_QTAML	&& ERASMO - 15/12/2011
			REPLACE ORD_QTAMCE WITH ORD_QTAMCE + M.ORD_QTAMC	&& ERASMO - 15/12/2011
			*IF ORD_QTAEV >= ORD_QTAORD
			*IF ROUND(ORD_QTAEV,2) >= ROUND(ORD_QTAORD,2)	&& ERASMO - 15/12/2011 - CONSIDERO UN ARROTONDAMENTO A 2 CIFRE DECIMALI
			*	REPLACE ORD_CHIUSO WITH .T.
			*ELSE
			*	REPLACE ORD_CHIUSO WITH .F.
			*ENDIF
			
			**=> ERASMO - INIZIO 29/12/2011
			X_TIPO = CERCATIPO(ORD_CODART)
			X_CONDITION = .F.
			IF X_TIPO = '6'  && PANNELLI TRUCIOLARI
				X_CONDITION = (ORD_NUMBOE >= ORD_NUMBOB)
			ELSE
				X_CONDITION = (ORD_QTAEV >= ORD_QTAORD)
			ENDIF
			REPLACE ORD_CHIUSO WITH X_CONDITION
			**=> ERASMO - FINE 29/12/2011
			
			*REPLACE ORD_SALCON WITH M.ORD_SALCON
		ENDIF
		IF !ExecRW(cSql,"U_ORD_DD","W")
			return(.f.)
		ENDIF
		
		IF !EMPTY(_X_DAGGANCIO)
			x_agga = "daggancio = '" + _X_DAGGANCIO + "'"
			x_cond = x_agga
			cSql	= "SELECT ORD_QTAEV,ORD_QTAORD,ORD_CHIUSO FROM U_ORD_DD WHERE " + x_cond
			IF !ExecCommand(cSql,"TMP_ORD_DD")
				return(.f.)
			ENDIF 
			V_OPEN = .F.
			SELECT TMP_ORD_DD
			GO TOP
			DO WHILE .T.
				IF EOF()
					EXIT
				ENDIF
				IF ORD_QTAEV < ORD_QTAORD 
					IF ORD_CHIUSO
					ELSE
						V_OPEN = .T.
						EXIT
					ENDIF
				ENDIF
				SKIP +1
			ENDDO
			x_agga = "taggancio = '" + _X_DAGGANCIO + "'"
			x_cond = x_agga 
			cSql	= "SELECT * FROM U_ORD_TT WHERE " + x_cond
			IF !ExecRW(cSql,"U_ORD_TT","R")
				return(.f.) 
			ENDIF 
			SELECT U_ORD_TT
			GO TOP
			IF EOF()
			ELSE
				IF V_OPEN
					REPLACE ORD_CHIUSO WITH .F.
				ELSE
					REPLACE ORD_CHIUSO WITH .T.
				ENDIF
			ENDIF
			IF !ExecRW(cSql,"U_ORD_TT","W")
				return(.f.)
			ENDIF
		ENDIF
				
	ENDSCAN
	
ENDSCAN

SELECT(SS)

RETURN


