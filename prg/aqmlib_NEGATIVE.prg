*********************
FUNCTION AQM_SOMMA
*********************


	SELECT U_MAG_GG
	
	REPLACE MAG_GIACEN WITH MAG_GIACEN + AQM_GIACEN  
	*REPLACE MAG_QTAKG  WITH MAG_QTAKG  + AQM_QTAKG	
	*REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  + AQM_QTAMQ	
	*REPLACE MAG_QTAML  WITH MAG_QTAML  + AQM_QTAML	
*!*		_XX_QTAMQ = TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_LUNGHE,1)
*!*		REPLACE MAG_QTAMQ WITH _XX_QTAMQ 
*!*		_XX_QTAML = TROVA_ML_DA_LU(MAG_LUNGHE,1)
*!*		REPLACE MAG_QTAML WITH _XX_QTAML
*!*		_XX_QTAKG = TROVA_KG_DA_MQ(MAG_ANAART,MAG_SPESSO,MAG_QTAMQ,1)
*!*		REPLACE MAG_QTAKG WITH _XX_QTAKG
	
	**=> ERASMO - INIZIO 13/06/2012
	REPLACE MAG_QTAKG  WITH MAG_QTAKG + AQM_QTAKG
	REPLACE MAG_QTAMQ  WITH MAG_QTAMQ + AQM_QTAMQ
	REPLACE MAG_QTAML  WITH MAG_QTAML + AQM_QTAML
	REPLACE MAG_QTAMC  WITH MAG_QTAMC + AQM_QTAMC
	**=> ERASMO - FINE 13/06/2012
	
	IF LOCAL_AQM_IMPEGNI 	=  "AGGIORNA-IMPEGNI"
		REPLACE MAG_QTAIMP WITH MAG_QTAIMP + AQM_QTAIMP	 
		REPLACE MAG_GMLIMP WITH MAG_GMLIMP + AQM_GMLIMP  	
		REPLACE MAG_GKGIMP WITH MAG_GKGIMP + AQM_GKGIMP 	
	ENDIF	


RETURN(.T.)


*********************
FUNCTION AQM_SOTTRAE
*********************


	SELECT U_MAG_GG
	
	REPLACE MAG_GIACEN WITH MAG_GIACEN - AQM_GIACEN  
	*REPLACE MAG_QTAKG  WITH MAG_QTAKG  - AQM_QTAKG	
	*REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  - AQM_QTAMQ	
	*REPLACE MAG_QTAML  WITH MAG_QTAML  - AQM_QTAML	
*!*		_XX_QTAMQ = TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_LUNGHE,1)
*!*		REPLACE MAG_QTAMQ WITH _XX_QTAMQ 
*!*		_XX_QTAML = TROVA_ML_DA_LU(MAG_LUNGHE,1)
*!*		REPLACE MAG_QTAML WITH _XX_QTAML
*!*		_XX_QTAKG = TROVA_KG_DA_MQ(MAG_ANAART,MAG_SPESSO,MAG_QTAMQ,1)
*!*		REPLACE MAG_QTAKG WITH _XX_QTAKG
	
	**=> ERASMO - INIZIO 13/06/2012
	REPLACE MAG_QTAKG  WITH MAG_QTAKG - AQM_QTAKG
	REPLACE MAG_QTAMQ  WITH MAG_QTAMQ - AQM_QTAMQ
	REPLACE MAG_QTAML  WITH MAG_QTAML - AQM_QTAML
	REPLACE MAG_QTAMC  WITH MAG_QTAMC - AQM_QTAMC
	**=> ERASMO - FINE 13/06/2012

	IF MAG_GIACEN < 0  
		REPLACE MAG_GIACEN WITH 0
	ENDIF
	IF MAG_QTAKG < 0  
		REPLACE MAG_QTAKG WITH 0
	ENDIF
	IF MAG_QTAMQ < 0  
		REPLACE MAG_QTAMQ WITH 0
	ENDIF
	IF MAG_QTAML < 0  
		REPLACE MAG_QTAML WITH 0
	ENDIF
	**=> ERASMO - INIZIO 13/06/2012
	IF MAG_QTAMC < 0  
		REPLACE MAG_QTAMC WITH 0
	ENDIF
	**=> ERASMO - FINE 13/06/2012

	
	IF LOCAL_AQM_IMPEGNI 	=  "AGGIORNA-IMPEGNI"

		REPLACE MAG_QTAIMP WITH MAG_QTAIMP - AQM_QTAIMP	 
		REPLACE MAG_GMLIMP WITH MAG_GMLIMP - AQM_GMLIMP  	
		REPLACE MAG_GKGIMP WITH MAG_GKGIMP - AQM_GKGIMP 

		IF MAG_QTAIMP < 0
			REPLACE MAG_QTAIMP WITH 0
		ENDIF

		IF MAG_GMLIMP < 0
			REPLACE MAG_GMLIMP WITH 0
		ENDIF

		IF MAG_GKGIMP < 0
			REPLACE MAG_GKGIMP WITH 0
		ENDIF
			
	ENDIF	


	IF EMPTY(ALLTRIM(PUB_MAGNO0))
	ELSE
	   IF MAG_GIACEN = 0								&& CANCELLA IL RECORD SU U_MAG_GG SE E' = 0 ED E' PREVISTO NEI PARAMETRI AZIENDALI 
	      IF ALLTRIM(MAG_CODMAG) $ PUB_MAGNO0
	      ELSE
	         DELETE
	      ENDIF
	   ENDIF
	ENDIF


RETURN(.T.)


