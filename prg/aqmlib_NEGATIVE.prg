****************************************
FUNCTION AQM_RILEVA_GIACENZE_DISPONIBILI
****************************************

LPARAMETERS _par_codsoc,_par_anaart,_par_codmag,_par_prenot,_par_codint,_par_altezz,_par_lunghe,_par_fila_x,_par_pian_x,_par_ubic_x

SS=SELECT()

_RIT = 0

_x_soci = "mag_codsoc = '" + _par_codsoc + "'"
_x_data = "mag_datagg <> ''"
_x_codi = "mag_anaart = '" + ALLTRIM(_par_anaart) + "'"
_x_maga = IIF(EMPTY(_par_codmag),"1=1","mag_codmag = '" + ALLTRIM(_par_codmag) + "'")
_x_pren = IIF(_par_prenot = .F.,"1=1","mag_prenot = 0")

IF PUB_GIANEG 		&& 2012-09-05 SERGIO: ELABORA ANCHE LE GIACENZE NEGATIVE PRESENTI SU U_MAG_GG
	_x_disp = "1=1"		
ELSE
	_x_disp = "(mag_giacen - mag_qtaimp) > 0"
ENDIF

_x_cint = IIF(EMPTY(_par_codint),"1=1","mag_codart = '" + ALLTRIM(_par_codint) + "'")
_x_alte = IIF(_par_altezz <= 0,"1=1","mag_altezz = " + ALLTRIM(STR(_par_altezz,7,0)))
_x_lung = IIF(_par_lunghe <= 0,"1=1","mag_lunghe = " + ALLTRIM(STR(_par_lunghe,8,0)))
_x_fila = IIF(EMPTY(_par_fila_x),"1=1","mag_fila_x = '" + ALLTRIM(_par_fila_x) + "'")
_x_pian = IIF(EMPTY(_par_pian_x),"1=1","mag_pian_x = '" + ALLTRIM(_par_pian_x) + "'")
_x_ubic = IIF(EMPTY(_par_ubic_x),"1=1","mag_ubic_x = '" + ALLTRIM(_par_ubic_x) + "'")
_x_cond = _x_soci + " and " + _x_data + " and " + _x_codi + " and " + _x_maga + " and " + _x_pren + " and " + _x_disp + " and " + ;
          _x_cint + " and " + _x_alte + " and " + _x_lung + " and " + _x_fila + " and " + _x_pian + " and " + _x_ubic
_x_cond = STRTRAN(_x_cond," and 1=1","")
Csql    = "select * from u_mag_gg where " + _x_cond + " order by mag_datagg,mag_oracar,mag_codart"
IF !ExecCommand(cSql,"LOCAL_U_MAG_GG")
   return(.f.)
ENDIF
SELECT LOCAL_U_MAG_GG
GO TOP
SCAN
	_RIT = _RIT + (MAG_GIACEN - MAG_QTAIMP)
ENDSCAN

SELECT(SS)

RETURN _RIT


*********************************
FUNCTION AQM_GESTIONE_CARICHI_BFO
*********************************

**=> ERASMO - INIZIO 05/07/2012
LPARAMETERS _par_routine_chiamante
IF PCOUNT() = 0
	_par_routine_chiamante = ""
ENDIF
_par_routine_chiamante = ALLTRIM(_par_routine_chiamante)
**=> ERASMO - FINE 05/07/2012

SDDTS=SELECT()

AQM_NUMMOV_LOCALE = AQM_RILEVA_NUMERO_INTERNO()

XXX_NUMORD = M.ORD_NUMORD

*XXX_DATORD = IIF(SUBSTR(M.ORD_DATORD,3,1) = '/',RIBALTA2(M.ORD_DATORD),M.ORD_DATORD)
**=> ERASMO - INIZIO 05/07/2012
DO CASE
	
	CASE _par_routine_chiamante == "MENU_BFO000" OR _par_routine_chiamante == "MENU_BFOPES"
		*** NEL BFO000 LA DATA DEL DOCUMENTO E' ORD_DATOR2 MENTRE LA DATA DI REGISTRAZIONE E' ORD_DATORD
		XXX_DATORD = IIF(SUBSTR(M.ORD_DATOR2,3,1) = '/',RIBALTA2(M.ORD_DATOR2),M.ORD_DATOR2)
		PUB_DATREG = IIF(SUBSTR(M.ORD_DATORD,3,1) = '/',M.ORD_DATORD,RIBALTA2(M.ORD_DATORD))

	OTHERWISE
		XXX_DATORD = IIF(SUBSTR(M.ORD_DATORD,3,1) = '/',RIBALTA2(M.ORD_DATORD),M.ORD_DATORD)
		IF TYPE("PUB_DATREG") = 'C'
		ELSE
			PUBLIC PUB_DATREG 
			PUB_DATREG = ""
		ENDIF
		IF EMPTY(PUB_DATREG) OR PUB_DATREG = "  /  /    "
			PUB_DATREG = IIF(SUBSTR(M.ORD_DATORD,3,1) = '/',M.ORD_DATORD,RIBALTA2(M.ORD_DATORD))
		ENDIF
		
ENDCASE
**=> ERASMO - FINE 05/07/2012

XXX_CAUS = M.ORD_CAUS
XXX_VALUTA = M.ORD_VALUTA
XXX_CODBUN = M.ORD_CODBUN
XXX_NUMIDE = M.ORD_NUMIDE

SELECT CU_BFO_DD
SET FILTER TO
GO TOP

DO WHILE .T. 

	IF EOF()
		EXIT
	ENDIF

	IF DELETED()
		SKIP +1
		LOOP
	ENDIF

	IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
		SKIP +1
		LOOP
	ENDIF

	IF ORD_FLGMOD = 'I' .OR. ORD_FLGMOD = 'M' .OR. ORD_FLGMOD = 'A'
	ELSE
		SKIP +1
		LOOP
	ENDIF
	
	IF EMPTY(ORD_SYSMAG)
		REPLACE ORD_SYSMAG WITH SYS(2015)
	ENDIF
	
	SCATTER MEMVAR MEMO
	
	XXX_FLGMOD = M.ORD_FLGMOD
	
	IF ALLTRIM(XXX_FLGMOD) == 'M' .OR. ALLTRIM(XXX_FLGMOD) == 'A'
		
		=AQM_ANNULLA_CARICO_MAGAZZINO()
		DO AQM_ATTENDI_N_SECONDI WITH 1  && ATTENDO IL SECONDO SUCCESSIVO PER DIFFERENZIARE CRONOLOGICAMENTE I MOVIMENTI DI CARICO/SCARICO
		SELECT CU_BFO_DD
		REPLACE ORD_SYSMAG WITH ORD_SYSMAG_RIGENERATO 	
		M.ORD_SYSMAG = ORD_SYSMAG_RIGENERATO
		
	ENDIF
	
	SELECT CU_BFO_DD
	SCATTER MEMVAR MEMO
	XXX_ANAART = M.ORD_CODART
	XXX_CODFOR = M.ORS_CODCLI
	X_TIPO = CERCATIPO(M.ORD_CODART)
	
	IF ALLTRIM(XXX_FLGMOD) == 'I' .OR. ALLTRIM(XXX_FLGMOD) == 'M'
		
		*IF X_TIPO = '1' .OR. X_TIPO = '2'  && BOBINE O ADESIVI (CARICHI DA GESTIRE TRAMITE CU_BFO_DL)
		IF X_TIPO = '1' .OR. X_TIPO = '2' .OR. X_TIPO = '7'  && BOBINE O ADESIVI O BOBINE DI CARETE GREZZE (CARICHI DA GESTIRE TRAMITE CU_BFO_DL)  && ERASMO - 08/03/2012
			SELECT CU_BFO_DL
			SET FILTER TO
			SET FILTER TO DAGGANCIO = M.DAGGANCIO .AND. ORD_AGGORF = M.ORD_LEGAME .AND. ORD_SYSORF = M.ORD_LEGASY .AND. ORD_TIPMOV <> 'A'
			SET ORDER TO I_ORDINE
			GO TOP
			SCAN
				
				IF ALLTRIM(ORD_UM) == "KG"
					V_QTACTRL = ORD_QTAKG
				ELSE
					V_QTACTRL = ORD_QTAMQ
				ENDIF
				IF V_QTACTRL > 0
				ELSE
					DELETE
					SKIP +1
					LOOP
				ENDIF
				
				PUB_TIPOBOB = ""
				*IF X_TIPO = '1'
				IF X_TIPO = '1' .OR. X_TIPO = '7'  && ERASMO - 08/03/2012
					PUB_TIPOBOB = "FNU"
					IF ALLTRIM(ORD_UM) == "KG"
					ELSE
						PUB_TIPOBOB = "SPA"
					ENDIF
				ELSE
					IF X_TIPO = '2'
						PUB_TIPOBOB = "ADE"
					ELSE
						PUB_TIPOBOB = ""
					ENDIF
				ENDIF
				
				IF TYPE("M.ORD_TIPBOB") == 'C'
					PUB_TIPOBOB = M.ORD_TIPBOB
					RELEASE M.ORD_TIPBOB
				ENDIF
				
				SCATTER MEMVAR MEMO
				
				=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
				=AQM_VALORIZZA_VARIABILI_MAGAZZINO("CU_BFO_DD-DL")
				_YES_CAR = AQM_CARICA_MAGAZZINO()
				IF !_YES_CAR
					MESSAGEBOX("Si č verificato un errore generico durante il carico del magazzino" + CHR(13) + CHR(13) + ;
						"I dettagli BFO non verranno aggiornati completamente",16,"Attenzione")
					SELECT CU_BFO_DD
					DELETE
					SKIP +1
					LOOP
				ENDIF
	            
				SELECT CU_BFO_DL
				REPLACE ORD_NRLINT WITH AQM_NRLINT
				REPLACE ORD_CODART WITH AQM_CODART
				
				IF XXX_CAUS = 'BFO'
					*** AGGIORNAMENTO TABELLA U_PRD_D3 (BOBINE PER PRODUZIONE)
					SELECT CU_BFO_DL
					_WW_PJ_PRGPRD1 = PJ_PRGPRD1
					_WW_PJ_PRGPRD2 = PJ_PRGPRD2
					_WW_PJ_PRGPRD3 = PJ_PRGPRD3
					_WW_DAPRENOTARE = .F.
					x_pj_1 = "pj_prgprd1 = '" + ALLTRIM(PJ_PRGPRD1) + "'"
					x_pj_2 = "pj_prgprd2 = '" + ALLTRIM(PJ_PRGPRD2) + "'"
					x_pj_3 = "pj_prgprd3 = '" + ALLTRIM(PJ_PRGPRD3) + "'"
					x_cond = x_pj_1 + " and " + x_pj_2 + " and " + x_pj_3
					cSql	= "SELECT * FROM U_PRD_D3 WHERE " + x_cond
					IF !ExecRW(cSql,"U_PRD_D3","R")
						return(.f.)
					ENDIF
					SELECT U_PRD_D3
					GO TOP
					IF EOF()
					ELSE
						REPLACE PR3_CODINT WITH AQM_CODART
						REPLACE PR3_ALTCAR WITH M.ORD_ALTEZZ
						REPLACE PR3_LUNCAR WITH M.ORD_LUNGHE
						REPLACE PR3_SPECAR WITH M.ORD_SPESSO
						_WW_DAPRENOTARE = .T.
					ENDIF
					IF !ExecRW(cSql,"U_PRD_D3","W")
						return(.f.)
					ENDIF
					
					*** AGGIORNAMENTO FLAG DI 'PRENOTATO' SU GIACENZA DI MAGAZZINO U_MAG_GG (BOBINE PER PRODUZIONE)
					IF _WW_DAPRENOTARE
						x_cond = "mag_codart = '" + ALLTRIM(AQM_CODART) + "'"
						cSql   = "UPDATE U_MAG_GG SET MAG_PRENOT = 1 WHERE " + x_cond
						IF !ExecCommand(cSql,"UPD_MAG_GG")
							return(.f.)
						ENDIF
					ENDIF
				ENDIF
				
			ENDSCAN
		
		ELSE
			
			**=> ERASMO - INIZIO 01/06/2012
			IF X_TIPO = '6'  && PANNELLI TRUCIOLARI
				AQM_CODINT = ""
				AQM_NRLINT = 0
				AQM_NUMERO_LOTTO_INTERNO(M.ORD_CODART)
				SELECT CU_BFO_DD
				REPLACE ORD_CODFIS WITH AQM_CODINT
				REPLACE ORD_NRLINT WITH AQM_NRLINT
				SCATTER MEMVAR MEMO
			ENDIF
			**=> ERASMO - FINE 01/06/2012
			
			IF X_TIPO = '0' .AND. ALLTRIM(M.ORD_SERIE) = 'ZI'  && GESTIONE ARTICOLI FISCALI
			
				_NEW_NRLINTFISC = AQM_NUMERO_LOTTO_INTERNO_FISCALE()
				SELECT CU_BFO_DD
				REPLACE ORD_CODFIS WITH _NEW_NRLINTFISC
				REPLACE ORD_NRLINT WITH ROUND(VAL(SUBSTR(_NEW_NRLINTFISC,AT('.',_NEW_NRLINTFISC)+1)),0)
				SCATTER MEMVAR MEMO
							
			ENDIF
			
			=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
			=AQM_VALORIZZA_VARIABILI_MAGAZZINO("CU_BFO_DD")
			_YES_CAR = AQM_CARICA_MAGAZZINO()
			IF !_YES_CAR
				MESSAGEBOX("Si č verificato un errore generico durante il carico del magazzino" + CHR(13) + CHR(13) + ;
					"I dettagli BFO non verranno aggiornati completamente",16,"Attenzione")
				SELECT CU_BFO_DD
				DELETE
				SKIP +1
				LOOP
			ENDIF
			
		ENDIF
				
		**=> ERASMO - INIZIO 26/03/2012
		*** SCARICO AUTOMATICO MATERIALE IN CONTO LAVORO LEGATO
		SELECT CU_BFO_DD
		IF !EMPTY(ORD_SYSCTL)
			_XX_SYSCTL = ORD_SYSCTL
			_XX_QTACTL = ORD_QTACTL
			x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
			x_uniq = "mag_unique = '" + _XX_SYSCTL + "'"
			x_data = "mag_datagg <> SPACE(10)"
			x_giac = "mag_giacen > 0"
			x_cond = x_soci + " and " + x_uniq + " and " + x_data + " and " + x_giac
			cSql   = "select * from u_mag_gg where " + x_cond
			IF !ExecCommand(cSql,'CU_MAG_GM')
			   return(.f.)
			ENDIF
			SELECT CU_MAG_GM
			GO TOP
			IF !EOF()
				SCATTER MEMVAR MEMO
				*** VALORIZZAZIONE VARIABILI CHE DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA (LA QUANTITA' DA SCARICARE E' CONTENUTA IN CU_MAG_GM.MAG_GIACEN)
				=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
				=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
				*** VALORIZZAZIONE VARIABILI CHE NON DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA
				AQM_DTDOCU = XXX_DATORD
				AQM_NUMDOC = XXX_NUMORD
				AQM_CODCLI = XXX_CODFOR
				AQM_TOP    = PUB_CTLO
				AQM_DTREGI = XXX_DATORD
				AQM_VALUTA = XXX_VALUTA
				AQM_LEGSYS = SYS(2015)
				AQM_GIACEN = _XX_QTACTL
				DO AQM_IMPEGNA_DISIMPEGNA_MAGAZZINO WITH "-",M.MAG_UNIQUE,AQM_GIACEN
				_OK_SCAR = AQM_SCARICA_MAGAZZINO()
				IF _OK_SCAR
					SELECT CU_BFO_DD
					REPLACE ORD_MOVCTL WITH AQM_LEGSYS
				ELSE
					MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze per conto lavoro",16,"Attenzione")
				ENDIF
			ENDIF
		ENDIF
		**=> ERASMO - FINE 26/03/2012
		
	ENDIF

	SELECT CU_BFO_DD
	SKIP +1

ENDDO

RELEASE PUB_DATREG  && ERASMO - 20/03/2012

RETURN


*****************************
FUNCTION AQM_CARICA_MAGAZZINO
*****************************

_SEL=SELECT()

_OK_CARICA_MAGAZZINO = .F.

=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

LOCAL_LEGAME 			= SYS(2015)  && NUOVO VALORE PER IL CAMPO DI LEGAME TRA U_MAG_GG E U_MAG_MO
AQM_LEGAME 				= LOCAL_LEGAME
ORIGINALE_AQM_LEGAME 	= LOCAL_LEGAME
LOCAL_DATAOGGI 			= RIBALTA2(DTOC(DATE()))
ORIGINALE_AQM_CODFOR 	= AQM_CODFOR
ORIGINALE_AQM_DESFOR 	= AQM_DESFOR
ORIGINALE_AQM_PREACQ 	= AQM_PREACQ
ORIGINALE_AQM_SC1 		= AQM_SC1
ORIGINALE_AQM_SC2 		= AQM_SC2
ORIGINALE_AQM_SC3 		= AQM_SC3
ORIGINALE_AQM_SC4 		= 0
ORIGINALE_AQM_SC5 		= 0
ORIGINALE_AQM_GIACEN 	= AQM_GIACEN
ORIGINALE_AQM_QTAKG 	= AQM_QTAKG
ORIGINALE_AQM_QTAMQ 	= AQM_QTAMQ
ORIGINALE_AQM_QTAML 	= AQM_QTAML
ORIGINALE_AQM_QTAMC 	= AQM_QTAMC  && ERASMO - 13/06/2012
ORIGINALE_AQM_NUMIDE 	= AQM_NUMIDE
ORIGINALE_AQM_PREACQ 	= AQM_PREACQ

=ACCESSO_PARAMETRO_TOP()
=ACCESSO_ANAGRAFICA_FORNITORE()
=ACCESSO_ANAGRAFICA_CLIENTE()
=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)
**S?
=AQM_CREA_U_MAG_MO("CREA-MOVIMENTO")		&& ################################### CREA IL MOVIMENTO ###################################

Csql = "select * from u_mag_gg where 1=0"
IF !ExecRW(Csql,"u_mag_gg","R")
	return(.f.)
ENDIF


=AQM_CREA()									&& ################################### CREA LA GIACENZA ###################################
IF !ExecRW(cSql,"U_MAG_GG","W")				&& ################################### CREA LA GIACENZA ###################################
	return(.f.)								&& ################################### CREA LA GIACENZA ###################################
ENDIF										&& ################################### CREA LA GIACENZA ###################################

SELECT(_SEL)

_OK_CARICA_MAGAZZINO = .T.

IF TYPE("XXY_CODINT") == 'C'
	XXY_CODINT = AQM_CODINT
ENDIF
IF TYPE("XXY_NRLINT") == 'N'
	XXY_NRLINT = AQM_NRLINT
ENDIF
IF TYPE("XXY_UNIQUE") == 'C'
	XXY_UNIQUE = AQM_UNIQUE
ENDIF

RETURN _OK_CARICA_MAGAZZINO


*************************************
