			         V_NOTEBO = V_DESART + CHR(13) + "Nr. rotoli: " + ALLTRIM(STR(ORD_NUMBOB,5,0)) + " X " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + " = ML " + ALLTRIM(STR(ORD_QTAML,12,0))
			      ENDIF
		      ENDIF
		      **=> ERASMO - FINE 26/01/2012
		      
		      **=> ERASMO - INIZIO 21/02/2012
		      IF ALLTRIM(_cCaus) == "REF"
			      V_NOTEBO = ORD_DESART
			      IF ORD_NUMBOB > 0
			      	IF ORD_SPESSO > 0
			      		V_NOTEBO = V_NOTEBO + CHR(13) + "1 bobina da mm. " + ALLTRIM(STR(ORD_ALTEZZ,5,0)) + " x mtl. " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + " ==> Mq. " + ALLTRIM(STR(ORD_QTAMQ,10,0)) + "  -  Ns. Codice interno " + RES_CODINT
			      	ELSE
			      		V_NOTEBO = V_NOTEBO + CHR(13) + "Ns. Codice interno " + RES_CODINT
			      	ENDIF
			      ENDIF
		      ENDIF
		      **=> ERASMO - FINE 21/02/2012
		      
          *CASE X_TIPO = '6'			&& GESTIONE LEGNO TRUCIOLARE
          *    V_NOTEBO = V_DESART + CHR(13) + ;
          *               "Misure Lato 1: " + ALLTRIM(STR(M.ORD_ALTEZZ,50)) + " mm - Lato 2: " + ALLTRIM(STR(M.ORD_LUNGHE,6,0)) + " mm" + CHR(13) + ;
          *               "Nr.Fogli: " + ALLTRIM(STR(M.ORD_NUMBOB,6,0)) + " - Spessore: " + ALLTRIM(STR(M.ORD_SPESSO,5,0)) + " mm"
      ENDCASE
      **=> ERASMO - FINE 19/12/2011
   ELSE
      IF ORD_NUMBOB = 1
         V_NOTEBO = V_DESART + CHR(13) + ;
                    ALLTRIM(STR(ORD_NUMBOB,6,0)) + " " + ALLTRIM(ORD_DESIMB)
      ELSE
         V_NOTEBO = V_DESART + CHR(13) + ;
                    ALLTRIM(STR(ORD_NUMBOB,6,0)) + " " + ALLTRIM(ORD_DESIMB) + " da " + ALLTRIM(STR(ORD_LOTMIN,5,0))+ " KG."
      ENDIF
   ENDIF
ENDIF

REPLACE ORD_NOTEBO WITH V_NOTEBO

