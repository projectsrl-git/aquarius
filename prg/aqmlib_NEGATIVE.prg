    	AQM_SAVE_LEGSYS  	= MAG_LEGSYS											&& LEGA IL MOVIMENTO U_MAG_MO ALLA DDT U_BOL_DD 
    	LOCAL_IDUNIQUE		= ID_UNIQUE
		AQM_GIACEN  		= AQM_QTAMOV_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT 
    	
    	IF ORIGINALE_AQM_GIACEN > MAG_GIACEN  && CASO IN CUI HO GIA' SCARICATO PARZIALMENTE DELLE GIACENZE (ALTRIMENTI IL SALDO MOVIMENTI VA IN NEGATIVO)
