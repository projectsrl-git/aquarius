************************************************************************************************************************************
FUNCTION INTRA_AGGIORNA_ARCHIVIO_INTRASTAT
************************************************************************************************************************************

*!*	PER MEMORIZZARE I DATI INTRA, UTILIZZARE UNA TABELLA DEDICATA A PARTE (NON I MOVIMENTI CONTABILI); TALE TABELLA DOVRA' ESSERE GENERATA IN AUTOMATICO DURANTE LA REGISTRAZIONE DELLE FATTURE CEE (CLI/FOR),
*!*	CON RAGGRUPPAMENTO PER CLI/FOR+CL.DOG+COD.SERV.INTRA+N.DOC+DT.DOC.

*!*	IL CAMPO MODALITA' DI EROGAZIONE DEVE ESSERE UN CAMPO CONFIGURATO IN ANAGRAFICA FORNITORI, PER DEFAULT 'I' (ISTANTANEA)

*!*	CONTROLLO E MODIFICA DATI INTRA: LA TABELLA INTRA DOVRŕ ESSERE MODIFICABILE E GESTIBILE IN MODO AUTONOMO RISPETTO ALLA PARTE CONTABILE:
*!*	 - SE MODIFICO UNA FATTURA IN PRIMA NOTA, DEVE CONTRAGGIORNARE INTRA
*!*	 - SE ANNULLO UNA FATTURA IN PRIMA NOTA, DEVE ELIMINARE INTRA

*!*	CONTROLLO E MODIFICA INTRA: ELIMINARE QUEI FASTIDIOSI CONTROLLI BLOCCANTI CHE NON PERMETTONO L'USCITA DAL FORM

*!*	RICHIAMO DATI INTRA DA PRIMA NOTA: DEVE ESSERE LO STESSO FORM DI CONTROLLO E MODIFICA, PARAMETRIZZATO PER QUELLA SOLA FATTURA


AxABBSS_INTRA= SELECT()


x_soci = "mov_soc = '" + M.MOV_SOC + "'"
x_anno = "mov_anno = '" + M.MOV_ANNO + "'"
x_npro = "mov_numpro = '" + ALLTRIM(M.MOV_NUMPRO) + "'"
x_cont = "mov_conto = '" + ALLTRIM(M.MOV_CONTO) + "'"
x_cldo = "mov_cldog = '" + ALLTRIM(M.MOV_CLDOG) + "'"
x_seri = "mov_serv_intra = '" + ALLTRIM(M.MOV_SERV_INTRA) + "'"
x_numd = "mov_ndoc  = '" + ALLTRIM(M.MOV_NDOC) + "'"
x_dtdo = "mov_dtdoc  = '" + ALLTRIM(M.MOV_DTDOC) + "'"

Csql   = "select * from INTRASTAT where " + x_soci + " and " + x_anno + " and " + x_npro + " and " + ;
                                          x_cont + " and " + x_cldo + " and " + x_seri  + " and " + x_numd  + " and " + x_dtdo  +;
                                          " order by mov_soc,mov_anno,mov_numpro,mov_conto"


IF !ExecRW(cSql,"INTRASTAT","R")
   return(.f.)
ENDIF

**=> ERASMO - INIZIO 21/09/2020
*** AGGIORNO LA PARTITA IVA A PARTIRE DAL CONTO CLIENTE/FORNITORE
x_soci = "con_soc = '" + PUB_CODSOC + "'"
x_anno = "con_anno = '" + PUB_ANNO + "'"
x_cont = "con_conto = '" + ALLTRIM(M.MOV_CONTO) + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_cont
tsql   = "select CON_TIPOCO from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
IF !ExecCommand(tsql,"TMP_CONTI")
   return(.f.)
ENDIF

SELECT TMP_CONTI
GO TOP
IF !EOF()
	_CLI_FOR = SUBSTR(CON_TIPOCO,1,1)

	IF _CLI_FOR = "C"
	   x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
	   x_codi = "cli_codcli = '" + ALLTRIM(SUBSTR(M.MOV_CONTO,pub_sottog,9)) + "'"
	   x_cond = x_soci + " and " + x_codi
	   Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
	   IF !ExecCommand(cSql,"u_cli_an")
	      return(.f.)
	   ENDIF
	   SELECT u_cli_an
	   GO TOP
	   IF !EOF()
		   IF !EMPTY(CLI_IVACEE)
		   		M.MOV_PARTITA_IVA_INTRA	= CLI_IVACEE
		   ELSE
		   		M.MOV_PARTITA_IVA_INTRA	= CLI_PARIVA
		   ENDIF
	   ENDIF
	ENDIF

	IF _CLI_FOR = "F"
	   x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
	   x_codi = "for_codcli = '" + ALLTRIM(SUBSTR(M.MOV_CONTO,pub_sottog,9)) + "'"
	   x_cond = x_soci + " and " + x_codi
	   Csql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
	   IF !ExecCommand(cSql,"u_for_an")
	      return(.f.)
	   ENDIF
	   SELECT u_for_an
	   GO TOP
	   IF !EOF()
		   IF !EMPTY(FOR_IVACEE)
		   		M.MOV_PARTITA_IVA_INTRA	= FOR_IVACEE
		   ELSE
		   		M.MOV_PARTITA_IVA_INTRA	= FOR_PARIVA
		   ENDIF
	   ENDIF
	ENDIF
ENDIF
**=> ERASMO - FINE 21/09/2020

SELECT INTRASTAT
GO TOP
IF !EOF()


	REPLACE MOV_IMP   						WITH MOV_IMP       		+ M.MOV_IMP   	
	REPLACE MOV_IMPEUR_INTRA  				WITH MOV_IMPEUR_INTRA  	+ M.MOV_IMPEUR_INTRA  			
	REPLACE MOV_IMPSTAT_INTRA  				WITH MOV_IMPSTAT_INTRA  + M.MOV_IMPSTAT_INTRA   			
	REPLACE MOV_IMPVAL_INTRA   				WITH MOV_IMPVAL_INTRA   + M.MOV_IMPVAL_INTRA

	REPLACE MOV_QTA_INTRA  					WITH MOV_QTA_INTRA 		+ M.MOV_QTA_INTRA
	REPLACE MOV_UNITA_SUPPL_INTRA  			WITH MOV_UNITA_SUPPL_INTRA + M.MOV_UNITA_SUPPL_INTRA
	REPLACE MOV_PESO  						WITH MOV_PESO      		+ M.MOV_PESO		

			
ELSE

	SELECT INTRASTAT
	APPEND BLANK

	** CHIAVE DI ACCESSO ALLA TABELLA
	REPLACE MOV_SOC							WITH M.MOV_SOC 						
	REPLACE MOV_ANNO 						WITH M.MOV_ANNO 										
	REPLACE MOV_CONTO 						WITH M.MOV_CONTO
	REPLACE MOV_CLDOG   					WITH M.MOV_CLDOG
	REPLACE MOV_SERV_INTRA  				WITH M.MOV_SERV_INTRA  				
	REPLACE MOV_NDOC  						WITH M.MOV_NDOC  				
	REPLACE MOV_DTDOC 						WITH M.MOV_DTDOC 				

	** DATI DI DETTAGLIO
	REPLACE CON_DESCR 						WITH M.CON_DESCR 				
	REPLACE CON_TIPOCO 						WITH M.CON_TIPOCO 				
	REPLACE MOV_NREGIS 						WITH M.MOV_NREGIS 				
	REPLACE MOV_DTREG 						WITH M.MOV_DTREG 				
	REPLACE MOV_TOP   						WITH M.MOV_TOP				
	REPLACE TOP_INTRA 						WITH M.TOP_INTRA 				
	REPLACE TOP_CLI_FOR  					WITH M.TOP_CLI_FOR  				
	REPLACE MOV_ANT_CAMB_SEGNO 				WITH M.MOV_ANT_CAMB_SEGNO  			
	REPLACE MOV_IMP   						WITH M.MOV_IMP   		
	REPLACE MOV_TMOV 						WITH M.MOV_TMOV 				
	REPLACE MOV_VALUTA   					WITH M.MOV_VALUTA   				
	REPLACE MOV_CAMBIO 						WITH M.MOV_CAMBIO 			
	REPLACE MOV_IVA   						WITH M.MOV_IVA   				
	REPLACE FLG_BENI_SERVIZI 				WITH M.FLG_BENI_SERVIZI  			
	REPLACE MOV_MODPAG   					WITH M.MOV_MODPAG   				
	REPLACE CPA_MOD_PAG   					WITH M.CPA_MOD_PAG   				
	REPLACE MOV_PESO  						WITH M.MOV_PESO  				
	REPLACE MOV_TISPE   					WITH M.MOV_TISPE   				
	REPLACE MOV_PORTO   					WITH M.MOV_PORTO   				
	REPLACE MOV_IMPEUR_INTRA  				WITH M.MOV_IMPEUR_INTRA  			
	REPLACE MOV_IMPSTAT_INTRA  				WITH M.MOV_IMPSTAT_INTRA   			
	REPLACE MOV_NAZIONE_INTRA  				WITH M.MOV_NAZIONE_INTRA   			
	*REPLACE MOV_STATO_INTRA_PROV 			WITH M.PAESE_ORIGINE
	REPLACE MOV_STATO_INTRA_PROV 			WITH IIF(EMPTY(M.MOV_STATO_INTRA_PROV),M.PAESE_ORIGINE,M.MOV_STATO_INTRA_PROV)  && ERASMO - 05/11/2019
	REPLACE MOV_STATO_INTRA_ORIG 			WITH M.PAESE_ORIGINE
