	REPLACE MOV_QTA_INTRA  					WITH M.MOV_QTA_INTRA  			
	REPLACE MOV_COND_CONS_INTRA  			WITH M.MOV_COND_CONS_INTRA   		
	REPLACE MOV_MEZZI_TRASP_INTRA   		WITH M.MOV_MEZZI_TRASP_INTRA   		
	REPLACE MOV_PROVIN_DESTI_INTRA  		WITH M.MOV_PROVIN_DESTI_INTRA  		
