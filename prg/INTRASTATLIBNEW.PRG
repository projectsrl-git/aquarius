************************************************************************************************************************************
FUNCTION INTRA_ASSEGNA_VARIABILI_INTRASTAT
************************************************************************************************************************************

AxABBSS_INTRA2= SELECT()

*M.CPA_MOD_PAG = M.MOV_EROG
*M.CPA_MOD_INC = M.MOV_MODINC
*!*	IF M.MOV_ANT_CAMB_SEGNO
*!*		M.MOV_IMP = M.MOV_IMP * -1
*!*	ENDIF

IF !EMPTY(PUB_NAZION)
	** SERGIO : VIENE RIASSEGNATA DA OK_REG IN QUANTO SE UTENTE SBAGLIA A DIGITARE IL CONTO CONTABILE , UTENTE
	** MODIFICA LA PN ATTRIBUENDO IL CONTO GIUSTO PER CUI LA NAZIONE VIENE RIPESCATA DAL NUOVO CONTO CONTABILE
 	M.MOV_NAZIONE_INTRA     = PUB_NAZION
 	M.NAZIONE_INTRA         = PUB_NAZION
ENDIF


** ########################################### ACCESSO AI PARAMETRI ##################################################

	

	IF EMPTY(M.CPA_MOD_PAG)
		IF !EMPTY(ALLTRIM(M.MOV_MODPAG))
			TISPE__ = SEEK_PARA('CPA',ALLTRIM(M.MOV_MODPAG),'CODICE','CODICE',"4,10")
			IF !EMPTY(TISPE__)
			    SELECT _pj_para
			    __CPA_MOD_PAG	= LIBERA
			ELSE
				__CPA_MOD_PAG	= ""
			ENDIF
			MODALITA_EROGAZIONE = ALLTRIM(SUBSTR(__CPA_MOD_PAG,11,100))	&& DETERMINA LA MODALITA DI EROGAZIONE
			NR_TRANCHE=OCCURS(' ',MODALITA_EROGAZIONE)	
			DO CASE
				CASE	NR_TRANCHE = 0
					M.CPA_MOD_PAG = 'I'	&& MODALITA DI EROGAZIONE ISTANTANEA
				CASE	NR_TRANCHE = 1
					M.CPA_MOD_PAG = 'I'	&& MODALITA DI EROGAZIONE ISTANTANEA
				OTHERWISE
					M.CPA_MOD_PAG = 'R'	&& MODALITA DI EROGAZIONE A PIU' RIPRESE
			ENDCASE
			MODALITA_INCASSO = SUBSTR(__CPA_MOD_PAG,1,10)	&& DETERMINA LA MODALITA D'INCASSO A=Accredito; B=Bonifico; X=Altro
			BONIFICO=OCCURS(' ',MODALITA_INCASSO)	
			IF EMPTY(M.CPA_MOD_INC)
				IF SUBSTR(MODALITA_INCASSO,4,3) = "BON"			
					M.CPA_MOD_INC = 'B'	&& BONIFICO 		
				ELSE
					M.CPA_MOD_INC = 'X'	&& ALTRO
				ENDIF
			ENDIF
		ENDIF
	ENDIF



	IF EMPTY(M.CPA_MOD_INC)
		IF !EMPTY(ALLTRIM(M.MOV_MODPAG))
			TISPE__ = SEEK_PARA('CPA',ALLTRIM(M.MOV_MODPAG),'CODICE','CODICE',"4,10")
			IF !EMPTY(TISPE__)
			    SELECT _pj_para
			    __CPA_MOD_PAG	= LIBERA
			ELSE
				__CPA_MOD_PAG	= ""
			ENDIF
			MODALITA_INCASSO = SUBSTR(__CPA_MOD_PAG,1,10)	&& DETERMINA LA MODALITA D'INCASSO A=Accredito; B=Bonifico; X=Altro
			BONIFICO=OCCURS(' ',MODALITA_INCASSO)	
			IF EMPTY(M.CPA_MOD_INC)
				IF SUBSTR(MODALITA_INCASSO,4,3) = "BON"			
					M.CPA_MOD_INC = 'B'	&& BONIFICO 		
				ELSE
					M.CPA_MOD_INC = 'X'	&& ALTRO
				ENDIF
			ENDIF
		ENDIF
	ENDIF


	IF !EMPTY(M.MOV_PORTO)
		V_SEEK_= 'POR'+M.MOV_PORTO
	   	=seek_std("para",V_SEEK_,"codice","PARA0_CU")
	   	SELECT PARA0_CU
	   	GO TOP
	    IF !EOF()
			M.MOV_COND_CONS_INTRA = SUBSTR(LIBERA,1,1)
		ELSE
			M.MOV_COND_CONS_INTRA = ""
	    ENDIF
	ENDIF


	IF !EMPTY(ALLTRIM(M.MOV_TISPE))
		TISPE__ = seek_para('MEZ',ALLTRIM(M.MOV_TISPE),'CODICE','CODICE',"4,3")
		IF !EMPTY(TISPE__)
		    SELECT _pj_para
		    M.MOV_MEZZI_TRASP_INTRA	= SUBSTR(LIBERA,26,1)	&& LIBERA : TIPO TRASPORTO INTRASTAT:4
		ELSE
			M.MOV_MEZZI_TRASP_INTRA	= ""
		ENDIF
	ELSE
		M.MOV_MEZZI_TRASP_INTRA	= ""
	ENDIF


	V_SEEK_= 'TOP'+M.MOV_TOP
   	=seek_std("para",V_SEEK_,"codice","PARA1_CU")
   	SELECT PARA1_CU
   	GO TOP
    IF !EOF()
		M.TOP_INTRA   = SUBSTR(PARA1_CU.LIBERA,24,1)
		M.TOP_CLI_FOR = SUBSTR(PARA1_CU.LIBERA,12,1)
		M.MOV_NDOC    = IIF(SUBSTR(PARA1_CU.LIBERA,12,1) = 'C',M.MOV_NPROT,M.MOV_NDOC)
						
    ELSE
		M.TOP_INTRA 	= ""
		M.TOP_CLI_FOR 	= ""
 		M.MOV_NDOC    	= ""
   ENDIF


	**V_SEEK_= 'IVA'+M.MOV_IVA							&& 2016/01/05 SERGIO SENZA ALLTRIM NON FUNZIONA SU ALCUNI DATABASE COME SOPRAD
	V_SEEK_= 'IVA'+ALLTRIM(M.MOV_IVA)					&& 2016/01/05 SERGIO SENZA ALLTRIM NON FUNZIONA SU ALCUNI DATABASE COME SOPRAD
   	=seek_std("para",V_SEEK_,"codice","PARA2_CU")
   	SELECT PARA2_CU
   	GO TOP
    IF !EOF()
		M.FLG_BENI_SERVIZI = SUBSTR(PARA2_CU.ITALIANO,1,100)
    ELSE
		M.FLG_BENI_SERVIZI = ""
    ENDIF

 	
    IF EMPTY(M.MOV_STATO_INTRA_PROV)
		V_SEEK_= 'STA'+M.NAZIONE_INTRA
	   	=seek_std("para",V_SEEK_,"codice","PARA4_CU")
	   	SELECT PARA4_CU
	   	GO TOP
	    IF !EOF()
			M.MESSAGGIO_PARA4		= SUBSTR(PARA4_CU.ITALIANO,1,100)
			M.MOV_STATO_INTRA_PROV	= IIF(SUBSTR(PARA4_CU.LIBERA,1,2) = '',M.MOV_STATO_INTRA_PROV,SUBSTR(PARA4_CU.LIBERA,1,2))
	 		M.MOV_NAZIONE_INTRA     = M.NAZIONE_INTRA
	    ELSE
			M.MESSAGGIO_PARA4		= ""
			*M.PAESE_ORIGINE 		= ""
			M.MOV_STATO_INTRA_PROV	= ""
			M.MOV_NAZIONE_INTRA     = ""
	    ENDIF
	ENDIF
	
    IF EMPTY(M.MOV_STATO_INTRA_ORIG)
		V_SEEK_= 'STA'+M.MOV_NAZIONE_INTRA
	   	=seek_std("para",V_SEEK_,"codice","PARA4_CU")
	   	SELECT PARA4_CU
	   	GO TOP
	    IF !EOF()
			M.MESSAGGIO_PARA4		= SUBSTR(PARA4_CU.ITALIANO,1,100)
			M.MOV_STATO_INTRA_ORIG	= IIF(SUBSTR(PARA4_CU.LIBERA,1,2) = '',M.MOV_STATO_INTRA_ORIG,SUBSTR(PARA4_CU.LIBERA,1,2))
	    ELSE
			M.MESSAGGIO_PARA4		= ""
			M.MOV_STATO_INTRA_ORIG	= ""
	    ENDIF
*!*			**=> ERASMO - INIZIO 24/01/2018
*!*			*** Paese pagamento: va indicato il codice ISO del paese dove viene effettuato il pagamento.
*!*			*** Per la Grecia va utilizzato il codice GR
*!*			IF M.MOV_STATO_INTRA_ORIG = "EL"
*!*				M.MOV_STATO_INTRA_ORIG = "GR"
*!*			ENDIF
*!*			**=> ERASMO - FINE 24/01/2018
	ENDIF
	
	M.PAESE_ORIGINE=M.MOV_STATO_INTRA_ORIG


** ########################################### ACCESSO A MOV_CONT ##################################################



	cSql=""
	cNomeCursorSql="MOV_CONT_CURS__"
	TEXT TO cSql NOSHOW
		
		
		SELECT * FROM CONTI
		WHERE
			CON_ANNO='<<M.MOV_ANNO>>' 	AND
			CON_TIPOCO IN ('C','F') 	AND
			CON_CONTO IN (SELECT MOV_CONTO FROM MOV_CONT WHERE MOV_NUMPRO='<<M.MOV_NUMPRO>>')

	
	ENDTEXT
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
		
	SELECT MOV_CONT_CURS__
	GO TOP
	IF !EOF()
			M.MOV_CONTO 	= CON_CONTO
			M.CON_DESCR 	= CON_DESCR
			M.CON_TIPOCO 	= CON_TIPOCO
	ELSE
			WAIT WINDOWS "CONTO CONTABILE NON TROVATO SU MOV_CONT"
			M.MOV_CONTO 	= "????????"
			M.CON_DESCR 	= "????????"
			M.CON_TIPOCO 	= ""
	ENDIF



	DO CASE
		CASE M.MOV_VALUTA ='EUR'
		
			M.MOV_IMPEUR_INTRA = ROUND(IIF(M.MOV_ANT_CAMB_SEGNO,(M.MOV_IMP* -1),M.MOV_IMP),0)
			M.MOV_IMPSTAT_INTRA= ROUND(IIF(M.MOV_ANT_CAMB_SEGNO,(M.MOV_IMP* -1),M.MOV_IMP),0)
			M.MOV_IMPVAL_INTRA = 0
		
		OTHERWISE
		
			M.MOV_IMPEUR_INTRA = ROUND(IIF(M.MOV_ANT_CAMB_SEGNO,(M.MOV_IMP* -1),M.MOV_IMP)*MOV_CAMBIO,0)
			M.MOV_IMPSTAT_INTRA= ROUND(IIF(M.MOV_ANT_CAMB_SEGNO,(M.MOV_IMP* -1),M.MOV_IMP)*MOV_CAMBIO,0)
			M.MOV_IMPVAL_INTRA = ROUND(IIF(M.MOV_ANT_CAMB_SEGNO,(M.MOV_IMP* -1),M.MOV_IMP),0)

	ENDCASE
	




SELECT(AxABBSS_INTRA2)													
RETURN





************************************************************************************************************************************
FUNCTION INTRA_VERIFICA_SE_DEVE_ELABORARE_CONTROPARTITA
************************************************************************************************************************************


AxABBSS_INTRA3= SELECT()

__ELABORA_CONTROPARTITA = .T.


** ELABORA SOLO LE CONTROPARTITE IDENTIFICATE DA UN TOP INTRA 			: PARA.INTRA    					= SUBSTR(M.LIBERA,24,1) = 'S'
** ELABORA SOLO LE CONTROPARTITE DELLE FATTURE DEI PAESI MEMBRI CEE 	: PARA.FATTURE  					= SUBSTR(M.LIBERA,2,1)  = 'S'
** ELABORA SOLO LE CONTROPARTITE IDENTIFICATE CON						: CON_TIPOCO    					= 'X'
** ESCLUDE I MOVIMENTI DI CONTABILITA' PREVISIONALE 					: MOV_CONTABILITA_PREVISIONALE 		= 'P'
** ESCLUDE I MOVIMENTI DI CHIUSURA										: MOV_TOP 							= 'CHI'
** ESCLUDE I MOVIMENTI DIVERSI DA BENI/SERVIZI							: SUBSTRING(PARA2.ITALIANO,1,100) = 'BENI-INTRASTAT' OR SUBSTRING(PARA2.ITALIANO,1,100) = 'SERVIZI-INTRASTAT')
** ESCLUDE I MOVIMENTI INTRA ELIMINATI DA APPOSITA FUNZIONE				: MOV.MOV_INTRA_DELETED = 0
** ELABORA SOLO LE CONTROPARTITE DEI PAESI MEMBRI CEE 					: MOV_STATO_CEE 					= 'CEE'

** ______________________________________________________________VERIFICA SE TOP INTRA____________________________________________

	
	V_SEEK_= 'TOP'+M.MOV_TOP
	=seek_std("para",V_SEEK_,"codice","PARA1_CU")
	SELECT PARA1_CU
	GO TOP
	IF !EOF()
		__TOP_INTRA   = SUBSTR(PARA1_CU.LIBERA,24,1)
	ELSE
		__TOP_INTRA 	= ""
	ENDIF
	IF	__TOP_INTRA   <> "S"
		SELECT(AxABBSS_INTRA3)
		__ELABORA_CONTROPARTITA = .F.
		RETURN(__ELABORA_CONTROPARTITA)
	ENDIF

 ** ______________________________________________________________VERIFICA SE CONTO CONTABILE  'X'____________________________________________


	x_soci = "con_soc = '" + PUB_CODSOC + "'"
	x_anno = "con_anno = '" + M.MOV_ANNO + "'"
	x_cont = "con_conto = '" + ALLTRIM(M.MOV_CONTO) + "'"
	x_cond = x_soci + " and " + x_anno + " and " + x_cont
	Csql   = "select * from conti where " + x_cond + " order by con_soc,con_anno,con_conto"
	IF !ExecCommand(cSql,"tmp_conti_")
	   return(.f.)
	ENDIF
	SELECT tmp_conti_
	GO TOP
	IF EOF()
		WAIT WINDOWS "CONTROPARTITA INESISTENTE :" + ALLTRIM(M.MOV_CONTO)
		SELECT(AxABBSS_INTRA3)
		__ELABORA_CONTROPARTITA = .F.
		RETURN(__ELABORA_CONTROPARTITA)
	ELSE
		IF CON_TIPOCO <> "X"
			SELECT(AxABBSS_INTRA3)
			__ELABORA_CONTROPARTITA = .F.
			RETURN(__ELABORA_CONTROPARTITA)
		ENDIF		
	ENDIF


 ** ______________________________________________________________ESCLUDE I MOVIMENTI DI CONTABILIITA' PREVISIONALE____________________________________________


	IF MOV_CONTABILITA_PREVISIONALE 		= 'P'
		SELECT(AxABBSS_INTRA3)
		__ELABORA_CONTROPARTITA = .F.
		RETURN(__ELABORA_CONTROPARTITA)
	ENDIF	

 ** ______________________________________________________________ESCLUDE I MOVIMENTI DI CHIUSURA____________________________________________


	IF MOV_TOP 	= 'CHI'
		SELECT(AxABBSS_INTRA3)
		__ELABORA_CONTROPARTITA = .F.
		RETURN(__ELABORA_CONTROPARTITA)
	ENDIF	


 ** ______________________________________________________________ESCLUDE I MOVIMENTI DIVERSI DA BENI/SERVIZI____________________________________________



	**V_SEEK_= 'IVA'+M.MOV_IVA							&& 2016/01/05 SERGIO SENZA ALLTRIM NON FUNZIONA SU ALCUNI DATABASE COME SOPRAD
	V_SEEK_= 'IVA'+ALLTRIM(M.MOV_IVA)					&& 2016/01/05 SERGIO SENZA ALLTRIM NON FUNZIONA SU ALCUNI DATABASE COME SOPRAD
   	=seek_std("para",V_SEEK_,"codice","PARA2_CU")
   	SELECT PARA2_CU
   	GO TOP
    IF !EOF()
		__FLG_BENI_SERVIZI = SUBSTR(PARA2_CU.ITALIANO,1,100)
    ELSE
		__FLG_BENI_SERVIZI = ""
    ENDIF

 	IF __FLG_BENI_SERVIZI =	'BENI-INTRASTAT' OR  __FLG_BENI_SERVIZI = 'SERVIZI-INTRASTAT'
 	ELSE
		SELECT(AxABBSS_INTRA3)
		__ELABORA_CONTROPARTITA = .F.
		RETURN(__ELABORA_CONTROPARTITA)
	ENDIF	

 ** ______________________________________________________________ESCLUDE I MOVIMENTI INTRA ELIMINATI DA APPOSITA FUNZIONE____________________________________________


 	IF M.MOV_INTRA_DELETED	
		SELECT(AxABBSS_INTRA3)
		__ELABORA_CONTROPARTITA = .F.
		RETURN(__ELABORA_CONTROPARTITA)
	ENDIF	

** ______________________________________________ELABORA SOLO LE CONTROPARTITE CEE DEI CLIENTI/FORNITORI CEE______________________________________


	*** ERASMO - 24/12/2019 - LA SCRITTURA DELLA TABELLA INTRASTAT VIENE EFFETTUATA ANCHE SE NON SI TRATTA DI UN PAESE CEE, L'IMPORTANTE E' CHE SODDISFI LE CONDIZIONI DI CUI SOPRA
	*** ERASMO - 24/12/2019 - IN QUESTO MODO VIENE RISOLTO IL CASO DI OPERAZIONI VERSO PAESI NON CEE MA CON CONSEGNA VERSO PAESI CEE PER I QUALI E' NECESSARIO EFFETTUARE LA DICHIARAZIONE INTRA
*!*		IF PUB_PAESE_CEE	&& SE PAESE CEE ELABORA ALTRIMENTI NO (VARIABILE ASSEGNATA DURANTE LA QUADRATURA DELLA PRIMA NOTA)
*!*		ELSE
*!*			SELECT(AxABBSS_INTRA3)
*!*			__ELABORA_CONTROPARTITA = .F.
*!*			RETURN(__ELABORA_CONTROPARTITA)
*!*		ENDIF
	


SELECT(AxABBSS_INTRA3)													
RETURN(__ELABORA_CONTROPARTITA)




************************************************************************************************************************************
PROCEDURE INTRA_CARICA_INTRASTAT
************************************************************************************************************************************
**
** FUNZIONALITA' :
**
**		CREA CURSORE1 (_PAR_INTRA_CURSOR1) : - Modello INTRA 2 bis - SEZIONE 1 			: ACQUISTO BENI
**		CREA CURSORE2 (_PAR_INTRA_CURSOR2) : - Modello INTRA 2 quater - SEZIONE 3		: ACQUISTO SERVIZI RICEVUTI
**		CREA CURSORE3 (_PAR_INTRA_CURSOR3) : - Modello INTRA 1 bis - SEZIONE 1 			: CESSIONE BENI
**		CREA CURSORE4 (_PAR_INTRA_CURSOR4) : - Modello INTRA 1 quater - SEZIONE 3		: CESSIONE SERVIZI RESI
**		CREA CURSORE5 (_PAR_INTRA_CURSOR5) : - Modello INTRA 2 ter - SEZIONE 2			: RETTIFICHE ACQUISTI BENI PERIODI PRECEDENTI
**		CREA CURSORE6 (_PAR_INTRA_CURSOR6) : - Modello INTRA 2 quinques - SEZIONE 4		: RETTIFICHE ACQUISTI SERVIZI PERIODI PRECEDENTI
**		CREA CURSORE7 (_PAR_INTRA_CURSOR7) : - Modello INTRA 1 ter - SEZIONE 2			: RETTIFICHE CESSIONI BENI PERIODI PRECEDENTI
**		CREA CURSORE8 (_PAR_INTRA_CURSOR8) : - Modello INTRA 1 quinques - SEZIONE 4		: RETTIFICHE ACQUISTI CESSIONE PERIODI PRECEDENTI
**
**		TIPO DI ESTRAZIONE DATI CONTABILI :
**
**			_PAR_FATTURE_CLI_FOR = "F" 	MOVIMENTI DI ACQUISTO
**			_PAR_FATTURE_CLI_FOR = "C" 	MOVIMENTI DI CESIONE
**			_PAR_FATTURE_CLI_FOR = "A" 	MOVIMENTI DI ACQUISTO+CESSIONE
**
**
** 		RESTITUISCE IL CURSORE >>>>>>> INTRA_MOV_CONT <<<<<<<  SE SI DESIDERA SOLO ESTRARRE I MOVIMENTI CONTABILI INTRASTAT E NON I CURSORI INTRASTAT
**
**
LPARAMETERS _PAR_MOVNUMPRO,_PAR_DATA_DAL,_PAR_DATA_AL,_PAR_FATTURE_CLI_FOR,_PAR_INTRA,_PAR_INTRA_CURSOR1,_PAR_INTRA_CURSOR2,_PAR_INTRA_CURSOR3,_PAR_INTRA_CURSOR4,_PAR_INTRA_CURSOR5,_PAR_INTRA_CURSOR7,_PAR_INTRA_CURSOR6,_PAR_INTRA_CURSOR8


RELEASE _V_PROG_RIGA_RETTIFICHE_ACQUISTO_BENI,_V_PROG_RIGA_RETTIFICHE_ACQUISTO_SERVIZI
RELEASE _V_PROG_RIGA_RETTIFICHE_CESSIONE_BENI,_V_PROG_RIGA_RETTIFICHE_CESSIONE_SERVIZI
PUBLIC _V_PROG_RIGA_RETTIFICHE_ACQUISTO_BENI,_V_PROG_RIGA_RETTIFICHE_ACQUISTO_SERVIZI
PUBLIC _V_PROG_RIGA_RETTIFICHE_CESSIONE_BENI,_V_PROG_RIGA_RETTIFICHE_CESSIONE_SERVIZI

_V_PROG_RIGA_RETTIFICHE_ACQUISTO_BENI	 = 0
_V_PROG_RIGA_RETTIFICHE_ACQUISTO_SERVIZI = 0
_V_PROG_RIGA_RETTIFICHE_CESSIONE_BENI    = 0
_V_PROG_RIGA_RETTIFICHE_CESSIONE_SERVIZI = 0


RELEASE _V_DARE,_V_AVERE,_V_DATA_DAL,_V_DATA_AL,_INTRASTAT_MOVIMENTI_CONTABILI_ELABORATI,__NUMERO_PROGR_RIGA_1,_V_VALORE_EURO
RELEASE _V_QTA_IN_UM,_V_PORTO,_V_CLDOG,_V_VALORE_STATISTICO,_FATTURE_INTRA_CLIENTI_FORNITORI_,_V_FATTURE_CLI_FOR,_V_CREA_INTRA
RELEASE _V_VALORE_VALUTA,_V_PESO,_V_PROG_RIGA_ACQUISTO_BENI,_V_PROG_RIGA_ACQUISTO_SERVIZI,_V_NDOC,_V_DTDOC,_V_SERV_INTRA,_V_MOD_PAG,_V_MOD_INC,_V_NUM_RECORDS_TOTALI
RELEASE _V_VALORE_EURO_NUMERICO,_V_UNITA_SUPPLEMENTARI
RELEASE _V_INTRA_CURSOR1,_V_INTRA_CURSOR2,_V_INTRA_CURSOR3,_V_INTRA_CURSOR4


PUBLIC _V_DARE,_V_AVERE,_V_DATA_DAL,_V_DATA_AL,_INTRASTAT_MOVIMENTI_CONTABILI_ELABORATI,__NUMERO_PROGR_RIGA_1,_V_VALORE_EURO
PUBLIC _V_QTA_IN_UM,_V_PORTO,_V_CLDOG,_V_VALORE_STATISTICO,_FATTURE_INTRA_CLIENTI_FORNITORI_,_V_FATTURE_CLI_FOR,_V_CREA_INTRA
PUBLIC _V_VALORE_VALUTA,_V_PESO,_V_PROG_RIGA_ACQUISTO_BENI,_V_PROG_RIGA_ACQUISTO_SERVIZI,_V_NDOC,_V_DTDOC,_V_SERV_INTRA,_V_MOD_PAG,_V_MOD_INC,_V_NUM_RECORDS_TOTALI
PUBLIC _V_VALORE_EURO_NUMERICO,_V_UNITA_SUPPLEMENTARI
PUBLIC _V_INTRA_CURSOR1,_V_INTRA_CURSOR2,_V_INTRA_CURSOR3,_V_INTRA_CURSOR4


__NUMERO_PROGR_RIGA_1 						= 0
_V_DATA_DAL									= _PAR_DATA_DAL
_V_DATA_AL									= _PAR_DATA_AL
_V_FATTURE_CLI_FOR							= _PAR_FATTURE_CLI_FOR
_V_CREA_INTRA       						= _PAR_INTRA
_V_PROG_RIGA_ACQUISTO_BENI					= 0
_V_PROG_RIGA_ACQUISTO_SERVIZI				= 0
_V_NDOC 									= ""
_V_DTDOC									= ""
_V_SERV_INTRA								= ""
_V_MOD_PAG									= 0
_V_MOD_INC 									= ""
_V_VALORE_EURO_NUMERICO						= 0
_V_INTRA_CURSOR1							= _PAR_INTRA_CURSOR1
_V_INTRA_CURSOR2							= _PAR_INTRA_CURSOR2
_V_INTRA_CURSOR3							= _PAR_INTRA_CURSOR3
_V_INTRA_CURSOR4							= _PAR_INTRA_CURSOR4
_V_INTRA_CURSOR5							= _PAR_INTRA_CURSOR5
_V_INTRA_CURSOR7							= _PAR_INTRA_CURSOR7
_V_INTRA_CURSOR6							= _PAR_INTRA_CURSOR6
_V_INTRA_CURSOR8							= _PAR_INTRA_CURSOR8
_V_UNITA_SUPPLEMENTARI						= 0
_INTRASTAT_MOVIMENTI_CONTABILI_ELABORATI	= 0

DO CASE


	CASE _V_FATTURE_CLI_FOR = "F"
		WAIT WINDOW "Elaborazione movimenti contabili di ACQUISTO INTRACOMUNITARIO in corso. Questa operazione potrebbe richiedere qualche secondo..." NOWAIT

	CASE _V_FATTURE_CLI_FOR = "C"
		WAIT WINDOW "Elaborazione movimenti contabili di CESSIONI INTRACOMUNITARI in corso. Questa operazione potrebbe richiedere qualche secondo..." NOWAIT

*!*		CASE _V_FATTURE_CLI_FOR = "C"
*!*			WAIT WINDOW "Elaborazione movimenti contabili di ACQUISTO/CESSIONI INTRACOMUNITARI in corso. Questa operazione potrebbe richiedere qualche secondo..." NOWAIT


	OTHERWISE
		WAIT WINDOW "ATTENZIONE : NON HAI INDICATO IL TIPO DI ELABORAZIONE ????" NOWAIT
		RETURN	

ENDCASE
cSql=""
cNomeCursorSql="INTRA_MOV_CONT"

** ELABORA SOLO LE CONTROPARTITE IDENTIFICATE DA UN TOP INTRA 			: PARA.INTRA    					= SUBSTR(M.LIBERA,24,1) = 'S'
** ELABORA SOLO LE CONTROPARTITE DELLE FATTURE DEI PAESI MEMBRI CEE 	: PARA.FATTURE  					= SUBSTR(M.LIBERA,2,1)  = 'S'
** ELABORA SOLO LE CONTROPARTITE DEI PAESI MEMBRI CEE 					: MOV_STATO_CEE 					= 'CEE'
** ELABORA SOLO LE CONTROPARTITE IDENTIFICATE CON						: CON_TIPOCO    					= 'X'
** ESCLUDE I MOVIMENTI DI CONTABILITA' PREVISIONALE 					: MOV_CONTABILITA_PREVISIONALE 		<> 'P'
** ESCLUDE I MOVIMENTI DI CHIUSURA										: MOV_TOP 							<> 'CHI'


IF EMPTY(_PAR_MOVNUMPRO)

	TEXT TO cSql NOSHOW

		SELECT
			id_unique,			
			MOV_SOC,
			MOV_ANNO,
			MOV_CONTO,
			CON_DESCR,
			CON_TIPOCO,
			MOV_NREGIS,
			MOV_DTREG,
			MOV_NDOC,
			MOV_DTDOC,
		    MOV_TOP,
			TOP_INTRA,
			TOP_CLI_FOR,
			MOV_IMP,
			MOV_TMOV,
			MOV_VALUTA,
			MOV_CAMBIO,
			MOV_IVA,
			FLG_BENI_SERVIZI,
			MOV_MODPAG,
			CPA_MOD_PAG,
			MOV_PESO,
			MOV_TISPE,
			MOV_PORTO,
			MOV_CLDOG,
			MOV_SERV_INTRA,
			MOV_IMPEUR_INTRA,
			MOV_IMPVAL_INTRA ,
			MOV_IMPSTAT_INTRA,
			MOV_NAZIONE_INTRA,
			MOV_STATO_INTRA_PROV,
			--CASE MOV_STATO_INTRA_ORIG WHEN 'EL' THEN 'GR' ELSE MOV_STATO_INTRA_ORIG END AS MOV_STATO_INTRA_ORIG,
			MOV_STATO_INTRA_ORIG, -- ERASMO - 24/12/2019
			PAESE_ORIGINE,
			ITALIANO,
			MOV_PARTITA_IVA_INTRA,
			MOV_QTA_INTRA,
			MOV_COND_CONS_INTRA,
			MOV_MEZZI_TRASP_INTRA,
			MOV_PROVIN_DESTI_INTRA,
			MOV_UNITA_SUPPL_INTRA,
			MOV_NUMPRO,	
			CPA_MOD_INC, 	
			MOV_INTRA_ok_ko,
			MOV_CONTABILITA_PREVISIONALE,
			MESSAGGIO_PARA4
		FROM INTRASTAT
		WHERE
			TOP_CLI_FOR = '<<_V_FATTURE_CLI_FOR>>' AND
			MOV_DTREG BETWEEN '<<_V_DATA_DAL>>' AND '<<_V_DATA_AL>>' AND
			MOV_INTRA_DELETED = 0  -- && FILTRO PER RIGHE INTRA ELIMINATE CON APPOSITA FUNZIONE
		ORDER BY TOP_CLI_FOR, MOV_NREGIS,MOV_CLDOG,MOV_SERV_INTRA,MOV_CONTO,MOV_DTREG,FLG_BENI_SERVIZI
		
	ENDTEXT

ELSE

	TEXT TO cSql NOSHOW

		SELECT
			id_unique,			
			MOV_SOC,
			MOV_ANNO,
			MOV_CONTO,
			CON_DESCR,
			CON_TIPOCO,
			MOV_NREGIS,
			MOV_DTREG,
			MOV_NDOC,
			MOV_DTDOC,
		    MOV_TOP,
			TOP_INTRA,
			TOP_CLI_FOR,
			MOV_IMP,
			MOV_TMOV,
			MOV_VALUTA,
			MOV_CAMBIO,
			MOV_IVA,
			FLG_BENI_SERVIZI,
			MOV_MODPAG,
			CPA_MOD_PAG,
			MOV_PESO,
			MOV_TISPE,
			MOV_PORTO,
			MOV_CLDOG,
			MOV_SERV_INTRA,
			MOV_IMPEUR_INTRA,
			MOV_IMPVAL_INTRA ,
			MOV_IMPSTAT_INTRA,
			MOV_NAZIONE_INTRA,
			MOV_STATO_INTRA_PROV,
			--CASE MOV_STATO_INTRA_ORIG WHEN 'EL' THEN 'GR' ELSE MOV_STATO_INTRA_ORIG END AS MOV_STATO_INTRA_ORIG,
			MOV_STATO_INTRA_ORIG, -- ERASMO - 24/12/2019
			PAESE_ORIGINE,
			ITALIANO,
			MOV_PARTITA_IVA_INTRA,
			MOV_QTA_INTRA,
			MOV_COND_CONS_INTRA,
			MOV_MEZZI_TRASP_INTRA,
			MOV_PROVIN_DESTI_INTRA,
			MOV_UNITA_SUPPL_INTRA,
			MOV_NUMPRO,	
			CPA_MOD_INC, 	
			MOV_INTRA_ok_ko,
			MOV_CONTABILITA_PREVISIONALE,
			MESSAGGIO_PARA4
		FROM INTRASTAT
		WHERE
			MOV_NUMPRO = '<<_PAR_MOVNUMPRO>>' AND
			MOV_INTRA_DELETED = 0  -- && FILTRO PER RIGHE INTRA ELIMINATE CON APPOSITA FUNZIONE
		ORDER BY TOP_CLI_FOR, MOV_NREGIS,MOV_CLDOG,MOV_SERV_INTRA,MOV_CONTO,MOV_DTREG,FLG_BENI_SERVIZI
		
