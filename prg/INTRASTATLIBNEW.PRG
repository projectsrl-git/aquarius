************************************************************************************************************************************
FUNCTION INTRA_CREA_TABELLA_INTRASTAT
************************************************************************************************************************************
** CREAZIONE TABELLA INTRASTAT DALLE VARIABILI DI MOV_CONT

INTRA_INTRA= SELECT()


IF (PUB_VARPN=.T.) .OR. (PUB_ANNPN=.T.)		&& SOLO PER VARIAZIONI/ANNULLI DELLA PRIMA NOTA
	IF PUB_AGGIORNA_TABELLA_INTRASTAT = 1 OR PUB_AGGIORNA_TABELLA_INTRASTAT = 3	&& = 1 LASCIA INALTERATI I RECORD INTRASTAT; = 2 RICREA I DATI INTRASTAT DALLA PRIMA NOTA CORRENTE; = 3 MODIFICA I DATI INTRASTAT A PRESCINDERE DELLA PRIMA NOTA CORRENTE
		=INTRASTAT_CONTROAGGIORNA_MOVNUMPRO()
		RETURN
	ENDIF
	IF PUB_AGGIORNA_TABELLA_INTRASTAT = 2	&& = 1 LASCIA INALTERATI I RECORD INTRASTAT; = 2 RICREA I DATI INTRASTAT DALLA PRIMA NOTA CORRENTE; = 3 MODIFICA I DATI INTRASTAT A PRESCINDERE DELLA PRIMA NOTA CORRENTE
	ELSE
		RETURN
	ENDIF
ENDIF


__ELABORA_CONTROPARTITA__=INTRA_VERIFICA_SE_DEVE_ELABORARE_CONTROPARTITA()

IF !__ELABORA_CONTROPARTITA__
	RETURN
ENDIF
	
=INTRA_ASSEGNA_VARIABILI_INTRASTAT()	
=INTRA_AGGIORNA_ARCHIVIO_INTRASTAT()
	

SELECT(INTRA_INTRA)	
	
	
RETURN


