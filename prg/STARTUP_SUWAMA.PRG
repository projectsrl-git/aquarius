	ENDIF
	SELECT DBSOCIETA
	GO TOP
	V_CONTARECORD=0

	DO WHILE !EOF()

		IF DELETED()
			SKIP
			LOOP
		ENDIF
		
		V_CONTARECORD=V_CONTARECORD+1

		SKIP
	ENDDO
ELSE
