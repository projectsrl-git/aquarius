*=> Gestione licenza software
xxSql   = "select * from u_lic_an"
IF !ExecCommand(xxSql,"CUR_LICENZA")
   return(.f.)
ENDIF
SELECT CUR_LICENZA

xUsaFormScad = CUR_LICENZA.AZI_MSGAVV
PUB_LICENZA  = ALLTRIM(CUR_LICENZA.LICENZA)

AUTORIZZATO_A_CONTINUARE = .T.


IF ( xUsaFormScad = .T. )

	dataScadenza = ribalta2(CUR_LICENZA.AZI_DTSCAD)

	xScadenza = SUBSTR(TRIM(CUR_LICENZA.AZI_DTSCAD),1,4)+;
				SUBSTR(TRIM(CUR_LICENZA.AZI_DTSCAD),6,2)+;
				SUBSTR(TRIM(CUR_LICENZA.AZI_DTSCAD),9,2)

	xDtodierna = SUBSTR(ribalta2(DTOC(DATE())),1,4)+;
				 SUBSTR(ribalta2(DTOC(DATE())),6,2)+;
				 SUBSTR(ribalta2(DTOC(DATE())),9,2)



  *##########################################################################################
  *   LA LICENZA AQUARIUS STA PER SCADERE
  *##########################################################################################  
	*!*	La licenza scade nei prossimi 90 gg
	IF BETWEEN(VAL(xScadenza) - VAL(xDtodierna),201,300)
		DO FORM form\scadenza WITH 'smiley_28.GIF',166,601,'1',dataScadenza  
		AUTORIZZATO_A_CONTINUARE = .T.
	ENDIF
	
	*!*	La licenza scade nei prossimi 60 gg
	IF BETWEEN(VAL(xScadenza) - VAL(xDtodierna),101,200)
		DO FORM form\scadenza WITH 'smiley_32.GIF',165,604,'1',dataScadenza  
		AUTORIZZATO_A_CONTINUARE = .T.
	ENDIF	

	*!*	La licenza scade nei prossimi 30 gg
	IF BETWEEN(VAL(xScadenza) - VAL(xDtodierna),1,100)
		DO FORM form\scadenza WITH 'smiley_32.GIF',165,604,'1',dataScadenza  
		AUTORIZZATO_A_CONTINUARE = .T.
	ENDIF


  *##########################################################################################
  *   LA LICENZA AQUARIUS E' APPENA SCADUTA
  *##########################################################################################  
	*!*	La licenza č scaduta OGGI
	IF ( VAL(xScadenza) - VAL(xDtodierna) = 0 ) 
		DO FORM form\scadenza WITH 'smiley_29.gif',168,595,'2',dataScadenza  
		AUTORIZZATO_A_CONTINUARE = .T.
	ENDIF


  *##########################################################################################
  *   LA LICENZA AQUARIUS E' SCADUTA DA TEMPO
  *##########################################################################################  
	*!*	La licenza č scaduta in una finestra di tempo da 1 a 30 gg
	IF BETWEEN(VAL(xScadenza) - VAL(xDtodierna),-100,-1)
		DO FORM form\scadenza WITH 'smiley_16.GIF',175,600,'3',dataScadenza  
		AUTORIZZATO_A_CONTINUARE = .F.
	ENDIF

	*!*	La licenza č scaduta in una finestra di tempo da 31 a 60 gg
	IF BETWEEN(VAL(xScadenza) - VAL(xDtodierna),-200,-101)
		DO FORM form\scadenza WITH 'smiley_16.GIF',175,600,'3',dataScadenza  
		AUTORIZZATO_A_CONTINUARE = .F.		
	ENDIF

	*!*	La licenza č scaduta in una finestra di tempo da 61 a 90 gg
	IF BETWEEN(VAL(xScadenza) - VAL(xDtodierna),-300,-201)
		DO FORM form\scadenza WITH 'smiley_16.GIF',175,600,'3',dataScadenza  
		AUTORIZZATO_A_CONTINUARE = .F.		
	ENDIF

	*!*	La licenza č scaduta da oltre 90 gg
	IF ( VAL(xScadenza) - VAL(xDtodierna) <= -301 ) 
		DO FORM form\scadenza WITH 'smiley_16.GIF',175,600,'3',dataScadenza  
		AUTORIZZATO_A_CONTINUARE = .F.		
	ENDIF
	
	IF BETWEEN(VAL(xScadenza) - VAL(xDtodierna),1,100)
		ZTF.COMMAND7.CAPTION= "-" + ALLTRIM(STR(VAL(SYS(11,dataScadenza)) - VAL(SYS(11,DTOC(DATE())))))
		ZTF.COMMAND7.FORECOLOR = RGB(0,128,0)
	ENDIF
	IF ( VAL(xScadenza) - VAL(xDtodierna) = 0 ) 
		ZTF.COMMAND7.CAPTION= "Oggi!!"
		ZTF.COMMAND7.FORECOLOR = RGB(0,0,128)
	ENDIF
	IF ( VAL(xScadenza) - VAL(xDtodierna) <= -1 ) 
		ZTF.COMMAND7.CAPTION= ALLTRIM(STR(VAL(SYS(11,DTOC(DATE()))) - VAL(SYS(11,dataScadenza))))
		ZTF.COMMAND7.FORECOLOR = RGB(223,0,0)
	ENDIF

ENDIF

