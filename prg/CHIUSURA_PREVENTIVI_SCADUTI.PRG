************************************
* CHIUSURA PREVENTIVI SCADUTI
************************************

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO
PUBLIC V_TITOLO

V_TITOLO = "Preventivi scaduti chiusi"

WAIT WINDOWS "ESEGUE PROGRAMMA PREVENTIVI_SCADUTI_CHIUSI" TIMEOUT 3

*** REPORT RIEPILOGO
cSql=""     
cNomeCursorSql="CU_PREVENTIVI"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
	SELECT
		TAGGANCIO,
		CODICE_CLIENTE,
		CLIENTE,
		NUM_PREVENTIVO,
		DATA_PREVENTIVO_RIBALTATA, 
		DATA_PREVENTIVO,
		DATA_SCADENZA_RIBALTATA, 
		DATA_SCADENZA,
		CONDIZIONE_PAGAMENTO,
		CENTRO_COSTO,
		DESCRIZIONE_CENTRO_COSTO,
		DATA_CONSEGNA_RIBALTATA,
		DATA_CONSEGNA,
		SUM(VALORE) AS VALORE	
	FROM (
		SELECT
			TAGGANCIO,
			TT.ORD_CODCLI AS CODICE_CLIENTE,
			TT.ORD_RAGSOC AS CLIENTE,
			TT.ORD_NUMORD AS NUM_PREVENTIVO,
			TT.ORD_DATORD AS DATA_PREVENTIVO_RIBALTATA, 
			DBO.RIBALTA2(TT.ORD_DATORD) AS DATA_PREVENTIVO,
			TT.ORD_DATSCA AS DATA_SCADENZA_RIBALTATA, 
			DBO.RIBALTA2(TT.ORD_DATSCA) AS DATA_SCADENZA,
			TT.ORD_CPA AS CONDIZIONE_PAGAMENTO,
			DD.ORD_CCODET AS CENTRO_COSTO,
			COALESCE(CC.CON_DESCR,'') AS DESCRIZIONE_CENTRO_COSTO,
			DD.ORD_DATCON AS DATA_CONSEGNA_RIBALTATA,
			DBO.RIBALTA2(DD.ORD_DATCON) AS DATA_CONSEGNA,
			(DD.ORD_VALORE * TT.ORD_CAMBIO) AS VALORE
		FROM U_OFF_DD AS DD
		LEFT OUTER JOIN U_OFF_TT AS TT ON TT.TAGGANCIO = DD.DAGGANCIO
		LEFT OUTER JOIN CCOSTO AS CC ON CC.CON_CONTO = DD.ORD_CCODET AND CC.CON_ANNO = TT.ORD_ANNO
		WHERE TT.ORD_CHIUSO = 0 AND TT.ORD_FLBOL <> 'S' AND TT.ORD_DATSCA <> '' AND TT.ORD_DATSCA < '<<RIBALTA2(DTOC(DATE()))>>'  
		) AS MAIN
	
	GROUP BY TAGGANCIO,CENTRO_COSTO,DESCRIZIONE_CENTRO_COSTO,CODICE_CLIENTE,CLIENTE,NUM_PREVENTIVO,DATA_PREVENTIVO_RIBALTATA,DATA_PREVENTIVO,DATA_SCADENZA_RIBALTATA,DATA_SCADENZA,CONDIZIONE_PAGAMENTO,DATA_CONSEGNA_RIBALTATA,DATA_CONSEGNA
	ORDER BY DESCRIZIONE_CENTRO_COSTO,DATA_SCADENZA_RIBALTATA,CLIENTE,NUM_PREVENTIVO

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT CU_PREVENTIVI
GO TOP
IF EOF()
	RETURN
ENDIF
SCAN
	cSql = "UPDATE U_OFF_TT SET ORD_CHIUSO = 1, ORD_MOTIVAZ = '04' WHERE TAGGANCIO = '" + TAGGANCIO + "'"
	IF !ExecCommand(cSql,"UPD_OFF_TT")
		return(.F.)
	ENDIF
ENDSCAN

SELECT CU_PREVENTIVI

_PDF_REPORT_ 		=ALLTRIM(CERCAREPO("XXX","PREVENTIVI_SCADUTI_CHIUSI","PREVENTIVI_SCADUTI_CHIUSI.FRX"))
_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "CU_PREVENTIVI"

IF !EMPTY(_PDF_SUBDIR_ )
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
