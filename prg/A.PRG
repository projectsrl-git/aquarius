*!*	VARCHIVIO	= "PART_FOR"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
*!*	VCONTO   	= "2202006000277"	 	&& CODICE DEL CLIENTE
