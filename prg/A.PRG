*!*	    GO TOP
*!*	    SUM VAL(DARE) TO TDARE ALL
*!*	    SUM VAL(AVEREX) TO TAVERE ALL
*!*		WAIT WINDOWS "PARTITA TROVATA  DARE :" + STR(TDARE,13,2) + "    AVERE :" + " SALDO :" +STR(TAVERE,13,2) + STR(TDARE-TAVERE,13,2)
*!*	ENDIF






*!*	TUTTE LE PARTITE APERTE DEL FORNITORE 
VTIPO    	= "F"			 		&& C= CLIENTE F= FORNITORE	
VARCHIVIO	= "PART_FOR"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
VCONTO   	= "2202002002303"	 	&& CODICE DEL CLIENTE
VDTDAL		= "01/01/1990"			&& PERIODO DI ESTRAZIONE DELLE PARTITE DAL
VDTAL		= "31/12/2990"			&& PERIODO DI ESTRAZIONE DELLE PARTITE AL
VPARTITA 	= 0				 		&& NUMERO DI PARTITA , SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
VNUMREGI 	= ""			 		&& NUMERO DI REGISTRAZIONE ,SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
VCURSORE 	= "SCADE"		 		&& NOME DEL CURSORE DI RITORNO CONTENENTE LE PARITE
VDTSCADE 	= ""		     		&& RITORNA TUTTE LE PARTITE SCADUTE SINO ALLA DATA COMPRESA
VDTASCAD 	= ""  			      	&& RITORNA TUTTE LE PARTITE CHE SCADRANNO DALA DATA INDICATA , ALTRIMENTI TUTTE
VSOLOSALDO	= ""			 		&& RITORNA SOLO IL SALDO DELLA PARTITA , ALTRIMENTI TUTTE
VORDINE		= 5				 		&& IN ORDINE DI NUMERO DATA SCADENZA
VOPENCLOSE	= 2				 		&& SOLO LE PARTITE APERTE


IF CERCA_PARTITE(VTIPO,VARCHIVIO,VCONTO,VDTDAL,VDTAL,VPARTITA,VNUMREGI,VCURSORE,VDTSCADE,VDTASCAD,VSOLOSALDO,VORDINE,VOPENCLOSE)  
    SELECT SCADE
    GO TOP
    SUM VAL(DARE) TO TDARE ALL
    SUM VAL(AVEREX) TO TAVERE ALL
	WAIT WINDOWS "PARTITA TROVATA  DARE :" + STR(TDARE,13,2) + "    AVERE :" + " SALDO :" +STR(TAVERE,13,2) + STR(TDARE-TAVERE,13,2)
ENDIF




















