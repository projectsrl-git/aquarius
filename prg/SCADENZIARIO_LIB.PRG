
*!*	***********************************************************************************
FUNCTION CARICA_PARTITE_DAL_AL
*!*	***********************************************************************************
*!*	**
*!*	** CREA IL CURSORE SCADE CONTENETE LE PARTITE DEI CLIENTI O DEI FORNITORI
*!*	**
*!*	** ESTRARE LE PARTITE DEI CLIENTI O DEI FORNITORI SEGUENDO LE SEGUENTI REGOLE :
*!*	**
*!*	** PARAMETRI DA GESTIRE :
*!*	**
*!*	**     _CF  		=  C  SE CLIENTE , F SE FORNITORE
*!*	**     _CONTODAL	=  CODICE DAL DEL CONTO CLIENTE / FORNITORE (COMPRENSIVO DEL SOTTOGRUPPO)
*!*	**     _CONTOAL	    =  CODICE AL  DEL CONTO CLIENTE / FORNITORE (COMPRENSIVO DEL SOTTOGRUPPO)
*!*	**     _OPENCLOSE	=  1 : RITORNA TUTTE LE PARTITE SIA APERTE CHE CHIUSE
*!*	**      			=  2 : RITORNA SOLO I MOVIMENTI DI DETTAGLIO DELLE PARTITE ANCORA APERTE
*!*	**      			=  3 : RITORNA SOLO I MOVIMENTI DI DETTAGLIO DELLE PARTITE CHIUSE CON IL SALDO = 0
*!*	**     _TUTTI		=  "TUTTI"    : RITORNA TUTTE LE PARTITE APERTE CHE CHIUSE INDICATE DI TUTTI I FORNITORI/CLIENTI
*!*	**					=               IN QUESTO CASO IL CONTODAL ED IL CONTOAL NON SONO SIGNIFICATIVI
*!*	**					=  "TRANCHE"  : IN QUESTO CASO RESTITUISCE SOLO LA TRANCHE DELLA FATTURA NON ANCORA PAGATA (OBBLIGATORIO IL PARAMETRO _XVPARTITA)
*!*	**	   _DTSCDAL		=  DATA DI SCADENZA GG/MM/AAAA PERIODO DI ESTRAZIONE DAL 
*!*	**	   _DTSCAL		=  DATA DI SCADENZA GG/MM/AAAA PERIODO DI ESTRAZIONE AL 
*!*	**
*!*	**	   _SOLO_RIBA_  =  0 : NESSUNA CONSIDERAZIONE SULLE RIBA
*!*	**	   			    =  1 : SOLO RIBA SCADENTI
*!*	**	   			    =  2 : CONSIDERA LE RICEVUTE BANCARIE CLIENTI EFFETTIVAMENTE INCASSATE ALLA DATA DI SCADENZA AL + PUB_GGRIBA  
*!*	**
*!*	**
*!*	**    _XVTIPOPA     = .T. ELABORA SOLO LE PARTITA RICLASSIFICATE
*!*	**
*!*	** _RISPOSTA        =  .T. SE ALMENO UNA PARTITA E' STATA TROVATA
*!*	**
*!*	**
*!*	** _XSOLOSALDO      =  "SCADENZE"  : RITORNA LA TRANCHE DELLA SINGOLA SCADENZA NON PAGATA
*!*	**
*!*	**
*!*	** CURSORE DI SUPPORTO DA USARE E DI RITORNO:
*!*	**
*!*	**		SCADEDALAL	=  DA CREARE LA PRIMA VOLTA ; CONTIENE LE PARTITE CLIENTI O FORNITORI
*!*	**						
*!*	** GESTIONE MOVIMENTI DI CONTABILITA' PREVISIONALE	
*!*	**
*!*	**		_XINCLUDE_CONTABILITA_PREVISIONALE = 0		&& SOLO MOVIMENTI NON PREVISIONALI
*!*	**			
*!*	**		_XINCLUDE_CONTABILITA_PREVISIONALE = 1		&& AGGIUNGE MOVIMENTI PREVISIONALI
*!*	**			
*!*	**		_XINCLUDE_CONTABILITA_PREVISIONALE = 2		&& SOLO MOVIMENTI PREVISIONALI
*!*	**	

*!*	**						
*!*	**	

PARA _CF,_CONTODAL,_CONTOAL,_OPENCLOSE,_TUTTI,_DTSCDAL,_DTSCAL,_SOLO_RIBA,_ELA_AGEN_,_XSOLOSALDO,_XVTIPOPA,_XVPARTITA,_XINCLUDE_CONTABILITA_PREVISIONALE 

LOCAL AABBSXS  
AABBSXS  = SELECT()



IF PCOUNT()<8
	_SOLO_RIBA	= 0
	_ELA_AGEN_	= ""
	_VSOLOSALDO = ""
	_VPARTITA   = 0
	_XVTIPOPA   = .F.
	_XINCLUDE_CONTABILITA_PREVISIONALE = 0
ENDIF
 

IF PCOUNT()<9
	IF _SOLO_RIBA <>2
		_SOLO_RIBA = 0
	ENDIF
	_ELA_AGEN_	= ""
	_VSOLOSALDO = ""
	_VPARTITA   = 0
	_XVTIPOPA   = .F.
	_XINCLUDE_CONTABILITA_PREVISIONALE = 0
ENDIF


IF PCOUNT()<10
	IF _SOLO_RIBA <>2
		_SOLO_RIBA = 0
	ENDIF
	_ELA_AGEN_	= ""
	_VSOLOSALDO = ""
	_VPARTITA   = 0
	_XVTIPOPA   = .F.
	_XINCLUDE_CONTABILITA_PREVISIONALE = 0
ENDIF

IF PCOUNT()<11
	IF _SOLO_RIBA <>2
		_SOLO_RIBA = 0
	ENDIF
	_ELA_AGEN_	= ""
	_VSOLOSALDO = ""
	_VPARTITA   = 0
	_XVTIPOPA   = .F.
	_XINCLUDE_CONTABILITA_PREVISIONALE = 0	
ENDIF


IF PCOUNT()<12
	_VPARTITA   = 0 
	_XINCLUDE_CONTABILITA_PREVISIONALE = 0
ENDIF


IF PCOUNT()<13
	_XINCLUDE_CONTABILITA_PREVISIONALE = 0
ENDIF


IF PCOUNT()=10
	IF _SOLO_RIBA <>2
		_SOLO_RIBA = 0
	ENDIF
	_ELA_AGEN_	= ""
	_VSOLOSALDO	= _XSOLOSALDO
	_VPARTITA   = 0 
	_XINCLUDE_CONTABILITA_PREVISIONALE = 0	
ENDIF

IF PCOUNT()=11
	IF _SOLO_RIBA <>2
		_SOLO_RIBA = 0
	ENDIF
	_ELA_AGEN_	= ""
	_VSOLOSALDO	= _XSOLOSALDO
	_VPARTITA   = 0 
	_XINCLUDE_CONTABILITA_PREVISIONALE = 0	
ENDIF


IF PCOUNT()=12
	IF _SOLO_RIBA <>2
		_SOLO_RIBA = 0
	ENDIF
	_ELA_AGEN_	= ""
	_VSOLOSALDO	= _XSOLOSALDO
	_VPARTITA   = _XVPARTITA  
	_XINCLUDE_CONTABILITA_PREVISIONALE = 0
ENDIF

IF PCOUNT()=13
	IF _SOLO_RIBA <>2
		_SOLO_RIBA = 0
	ENDIF
	_ELA_AGEN_	= ""
	_VSOLOSALDO	= _XSOLOSALDO
	_VPARTITA   = _XVPARTITA  
ENDIF


IF _OPENCLOSE = 1 OR _OPENCLOSE = 2 OR _OPENCLOSE = 3
ELSE
	_OPENCLOSE = 2
ENDIF


_XTIPOPA_PARTITE_RICLASSIFICATE  = .F.

DO CASE


		CASE _TUTTI	= "TUTTI"


					*!*	TUTTE LE PARTITE DEL FORNITORE / CLIENTE APERTE
					IF _CF  = "C"
						VTIPO    	= "C"			 		&& C= CLIENTE F= FORNITORE	
						VARCHIVIO	= "PART_CLI"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
					ELSE
						VTIPO    	= "F"			 		&& C= CLIENTE F= FORNITORE	
						VARCHIVIO	= "PART_FOR"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
					ENDIF

					VCONTO   	= "TUTTI"			  	&& CODICE DEL CLIENTE/FORNITORE
					VDTDAL		= _DTSCDAL				&& PERIODO DI ESTRAZIONE DELLE PARTITE DAL
					VDTAL		= _DTSCAL				&& PERIODO DI ESTRAZIONE DELLE PARTITE AL
					VPARTITA 	= 0				 		&& NUMERO DI PARTITA , SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
					VNUMREGI 	= ""			 		&& NUMERO DI REGISTRAZIONE ,SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
					VCURSORE 	= "SCADE"		 		&& NOME DEL CURSORE DI RITORNO CONTENENTE LE PARITE
					VDTSCADE 	= _DTSCAL          		&& RITORNA TUTTE LE PARTITE SCADUTE SINO ALLA DATA COMPRESA
					VDTASCAD 	= ""	          		&& RITORNA TUTTE LE PARTITE CHE SCADRANNO DALA DATA INDICATA , ALTRIMENTI TUTTE
					VSOLOSALDO	= _VSOLOSALDO	 		&& RITORNA SOLO IL SALDO DELLA PARTITA , ALTRIMENTI TUTTE
					VORDINE		= 5				 		&& IN ORDINE DI DATA SCADENZA
					VOPENCLOSE	= _OPENCLOSE	 		&& 
					VSOLORIBA	= _SOLO_RIBA			&&
				    VELA_AGEN_  = _ELA_AGEN_			&& ELABORA AGENTE DESIDERATO
					VTIPOPA     = _XVTIPOPA  			&& ELABORA SOLO LE PARTITE RICLASSIFICATE 			


					=CERCA_PARTITE(VTIPO,VARCHIVIO,VCONTO,VDTDAL,VDTAL,VPARTITA,VNUMREGI,VCURSORE,VDTSCADE,VDTASCAD,VSOLOSALDO,VORDINE,VOPENCLOSE,VSOLORIBA,VELA_AGEN_,VPARTITA ,VTIPOPA,_XINCLUDE_CONTABILITA_PREVISIONALE)  


					SELECT SCADE
					GO TOP
					
		CASE _TUTTI	= "AGENTE"


					*!*	TUTTE LE PARTITE DEL FORNITORE / CLIENTE APERTE
					IF _CF  = "C"
						VTIPO    	= "C"			 		&& C= CLIENTE F= FORNITORE	
						VARCHIVIO	= "PART_CLI"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
					ELSE
						VTIPO    	= "F"			 		&& C= CLIENTE F= FORNITORE	
						VARCHIVIO	= "PART_FOR"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
					ENDIF

					VCONTO   	= "AGENTE"			  	&& CODICE DEL CLIENTE/FORNITORE
					VDTDAL		= _DTSCDAL				&& PERIODO DI ESTRAZIONE DELLE PARTITE DAL
					VDTAL		= _DTSCAL				&& PERIODO DI ESTRAZIONE DELLE PARTITE AL
					VPARTITA 	= 0				 		&& NUMERO DI PARTITA , SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
					VNUMREGI 	= ""			 		&& NUMERO DI REGISTRAZIONE ,SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
					VCURSORE 	= "SCADE"		 		&& NOME DEL CURSORE DI RITORNO CONTENENTE LE PARITE
					VDTSCADE 	= _DTSCAL          		&& RITORNA TUTTE LE PARTITE SCADUTE SINO ALLA DATA COMPRESA
					VDTASCAD 	= ""	          		&& RITORNA TUTTE LE PARTITE CHE SCADRANNO DALA DATA INDICATA , ALTRIMENTI TUTTE
					VSOLOSALDO	= _VSOLOSALDO	 		&& RITORNA SOLO IL SALDO DELLA PARTITA , ALTRIMENTI TUTTE
					VORDINE		= 5				 		&& IN ORDINE DI DATA SCADENZA
					VOPENCLOSE	= _OPENCLOSE	 		&& 
					VSOLORIBA	= _SOLO_RIBA			&&
				    VELA_AGEN_  = _ELA_AGEN_			&& ELABORA AGENTE DESIDERATO
					VTIPOPA     = _XVTIPOPA  			&& ELABORA SOLO LE PARTITE RICLASSIFICATE 			



					=CERCA_PARTITE(VTIPO,VARCHIVIO,VCONTO,VDTDAL,VDTAL,VPARTITA,VNUMREGI,VCURSORE,VDTSCADE,VDTASCAD,VSOLOSALDO,VORDINE,VOPENCLOSE,VSOLORIBA,VELA_AGEN_,VPARTITA ,VTIPOPA,_XINCLUDE_CONTABILITA_PREVISIONALE)  

					SELECT SCADE
					GO TOP
					

		CASE _TUTTI	= "TRANCHE"

					*!*	RESTITUISCE LE TRANCHE DI SCADENZA ANCORA DA PAGARE PER NUMEO DI PARTITA DEL CLIENTE/FORNITORE
					IF _CF  = "C"
						VTIPO    	= "C"			 		&& C= CLIENTE F= FORNITORE	
						VARCHIVIO	= "PART_CLI"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
					ELSE
						VTIPO    	= "F"			 		&& C= CLIENTE F= FORNITORE	
						VARCHIVIO	= "PART_FOR"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
					ENDIF

					VCONTO   	= _CONTODAL			  	&& CODICE DEL CLIENTE/FORNITORE
					VDTDAL		= _DTSCDAL				&& PERIODO DI ESTRAZIONE DELLE PARTITE DAL
					VDTAL		= _DTSCAL				&& PERIODO DI ESTRAZIONE DELLE PARTITE AL
					VPARTITA 	= _VPARTITA		 		&& NUMERO DI PARTITA , SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
					VNUMREGI 	= ""			 		&& NUMERO DI REGISTRAZIONE ,SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
					VCURSORE 	= "SCADE"		 		&& NOME DEL CURSORE DI RITORNO CONTENENTE LE PARITE
					VDTSCADE 	= _DTSCAL          		&& RITORNA TUTTE LE PARTITE SCADUTE SINO ALLA DATA COMPRESA
					VDTASCAD 	= ""	          		&& RITORNA TUTTE LE PARTITE CHE SCADRANNO DALA DATA INDICATA , ALTRIMENTI TUTTE
					VSOLOSALDO	= _VSOLOSALDO	 		&& RITORNA SOLO IL SALDO DELLA PARTITA , ALTRIMENTI TUTTE
					VORDINE		= 5				 		&& IN ORDINE DI DATA SCADENZA
					VOPENCLOSE	= _OPENCLOSE	 		&& 
					VSOLORIBA	= _SOLO_RIBA			&&
				    VELA_AGEN_  = _ELA_AGEN_			&& ELABORA AGENTE DESIDERATO
					XPARTITA    = _VPARTITA             && ACCESSO DIRETTO PER NUMERO PARTITA
					VTIPOPA     = _XVTIPOPA  			&& ELABORA SOLO LE PARTITE RICLASSIFICATE 		

					=CERCA_PARTITE(VTIPO,VARCHIVIO,VCONTO,VDTDAL,VDTAL,VPARTITA,VNUMREGI,VCURSORE,VDTSCADE,VDTASCAD,VSOLOSALDO,VORDINE,VOPENCLOSE,VSOLORIBA,VELA_AGEN_,VPARTITA ,VTIPOPA,_XINCLUDE_CONTABILITA_PREVISIONALE)  

					SELECT SCADE
					GO TOP
					

		
		OTHERWISE

					*!*	TUTTE LE PARTITE DEL FORNITORE / CLIENTE APERTE
					IF _CF  = "C"
						VTIPO    	= "C"			 		&& C= CLIENTE F= FORNITORE	
						VARCHIVIO	= "PART_CLI"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
					ELSE
						VTIPO    	= "F"			 		&& C= CLIENTE F= FORNITORE	
						VARCHIVIO	= "PART_FOR"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
					ENDIF

					VCONTO   	= _CONTODAL			  	&& CODICE DEL CLIENTE/FORNITORE
					VDTDAL		= _DTSCDAL				&& PERIODO DI ESTRAZIONE DELLE PARTITE DAL
					VDTAL		= _DTSCAL				&& PERIODO DI ESTRAZIONE DELLE PARTITE AL
					VPARTITA 	= 0				 		&& NUMERO DI PARTITA , SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
					VNUMREGI 	= ""			 		&& NUMERO DI REGISTRAZIONE ,SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
					VCURSORE 	= "SCADE"		 		&& NOME DEL CURSORE DI RITORNO CONTENENTE LE PARITE
					VDTSCADE 	= _DTSCAL          		&& RITORNA TUTTE LE PARTITE SCADUTE SINO ALLA DATA COMPRESA
					VDTASCAD 	= ""	          		&& RITORNA TUTTE LE PARTITE CHE SCADRANNO DALA DATA INDICATA , ALTRIMENTI TUTTE
					VSOLOSALDO	= _VSOLOSALDO	 		&& RITORNA SOLO IL SALDO DELLA PARTITA , ALTRIMENTI TUTTE
					VORDINE		= 5				 		&& IN ORDINE DI DATA SCADENZA
					VOPENCLOSE	= _OPENCLOSE	 		&& 
					VSOLORIBA	= _SOLO_RIBA			&&
				    VELA_AGEN_  = _ELA_AGEN_			&& ELABORA AGENTE DESIDERATO
					VTIPOPA     = _XVTIPOPA  			&& ELABORA SOLO LE PARTITE RICLASSIFICATE 		

					

					=CERCA_PARTITE(VTIPO,VARCHIVIO,VCONTO,VDTDAL,VDTAL,VPARTITA,VNUMREGI,VCURSORE,VDTSCADE,VDTASCAD,VSOLOSALDO,VORDINE,VOPENCLOSE,VSOLORIBA,VELA_AGEN_,VPARTITA ,VTIPOPA,_XINCLUDE_CONTABILITA_PREVISIONALE)  

					SELECT SCADE
					GO TOP
					


ENDCASE


SELECT(AABBSXS)
RETURN(.T.)




*!*	***********************************************************************************
FUNCTION CERCA_PARTITE
*!*	***********************************************************************************
*!*	**
*!*	** CREA IL CURSORE SCADE CONTENETE LE PARTITE DEI CLIENTI O DEI FORNITORI
*!*	**
*!*	** ESTRARE LE PARTITE DEI CLIENTI O DEI FORNITORI SEGUENDO LE SEGUENTI REGOLE :
*!*	**
*!*	** PARAMETRI DA GESTIRE :
*!*	**
*!*	**     _CF  		=  C  SE CLIENTE , F SE FORNITORE
*!*	**     _ARCH_IN		=  PART_CLI SE PARTITARIO CLIENTI , PART_FOR SE PARTITARIO FORNITORI
*!*	**     _CONTO		=  CODICE DEL CONTO CLIENTE / FORNITORE (COMPRENSIVO DEL SOTTOGRUPPO)
*!*	**      			=  SE IL CAMPO CONTIENE IL VALORE "TUTTI" ESTRAE TUTTE LE PARTITE APERTE DI TUTTI I FORNITORI ALLA SCADENZA
*!*	**     _DATADAL		=  PERIODO DI AESTRAZIONE DELE PARTITE DAL
*!*	**     _DATAAL		=  PERIODO DI AESTRAZIONE DELE PARTITE AL
*!*	**     _PARTITA		=  NUMERO DELLA PARTITA DA RICERCARE , SE NON INDICATA ESTRAE TUTTO
*!*	**     _NUMREGI		=  NUMERO DI REGISTRAZIONE CONTABILE DA RICERCARE , SE NON INDICATA ESTRAE TUTTO
*!*	**     _CURSORE     =  NOME DEL CURSORE DI LAVORO (SCADE)	
*!*	**     _DTSCADE		=  SE INDICATA ESTRAE TUTTE LE PARTITE SCADUTE ALLA DATA
*!*	**     _DTASCAD		=  SE INDICATA ESTRAE TUTTE LE PARTITE CHE SCADRANNO ALLA DATA
*!*	**     _SOLOSALDO	=  SI: SE INDICATO ESTRAE IL SOLO RECORD DI SALDO DELLA PARTITA DEL CLIENTE O FORNITORE
*!*	**     				=  SCADENZE: MOSTRA LE SCADENZE DELLE PARTITE
*!*	**     				=  SOLO_SCADENZE_NEL_PERIODO: MOSTRA SOLO LE SCADENZE DEL PERIODO _DATDAL-_DATAAL
*!*	**
*!*	**     _ORDINE		=  1 : RITORNA SCADE CODIFICANDO LA CHIAVE (CAMPO : INDICE) IN ORDINE DI DATA DI REGISTRAZIONE
*!*	**      			=  2 : RITORNA SCADE CODIFICANDO LA CHIAVE (CAMPO : INDICE) IN ORDINE DI NUMERO PARTITA / DATA DI SCADENZA
*!*	**      			=  3 : RITORNA SCADE CODIFICANDO LA CHIAVE (CAMPO : INDICE) IN ORDINE DI NUMERO PARTITA 
*!*	**      			=  4 : RITORNA SCADE CODIFICANDO LA CHIAVE (CAMPO : INDICE) IN ORDINE DI ANNO / NUMERO DI REGISTRAZIONE
*!*	**      			=  5 : RITORNA SCADE CODIFICANDO LA CHIAVE (CAMPO : INDICE) IN ORDINE DI DATA DI SCADENZA
*!*	**      			=  6 : RITORNA SCADE CODIFICANDO LA CHIAVE (CAMPO : INDICE) IN ORDINE DI CLIENTE-FORNITORE  
*!*	**      			=  7 : RITORNA SCADE CODIFICANDO LA CHIAVE (CAMPO : INDICE) IN ORDINE DI CLIENTE-FORNITORE / NUMERO PARTITA / DATA DI SCADENZA
*!*	**      			=  8 : RITORNA SCADE CODIFICANDO LA CHIAVE (CAMPO : INDICE) IN ORDINE DI ANNO / NUMERO PARTITA / DATA DI SCADENZA
*!*	**
*!*	**     _OPENCLOSE	=  1 : RITORNA TUTTE LE PARTITE SIA APERTE CHE CHIUSE
*!*	**      			=  2 : RITORNA SOLO I MOVIMENTI DI DETTAGLIO DELLE PARTITE ANCORA APERTE
*!*	**      			=  3 : RITORNA SOLO I MOVIMENTI DI DETTAGLIO DELLE PARTITE CHIUSE CON IL SALDO = 0
*!*	**
*!*	**	   _SOLO_RIBA_  =  0 : NESSUNA CONSIDERAZIONE SULLE RIBA
*!*	**	   			    =  1 : SOLO RIBA SCADENTI
*!*	**		            =  2 : TUTTE LE SCADENZE NON-RIBA + LE SCADENZE RIBA NON CONSOLIDATE
*!*	**		
*!*	**		
*!*	**
*!*	**	   _XTIPOPA_    =  .T. : ELABORA SOLO LE PARTITE RICLASSIFICATE
*!*	**		
*!*	**		
*!*	**		
*!*	** _RISPOSTA        =  .T. SE ALMENO UNA PARTITA E' STATA TROVATA
*!*	**
*!*	**
*!*	** CURSORE DI SUPPORTO DA USARE E DI RITORNO:
*!*	**
*!*	**		SCADE  		=  DA CREARE LA PRIMA VOLTA ; CONTIENE LE PARTITE CLIENTI O FORNITORI
*!*	**	
*!*	** GESTIONE MOVIMENTI DI CONTABILITA' PREVISIONALE	
*!*	**	
*!*	**		_X_INCLUDE_CONTABILITA_PREVISIONALE = 0		&& SOLO MOVIMENTI NON PREVISIONALI
*!*	**			
*!*	**		_X_INCLUDE_CONTABILITA_PREVISIONALE = 1		&& AGGIUNGE MOVIMENTI PREVISIONALI
*!*	**			
*!*	**		_X_INCLUDE_CONTABILITA_PREVISIONALE = 2		&& SOLO MOVIMENTI PREVISIONALI
*!*	**	

PARA _CF,_ARCH_IN,_CONTO,_DATADAL,_DATAAL,_PARTITA,_NUMREGI,_CURSORE,_DTSCADE,_DTASCAD,_SOLOSALDO,_ORDINE,_OPENCLOSE,_SOLO_RIBA_,_ELA_AGEN_,_XPARTITA,_XTIPOPA_,_X_INCLUDE_CONTABILITA_PREVISIONALE 

RELEASE _LISTA_VALUTE
PUBLIC 	_LISTA_VALUTE
_LISTA_VALUTE = ""

LOCAL AABBSXS
AABBSXS  = SELECT()



*!*	** DEFINIZIONE VARIABILI

IF PCOUNT()<14
	_SOLO_RIBA_= 0
	_XPARTITA  = 0
	_ACCESSO_PER_NUMERO_PARTITA = .F.
	_XTIPOPA_  = .F.
	_X_INCLUDE_CONTABILITA_PREVISIONALE = 0
ENDIF

IF PCOUNT()<15
	IF _SOLO_RIBA_<>2
		_SOLO_RIBA_= 0
	ENDIF
	_ELA_AGEN_ = ""
	_XPARTITA  = 0
	_ACCESSO_PER_NUMERO_PARTITA = .F.
	_XTIPOPA_  = .F.
	_X_INCLUDE_CONTABILITA_PREVISIONALE = 0
ENDIF

IF PCOUNT()<16
	IF _SOLO_RIBA_<>2
		_SOLO_RIBA_= 0
	ENDIF
	_ELA_AGEN_ = ""
	_XPARTITA  = 0
	_ACCESSO_PER_NUMERO_PARTITA = .F.
	_XTIPOPA_  = .F.
	_X_INCLUDE_CONTABILITA_PREVISIONALE = 0
ENDIF

IF PCOUNT()<17
	IF _SOLO_RIBA_<>2
		_SOLO_RIBA_= 0
	ENDIF
	_ELA_AGEN_ = ""
	_XPARTITA  = 0
	_ACCESSO_PER_NUMERO_PARTITA = .F.
	_XTIPOPA_  = .F.
	_X_INCLUDE_CONTABILITA_PREVISIONALE = 0	
ENDIF


IF PCOUNT()<18
	IF _SOLO_RIBA_<>2
		_SOLO_RIBA_= 0
	ENDIF
	_ELA_AGEN_ = ""
	_XPARTITA  = 0
	_ACCESSO_PER_NUMERO_PARTITA = .F.
	_X_INCLUDE_CONTABILITA_PREVISIONALE = 0	
ENDIF


IF PCOUNT()=>16
	IF _XPARTITA > 0
		_ACCESSO_PER_NUMERO_PARTITA = .T.
	ELSE
