*******************************
* ESEGUI_REPORT_ANALISI_ARCHIVI
*******************************
*LPARAMETERS _PAR_NOME_REPORT,_PAR1,_PAR2,_PAR3,_PAR4,_PAR5
LPARAMETERS _PAR_NOME_REPORT,_PAR1,_PAR2,_PAR3,_PAR4,_PAR5,_PAR_NON_FORMATTATA  && ERASMO - 08/07/2024

IF PCOUNT() >= 1
ELSE
	MESSAGEBOX("Parametri insufficienti",16,"Attenzione",3000)
	RETURN .F.
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE _V_TITOLO
PUBLIC _V_TITOLO
_V_TITOLO = ALLTRIM(_PAR_NOME_REPORT)

_ALLEGATI = ""

WAIT WINDOWS "ESEGUE REPORT:" + ALLTRIM(_PAR_NOME_REPORT) TIMEOUT 3

x_nome = "NOME = '" + ALLTRIM(_PAR_NOME_REPORT) + "'"
x_cond = x_nome
cSql   = "select * from SQLFIND WHERE " + x_cond + " ORDER BY CHIAVE"
IF !ExecCommand(cSql,"TMP_SQLFIND")
  return(.f.)
ENDIF
SELECT TMP_SQLFIND
GO TOP
IF EOF()
	MESSAGEBOX("Report '" + ALLTRIM(_PAR_NOME_REPORT) + "' non trovato",16,"Attenzione",3000)
	RETURN .F.
ENDIF

SCATTER MEMVAR MEMO

_CHIAVE = ALLTRIM(M.CHIAVE)
_V_QUERYSQL = ALLTRIM(M.QUERYSQL)
_V_FILTRI = ""

*** RICERCA DETTAGLI CON EVENTUALI PARAMETRI DA SOSTITUIRE NELLA WHERE CONDITION
x_chia = "CHIAVE = '" + _CHIAVE + "'"
x_tipo = "SUBSTRING(TIPO,1,1) = '2'"
x_cond = x_chia + " and " + x_tipo
cSql   = "select * from SQLFIND_DETT WHERE " + x_cond + " ORDER BY SEQUEN"
IF !ExecCommand(cSql,"TMP_SQLFIND_DETT")
  return(.f.)
ENDIF
SELECT TMP_SQLFIND_DETT
GO TOP
_nPar = 0
SCAN
	_FRASESQL = FRASESQL
	IF "&_VAR" $ _FRASESQL
		_nPar = _nPar + 1
		_nomeParametroIngresso = "_PAR" + ALLTRIM(STR(_nPar,10,0))
		_C_VAR = ""
		IF TYPE(_nomeParametroIngresso) == "C"
			_C_VAR = &_nomeParametroIngresso
		ENDIF
		IF EMPTY(_C_VAR)
			MESSAGEBOX("Parametro di ingresso aggiuntivo n° '" + ALLTRIM(STR(_nPar,10,0)) + "' per assegnazione variabile in where condition vuoto o non passato",16,"Attenzione",3000)
			RETURN .F.
		ENDIF
		_CUSTOM_FRASESQL = STRTRAN(_FRASESQL,"&_VAR",ALLTRIM(_C_VAR))
		_V_QUERYSQL = STRTRAN(_V_QUERYSQL,_FRASESQL,_CUSTOM_FRASESQL)
		_V_FILTRI = ALLTRIM(_V_FILTRI) + IIF(!EMPTY(_V_FILTRI)," - ","") + _CUSTOM_FRASESQL
	ENDIF
ENDSCAN

IF EMPTY(_V_QUERYSQL)
	MESSAGEBOX("Query SQL in Report '" + ALLTRIM(_PAR_NOME_REPORT) + "' vuota",16,"Attenzione",3000)
	RETURN .F.
ENDIF

cSql = _V_QUERYSQL
cNomeCursorSql = "CU_REPORT" + SYS(2015)
IF !ExecCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


LOCAL _DIRECTORY_PDF,_NOME_REPORT

_DIRECTORY_PDF=LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")  && RICERCA PERCORSO
IF !DIRECTORY(_DIRECTORY_PDF)
	MESSAGEBOX("Directory '" + JUSTDRIVE(_DIRECTORY_PDF) + "' non trovata",16,"Attenzione",3000)
	RETURN .F.
ENDIF

*_NOME_FILE_XLS = _DIRECTORY_PDF + "\" + STRTRAN(_PAR_NOME_REPORT," ","_") + SYS(2015) + ".XLSX"
_NOME_FILE_XLS = _DIRECTORY_PDF + "\" + STRTRAN(_PAR_NOME_REPORT," ","_") + SYS(2015) + IIF(_PAR_NON_FORMATTATA,".XLS",".XLSX")  && ERASMO - 08/07/2024

SET PROCEDURE TO PRG\APPLILIB ADDITIVE
SET PROCEDURE TO PRG\XLSLIB	ADDITIVE

SELECT &cNomeCursorSql
GO TOP

*!*	_TITOLO_EXCEL1 = _V_TITOLO
*!*	_TITOLO_EXCEL2 = _V_FILTRI
*!*	_TITOLO_EXCEL3 = ""
*!*	_TOTALI_GENERALI = .F.
*!*	DO ESTRXLS WITH cNomeCursorSql,_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,_TOTALI_GENERALI,.F.,.F.,_NOME_FILE_XLS

**=> ERASMO - INIZIO 08/07/2024
RELEASE PUB_INTXLS
PUBLIC PUB_INTXLS
PUB_INTXLS = ""
IF !ExecCommand("select * from u_azi_pb","u_azi_pb")
   return
ENDIF
SELECT u_azi_pb
GO TOP
IF !EOF()
	PUB_INTXLS = AZI_INTXLS
ENDIF

SELECT &cNomeCursorSql
GO TOP

IF _PAR_NON_FORMATTATA
	WAIT WINDOW "ATTENDERE PREGO: creazione excel in corso..." NOWAIT
	COPY TO &_NOME_FILE_XLS TYPE XL5
ELSE
	_TITOLO_EXCEL1 = _V_TITOLO
	_TITOLO_EXCEL2 = _V_FILTRI
	_TITOLO_EXCEL3 = ""
	_TOTALI_GENERALI = .F.
	DO ESTRXLS WITH cNomeCursorSql,_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,_TOTALI_GENERALI,.F.,.F.,_NOME_FILE_XLS
ENDIF
**=> ERASMO - FINE 08/07/2024

*!*	RELEASE PROCEDURE PRG\APPLILIB 
*!*	RELEASE PROCEDURE PRG\XLSLIB

_FILE_DA_ALLEGARE = JUSTFNAME(_NOME_FILE_XLS)

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 

_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
