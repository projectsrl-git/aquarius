************************************
* ORDINI_VISIONE_IN_SCADENZA
************************************
LPARAMETERS _NR_GIORNI

IF PCOUNT()<1
	RETURN .F.
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO,V_NR_GIORNI
PUBLIC V_TITOLO,V_NR_GIORNI

V_TITOLO = "Ordini di VISIONE in scadenza nei prossimi " + ALLTRIM(STR(_NR_GIORNI,10,0)) + " giorni"
V_NR_GIORNI = _NR_GIORNI

WAIT WINDOWS "ESEGUE PROGRAMMA ORDINI_VISIONE_IN_SCADENZA" TIMEOUT 3

*** REPORT RIEPILOGO
cSql=""     
cNomeCursorSql="CU_ORDINI_SC"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
		
	SELECT
		TAGGANCIO,
		CODICE_CLIENTE,
		CLIENTE,
		NUM_ORDINE,
		DATA_ORDINE_RIBALTATA, 
		DATA_ORDINE,
		CONDIZIONE_PAGAMENTO,
		CENTRO_COSTO,
		DESCRIZIONE_CENTRO_COSTO,
		DATA_CONSEGNA_RIBALTATA,
		DATA_CONSEGNA,
		DATA_SCADENZA,
		SUM(VALORE) AS VALORE	
	FROM (
		SELECT
			TAGGANCIO,
			TT.ORD_CODCLI AS CODICE_CLIENTE,
			TT.ORD_RAGSOC AS CLIENTE,
			TT.ORD_NUMORD AS NUM_ORDINE,
			TT.ORD_DATORD AS DATA_ORDINE_RIBALTATA, 
			DBO.RIBALTA2(TT.ORD_DATORD) AS DATA_ORDINE,
			TT.ORD_CPA AS CONDIZIONE_PAGAMENTO,
			DD.ORD_CCODET AS CENTRO_COSTO,
			COALESCE(CC.CON_DESCR,'') AS DESCRIZIONE_CENTRO_COSTO,
			DD.ORD_DATCON AS DATA_CONSEGNA_RIBALTATA,
			DBO.RIBALTA2(DD.ORD_DATCON) AS DATA_CONSEGNA,
			TT.ORD_DATSCA AS DATA_SCADENZA,
			(DD.ORD_VALORE * TT.ORD_CAMBIO) AS VALORE
		FROM U_ORD_DD AS DD
		LEFT OUTER JOIN U_ORD_TT AS TT ON TT.TAGGANCIO = DD.DAGGANCIO
		LEFT OUTER JOIN CCOSTO AS CC ON CC.CON_CONTO = DD.ORD_CCODET AND CC.CON_ANNO = TT.ORD_ANNO
		WHERE TT.ORD_CHIUSO = 1 AND TT.ORD_TIPOLOGIA = 'VIS' AND DD.ORD_CHIUSO = 1 AND TT.ORD_DATSCA <> '' AND 
			TT.ORD_DATSCA <= convert(varchar, DATEADD(day, + <<ALLTRIM(STR(V_NR_GIORNI,10,0))>>, GETDATE()), 111)		
		) AS MAIN
	
	GROUP BY TAGGANCIO,CENTRO_COSTO,DESCRIZIONE_CENTRO_COSTO,CODICE_CLIENTE,CLIENTE,NUM_ORDINE,DATA_ORDINE_RIBALTATA,DATA_ORDINE,CONDIZIONE_PAGAMENTO,DATA_CONSEGNA_RIBALTATA,DATA_CONSEGNA,DATA_SCADENZA
	ORDER BY DESCRIZIONE_CENTRO_COSTO,DATA_CONSEGNA_RIBALTATA,CLIENTE,NUM_ORDINE

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT CU_ORDINI_SC

_PDF_REPORT_ 		=ALLTRIM(CERCAREPO("XXX","ORDINI_VISIONE_IN_SCADENZA","ORDINI_VISIONE_IN_SCADENZA.FRX"))
_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "CU_ORDINI_SC"

IF !EMPTY(_PDF_SUBDIR_ )
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
