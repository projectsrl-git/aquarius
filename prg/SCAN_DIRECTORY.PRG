RELEASE PUB_ESTENSIONE_CORROTTO
PUBLIC PUB_ESTENSIONE_CORROTTO

PUB_ESTENSIONE_CORROTTO=".encrypted"

_OLD_DIR=SYS(5)+SYS(2003)

CREATE CURSOR FILE_CORROTTI (;
	PERCORSO C(254), NOME_FILE C(100), DATA_FILE C(10), DIMENSIONE N(15,0))

CREATE CURSOR FILE_SANI (;
	PERCORSO C(254), NOME_FILE C(100), DATA_FILE C(10), DIMENSIONE N(15,0))
	
SELECT FILE_SANI 
INDEX ON NOME_FILE+DATA_FILE DESCENDING TAG NOME_FILE 
SET ORDER TO NOME_FILE 

STRTOFILE( "***************** CORROTTI"+CHR(13),"D:\LOG\SCAN_DIRECTORY.TXT",.T.)
SCORRI_FILE("D:\___TEST_COPIA_FILE","FILE_CORROTTI")

STRTOFILE( "***************** SANI"+CHR(13),"D:\LOG\SCAN_DIRECTORY.TXT",.T.)
SCORRI_FILE("C:\Users\standard\Google Drive\Progetti","FILE_SANI")

SELECT FILE_CORROTTI 
GO TOP
STRTOFILE( "***************** quanti FILE_CORROTTI ? "+ALLTRIM(str(RECCOUNT()))+CHR(13),"D:\LOG\SCAN_DIRECTORY.TXT",.T.)


_PERCORSO = ""
_PERCORSO_FILE_SANO = ""
_NOME_FILE = ""
_DATA_FILE = ""
_DIMENSIONE = 0
_NOME_FILE_SORGENTE_COMPLETO =""
_NOME_FILE_DESTINAZIONE_COMPLETO =""

_conta_recuperati =0

SELECT FILE_CORROTTI 
GO TOP

***LEGGO TUTTI I FILE CORROTTI
DO WHILE !EOF()
	
	_PERCORSO = ALLTRIM(PERCORSO )
	_NOME_FILE_CORROTTO = ALLTRIM(NOME_FILE )
	_NOME_FILE_SANO=  SUBSTR(_NOME_FILE_CORROTTO  , 1,LEN(_NOME_FILE_CORROTTO  )-LEN(PUB_ESTENSIONE_CORROTTO))
	_DATA_FILE = DATA_FILE 
	_DIMENSIONE = DIMENSIONE 
	
	
	*** PER CIASCUN FILE CORROTTO LEGGO TUTTE LE DIRECTORY CON I FILE SANI
	SELECT FILE_SANI 
	SET ORDER TO NOME_FILE 
	SET NEAR ON
	SEEK _NOME_FILE_SANO
	
	IF FOUND()

		_PERCORSO_FILE_SANO = ALLTRIM(PERCORSO )
		
		_NOME_FILE_SORGENTE_COMPLETO='"'+_PERCORSO_FILE_SANO + _NOME_FILE_SANO+'"'
		_NOME_FILE_DESTINAZIONE_COMPLETO='"'+_PERCORSO + _NOME_FILE_SANO +'"'
		_NOME_FILE_CORROTTO_COMPLETO ='"'+_PERCORSO + _NOME_FILE_CORROTTO +'"' 
		
		STRTOFILE("TROVATO FILE "+_NOME_FILE_SANO+" CHE CORRISPONDE AL FILE CORROTTO "+_NOME_FILE_CORROTTO+CHR(13),"D:\LOG\SCAN_DIRECTORY.TXT",.T.)		
		**COPY FILE  (_NOME_FILE_SORGENTE_COMPLETO) TO (_NOME_FILE_DESTINAZIONE_COMPLETO)
		**DELETE FILE (_NOME_FILE_CORROTTO_COMPLETO )
		
		_conta_recuperati = _conta_recuperati+1
	ENDIF
	
	SELECT FILE_CORROTTI 
	SKIP
ENDDO

SET NEAR OFF

SET DEFAULT TO &_OLD_DIR

STRTOFILE( "***************** quanti recuperati? "+ALLTRIM(str(_conta_recuperati))+CHR(13),"D:\LOG\SCAN_DIRECTORY.TXT",.T.)


RETURN


*******************************************
FUNCTION SCORRI_FILE
*******************************************

LPARAMETERS pcDir,P_NOME_CURSORE


LOCAL lnPtr, lnFileCount, laFileList, lcDir, lcFile

CHDIR (pcDir)
STRTOFILE('Dir -> ' + FULLPATH(CURDIR())+CHR(13),"D:\LOG\SCAN_DIRECTORY.TXT",.T.)


DIMENSION laFileList[1]

*--- Read the chosen directory.
lnFileCount = ADIR(laFileList, '*.*', 'D')
FOR lnPtr = 1 TO lnFileCount

  IF 'D' $ laFileList[lnPtr, 5]

    *--- Get directory name.
    lcDir = laFileList[lnPtr, 1]

    *--- Ignore current and parent directory pointers.
    IF lcDir != '.' AND lcDir != '..'
      *--- Call this routine again.
      SCORRI_FILE(lcDir,P_NOME_CURSORE)
    ENDIF

  ELSE

	lcFile = LOWER(laFileList[lnPtr, 1])

	IF P_NOME_CURSORE = "FILE_CORROTTI"
		*--- Get the file name.
		IF LOWER(SUBSTR(lcFile , LEN(lcFile )-(LEN(PUB_ESTENSIONE_CORROTTO)-1))) = PUB_ESTENSIONE_CORROTTO
			STRTOFILE(">>>>>>>>>>>>>>>> QUESTO E' CORROTTO"+ FULLPATH(CURDIR())+lcFile +CHR(13),"D:\LOG\SCAN_DIRECTORY.TXT",.T.)
		ELSE
			LOOP
		ENDIF
	ENDIF
		
	SELECT &P_NOME_CURSORE 
	APPEND BLANK 
	REPLACE NOME_FILE WITH lcFile 
	REPLACE PERCORSO WITH FULLPATH(CURDIR()) 
	REPLACE DIMENSIONE  WITH laFileList[lnPtr, 2]
	REPLACE DATA_FILE  WITH DTOC(laFileList[lnPtr, 3])

  ENDIF

ENDFOR

*--- Move back to parent directory.
CHDIR ..

RETURN



