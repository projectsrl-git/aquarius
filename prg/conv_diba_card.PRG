	**=> ERASMO - INIZIO 08/05/2014
	__DIS_SECTOT = 0
	x_codi = "CARD_ANCICLI.CODART = '" + __DIT_GRUPPO + "'"
	x_cond = x_codi
	cSql = "SELECT CARD_ANCICLI.*, CARD_ANFOR.CHIEST, CARD_ANFOR.NOME FROM CARD_ANCICLI " + ;
	       "LEFT OUTER JOIN CARD_ANFOR ON CARD_ANFOR.CODCLF = CARD_ANCICLI.CODCLF WHERE " + x_cond + " ORDER BY ORDINE"
	IF !ExecCommand(cSql,"CX_CARD_ANCICLI")
	   return
	ENDIF
	SELECT CX_CARD_ANCICLI
	GO TOP
	SCAN
		SCATTER MEMVAR
		__DIT_TIPOPR = M.TIPO  && TIPO LAVORAZIONE (I/E) DA RIPORTARE ANCHE SU TESTATA
		
		__DIS_TIPOPR = M.TIPO
		__DIS_SEQUEN = __DIS_SEQUEN + 10
		__DAGGANCIO = _AGGA
		__DIS_GRUPPO = __DIT_GRUPPO
		__DIS_CODART = SUBSTR(M.CODFASE,2,3)
		__DIS_QTA = 1
		__DIS_UM = "NR"
					
		__DIS_OPZCST = 2  && DETERMINAZIONE COSTI E TEMPI DA DETTAGLIO DISTINTA BASE (NON RIVALUTATO DA ANAGRAFICA ARTICOLI)
		
		*** COSTI
		__DIS_COSLAI = 0
		__DIS_COSLAE = 0
		IF __DIS_TIPOPR = 'E'
			IF !ISNULL(M.ECOSTU)
				__DIS_COSLAE = M.ECOSTU
			ENDIF
			__DIS_OPZCST = 1  && ERASMO - 01/10/2014 - DETERMINAZIONE COSTI E TEMPI DINAMICA DA ANAGRAFICA ARTICOLI (PER FASI LAV. ESTERNE CONSIDERA IL COD. PADRE E LA SCHEDA ARTICOLI/FORNITORI)
		ELSE
			IF !ISNULL(M.ECOSTU)
				__DIS_COSLAI = M.ECOSTU
			ENDIF
		ENDIF
		__DIS_COSMAT = 0
		__DIS_COSATR = 0
		__DIS_COSTO = __DIS_COSLAI + __DIS_COSLAE + __DIS_COSMAT + __DIS_COSATR
		
		*** FORNITORE
		__DIS_CODFOR = IIF(!ISNULL(M.CHIEST), M.CHIEST, "")
		__DIS_DESFOR = IIF(!ISNULL(M.NOME), M.NOME, "")
		
		*** TEMPI
		DO CASE
			CASE M.UMIST = 'S'
				__DIS_ORELAV = da_secondi_a_ore_minuti_secondi(M.TCICLO)
			CASE M.UMIST = 'GG'
				__DIS_ORELAV = da_secondi_a_ore_minuti_secondi(M.TCICLO * 24 * 3600)
			OTHERWISE
				__DIS_ORELAV = 0
		ENDCASE
		__DIS_SECLAV = da_ore_minuti_secondi_a_secondi(__DIS_ORELAV)
		__DIS_OREATT = "00000:00:00"
		__DIS_SECATT = 0
		__DIS_SECIMP = __DIS_SECLAV + __DIS_SECATT 
		__DIS_OREIMP = da_secondi_a_ore_minuti_secondi(__DIS_SECIMP)

		__DIS_TIPO = 'A'
		*__DIS_ESPLOD = 'X'
		__DIS_ESPLOD = ''
		__DIS_FITTIZ = .F.
		__DIS_FASELA = SUBSTR(M.CODFASE,2,3)
		
		__DIS_NOTE = ALLTRIM(M.DESCR)
		__DIS_DESCRI = ""
		__DIS_MAGA = PUB_CODM
		
		x_codi = "CODICE = 'FAL" + __DIS_CODART + "'"
		x_cond = x_codi
		cSql = "SELECT * FROM PARA WHERE " + x_cond
		IF !ExecCommand(cSql,"CX_PARA")
			RETURN .F.
		ENDIF
		SELECT CX_PARA
		GO TOP
		IF !EOF()
			__DIS_DESCRI = ALLTRIM(DESCRI)
		ENDIF
		
		cSql = "SELECT * FROM U_DIS_DD WHERE 1=0"
		IF !ExecRW(cSql,"U_DIS_DD","R")
		   return
		ENDIF
		SELECT U_DIS_DD
		APPEND BLANK

		REPLACE DIS_TIPOPR WITH __DIS_TIPOPR 
		REPLACE DIS_SEQUEN WITH __DIS_SEQUEN 
		REPLACE DAGGANCIO WITH __DAGGANCIO 
		REPLACE DIS_GRUPPO WITH __DIS_GRUPPO 
		REPLACE DIS_CODART WITH __DIS_CODART 
		REPLACE DIS_QTA WITH __DIS_QTA 
