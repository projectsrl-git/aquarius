RIT = MESSAGEBOX("Procedo con la conversione delle Distinte Base dalle tabelle CARD_TESDIS/CARD_RIGDIS/CARD_ANDB/CARD_ANCICLI/CARD_ANFOR?",292,"ATTENZIONE")
IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF


WAIT WINDOWS "Cancellazione vecchie Distinte Base in corso..." NOWAIT

cSql = "DELETE FROM U_DIS_TT"
IF !ExecCommand(cSql,"DEL_DIS_TT")
   return
ENDIF

cSql = "DELETE FROM U_DIS_DD"
IF !ExecCommand(cSql,"DEL_DIS_DD")
   return
ENDIF

WAIT WINDOWS "Conversione Distinte Base SIGLA in corso..." NOWAIT

_TOT_COUNT = 0

cSql = 	"SELECT * FROM CARD_TESDIS WHERE CODICE IN (SELECT CODICE FROM CARD_RIGDIS) ORDER BY CODICE"
IF !ExecCommand(cSql,"CX_CARD_TESDIS")
   return
ENDIF
SELECT CX_CARD_TESDIS
GO TOP
SCAN
	
	_NEW_AGGA = SYS(2015)
	
	WAIT WINDOWS "Conversione Distinta Base (SIGLA) " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + ;
		" (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 
	
	SCATTER MEMVAR
	
	__DIT_CODSOC = PUB_CODSOC
	__TAGGANCIO = _NEW_AGGA 
	__DIT_GRUPPO = M.CODICE
	__DIT_NOTE = IIF(ISNULL(FILE1),'','Nome file elettronici: ' + ALLTRIM(FILE1))
	__DIT_DESCRI = ""
	__DIT_UM = ""
	__DIT_MAGA = ""
	__DIT_CODIVA = ""
	__DIT_LINEA = ""
	__DIT_TIPOPR = ""
		
	x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
	x_codi = "ART_CODPRI = '" + __DIT_GRUPPO + "'"
	x_cond = x_soci + " and " + x_codi
	cSql = "SELECT ART_CODPRI,ART_DESCR,ART_UMMAGA,ART_MAGA,ART_CODIVA,ART_LINEA,ART_TIPOPR FROM U_ART_PR WHERE " + x_cond
	IF !ExecCommand(cSql,"CX_ART_PR")
		RETURN .F.
	ENDIF
	SELECT CX_ART_PR
	GO TOP
	IF !EOF()
		__DIT_DESCRI = ART_DESCR
		__DIT_UM = ART_UMMAGA
		__DIT_MAGA = ART_MAGA
		__DIT_CODIVA = ART_CODIVA
		__DIT_LINEA = ART_LINEA
		__DIT_TIPOPR = ART_TIPOPR
	ENDIF
	
	cSql = "SELECT * FROM U_DIS_TT WHERE 1=0"
	IF !ExecRW(cSql,"U_DIS_TT","R")
	   return
	ENDIF
	SELECT U_DIS_TT
	APPEND BLANK
	REPLACE DIT_CODSOC WITH __DIT_CODSOC 
	REPLACE TAGGANCIO WITH __TAGGANCIO 
	REPLACE DIT_GRUPPO WITH __DIT_GRUPPO 
	REPLACE DIT_NOTE WITH __DIT_NOTE 
	REPLACE DIT_DESCRI WITH __DIT_DESCRI 
	REPLACE DIT_UM WITH __DIT_UM 
	REPLACE DIT_MAGA WITH __DIT_MAGA 
	REPLACE DIT_CODIVA WITH __DIT_CODIVA 
	REPLACE DIT_LINEA WITH __DIT_LINEA 
	REPLACE DIT_TIPOPR WITH __DIT_TIPOPR 
	IF !ExecRW(cSql,"U_DIS_TT","W")
	   return
	ENDIF
	
	__DIS_SEQUEN = 0
	x_codi = "CARD_RIGDIS.CODICE = '" + __DIT_GRUPPO + "'"
	x_cond = x_codi 
	cSql = 	"SELECT CARD_RIGDIS.*, " + ;
			"	CASE COALESCE(CARD_TESDIS.CODICE,'') " + ;
			"		WHEN '' THEN 'A' " + ;
			"		ELSE 'G' " + ;
			"	END AS TIPO, " + ;
			"	CAST(" + ;
			"		CASE COALESCE(CARD_ANARTIC.FITTIZIO,'N') " + ;
			"			WHEN 'S' THEN 1 " + ;
			"			ELSE 0 " + ;
			"		END AS BIT) " + ;
			"	AS FITTIZIO " + ;
			"FROM CARD_RIGDIS " + ;
			"LEFT OUTER JOIN CARD_TESDIS AS CARD_TESDIS ON CARD_TESDIS.CODICE = CARD_RIGDIS.CODART " + ;
			"LEFT OUTER JOIN CARD_ANARTIC AS CARD_ANARTIC ON CARD_ANARTIC.CODART = CARD_RIGDIS.CODART " + ;
			"WHERE " + x_cond + " ORDER BY CODICE,CODART"
	IF !ExecCommand(cSql,"CX_CARD_RIGDIS")
	   return
	ENDIF
	SELECT CX_CARD_RIGDIS
	GO TOP
	SCAN
		SCATTER MEMVAR
		__DIS_SEQUEN = __DIS_SEQUEN + 10
		__DAGGANCIO = _NEW_AGGA 
		__DIS_GRUPPO = M.CODICE
		__DIS_CODART = M.CODART
		__DIS_QTA = M.QUANTITA
		__DIS_NOTE = IIF(ISNULL(FILE1),'','Nome file elettronici: ' + ALLTRIM(FILE1))
		__DIS_DESCRI = ""
		__DIS_UM = ""
		__DIS_MAGA = ""
		__DIS_TIPO = M.TIPO
		__DIS_FITTIZ = M.FITTIZIO
			
		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "ART_CODPRI = '" + __DIS_CODART + "'"
		x_cond = x_soci + " and " + x_codi
		cSql = "SELECT ART_CODPRI,ART_DESCR,ART_UMMAGA,ART_MAGA FROM U_ART_PR WHERE " + x_cond
		IF !ExecCommand(cSql,"CX_ART_PR")
			RETURN .F.
		ENDIF
		SELECT CX_ART_PR
		GO TOP
		IF !EOF()
			__DIS_DESCRI = ART_DESCR
			__DIS_UM = ART_UMMAGA
			__DIS_MAGA = ART_MAGA
		ENDIF
		
		cSql = "SELECT * FROM U_DIS_DD WHERE 1=0"
		IF !ExecRW(cSql,"U_DIS_DD","R")
		   return
		ENDIF
		SELECT U_DIS_DD
		APPEND BLANK

		REPLACE DIS_SEQUEN WITH __DIS_SEQUEN 
		REPLACE DAGGANCIO WITH __DAGGANCIO 
		REPLACE DIS_GRUPPO WITH __DIS_GRUPPO 
		REPLACE DIS_CODART WITH __DIS_CODART 
		REPLACE DIS_QTA WITH __DIS_QTA 
		REPLACE DIS_NOTE WITH __DIS_NOTE 
		REPLACE DIS_DESCRI WITH __DIS_DESCRI 
		REPLACE DIS_UM WITH __DIS_UM 
		REPLACE DIS_MAGA WITH __DIS_MAGA 
		REPLACE DIS_TIPO WITH __DIS_TIPO 
		REPLACE DIS_FITTIZ WITH __DIS_FITTIZ
		
		IF !ExecRW(cSql,"U_DIS_DD","W")
		   return
		ENDIF
	ENDSCAN
	
	_TOT_COUNT = _TOT_COUNT + 1
	
ENDSCAN


WAIT WINDOWS "Conversione Distinte Base FABRICA in corso..." NOWAIT

cSql = 	"SELECT CODPART FROM CARD_ANDB " + ;
		"WHERE CODPART IN (SELECT CODPART FROM CARD_ANDB WHERE CODPART <> CODCOMP)" + ;
		"GROUP BY CODPART ORDER BY CODPART"
IF !ExecCommand(cSql,"CX_CARD_ANDB_TT")
   return
ENDIF
SELECT CX_CARD_ANDB_TT
GO TOP
SCAN
	
	_NEW_AGGA = SYS(2015)
	
	WAIT WINDOWS "Conversione Distinta Base (FABRICA) " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + ;
		" (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 
	
	SCATTER MEMVAR
	
	__DIT_CODSOC = PUB_CODSOC
	__TAGGANCIO = _NEW_AGGA 
	__DIT_GRUPPO = M.CODPART
	__DIT_NOTE = ""
	__DIT_DESCRI = ""
	__DIT_UM = ""
	__DIT_MAGA = ""
	__DIT_CODIVA = ""
	__DIT_LINEA = ""
	__DIT_TIPOPR = ""
		
	x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
	x_codi = "ART_CODPRI = '" + __DIT_GRUPPO + "'"
	x_cond = x_soci + " and " + x_codi
	cSql = "SELECT ART_CODPRI,ART_DESCR,ART_UMMAGA,ART_MAGA,ART_CODIVA,ART_LINEA,ART_TIPOPR FROM U_ART_PR WHERE " + x_cond
	IF !ExecCommand(cSql,"CX_ART_PR")
		RETURN .F.
	ENDIF
	SELECT CX_ART_PR
	GO TOP
	IF !EOF()
		__DIT_DESCRI = ART_DESCR
		__DIT_UM = ART_UMMAGA
		__DIT_MAGA = ART_MAGA
		__DIT_CODIVA = ART_CODIVA
		__DIT_LINEA = ART_LINEA
		__DIT_TIPOPR = ART_TIPOPR
	ENDIF
	
	cSql = "SELECT * FROM U_DIS_TT WHERE 1=0"
	IF !ExecRW(cSql,"U_DIS_TT","R")
	   return
	ENDIF
	SELECT U_DIS_TT
	APPEND BLANK
	REPLACE DIT_CODSOC WITH __DIT_CODSOC 
	REPLACE TAGGANCIO WITH __TAGGANCIO 
	REPLACE DIT_GRUPPO WITH __DIT_GRUPPO 
	REPLACE DIT_NOTE WITH __DIT_NOTE 
	REPLACE DIT_DESCRI WITH __DIT_DESCRI 
	REPLACE DIT_UM WITH __DIT_UM 
	REPLACE DIT_MAGA WITH __DIT_MAGA 
	REPLACE DIT_CODIVA WITH __DIT_CODIVA 
	REPLACE DIT_LINEA WITH __DIT_LINEA 
	REPLACE DIT_TIPOPR WITH __DIT_TIPOPR 
	IF !ExecRW(cSql,"U_DIS_TT","W")
	   return
	ENDIF
	
	__DIS_SEQUEN = 0
	x_codi = "CARD_ANDB.CODPART = '" + __DIT_GRUPPO + "'"
	x_sons = "CARD_ANDB.CODPART <> CARD_ANDB.CODCOMP"
	x_cond = x_codi + " and " + x_sons
	cSql = 	"SELECT CARD_ANDB.*, " + ;
			"	CASE COALESCE(CARD_ANDB_TES.CODPART,'') " + ;
			"		WHEN '' THEN 'A' " + ;
			"		ELSE 'G' " + ;
			"	END AS TIPO, " + ;
			"	CAST(" + ;
			"		CASE COALESCE(CARD_ANARTIC.FITTIZIO,'N') " + ;
			"			WHEN 'S' THEN 1 " + ;
			"			ELSE 0 " + ;
			"		END AS BIT) " + ;
			"	AS FITTIZIO " + ;
			"FROM CARD_ANDB " + ;
			"LEFT OUTER JOIN (SELECT CODPART FROM CARD_ANDB WHERE CODPART <> CODCOMP GROUP BY CODPART) AS CARD_ANDB_TES ON CARD_ANDB_TES.CODPART = CARD_ANDB.CODCOMP " + ;
			"LEFT OUTER JOIN CARD_ANARTIC AS CARD_ANARTIC ON CARD_ANARTIC.CODART = CARD_ANDB.CODCOMP " + ;
			"WHERE " + x_cond + " ORDER BY CODCOMP"
	IF !ExecCommand(cSql,"CX_CARD_ANDB_DD")
	   return
	ENDIF
	SELECT CX_CARD_ANDB_DD
	GO TOP
	SCAN
		SCATTER MEMVAR
		__DIS_SEQUEN = __DIS_SEQUEN + 10
		__DAGGANCIO = _NEW_AGGA 
		__DIS_GRUPPO = M.CODPART
		__DIS_CODART = M.CODCOMP
		__DIS_QTA = M.QOCC
		__DIT_UM = M.UM
		__DIS_NOTE = ""
		__DIS_DESCRI = ""
		__DIS_UM = ""
		__DIS_MAGA = ""
		__DIS_TIPO = M.TIPO
		__DIS_FITTIZ = M.FITTIZIO
			
		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "ART_CODPRI = '" + __DIS_CODART + "'"
		x_cond = x_soci + " and " + x_codi
		cSql = "SELECT ART_CODPRI,ART_DESCR,ART_UMMAGA,ART_MAGA FROM U_ART_PR WHERE " + x_cond
		IF !ExecCommand(cSql,"CX_ART_PR")
			RETURN .F.
		ENDIF
		SELECT CX_ART_PR
		GO TOP
		IF !EOF()
			__DIS_DESCRI = ART_DESCR
			__DIS_UM = ART_UMMAGA
			IF UPPER(ALLTRIM(M.UM)) <> UPPER(ALLTRIM(__DIT_UM))
				__DIS_NOTE = "Unitŕ di misura da controllare perchč diversa da quella in anagrafica articoli"
			ENDIF
			__DIS_MAGA = ART_MAGA
		ENDIF
		
		cSql = "SELECT * FROM U_DIS_DD WHERE 1=0"
		IF !ExecRW(cSql,"U_DIS_DD","R")
		   return
		ENDIF
		SELECT U_DIS_DD
		APPEND BLANK

		REPLACE DIS_SEQUEN WITH __DIS_SEQUEN 
		REPLACE DAGGANCIO WITH __DAGGANCIO 
		REPLACE DIS_GRUPPO WITH __DIS_GRUPPO 
		REPLACE DIS_CODART WITH __DIS_CODART 
		REPLACE DIS_QTA WITH __DIS_QTA 
		REPLACE DIS_NOTE WITH __DIS_NOTE 
		REPLACE DIS_DESCRI WITH __DIS_DESCRI 
		REPLACE DIS_UM WITH __DIS_UM 
		REPLACE DIS_MAGA WITH __DIS_MAGA 
		REPLACE DIS_TIPO WITH __DIS_TIPO 
		REPLACE DIS_FITTIZ WITH __DIS_FITTIZ
		
		REPLACE DIS_OPZCST WITH 1 
		
		REPLACE DIS_COSLAI WITH 0
		REPLACE DIS_COSLAE WITH 0
		REPLACE DIS_COSMAT WITH 0
		REPLACE DIS_COSATR WITH 0
		REPLACE DIS_COSTO  WITH 0
		
		REPLACE DIS_CODFOR WITH "" 
		REPLACE DIS_DESFOR WITH "" 
		
		REPLACE DIS_ORELAV WITH "00000:00:00"
		REPLACE DIS_SECLAV WITH 0 
		REPLACE DIS_OREATT WITH "00000:00:00"
		REPLACE DIS_SECATT WITH 0 
		REPLACE DIS_OREIMP WITH "00000:00:00"
		REPLACE DIS_SECIMP WITH 0 
		
		IF !ExecRW(cSql,"U_DIS_DD","W")
		   return
		ENDIF
	ENDSCAN
	
	_TOT_COUNT = _TOT_COUNT + 1
	
ENDSCAN

WAIT WINDOWS "Integrazione Cicli di Lavorazione FABRICA in corso..." NOWAIT

cSql = 	"SELECT * FROM U_DIS_TT ORDER BY DIT_GRUPPO"
IF !ExecCommand(cSql,"CX_DIS_TT")
   return
ENDIF
SELECT CX_DIS_TT
GO TOP
SCAN
	_AGGA = TAGGANCIO
	__DIT_GRUPPO = DIT_GRUPPO
	__DIT_TIPOPR = ""
	
	WAIT WINDOWS "Integrazione Ciclo di Lavorazione (FABRICA) " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + ;
		" (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT
		
	__DIS_SEQUEN = 0
	x_agga = "DAGGANCIO = '" + _AGGA + "'"
	x_grup = "DIS_GRUPPO = '" + __DIT_GRUPPO + "'"
	x_cond = x_agga + " and " + x_grup 
	cSql = 	"SELECT TOP 1 DIS_SEQUEN FROM U_DIS_DD WHERE " + x_cond + " ORDER BY DIS_SEQUEN DESC"
	IF !ExecCommand(cSql,"CX_DIS_DD")
	   return
	ENDIF
	SELECT CX_DIS_DD
	GO TOP
	IF !EOF()
		__DIS_SEQUEN = DIS_SEQUEN
	ENDIF	
	
