		REPLACE DIS_TIPO WITH __DIS_TIPO 
		REPLACE DIS_ESPLOD WITH __DIS_ESPLOD 
		REPLACE DIS_FITTIZ WITH __DIS_FITTIZ 
		REPLACE DIS_FASELA WITH __DIS_FASELA 
		REPLACE DIS_NOTE WITH __DIS_NOTE 
		REPLACE DIS_DESCRI WITH __DIS_DESCRI 
		REPLACE DIS_UM WITH __DIS_UM 
		REPLACE DIS_MAGA WITH __DIS_MAGA 
		
		REPLACE DIS_OPZCST WITH __DIS_OPZCST 
		
		REPLACE DIS_COSLAI WITH __DIS_COSLAI 
		REPLACE DIS_COSLAE WITH __DIS_COSLAE 
		REPLACE DIS_COSMAT WITH __DIS_COSMAT 
		REPLACE DIS_COSATR WITH __DIS_COSATR 
		REPLACE DIS_COSTO  WITH __DIS_COSTO 
		
		REPLACE DIS_CODFOR WITH __DIS_CODFOR 
		REPLACE DIS_DESFOR WITH __DIS_DESFOR 
		
		REPLACE DIS_ORELAV WITH __DIS_ORELAV 
		REPLACE DIS_SECLAV WITH __DIS_SECLAV 
		
		
		REPLACE DIS_OREATT WITH __DIS_OREATT 
		REPLACE DIS_SECATT WITH __DIS_SECATT 
		REPLACE DIS_OREIMP WITH __DIS_OREIMP 
		REPLACE DIS_SECIMP WITH __DIS_SECIMP 
		
		IF !ExecRW(cSql,"U_DIS_DD","W")
		   return
		ENDIF
		
		__DIS_SECTOT = __DIS_SECTOT + __DIS_QTA
		
		**=> ERASMO - INIZIO 01/10/2014
		*** AGGIORNAMENTO GRUPPO IN ANAGRAFICA ARTICOLI
		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "ART_CODPRI = '" + __DIT_GRUPPO + "'"
		x_cond = x_soci + " and " + x_codi
		cSql = "SELECT * FROM U_ART_PR WHERE " + x_cond
		IF !ExecRW(cSql,"U_ART_PR","R")
			RETURN .F.
		ENDIF
		SELECT U_ART_PR
		GO TOP
		IF !EOF()
			*REPLACE ART_SECLAV WITH __DIS_SECTOT
			*REPLACE ART_SECATT WITH 0
			*REPLACE ART_SECIMP WITH ART_SECLAV
			*REPLACE ART_OREATT WITH ""
			*REPLACE ART_ORELAV WITH da_secondi_a_ore_minuti_secondi(ART_SECIMP)
			*REPLACE ART_OREIMP WITH da_secondi_a_ore_minuti_secondi(ART_SECIMP)
			
			REPLACE ART_TIPOPR WITH ALLTRIM(__DIT_TIPOPR)
			
			*** AGGIORNAMENTO CAMPI PER DETERMINAZIONE COSTI E TEMPI DINAMICA DA ANAGRAFICA ARTICOLI
			*** (PER FASI LAV. ESTERNE CONSIDERA IL COD. PADRE E LA SCHEDA ARTICOLI/FORNITORI)
			IF __DIS_TIPOPR = 'E' AND !EMPTY(__DIS_CODFOR)
				IF EMPTY(ART_CODF1) OR ALLTRIM(ART_CODF1) = ALLTRIM(__DIS_CODFOR)
					REPLACE ART_CODF1 WITH ALLTRIM(__DIS_CODFOR)
					REPLACE ART_PRZCO1 WITH __DIS_COSLAE 
				ELSE
					IF EMPTY(ART_CODF2) OR ALLTRIM(ART_CODF2) = ALLTRIM(__DIS_CODFOR)
						REPLACE ART_CODF2 WITH ALLTRIM(__DIS_CODFOR)
						REPLACE ART_PRZCO2 WITH __DIS_COSLAE 
					ELSE
						IF EMPTY(ART_CODF3) OR ALLTRIM(ART_CODF3) = ALLTRIM(__DIS_CODFOR)
							REPLACE ART_CODF3 WITH ALLTRIM(__DIS_CODFOR)
							REPLACE ART_PRZCO3 WITH __DIS_COSLAE 
						ELSE
							IF EMPTY(ART_CODF4) OR ALLTRIM(ART_CODF4) = ALLTRIM(__DIS_CODFOR)
								REPLACE ART_CODF4 WITH ALLTRIM(__DIS_CODFOR)
								REPLACE ART_PRZCO4 WITH __DIS_COSLAE 
							ELSE
								IF EMPTY(ART_CODF5) OR ALLTRIM(ART_CODF5) = ALLTRIM(__DIS_CODFOR)
									REPLACE ART_CODF5 WITH ALLTRIM(__DIS_CODFOR)
									REPLACE ART_PRZCO5 WITH __DIS_COSLAE 
								ENDIF
							ENDIF
						ENDIF
					ENDIF
				ENDIF
			ENDIF
		ENDIF
		IF !ExecRW(cSql,"U_ART_PR","W")
			RETURN .F.
		ENDIF
		**=> ERASMO - FINE 01/10/2014
		
	ENDSCAN
	**=> ERASMO - FINE 08/05/2014	

	x_agga = "TAGGANCIO = '" + _AGGA + "'"
	x_grup = "DIT_GRUPPO = '" + __DIT_GRUPPO + "'"
	x_cond = x_agga + " and " + x_grup 
	cSql = "UPDATE U_DIS_TT SET DIT_TIPOPR = '" + ALLTRIM(__DIT_TIPOPR) + "' WHERE " + x_cond
	IF !ExecCommand(cSql,"UPD_DIS_TT")
	   return
	ENDIF

