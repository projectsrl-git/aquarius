RIT = MESSAGEBOX("Procedo con la conversione "+CHR(13)+"delle distinte basi ?",292,"ATTENZIONE")
IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF

=OPENDB("PERCORSO")
SELECT PERCORSO
SET ORDER TO I_TIPO
SEEK 'DIB'
IF FOUND()
ELSE
   RETURN
ENDIF

SELECT PERCORSO
V_PATH = ALLTRIM(PER_PATH)

WAIT WINDOWS "ATTENDERE PREGO, CANCELLAZIONE VECCHIE DISTINTE BASI" NOWAIT

cSql = "delete from u_dis_tt"
IF !ExecCommand(cSql,"U_DIS_TT")
   return(.f.)
ENDIF
cSql = "delete from u_dis_dd"
IF !ExecCommand(cSql,"U_DIS_DD")
   return(.f.)
ENDIF

PUBLIC Y_CAMPO,V_CAMPO,_CTR,V_PROGRE
Y_CAMPO  = ""
V_CAMPO  = ""
_CTR     = 0
V_PROGRE = 0

CREATE CURSOR TRANSITO (TRA_RECORD C(200))

SELECT TRANSITO
APPEND FROM &V_PATH SDF

*SELECT TRANSITO  
*gcTable = GETFILE('', 'Seleziona file distinte basi da convertire', 'Converti',0)
*IF empty(gcTable) .or. gcTable = ""
*   =MESSAGEBOX("Nessun file selezionato, operazione abbandonata",62,"ATTENZIONE")
*   RETURN
*ENDIF
*SELECT TRANSITO
*APPEND FROM &gcTable SDF

SELECT TRANSITO
GO TOP

DELETE FOR SUBSTR(tra_record,2,1) = '=' ALL
DELETE FOR SUBSTR(tra_record,3,7) = 'Azienda' ALL
DELETE FOR SUBSTR(tra_record,1,8) = 'Gru.Merc' ALL
DELETE FOR SUBSTR(tra_record,1,8) = 'Cod.Arti' ALL
DELETE FOR SUBSTR(tra_record,3,8) = 'Cod.Comp' ALL
DELETE FOR SUBSTR(tra_record,1,2) = '  ' .AND. SUBSTR(tra_record,3,1) = ' ' ALL
DELETE FOR SUBSTR(tra_record,2,1) = '-' ALL
DELETE FOR SUBSTR(tra_record,3,4) = 'FILM' ALL

V_CONTA = 0
V_SALTA = .T.
V_TESTA = .T.

*SET STEP ON 

SELECT TRANSITO
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF V_SALTA
      V_SALTA = .F.
      SKIP +1
      LOOP
   ENDIF
  
   IF V_TESTA
      V_TESTA      = .F.
      M.TAGGANCIO  = STR(NEWPROG('NUMDIS'),10)
      SELECT TRANSITO
      M.DIT_CODSOC = PUB_CODSOC
      M.DIT_GRUPPO = ALLTRIM(SUBSTR(TRA_RECORD,1,15)) + ' SLC'
      M.DIT_DESCRI = ALLTRIM(SUBSTR(TRA_RECORD,17,32)) + ' SLC'
      M.DIT_UM     = ALLTRIM(SUBSTR(TRA_RECORD,50,2))   
      M.DIT_MAGA   = PUB_CODM  
      M.DIT_LINEA  = PUB_LINEA 
      M.DIT_CODIVA = PUB_IVA   
      M.DIT_VALUTA = PUB_VALU   
      M.DIT_GGATCQ = 2
      V_PROGRE     = 0
      DO GESTIONE_TESTA
      SELECT TRANSITO
      SKIP +1
   ENDIF
   
   IF SUBSTR(TRA_RECORD,1,1) = 'A' .OR. SUBSTR(TRA_RECORD,1,1) = ' '
   ELSE
      V_SALTA = .T.
      V_TESTA = .T.
      LOOP
   ENDIF

   V_PROGRE     = V_PROGRE + 10
   
   M.DAGGANCIO  = M.TAGGANCIO
   M.DIS_GRUPPO = M.DIT_GRUPPO
   M.DIS_TIPO   = 'A'
   M.DIS_CODART = ALLTRIM(SUBSTR(TRA_RECORD,3,15))

   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,53,8))
   DO TOGLI_PUNTI
   V_QUANTI     = VAL(ALLTRIM(Y_CAMPO))

   M.DIS_QTA    = V_QUANTI
   M.DIS_MAGA   = PUB_CODM  
   M.DIS_DESCRI = ALLTRIM(SUBSTR(TRA_RECORD,18,31))   
   M.DIS_UM     = ALLTRIM(SUBSTR(TRA_RECORD,50,2))   
   M.DIS_SEQUEN = V_PROGRE
   
   DO GESTIONE_DETTA

   SELECT TRANSITO
   SKIP +1
   
ENDDO

=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

RETURN


************************
PROCEDURE GESTIONE_TESTA
************************

x_soci = "dit_codsoc = '" + M.DIT_CODSOC + "'"
x_codi = "dit_gruppo = '" + M.DIT_GRUPPO + "'"
x_cond = x_soci + " and " + x_codi
cSql   = "select * from u_dis_tt where " + x_cond 
IF !ExecRW(cSql,"u_dis_tt","R")
   return
ENDIF
SELECT u_dis_tt
IF EOF()
   m.id_unique = ""
   APPEND BLANK
ENDIF

M.DIT_GRUPPO  = UPPER(M.DIT_GRUPPO)
M.DIT_GRUPPO  = APITOSPA(M.DIT_GRUPPO)
M.DIT_DESCRI  = UPPER(M.DIT_DESCRI)
M.DIT_DESCRI  = APITOSPA(M.DIT_DESCRI)
M.DIT_UM      = UPPER(M.DIT_UM)
M.DIT_UM      = APITOSPA(M.DIT_UM)

REPLACE TAGGANCIO  WITH M.TAGGANCIO
REPLACE DIT_CODSOC WITH M.DIT_CODSOC
REPLACE DIT_GRUPPO WITH M.DIT_GRUPPO
REPLACE DIT_DESCRI WITH M.DIT_DESCRI
REPLACE DIT_UM     WITH M.DIT_UM
REPLACE DIT_MAGA   WITH M.DIT_MAGA
REPLACE DIT_LINEA  WITH M.DIT_LINEA
REPLACE DIT_CODIVA WITH M.DIT_CODIVA
REPLACE DIT_VALUTA WITH M.DIT_VALUTA
REPLACE DIT_GGATCQ WITH M.DIT_GGATCQ

IF !ExecRW(cSql,"u_dis_tt","W")
   return
ENDIF

V_CONTA = V_CONTA + 1

_CTR = _CTR +1
WAIT WINDOWS "RECORDS SCRITTI : "+STR(_CTR,10,0) NOWAIT

RETURN


************************
PROCEDURE GESTIONE_DETTA
************************

cSql = "select * from u_dis_dd where 1=0"
IF !ExecRW(cSql,"u_dis_dd","R")
   return
ENDIF
SELECT u_dis_dd
APPEND BLANK

M.DIS_CODART  = UPPER(M.DIS_CODART)
M.DIS_CODART  = APITOSPA(M.DIS_CODART)
M.DIS_DESCRI  = UPPER(M.DIS_DESCRI)
M.DIS_DESCRI  = APITOSPA(M.DIS_DESCRI)
M.DIS_UM      = UPPER(M.DIS_UM)
M.DIS_UM      = APITOSPA(M.DIS_UM)

REPLACE DAGGANCIO  WITH M.DAGGANCIO
REPLACE DIS_GRUPPO WITH M.DIS_GRUPPO
REPLACE DIS_TIPO   WITH M.DIS_TIPO
REPLACE DIS_CODART WITH M.DIS_CODART
REPLACE DIS_DESCRI WITH M.DIS_DESCRI
REPLACE DIS_UM     WITH M.DIS_UM
REPLACE DIS_MAGA   WITH M.DIS_MAGA
REPLACE DIS_QTA    WITH M.DIS_QTA
REPLACE DIS_SEQUEN WITH M.DIS_SEQUEN

IF !ExecRW(cSql,"u_dis_dd","W")
   return
ENDIF

RETURN


*********************
PROCEDURE TOGLI_PUNTI
*********************

YY      = LEN(V_CAMPO)
XX      = 1
Y_CAMPO =  ' '
DO WHILE .T.
   IF XX > YY
      EXIT
   ENDIF
   IF SUBSTR(V_CAMPO,XX,1) = '.'  
   ELSE
      Y_CAMPO = Y_CAMPO + SUBSTR(V_CAMPO,XX,1) 
   ENDIF
   XX = XX + 1
ENDDO

RETURN

