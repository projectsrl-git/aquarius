*************************
PROCEDURE IVAERA 
*************************
*RECUPERO IVA PRECEDENTE*
    
x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
x_anno = "iva_anno = " + ANNO
x_cond = x_soci + " and " + x_anno
CSQL   = "select * from u_iva_cr where " + x_cond + " order by iva_codsoc,iva_anno" 
IF !ExecCommand(CSQL,"u_iva_cr")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_CR
GO TOP
IF !EOF()
   IF OK_TRIM = 0
      IF VAL(MESE_DAL) = 1
         E_IMPOST = IVA_GENNAI
      ENDIF
      IF VAL(MESE_DAL) = 2
         E_IMPOST = IVA_FEBBRA
      ENDIF
      IF VAL(MESE_DAL) = 3
         E_IMPOST = IVA_MARZO
      ENDIF
      IF VAL(MESE_DAL) = 4
         E_IMPOST = IVA_APRILE
      ENDIF
      IF VAL(MESE_DAL) = 5
         E_IMPOST = IVA_MAGGIO
      ENDIF
      IF VAL(MESE_DAL) = 6
         E_IMPOST = IVA_GIUGNO
      ENDIF
      IF VAL(MESE_DAL) = 7
         E_IMPOST = IVA_LUGLIO
      ENDIF
      IF VAL(MESE_DAL) = 8
         E_IMPOST = IVA_AGOSTO
      ENDIF
      IF VAL(MESE_DAL) = 9
         E_IMPOST = IVA_SETTEM
      ENDIF
      IF VAL(MESE_DAL) = 10
         E_IMPOST = IVA_OTTOBR
      ENDIF
      IF VAL(MESE_DAL) = 11
         E_IMPOST = IVA_NOVEMB
      ENDIF
      IF VAL(MESE_DAL) = 12
         E_IMPOST = IVA_DICEMB
      ENDIF
   ENDIF
   IF OK_TRIM = 1
      E_IMPOST = IVA_GENNAI + IVA_FEBBRA + IVA_MARZO
   ENDIF
   IF OK_TRIM = 2
      E_IMPOST = IVA_APRILE + IVA_MAGGIO + IVA_GIUGNO
   ENDIF
   IF OK_TRIM = 3
      E_IMPOST = IVA_LUGLIO + IVA_AGOSTO + IVA_SETTEM
   ENDIF
   IF OK_TRIM = 4
      E_IMPOST = IVA_OTTOBR + IVA_NOVEMB + IVA_DICEMB
   ENDIF
ELSE
   E_IMPOST  = 0 
ENDIF 

* >>>>>>> PRELIEVO DELL'IVA DI RIPORTO ANNO SUCCESSIVO

x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
x_anno = "iva_anno = " + PUB_ANNOP
x_cond = x_soci + " and " + x_anno
CSQL   = "select * from u_iva_cr where " + x_cond + " order by iva_codsoc,iva_anno" 
IF !ExecCommand(CSQL,"u_iva_cr")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_CR
GO TOP
IF !EOF()
   IVADARIPORTARE  		= IVA_DARIPO
ELSE
   IVADARIPORTARE  		= 0 
ENDIF 

* >>>>>>> PRELIEVO DELL'IVA GIA' RECUPERATA TOGLIENDOLA DALL'IVA DA RECUPERARE


x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
**x_anno = "iva_anno = " + PUB_ANNO					&& 01/03/2016 SERGIO CALCOLO ACCONTO IVA IN CORSO (IN QUESTO CASO NON STAMPIAMO IL RIEPILOGO)
IF PUB_CALCOLO_ACCONTO_IVA							&& 01/03/2016 SERGIO CALCOLO ACCONTO IVA IN CORSO (IN QUESTO CASO NON STAMPIAMO IL RIEPILOGO)
	x_anno = "iva_anno = '" + __PUB_ANNOP + "'"		&& 01/03/2016 SERGIO CALCOLO ACCONTO IVA IN CORSO (IN QUESTO CASO NON STAMPIAMO IL RIEPILOGO)
ELSE
	x_anno = "iva_anno = '" + PUB_ANNO + "'"
ENDIF

x_cond = x_soci + " and " + x_anno
CSQL   = "select * from u_iva_cr where " + x_cond + " order by iva_codsoc,iva_anno" 
IF !ExecCommand(CSQL,"u_iva_cr")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_CR
GO TOP
IF !EOF()


	IF OK_TRIM = 0     				

	    MESE_SUCCESSIVO = VAL(MESE_DAL) 

	    IF MESE_SUCCESSIVO = 1
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_01RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 2
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_02RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 3
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_03RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 4
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_04RECU
	    ENDIF
	    IF MESE_SUCCESSIVO = 5
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_05RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 6
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_06RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 7
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_07RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 8
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_08RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 9
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_09RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 10
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_10RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 11
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_11RECU 
	    ENDIF
	    IF MESE_SUCCESSIVO = 12
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_12RECU 
	    ENDIF


		IF !AGG_IVAREC  				

		    MESE_SUCCESSIVO = VAL(MESE_DAL) 

			EXTRAIVADARECUPERARE   = 0
			
		    IF MESE_SUCCESSIVO = 1
		        EXTRAIVADARECUPERARE  = IVA_01EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 2
		        EXTRAIVADARECUPERARE  = IVA_02EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 3
		        EXTRAIVADARECUPERARE  = IVA_03EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 4
		        EXTRAIVADARECUPERARE  = IVA_04EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 5
		        EXTRAIVADARECUPERARE  = IVA_05EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 6
		        EXTRAIVADARECUPERARE  = IVA_06EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 7
		        EXTRAIVADARECUPERARE  = IVA_07EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 8
		        EXTRAIVADARECUPERARE  = IVA_08EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 9
		        EXTRAIVADARECUPERARE  = IVA_09EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 10
		        EXTRAIVADARECUPERARE  = IVA_10EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 11
		        EXTRAIVADARECUPERARE  = IVA_11EXTR
		    ENDIF
		    IF MESE_SUCCESSIVO = 12
		        EXTRAIVADARECUPERARE  = IVA_12EXTR
		    ENDIF

		ENDIF OK_TRIM = 0     				





	ELSE

		IF OK_TRIM = 1						&& primo trimestre 
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_03RECU + IVA_03EXTR
		ENDIF     

		IF OK_TRIM = 2
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_06RECU + IVA_06EXTR
		ENDIF     

		IF OK_TRIM = 3	
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_09RECU + IVA_09EXTR
		ENDIF     

		IF OK_TRIM = 4						&& quarto trimestre 
	        IVADARIPORTARE  = IVADARIPORTARE  - IVA_TTRECU + IVA_12RECU + IVA_12EXTR
		ENDIF     


		IF !AGG_IVAREC  

			EXTRAIVADARECUPERARE   = 0
			
			
			IF OK_TRIM = 1						&& primo trimestre 
		        EXTRAIVADARECUPERARE  = IVA_03EXTR
			ENDIF     

			IF OK_TRIM = 2
		        EXTRAIVADARECUPERARE  = IVA_06EXTR
			ENDIF     

			IF OK_TRIM = 3	
		        EXTRAIVADARECUPERARE  = IVA_09EXTR
			ENDIF     

			IF OK_TRIM = 4						&& quarto trimestre 
		        EXTRAIVADARECUPERARE  = IVA_12EXTR
			ENDIF     


		ENDIF !AGG_IVAREC  		

	ENDIF
ENDIF 



SELECT IVA_CL

RETURN


*************************
PROCEDURE OK_SPOOL 
*************************
****** INIZIO: TOTALE PER OGNI CODICE IVA DI TUTTI I MESI CONSIDERATI ... FABIANO

_XXX_SSS=SELECT()


SELECT IVA_CL
GO TOP

DO WHILE .T. 

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
  	  SKIP +1
	  LOOP 
   ENDIF

   ****** INIZIO: SCARTA I DETTAGLI --> CHIAVE_R="DET"
   IF CHIAVE_R="DET"
	  SELECT IVA_CL
	  SKIP +1
	  LOOP 
   ENDIF
   ****** FINE: SCARTA I DETTAGLI --> CHIAVE_R="DET"

   SCATTER MEMVAR MEMO
   V_CODIVA=ITO_CODIVA
   V_CHIAVE=STR(CHIAVE,6,0)
   V_FATNOT=ITO_FATNOT
   V_DESIVA=ITO_DESIVA
   V_IND100=ITO_IND100
   __DEDUCIBILE = ITO_DEDUCIBILE	&& IMPOSTA INDEDUCIBILE = .F. / IMPOSTA DEDUCIBILE = .T.
 
   
   IF EMPTY(V_CODIVA)
      SELECT IVACLTOT
      APPEND BLANK
      GATHER MEMVAR
   ELSE
      SELECT IVACLTOT
      SET ORDER TO ITO_CODIVA
      SEEK V_CHIAVE+V_CODIVA+V_FATNOT
      IF !FOUND()
         APPEND BLANK
         GATHER MEMVAR
         DO CASE 
         
         	CASE V_CHIAVE="888222"
         	
	            **IF V_IND100 = 'S'	.OR. "*" $ V_CODIVA	 && IMPOSTE INDEDUCIBILI  
	            IF V_IND100 = 'S'	.OR. __DEDUCIBILE && IMPOSTE INDEDUCIBILI  
	               _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA  +  " | " +SPACE(18)+ " | " +SPACE(18)
	               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
	               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPOST,"999,999,999,999.99"),1,18)
	            ELSE
	               _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
	               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
	               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPOST,"999,999,999,999.99"),1,18) +  " | " +SPACE(18)+ " | " +SPACE(18)
	            ENDIF
	            
         	CASE V_CHIAVE="666888"
         	
               _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITS_IMPONI,"999,999,999,999.99"),1,18) 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITS_IMPOST,"999,999,999,999.99"),1,18) +  " | " +SPACE(18)+ " | " +SPACE(18)

         	CASE V_CHIAVE="777777"
         	
               _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITS_IMPONI,"999,999,999,999.99"),1,18) 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITS_IMPOST,"999,999,999,999.99"),1,18) +  " | " +SPACE(18)+ " | " +SPACE(18)


			OTHERWISE   
			      
               _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
