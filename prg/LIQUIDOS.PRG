****************************************
FUNCTION CALCOLA_IVA_DETRAIBILE_PRORATA
****************************************
* CALCOLA L'IVA PRORATA DETRAIBILE     *
   
*** >>>>>  TOTALI IVA FORNITORI 

IMPONIB_F_PRORATA = 0  && IVE FATTURE
IMPOSTA_F_PRORATA = 0
IMPONIB_N_PRORATA = 0  && IVE NOTE CREDITO
IMPOSTA_N_PRORATA = 0
IMPONIB_X_PRORATA = 0  && IVE INDEDUCIBILI
IMPOSTA_X_PRORATA = 0

x_soci = "ito_codsoc = '" + PUB_CODSOC + "'"
x_anno = "ito_anno = '" + ANNO + "'"
x_mese = "ito_mese >= '" + MESE_DAL + "'"
x_tipo = "ito_clifor = 'F'"
x_cond = x_soci + " and " + x_anno + " and " + x_mese + " and " + x_tipo
*CSQL   = "select * from u_iva_to where " + x_cond + " order by ito_codsoc,ito_anno,ito_mese,ito_clifor" 
CSQL   = "select * from " + IIF(_OK_LIQDTDOC,"U_IVA_TO_DTDOC","U_IVA_TO") + " AS U_IVA_TO where " + x_cond + " order by ito_codsoc,ito_anno,ito_mese,ito_clifor"  && ERASMO - 11/04/2023
IF !ExecCommand(CSQL,"u_iva_to")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_TO
GO TOP

DO WHILE .T. 

   IF EOF()
      EXIT
   ENDIF

   IF ITO_MESE < MESE_DAL .OR. ITO_MESE > MESE_AL
      SELECT U_IVA_TO
      SKIP + 1
      LOOP
   ENDIF

   V_CODIVA = ITO_CODIVA 
   V_FATNOT = ITO_FATNOT 
   V_DESIVA = ITO_DESIVA
   V_IMPONI = ITO_IMPONI
   V_IMPOST = ITO_IMPOST
   V_IND100 = ITO_IND100
 
   ** IVE INDEDUCIBILI  
 
   v_seek	= 'IVA'+V_CODIVA
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      TIPOIVA   = SUBSTR(LIBERA,100,1)
	  KK_NO_IMPOSTA = SUBSTR(LIBERA,128,1)
   ELSE
      TIPOIVA   = " "
	  KK_NO_IMPOSTA = ""
   ENDIF

   IF KK_NO_IMPOSTA = "S"		&& SCARTA LE IVE NON CONTEMPLATE NELLA SOMMA DELL'IVA PRORATA DETRAIBILE
      SELECT U_IVA_TO
      SKIP +1
      LOOP
   ENDIF
	

   SELECT U_IVA_TO

   IND_100 = ' '
   IF ITO_IND100 = 'S'  && IVA INDEDUCIBILE AL 100%
      IND_100   = "S"
   ENDIF

    __DEDUCIBILE = ITO_DEDUCIBILE	&& IMPOSTA INDEDUCIBILE = .F. / IMPOSTA DEDUCIBILE = .T.

   **IF IND_100 = 'S'	.OR. "*" $ V_CODIVA	 && IMPOSTE INDEDUCIBILI  
   IF IND_100 = 'S'	.OR. __DEDUCIBILE	 && IMPOSTE INDEDUCIBILI             
      IF IND_100 = 'S'
 	     IF V_FATNOT = "F" 
			IMPONIB_X_PRORATA =  IMPONIB_X_PRORATA  + ITO_IMPONI + ITO_IMPOST  	&& IVE INDEDUCIBILI AL 100%
			IMPOSTA_X_PRORATA =  IMPOSTA_X_PRORATA  + ITO_IMPOST
	 		V_IMPONI  =  ITO_IMPONI + ITO_IMPOST 								&& IVE INDEDUCIBILI AL 100%
		 ELSE
			IMPONIB_X_PRORATA =  IMPONIB_X_PRORATA  - ITO_IMPONI - ITO_IMPOST  	&& PER NOTE C. TOGLIE
			IMPOSTA_X_PRORATA =  IMPOSTA_X_PRORATA  - ITO_IMPOST
	 		V_IMPONI  =  ITO_IMPONI + ITO_IMPOST 								&& IVE INDEDUCIBILI AL 100%
		 ENDIF
      ELSE
         IF V_FATNOT = "F" 
		    IMPONIB_X_PRORATA =  IMPONIB_X_PRORATA  + ITO_IMPONI  				&& IVE INDEDUCIBILI AL 100%
		    IMPOSTA_X_PRORATA =  IMPOSTA_X_PRORATA  + ITO_IMPOST
		 ELSE
		    IMPONIB_X_PRORATA =  IMPONIB_X_PRORATA  - ITO_IMPONI  				&& IVE INDEDUCIBILI AL 100%
		    IMPOSTA_X_PRORATA =  IMPOSTA_X_PRORATA  - ITO_IMPOST
		 ENDIF
	  ENDIF	 
   ELSE 
      IF V_FATNOT = "F" 
         IMPONIB_F_PRORATA =  IMPONIB_F_PRORATA  + ITO_IMPONI  && IVE FATTURE
         IMPOSTA_F_PRORATA =  IMPOSTA_F_PRORATA  + ITO_IMPOST
      ENDIF 
      IF V_FATNOT = "N" 
         IMPONIB_F_PRORATA =  IMPONIB_F_PRORATA  - ITO_IMPONI  && IVE NOTE CREDITO
         IMPOSTA_F_PRORATA =  IMPOSTA_F_PRORATA  - ITO_IMPOST
      ENDIF 
   ENDIF

    
   SELECT U_IVA_TO
   SKIP + 1

ENDDO

IVA_IMPONIBILE_PRORATA = IMPONIB_F_PRORATA + IMPONIB_X_PRORATA
IVA_PRORATA_DETRAIBILE = IMPOSTA_F_PRORATA + IMPOSTA_X_PRORATA 
IVA_PRORAT = ((IMPOSTA_F_PRORATA * PERC_PRORATA) / 100)
IVA_PRORATA =	ROUND((IVA_PRORAT+.0000),2)




RETURN


