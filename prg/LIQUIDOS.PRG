	   	IF IVADARIPORTARE  >= 	EXTRAIVADARECUPERARE 
	   
	   
	   	   DO CASE

	   	   		CASE T_IMPOST  <=  IVADARIPORTARE  && IVA DA PAGARE CONTENUTA NELL'IMPORTO IVA DA RECUPERARE ANNO PRECEDENTE
	   	   
					   IF T_IMPOST  => EXTRAIVADARECUPERARE 
				       		IVARECUPERATA  		=  T_IMPOST - EXTRAIVADARECUPERARE 			&& IVA CHE DVEVO PAGARE MA CHE NON PAGO IN QUANTO RECUPERATA DA ANNO PRECEDENTE
					       	EXTRAIVARECUPERATA  =  EXTRAIVADARECUPERARE 					&& RECUPERO ANCHE L'EXTRAIVA 
						   	T_IMPOST 			=  0			  							&& NON PAGO NULLA
					   ELSE
				       		IVARECUPERATA  		=  0  		
					       	EXTRAIVARECUPERATA  =  T_IMPOST  					 					
						   	T_IMPOST 			=  0			  							&& NON PAGO NULLA
					   ENDIF
					   	 
		
	   	   
	   	   		CASE T_IMPOST  >  IVADARIPORTARE  && IVA DA PAGARE NON CONTENUTA NELL'IMPORTO IVA DA RECUPERARE ANNO PRECEDENTE E QUINDI SI RIPARTISCE IN PARTE NELL'EXTRAIVA DA RECUPERARE
	   	   
				       IVARECUPERATA  		=  IVADARIPORTARE				 
					   T_IMPOST 			=  T_IMPOST - IVADARIPORTARE 	

					   IF T_IMPOST  =>  EXTRAIVADARECUPERARE 
					       EXTRAIVARECUPERATA	=  EXTRAIVADARECUPERARE 		
						   T_IMPOST 			=  T_IMPOST - EXTRAIVADARECUPERARE 			  	
					   ELSE
					       EXTRAIVARECUPERATA	=  T_IMPOST 	&& VIENE FORZATO L'IMPORTO DELL'EXTRAIVA 	
						   T_IMPOST 			=  0		  	
					   ENDIF

	   	   ENDCASE

		ELSE
		
	   	   DO CASE

	   	   		CASE T_IMPOST  <=  EXTRAIVADARECUPERARE && IVA DA PAGARE CONTENUTA NELL'IMPORTO EXTRAIVA DA RECUPERARE ANNO PRECEDENTE

   	   
	   	   			   IF T_IMPOST => IVADARIPORTARE
	   	   			   
					       IVARECUPERATA  		=  IVADARIPORTARE   			
						   T_IMPOST 			=  T_IMPOST - 	IVADARIPORTARE
						
						   IF T_IMPOST <= EXTRAIVADARECUPERARE 
								EXTRAIVARECUPERATA  	=  T_IMPOST 
								T_IMPOST 				=  0									
						   ELSE
								EXTRAIVARECUPERATA  	=  EXTRAIVADARECUPERARE 								
								T_IMPOST 				=  T_IMPOST -	EXTRAIVADARECUPERARE 
						   ENDIF

					   ELSE
					       IVARECUPERATA  		=  T_IMPOST 			
					       EXTRAIVARECUPERATA  	=  0				
						   T_IMPOST 			=  0			  						&& NON PAGO NULLA
					   ENDIF
					   
	   	   
	   	   		CASE T_IMPOST  >  EXTRAIVADARECUPERARE && IVA DA PAGARE NON CONTENUTA NELL'IMPORTO EXTRAIVA DA RECUPERARE ANNO PRECEDENTE E QUINDI SI RIPARTISCE IN PARTE NELL'EXTRAIVA DA RECUPERARE
	   	   

				       EXTRAIVARECUPERATA	=  EXTRAIVADARECUPERARE 		
					   T_IMPOST 			=  T_IMPOST - EXTRAIVADARECUPERARE 	

					   IF T_IMPOST  =>  IVADARIPORTARE  
					       IVARECUPERATA  		=  IVADARIPORTARE  		
						   T_IMPOST 			=  T_IMPOST - IVADARIPORTARE  			  	
					   ELSE
					       IVARECUPERATA  		=  T_IMPOST 	&& VIENE FORZATO L'IMPORTO DELL'IVA 	
						   T_IMPOST 			=  0		  	
					   ENDIF

	   	   ENDCASE
		
	   	ENDIF IVADARIPORTARE  >= 	EXTRAIVADARECUPERARE 
   
   
   ELSE

       IVARECUPERATA  		= IVADARIPORTARE 
       EXTRAIVARECUPERATA  	= EXTRAIVADARECUPERARE 
	   T_IMPOST = T_IMPOST - (IVADARIPORTARE  + EXTRAIVADARECUPERARE)	  && HO TOLTO TUTTA L'IVA/EXTRAIVA RECUPERABILE DALL'ANNO PRECEDENTE

   ENDIF
ELSE
   PAGO_S_N = "CREDITO"
ENDIF


IF OK_ARR
   T_IMPOST = OK_ARROTB(T_IMPOST,PUB_VALRIF)
ENDIF

SAVE_T_IMPOST = T_IMPOST

RIGA_D = " >>>>> TOTALI GENERALI   " 
RIGA_D = RIGA_D + SPACE(12) + "   " + SPACE(12) 
