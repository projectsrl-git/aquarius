	  RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(_ABIT_IMPOST,"999,999,999,999.99"),1,18)
   ELSE
	  RIGA_D = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
