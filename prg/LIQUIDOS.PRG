	  _ABIT_IMPONI = V_IMPONI * -1
	  _ABIT_IMPOST = V_IMPOST * -1
   ELSE
	  _ABIT_IMPONI = V_IMPONI 
	  _ABIT_IMPOST = V_IMPOST 
   ENDIF

 
   **IF IND_100 = 'S'	.OR. "*" $ V_CODIVA	 && IMPOSTE INDEDUCIBILI  
   IF IND_100 = 'S'	.OR. __DEDUCIBILE	 && IMPOSTE INDEDUCIBILI             
