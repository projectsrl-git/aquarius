	            _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITS_IMPONI,"999,999,999,999.99"),1,18) 
	            _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITS_IMPOST,"999,999,999,999.99"),1,18)        	
			
			OTHERWISE  
			
	            _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA
	            _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
