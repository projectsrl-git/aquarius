SET PROCEDURE TO PRG\FLW_GESTIONE_PROCEDURE_LIB ADDITIVE

DO FLW_CREA_CURSORI_GRIGLIE

*** CARICA LE PROCEDURE VISIBILI DALL'UTENTE

*** SELEZIONO LE PROCEDURE
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 	PRO.SELEZIONE, 
			PRO.ID_PROCEDURA, 
			PRO.CODATTIV,
			COALESCE(PAR.DESCRI,'') AS DESATTIV,
			PRO.DATA_ULTAGG, 
			PRO.ORA_ULTAGG, 
			PRO.DESCRIZIONE,
			PRO.CODCLI,
	 		COALESCE(CLI.CLI_RAGSOC,'') AS RAGSOC
	FROM FLOW_PROCEDURE AS PRO
	LEFT OUTER JOIN U_CLI_AN AS CLI
	ON PRO.CODCLI = CLI_CODCLI
	LEFT OUTER JOIN PARA AS PAR  
	ON PAR.CODICE= 'AST'+PRO.CODATTIV 
	ORDER BY ID_PROCEDURA
ENDTEXT					&& FINE SCRITTURA QUERY
IF !ExecCommand(cSql,"GEST_FLOW_PROCEDURE")
	return(.f.)
ENDIF

SELECT GEST_FLOW_PROCEDURE
GO TOP

REFRESH_CURSORE_GRIGLIA("GEST_FLOW_PROCEDURE")

cSql="SELECT * FROM FLOW_BLOCCHI WHERE 1=0"
IF !ExecCommand(cSql,"GEST_FLOW_BLOCCHI")
	return(.f.)
ENDIF

REFRESH_CURSORE_GRIGLIA("GEST_FLOW_BLOCCHI")


DO FORM FORM\FLW_GESTIONE_PROCEDURE LINKED


