		ENDIF
		
		
		cSql = "SELECT * FROM U_FAT_DD WHERE 1=0"
		IF !ExecRW(cSql,"U_FAT_DD","R")
		   return
		ENDIF
		SELECT U_FAT_DD
		APPEND BLANK

		REPLACE ORD_SEQUEN WITH __ORD_SEQUEN
