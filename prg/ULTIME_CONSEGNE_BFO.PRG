*********************
* ULTIME_CONSEGNE_BFO
*********************

LPARAMETERS _GIORNI_PRECEDENTI

IF PCOUNT()<1
	RETURN .F.
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO,V_GIORNI_PRECEDENTI
PUBLIC V_TITOLO,V_GIORNI_PRECEDENTI

V_GIORNI_PRECEDENTI = _GIORNI_PRECEDENTI

V_TITOLO = "Consegne da fornitori degli ultimi " + ALLTRIM(STR(V_GIORNI_PRECEDENTI,10,0)) + " giorni"

WAIT WINDOWS "ESEGUE PROGRAMMA ULTIME_CONSEGNE_BFO" TIMEOUT 3

*** REPORT RIEPILOGO
cSql=""     
cNomeCursorSql="CU_CONSEGNE_BFO"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
	SELECT 
		DBO.RIBALTA2(TT.ORD_DATORD) AS DATA_REG,
		TT.ORD_NUMORD AS NUM_DDT,
		DD.ORD_CODART AS COD_ARTICOLO,
		PR.ART_DESCR AS DESCRIZIONE,
		TT.ORD_CODCLI AS COD_FORNITORE,
		TT.ORD_RAGSOC AS RAG_SOCIALE,
		AN.ART_LDTMST AS LEAD_TIME_STD,
		CASE
			WHEN PR.ART_CODF1 = TT.ORD_CODCLI THEN ART_LDTM1
			WHEN PR.ART_CODF2 = TT.ORD_CODCLI THEN ART_LDTM2
			WHEN PR.ART_CODF3 = TT.ORD_CODCLI THEN ART_LDTM3
			WHEN PR.ART_CODF4 = TT.ORD_CODCLI THEN ART_LDTM4
			WHEN PR.ART_CODF5 = TT.ORD_CODCLI THEN ART_LDTM5
			ELSE 0
		END AS LEAD_TIME_EFF,
		CASE
			WHEN PR.ART_CODF1 = TT.ORD_CODCLI THEN ART_LDTM1 - AN.ART_LDTMST
			WHEN PR.ART_CODF2 = TT.ORD_CODCLI THEN ART_LDTM2 - AN.ART_LDTMST
			WHEN PR.ART_CODF3 = TT.ORD_CODCLI THEN ART_LDTM3 - AN.ART_LDTMST
			WHEN PR.ART_CODF4 = TT.ORD_CODCLI THEN ART_LDTM4 - AN.ART_LDTMST
			WHEN PR.ART_CODF5 = TT.ORD_CODCLI THEN ART_LDTM5 - AN.ART_LDTMST
			ELSE 0
		END AS GG_RITARDO
	FROM U_BFO_TT AS TT
	LEFT OUTER JOIN U_BFO_DD AS DD ON DD.DAGGANCIO = TT.TAGGANCIO
	LEFT OUTER JOIN U_ART_PR AS PR ON PR.ART_CODPRI = DD.ORD_CODART
	LEFT OUTER JOIN U_ART_AN AS AN ON AN.ART_CODPRI = PR.ART_CODPRI
	LEFT OUTER JOIN U_ORF_DD AS OD ON OD.ORD_CODSYS = DD.ORD_LEGASY
	LEFT OUTER JOIN U_ORF_TT AS OT ON OT.TAGGANCIO = OD.DAGGANCIO
	WHERE
		DD.ORD_DESART <> '*** COMMENTO ***' AND
		DD.ORD_QTAORD > 0 AND 
		TT.ORD_DATORD >= CONVERT(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111) AND
		COALESCE(OT.ORD_PIANIF,0) = 0
	ORDER BY TT.ORD_DATORD,DD.ORD_CODART

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

LOCAL _DIRECTORY_PDF,_NOME_REPORT

_DIRECTORY_PDF=LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")  && RICERCA PERCORSO
IF !DIRECTORY(_DIRECTORY_PDF)
	*MESSAGEBOX("Directory '" + JUSTDRIVE(_DIRECTORY_PDF) + "' inesistente" + CHR(13) + CHR(13) + ;
		"Non sarą possibile creare correttamente i files PDF",48,"Attenzione")
	RETURN .F.
ENDIF	

_NOME_REPORT = _DIRECTORY_PDF + "\" + "ULTIME_CONSEGNE_NON_PIANIFICATE" + SYS(2015) + ".XLS"

WAIT WINDOW "ATTENDERE PREGO: creazione excel in corso..." NOWAIT

SELECT CU_CONSEGNE_BFO
GO TOP
COPY TO &_NOME_REPORT TYPE XL5

_FILE_DA_ALLEGARE = JUSTFNAME(_NOME_REPORT)

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 

_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
