*    INIZIO PROGRAMMA CREAZIONE FATTURE DA BOLLE : N. BOLLE UNA FATTURA         *
*********************************************************************************

RIT = MESSAGEBOX("Procedo con la creazione "+CHR(13)+"delle fatture",292,"ATTENZIONE")
IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF

PUBLIC YES,CONTA_FAT,OK_PRELEVA,X_NUMORD,XXX_NUMORD,XXX_SEQUEN 
YES        = 0
CONTA_FAT  = 0
XXX_NUMORD = ""
XXX_SEQUEN = 0

PUBLIC IVA_ESE,IVA_CLI,V_CLIES,V_DTCLES,V_NSES,V_DTNSES

DEFINE WINDOW WSELESOC;
AT 0,0 SIZE 20,100;
SYSTEM CLOSE NOGROW FLOAT;
FONT 'Courier New',8
MOVE WINDOW WSELESOC CENTER

IF !ExecCommand("select * from u_fat_tt where 0=1","cu_fat_tt")
   return(.f.)
ENDIF
IF !ExecCommand("select * from u_fat_dd where 0=1","cu_fat_dd")
   return(.f.)
ENDIF

IF !ExecCommand("select * from u_bol_tt where 0=1","u_bol_tt")
   return(.f.)
ENDIF
SELECT U_BOL_TT
HH=AFIELDS(TRAN_BOL)
CREATE CURSOR CBOL_TT FROM ARRAY TRAN_BOL
SELECT CBOL_TT
INDEX ON ORD_CODCLI+ORD_CPA+STR(VAL(ord_numord)) TAG T_NUMERIC ADDITIVE

=_ELABOL("DATA",DATADAL,DATAAL,PUB_ANNO,SPACE(06),"  ",CLIDAL,SPACE(03))

SELECT CBOL_TT
SET ORDER TO T_NUMERIC
GO TOP

IF _SELEFAT

   ON KEY LABEL ENTER DO CHK2
   ON KEY LABEL F DO CHKR
   ON KEY LABEL RIGHTMOUSE DO CHKR

   DEFINE WINDOW WSELESOC;
   AT 0,0 SIZE 20,100;
   SYSTEM CLOSE NOGROW FLOAT;
   FONT 'Courier New',8
   MOVE WINDOW WSELESOC CENTER

   BROWSE FIELDS SELEZIONE:10:H='SELEZIONE',ORD_CODCLI:10:H='CLIENTE', ;
	  ORD_RAGSOC:35:H='RAGIONE SOCIALE',ORD_DATORD:15:H='DATA BOLLA', ;
	  ORD_NUMORD:15:H='NUM.BOLLA' NOMENU NODELETE NOEDIT WINDOW WSELESOC
   RELEASE WINDOWS WSELESOC
   PUSH KEY CLEAR

ENDIF

******* PER GESTIRE I LEGAMI TRA I DOCUMENTI
CREATE CURSOR BOLLE_CUR (CUR_NUMORD C(06), CUR_DATORD C(10), CUR_CODCLI C(10), CUR_RAGSOC C(10))
INDEX ON CUR_NUMORD + CUR_DATORD TAG I_BOLLE ADDITIVE  
******* PER GESTIRE I LEGAMI TRA I DOCUMENTI

OK_PRELEVA  = .T.
M.T_IMPONIB = 0
M.T_IMPOSTA = 0
MATPUBX     = 0
V_SPESE     = 0
SOLO_ORA	= .T.

SELECT CBOL_TT
SET ORDER TO T_NUMERIC
GO TOP

CLINEW = ORD_CODCLI
CPANEW = ORD_CPA

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF _SELEFAT
	  IF SELEZIONE <> '=>'
	     SKIP +1
	     LOOP
	  ENDIF
   ENDIF	

   IF _SOLOEXP 					&& TRATTA SOLO EXPORT
      IF ORD_ITAEXP <> "S"
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   IF SOLO_ORA
	  CLINEW   = ORD_CODCLI
	  CPANEW   = ORD_CPA
	  SOLO_ORA = .F.
   ENDIF	

   * SE ROTTURA CLIENTE CREO LA TESTATA FATTURE SU SCATTER MEMVAR VECCHIA

   KATT = ORD_CODCLI+ORD_CPA
   KPRE = CLINEW+CPANEW

   IF KATT <> KPRE
      DO NFATTU

      ******* PER GESTIRE I LEGAMI TRA I DOCUMENTI
      RELEASE _TABLE,_CAUS,_DOCRE,_CLOSE,_ORDCR
      PUBLIC  _TABLE,_CAUS,_DOCRE,_CLOSE,_ORDCR
      _TABLE = "CBOL_TT"
      _CAUS  = "BOLL"
      _DOCRE = "FATT"
      _CLOSE = .F.
      _ORDCR = M.ORD_NUMORD
      SELECT BOLLE_CUR
      GO TOP
      DO WHILE .T.
         IF EOF()
            EXIT
         ENDIF
         RIS_FUN=LEGDFUNZ(_TABLE,_CAUS,SUBSTR(CUR_DATORD,7,4),CUR_CODCLI,CUR_RAGSOC,CUR_NUMORD, ;
                          CUR_DATORD,_DOCRE,_ORDCR,DATAREGI,_CLOSE)
         SELECT BOLLE_CUR
         SKIP +1
      ENDDO
      CREATE CURSOR BOLLE_CUR (CUR_NUMORD C(06), CUR_DATORD C(10), CUR_CODCLI C(10), CUR_RAGSOC C(10))
      INDEX ON CUR_NUMORD + CUR_DATORD TAG I_BOLLE ADDITIVE  
      ******* PER GESTIRE I LEGAMI TRA I DOCUMENTI

      X_SPINC = 0

      =CREA_SPIN("FAT","CU_FAT_DD",M.ORD_VALUTA,M.ORD_CPA)  && CREA ARTICOLO CON SPESE D'INCASSO

   	  PUB_DAGGANCIO = M.TAGGANCIO	&& SERGIO : SERVE PER CANCELLARE IN AUTOMATICO I COMMENTI VECCHI PRIMA DEL NUOVO INSERIMENTO DELLO STESSO COMMENTO , ALTRIMENTI HO DEI COMMENTI DOPPI
      =CREA_NOTE("FAT","CU_FAT_DD")
      PUB_DAGGANCIO = ""			&& SERGIO : SERVE PER CANCELLARE IN AUTOMATICO I COMMENTI VECCHI PRIMA DEL NUOVO INSERIMENTO DELLO STESSO COMMENTO , ALTRIMENTI HO DEI COMMENTI DOPPI


      SELECT CU_FAT_TT
      REPLACE ORD_VALORE WITH ORD_VALORE + X_SPINC && AGGIUNGE SPESE INCASSO
      REPLACE ORD_RIBA   WITH .F.
      REPLACE ORD_PROG   WITH 0
      
      DO ESENOTB         && GESTIONE ESENZIONI
      XXX_SEQUEN = 0
   
   ENDIF

   SELECT CBOL_TT
   
   IF OK_PRELEVA  	  && PRELEVA UNCINO PER LEGARE TESTATA/DETTAGLIO
      OK_PRELEVA  = .F.
	  M.TAGGANCIO = STR(NEWPROG('NUMFAT'),10)
	  X_UNCINO    = M.TAGGANCIO
   ENDIF	

   SELECT CBOL_TT
   
   CLINEW  = ORD_CODCLI
   CPANEW  = ORD_CPA
   OR_DINE = ORD_NUMORD
   DT_ORDI = RIBALTA2(ORD_DATORD)
   UNCINO  = TAGGANCIO

   SCATTER MEMVAR MEMO	
   V_SPESE  = V_SPESE  + M.ORD_SPBOLL + M.ORD_SPTRAS
   V_SPBOLL = V_SPBOLL + M.ORD_SPBOLL
   V_SPTRAS = V_SPTRAS + M.ORD_SPTRAS

   * PRELEVA IL N.DI FATTURA DA ASSEGNARE ALLE RIGHE
   IF PUB_NFATDIFFERITA
	   v_seek   = ACCESS_YEAR('NUMFAD'+PUB_CODSOC)		&& FATTURE CONTABILIZZATE SUL BOLLATO IVA FATTURE IN DIFFERITA
   ELSE
	   v_seek   = ACCESS_YEAR('NUMFAT'+PUB_CODSOC)		&& FATTURE CONTABILIZZATE SUL BOLLAO IVA NORMALE
   ENDIF


   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      V2=VAL(SUBSTR(LIBERA,1,7)) + 1
      X_NUMORD = ALLTRIM(SUBSTR(STR(V2,7,0),1,7))
   ELSE
      RIT = MSGBOX('Parametro numero fattura non trovato','ATTENZIONE',31)
      RETURN
   ENDIF

   PUB_LNO  = 6
   X_NUMORD = TRC(PUB_LNO,ALLTRIM(X_NUMORD))
   
   x_cond = "daggancio = '" + ALLTRIM(UNCINO) + "'"
   Csql   = "select * from u_bol_dd where " + x_cond + " order by daggancio,ord_sequen"
   IF !ExecCommand(cSql,"CU_BOL_DD")
      return(.f.)
   ENDIF
   SELECT CU_BOL_DD
   GO TOP
   IF !EOF()
      DO WHILE .T.
         IF EOF()
            EXIT
         ENDIF
         IF DELETED()
            SKIP +1
            LOOP
         ENDIF
         IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"   && VERIFICA SE DEVE GESTIRE IL COMMENTO
            IF EMPTY(ALLTRIM(ORD_CODICE))
            ELSE
          	   IF !GEST_NOTE("FAT",ORD_CODICE)
                  SELECT CU_BOL_DD
                  SKIP +1  
                  LOOP
               ENDIF
            ENDIF          	 
         ENDIF
         * SI CREA LE VARIABILI DAL RECORD
	     SCATTER MEMVAR MEMO
	     * AGGIORNA UNCINO
	     M.DAGGANCIO = X_UNCINO
	     * AGGIORNA I DETTAGLI
	     SELECT CU_FAT_DD
	     APPEND BLANK
	     GATHER MEMVAR MEMO
	     REPLACE ORD_QTAEV  WITH 0
	     REPLACE ORD_QTADEV WITH 0
	     REPLACE ORD_FLARTC WITH 0
	     REPLACE ORD_CHIUSO WITH .F.
	     REPLACE ORD_FDITRA WITH SPACE(1)	     
	     REPLACE SELEZIONE  WITH SPACE(10)
	     REPLACE ORD_TRASME WITH .F.     
	     REPLACE ORS_VALUTA WITH M.ORD_VALUTA
	     REPLACE ORD_TRASMD WITH .F.		     
	     REPLACE ORS_NUMORC WITH SPACE(06)
	     REPLACE ORS_DATORC WITH SPACE(10)
	     REPLACE ORS_CODCLI WITH M.ORD_CODCLI
	     REPLACE ORS_RAGSOC WITH M.ORD_RAGSOC
	     REPLACE ORS_NUMORD WITH X_NUMORD
	     REPLACE ORS_DATORD WITH RIBALTA2(DATAREGI)
	     REPLACE ORS_CODEMI WITH PUB_CLISOC
	     REPLACE ORS_RAGEMI WITH PUB_RAGSOC
         REPLACE ORD_CODSYS WITH SYS(2015)
	     REPLACE ORS_NUMDDT WITH OR_DINE
	     REPLACE ORS_DATDDT WITH RIBALTA2(DT_ORDI)
	     XXX_SEQUEN = XXX_SEQUEN + 10
	     REPLACE ORD_SEQUEN WITH XXX_SEQUEN
	     CIVA = ORD_IVA
         v_seek	= 'IVA' + CIVA
         v_chiave = "codice"
         IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
            SELECT CUR_PARA
            VIVA = VAL(SUBSTR(LIBERA,1,3))
         ELSE
     	    VIVA = 0
         ENDIF
	     SELECT CU_FAT_DD
	     IF ORD_PUBBLI = "S"
	        MATPUBX = MATPUBX + ORD_VALORE
	     ENDIF
	     M.T_IMPONIB = M.T_IMPONIB + ORD_VALORE
	     M.T_IMPOSTA = M.T_IMPOSTA + (ORD_VALORE * (VIVA/100))
         SELECT CU_BOL_DD
         SKIP +1
      ENDDO
      DO COMMENTO   && INSERISCE RIFERIMENTO A DOCUMENTO DI TRASPORTO
   ELSE
      PUB_ERRORE=MESSAGEBOX('Dettagli inesistenti ordine : '+ OR_DINE,64,'*** ATTENZIONE ***')
   ENDIF

   SELECT CBOL_TT
   M.ORD_CODSYS = ORD_CODSYS
 
   v_seek   = M.ORD_CODSYS
   v_chiave = "ord_codsys"
   cSql     = "select * from u_bol_tt where " + v_chiave + " = '" + v_seek + "'"
   IF !ExecRW(cSql,"U_BOL_TT","R")
      return(.f.)
   ENDIF
   SELECT U_BOL_TT
   IF RECCOUNT() <> 0 
	  REPLACE ORD_FLBOL  WITH  "S"        					 && AGGIORNA LA TESTATA DELLA BOLLA (FLAG ELABORATO)
	  REPLACE ORD_DATFAT WITH  RIBALTA2(DATAREGI)	         && AGGIORNA LA TESTATA DELLA BOLLA (DATA FATTURAZIONE)
   ENDIF

   IF !ExecRW(cSql,"U_BOL_TT","W")
      return(.f.)
   ENDIF

   ******* PER GESTIRE I LEGAMI TRA I DOCUMENTI
   SELECT CBOL_TT
   M.CUR_NUMORD = ORD_NUMORD
   M.CUR_DATORD = ORD_DATORD
   M.CUR_CODCLI = ORD_CODCLI
   M.CUR_RAGSOC = ORD_RAGSOC
   SELECT BOLLE_CUR
   SET ORDER TO I_BOLLE
   SEEK M.CUR_NUMORD + M.CUR_DATORD
   IF FOUND()
   ELSE
      APPEND BLANK
      GATHER MEMVAR MEMO
   ENDIF
   ******* PER GESTIRE I LEGAMI TRA I DOCUMENTI

   YES = 1
   
   SELECT CBOL_TT
   SKIP +1

ENDDO

IF YES = 1

   DO NFATTU

   ******* PER GESTIRE I LEGAMI TRA I DOCUMENTI
   RELEASE _TABLE,_CAUS,_DOCRE,_CLOSE,_ORDCR
   PUBLIC  _TABLE,_CAUS,_DOCRE,_CLOSE,_ORDCR
   _TABLE = "CBOL_TT"
   _CAUS  = "BOLL"
   _DOCRE = "FATT"
   _CLOSE = .F.
   _ORDCR = M.ORD_NUMORD
   SELECT BOLLE_CUR
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      RIS_FUN=LEGDFUNZ(_TABLE,_CAUS,SUBSTR(CUR_DATORD,7,4),CUR_CODCLI,CUR_RAGSOC,CUR_NUMORD, ;
                       CUR_DATORD,_DOCRE,_ORDCR,DATAREGI,_CLOSE)
      SELECT BOLLE_CUR
      SKIP +1
   ENDDO
   CREATE CURSOR BOLLE_CUR (CUR_NUMORD C(06), CUR_DATORD C(10), CUR_CODCLI C(10), CUR_RAGSOC C(10))
   INDEX ON CUR_NUMORD + CUR_DATORD TAG I_BOLLE ADDITIVE  
   SELECT  CBOL_TT
   ******* PER GESTIRE I LEGAMI TRA I DOCUMENTI

   X_SPINC = 0
   
   =CREA_SPIN("FAT","CU_FAT_DD",M.ORD_VALUTA,M.ORD_CPA)  && CREA ARTICOLO CON SPESE D'INCASSO

   

   PUB_DAGGANCIO = M.TAGGANCIO	&& SERGIO : SERVE PER CANCELLARE IN AUTOMATICO I COMMENTI VECCHI PRIMA DEL NUOVO INSERIMENTO DELLO STESSO COMMENTO , ALTRIMENTI HO DEI COMMENTI DOPPI
   =CREA_NOTE("FAT","CU_FAT_DD")
   PUB_DAGGANCIO = ""			&& SERGIO : SERVE PER CANCELLARE IN AUTOMATICO I COMMENTI VECCHI PRIMA DEL NUOVO INSERIMENTO DELLO STESSO COMMENTO , ALTRIMENTI HO DEI COMMENTI DOPPI


   SELECT CU_FAT_TT
   REPLACE ORD_VALORE WITH ORD_VALORE + X_SPINC && AGGIUNGE SPESE INCASSO
   REPLACE ORD_RIBA   WITH .F.
   REPLACE ORD_PROG   WITH 0

   DO ESENOTB         && GESTIONE ESENZIONI

   SELECT CBOL_TT
   USE
   PUB_ERRORE=MESSAGEBOX('Totale fatture create :'+STR(CONTA_FAT,5,0)+CHR(13)+'correttamente',64,'*** ATTENZIONE ***')
   DO GESTIONE_POLIECO WITH 'CU_FAT_DD'						&& INSERIMENTO POLIECO IN DETTAGLIO FATTURA
   DO GESTIONE_RIEPILOGO WITH 'INS','FAT',PUB_FATTU,SPACE(10)	&& INSERIMENTO NUOVI RIEPILOGHI SU U_VEN_CL
ELSE
   PUB_ERRORE=MESSAGEBOX('Nessuna fattura '+CHR(13)+'creata',64,'*** ATTENZIONE ***')
ENDIF

