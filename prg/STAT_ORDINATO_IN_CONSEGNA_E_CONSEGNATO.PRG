cSql=""     
cNomeCursorSql="CU_ORDINATO"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 	
		CODICE_STATO,
		STATO,
		CODICE_CLIENTE,
		CLIENTE,
		NUM_ORDINE,
		DATA_ORDINE_RIBALTATA, 
		DATA_ORDINE,
		CENTRO_COSTO,
		DESCRIZIONE_CENTRO_COSTO,
		DATA_CONSEGNA_RIBALTATA,
		DATA_CONSEGNA,
		SUM(VALORE) AS VALORE
	FROM ORDINI_IN_CONSEGNA_CONSEGNATI 
	GROUP BY CODICE_STATO,STATO,CENTRO_COSTO,DESCRIZIONE_CENTRO_COSTO,CODICE_CLIENTE,CLIENTE,NUM_ORDINE,DATA_ORDINE_RIBALTATA,DATA_ORDINE,DATA_CONSEGNA_RIBALTATA,DATA_CONSEGNA
	ORDER BY CODICE_STATO,DESCRIZIONE_CENTRO_COSTO,CLIENTE,NUM_ORDINE

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


SELECT CU_ORDINATO

_V_FILTRI=""

DO PRG\MENUSTA WITH "CU_ORDINATO",.T.,.F.,"XXX","ORDINI_IN_PROSSIMA_CONSEGNA","ORDINI_IN_PROSSIMA_CONSEGNA.FRX",.T.



cSql=""     
cNomeCursorSql="CU_ORDINATO"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 	* 
	FROM ORDINI_IN_CONSEGNA_CONSEGNATI 
	ORDER BY CODICE_STATO,DESCRIZIONE_CENTRO_COSTO,CLIENTE,NUM_ORDINE

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


