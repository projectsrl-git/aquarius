** ASSEGNAZIONE DELLA VARIABILE PATH **************************
V_PATH = ""
=OPENDB("PERCORSO")
SELECT PERCORSO
SET ORDER TO I_TIPO
GO TOP
SEEK "IMP"
IF FOUND()
	V_PATH = ALLTRIM(PER_PATH)
ELSE
	MESSAGEBOX("Percorso 'IMP' non configurato" + CHR(13) + CHR(13) + ;
		"Controllare il file PERCORSO.DBF",16,"Attenzione")
	USE
	RETURN .F.
ENDIF

IF DIRECTORY(V_PATH)
ELSE
	MESSAGEBOX("Percorso '" + ALLTRIM(V_PATH) + "' non trovato!" + CHR(13) + CHR(13) + ;
		"Controllare il file PERCORSO.DBF",16,"Attenzione")
	RETURN .F.
ENDIF

SET DEFAULT TO &V_PATH


RIT = MESSAGEBOX("Conversione anagrafica listini da foglio Excel: " + REPLICATE(CHR(13),2) + ;
		ALLTRIM(V_PATH) + REPLICATE(CHR(13),2) + "Continuare?",4+32+256,"ATTENZIONE")
		
IF RIT = 7
   MESSAGEBOX("Operazione abbandonata",48,"Informazione")
   RETURN
ENDIF



*!*	IF !ExecCommand("select * from U_ART_PR where 1=0","curs_U_ART_PR")
*!*	   return
*!*	ENDIF



CREATE CURSOR curs_U_ART_PR (ART_CODPRI C(30), ;
					   ART_DESCR  C(90),   ART_UMMAGA C(2))



**** CARICAMENTO DEL FILE IN FORMATO EXCEL 5.0 
gcFile = GETFILE('XLS', '', 'Browse', 1, 'Seleziona')
SET DEFAULT TO &PUB_DIR

IF EMPTY(gcFile)
	MESSAGEBOX("Nessun file selezionato",64,"Informazione")
	RETURN
ENDIF


* PROCEDURA PER IDENTIFICARE I LISTINI
_TIPO_LISTINO = ""
_STRINGA=gcFile 
_LUNGHEZZA_DA_CERCARE = 9 

_STRINGA_DA_CERCARE = "1_LISTINO"
POS_STRINGA=CERCA_CHR(_STRINGA,_STRINGA_DA_CERCARE,_LUNGHEZZA_DA_CERCARE)
IF POS_STRINGA > 0
	_TIPO_LISTINO = 'LISTINO_FORNITORE_1'
ENDIF
	
_STRINGA_DA_CERCARE = "2_LISTINO"
POS_STRINGA=CERCA_CHR(_STRINGA,_STRINGA_DA_CERCARE,_LUNGHEZZA_DA_CERCARE)
IF POS_STRINGA > 0
	_TIPO_LISTINO = 'LISTINO_FORNITORE_2'
ENDIF

_STRINGA_DA_CERCARE = "3_LISTINO"
POS_STRINGA=CERCA_CHR(_STRINGA,_STRINGA_DA_CERCARE,_LUNGHEZZA_DA_CERCARE)
IF POS_STRINGA > 0
	_TIPO_LISTINO = 'LISTINO_FORNITORE_3'
ENDIF

_STRINGA_DA_CERCARE = "4_LISTINO"
POS_STRINGA=CERCA_CHR(_STRINGA,_STRINGA_DA_CERCARE,_LUNGHEZZA_DA_CERCARE)
IF POS_STRINGA > 0
	_TIPO_LISTINO = 'LISTINO_FORNITORE_4'
ENDIF

_STRINGA_DA_CERCARE = "5_LISTINO"
POS_STRINGA=CERCA_CHR(_STRINGA,_STRINGA_DA_CERCARE,_LUNGHEZZA_DA_CERCARE)
IF POS_STRINGA > 0
	_TIPO_LISTINO = 'LISTINO_FORNITORE_5'
ENDIF

_STRINGA_DA_CERCARE = "6_LISTINO ARTICOLI"
POS_STRINGA=CERCA_CHR(_STRINGA,_STRINGA_DA_CERCARE,_LUNGHEZZA_DA_CERCARE)
IF POS_STRINGA > 0
	_TIPO_LISTINO = 'LISTINO_ARTICOLI_VENDITA'
ENDIF


*!*	RIT = MESSAGEBOX("Desideri cancellare l'anagrafica articoli esistente ??" + REPLICATE(CHR(13),2) + ;
*!*			 "Continuare?",4+32+256,"ATTENZIONE")
*!*			
*!*	IF RIT <> 7
*!*		WAIT WINDOWS "Cancellazione vecchia anagrafica articoli in corso..." NOWAIT

*!*		cSql = "DELETE FROM U_ART_PR"
*!*		IF !ExecCommand(cSql,"DEL_ART_PR")
*!*		   return
*!*		ENDIF

*!*		cSql = "DELETE FROM U_ART_AN"
*!*		IF !ExecCommand(cSql,"DEL_ART_AN")
*!*		   return
*!*		ENDIF
*!*	ENDIF 


CT_INESISTENTI = 0

WAIT WINDOWS "Conversione anagrafica listini in corso: " + _TIPO_LISTINO  NOWAIT		


DO CASE 

	CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_1'

		CREATE CURSOR IMPORTAXLS ( ;
			TCODART	C(30), ;
			TDESART	C(200), ;
			TUNITAM	C(2), ;
			TCODMAG	C(20), ;
			TCODFO1	C(20), ;
			DESCR_FORN1	C(200), ;
			COD_ART_FORN1 C(200), ;	
			COS_FORN1 C(20))	

	CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_2'

		CREATE CURSOR IMPORTAXLS ( ;
			TCODART	C(30), ;
			TDESART	C(200), ;
			TUNITAM	C(2), ;
			TCODMAG	C(20), ;
			TCODFO2	C(20), ;
			DESCR_FORN2	C(200), ;
			COD_ART_FORN2 C(200), ;	
			COS_FORN2 C(20))	


	CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_3'

		CREATE CURSOR IMPORTAXLS ( ;
			TCODART	C(30), ;
			TDESART	C(200), ;
			TUNITAM	C(2), ;
			TCODMAG	C(20), ;
			TCODFO3	C(20), ;
			DESCR_FORN3	C(200), ;
			COD_ART_FORN3 C(200), ;	
			COS_FORN3 C(20))	

	CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_4'

		CREATE CURSOR IMPORTAXLS ( ;
			TCODART	C(30), ;
			TDESART	C(200), ;
			TUNITAM	C(2), ;
			TCODMAG	C(20), ;
			TCODFO4	C(20), ;
			DESCR_FORN4	C(200), ;
			COD_ART_FORN4 C(200), ;	
			COS_FORN4 C(20))	

	CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_5'

		CREATE CURSOR IMPORTAXLS ( ;
			TCODART	C(30), ;
			TDESART	C(200), ;
			TUNITAM	C(2), ;
			TCODMAG	C(20), ;
			TCODFO5	C(20), ;
			DESCR_FORN5	C(200), ;
			COD_ART_FORN5 C(200), ;	
			COS_FORN5 C(20))	


	CASE _TIPO_LISTINO = 'LISTINO_ARTICOLI_VENDITA'

		CREATE CURSOR IMPORTAXLS ( ;
			TCODART	C(30), ;
			TPRZVEN C(20), ;			
			COS_STD C(20))	

ENDCASE 

SELECT IMPORTAXLS 
APPEND FROM (gcFile) TYPE XLS


_TOT_COUNT = 0

SELECT IMPORTAXLS
GO TOP 
SCAN   

    IF ALLTRIM(TCODART) = "TCODART"  && SCARTO PRIMO RECORD (INTESTAZIONI DI COLONNA)
		LOOP
    ENDIF 


    IF EMPTY(TCODART)   && SCARTO PRIMO RECORD (INTESTAZIONI DI COLONNA)
		LOOP
    ENDIF 
    
    
    SCATTER MEMVAR MEMO
    
	WAIT WINDOWS "Conversione Articolo " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + ;
		" (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 




	x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
	x_codi = "art_codpri = '" + ALLTRIM(M.TCODART) + "'"
	x_cond = x_soci + " and " + x_codi
	cSql = "select * from U_ART_PR where " + x_cond + " order by art_codsoc,art_codpri"
	IF !ExecCommand(cSql,"VERIFICA_ART_PR")
	   RETURN .F.
	ENDIF
	SELECT VERIFICA_ART_PR
	GO TOP 
	IF EOF() 


			    CT_INESISTENTI = CT_INESISTENTI +1
			    

			   	SELECT curs_U_ART_PR				&& SALVATAGGIO PER ELENCO CLIENTI INESISTENTI DA VERIFICARE
				APPEND BLANK
				REPLACE ART_CODPRI WITH ALLTRIM(M.TCODART)
				REPLACE ART_DESCR  WITH ALLTRIM(M.TDESART)	
				REPLACE ART_UMMAGA WITH ALLTRIM(M.TUNITAM)	

			
				cSql = "SELECT * FROM U_ART_PR WHERE 1=0"
				IF !ExecRW(cSql,"U_ART_PR","R")
				   RETURN .F.
				ENDIF
				SELECT U_ART_PR
				APPEND BLANK
				

				DO aggiorna_campi_anagrafici

				
				IF !ExecRW(cSql,"U_ART_PR","W")
				   RETURN .F.
				ENDIF
								
				cSql = "SELECT * FROM U_ART_AN WHERE 1=0"
				IF !ExecRW(cSql,"U_ART_AN","R")
				   RETURN .F.
				ENDIF
				SELECT U_ART_AN
				APPEND BLANK
				REPLACE ART_CODSOC WITH PUB_CODSOC
				REPLACE ART_CODPRI WITH ALLTRIM(M.TCODART)	
				
				IF !ExecRW(cSql,"U_ART_AN","W")
				   RETURN .F.
				ENDIF

				
				
								
	ELSE 
	

			x_soci  = "ART_CODSOC = '" + PUB_CODSOC + "'"
			x_arti  = "ART_CODPRI = '" + M.TCODART + "'"
			x_cond  = x_soci + " and " + x_arti
			cSql    = "select * from U_ART_PR where " + x_cond + " order by art_codpri"
			IF !ExecRW(cSql,"u_art_pr","R")
			   return(.f.)
			ENDIF

			DO aggiorna_campi_anagrafici

			IF !ExecRW(cSql,"u_art_pr","W")
			   return(.f.)
			ENDIF

	
	ENDIF 




					   
   	_TOT_COUNT = _TOT_COUNT + 1



ENDSCAN

WAIT CLEAR


SELECT curs_U_ART_PR
GO TOP
COPY TO LIST_INE SDF




MESSAGEBOX("Operazione terminata correttamente" + REPLICATE(CHR(13),2) + ;
	"Totale articoli convertiti: " + ALLTRIM(STR(_TOT_COUNT,10,0))     + ; 
	"Totale articoli inesistenti: " + ALLTRIM(STR(CT_INESISTENTI,10,0)),64,"Informazione")



RETURN

PROCEDURE aggiorna_campi_anagrafici


	DO CASE 

		CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_1'


			REPLACE ART_CODSOC WITH PUB_CODSOC 
			REPLACE ART_CODPRI WITH ALLTRIM(M.TCODART)
			REPLACE ART_DESCR  WITH ALLTRIM(M.TDESART)	
			REPLACE ART_UMMAGA WITH ALLTRIM(M.TUNITAM)	
			REPLACE ART_MAGA   WITH ALLTRIM(M.TCODMAG)
			REPLACE ART_CODF1  WITH ALLTRIM(M.TCODFO1)
			REPLACE ART_NOTA1  WITH ALLTRIM(M.COD_ART_FORN1)
			REPLACE ART_PRZCO1 WITH VAL(M.COS_FORN1)	   
			*REPLACE 	DESCR_FORN1	C(200)

		CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_2'

			REPLACE ART_CODSOC WITH PUB_CODSOC 
			REPLACE ART_CODPRI WITH ALLTRIM(M.TCODART)
			REPLACE ART_DESCR  WITH ALLTRIM(M.TDESART)	
			REPLACE ART_UMMAGA WITH ALLTRIM(M.TUNITAM)	
			REPLACE ART_MAGA   WITH ALLTRIM(M.TCODMAG)
			REPLACE ART_CODF2  WITH ALLTRIM(M.TCODFO2)
			REPLACE ART_NOTA2  WITH ALLTRIM(M.COD_ART_FORN2)
			REPLACE ART_PRZCO2 WITH VAL(M.COS_FORN2)	   
			*REPLACE 	DESCR_FORN2	C(200)

		CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_3'

			REPLACE ART_CODSOC WITH PUB_CODSOC 
			REPLACE ART_CODPRI WITH ALLTRIM(M.TCODART)
			REPLACE ART_DESCR  WITH ALLTRIM(M.TDESART)	
			REPLACE ART_UMMAGA WITH ALLTRIM(M.TUNITAM)	
			REPLACE ART_MAGA   WITH ALLTRIM(M.TCODMAG)
			REPLACE ART_CODF3  WITH ALLTRIM(M.TCODFO3)
			REPLACE ART_NOTA3  WITH ALLTRIM(M.COD_ART_FORN3)
			REPLACE ART_PRZCO3 WITH VAL(M.COS_FORN3)	   
			*REPLACE 	DESCR_FORN3	C(200)

		CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_4'

			REPLACE ART_CODSOC WITH PUB_CODSOC 
			REPLACE ART_CODPRI WITH ALLTRIM(M.TCODART)
			REPLACE ART_DESCR  WITH ALLTRIM(M.TDESART)	
			REPLACE ART_UMMAGA WITH ALLTRIM(M.TUNITAM)	
			REPLACE ART_MAGA   WITH ALLTRIM(M.TCODMAG)
			REPLACE ART_CODF4  WITH ALLTRIM(M.TCODFO4)
			REPLACE ART_NOTA4  WITH ALLTRIM(M.COD_ART_FORN4)
			REPLACE ART_PRZCO4 WITH VAL(M.COS_FORN4)	   
			*REPLACE 	DESCR_FORN4	C(200)

		CASE _TIPO_LISTINO = 'LISTINO_FORNITORE_5'


			REPLACE ART_CODSOC WITH PUB_CODSOC 
			REPLACE ART_CODPRI WITH ALLTRIM(M.TCODART)
			REPLACE ART_DESCR  WITH ALLTRIM(M.TDESART)	
			REPLACE ART_UMMAGA WITH ALLTRIM(M.TUNITAM)	
			REPLACE ART_MAGA   WITH ALLTRIM(M.TCODMAG)
			REPLACE ART_CODF5  WITH ALLTRIM(M.TCODFO5)
			REPLACE ART_NOTA5  WITH ALLTRIM(M.COD_ART_FORN5)
			REPLACE ART_PRZCO5 WITH VAL(M.COS_FORN5)	   
			*REPLACE 	DESCR_FORN5	C(200)

		CASE _TIPO_LISTINO = 'LISTINO_ARTICOLI_VENDITA'

			REPLACE ART_CODSOC WITH PUB_CODSOC 
			REPLACE ART_CODPRI WITH ALLTRIM(M.TCODART)
			REPLACE ART_PRZVEN WITH VAL(M.TPRZVEN)	   
			REPLACE ART_PRZCOS WITH VAL(M.COS_STD)	  	


	ENDCASE 


RETURN

 