************************************************************************************************************************************
PROCEDURE BLACKLIST_CARICA_PRIMA_NOTA 
************************************************************************************************************************************
**
** FUNZIONALITA' :
**
**
**
**		TIPO DI ESTRAZIONE DATI CONTABILI :
**
**			_PAR_FATTURE_CLI_FOR = "F" 	MOVIMENTI DI ACQUISTO
**
** 		RESTITUISCE IL CURSORE >>>>>>> BLACKLIST_MOV_CONT 
**
**
LPARAMETERS _PAR_DATA_DAL,_PAR_DATA_AL,_PAR_FATTURE_CLI_FOR

RELEASE _V_DARE,_V_AVERE,_V_DATA_DAL,_V_DATA_AL,_BLACKLIST_MOVIMENTI_CONTABILI_ELABORATI,__NUMERO_PROGR_RIGA_1,_V_VALORE_EURO
RELEASE _V_QTA_IN_UM,_V_PORTO,_V_CLDOG,_V_VALORE_STATISTICO,_FATTURE_BLACKLIST_FORNITORI_,_V_FATTURE_CLI_FOR
RELEASE _V_VALORE_VALUTA,_V_PESO,_V_PROG_RIGA_ACQUISTO_BENI,_V_PROG_RIGA_ACQUISTO_SERVIZI,_V_NDOC,_V_DTDOC,_V_MOD_PAG,_V_MOD_INC,_V_NUM_RECORDS_TOTALI  
RELEASE _V_VALORE_EURO_NUMERICO,_V_UNITA_SUPPLEMENTARI

PUBLIC _V_DARE,_V_AVERE,_V_DATA_DAL,_V_DATA_AL,_BLACKLIST_MOVIMENTI_CONTABILI_ELABORATI,__NUMERO_PROGR_RIGA_1,_V_VALORE_EURO
PUBLIC _V_QTA_IN_UM,_V_PORTO,_V_CLDOG,_V_VALORE_STATISTICO,_FATTURE_BLACKLIST_FORNITORI_,_V_FATTURE_CLI_FOR
PUBLIC _V_VALORE_VALUTA,_V_PESO,_V_PROG_RIGA_ACQUISTO_BENI,_V_PROG_RIGA_ACQUISTO_SERVIZI,_V_NDOC,_V_DTDOC,_V_MOD_PAG,_V_MOD_INC,_V_NUM_RECORDS_TOTALI  
PUBLIC _V_VALORE_EURO_NUMERICO,_V_UNITA_SUPPLEMENTARI


__NUMERO_PROGR_RIGA_1 						= 0 
_V_DATA_DAL									= _PAR_DATA_DAL    
_V_DATA_AL									= _PAR_DATA_AL
_V_FATTURE_CLI_FOR							= _PAR_FATTURE_CLI_FOR
_V_PROG_RIGA_ACQUISTO_BENI					= 0
_V_PROG_RIGA_ACQUISTO_SERVIZI				= 0
_V_NDOC 									= ""
_V_DTDOC									= ""
_V_MOD_PAG									= 0
_V_MOD_INC 									= ""
_V_VALORE_EURO_NUMERICO						= 0
_V_UNITA_SUPPLEMENTARI						= 0
_BLACKLIST_MOVIMENTI_CONTABILI_ELABORATI	= 0


WAIT WINDOW "Elaborazione movimenti contabili di acquisto nei paesi BLACKLIST in corso. Questa operazione potrebbe richiedere qualche secondo..." NOWAIT 

cSql=""     
cNomeCursorSql="BLACKLIST_MOV_CONT_TMP"

** ELABORA SOLO LE CONTROPARTITE IDENTIFICATE DA UN TOP INTRA 			: PARA.INTRA    					= SUBSTR(M.LIBERA,24,1) = 'S'
** ELABORA SOLO LE CONTROPARTITE DELLE FATTURE DEI PAESI MEMBRI CEE 	: PARA.FATTURE  					= SUBSTR(M.LIBERA,2,1)  = 'S'
** ELABORA SOLO LE CONTROPARTITE DEI PAESI MEMBRI CEE 					: MOV_STATO_CEE 					= 'CEE'
** ELABORA SOLO LE CONTROPARTITE IDENTIFICATE CON						: CON_TIPOCO    					= 'X'
** ESCLUDE I MOVIMENTI DI CONTABILITA' PREVISIONALE 					: MOV_CONTABILITA_PREVISIONALE 		<> 'P'
** ESCLUDE I MOVIMENTI DI CHIUSURA										: MOV_TOP 							<> 'CHI'


TEXT TO cSql NOSHOW


	SELECT 
		FORN.FOR_CODCLI AS MOV_CODFOR,
		FORN.FOR_RAGSOC AS FOR_RAGSOC,
		FORN.FOR_ESTNAZ AS FOR_NAZIONE_COD_UNICO,
		FORN.FOR_INDIR  AS FOR_INDIRIZZO_ESTERO,
		FORN.FOR_LOCALI AS FOR_LOCALITA_ESTERA,
		FORN.FOR_CODFIS AS FOR_CODICE_FISCALE,
		FORN.FOR_IVACEE AS FOR_PIVA_ESTERA,
		MOV_CONT.id_unique,			
		MOV_RAGSOC,
		MOV_NAZIONE_COD_UNICO,
		MOV_INDIRIZZO_ESTERO,
		MOV_LOCALITA_ESTERA,
		MOV_CODICE_FISCALE,
		MOV_PIVA_ESTERA,
		MOV_IMP_BLACKLIST,
		MOV_SOC,
		MOV_ANNO,
		MOV_CONTO,
		CONTI.CON_TIPOCO,
		CONTI.CON_DESCR,
		MOV_NREGIS, 
		MOV_DTREG,
		MOV_NDOC, 
		MOV_DTDOC,
	    MOV_TOP,
		SUBSTRING(PARA1.LIBERA,12,1) AS TOP_CLI_FOR,
		MOV_IMP,
		MOV_TMOV,
		MOV_VALUTA,
		MOV_CAMBIO,
		MOV_IVA,
		MOV_MODPAG,
		SUBSTRING(PARA3.LIBERA,1,100) AS CPA_MOD_PAG,
		MOV_NUMPRO,	
		MOV_CONTABILITA_PREVISIONALE,
		MOV_BLACKLIST_ok_ko
	FROM MOV_CONT 
	LEFT OUTER JOIN U_FOR_AN AS FORN
	ON MOV_CONTO=(SELECT RTRIM(LTRIM(SUBSTRING( LIBERA, CHARINDEX ( 'GRUPPO CLI' ,LIBERA )+LEN('GRUPPO CLI'),CHARINDEX ( 'GRUPPO FOR' ,LIBERA )-(CHARINDEX ( 'GRUPPO CLI' ,LIBERA )+LEN('GRUPPO CLI'))))) AS GRUPPO_FOR  FROM PARA WHERE CODICE ='GENEX')+FORN.FOR_CODCLI
	LEFT OUTER JOIN PARA AS PARA1
	ON 'TOP'+MOV_CONT.MOV_TOP = PARA1.CODICE
	LEFT OUTER JOIN PARA AS PARA2
	ON 'IVA'+MOV_CONT.MOV_IVA = PARA2.CODICE
	LEFT OUTER JOIN PARA AS PARA3
	ON 'CPA'+MOV_CONT.MOV_MODPAG = PARA3.CODICE
	LEFT OUTER JOIN CONTI AS CONTI
	ON MOV_CONTO=CONTI.CON_CONTO 
	WHERE MOV_SOC='<<PUB_CODSOC>>'
	AND MOV_DTREG BETWEEN '<<_V_DATA_DAL>>' AND '<<_V_DATA_AL>>'
	AND MOV_TOP <> 'CHI' 
	AND MOV_CONTABILITA_PREVISIONALE<>'P'
	AND SUBSTRING(PARA1.LIBERA,12,1)='<<_V_FATTURE_CLI_FOR>>'
	AND SUBSTRING(PARA1.LIBERA,2,1)='S'
	AND CONTI.CON_TIPOCO='F'
	AND CONTI.CON_ANNO=MOV_ANNO
	AND MOV_CONTO LIKE (SELECT RTRIM(LTRIM(SUBSTRING( LIBERA, CHARINDEX ( 'GRUPPO CLI' ,LIBERA )+LEN('GRUPPO CLI'),CHARINDEX ( 'GRUPPO FOR' ,LIBERA )-(CHARINDEX ( 'GRUPPO CLI' ,LIBERA )+LEN('GRUPPO CLI'))))) AS GRUPPO_FOR  FROM PARA WHERE CODICE ='GENEX')+'%'
	AND FORN.FOR_ESTNAZ IN (SELECT CODICE FROM NAZIONI_UNICO WHERE  BLACK='X') 
	ORDER BY MOV_CONTO,MOV_DTREG

ENDTEXT



IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF	




SELECT BLACKLIST_MOV_CONT_TMP
GO TOP
IF EOF()
   _BLACKLIST_MOVIMENTI_CONTABILI_ELABORATI =0
ENDIF


RETURN



