**********************************************************
PROCEDURE GESTIONE_CLICK_SU_ROTOLO
**********************************************************

LPARAMETERS _OBJ

LOCAL _SEZIONE,_ALTEZZA,_LUNGHEZZA

_OBJ.FILLSTYLE=4

IF !EMPTY(PUB_ROTOLO)
	_COMANDO="_OBJ.PARENT."+ALLTRIM(PUB_ROTOLO)+".FILLSTYLE=0"
	&_COMANDO
ENDIF
	
PUB_ROTOLO=_OBJ.ID_ROTOLO

SELECT TAPPETO
SET ORDER TO ID_ROTOLO
SEEK PUB_ROTOLO
PUB_NUMORD=NUMORD
PUB_CODCLI=CODCLI
PUB_RAGSOC=RAGSOC
PUB_DATORD=DATORD
_SEZIONE=SEZIONE

IF PUB_FLAG_SELEZIONA_PER_RIBOBINATURA
	PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_NUMERO_DI_CLICK=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_NUMERO_DI_CLICK+1
	
	IF PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_NUMERO_DI_CLICK=1
		PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE=_SEZIONE
	ENDIF

	IF PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_NUMERO_DI_CLICK=2
		DO PUSH_TAPPETO
	
		PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE=_SEZIONE
		PUB_FLAG_SELEZIONA_PER_RIBOBINATURA=.F.
		PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_NUMERO_DI_CLICK=0
		
		SELECT SEZIONI
		
		REPLACE PATTERN WITH ALLTRIM(PATTERN)+"#" FOR SEZIONE < PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE
		
		SELECT SEZIONI
		SET ORDER TO SEZIONE
		SEEK PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE
		_ALTEZZA=ALTEZ
		_LUNGHEZZA=0
		
		DO WHILE !EOF()
			IF SEZIONE>PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE
				EXIT
			ENDIF
			
			_SEZIONE=SEZIONE
			_LUNGHEZZA=_LUNGHEZZA+LUNGH
			_LUNGHEZZA_ORIGINALE=LUNGH
			_ALTEZZA_ORIGINALE=ALTEZ
			
			SELECT BARRERIB
			APPEND BLANK
			REPLACE SEZIRIB WITH PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE
			REPLACE SEZIONE WITH _SEZIONE
			REPLACE LUNGH WITH _LUNGHEZZA_ORIGINALE
			REPLACE ALTEZ WITH _ALTEZZA_ORIGINALE
			
			SELECT SEZIONI
			SKIP
		ENDDO		
		
		SELECT BARRERIB
		REPLACE LUNRIBO WITH _LUNGHEZZA,;
				ALTRIBO WITH _ALTEZZA  ;
				FOR SEZIRIB =PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE

		_CURNAME=SYS(2015)
		SELECT * FROM SEZIONI WHERE SEZIONE>=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE AND SEZIONE<=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE INTO CURSOR &_CURNAME
		SELECT &_CURNAME
		GO TOP
		DO WHILE !EOF()
		
			SCATTER MEMVAR
			
			SELECT SAVEBARRIB
			APPEND BLANK
			GATHER MEMVAR
			
			SELECT &_CURNAME
			SKIP
		ENDDO	
		SELECT &_CURNAME
		USE	
						
		
		SELECT SEZIONI
		REPLACE FLGVIEW WITH .F.,;
		        ALTEZ WITH _ALTEZZA ,;
				LUNGH WITH _LUNGHEZZA ,;
				PATTERN WITH "BOB"+ALLTRIM(STR(BOBINA))+"_RIBOBINATURA_"+ALLTRIM(STR(ALTEZ)) ;
				FOR SEZIONE>=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE AND SEZIONE<=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE
		
		_CURNAME=SYS(2015)
		SELECT * FROM TAPPETO WHERE SEZIONE>=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE AND SEZIONE<=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE INTO CURSOR &_CURNAME
		SELECT &_CURNAME
		GO TOP
		DO WHILE !EOF()
		
			SCATTER MEMVAR
			
			SELECT TAPRIBOB
			APPEND BLANK
			GATHER MEMVAR
			
			SELECT &_CURNAME
			SKIP
		ENDDO
		
		SELECT &_CURNAME
		USE

		
		SELECT TAPPETO
		REPLACE ID_ROTOLO WITH '' ,;
		        ALTEZ WITH 0 ,;
				LUNGH WITH _LUNGHEZZA ,;
				NUMORD WITH "RIBOB" ;
				FOR SEZIONE>=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE AND SEZIONE<=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE
		
		
		SET ORDER TO SEZIONE
		SEEK PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE
		REPLACE ALTEZ WITH _ALTEZZA
		
		SELECT SEZIONI
		REPLACE RIBOBI WITH .T. FOR SEZIONE>PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE AND SEZIONE<=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE 
		
			
		DO RAGGRUPPA_BARRE_CON_LO_STESSO_PATTERN
		
		IF FLAG_VISUALIZZAZIONE_RAGGRUPPATA=0
			DO VISUALIZZAZIONE_STANDARD
		ENDIF
		
		DO PAGINAZIONE_TAPPETO
		
		DO REFRESH_ROTOLI WITH _OBJ.PARENT
				
			
		PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE=0
		PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE  =0
		
	
	ENDIF
	
	RETURN .F.
ELSE

	RETURN .T.	
	
ENDIF

* FINE PROCEDURE GESTIONE_CLICK_SU_ROTOLO
**********************************************************



**********************************************************
PROCEDURE RIBOBINA
**********************************************************
LPARAMETERS _OFORM

	SELECT TAPRIBOB
	SET ORDER TO SEZIONE
	GO TOP
	PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE=SEZIONE
	
	GO BOTTOM
	PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE=SEZIONE
	
	GO TOP
	DO WHILE !EOF()
	
		SCATTER MEMVAR
		
		SELECT TAPPETO
		APPEND BLANK
		GATHER MEMVAR
		
		SELECT TAPRIBOB
		SKIP
	ENDDO
		
	SELECT TAPPETO
	DELETE FOR ALLTRIM(NUMORD) = "RIBOB"
	
		
	SELECT SAVEBARRIB
	GO TOP
	DO WHILE !EOF()
	
		SCATTER MEMVAR
		
		SELECT SEZIONI
		APPEND BLANK
		GATHER MEMVAR
		
		SELECT SAVEBARRIB
		SKIP
	ENDDO	

	SELECT SEZIONI
	DELETE FOR "_RIBOBINATURA_" $ PATTERN
	
	
		SELECT SEZIONI
		SET ORDER TO SEZIONE
		SEEK PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE
		_ALTEZZA=ALTEZ
		_LUNGHEZZA=0
		
		SELECT SEZIONI
		DO WHILE !EOF()
			IF SEZIONE>PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE
				EXIT
			ENDIF
			
			_SEZIONE=SEZIONE
			_LUNGHEZZA=_LUNGHEZZA+LUNGH
			_LUNGHEZZA_ORIGINALE=LUNGH
			_ALTEZZA_ORIGINALE=ALTEZ
			
			SELECT SEZIONI
			SKIP
		ENDDO		
		
		SELECT SEZIONI
		REPLACE FLGVIEW WITH .F.,;
				ALTEZ WITH _ALTEZZA ,;
				LUNGH WITH _LUNGHEZZA ,;
				PATTERN WITH "BOB"+ALLTRIM(STR(BOBINA))+"_RIBOBINATURA_"+ALLTRIM(STR(ALTEZ)) ;
				FOR SEZIONE>=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE AND SEZIONE<=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE
		
		SELECT TAPPETO
		REPLACE ID_ROTOLO WITH '' ,;
				ALTEZ WITH 0 ,;
				LUNGH WITH _LUNGHEZZA ,;
				NUMORD WITH "RIBOB" ;
				FOR SEZIONE>=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE AND SEZIONE<=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE
		
		SET ORDER TO SEZIONE
		SEEK PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE
		REPLACE ALTEZ WITH _ALTEZZA
		
		SELECT SEZIONI
		REPLACE RIBOBI WITH .T. FOR SEZIONE>PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE AND SEZIONE<=PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE 

		
		DO RAGGRUPPA_BARRE_CON_LO_STESSO_PATTERN
		
		IF FLAG_VISUALIZZAZIONE_RAGGRUPPATA=0
			DO VISUALIZZAZIONE_STANDARD
		ENDIF
		
		DO PAGINAZIONE_TAPPETO
		
		DO REFRESH_ROTOLI WITH _OFORM
				
			
		PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_INIZIALE=0
		PUB_FLAG_SELEZIONA_PER_RIBOBINATURA_SEZIONE_FINALE  =0
		
* FINE PROCEDURE RIBOBINA
**********************************************************

