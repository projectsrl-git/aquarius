PUBLIC Y_CAMPO,V_CAMPO,_CTR
Y_CAMPO = ""
V_CAMPO = ""
_CTR    = 0

CREATE CURSOR TRANSITO (TRA_RECORD C(250))

SELECT TRANSITO
APPEND FROM &V_PATH SDF

*SELECT TRANSITO  
*gcTable = GETFILE('', 'Seleziona file anagrafica collaboratori da convertire', 'Converti',0)
*IF empty(gcTable) .or. gcTable = ""
*   =MESSAGEBOX("Nessun file selezionato, operazione abbandonata",62,"ATTENZIONE")
*   RETURN
*ENDIF
*SELECT TRANSITO
*APPEND FROM &gcTable SDF

SELECT TRANSITO
GO TOP

DELETE FOR SUBSTR(TRA_RECORD,2,7) = "Azienda"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,3,30) = SPACE(30)  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,21,2) = "Da"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,21,9) = "Associati"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,10) = "Assoc Nome"  ALL
GO TOP

V_CONTA = 0

SELECT TRANSITO
GO TOP

M.PER_CODSOC = PUB_CODSOC

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF SUBSTR(TRA_RECORD,6,1) = ' '
   ELSE
      M.PER_CODPDV = SUBSTR(TRA_RECORD,1,3)
      PUB_LNO      = 3
      M.PER_CODPDV = TRC(PUB_LNO,ALLTRIM(M.PER_CODPDV))
      M.PER_DESPDV = ALLTRIM(SUBSTR(TRA_RECORD,5,30))
      M.PER_DESPDV = UPPER(M.PER_DESPDV)
      M.PER_DESPDV = APITOSPA(M.PER_DESPDV)
      SKIP +1
      LOOP
   ENDIF
   
   M.PER_CODICE = ALLTRIM(M.PER_CODPDV) + ALLTRIM(SUBSTR(TRA_RECORD,1,5))

   M.PER_RAGSOC = ALLTRIM(SUBSTR(TRA_RECORD,7,30))
   M.PER_RAGSOC = UPPER(M.PER_RAGSOC)
   M.PER_RAGSOC = APITOSPA(M.PER_RAGSOC)

   M.PER_CONTO  = '220200' + ALLTRIM(SUBSTR(TRA_RECORD,47,2)) + ALLTRIM(SUBSTR(TRA_RECORD,50,5))

   M.PER_DATCON = SUBSTR(TRA_RECORD,97,8)
   IF SUBSTR(M.PER_DATCON,1,1) = ' '
      M.PER_DATCON = '0' + SUBSTR(M.PER_DATCON,2,7)
   ENDIF
   IF SUBSTR(M.PER_DATCON,4,1) = ' '
      M.PER_DATCON = SUBSTR(M.PER_DATCON,1,3) + '0' + SUBSTR(M.PER_DATCON,5,4)
   ENDIF
   IF VAL(SUBSTR(M.PER_DATCON,7,2)) > 50
      M.PER_DATCON = SUBSTR(M.PER_DATCON,1,6) + '19' + SUBSTR(M.PER_DATCON,7,2)
   ELSE
      M.PER_DATCON = SUBSTR(M.PER_DATCON,1,6) + '20' + SUBSTR(M.PER_DATCON,7,2)
   ENDIF

   M.PER_DATINI = SUBSTR(TRA_RECORD,106,8)
   IF SUBSTR(M.PER_DATINI,1,1) = ' '
      M.PER_DATINI = '0' + SUBSTR(M.PER_DATINI,2,7)
   ENDIF
   IF SUBSTR(M.PER_DATINI,4,1) = ' '
      M.PER_DATINI = SUBSTR(M.PER_DATINI,1,3) + '0' + SUBSTR(M.PER_DATINI,5,4)
   ENDIF
   IF VAL(SUBSTR(M.PER_DATINI,7,2)) > 50
      M.PER_DATINI = SUBSTR(M.PER_DATINI,1,6) + '19' + SUBSTR(M.PER_DATINI,7,2)
   ELSE
      M.PER_DATINI = SUBSTR(M.PER_DATINI,1,6) + '20' + SUBSTR(M.PER_DATINI,7,2)
   ENDIF

   M.PER_DATFIN = SUBSTR(TRA_RECORD,115,8)
   IF M.PER_DATFIN = SPACE(08)
   ELSE
      IF SUBSTR(M.PER_DATFIN,1,1) = ' '
         M.PER_DATFIN = '0' + SUBSTR(M.PER_DATFIN,2,7)
      ENDIF
      IF SUBSTR(M.PER_DATFIN,4,1) = ' '
         M.PER_DATFIN = SUBSTR(M.PER_DATFIN,1,3) + '0' + SUBSTR(M.PER_DATFIN,5,4)
      ENDIF
      IF VAL(SUBSTR(M.PER_DATFIN,7,2)) > 50
         M.PER_DATFIN = SUBSTR(M.PER_DATFIN,1,6) + '19' + SUBSTR(M.PER_DATFIN,7,2) 
      ELSE
         M.PER_DATFIN = SUBSTR(M.PER_DATFIN,1,6) + '20' + SUBSTR(M.PER_DATFIN,7,2)
      ENDIF
   ENDIF

   DO GESTIONE_ANA

   SELECT TRANSITO      
   SKIP +1

ENDDO

cSql = "select * from u_cnt_an where cnt_tipo = 'CO1'"
IF !ExecRW(cSql,"U_CNT_AN","R")
   return(.f.)
ENDIF
SELECT U_CNT_AN
REPLACE CNT_DATFIN WITH RIBALTA2(DTOC(DATE()))
REPLACE CNT_ORAFIN WITH TIME()
REPLACE CNT_NUMREC WITH V_CONTA
IF !ExecRW(cSql,"U_CNT_AN","W")
   return(.f.)
ENDIF

=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

RETURN


**********************
PROCEDURE GESTIONE_ANA
**********************

x_soci = "per_codsoc = '" + ALLTRIM(M.PER_CODSOC) + "'"
x_codi = "per_codice = '" + ALLTRIM(M.PER_CODICE) + "'"
x_cond = x_soci + " and " + x_codi
cSql   = "select * from u_per_an where " + x_cond + " order by per_codsoc,per_codice"
IF !ExecRW(cSql,"u_per_an","R")
   return
ENDIF
SELECT u_per_an
IF EOF()
   m.id_unique = ""
   APPEND BLANK
ENDIF
REPLACE PER_CODSOC WITH M.PER_CODSOC
REPLACE PER_CODICE WITH M.PER_CODICE
REPLACE PER_RAGSOC WITH M.PER_RAGSOC
REPLACE PER_INDIRI WITH SPACE(100)
REPLACE PER_LOCALI WITH SPACE(100)
REPLACE PER_CAP    WITH SPACE(5)
REPLACE PER_PROVIN WITH SPACE(2)
REPLACE PER_TEL    WITH SPACE(20)
REPLACE PER_CELL   WITH SPACE(20)
REPLACE PER_FAX    WITH SPACE(20)
REPLACE PER_EMAIL  WITH SPACE(50)
REPLACE PER_TIPCON WITH '002'
REPLACE PER_DESCON WITH 'ASSOCIATO'
REPLACE PER_DATCON WITH RIBALTA2(M.PER_DATCON)
REPLACE PER_ORELAV WITH 0
REPLACE PER_CODFIS WITH SPACE(16)
REPLACE PER_PARIVA WITH SPACE(11)
REPLACE PER_TIPPER WITH SPACE(1)
REPLACE PER_CODPDV WITH M.PER_CODPDV
REPLACE PER_DESPDV WITH M.PER_DESPDV
REPLACE PER_NOTGEN WITH SPACE(10)
REPLACE PER_CODCON WITH SPACE(07)
REPLACE PER_DSCONT WITH SPACE(50)
REPLACE PER_DATINI WITH RIBALTA2(M.PER_DATINI)
IF M.PER_DATFIN = SPACE(10)
   REPLACE PER_DATFIN WITH M.PER_DATFIN
ELSE
   REPLACE PER_DATFIN WITH RIBALTA2(M.PER_DATFIN)
ENDIF
REPLACE PER_CONTO  WITH M.PER_CONTO
REPLACE PER_COMLOR WITH 0
REPLACE PER_RITACC WITH 0
REPLACE PER_PERCON WITH 0
REPLACE PER_NOTCON WITH SPACE(10)
REPLACE PER_PFTCON WITH SPACE(2)

IF !ExecRW(cSql,"u_per_an","W")
   return
ENDIF

V_CONTA = V_CONTA + 1

_CTR = _CTR +1
WAIT WINDOWS "RECORDS SCRITTI : "+STR(_CTR,10,0) NOWAIT

RETURN