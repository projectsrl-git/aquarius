

RIT = MESSAGEBOX("Procedo con l'impianto"+CHR(13)+"del campo FASCIA DI COMPETENZA sull'archivio PARA ??? ",292,"ATTENZIONE")

IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF

cSql = "select * from para where SUBSTRING(CODICE,1,3) = 'TOP'"
IF !ExecCommand(cSql,"CUR_PARA")
   RETURN .F.
ENDIF
SELECT CUR_PARA
GO TOP   

DO WHILE .NOT. EOF()


	LEN_LIBERA = LEN(LIBERA)

    DO CASE
    
    	CASE SUBSTR(LIBERA,1,1) = 'D' 
    		NUOVA_LIBERA = SUBSTR(LIBERA,1,41)+ "C" + SUBSTR(LIBERA,43,LEN_LIBERA)
    
    	CASE SUBSTR(LIBERA,1,1) = 'A' 
    		NUOVA_LIBERA = SUBSTR(LIBERA,1,41)+ "C" + SUBSTR(LIBERA,43,LEN_LIBERA)

    	CASE SUBSTR(LIBERA,1,1) = 'C'     
    		NUOVA_LIBERA = SUBSTR(LIBERA,1,41)+ "M" + SUBSTR(LIBERA,43,LEN_LIBERA)
    
    	CASE SUBSTR(LIBERA,1,1) = 'S'     
    		NUOVA_LIBERA = SUBSTR(LIBERA,1,41)+ "M" + SUBSTR(LIBERA,43,LEN_LIBERA)

    	CASE SUBSTR(LIBERA,1,1) = 'R'     
    		NUOVA_LIBERA = SUBSTR(LIBERA,1,41)+ "R" + SUBSTR(LIBERA,43,LEN_LIBERA)

		OTHERWISE
    		NUOVA_LIBERA = SUBSTR(LIBERA,1,41)+ " " + SUBSTR(LIBERA,43,LEN_LIBERA)
		
    
    ENDCASE

	REPLACE LIBERA WITH NUOVA_LIBERA

	SELECT CUR_PARA
	SKIP +1
	
ENDDO



SELECT CUR_PARA
GO TOP   

IF !ExecRW('','PARA','I','','CUR_PARA')
     return(.f.)
ENDIF



RIT = MESSAGEBOX("Archivio PARA  "+CHR(13)+"aggiornato correttamente",16,"ATTENZIONE")