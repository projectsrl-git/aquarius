****************************************************************************
PROCEDURE CREA_WINMAIN
****************************************************************************

SET SYSMENU TO
SET SYSMENU AUTOMATIC

*** CREO CURSORE CON MENU DI PRIMO LIVELLO
cSql=""     
cNomeCursorSql="CPRIMO_LIVELLO"	

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 
		TBL_MENU.*,
		'N' AS VISIBILE
	FROM TBL_MENU 
	WHERE LIVELLO_MENU=1
	ORDER BY ORDINE
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	MESSAGEBOX("ERRORE NELLA CREZIONE DEL MENU DI PRIMO LIVELLO",48,"Creazione menu")
	RETURN 
ENDIF

SELECT CPRIMO_LIVELLO

*** CREO CURSORE CON MENU DI SECONDO LIVELLO

cSql=""     
cNomeCursorSql="CSECONDO_LIVELLO"	

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 
		T2L.*,
		'N' AS VISIBILE
	FROM TBL_MENU AS T2L
	LEFT OUTER JOIN TBL_MENU AS T1L
	ON T2L.MENU = T1L.MENU AND T1L.LIVELLO_MENU=1
	WHERE T2L.LIVELLO_MENU=2
	ORDER BY T1L.ORDINE*100+T2L.ORDINE
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	MESSAGEBOX("ERRORE NELLA CREZIONE DEL MENU DI SECONDO LIVELLO",48,"Creazione menu")
	RETURN 
ENDIF

SELECT CSECONDO_LIVELLO


*** CREO CURSORE CON OPZIONI ATTIVATE PER L'UTENTE

cSql=""     
cNomeCursorSql="CTBL_MENU"	

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 
	*
	FROM TBL_MENU 
	WHERE UTENTI LIKE '%.<<PUB_CODOPE>>.%'
	AND LIVELLO_MENU=0
	ORDER BY MENU,ORDINE
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	MESSAGEBOX("ERRORE NELLA CREZIONE DEL MENU DI SECONDO LIVELLO",48,"Creazione menu")
	RETURN 
ENDIF

SELECT CTBL_MENU
GO TOP
DO WHILE !EOF()

	_MENU=ALLTRIM(MENU)
	
	SELECT CSECONDO_LIVELLO
	GO TOP
	
	DO WHILE !EOF()
	
		IF VISIBILE ='S'
			SELECT CSECONDO_LIVELLO
			SKIP
			LOOP
		ENDIF
		

		IF !EMPTY(VISIBILE_SE)
		 
			IF !EVALUATE(ALLTRIM(VISIBILE_SE ))
				REPLACE VISIBILE WITH 'N'
				SELECT CSECONDO_LIVELLO
				SKIP
				LOOP				
			ENDIF		
		
		ENDIF
		
		IF !('SUBMENU' $ UPPER(COMANDO))
			REPLACE VISIBILE WITH 'S'
			SKIP
			LOOP			
		ENDIF
		
		IF "'"+UPPER(_MENU)+"'" $ UPPER(COMANDO)
			REPLACE VISIBILE WITH 'S'
			EXIT
		ENDIF
		
		SELECT CSECONDO_LIVELLO
		SKIP
	ENDDO

	
	SELECT CTBL_MENU
	SKIP
ENDDO

_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.F.

SELECT CSECONDO_LIVELLO
GO TOP
DO WHILE !EOF()

	IF VISIBILE <> 'S'
		SELECT CSECONDO_LIVELLO	
		SKIP
		LOOP
	ENDIF
	
	IF LABEL="\-"
		IF _ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE
			REPLACE VISIBILE WITH 'N'
		ENDIF		
		_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.T.
		SELECT CSECONDO_LIVELLO	
		SKIP
		LOOP
	ELSE
		_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.F.
	ENDIF		

	
	_MENU=ALLTRIM(MENU)
	
	SELECT CPRIMO_LIVELLO
	GO TOP
	DO WHILE !EOF()

		IF !EMPTY(	VISIBILE_SE )
			IF !EVALUATE(ALLTRIM(VISIBILE_SE ))
				REPLACE VISIBILE WITH 'N'
				SELECT CPRIMO_LIVELLO
				SKIP
				LOOP				
			ENDIF
		ENDIF
	
		
		IF VISIBILE ='S'
			SELECT CPRIMO_LIVELLO
			SKIP
			LOOP
		ENDIF
		
		IF UPPER(_MENU)=UPPER(MENU)
			REPLACE VISIBILE WITH 'S'
			EXIT
		ENDIF
		
		SELECT CPRIMO_LIVELLO
		SKIP
	ENDDO

	SELECT CSECONDO_LIVELLO
	SKIP
	
ENDDO


*** ELIMINA LE RIGHE DI SEPARAZIONE ALLA FINE DEI POPUP
SELECT CSECONDO_LIVELLO
DELETE FOR VISIBILE<>'S'
GO TOP 

_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.F.
_MENU_ATTUALE=''
SELECT CSECONDO_LIVELLO
GO TOP
DO WHILE !EOF()

	IF _MENU_ATTUALE<>ALLTRIM(MENU)
	
		IF _ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE
			SKIP -1
			REPLACE VISIBILE WITH 'N'
			SKIP +1
		ENDIF
		
		IF LABEL="\-"
			REPLACE VISIBILE WITH 'N'
			SKIP
			LOOP 
		ENDIF
		
		_MENU_ATTUALE=ALLTRIM(MENU)
	ENDIF
		
	IF LABEL="\-"
		_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.T.
	ELSE
		_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.F.
	ENDIF		
	
	SELECT CSECONDO_LIVELLO
	SKIP
	
ENDDO

*** CREA PRIMO LIVELLO DI MENU
SELECT CPRIMO_LIVELLO
GO TOP 


_PRIMO_MENU=""

DO WHILE !EOF()

	IF VISIBILE<>'S'
		_MENU=MENU
		SELECT CSECONDO_LIVELLO 
		REPLACE VISIBILE WITH 'N' FOR MENU=_MENU
		SELECT CPRIMO_LIVELLO
		SKIP
		LOOP
	ENDIF
	
	IF _PRIMO_MENU=""
		_PRIMO_MENU=ALLTRIM(MENU)
	ENDIF
	
	_KEY=SUBSTR(LABEL,1,1)
	
	_DEFINE="DEFINE PAD _PAD_"+ALLTRIM(MENU)+" OF _MSYSMENU PROMPT '"+ALLTRIM(LABEL)+"' COLOR SCHEME 3 KEY ALT+"+_KEY
	&_DEFINE
	
	_ONPAD="ON PAD _PAD_"+ALLTRIM(MENU)+" OF _MSYSMENU ACTIVATE POPUP "+ALLTRIM(MENU)
	&_ONPAD
	
	_DEFINE_POPUP="DEFINE POPUP "+ALLTRIM(MENU)+" MARGIN RELATIVE SHADOW COLOR SCHEME 4"
	&_DEFINE_POPUP
	
	SKIP
ENDDO

_ULTIMA_VOCE_PRIMO_MENU=0

*** CREA SECONDO LIVELLO DI MENU
SELECT CSECONDO_LIVELLO
GO TOP 


DO WHILE !EOF()

	IF VISIBILE<>'S'
		SKIP
		LOOP
	ENDIF

	_DEFINE_BAR="DEFINE BAR "+ALLTRIM(STR(ORDINE))+" OF "+ALLTRIM(MENU)+" PROMPT '"+ALLTRIM(LABEL)+"' PICTURE '"+ALLTRIM(ICONA)+"'"
	&_DEFINE_BAR
	
	_ON_SELECTION="ON SELECTION BAR "+ALLTRIM(STR(ORDINE))+" OF "+ALLTRIM(MENU)+" "+ALLTRIM(COMANDO)
	&_ON_SELECTION
	
	IF  ALLTRIM(MENU)=_PRIMO_MENU 
		_ULTIMA_VOCE_PRIMO_MENU=ORDINE
	ENDIF
	
	SKIP
ENDDO


*!*	_DEFINE_BAR ="DEFINE BAR "+ALLTRIM(STR(_ULTIMA_VOCE_PRIMO_MENU+1))+" OF "+ALLTRIM(_PRIMO_MENU)+" PROMPT '\-' "
*!*	&_DEFINE_BAR 
*!*		
*!*	_DEFINE_BAR ="DEFINE BAR "+ALLTRIM(STR(_ULTIMA_VOCE_PRIMO_MENU+2))+" OF "+ALLTRIM(_PRIMO_MENU)+" PROMPT 'Fine lavoro' KEY CTRL+F1, 'CTRL+F1' PICTURE 'bmp\ambiente\ztoolbar\_termina.bmp' "
*!*	&_DEFINE_BAR 	
*!*		
*!*	_ON_SELECTION_BAR_TERMINA="ON SELECTION BAR "+ALLTRIM(STR(_ULTIMA_VOCE_PRIMO_MENU+2))+" OF "+ALLTRIM(_PRIMO_MENU)+" DO FINE_LAVORO"
*!*	&_ON_SELECTION_BAR_TERMINA


**=> ERASMO - INIZIO 07/04/2015
IF !EMPTY(_PRIMO_MENU)
	
	_DEFINE_BAR ="DEFINE BAR "+ALLTRIM(STR(_ULTIMA_VOCE_PRIMO_MENU+1))+" OF "+ALLTRIM(_PRIMO_MENU)+" PROMPT '\-' "
	&_DEFINE_BAR 
		
	_DEFINE_BAR ="DEFINE BAR "+ALLTRIM(STR(_ULTIMA_VOCE_PRIMO_MENU+2))+" OF "+ALLTRIM(_PRIMO_MENU)+" PROMPT 'Fine lavoro' KEY CTRL+F1, 'CTRL+F1' PICTURE 'bmp\ambiente\ztoolbar\_termina.bmp' "
	&_DEFINE_BAR 	
		
	_ON_SELECTION_BAR_TERMINA="ON SELECTION BAR "+ALLTRIM(STR(_ULTIMA_VOCE_PRIMO_MENU+2))+" OF "+ALLTRIM(_PRIMO_MENU)+" DO FINE_LAVORO"
	&_ON_SELECTION_BAR_TERMINA

ELSE
	
	*** NEL CASO IN CUI NON RISULTI ABILITATA NESSUNA VOCE DI MENU PER L'UTENTE SELEZIONATO, DO' UN MESSAGGIO DI AVVISO E AGGIUNGO UNA VOCE DI MENU PER LA CHIUSURA DI AQUARIUS
	
	MESSAGEBOX("Nessuna voce di menu abilitata per l'utente selezionato" + REPLICATE(CHR(13),2) + "Provvedere all'abilitazione di almeno una funzionalitŕ",64,"Attenzione")
	
	_MENU="finelavoro"
	_LABEL="Fine lavoro"
	
	_KEY=SUBSTR(_LABEL,1,1)
	
	_DEFINE="DEFINE PAD _PAD_"+ALLTRIM(_MENU)+" OF _MSYSMENU PROMPT '"+ALLTRIM(_LABEL)+"' COLOR SCHEME 3 KEY ALT+"+_KEY
	&_DEFINE
	
	_ONPAD="ON SELECTION PAD _PAD_"+ALLTRIM(_MENU)+" OF _MSYSMENU DO FINE_LAVORO"
	&_ONPAD
	
ENDIF
**=> ERASMO - FINE 07/04/2015


RETURN


*********************************************************
PROCEDURE FINE_LAVORO
*********************************************************
IF !FILE("SVILUPPO.TB")
	DO PLAYWAV WITH "PROMEMOR.WAV"
	DO PLAYWAV WITH ""
ENDIF
CLEAR EVENTS

RETURN






****************************************************************************
PROCEDURE CREA_VOCI_MENU_VISIBILI
****************************************************************************

*SET SYSMENU TO
*SET SYSMENU AUTOMATIC

*** CREO CURSORE CON MENU DI PRIMO LIVELLO


CREATE CURSOR CUR_TMENUL1 (;
	 ID_UNIQUE             C(150), ;   
	 MENU		           C(50),  ; 
	 LABEL		           C(50),  ; 
	 COMANDO	           C(200), ;	 
	 DESCRIZION	           M,      ;
	 UTENTI                M,      ;
	 ORDINE                N(3,0), ;
	 VISIBILE	           C(1))	
INDEX ON ALLTRIM(MENU)  TAG I_MENU 		ADDITIVE
*INDEX ON ID_UNIQUE    	TAG I_IDMENU 	ADDITIVE


cSql=""     
cNomeCursorSql="CPRIMO_LIVELLO"	

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 
		TBL_MENU.*,
		'N' AS VISIBILE
	FROM TBL_MENU 
	WHERE LIVELLO_MENU=1
	ORDER BY ORDINE
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	MESSAGEBOX("ERRORE NELLA CREZIONE DEL MENU DI PRIMO LIVELLO",48,"Creazione menu")
	RETURN 
ENDIF

*** CREO CURSORE CON MENU DI SECONDO LIVELLO

CREATE CURSOR CUR_TMENUL2 (;
	 ID_UNIQUE             C(150), ;   
	 MENU		           C(50),  ; 
	 LABEL		           C(50),  ; 
	 COMANDO	           C(200), ;	 
	 DESCRIZION	           M,      ;
	 UTENTI                M,      ;
	 ORDINE                N(3,0), ;	 
	 VISIBILE	           C(1))	
INDEX ON ALLTRIM(MENU)  TAG I_MENU 		ADDITIVE
*INDEX ON ID_UNIQUE    	TAG I_IDMENU 	ADDITIVE


cSql=""     
cNomeCursorSql="CSECONDO_LIVELLO"	

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 
		T2L.*,
		'N' AS VISIBILE
	FROM TBL_MENU AS T2L
	LEFT OUTER JOIN TBL_MENU AS T1L
	ON T2L.MENU = T1L.MENU AND T1L.LIVELLO_MENU=1
	WHERE T2L.LIVELLO_MENU=2
	ORDER BY T1L.ORDINE*100+T2L.ORDINE
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	MESSAGEBOX("ERRORE NELLA CREZIONE DEL MENU DI SECONDO LIVELLO",48,"Creazione menu")
	RETURN 
ENDIF

SELECT CSECONDO_LIVELLO




*** CREO CURSORE CON OPZIONI ATTIVATE PER L'UTENTE

cSql=""     
cNomeCursorSql="CTBL_MENU"	

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 
	*
	FROM TBL_MENU 
	WHERE UTENTI LIKE '%.<<PUB_CODOPE>>.%'
	AND LIVELLO_MENU=0
	ORDER BY MENU,ORDINE
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	MESSAGEBOX("ERRORE NELLA CREZIONE DEL MENU DI SECONDO LIVELLO",48,"Creazione menu")
	RETURN 
ENDIF

SELECT CTBL_MENU
GO TOP
DO WHILE !EOF()

	_MENU=ALLTRIM(MENU)
	
	SELECT CSECONDO_LIVELLO
	GO TOP
	
	DO WHILE !EOF()
	
		IF VISIBILE ='S'
			SELECT CSECONDO_LIVELLO
			SKIP
			LOOP
		ENDIF
		

		IF !EMPTY(VISIBILE_SE)
		 
			IF !EVALUATE(ALLTRIM(VISIBILE_SE ))
				REPLACE VISIBILE WITH 'N'
				SELECT CSECONDO_LIVELLO
				SKIP
				LOOP				
			ENDIF		
		
		ENDIF
		
		IF !('SUBMENU' $ UPPER(COMANDO))
			REPLACE VISIBILE WITH 'S'
			SKIP
			LOOP			
		ENDIF
		
		IF "'"+UPPER(_MENU)+"'" $ UPPER(COMANDO)
			REPLACE VISIBILE WITH 'S'
			EXIT
		ENDIF
		
		SELECT CSECONDO_LIVELLO
		SKIP
	ENDDO

	
	SELECT CTBL_MENU
	SKIP
ENDDO

_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.F.

SELECT CSECONDO_LIVELLO
GO TOP
DO WHILE !EOF()

	IF VISIBILE <> 'S'
		SELECT CSECONDO_LIVELLO	
		SKIP
		LOOP
	ENDIF
	
	IF LABEL="\-"
		IF _ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE
			REPLACE VISIBILE WITH 'N'
		ENDIF		
		_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.T.
		SELECT CSECONDO_LIVELLO	
		SKIP
		LOOP
	ELSE
		_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.F.
	ENDIF		

	
	_MENU=ALLTRIM(MENU)
	
	SELECT CPRIMO_LIVELLO
	GO TOP
	DO WHILE !EOF()

		IF !EMPTY(	VISIBILE_SE )
			IF !EVALUATE(ALLTRIM(VISIBILE_SE ))
				REPLACE VISIBILE WITH 'N'
				SELECT CPRIMO_LIVELLO
				SKIP
				LOOP				
			ENDIF
		ENDIF
	
		
		IF VISIBILE ='S'
			SELECT CPRIMO_LIVELLO
			SKIP
			LOOP
		ENDIF
		
		IF UPPER(_MENU)=UPPER(MENU)
			REPLACE VISIBILE WITH 'S'
			EXIT
		ENDIF
		
		SELECT CPRIMO_LIVELLO
		SKIP
	ENDDO

	SELECT CSECONDO_LIVELLO
	SKIP
	
ENDDO


*** ELIMINA LE RIGHE DI SEPARAZIONE ALLA FINE DEI POPUP
SELECT CSECONDO_LIVELLO
DELETE FOR VISIBILE<>'S'
GO TOP 

_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.F.
_MENU_ATTUALE=''
SELECT CSECONDO_LIVELLO
GO TOP
DO WHILE !EOF()

	IF _MENU_ATTUALE<>ALLTRIM(MENU)
	
		IF _ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE
			SKIP -1
			REPLACE VISIBILE WITH 'N'
			SKIP +1
		ENDIF
		
		IF LABEL="\-"
			REPLACE VISIBILE WITH 'N'
			SKIP
			LOOP 
		ENDIF
		
		_MENU_ATTUALE=ALLTRIM(MENU)
	ENDIF
		
	IF LABEL="\-"
		_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.T.
	ELSE
		_ULTIMA_VOCE_VISIBILE_ERA_UNA_SEPARAZIONE=.F.
	ENDIF		
	
	SELECT CSECONDO_LIVELLO
	SKIP
	
ENDDO

*** CREA PRIMO LIVELLO DI MENU
SELECT CPRIMO_LIVELLO
GO TOP 


_PRIMO_MENU=""

DO WHILE !EOF()

	IF VISIBILE<>'S'
		_MENU=MENU
		SELECT CSECONDO_LIVELLO 
		REPLACE VISIBILE WITH 'N' FOR MENU=_MENU
		SELECT CPRIMO_LIVELLO
		SKIP
		LOOP
	ENDIF
	
	IF _PRIMO_MENU=""
		_PRIMO_MENU=ALLTRIM(MENU)
	ENDIF
	
	_KEY=SUBSTR(LABEL,1,1)
	
	
	SKIP
ENDDO

_ULTIMA_VOCE_PRIMO_MENU=0

*** CREA SECONDO LIVELLO DI MENU
SELECT CSECONDO_LIVELLO
GO TOP 


DO WHILE !EOF()

	IF VISIBILE<>'S'
		SKIP
		LOOP
	ENDIF

	
	IF  ALLTRIM(MENU)=_PRIMO_MENU 
		_ULTIMA_VOCE_PRIMO_MENU=ORDINE
	ENDIF
	
	SKIP
ENDDO




IF !EMPTY(_PRIMO_MENU)
ELSE
	*** NEL CASO IN CUI NON RISULTI ABILITATA NESSUNA VOCE DI MENU PER L'UTENTE SELEZIONATO, DO' UN MESSAGGIO DI AVVISO E AGGIUNGO UNA VOCE DI MENU PER LA CHIUSURA DI AQUARIUS
	MESSAGEBOX("Nessuna voce di menu abilitata per l'utente selezionato" + REPLICATE(CHR(13),2) + "Provvedere all'abilitazione di almeno una funzionalitŕ",64,"Attenzione")
ENDIF


SELECT CPRIMO_LIVELLO
GO TOP
SCAN

	SCATTER MEMVAR memo
	SELECT CUR_TMENUL1 
	APPEND BLANK 
	REPLACE ID_UNIQUE 	WITH M.ID_UNIQUE
	REPLACE MENU 		WITH M.MENU
	REPLACE LABEL 		WITH M.LABEL
	REPLACE COMANDO 	WITH M.COMANDO
	REPLACE DESCRIZION 	WITH M.DESCRIZION
	REPLACE VISIBILE 	WITH M.VISIBILE
	REPLACE UTENTI      WITH M.UTENTI 
	REPLACE ORDINE      WITH M.ORDINE
		
	SELECT CPRIMO_LIVELLO

ENDSCAN 

*!*	SELECT CPRIMO_LIVELLO
*!*	GO TOP 
*!*	BROWSE NORMAL
*!*	GO TOP

*!*	SELECT CUR_TMENUL1 
*!*	SET ORDER TO I_MENU
*!*	GO TOP 
*!*	BROWSE NORMAL
*!*	GO TOP


SELECT CSECONDO_LIVELLO
GO TOP 
SCAN

	SCATTER MEMVAR memo
	SELECT CUR_TMENUL2 
	APPEND BLANK 
	REPLACE ID_UNIQUE 	WITH M.ID_UNIQUE
	REPLACE MENU 		WITH M.MENU
	REPLACE LABEL 		WITH M.LABEL
	REPLACE COMANDO 	WITH M.COMANDO
	REPLACE DESCRIZION 	WITH M.DESCRIZION
	REPLACE VISIBILE 	WITH M.VISIBILE
	REPLACE UTENTI      WITH M.UTENTI 
	REPLACE ORDINE      WITH M.ORDINE 
	
	SELECT CSECONDO_LIVELLO

ENDSCAN 

*!*	SELECT CSECONDO_LIVELLO
*!*	GO TOP 
*!*	BROWSE NORMAL
*!*	GO TOP

RETURN
