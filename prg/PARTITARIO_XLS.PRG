
LPARAMETERS _par_aperte_chiuse

IF PCOUNT() >= 1
ELSE
	_par_aperte_chiuse = ""
ENDIF

LOCAL _C_TITOLO,_C_DATA_AL,_C_ANNO_DAL

_C_TITOLO = "Estrazione partite " + IIF(_par_aperte_chiuse="APERTA","aperte ",IIF(_par_aperte_chiuse="CHIUSA","chiuse ","")) + "alla data"
_C_DATA_AL = DTOC(DATE())
DO WHILE .T.
	_C_DATA_AL = PJ_INPUTBOX("Data pagamento Al",_C_TITOLO,_C_DATA_AL)
	IF EMPTY(_C_DATA_AL)
		MESSAGEBOX("Operazione abbandonata",48,"Informazione")
		RETURN .F.
	ENDIF
	IF VALID_DATA(_C_DATA_AL)
	ELSE
	   MESSAGEBOX("Data non valida",16,"Attenzione")
	   LOOP
	ENDIF
	_C_DATA_AL=OK_DATA(_C_DATA_AL)
	EXIT
ENDDO
_C_DATA_AL = RIBALTA2(_C_DATA_AL)

_C_ANNO_DAL = "1900"
IF _par_aperte_chiuse = "CHIUSA"
	_C_ANNO_DAL = PADL(ALLTRIM(STR(VAL(PUB_ANNO)-1,4,0)),4,'0')
	DO WHILE .T.
		_C_ANNO_DAL = PJ_INPUTBOX("Anno elaborazione Dal",_C_TITOLO,_C_ANNO_DAL)
		IF EMPTY(_C_ANNO_DAL)
			MESSAGEBOX("Operazione abbandonata",48,"Informazione")
			RETURN .F.
		ENDIF
			
		EXIT
	ENDDO
ENDIF

ac_cond = "1=1"
IF _par_aperte_chiuse = "CHIUSA"
	ac_cond = "COALESCE(PAG_TOT.IMPORTO_TOTALE_PAG_ALLA_DATA,0) = FAT_TOT.IMPORTO_TOTALE"
ENDIF
IF _par_aperte_chiuse = "APERTA"
	ac_cond = "COALESCE(PAG_TOT.IMPORTO_TOTALE_PAG_ALLA_DATA,0) <> FAT_TOT.IMPORTO_TOTALE"
ENDIF

WAIT WINDOWS "Elaborazione in corso..." NOWAIT

cSql = ""
TEXT TO cSql NOSHOW

	SELECT
		TEST_PART.PAR_ANNO AS ANNO,
		--TEST_PART.PAR_DTSCAD AS DATA_PRIMA_SCADENZA,
		RIGHE_PART.PAR_CODCLI AS COD_CLIENTE,
		RIGHE_PART.PAR_RAGSOC AS RAG_SOCIALE,
		--RIGHE_PART.PAR_TIPFAT AS COD_CAUSALE,
		COALESCE(PARA_TOP.DESCRI,'') AS CAUSALE,
		RIGHE_PART.PAR_NPROT AS NUM_DOCUMENTO,
		CAST(RIGHE_PART.PAR_NPART AS VARCHAR(10)) AS NUM_RIFERIMENTO,
		RIGHE_PART.PAR_DTFAT AS DATA_DOCUMENTO,
		RIGHE_PART.PAR_DTSCAD AS DATA_SCADENZA,
		RIGHE_PART.PAR_DTREG as DATA_REGISTRAZ,
		CASE WHEN RIGHE_PART.PAR_TMOV = 'D' THEN RIGHE_PART.PAR_FATT ELSE -1 * RIGHE_PART.PAR_FATT END AS IMPORTO,
		COALESCE(PARA_CPA.DESCRI,'') AS COND_PAGAMENTO,
		FAT_TOT.IMPORTO_TOTALE AS IMPORTO_TOTALE,
		COALESCE(PAG_TOT.IMPORTO_TOTALE_PAG_ALLA_DATA,0) AS IMPORTO_TOTALE_PAG_ALLA_DATA,
		CASE
			WHEN COALESCE(PAG_TOT.IMPORTO_TOTALE_PAG_ALLA_DATA,0) = FAT_TOT.IMPORTO_TOTALE THEN 'CHIUSA'
			ELSE 'APERTA'
		END AS STATO_ALLA_DATA
	FROM PART_CLI AS RIGHE_PART
		LEFT OUTER JOIN PARA AS PARA_TOP ON PARA_TOP.CODICE = 'TOP'+RIGHE_PART.PAR_TIPFAT
		LEFT OUTER JOIN PARA AS PARA_CPA ON PARA_CPA.CODICE = 'CPA'+RIGHE_PART.PAR_CODPAG
		INNER JOIN (SELECT PAR_CODCLI, PAR_NPART, SUM(PAR_FATT) AS IMPORTO_TOTALE FROM PART_CLI WHERE PAR_NPROG <> 100 AND PAR_TMOV = 'D' GROUP BY PAR_CODCLI, PAR_NPART) AS FAT_TOT ON FAT_TOT.PAR_CODCLI = RIGHE_PART.PAR_CODCLI AND FAT_TOT.PAR_NPART = RIGHE_PART.PAR_NPART
		LEFT OUTER JOIN (SELECT PAR_CODCLI, PAR_NPART, SUM(PAR_FATT) AS IMPORTO_TOTALE_PAG_ALLA_DATA FROM PART_CLI WHERE PAR_NPROG <> 100 AND PAR_TMOV = 'A' AND PAR_DTREG <= '<<_C_DATA_AL>>' GROUP BY PAR_CODCLI, PAR_NPART) AS PAG_TOT ON PAG_TOT.PAR_CODCLI = RIGHE_PART.PAR_CODCLI AND PAG_TOT.PAR_NPART = RIGHE_PART.PAR_NPART
		OUTER APPLY (SELECT TOP 1 PAR_ANNO,PAR_DTSCAD,PAR_NPROT,PAR_DTFAT FROM PART_CLI WHERE PAR_NPART = RIGHE_PART.PAR_NPART AND PAR_NPROG <> 100 AND PAR_TMOV = 'D' AND PAR_TIPODO = 'FAT' ORDER BY PAR_DTSCAD) AS TEST_PART
	WHERE
		RIGHE_PART.PAR_NPROG <> 100 
		AND TEST_PART.PAR_ANNO >= '<<_C_ANNO_DAL>>'
		AND (RIGHE_PART.PAR_DTREG <= '<<_C_DATA_AL>>' OR (RIGHE_PART.PAR_TMOV = 'D' AND RIGHE_PART.PAR_TIPODO = 'FAT'))
		AND <<ac_cond>>
	ORDER BY TEST_PART.PAR_ANNO,TEST_PART.PAR_DTSCAD,RIGHE_PART.PAR_NPART,RIGHE_PART.PAR_DTSCAD,IMPORTO DESC

ENDTEXT

IF !ExecPreparedCommand(cSql,"PARTITARIO")
  return(.f.)
ENDIF
SELECT PARTITARIO
GO TOP

WAIT CLEAR

_TITOLO_EXCEL1 = _C_TITOLO
_TITOLO_EXCEL2 = ""
_TITOLO_EXCEL3 = "Valuta di riferimento " + ALLTRIM(PUB_VALRIF)
_TOTALI_GENERALI = .F.
DO ESTRXLS WITH "PARTITARIO",_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,_TOTALI_GENERALI

MESSAGEBOX("Operazione conclusa",64,"Informazione")

RETURN
