RIT = MESSAGEBOX("-Procedo con la conversione dell'anagrafica articoli dalla tabella CARD_ANAMAGA/CARD_ANARTIC/CARD_TABDIST/CARD_BARCODE?",292,"ATTENZIONE")
IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF


WAIT WINDOWS "Cancellazione vecchia anagrafica articoli in corso..." NOWAIT

cSql = "DELETE FROM U_ART_PR"
IF !ExecCommand(cSql,"DEL_ART_PR")
   return
ENDIF

cSql = "DELETE FROM U_ART_AN"
IF !ExecCommand(cSql,"DEL_ART_AN")
   return
ENDIF


WAIT WINDOWS "Conversione anagrafica articoli in corso..." NOWAIT


cSql = ""
TEXT TO cSql NOSHOW

	INSERT INTO U_ART_PR (ART_CODSOC,ART_MAGA,ART_CODMAT,ART_CODPRI,ART_DESCR,ART_TIPART,ART_GRUPPO,ART_TIPOPR,ART_CATMER,ART_LINEA,ART_DESLIN,ART_UNIMIS,ART_UMMAGA,ART_DATVAR,ART_DATINS,ART_CODIVA,ART_CLDOG,ART_CODF1,ART_CGE,ART_PRZCO1,ART_ULDCAR,ART_SCORMI,ART_QTACON,ART_PRZCOS,ART_COSMAT,ART_PESOUM,ART_NOTE,ART_OBSOL,ART_DESRID,ART_CODITG1,ART_CODCTL,ART_BARCLI)
		SELECT
			'01' AS ART_CODSOC,
			CASE COALESCE(CARD_ANARTIC.CODMAG,'')
				WHEN '' THEN
					CASE
						WHEN COALESCE(CASE CARD_TABDIST.CODMAG WHEN 'VEN' THEN 'SEDE' ELSE CARD_TABDIST.CODMAG END,'') <> '' THEN COALESCE(CASE CARD_TABDIST.CODMAG WHEN 'VEN' THEN 'SEDE' ELSE CARD_TABDIST.CODMAG END,'')
						ELSE 'SEDE'
					END
				WHEN 'VEN' THEN 'SEDE'
				ELSE CARD_ANARTIC.CODMAG
			END AS ART_MAGA,
			'001' AS ART_CODMAT,
			ANAMAGA.CODICE AS ART_CODPRI,
			COALESCE(DESCRIZION,'') AS ART_DESCR,
			CASE
				WHEN ANAMAGA.CODICE IN (SELECT CODICE FROM CARD_TESDIS) OR ANAMAGA.CODICE IN (SELECT CODPART FROM CARD_ANDB WHERE CODPART <> CODCOMP)
				THEN 'P'
				ELSE
					CASE ANAMAGA.TIPO
						WHEN 'M' THEN 'A'
						WHEN 'P' THEN 'A'
						WHEN 'S' THEN 'P'
						WHEN 'K' THEN 'P'
						ELSE 'A'
					END
			END AS ART_TIPART,
			CASE
				WHEN ANAMAGA.CODICE IN (SELECT CODICE FROM CARD_TESDIS) OR ANAMAGA.CODICE IN (SELECT CODPART FROM CARD_ANDB WHERE CODPART <> CODCOMP)
				THEN 1
				ELSE 0
			END AS ART_GRUPPO,
			CASE COALESCE(CARD_TABDIST.TPDOC,'')
				WHEN 'F' THEN ''
				ELSE COALESCE(CARD_TABDIST.TPDOC,'')
			END AS ART_TIPOPR,
			COALESCE(ANAMAGA.TIPO,'') 		AS ART_CATMER,			
			COALESCE(CARD_TABDIST.COD,'') 	AS ART_LINEA,
			COALESCE(CARD_TABDIST.DESCR,'') AS ART_DESLIN,
			COALESCE(UNITAMIACQ,'NR') 		AS ART_UNIMIS,
			COALESCE(UNITAMIVEN,'NR') 		AS ART_UMMAGA,
			SUBSTRING(DATACREAZI,1,4) + '/' + SUBSTRING(DATACREAZI,5,2) + '/' + SUBSTRING(DATACREAZI,7,2) AS ART_DATVAR,
			SUBSTRING(ULT_AGG,1,4) + '/' + SUBSTRING(ULT_AGG,5,2) + '/' + SUBSTRING(ULT_AGG,7,2) AS ART_DATINS,
			COALESCE(CODICEIVA,'') 			AS ART_CODIVA,
			COALESCE(CLASDOGANA,'') 		AS ART_CLDOG,
			''						 		AS ART_CODF1,
			'' 								AS ART_CGE,
			0					 			AS ART_PRZCO1,
			CASE COALESCE(DTULTACQUI,'')
				WHEN '' THEN ''
				ELSE SUBSTRING(DTULTACQUI,1,4) + '/' + SUBSTRING(DTULTACQUI,5,2) + '/' + SUBSTRING(DTULTACQUI,7,2)
			END 							AS ART_ULDCAR,
			COALESCE(SCORTASICU,0) 			AS ART_SCORMI,
			CASE UNITAMIVEN
				WHEN 'NR' THEN NUMPEZCONF
				ELSE ''
			END 							AS ART_QTACON,
			COALESCE(EPRSTANDAR,0) 			AS ART_PRZCOS,
			COALESCE(EPRSTANDAR,0) 			AS ART_COSMAT,
			COALESCE(PESOKG,0) 				AS ART_PESOUM,
			COALESCE(NOTASTD,'') 			AS ART_NOTE,
			CASE COALESCE(STATO,'')
				WHEN 'S' THEN ''
				ELSE 'S'
			END 							AS ART_OBSOL,
			COALESCE(CODICERICE,'') 		AS ART_DESRID,
			COALESCE(CODICEVUOT,'') 		AS ART_CODITG1,
			COALESCE(CODIS,'') 				AS ART_CODCTL,
			COALESCE(BARCODE,'') 			AS ART_BARCLI
		FROM CARD_ANAMAGA AS ANAMAGA
		LEFT OUTER JOIN (SELECT CODART,CODMAG,TIPDIST,CODIS FROM CARD_ANARTIC) AS CARD_ANARTIC ON ANAMAGA.CODICE = CARD_ANARTIC.CODART
		LEFT OUTER JOIN (SELECT COD,DESCR,TPDOC,CODMAG FROM CARD_TABDIST) AS CARD_TABDIST ON CARD_ANARTIC.TIPDIST = CARD_TABDIST.COD
		LEFT OUTER JOIN (SELECT CODICE AS CODICE_BARCODE, BARCODE FROM CARD_BARCODE) AS CARD_BARCODE ON CARD_BARCODE.CODICE_BARCODE = ANAMAGA.CODICE
		WHERE ANAMAGA.CODICE NOT LIKE '1999%'
		
ENDTEXT

IF !ExecCommand(cSql,"INS_ART_PR")
   return
ENDIF


cSql = ""
TEXT TO cSql NOSHOW

	INSERT INTO U_ART_AN (ART_CODSOC,ART_CODPRI,ART_ARTSIMI,ART_CODGMI,ART_QTANRC,ART_CGEACQ,ART_NONVAL)
		SELECT
			'01' AS ART_CODSOC,
			CODICE AS ART_CODPRI,
			COALESCE(CODICEALTE,'') AS ART_ARTSIMI,
			COALESCE(GRUPPOMERC,'') AS ART_CODGMI,
			COALESCE(NUMPEZCONF,0) 	AS ART_QTANRC,
			COALESCE(CONTROACQ,'') 	AS ART_CGEACQ,
			CASE COALESCE(VALORIZZAZ,'')
				WHEN 'S' THEN 0
				ELSE 1
			END 					AS ART_NONVAL
			
		FROM CARD_ANAMAGA
		WHERE CODICE NOT LIKE '1999%'

ENDTEXT

IF !ExecCommand(cSql,"INS_ART_AN")
   return
ENDIF

*** PATCH PER SBIANCAMENTO CAMPO ART_TIPOPR SE ARTICOLO DI ACQUISTO
cSql = "UPDATE U_ART_PR SET ART_TIPOPR = '' WHERE ART_TIPART <> 'P'"
IF !ExecCommand(cSql,"UPD_ART_PR")
   return
ENDIF


WAIT WINDOWS "Valorizzazione descrizione e parametro categoria merceologica in corso..." NOWAIT

*** VALORIZZAZIONE CATEGORIA MERCEOLOGICA
*!*	"M" - MATERIA PRIMA 
*!*	"P" - PRODOTTO FINITO 
*!*	"S" - SEMILAVORATO 
*!*	"K" - KIT 

cSql = "DELETE FROM PARA WHERE CODICE LIKE 'MER%'"
IF !ExecCommand(cSql,"DEL_PARA_MER")
   return
ENDIF

cSql = "INSERT INTO PARA (CODICE, DESCRI, LIBERA) VALUES ('MERM','MATERIA PRIMA','')"
IF !ExecCommand(cSql,"INS_PARA_MER")
   return
ENDIF
cSql = "INSERT INTO PARA (CODICE, DESCRI, LIBERA) VALUES ('MERP','PRODOTTO FINITO','')"
IF !ExecCommand(cSql,"INS_PARA_MER")
   return
ENDIF
cSql = "INSERT INTO PARA (CODICE, DESCRI, LIBERA) VALUES ('MERS','SEMILAVORATO','')"
IF !ExecCommand(cSql,"INS_PARA_MER")
   return
ENDIF
cSql = "INSERT INTO PARA (CODICE, DESCRI, LIBERA) VALUES ('MERK','KIT','')"
IF !ExecCommand(cSql,"INS_PARA_MER")
   return
ENDIF

cSql = "UPDATE U_ART_PR SET ART_DESMER = (SELECT COALESCE(DESCRI,'') AS DESCRI FROM PARA WHERE CODICE = 'MER'+U_ART_PR.ART_CODPRI)"
IF !ExecCommand(cSql,"UPD_ART_PR")
   return
ENDIF


WAIT WINDOWS "Valorizzazione articoli fornitori in corso..." NOWAIT

*** VALORIZZAZIONE ARTICOLI FORNITORI
cSql = "SELECT ART_CODPRI, ART_DESCR FROM U_ART_PR WHERE SUBSTRING(ART_CODPRI,1,1) <> '.' ORDER BY ART_CODPRI"
IF !ExecCommand(cSql,"CX_ART_PR")
   return
ENDIF
SELECT CX_ART_PR
GO TOP
SCAN
	
	WAIT WINDOWS "Valorizzazione articoli fornitori in corso... (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT
	
	SCATTER MEMVAR
	x_tipo = "TIPO = 'DC'"
	x_tpef = "TIPOEFFET = 'B'"
	x_forn = "C_F = 'F'"
	x_null = "COALESCE(CLI_FOR,'') <> ''"
	x_codi = "ARTICOLO = '" + ALLTRIM(M.ART_CODPRI) + "'"
	x_clfo = "COALESCE(CLI_FOR,'') <> ''"
	x_cond = x_tipo + " and " + x_tpef + " and " + x_forn + " and " + x_null + " and " + x_codi + " and " + x_clfo 
	cSql = "SELECT TOP 3 CLI_FOR, EPRLORDO, PRVALUTA FROM CARD_MOVIMAG WHERE " + x_cond + " ORDER BY DATADOC DESC"
	IF !ExecCommand(cSql,"CX_MOVIMAG")
	   return
	ENDIF
	_CONTA = 0
	SCAN
		SCATTER MEMVAR
		
		_PREZZO = M.EPRLORDO
		*** SE ESISTE PREZZO ESPRESSO IN VALUTA CONSIDERO QUELLO, IN QUANTO QUEL FORNITORE GESTISCE IL PREZZO NELLA SUA VALUTA
		IF M.PRVALUTA > 0
			_PREZZO = M.PRVALUTA
		ENDIF
		
		x_codi = "ART_CODPRI = '" + ALLTRIM(M.ART_CODPRI) + "'"
		x_cdf1 = "ART_CODF1 = '" + ALLTRIM(M.CLI_FOR) + "'"
		x_cdf2 = "ART_CODF2 = '" + ALLTRIM(M.CLI_FOR) + "'"
		x_cdf3 = "ART_CODF3 = '" + ALLTRIM(M.CLI_FOR) + "'"
		x_cond = x_codi + " and (" + x_cdf1 + " or " + x_cdf2 + " or " + x_cdf3 + ")"
		cSql = "SELECT ART_CODPRI, ART_DESCR, ART_CODF1, ART_CODF2, ART_CODF3 FROM U_ART_PR WHERE " + x_cond
		IF !ExecCommand(cSql,"TMP_ART_PR")
			RETURN .F.
		ENDIF
		SELECT TMP_ART_PR
		GO TOP
		IF EOF()  && FORNITORE NON ANCORA INSERITO
			_CONTA = _CONTA + 1
			_cNomeCampoForn = "ART_CODF" + ALLTRIM(STR(_CONTA,1,0))
			_cNomeCampoPrez = "ART_PRZCO" + ALLTRIM(STR(_CONTA,1,0))
			cSql = "UPDATE U_ART_PR SET " + ;
				_cNomeCampoForn + " = '" + ALLTRIM(M.CLI_FOR) + "', " + ;
				_cNomeCampoPrez + " = " + IIF(ISNULL(_PREZZO),0,STRTRAN(ALLTRIM(STR(_PREZZO,19,6)),',','.')) + ;
				" WHERE ART_CODPRI = '" + ALLTRIM(M.ART_CODPRI) + "'"
			IF !ExecCommand(cSql,"UPD_ART_PR")
				RETURN .F.
			ENDIF
		ENDIF
		
		IF _CONTA >= 3
			EXIT
		ENDIF
	ENDSCAN
ENDSCAN


_TOT_COUNT = 0
cSql = "SELECT COUNT(*) AS CONTA FROM U_ART_PR"
IF !ExecCommand(cSql,"TMP_ART_PR")
   return
ENDIF
SELECT TMP_ART_PR
GO TOP
IF !EOF()
	_TOT_COUNT = CONTA
ENDIF

WAIT CLEAR

MESSAGEBOX("Operazione terminata correttamente" + REPLICATE(CHR(13),2) + ;
	"Totale articoli convertiti: " + ALLTRIM(STR(_TOT_COUNT,10,0)) + REPLICATE(CHR(13),2) + ;
	"RICORDATI DI ESEGUIRE NUOVAMENTE LA CONVERSIONE DELLE FASI DI LAVORAZIONE",64,"Informazione")

RETURN


 