**********************************************************	
PROCEDURE RIEPILOGO_SEQUENZE_OTTENUTE
**********************************************************	

*** INSERISCE L'ULTIMA SEQUENZA 

SELECT SEQUENZE
GO TOP

DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	_ID_SEQUEN=ID_SEQUEN
	
	DO LEGGE_STRINGA_SEQUENZA	
	
	SELECT RIEPILOGO
	SET ORDER TO RIE_IDSEQ
	GO TOP
	SEEK _ID_SEQUEN

	IF FOUND()
	
		DO WHILE !EOF()
			
			IF DELETED()
				SKIP
				LOOP
			ENDIF
			
			IF ALLTRIM(RIE_IDSEQ) <> ALLTRIM(_ID_SEQUEN)
				EXIT
			ENDIF
		
			____ALTEZZA_FASCIA_RIEPILOGO=RIE_ALTEZ
			____NUMERO_BARRE_FASCIA_RIEPILOGO=RIE_NBARR
			____TROVATA_SEQUENZA_RIEPLOGO=.F.
			____LUNGHEZZA_BARRE_FASCIA_RIEPILOGO=RIE_LUNGH
			
			SELECT SEQUENZE_DD
			SET ORDER TO ID_SEQUEN
			GO TOP
			SEEK _ID_SEQUEN+"00001"
			
			IF FOUND()
					
				____PASSO=PASSO
				____ALTEZZA_FASCIA=ALTEZ
				____NUMERO_BARRE_FASCIA=NUMBARRE
				____LUNGHEZZA_BARRE_FASCIA=LUNGH
			
				DO WHILE !EOF()
					
					IF DELETED()
						SKIP
						LOOP
					ENDIF
					
					IF ALLTRIM(ID_SEQUEN)<>ALLTRIM(_ID_SEQUEN)
						EXIT
					ENDIF
					
					IF ALLTRIM(PASSO)=ALLTRIM(____PASSO)
					
						____ALTEZZA_FASCIA	=____ALTEZZA_FASCIA+ALTEZ
					
					ELSE
					
						IF ____ALTEZZA_FASCIA_RIEPILOGO=____ALTEZZA_FASCIA+SCARTO_LATERALE AND ____NUMERO_BARRE_FASCIA_RIEPILOGO=____NUMERO_BARRE_FASCIA
							____TROVATA_SEQUENZA_RIEPLOGO=.T.
							EXIT
						ENDIF
						
						____ALTEZZA_FASCIA=ALTEZ
						____NUMERO_BARRE_FASCIA=NUMBARRE
						____LUNGHEZZA_BARRE_FASCIA=LUNGH
						____PASSO=PASSO
					ENDIF
					
					SELECT SEQUENZE_DD
					SKIP
					
				ENDDO	
										
			ENDIF
	
			SELECT RIEPILOGO
			_RECNO = RECNO()  && ERASMO - 12/02/2010
			
			IF ____TROVATA_SEQUENZA_RIEPLOGO
				SKIP 
				LOOP
			ENDIF
			
			____SEQUENZA_RIEPILOGO=ALLTRIM(RIE_SEQUE)+ALLTRIM(STR(____ALTEZZA_FASCIA_RIEPILOGO-SCARTO_LATERALE))+"+0L"+ALLTRIM(STR(____LUNGHEZZA_BARRE_FASCIA_RIEPILOGO))+"*"+ALLTRIM(STR(____NUMERO_BARRE_FASCIA_RIEPILOGO))+"/"
			REPLACE RIE_SEQUE WITH ____SEQUENZA_RIEPILOGO FOR ALLTRIM(RIE_IDSEQ)=ALLTRIM(_ID_SEQUEN)
			
			SELECT RIEPILOGO  && ERASMO - 12/02/2010
			GOTO _RECNO  && ERASMO - 12/02/2010
			
			SELECT SEQUENZE
			SET ORDER TO ID_SEQUEN
			SEEK _ID_SEQUEN
			
			REPLACE SEQUENZA WITH ____SEQUENZA_RIEPILOGO
			
			DO LEGGE_STRINGA_SEQUENZA	
			
			SELECT RIEPILOGO
			*EXIT
			SKIP +1  && ERASMO - 12/02/2010
			LOOP  && ERASMO - 12/02/2010
		ENDDO
		
	ENDIF
		
	SELECT SEQUENZE
	SKIP
	
ENDDO



SELECT RIEPILOGO 
SET ORDER TO RIE_TAPPE
GO TOP


DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF

	_ID_TAPPETO		=RIE_TAPPE
	_H_FASCIA  		=RIE_ALTEZ
	_LUNGH_FASCIA	=RIE_LUNGH*RIE_NBARR
	_IDSEQ			=RIE_IDSEQ
	_NBARR          =RIE_NBARR

	SELECT OTTIMALE
	SET ORDER TO OTT_TAPPE
	SEEK _ID_TAPPETO
	IF !FOUND()
		APPEND BLANK
		REPLACE OTT_TAPPE 	WITH _ID_TAPPETO
	ENDIF
	
	REPLACE OTT_NUMFA 	WITH OTT_NUMFA+1
	REPLACE OTT_SNUMFA 	WITH STR_FILL_ZERO(OTT_NUMFA,5)
	REPLACE OTT_ML 		WITH OTT_ML+_LUNGH_FASCIA
	REPLACE OTT_MQ 		WITH OTT_MQ+_LUNGH_FASCIA*_H_FASCIA/1000
	REPLACE OTT_IDSEQ 	WITH _IDSEQ
	REPLACE OTT_NBARR   WITH OTT_NBARR + _NBARR
	
	IF OTT_HMAX<_H_FASCIA
		REPLACE OTT_HMAX 	WITH _H_FASCIA
		REPLACE OTT_SHMAX 	WITH STR_FILL_ZERO(OTT_HMAX,5)
	ENDIF
	
	SELECT RIEPILOGO
	SKIP
	
ENDDO


SELECT SEQUENZE
GO TOP

DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF

	DO LEGGE_STRINGA_SEQUENZA	
		
	SELECT SEQUENZE
	SKIP
	
ENDDO


* FINE PROCEDURE RIEPILOGO_SEQUENZE_OTTENUTE
**********************************************************		




**********************************************************
PROCEDURE LEGGE_STRINGA_SEQUENZA
**********************************************************

LOCAL 	_posizione,;
		_stringa,;
		_ALTEZZA_ROTOLO1,;
		_ALTEZZA_ROTOLO2,;
		_NUMROT,;
		_LUNGHEZZA_BARRA,;
		_PASSO,;
		_CARATTERE,;
		_ID_SEQUEN,;
		_STRINGA_PARZIALE

SELECT SEQUENZE

_STRINGA         =SEQUENZA

_ID_SEQUEN       =ID_SEQUEN

_PASSO=0

_NUMBARRE=""

_ALTEZZA_ROTOLO1=""
_ALTEZZA_ROTOLO2=""
_LUNGHEZZA_BARRA =""
_STRINGA_PARZIALE=""
	
SELECT SEQUENZE_DD

DELETE FOR ID_SEQUEN = _ID_SEQUEN

SELECT SEQUENZE

FOR _posizione =1 TO LEN(_stringa)
	
	_CARATTERE=SUBSTR(_stringa,_posizione,1)

	DO CASE 
	
		CASE _CARATTERE="+" 	
			_ALTEZZA_ROTOLO1=_STRINGA_PARZIALE
			_STRINGA_PARZIALE=""

		CASE _CARATTERE="L" 	
			_ALTEZZA_ROTOLO2=_STRINGA_PARZIALE
			_STRINGA_PARZIALE=""

		CASE _CARATTERE="*" 	
			_LUNGHEZZA_BARRA=_STRINGA_PARZIALE
			_STRINGA_PARZIALE=""						
			
		CASE _CARATTERE="/"
			_NUMBARRE=_STRINGA_PARZIALE
			
			_PASSO=_PASSO+1
			
			IF VAL(_ALTEZZA_ROTOLO1)>0
				SELECT SEQUENZE_DD
				APPEND BLANK
				REPLACE NUMBARRE  WITH VAL(_NUMBARRE)
				REPLACE ALTEZ     WITH VAL(_ALTEZZA_ROTOLO1)
				REPLACE LUNGH     WITH VAL(_LUNGHEZZA_BARRA)
				REPLACE ID_SEQUEN WITH _ID_SEQUEN
				REPLACE PASSO     WITH STR_FILL_ZERO(_PASSO,5)
			ENDIF
			
			IF VAL(_ALTEZZA_ROTOLO2)>0
				SELECT SEQUENZE_DD
				APPEND BLANK
				REPLACE NUMBARRE  WITH VAL(_NUMBARRE)
				REPLACE ALTEZ     WITH VAL(_ALTEZZA_ROTOLO2)
				REPLACE LUNGH     WITH VAL(_LUNGHEZZA_BARRA)
				REPLACE ID_SEQUEN WITH _ID_SEQUEN
				REPLACE PASSO     WITH STR_FILL_ZERO(_PASSO,5)
			ENDIF
			
			_NUMBARRE=""
			_ALTEZZA_ROTOLO1=""
			_ALTEZZA_ROTOLO2=""
			_STRINGA_PARZIALE=""
			_LUNGHEZZA_BARRA =""
		
		OTHERWISE
			_STRINGA_PARZIALE=_STRINGA_PARZIALE+_CARATTERE		

	ENDCASE
	
NEXT

SELECT SEQUENZE


* FINE PROCEDURE LEGGE_STRINGA_SEQUENZA
**********************************************************


**********************************************************
PROCEDURE RICREO_RIEPILOGO_INIZIALE_DEI_GRUPPI_DI_ROTOLI	
**********************************************************

*** RICREO IL RIEPILOGO INIZIALE DI TUTTI I ROTOLI
*** PER UN NUOVO CICLO DI OTTIMIZZAZIONE
***
CREATE CURSOR GRUPPI (;
	GRP_PROD C(30),;
	ALTEZ    N(5),;
	LUNGH    N(5),;
	NUMROT   N(5))
SELECT 	GRUPPI
INDEX ON ALTEZ TAG ALTEZ
INDEX ON STR_FILL_ZERO(ALTEZ,5)+STR_FILL_ZERO(LUNGH,5)+GRP_PROD TAG ALTLUNGRP


SELECT ORDINE_DISP0
GO TOP
IF EOF()
	DO MESSAGGIO_GROSSO_BLU WITH "NON CI SONO GRUPPI DI ROTOLI DA ELABORARE"
	RETURN
ENDIF

_NUMERO_GRUPPI_INIZIALE=0
		
DO WHILE !EOF()
	
	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	SCATTER MEMVAR
	SELECT GRUPPI
	APPEND BLANK
	GATHER MEMVAR
	
	SELECT ORDINE_DISP0
	_NUMERO_GRUPPI_INIZIALE=_NUMERO_GRUPPI_INIZIALE+1
	SKIP 
	
ENDDO
	
* FINE PROCEDURE RICREO_RIEPILOGO_INIZIALE_DEI_GRUPPI_DI_ROTOLI
**********************************************************
	