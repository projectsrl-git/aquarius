**********************************************************
PROCEDURE OTTIMIZZA_ROTOLI_IN_ALTEZZA
**********************************************************

LOCAL _CI_SONO_ANCORA_ROTOLI_DA_ELABORARE,_SEQUENZA,_STEP

RELEASE _NUMERO_GRUPPI,_NUMERO_GRUPPI_INIZIALE
PUBLIC  _NUMERO_GRUPPI,_NUMERO_GRUPPI_INIZIALE

DO CREA_CURSORI_PER_OTTIMIZZAZIONE

_CICLO=0
_CONTA_SEQUENZE_CON_FASCIA_MINIMA_PER_ROTTURA_APPROSSIMATA=0
_NUMERO_GRUPPI_INIZIALE=0

DO WHILE .T.

 	IF _CICLO>PUB_NUMERO_MASSIMO_COMBINAZIONI_DA_PROVARE
 		***** RAGGIUNTO LIMITE DI COMBINAZIONI IMPOSTO
 		***** DO MESSAGGIO_GROSSO_BLU WITH "VERIFICARE LE COMBINAZIONI CALCOLATE - FASE 1"
 		EXIT
 	ENDIF
 	
 	DO RICREO_RIEPILOGO_INIZIALE_DEI_GRUPPI_DI_ROTOLI	

	*** ROTTURA APPROSSIMATA (1)
	***
	IF _CONTA_SEQUENZE_CON_FASCIA_MINIMA_PER_ROTTURA_APPROSSIMATA>=PUB_NUMERO_RICORRENZE_FASCIA_MINIMA_PER_FERMARE_IL_CALCOLO
		EXIT	
	ENDIF
	
	_CICLO=_CICLO+1
	
	WAIT WINDOW "CICLO ELABORAZIONE IN CORSO: CALCOLO MATRICIALE LIVELLO "+ALLTRIM(STR(_CICLO))  NOWAIT && +" - SEQUENZE A FASCIA MINIMA "+ALLTRIM(STR(_CONTA_SEQUENZE_CON_FASCIA_MINIMA_PER_ROTTURA_APPROSSIMATA)) NOWAIT
		
	_CI_SONO_ANCORA_ROTOLI_DA_ELABORARE=.T.
	_STEP	 =0
	_SEQUENZA=""	
	
	
						*SET STEP ON 
						
	DO WHILE .T.
	
		SELECT GRUPPI
		***SET ORDER TO ALTEZ
		SET ORDER TO ALTLUNGRP
		GO TOP
		
		IF EOF()
			RETURN
		ENDIF
		
		*** CONTO QUANTI GRUPPI CI SONO E CONSIDERO CHE C'E' ANCHE L'ALTEZZA ZERO
		*** QUINDI UN GRUPPO IN PIU'
		***
		***_NUMERO_GRUPPI=RECCOUNT()+1 
		_NUMERO_GRUPPI=RECCOUNT()

		_STEP	 =_STEP+1

		DO COMPILO_LA_MATRICE_DEI_ROTOLI WITH _NUMERO_GRUPPI
	
		DO METTO_SI_E_NO_NELLE_CASELLE_DA_ELABORARE WITH _NUMERO_GRUPPI

		_CI_SONO_ANCORA_ROTOLI_DA_ELABORARE=VERIFICA_SE_CI_SONO_ANCORA_ROTOLI_DA_COMBINARE_IN_QUESTA_SEQUENZA(_NUMERO_GRUPPI)
		
		*****!!!!!!!!!!!!!!*****************
		***** SE CI SONO ANCORA ROTOLI CHE NON SONO STATI ACCOPPIATO ALLORA DEVO AGGIUNGERE ALLA SEQUENZA LE SINGOLE FASCE DI OGNI
		***** ROTOLO NON ACCOPPIATO

		IF (EMPTY(_SEQUENZA) AND _STEP=1 ) = .F. && TEST PER POTER GESTIRE LA SEQUENZA AL PRIMO GIRO PERCHE' ALMENO UNA SCELTA LA DEVE FARE
										 
			*** CALCOLO DEL RIEPILOGO
			***										 
										 
			IF _CI_SONO_ANCORA_ROTOLI_DA_ELABORARE = .F.
			
				SELECT SEQUENZE
				SET ORDER TO SEQUENZA
				SEEK _SEQUENZA
				
				_ID_SEQUEN=""
				
				IF FOUND()
				
					REPLACE FINITA WITH .T.
					_ID_SEQUEN=ID_SEQUEN
					
					_ID_TAPPETO=SYS(2015)
					
*!*						***************************************
*!*						
*!*						FOR _INDICE_SEQUENZE=1 TO _NUMERO_GRUPPI
*!*							REPLACE LUNGH     WITH ARRAY_GRUPPI_LUNGHEZZA[_INDICE_SEQUENZE]
*!*							REPLACE SEQUENZA  WITH ALLTRIM(SEQUENZA)+ALLTRIM(STR(ARRAY_GRUPPI_ALTEZZA[_INDICE_SEQUENZE]))+"+0L"+ALLTRIM(STR(ARRAY_GRUPPI_LUNGHEZZA[_INDICE_SEQUENZE]))+"*"+ALLTRIM(STR(ARRAY_GRUPPI_NUMROT[_INDICE_SEQUENZE]))+"/"
*!*						NEXT
*!*						
*!*						_SEQUENZA_MEMORIZZATA=SEQUENZA			
*!*						
*!*						**************************************************
					
					FOR _INDICE_RIEPILOGO=1 TO _NUMERO_GRUPPI
					
						SELECT RIEPILOGO 
						APPEND BLANK 
						REPLACE RIE_TAPPE WITH _ID_TAPPETO
						
						REPLACE RIE_ALTEZ WITH ARRAY_GRUPPI_ALTEZZA[_INDICE_RIEPILOGO]
					    IF _CICLO=1
				    		REPLACE RIE_ALTEZ WITH RIE_ALTEZ+SCARTO_LATERALE
					    ENDIF
						REPLACE RIE_SALTE WITH STR_FILL_ZERO(RIE_ALTEZ,5)
	
						REPLACE RIE_LUNGH WITH ARRAY_GRUPPI_LUNGHEZZA[_INDICE_RIEPILOGO]
						REPLACE RIE_NBARR WITH ARRAY_GRUPPI_NUMROT[_INDICE_RIEPILOGO]
						REPLACE RIE_LUNFA WITH RIE_NBARR*RIE_LUNGH
						
						REPLACE RIE_IDSEQ WITH _ID_SEQUEN
						REPLACE RIE_SEQUE WITH _SEQUENZA
						
					NEXT					
					
				ELSE
					
					
		*****!!!!!!!!!!!!!!*****************
		***** SE CI SONO ANCORA ROTOLI CHE NON SONO STATI ACCOPPIATO ALLORA DEVO AGGIUNGERE ALLA SEQUENZA LE SINGOLE FASCE DI OGNI
		***** ROTOLO NON ACCOPPIATO
		******************
		***** COME IN QUESTO PEZZO DI CODICE
		*****
					
					*** INSERISCE UNA SEQUENZA CHE RACCOGLIE I GRUPPI DI BARRE CHE 
					*** GIA DALL'INIZIO NON SONO RIUSCITO AD ACCOPPIARE
					***
					
					_ID_TAPPETO=SYS(2015)
					_ID_SEQUEN=SYS(2015)
					

					
					SELECT SEQUENZE
					APPEND BLANK
					REPLACE ID_SEQUEN WITH _ID_SEQUEN
					REPLACE STEP      WITH _STEP
					REPLACE FINITA    WITH .T.
					
					FOR _INDICE_SEQUENZE=1 TO _NUMERO_GRUPPI
						REPLACE LUNGH     WITH ARRAY_GRUPPI_LUNGHEZZA[_INDICE_SEQUENZE]
						REPLACE SEQUENZA  WITH ALLTRIM(SEQUENZA)+ALLTRIM(STR(ARRAY_GRUPPI_ALTEZZA[_INDICE_SEQUENZE]))+"+0L"+ALLTRIM(STR(ARRAY_GRUPPI_LUNGHEZZA[_INDICE_SEQUENZE]))+"*"+ALLTRIM(STR(ARRAY_GRUPPI_NUMROT[_INDICE_SEQUENZE]))+"/"
						*** FABIANO 02/02/2009 - MODIFICA PER RIPORTARE SUL TAPPETO TUTTE LE FASCE - PRIMA SE NE PERDEVA ALCUNE PERCHE' LE VEDEVA COME LUNGHEZZA ZERO
						***
						***REPLACE SEQUENZA  WITH ALLTRIM(SEQUENZA)+ALLTRIM(STR(ARRAY_GRUPPI_ALTEZZA[_INDICE_SEQUENZE]))+"+0*"ALLTRIM(STR(ARRAY_GRUPPI_NUMROT[_INDICE_SEQUENZE]))+"/"
					NEXT
					
					_SEQUENZA_MEMORIZZATA=SEQUENZA

					_ID_TAPPETO=SYS(2015)
					FOR _INDICE_RIEPILOGO=1 TO _NUMERO_GRUPPI
						SELECT RIEPILOGO 
						APPEND BLANK 
						REPLACE RIE_TAPPE WITH _ID_TAPPETO
						
						REPLACE RIE_ALTEZ WITH ARRAY_GRUPPI_ALTEZZA[_INDICE_RIEPILOGO]
					    IF _CICLO=1
				    		REPLACE RIE_ALTEZ WITH RIE_ALTEZ+SCARTO_LATERALE
					    ENDIF
						REPLACE RIE_SALTE WITH STR_FILL_ZERO(RIE_ALTEZ,5)
	
						REPLACE RIE_LUNGH WITH ARRAY_GRUPPI_LUNGHEZZA[_INDICE_RIEPILOGO]
						REPLACE RIE_NBARR WITH ARRAY_GRUPPI_NUMROT[_INDICE_RIEPILOGO]
						REPLACE RIE_LUNFA WITH RIE_NBARR*RIE_LUNGH
						
						REPLACE RIE_IDSEQ WITH _ID_SEQUEN
						REPLACE RIE_SEQUE WITH _SEQUENZA_MEMORIZZATA
					NEXT					
			
				ENDIF

				IF _NUMERO_GRUPPI<=_NUMERO_GRUPPI_INIZIALE 
					_CONTA_SEQUENZE_CON_FASCIA_MINIMA_PER_ROTTURA_APPROSSIMATA=_CONTA_SEQUENZE_CON_FASCIA_MINIMA_PER_ROTTURA_APPROSSIMATA+1
				ENDIF
								
				SELECT SEQUENZE
				
				EXIT
			ENDIF
			
		ENDIF
				
		_SCELTO_PROSSIMO_STEP=.F.
		
		_SEQUENZA_MADRE =_SEQUENZA
		_SEQUENZA_FIGLIA=""
		
		SELECT SEQUENZE
		SET ORDER TO SEQUENZA
		SEEK _SEQUENZA_MADRE
		*** CANCELLO LA SEQUENZA MADRE
		*** CHE MI HA PORTATO A QUESTO LIVELLO
		IF FOUND() AND STEP=_STEP-1
			DELETE
		ENDIF

		
		FOR X=1 TO _NUMERO_GRUPPI
			FOR Y=1 TO _NUMERO_GRUPPI
				IF ARRAY_COMBINAZIONI[X,Y]="S"
				
					_SEQUENZA=_SEQUENZA_MADRE+ALLTRIM(STR(ARRAY_GRUPPI_ALTEZZA[X]))+"+"+ALLTRIM(STR(ARRAY_GRUPPI_ALTEZZA[Y]))+"L"+ALLTRIM(STR(ARRAY_GRUPPI_LUNGHEZZA[Y]))+"*"+ALLTRIM(STR(ARRAY_NUMROT_COMBINAZIONI[X,Y]))+"/"
					
					SELECT SEQUENZE
					SET ORDER TO SEQUENZA
					GO TOP
					
					_TROVATA_SEQUENZA=.F.
					_SEQUENZA_FINITA =.F.
					_SEQUENZA_CON_FIGLIE=.F.
					_TUTTE_SEQUENZE_FIGLIE_FINITE=.T.
					
					DO WHILE !EOF()
					
						IF DELETED()
							SKIP
							LOOP
						ENDIF

						*** LA SEQUENZA E' GIA' STATA SCRITTA
						IF ALLTRIM(SEQUENZA)=ALLTRIM(_SEQUENZA)
							_TROVATA_SEQUENZA=.T.
							IF FINITA
								_SEQUENZA_FINITA=.T.
							ENDIF
						ENDIF	
								
						*** CONTROLLO SE LA SEQUENZA HA GIA' DELLE FIGLIE
						*** NON TROVERO' IN TAL CASO LA SEQUENZA STESSA
						*** MA TUTTE LE SUE FIGLIE 
						*** PERCHE' LA MADRE E' STATA CANCELLATA
						***
						IF ALLTRIM(_SEQUENZA)=SUBSTR(ALLTRIM(SEQUENZA),1,LEN(ALLTRIM(_SEQUENZA)))
							_SEQUENZA_CON_FIGLIE=.T.
							*** SE ANCHE UNA SOLA DELLE SUE FIGLIE
							*** NON E' FINITA
							*** ALLORA DEVO ANDARE FINO IN FONDO ALMENO CON QUELLA
							***
							
							SELECT SEQUENZE
							_POSIZIONE=RECNO()
							
							_TUTTE_SEQUENZE_FIGLIE_FINITE=VERIFICA_SE_LE_FIGLIE_SONO_FINITE(_SEQUENZA)							
							
							SELECT SEQUENZE
							GO _POSIZIONE
							
						ENDIF	
						
						IF _TROVATA_SEQUENZA OR _SEQUENZA_CON_FIGLIE
							EXIT
						ENDIF
						
						SELECT SEQUENZE
						SKIP
					ENDDO

					IF (_TROVATA_SEQUENZA OR _SEQUENZA_CON_FIGLIE) = .F.
						SELECT SEQUENZE
						APPEND BLANK
						
						_ID_SEQUEN=SYS(2015)
						REPLACE ID_SEQUEN WITH _ID_SEQUEN
						REPLACE STEP      WITH _STEP
						REPLACE FINITA    WITH .F.
						REPLACE SEQUENZA  WITH _SEQUENZA
						REPLACE LUNGH     WITH ARRAY_GRUPPI_LUNGHEZZA[X]
					ENDIF
										
					IF _SEQUENZA_FINITA
						LOOP
					ENDIF
					
					IF _SEQUENZA_CON_FIGLIE AND _TUTTE_SEQUENZE_FIGLIE_FINITE
						LOOP
					ENDIF
					
					IF !_SCELTO_PROSSIMO_STEP
				
						CONTINUA(X,Y)	
						
						_SEQUENZA_FIGLIA=_SEQUENZA
						_SCELTO_PROSSIMO_STEP=.T.
					ENDIF

				ENDIF
			NEXT
		NEXT
		
		_SEQUENZA=_SEQUENZA_FIGLIA
		SELECT SEQUENZE
		
	ENDDO

	IF VERIFICA_SE_CI_SONO_ANCORA_SEQUENZE_DA_PROVARE() = .F.
		EXIT
	ENDIF
	
ENDDO

DO RIEPILOGO_SEQUENZE_OTTENUTE

DO SELEZIONA_TAPPETO_DA_VISUALIZZARE

SELECT OTTIMALE
SET FILTER TO OTT_IDSEQ= PUB_ID_SEQUEN
GO TOP

SELECT RIEPILOGO
GO TOP

SELECT SEQUENZE
GO TOP

SELECT SEQUENZE_DD
GO TOP

RELEASE _NUMERO_GRUPPI

* FINE PROCEDURE OTTIMIZZA_ROTOLI_IN_ALTEZZA
**********************************************************



**********************************************************
PROCEDURE VERIFICA_SE_CI_SONO_ANCORA_ROTOLI_DA_COMBINARE_IN_QUESTA_SEQUENZA
**********************************************************
LPARAMETERS _NUMERO_GRUPPI

_CI_SONO_ANCORA_ROTOLI_DA_ELABORARE=.F.


*** FACCIO UN TEST SU A5)
*** PER CAPIRE SE SONO ARRIVATO ALLA FINE DI UN PERCORSO
***
FOR X=1 TO _NUMERO_GRUPPI
	FOR Y=1 TO _NUMERO_GRUPPI
	
		*** SE HO RESTO DIVERSO DA ZERO VADO AVANTI AD ELABORARE
		*** OTTENENDO LA NUOVA MATRICE
		***
		IF ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y]>0
			_CI_SONO_ANCORA_ROTOLI_DA_ELABORARE=.T.
		ENDIF
		
		*** SE HO RESTO UGUALE A ZERO 
		*** E I ROTOLI CHE CONFRONTO HANNO LA STESSA ALTEZZA
		*** VADO AVANTI AD ELABORARE
		***
		IF ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y]=0 AND ARRAY_COMBINAZIONI[X,Y]="S"
			
			IF ARRAY_GRUPPI_ALTEZZA[X]=ARRAY_GRUPPI_ALTEZZA[Y]
				_CI_SONO_ANCORA_ROTOLI_DA_ELABORARE=.T.
			ENDIF
		ENDIF
		
		*** DOVREBBE ESSERE L'ULTIMO GIRO PRIMA DI CHIUDERE
		***
		
	NEXT
NEXT

RETURN 	_CI_SONO_ANCORA_ROTOLI_DA_ELABORARE	
		
* FINE PROCEDURE VERIFICA_SE_CI_SONO_ANCORA_ROTOLI_DA_COMBINARE_IN_QUESTA_SEQUENZA
**********************************************************



**********************************************************
PROCEDURE VERIFICA_SE_CI_SONO_ANCORA_SEQUENZE_DA_PROVARE
**********************************************************
LOCAL _CI_SONO_ANCORA_SEQUENZE_DA_PROVARE

_CI_SONO_ANCORA_SEQUENZE_DA_PROVARE=.F.

SELECT SEQUENZE
GO TOP
DO WHILE !EOF()
	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	IF !FINITA
		_CI_SONO_ANCORA_SEQUENZE_DA_PROVARE=.T.
	ENDIF
	SKIP
ENDDO

RETURN _CI_SONO_ANCORA_SEQUENZE_DA_PROVARE
	
*FINE PROCEDURE VERIFICA_SE_CI_SONO_ANCORA_SEQUENZE_DA_PROVARE
**********************************************************

	
**********************************************************
PROCEDURE VERIFICA_SE_LE_FIGLIE_SONO_FINITE
**********************************************************
PARAMETERS _SEQUENZA_DA_VERIFICARE

LOCAL _TUTTE_LE_FIGLIE_SONO_FINITE

_TUTTE_LE_FIGLIE_SONO_FINITE=.T.

SELECT SEQUENZE
GO TOP
DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	*** CONTROLLO SOLO LE FIGLIE DI 
	*** _SEQUENZA_DA_VERIFICARE
	***
	IF ALLTRIM(_SEQUENZA_DA_VERIFICARE)<>SUBSTR(ALLTRIM(SEQUENZA),1,LEN(ALLTRIM(_SEQUENZA_DA_VERIFICARE)))
		SKIP
		LOOP
	ENDIF
	
	IF !FINITA
		_TUTTE_LE_FIGLIE_SONO_FINITE=.F.
	ENDIF
	
	SKIP
ENDDO
	
RETURN _TUTTE_LE_FIGLIE_SONO_FINITE

* FINE PROCEDURE VERIFICA_SE_LE_FIGLIE_SONO_FINITE
**********************************************************
							
				
**********************************************************
PROCEDURE CONTINUA
**********************************************************

PARAMETERS _X,_Y

LOCAL X,Y

X=_X
Y=_Y

IF ARRAY_COMBINAZIONI[X,Y]<>"S"
	RETURN .F.
ENDIF


SELECT GRUPPI
ZAP


*** AGGIUNGO UN RECORD PER LA COMBINAZIONE DI ROTOLI OTTENUTA
APPEND BLANK
REPLACE ALTEZ WITH ARRAY_FASCIA_COMBINAZIONI[X,Y]
REPLACE LUNGH WITH ARRAY_GRUPPI_LUNGHEZZA[X]
REPLACE NUMROT WITH ARRAY_NUMROT_COMBINAZIONI[X,Y]

 
*** AGGIUNGO UN RECORD PER I ROTOLI RESTANTI DALLA COMBINAZIONE
IF ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y]>0
	APPEND BLANK
	REPLACE ALTEZ WITH ARRAY_ALTEZZA_RESTANTE[X,Y]
	REPLACE LUNGH WITH ARRAY_GRUPPI_LUNGHEZZA[X]
	REPLACE NUMROT WITH ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y]
ENDIF

*** AGGIUNGO TANTI RECORD QUANTI SONO TUTTI GLI ALTRI ROTOLI NON TOCCATI
FOR I=1 TO _NUMERO_GRUPPI
	
	IF I=_X OR I=_Y
		LOOP
	ENDIF

	APPEND BLANK
	REPLACE ALTEZ WITH ARRAY_GRUPPI_ALTEZZA[I]
	REPLACE LUNGH WITH ARRAY_GRUPPI_LUNGHEZZA[I]
	REPLACE NUMROT WITH ARRAY_GRUPPI_NUMROT[I]

NEXT

RETURN .T.

* FINE PROCEDURE CONTINUA
**********************************************************


**********************************************************
PROCEDURE CREA_CURSORI_PER_OTTIMIZZAZIONE
**********************************************************

CREATE CURSOR RIEPILOGO (;
	RIE_IDSEQ C(10),;
	RIE_TAPPE C(30),;
	RIE_ALTEZ N(5),;
	RIE_SALTE C(5),;
	RIE_LUNGH N(5),;
	RIE_NBARR N(5),;
	RIE_LUNFA N(10),;
	RIE_SEQUE C(120))
INDEX ON RIE_TAPPE TAG RIE_TAPPE
INDEX ON RIE_SALTE+RIE_TAPPE TAG RIE_SALTE 
INDEX ON RIE_IDSEQ TAG RIE_IDSEQ
	
CREATE CURSOR OTTIMALE (;
	OTT_IDSEQ C(10),;
	OTT_TAPPE  C(30),;
	OTT_PROGR  N(15),;
	OTT_NUMFA  N(5),;
	OTT_NBARR  N(5),;
	OTT_SNUMFA C(5),;
	OTT_HMAX   N(5),;
	OTT_SHMAX  C(5),;
	OTT_ML     N(10),;
	OTT_MQ     N(10),;
	OTT_KG     N(10))
INDEX ON OTT_TAPPE TAG OTT_TAPPE
INDEX ON OTT_NUMFA TAG OTT_NUMFA 
INDEX ON OTT_SNUMFA+OTT_SHMAX+OTT_TAPPE TAG OTT_SNUMFA 

CREATE CURSOR SEQUENZE (;
	ID_SEQUEN C(10),;
	STEP      N(5),;
	FINITA    L,;
	LUNGH     N(5),;
	SEQUENZA  C(120))
INDEX ON SEQUENZA TAG SEQUENZA	
INDEX ON ID_SEQUEN TAG ID_SEQUEN	
	
CREATE CURSOR SEQUENZE_DD (;
	ID_SEQUEN   C(10),;
	PASSO       C(5),;
	ALTEZ       N(5),;
	LUNGH       N(5),;
	NUMBARRE    N(5))
INDEX ON ID_SEQUEN+PASSO TAG ID_SEQUEN	
							
* FINE PROCEDURE CREA_CURSORI_PER_OTTIMIZZAZIONE
**********************************************************


**********************************************************
PROCEDURE COMPILO_LA_MATRICE_DEI_ROTOLI
**********************************************************
LPARAMETERS _NUMERO_GRUPPI


***   COMPILO UNA MATRICE AD ESEMPIO 3 X 3 CHE SONO LE TRE ALTEZZE DIVERSE DI ROTOLI CHE HO SCELTO IN BASE AGLI ORDINI
***
***                  h=1010    |  h=1210   |  H=1170  
***               N.ROT=87     | N.ROT=45  | N.ROT=46  
***   ================================================
***   h=1010    | A2) 2080     |           |
***   N.ROT=87  | A3)  43      |    A1=N   |  A1=N 
***             |		       |           |                
***             | A4) 1010     |           |                
***             | A5)  1       |           |                
***   ================================================
***   h=1210    | A2) 2280     |           |
***   N.ROT=45  | A3)  45      |           |
***             |		       |    A1=N   |    A1=N              
***             | A4) 1010     |           |                
***             | A5)  42      |           |                
***   ================================================
***   h=1170    | A2) 2240     |           |
***   N.ROT=46  | A3)  46      |           |
***             |		       |    A1=N   |    A1=N               
***             | A4) 1170     |           |                
***             | A5)  41      |           |                
***   ================================================

		
*** PREPARO 3 ARRAY CON UNA DIMENSIONE OSSIA DEI VETTORI
*** PER CONTENERE I SINGOLI RAGGRUPPAMENTI E DARE A LORO DEGLI INDICI NUMERICI

PUBLIC ARRAY_GRUPPI_ALTEZZA[_NUMERO_GRUPPI]
PUBLIC ARRAY_GRUPPI_NUMROT[_NUMERO_GRUPPI]
PUBLIC ARRAY_GRUPPI_LUNGHEZZA[_NUMERO_GRUPPI]
PUBLIC ARRAY_GRUPPI_GRP_PROD[_NUMERO_GRUPPI]

*** PREPARO 5 ARRAY CON DUE DIMENSIONI OSSIA DELLE MATRICI 
*** PER CONTENERE I DATI DELLA TABELLA

PUBLIC ARRAY_COMBINAZIONI[_NUMERO_GRUPPI,_NUMERO_GRUPPI]   			&& A1) S/N SE LA CASELLINA E' DA CONSIDERARE OPPURE NO
																	&& VALE N=NO SE L'ALTEZZA OTTENUTA NON CI STA NELLA SPALMATRICE
																	&& OPPURE
																	&& SE NON CONSIDERO LA COMBINAZIONE PERCHE' E' UN DOPPIONE DI UNA COMBINAZIONE CHE GIA' 
																	&& CONSIDERO IN UN'ALTRA CASELLA
																		
PUBLIC ARRAY_FASCIA_COMBINAZIONI[_NUMERO_GRUPPI,_NUMERO_GRUPPI]		&& A2) L'ALTEZZA RISULTANTE DELLA COMBINAZIONE CHE HO PROVATO A SOMMARE
PUBLIC ARRAY_NUMROT_COMBINAZIONI[_NUMERO_GRUPPI,_NUMERO_GRUPPI]		&& A3) NUMERO DI ROTOLI DELLA COMBINAZIONE CHE E' IL MINIMO TRA I NUMERI DI ROTOLI DELLE ALTEZZE CHE COMBINO
PUBLIC ARRAY_ALTEZZA_RESTANTE[_NUMERO_GRUPPI,_NUMERO_GRUPPI]		&& A4) ALTEZZA DEI ROTOLI CHE HO AVANZATO PERCHE' NON SI POTEVANO COMBINARE, ERANO IN PIU' RISPETTO AGLI ALTRI
PUBLIC ARRAY_NUMROT_ALTEZZA_RESTANTE[_NUMERO_GRUPPI,_NUMERO_GRUPPI] && A5) NUMERO DEI ROTOLI CHE HO AVANZATO PERCHE' NON SI POTEVANO COMBINARE, ERANO IN PIU' RISPETTO AGLI ALTRI

*** inizializzo tutto a vuoto
***
FOR X=1 TO _NUMERO_GRUPPI
	ARRAY_GRUPPI_ALTEZZA[X]=0
	ARRAY_GRUPPI_LUNGHEZZA[X]=0
	ARRAY_GRUPPI_NUMROT[X]=0
	ARRAY_GRUPPI_GRP_PROD[X]=""
	FOR Y=1 TO _NUMERO_GRUPPI
		ARRAY_COMBINAZIONI[X,Y]=""
		ARRAY_NUMROT_COMBINAZIONI[X,Y]=0
		ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y]=0
		ARRAY_ALTEZZA_RESTANTE[X,Y]=0
		ARRAY_FASCIA_COMBINAZIONI[X,Y]=0
	NEXT
NEXT

SELECT GRUPPI
SET ORDER TO ALTEZ
GO TOP

_INDICE_GRUPPI_ALTEZZA=0

DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	_INDICE_GRUPPI_ALTEZZA=_INDICE_GRUPPI_ALTEZZA+1
	
	ARRAY_GRUPPI_ALTEZZA[_INDICE_GRUPPI_ALTEZZA]=ALTEZ
	ARRAY_GRUPPI_LUNGHEZZA[_INDICE_GRUPPI_ALTEZZA]=LUNGH
	ARRAY_GRUPPI_NUMROT[_INDICE_GRUPPI_ALTEZZA]=NUMROT
	ARRAY_GRUPPI_GRP_PROD[_INDICE_GRUPPI_ALTEZZA]=GRP_PROD
	
	SKIP
ENDDO
		
* FINE PROCEDURE COMPILO_LA_MATRICE_DEI_ROTOLI	
**********************************************************



**********************************************************
PROCEDURE METTO_SI_E_NO_NELLE_CASELLE_DA_ELABORARE
**********************************************************

LPARAMETERS _NUMERO_GRUPPI

FOR X=1 TO _NUMERO_GRUPPI
	FOR Y=1 TO _NUMERO_GRUPPI
	
		*** A1)
		*** non considero le permutazione della stessa combinazione
		*** se considero 1010 x 1210 allora non mi interessa provare 
		*** anche 1210 x 1010
		*** 
		IF ALLTRIM(ARRAY_COMBINAZIONI[Y,X])="S"
			ARRAY_COMBINAZIONI[X,Y]="DOPPIONE"
		ELSE
			ARRAY_COMBINAZIONI[X,Y]="S"
		ENDIF
		
* 		*** A1)
* 		*** 
* 		IF ARRAY_COMBINAZIONI[X,Y]="S"
* 			IF ARRAY_GRUPPI_ALTEZZA[X]=0 AND ARRAY_GRUPPI_ALTEZZA[Y]=0
* 				ARRAY_COMBINAZIONI[X,Y]="ALTEZZA-ZERO"
* 			ELSE
* 				ARRAY_COMBINAZIONI[X,Y]="S"
* 			ENDIF
* 		ENDIF		
* 				
		*** A1)
		*** 
		IF ARRAY_COMBINAZIONI[X,Y]="S"
			IF ARRAY_GRUPPI_LUNGHEZZA[X]=ARRAY_GRUPPI_LUNGHEZZA[Y]
				ARRAY_COMBINAZIONI[X,Y]="S"
			ELSE
				***WAIT WINDOW STR(ARRAY_GRUPPI_LUNGHEZZA[X]) + "  "+STR(ARRAY_GRUPPI_LUNGHEZZA[Y])
				ARRAY_COMBINAZIONI[X,Y]="LUNGHEZZA-DIVERSA"
			ENDIF
		ENDIF		
		
		*** A1)
		*** 
		IF ARRAY_COMBINAZIONI[X,Y]="S"
			IF ARRAY_GRUPPI_GRP_PROD[X]=ARRAY_GRUPPI_GRP_PROD[Y]
				ARRAY_COMBINAZIONI[X,Y]="S"
			ELSE
				***WAIT WINDOW ARRAY_GRUPPI_GRP_PROD[X]+ "  "+ARRAY_GRUPPI_GRP_PROD[Y]
				ARRAY_COMBINAZIONI[X,Y]="GRUPPO-PRODUTTIVO-DIVERSO"
			ENDIF
		ENDIF		
		
		*** A1)
		*** se la somma delle altezze per una combinazione č fuori dalla
		*** altezza massima della bobina, non considero questa combinazione
		*** 
		IF ARRAY_COMBINAZIONI[X,Y]="S"
			IF ARRAY_GRUPPI_ALTEZZA[X]+ARRAY_GRUPPI_ALTEZZA[Y]<=ALTEZZA_BOBINA-SCARTO_LATERALE
				ARRAY_COMBINAZIONI[X,Y]="S"
			ELSE
				ARRAY_COMBINAZIONI[X,Y]="H-MAX"
			ENDIF
		ENDIF

		*** se le altezze sono uguali ma esiste un solo rotolo
		*** non si possono accoppiare
		*** 
		IF ARRAY_COMBINAZIONI[X,Y]="S"
			IF (ARRAY_GRUPPI_ALTEZZA[X]=ARRAY_GRUPPI_ALTEZZA[Y]) AND (ARRAY_GRUPPI_NUMROT[X]=1)
				ARRAY_COMBINAZIONI[X,Y]="1-ROTOLO"
			ENDIF
		ENDIF
		
		*** se la somma delle altezze per una combinazione č fuori dalla
		*** altezza massima della bobina, non considero questa combinazione
		*** 
		IF ALLTRIM(ARRAY_COMBINAZIONI[X,Y])<>"S"
			LOOP
		ENDIF
		
	
		*** A2)
		***	
		ARRAY_FASCIA_COMBINAZIONI[X,Y]= ARRAY_GRUPPI_ALTEZZA[X]+ARRAY_GRUPPI_ALTEZZA[Y]+SCARTO_LATERALE
		
		*** se le altezze da combinare sono diverse
		IF X<>Y
			ARRAY_NUMROT_COMBINAZIONI[X,Y]	   = MIN(ARRAY_GRUPPI_NUMROT[X],ARRAY_GRUPPI_NUMROT[Y])
			ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y] = MAX(ARRAY_GRUPPI_NUMROT[X],ARRAY_GRUPPI_NUMROT[Y])-ARRAY_NUMROT_COMBINAZIONI[X,Y]
			
			IF ARRAY_GRUPPI_NUMROT[X]=ARRAY_GRUPPI_NUMROT[Y]
				ARRAY_NUMROT_ALTEZZA_RESTANTE=0
				ARRAY_ALTEZZA_RESTANTE[X,Y]=0
			ELSE
				IF ARRAY_GRUPPI_NUMROT[X]>ARRAY_GRUPPI_NUMROT[Y]
					ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y]=ARRAY_GRUPPI_NUMROT[X]-ARRAY_GRUPPI_NUMROT[Y]
					ARRAY_ALTEZZA_RESTANTE[X,Y]=ARRAY_GRUPPI_ALTEZZA[X]
				ELSE
					ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y]=ARRAY_GRUPPI_NUMROT[Y]-ARRAY_GRUPPI_NUMROT[X]
					ARRAY_ALTEZZA_RESTANTE[X,Y]=ARRAY_GRUPPI_ALTEZZA[Y]
				ENDIF
			ENDIF
			
		*** se le altezze da combinare sono uguali
		ELSE
			ARRAY_NUMROT_COMBINAZIONI[X,Y]= INT(ARRAY_GRUPPI_NUMROT[X]/2)
			ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y]= ARRAY_GRUPPI_NUMROT[X]%2
			IF ARRAY_NUMROT_ALTEZZA_RESTANTE[X,Y]>0
				ARRAY_ALTEZZA_RESTANTE[X,Y]=ARRAY_GRUPPI_ALTEZZA[X]
			ENDIF
		ENDIF
		

	NEXT
NEXT
		
* FINE PROCEDURE METTO_SI_E_NO_NELLE_CASELLE_DA_ELABORARE
**********************************************************		


