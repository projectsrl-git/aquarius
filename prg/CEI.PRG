PROCEDURE CHK
PUSH KEY CLEAR
IF SELEZIONE='=>'
   REPLACE SELEZIONE WITH ' '
ELSE
   REPLACE SELEZIONE WITH '=>'
ENDIF
POP KEY
KEYBOARD "{RIGHTARROW}+{LEFTARROW}"
RETURN


***VERIFICA LA CLASSE DOGANALE
FUNCTION VEDIART
PARA FG

SELE=SELECT()
SELECT U_ART_PR
SET ORDER TO U_ART_CO

SEEK PUB_CODSOC + FG
IF FOUND()
   IF EMPTY(ART_CLDOG)
	  RIT=MSGBOX("MANCA LA CLASSE DOGANALE;DELL'ARTICOLO :"+FG+CHR(13)+"FORZO LA CLASSE :"+V_CLDOG,'ATTENZIONE',31)
 	  RET=V_CLDOG
   ELSE
      RET=ART_CLDOG
   ENDIF
  * IF ART_PESOUM = 0
  *	  RIT=MSGBOX("IL PESO DELL'ARTICOLO "+FG+CHR(13)+"= ZERO ",'ATTENZIONE',31)
  *    V_PESO = 0
  * ELSE
  *    V_PESO = ART_PESOUM
  * ENDIF

ELSE
   RET=V_CLDOG
   RIT=MSGBOX("MANCA LA CLASSE DOGANALE;DELL'ARTICOLO :"+FG+CHR(13)+"FORZO LA CLASSE :"+V_CLDOG,'ATTENZIONE',31)
ENDIF


SELECT(SELE)

RETURN(RET)


