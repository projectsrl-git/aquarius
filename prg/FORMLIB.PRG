		          XYZ_DTS = DATA_SCAD
		      ENDIF
		   ENDDO
           x_soci = "ban_codsoc = '" + PUB_CODSOC + "'"
 	       x_codi = "ban_codban = '" + ALLTRIM(XYZ_BAN) + "'"
		   x_cond = x_soci + " and " + x_codi
           Csql   = "select * from u_ban_an where " + x_cond + " order by ban_codsoc,ban_codban"
           IF !ExecCommand(cSql,"cur_banca")
              return(.f.)
           ENDIF
           SELECT cur_banca
           GO TOP
           IF EOF()
           ELSE
  		      XYZ_DCB = ALLTRIM(XYZ_DCB) +  " B." + XYZ_BAN + "-" + ALLTRIM(BAN_DESBAN)
           ENDIF
 		ENDIF

ENDCASE