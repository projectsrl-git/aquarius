
Parameters V_COMANDO

if Parameters()=0
   V_COMANDO=""
endif

** Impostazione SET Iniziali
SET AUTOSAVE ON
SET CENTURY ON
SET CLOCK STATUS
SET DATE TO dmy
SET DELETED ON
SET ESCAPE OFF
SET EXACT ON
SET EXCLUSIVE OFF
SET HOURS TO 24
SET NEAR ON
SET REPROCESS TO AUTOMATIC
SET SAFETY OFF
SET TALK OFF
SET MULTILOCKS ON

** Aggancio librerie di procedure esterne
SET PROCEDURE TO WINLIB ADDITIVE
SET PROCEDURE TO UTILITA ADDITIVE
SET PROCEDURE TO SQLLIB 	ADDITIVE

SET PROCEDURE TO PRG\DISTINTA_BASE_LIB	ADDITIVE  && ERASMO - 19/10/2012
SET PROCEDURE TO PRG\LOCAZIONILIB		ADDITIVE  && ERASMO - 13/12/2012

PUBLIC pub_sqlhd
pub_sqlhd=0

** Impostazione tasti per operazione immediate
ON KEY LABEL "CTRL+Q" DO STOPALL
ON KEY LABEL "CTRL+D" ACTIVATE WINDOW DEBUG
ON READERROR DO ZErrore


Do Form MUT00 With V_COMANDO

RETURN


******************************************
FUNCTION EDITBOX
******************************************
PARAMETERS _VALORE,_CAPTION

IF PCOUNT() >= 1
ELSE
	_VALORE = ""
ENDIF

IF PCOUNT() >= 2
ELSE
	_CAPTION = "Inserire il testo"
ENDIF

PUBLIC _VARIABILE_MEMO AS MEMO, _CONFERMA_TESTO AS Boolean
_VARIABILE_MEMO = _VALORE
_CONFERMA_TESTO = .F.

DO FORM FORM\EDITBOX WITH _CAPTION

IF _CONFERMA_TESTO
	RETURN _VARIABILE_MEMO
ELSE
	RETURN .F.
ENDIF

ENDFUNC


