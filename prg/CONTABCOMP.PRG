									DTSCAD WITH _PARTITA_DTSCAD ,;
									TOP	   WITH _PARTITA_TOP	,;
									NPART  WITH _PARTITA_NPART  ,;
									DARE   WITH _PARTITA_DARE	,;
									AVERE  WITH _PARTITA_AVERE	,;
									SALDO  WITH _PARTITA_SALDO	,;
									COSATRATTA WITH _PARTITA_COSATRATTA ,;
									GRADOIMPOR WITH _PARTITA_GRADOIMPOR ,;
									FORMAPAGAM WITH _PARTITA_FORMAPAGAM ,;
									TIPOCONTRA WITH _PARTITA_TIPOCONTRA ,;
									CODACQ 	   WITH _PARTITA_CODACQ 	,;
									PRIPAGA    WITH _PARTITA_PRIPAGA    ,;
									NUMEROFATT WITH _PARTITA_NUMEROFATT,;
									DATAFATT   WITH _PARTITA_DATAFATT,;
									DESMOV WITH _DESCRIZIONE_PAGAMENTO			
				
							APPEND BLANK
							REPLACE	CONTO  WITH _CONTROPARTITA_CONTO 	,;
									DESCRI WITH _CONTROPARTITA_DESCRI	,;
									CLIFOR WITH _CONTROPARTITA_CLIFOR	,;
									DTSCAD WITH _PARTITA_DTSCAD ,;
									TOP	   WITH _CONTROPARTITA_TOP		,;
									NPART  WITH _CONTROPARTITA_NPART    ,;
									DARE   WITH _PARTITA_AVERE			,;
									AVERE  WITH _PARTITA_DARE			,;
									SALDO  WITH _PARTITA_AVERE-_PARTITA_DARE,;
									COSATRATTA WITH _PARTITA_COSATRATTA ,;
									GRADOIMPOR WITH _PARTITA_GRADOIMPOR ,;
									FORMAPAGAM WITH _PARTITA_FORMAPAGAM ,;
									TIPOCONTRA WITH _PARTITA_TIPOCONTRA ,;
									CODACQ 	   WITH _PARTITA_CODACQ 	,;
									PRIPAGA    WITH _PARTITA_PRIPAGA    ,;
									NUMEROFATT WITH _PARTITA_NUMEROFATT,;
									DATAFATT   WITH _PARTITA_DATAFATT,;
									DESMOV WITH _DESCRIZIONE_PAGAMENTO
													
							_NUMERO_MOVIMENTI=_NUMERO_MOVIMENTI+1
						ENDIF
						
						*** QUELLO AVANZA LO PAGO
						SELECT CPARTCOMP
	
						_PARTITA_CONTO 	=CONTO
						_PARTITA_DESCRI	=DESCRI
						_PARTITA_CLIFOR	=CLIFOR		
						_PARTITA_TOP	=PUB_NCR
						_PARTITA_DARE	= AVERE - _TOT_DARE
						_PARTITA_AVERE	= 0
						_PARTITA_SALDO	=_PARTITA_DARE-_PARTITA_AVERE
		
						_CONTROPARTITA_CONTO 	=_CODICE_CONTO_BANCA
						_CONTROPARTITA_DESCRI	=_DESCRI_CONTO_BANCA
						_CONTROPARTITA_CLIFOR	=CLIFOR		
						_CONTROPARTITA_TOP		=PUB_NCR
						
						_DESCRIZIONE_PAGAMENTO="PAGAMENTO A CLIENTE"
						
						_TOT_DARE=0
						
					ENDIF
				
				ENDIF
					
			
				SELECT CESITOCOMP
				APPEND BLANK
				REPLACE	CONTO  WITH _PARTITA_CONTO 	,;
						DESCRI WITH _PARTITA_DESCRI	,;
						CLIFOR WITH _PARTITA_CLIFOR	,;
						DTSCAD WITH _PARTITA_DTSCAD ,;
						TOP	   WITH _PARTITA_TOP	,;
						NPART  WITH _PARTITA_NPART  ,;
						DARE   WITH _PARTITA_DARE	,;
						AVERE  WITH _PARTITA_AVERE	,;
						SALDO  WITH _PARTITA_SALDO	,;
						COSATRATTA WITH _PARTITA_COSATRATTA ,;
						GRADOIMPOR WITH _PARTITA_GRADOIMPOR ,;
						FORMAPAGAM WITH _PARTITA_FORMAPAGAM ,;
						TIPOCONTRA WITH _PARTITA_TIPOCONTRA ,;
						CODACQ 	   WITH _PARTITA_CODACQ 	,;
						PRIPAGA    WITH _PARTITA_PRIPAGA    ,;
						NUMEROFATT WITH _PARTITA_NUMEROFATT,;
						DATAFATT   WITH _PARTITA_DATAFATT,;
						DESMOV WITH _DESCRIZIONE_PAGAMENTO			
	
				APPEND BLANK
				REPLACE	CONTO  WITH _CONTROPARTITA_CONTO 	,;
						DESCRI WITH _CONTROPARTITA_DESCRI	,;
						CLIFOR WITH _CONTROPARTITA_CLIFOR	,;
						DTSCAD WITH _PARTITA_DTSCAD ,;
						TOP	   WITH _CONTROPARTITA_TOP		,;
						NPART  WITH _CONTROPARTITA_NPART    ,;
						DARE   WITH _PARTITA_AVERE		    ,;
						AVERE  WITH _PARTITA_DARE	        ,;
						COSATRATTA WITH _PARTITA_COSATRATTA ,;
						GRADOIMPOR WITH _PARTITA_GRADOIMPOR ,;
						FORMAPAGAM WITH _PARTITA_FORMAPAGAM ,;
						TIPOCONTRA WITH _PARTITA_TIPOCONTRA ,;
						CODACQ 	   WITH _PARTITA_CODACQ 	,;
						PRIPAGA    WITH _PARTITA_PRIPAGA    ,;
						NUMEROFATT WITH _PARTITA_NUMEROFATT,;
						DATAFATT   WITH _PARTITA_DATAFATT,;
						SALDO  WITH _PARTITA_AVERE-_PARTITA_DARE
						
										
						
				_NUMERO_MOVIMENTI=_NUMERO_MOVIMENTI+1
											
				SELECT CPARTCOMP
				SKIP
			ENDDO
	
			
	**************************************************************				
		CASE _CASO_DI_COMPENSAZIONE = "PAREGGIO"
	
			SELECT CPARTCOMP
			GO TOP
			DO WHILE !EOF()
			
				_DESCRIZIONE_PAGAMENTO=""
				
				_PARTITA_CONTO 	=""
				_PARTITA_DESCRI	=""
				_PARTITA_CLIFOR	=""		
				_PARTITA_TOP	=""
				_PARTITA_NPART  =NPART			
				_PARTITA_DARE	=AVERE
				_PARTITA_AVERE	=DARE
				_PARTITA_SALDO	=_PARTITA_DARE-_PARTITA_AVERE
				_PARTITA_DTSCAD =DTSCAD
				_PARTITA_COSATRATTA=COSATRATTA
				_PARTITA_GRADOIMPOR=GRADOIMPOR
				_PARTITA_FORMAPAGAM=FORMAPAGAM
				_PARTITA_TIPOCONTRA=TIPOCONTRA
				_PARTITA_CODACQ    =CODACQ 	  
				_PARTITA_PRIPAGA   =PRIPAGA   
				_PARTITA_NUMEROFATT=NUMEROFATT
				_PARTITA_DATAFATT  =DATAFATT
				
				_CONTROPARTITA_CONTO 	=""
				_CONTROPARTITA_DESCRI	=""
				_CONTROPARTITA_CLIFOR	=""		
				_CONTROPARTITA_TOP		=""
				_CONTROPARTITA_NPART    =_PARTITA_NPART
				
				IF CLIFOR="C"
				
				*** PARTITA CLIENTE
				
				*** LE PARTITE DEL CLIENTE SONO TUTTE DA CHIUDERE 
				*** COME COMPENSAZIONE
	
					_PARTITA_CONTO 	=CONTO
					_PARTITA_DESCRI	=DESCRI
					_PARTITA_CLIFOR	=CLIFOR		
					_PARTITA_TOP	=PUB_COMCLI
	
					_CONTROPARTITA_CONTO 	=_CODICE_CONTO_COMP_CLI
					_CONTROPARTITA_DESCRI	=""
					_CONTROPARTITA_CLIFOR	=CLIFOR		
					_CONTROPARTITA_TOP		=PUB_COMCLI
					
					_DESCRIZIONE_PAGAMENTO="COMPENSAZIONE AUTOMATICA PARI-01"
					
				ELSE
	
				*** PARTITA FORNITORE
	
				*** LE PARTITE DEL FORNITORE SONO TUTTE DA CHIUDERE 
				*** COME COMPENSAZIONE
					_PARTITA_CONTO 	=CONTO
					_PARTITA_DESCRI	=DESCRI
					_PARTITA_CLIFOR	=CLIFOR		
					_PARTITA_TOP	=PUB_COMFOR
		
					_CONTROPARTITA_CONTO 	=_CODICE_CONTO_COMP_FOR
					_CONTROPARTITA_DESCRI	=""
					_CONTROPARTITA_CLIFOR	=CLIFOR		
					_CONTROPARTITA_TOP		=PUB_COMFOR
					
					_DESCRIZIONE_PAGAMENTO="COMPENSAZIONE AUTOMATICA PARI-02"
				
				ENDIF 						
			
				SELECT CESITOCOMP
				APPEND BLANK
				REPLACE	CONTO  WITH _PARTITA_CONTO 	,;
						DESCRI WITH _PARTITA_DESCRI	,;
						CLIFOR WITH _PARTITA_CLIFOR	,;
						DTSCAD WITH _PARTITA_DTSCAD ,;
						TOP	   WITH _PARTITA_TOP	,;
						NPART  WITH _PARTITA_NPART  ,;
						DARE   WITH _PARTITA_DARE	,;
						AVERE  WITH _PARTITA_AVERE	,;
						SALDO  WITH _PARTITA_SALDO	,;
						COSATRATTA WITH _PARTITA_COSATRATTA ,;
						GRADOIMPOR WITH _PARTITA_GRADOIMPOR ,;
						FORMAPAGAM WITH _PARTITA_FORMAPAGAM ,;
						TIPOCONTRA WITH _PARTITA_TIPOCONTRA ,;
						CODACQ 	   WITH _PARTITA_CODACQ 	,;
						PRIPAGA    WITH _PARTITA_PRIPAGA    ,;
						NUMEROFATT WITH _PARTITA_NUMEROFATT,;
						DATAFATT   WITH _PARTITA_DATAFATT,;
						DESMOV WITH _DESCRIZIONE_PAGAMENTO			
	
				APPEND BLANK
				REPLACE	CONTO  WITH _CONTROPARTITA_CONTO 	,;
						DESCRI WITH _CONTROPARTITA_DESCRI	,;
						CLIFOR WITH _CONTROPARTITA_CLIFOR	,;
						DTSCAD WITH _PARTITA_DTSCAD ,;
						TOP	   WITH _CONTROPARTITA_TOP		,;
						NPART  WITH _CONTROPARTITA_NPART    ,;
						DARE   WITH _PARTITA_AVERE		    ,;
						AVERE  WITH _PARTITA_DARE	        ,;
						SALDO  WITH _PARTITA_AVERE-_PARTITA_DARE,;
						COSATRATTA WITH _PARTITA_COSATRATTA ,;
						GRADOIMPOR WITH _PARTITA_GRADOIMPOR ,;
						FORMAPAGAM WITH _PARTITA_FORMAPAGAM ,;
						TIPOCONTRA WITH _PARTITA_TIPOCONTRA ,;
						CODACQ 	   WITH _PARTITA_CODACQ 	,;
						PRIPAGA    WITH _PARTITA_PRIPAGA    ,;
						NUMEROFATT WITH _PARTITA_NUMEROFATT,;
						DATAFATT   WITH _PARTITA_DATAFATT,;
						DESMOV WITH _DESCRIZIONE_PAGAMENTO				
						
				_NUMERO_MOVIMENTI=_NUMERO_MOVIMENTI+1
											
				SELECT CPARTCOMP
				SKIP
			ENDDO
	
	ENDCASE
	
	WAIT WINDOW "Elaborazione compensazione terminata." NOWAIT
	*** FINE DEL CALCOLO DELLA DISTRIBUZIONE DELLA COMPENSAZIONE

ENDIF !PUB_FLAG_COMPENSAZIONE_GIA_CALCOLATA

SELECT CESITOCOMP
GO TOP
COUNT FOR DARE<>AVERE TO _NUMERO_MOVIMENTI
IF _NUMERO_MOVIMENTI>0
	_NUMERO_MOVIMENTI=INT(_NUMERO_MOVIMENTI/2)
ENDIF
	
PUB_FLAG_COMPENSAZIONE_GIA_CALCOLATA=.T.

IF !_FLAG_CONTABILIZZA
	RETURN
ENDIF

DO CONTABILIZZA_COMPENSAZIONI

RETURN 	_NUMERO_MOVIMENTI



**************************************************************************
FUNCTION CONTABILIZZA_COMPENSAZIONI
**************************************************************************

SELECT CESITOCOMP
GO TOP

_FLAG_CHIUDI=.T.
* IF MESSAGEBOX("Desideri effettuare solo la compensazione delle partite senza chiudere le partite che non compensano? ",292,'Compensazione partite') = 6  && RISPOSTA SI
*     _FLAG_CHIUDI=.F.
* ENDIF

_PRIMO_MOVIMENTO=.T.


DO WHILE !EOF()

    IF DARE=AVERE
    	SKIP
    	LOOP
    ENDIF   


	IF !_FLAG_CHIUDI
		IF (TOP!=PUB_COMFOR AND TOP!=PUB_COMCLI)
			SELECT CESITOCOMP
			SKIP
			LOOP
		ENDIF
	ENDIF
	
	IF !_PRIMO_MOVIMENTO
		_PAR_NUMPRO = CGE_NUMPRO          && AGGIORNA PARAMETRO NUM.INTERNO DI PRIMANOTA
		_PAR_INDICE = "INDICE CARICATO" && NON CREA INDICE
		_PAR_NREG   = ""                && MANTIENE IL NUMERO DI REGISTRAZIONE UTENTE
		_PAR_NDOC   = ""                && MANTIENE IL NUMERO DI REGISTRAZIONE PRECEDENTE
	ENDIF
	
	CGE_TOPX    = TOP
	CGE_CON		= CONTO
	CGE_DA 		= DARE
	CGE_AV 		= AVERE
	CGE_DESCO 	= DESCRI
	CGE_NPARF   = NPART
	CGE_COMM	= DESMOV		&& DESCRIZIONE DINAMICA DEL TIPO MOVIMENTO 
	CGE_DATASCAD = RIBALTA2(DTSCAD )
	
	CGE_FORMAPAGAMENTO    	= FORMAPAGAM
	CGE_COSATRATTA        	= COSATRATTA
	CGE_GRADOIMPORTANZA    	= GRADOIMPOR
	CGE_TIPOCONTRATTO    	= TIPOCONTRA 
	CGE_CODACQ            	= CODACQ
	CGE_PRIPAGA            	= PRIPAGA	

	
	IF CLIFOR="C"
		_PAR_CLIFOR="CLI"
				
        IF DARE>AVERE
		*** DARE CLIENTE
		
		ELSE
		*** AVERE CLIENTE

		ENDIF
		
	ELSE
	*** CONTABILIZZO MOVIMENTO FORNITORE
	
		_PAR_CLIFOR="FOR"
		
		IF DARE>AVERE
		*** DARE FORNITORE
			
		ELSE
		*** AVERE FORNITORE

		ENDIF
		
	ENDIF

	
	IF 	_PRIMO_MOVIMENTO
		DO CREA_MOVIMENTO WITH	_PAR_CLIFOR
	ELSE
		DO CREA_MOVIMENTO WITH	_PAR_CLIFOR,;
								_PAR_NUMPRO ,;  
								_PAR_INDICE ,;  
								_PAR_NREG   ,;
								_PAR_NDOC   
								
	ENDIF
	_PRIMO_MOVIMENTO=.F.
	
	SELECT CESITOCOMP
	SKIP
ENDDO

=AGGIORNA_TOTINDICE(CGE_NUMPRO ,_TOTALE_PRIMA_NOTA)


DO SALVAESITOCOMP   && SALVA IN U_CMP_TT IL CONTENUTO DI CESITOCOMP

*** FINE FUNCTION CONTABILIZZA_COMPENSAZIONI
**************************************************************************


**************************************************************************
FUNCTION CREA_MOVIMENTO
**************************************************************************
*
* impostare  
* CGE_CON	= CONTO
* CGE_DA 	= DARE
* CGE_AV 	= AVERE
* CGE_DESCO = DESCRI
* 
**************************************************************************
PARAMETERS _PAR_CLIFOR ,;
		   _PAR_NUMPRO ,;  
           _PAR_INDICE ,;  
           _PAR_NREG   ,;
           _PAR_NDOC   
            

_NPARF              = ""                  && SE NON IMPOSTATA CARICA AUTOMATICAMENTE CGE_NPARF

IF PCOUNT()>=1
	_CLIFOR				= _PAR_CLIFOR
ELSE
	RETURN
ENDIF


IF PCOUNT()>=2 
	_NUMPRO             = _PAR_NUMPRO          
ELSE
	_NUMPRO             = "CARICA"          && AGGIORNA PARAMETRO NUM.INTERNO DI PRIMANOTA
ENDIF

IF PCOUNT()>=3 
	_INDICE             = _PAR_INDICE          
ELSE
	_INDICE             = "CARICA"          && CREA INDICE
ENDIF

IF PCOUNT()>=4 
	_NREG               = _PAR_NREG          
ELSE
	_NREG               = "CARICA"            &&CERCA IL NUMERO DI REGISTRAZIONE UTENTE
ENDIF

IF PCOUNT()>=5 
	_NDOC               = _PAR_NDOC         
ELSE
	_NDOC               = ___NDOCU          && IMPOSTA IL NUMERO DI DOCUMENTO = PARTITA
ENDIF

CGE_IV               = "NO"
CGE_IMP              = 0.00

CGE_CECOS              = SPACE(13)  
CGE_WCCAGE             = SPACE(3)
CGE_KABBUO             = 0
CGE_XNOTE              = SPACE(13)
CGE_XCCLI              = SPACE(10)
CGE_XCFOR              = SPACE(10)
CGE_DATAREG            = ___DATAREGISTRAZIONE
CGE_DATADOC            = DTOC(DATE())
CGE_NDOC            = ___NDOCU
CGE_FR               = .F.
CGE_PESO            = 0
CGE_TISPE            = SPACE(03)
CGE_PORTO            = SPACE(03)
CGE_CLDOG            = SPACE(16)
CGE_BANCA            = "001"
CGE_CPA                = PUB_CPA
CGE_BOLLATOIVA        = SPACE(01)

CGE_XCAMBIO            = PUB_CAMBIO
CGE_XVALUTA            = "EUR"

*** Fabiano 14/04/2005 - GESTIONE DATA VALUTA
CGE_XDATAVAL        = ___dtvalu 
CGE_XANOMAX            = SPACE(3) 
CGE_CECO            = SPACE(10)
CGE_SEQUEN            = CGE_SEQUEN            +10                && AD OGNI RIGA INSERITA SOMMARE 10 

*CGE_COMM             = "PAGAMENTO N.: "+ALLTRIM(CGE_NDOC)+" DEL "+CGE_DATADOC
CGE_COM1             = "N.PART: "+ALLTRIM(STR(CGE_NPARF))+" - REG.DEL: "+CGE_DATAREG

*** Fabiano 14/04/2005 - GESTIONE DATA VALUTA
CGE_DTPAG			 = ___dtscad

IF pub_consolida_prev=1
    PUB_TIPOGE            = "PREVISIONALE"    && CONSIDERA LA REGISTRAZIONE COME REGISTRAZNE EFFETTIVA
ELSE
    PUB_TIPOGE            = "EFFETTIVA"    && CONSIDERA LA REGISTRAZIONE COME REGISTRAZNE EFFETTIVA
ENDIF

_TOTALE_PRIMA_NOTA=_TOTALE_PRIMA_NOTA+CGE_DA
=AQUAREP(_CLIFOR,_NPARF,_NUMPRO,_INDICE,_NREG,_NDOC)

RETURN
*** FINE FUNCTION MOVIMENTO_DARE
**************************************************************************




**************************************************************************
FUNCTION SALVAESITOCOMP
**************************************************************************

IF !ExecCommand("SELECT * FROM U_CMP_TT WHERE 0=1","CU_CMP_TT")
   RETURN(.F.)
ENDIF

SELECT CESITOCOMP
GO TOP
DO WHILE !EOF()

	SELECT CU_CMP_TT
	APPEND BLANK
	
	REPLACE ;
		CMP_CONTO 	WITH CESITOCOMP.CONTO ,;
		CMP_CLIFOR	WITH CESITOCOMP.CLIFOR,;
		CMP_TOP		WITH CESITOCOMP.TOP   ,;
		CMP_NPART   WITH CESITOCOMP.NPART ,;
		CMP_DARE	WITH CESITOCOMP.DARE  ,;
		CMP_AVERE	WITH CESITOCOMP.AVERE ,;
		CMP_SALDO   WITH CESITOCOMP.DARE-CESITOCOMP.AVERE ,;
		CMP_DESMOV  WITH CESITOCOMP.DESMOV,;
		CMP_ID		WITH ___NDOCU
		
	
	SELECT CESITOCOMP                                        
	SKIP
ENDDO

IF !ExecRW('','U_CMP_TT','I','','CU_CMP_TT')
   RETURN(.F.)
ENDIF



*** FINE FUNCTION SALVAESITOCOMP
**************************************************************************

