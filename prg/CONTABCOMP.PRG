***************************	
* Procedure CONTABCOMP
***************************
***PROCEDURE CONTABCOMP

PARAMETERS PAR_CONTABILIZZA

PRIVATE _SALDO_SINGOLA_PARTITA	,;
		_MASTRO_CLIENTI			,;
		_MASTRO_FORNITORI		,;
		_CODICE_CONTO_COMP_CLI  ,;
		_CODICE_CONTO_COMP_FOR  ,;
		_CODICE_CLIENTE			,;
		_RAGSOC_CLIENTE  		,;
		_CODICE_FORNITORE		,;
		_RAGSOC_FORNITORE		,;
		_CODICE_CONTO_BANCA		,;
		_DESCRI_CONTO_BANCA		,;
		_CONTAMOVIMENTI			,;
		_PAR_NUMPRO 			,;  
        _PAR_INDICE 			,;  
        _PAR_NREG   			,;
        _PAR_NDOC   			,;
        _CPARTCOMP_CONTO 		,;
		_CPARTCOMP_CLIFOR		,;
        _CPARTCOMP_TOP			,;
        _CPARTCOMP_DARE			,;
        _CPARTCOMP_AVERE		,;
        _CPARTCOMP_SALDO		,;
        _CPARTCOMP_NPART		,;
        _CPARTCOMP_DTSCAD		,;
        _CPARTCOMP_FORMAPAGAM   ,;
		_CPARTCOMP_COSATRATTA   ,;
		_CPARTCOMP_GRADOIMPOR   ,;
		_CPARTCOMP_TIPOCONTRA   ,;
		_CPARTCOMP_CODACQ 	    ,;
		_CPARTCOMP_PRIPAGA      ,;
        _NUMERO_MOVIMENTI	    ,;
        _FLAG_CONTABILIZZA		,;
        _DESCRIZIONE_PAGAMENTO		&& DESCRIVE SU MOV_CONT E SU PART_CLI/FOR IL TIPO DI 
									&& OPERAZIONE STO FACENDO
									&& PAGAMENTO/INCASSO E CLIENTE/FORNITORE
	

***------------------------------------------------------------------------------------------------***									
*** SONO PREVISTE PER _DESCRIZIONE_PAGAMENTO                                                       ***
***                                                                                                ***
*** DESCRIZIONE             |     TOP PER CONTROPARTITA                                            ***
***----------------------------------------------------------------                                ***
*** PAGAMENTO A FORNITORE   |    PUB_PAGAFOR && TOP PAGAMENTO FORNITORE                            ***
*** INCASSO DA CLIENTE      |    PUB_INCCLI	 && TOP INCASSO CLIENTE                                ***
*** PAGAMENTO A CLIENTE     |    PUB_NCR     && PAGAMENTO NOTA CREDITO CLIENTE                     ***
*** INCASSO DA FORNITORE    |    PUB_PAGANCR  && INCASSO NOTA CREDITO FORNITORE                    ***
***                                                                                                ***
*** NOTA BENE:                                                                                     ***
*** PER TUTTO QUELLO CHE NON ESCE COME DENARO DALLA MIA BANCA                                      ***
*** USO IL CONTO DI COMPENSAZIONE ASSOCIATO AL SUO TOP                                             ***
***                                                                                                ***
*** COMPENSAZIONE AUTOMATICA |   PUB_COMFOR --> TOP= 'CMF'                                         ***
***                                                                                                ***
*** NOTA BENE:                                                                                     ***
*** PER ORA GESTIAMO UN SOLO TIPO DI COMPENSAZIONE AUTOMATICA                                      ***
*** SIA PER CLIENTE                                                                                ***
*** SIA PER FORNITORE                                                                              ***
*** PER COMODITA DI GESTIONE DEI PARTITARI/MOVIMENTI SUCCESSIVA ALLA CREAZIONE DEI MOVIMENTI       ***
***------------------------------------------------------------------------------------------------***									


IF PCOUNT()>0 AND !PAR_CONTABILIZZA
	_FLAG_CONTABILIZZA=.F.
ELSE
	_FLAG_CONTABILIZZA=.T.
ENDIF
	
	

*** IMPOSTO VARIABILI PUBBLICHE PER CODICE MASTRO CLIENTI/FORNITORI
_ER = SOTTOGEN("ITA")
IF !_ER
   	_MASTRO_FORNITORI = SUBSTR(PUB_FF,1,2)
   	_MASTRO_CLIENTI	  = SUBSTR(PUB_CC,1,2)	
ELSE
	RETURN
ENDIF 

_SALDO_SINGOLA_PARTITA	=0
_TOTALE_PRIMA_NOTA		=0   && QUANDO ESEGUE AQUAREP SOMMA DARE PER OTTENERE IL TOTALE ALLA FINE 
							 && IL TOTALE OTTENUTO VA SU INDICE
_CODICE_CLIENTE		=""
_RAGSOC_CLIENTE  	=""
_CODICE_FORNITORE	=""
_RAGSOC_FORNITORE	=""
_CODICE_CONTO_BANCA	= ___codban
_DESCRI_CONTO_BANCA	= ___desban

_PAR_NUMPRO = SPACE(0)
_PAR_INDICE = SPACE(0)
_PAR_NREG   = SPACE(0)
_PAR_NDOC   = SPACE(0)

_CPARTCOMP_CONTO 	=""
_CPARTCOMP_DESCRI	=""
_CPARTCOMP_CLIFOR	=""		&& VALE C/F
_CPARTCOMP_TOP		=""
_CPARTCOMP_DARE		=0
_CPARTCOMP_AVERE	=0
_CPARTCOMP_SALDO	=0
_CPARTCOMP_DTSCAD   =""
_CPARTCOMP_FORMAPAGAM =""


_DESCRIZIONE_PAGAMENTO=""

_NUMERO_MOVIMENTI	=0

*** ___codban   && CODICE CONTO BANCA: SE PAGO FORNITORE SERVE PER LA CONTROPARTITA DI AVERE
*** ___desban   && DESCRIZIONE CONTO BANCA: SE PAGO FORNITORE SERVE PER LA CONTROPARTITA DI AVERE

*** ___codfor   && CODICE CONTO FORNITORE: SE PAGO FORNITORE SERVE PER LA PARTITA DI DARE
*** ___desfor   && DESCRIZIONE CONTO FORNITORE: SE PAGO FORNITORE SERVE PER LA PARTITA DI DARE


*** CALCOLO QUANTO HO A DISPOSIZIONE IN DARE E AVERE PER COMPENSARE
*** LE OPPOSTE PARTITE



IF !PUB_FLAG_COMPENSAZIONE_GIA_CALCOLATA

	WAIT WINDOW NOWAIT "Attendere prego... elaborazione compensazione in corso..."

	_COMPENSAZIONE_DARE=0
	_COMPENSAZIONE_AVERE=0

	*** CALCOLO LA DISTRIBUZIONE DELLA COMPENZAZIONE
	
	SELECT ABS(NSALDO) AS SALDO,* ;
		FROM CSPLITCOMP ;
		WHERE !EMPTY(SELEZIONE) ;
		INTO CURSOR CCOMP0
		
	SELECT * ;
		FROM CCOMP0 ;
		ORDER BY SALDO ;
		INTO CURSOR CCOMP		
	
	CREATE CURSOR CPARTCOMP (;
		CONTO 	C(13),;
		DESCRI  C(50),;
		CLIFOR	C(1),;
		DTSCAD  C(10),;
		TOP		C(10),;	
		NPART   N(10,0),;
		DARE	N(17,3),;
		AVERE	N(17,3),;
		SALDO	N(17,3),;
		cosatratta C(5),;
		gradoimpor C(5),;
		formapagam C(5),;
		tipocontra C(5),;
		codacq 	   C(3),;
		pripaga    C(4),;
		DATAFATT 	C(10),;
		NUMEROFATT	C(10),;
		DESMOV  C(50))
	
	CREATE CURSOR CESITOCOMP (;
		CONTO 	C(13),;
		DESCRI  C(50),;
		CLIFOR	C(1),;
		DTSCAD	C(10),;
		TOP		C(10),;	
		NPART   N(10,0),;
		DARE	N(17,3),;
		AVERE	N(17,3),;
		SALDO	N(17,3),;
		cosatratta C(5),;
		gradoimpor C(5),;
		formapagam C(5),;
		tipocontra C(5),;
		codacq 	   C(3),;
		pripaga    C(4),;
		DATAFATT 	C(10),;
		NUMEROFATT	C(10),;
		DESMOV  C(50))
	
	_DARE_CLIENTE	=0
	_AVERE_CLIENTE	=0
	_DARE_FORNITORE	=0
	_AVERE_FORNITORE=0
	_TOT_DARE       =0
	_TOT_AVERE      =0


	SELECT CCOMP
	GO TOP
	

	DO WHILE !EOF()
	
		_CPARTCOMP_CONTO 	=""
		_CPARTCOMP_DESCRI	=""
		_CPARTCOMP_CLIFOR	=""		&& VALE C/F
		_CPARTCOMP_TOP		=""
		_CPARTCOMP_NPART	=CCOMP.NPART
		_CPARTCOMP_DARE		=0
		_CPARTCOMP_AVERE	=0
		_CPARTCOMP_SALDO	=0
		_CPARTCOMP_DTSCAD   =CCOMP.DTSCAD
		_CPARTCOMP_COSATRATTA =CCOMP.COSATRATTA
		_CPARTCOMP_GRADOIMPOR =CCOMP.GRADOIMPOR
		_CPARTCOMP_FORMAPAGAM =CCOMP.FORMAPAGAM
		_CPARTCOMP_TIPOCONTRA =CCOMP.TIPOCONTRA
		_CPARTCOMP_CODACQ 	  =CCOMP.CODACQ 	    
		_CPARTCOMP_PRIPAGA    =CCOMP.PRIPAGA   
		_CPARTCOMP_NUMEROFATT =CCOMP.NUMEROFATT   
		_CPARTCOMP_DATAFATT   =CCOMP.DATAFATT   
		
	
		IF SUBSTR(codfor,1,LEN(_MASTRO_FORNITORI))=_MASTRO_FORNITORI
		&& E' IL FORNITORE DELLA COPPIA CLI/FOR PER COMPENSAZIONE
	
			IF EMPTY(_CODICE_FORNITORE)
				_CODICE_FORNITORE	=CCOMP.codfor
				_RAGSOC_FORNITORE	=CCOMP.RAGSOC
			ENDIF
		
			_CPARTCOMP_CLIFOR="F"
			_CPARTCOMP_SALDO =NSALDO
			_CPARTCOMP_CONTO =_CODICE_FORNITORE
			_CPARTCOMP_DESCRI=_RAGSOC_FORNITORE
			
			IF NSALDO>0
			&& DARE FORNITORE 
			&& NOTA DI ACCREDITO FORNITORE
			&& RICEVO DENARO DAL FORNITORE
				_DARE_FORNITORE	=_DARE_FORNITORE+NSALDO
				_CPARTCOMP_DARE=NSALDO
			
			ELSE
			&& AVERE FORNITORE
			&& PAGAMENTO A FORNITORE
			&& VERSO DENARO AL FORNITORE
				_AVERE_FORNITORE=_AVERE_FORNITORE+ABS(NSALDO)
				_CPARTCOMP_AVERE=ABS(NSALDO)
			
			ENDIF
			
			
		ELSE 
			IF SUBSTR(codfor,1,LEN(_MASTRO_CLIENTI))=_MASTRO_CLIENTI
			&& E' IL CLIENTE DELLA COPPIA CLI/FOR PER COMPENSAZIONE
			
				IF EMPTY(_CODICE_CLIENTE)
					_CODICE_CLIENTE	=CCOMP.codfor
					_RAGSOC_CLIENTE	=CCOMP.RAGSOC
				ENDIF
	
				_CPARTCOMP_CLIFOR="C"
				_CPARTCOMP_SALDO =NSALDO
				_CPARTCOMP_CONTO =_CODICE_CLIENTE
				_CPARTCOMP_DESCRI=_RAGSOC_CLIENTE
	
				IF NSALDO>0
				&& DARE CLIENTE 
				&& PAGAMENTO FATTURA CLIENTE
				&& RICEVO DENARO DAL CLIENTE
					_DARE_CLIENTE=_DARE_CLIENTE+NSALDO
					_CPARTCOMP_DARE=NSALDO
					
				ELSE
				&& AVERE CLIENTE
				&& NOTA DI ACCREDITO CLIENTE
				&& VERSO DENARO AL FORNITORE
					_AVERE_CLIENTE=_AVERE_CLIENTE+ABS(NSALDO)
					_CPARTCOMP_AVERE=ABS(NSALDO)
				
				ENDIF
			ENDIF
	
		ENDIF
	
		SELECT CPARTCOMP
		APPEND BLANK
		REPLACE	CONTO  WITH _CPARTCOMP_CONTO 	,;
				DESCRI WITH _CPARTCOMP_DESCRI	,;
				CLIFOR WITH _CPARTCOMP_CLIFOR	,;
				DTSCAD WITH _CPARTCOMP_DTSCAD   ,;
				TOP	   WITH _CPARTCOMP_TOP		,;
				NPART  WITH _CPARTCOMP_NPART    ,;
				DARE   WITH _CPARTCOMP_DARE		,;
				AVERE  WITH _CPARTCOMP_AVERE	,;
				SALDO  WITH _CPARTCOMP_SALDO	,;
				DESMOV WITH _DESCRIZIONE_PAGAMENTO,;
				NUMEROFATT WITH _CPARTCOMP_NUMEROFATT,;
				DATAFATT   WITH _CPARTCOMP_DATAFATT,;
				COSATRATTA WITH _CPARTCOMP_COSATRATTA,; 
				GRADOIMPOR WITH _CPARTCOMP_GRADOIMPOR,; 
				FORMAPAGAM WITH _CPARTCOMP_FORMAPAGAM,; 
				TIPOCONTRA WITH _CPARTCOMP_TIPOCONTRA,; 
				CODACQ 	   WITH _CPARTCOMP_CODACQ 	 ,; 
				PRIPAGA    WITH _CPARTCOMP_PRIPAGA   
	
	
			
		SELECT CCOMP
		SKIP +1
		
	ENDDO
	
	_CASO_DI_COMPENSAZIONE=""
	
	*** Che caso e' DARE o AVERE ?
	IF _DARE_CLIENTE+_DARE_FORNITORE > _AVERE_CLIENTE+_AVERE_FORNITORE
	*** E' DARE QUINDI DEVO INCASSARE DENARO
		
		_CASO_DI_COMPENSAZIONE="INCASSARE DA "
		
	ELSE
	*** E' AVERE QUINDI DEVO SPENDERE DENARO
		IF _DARE_CLIENTE+_DARE_FORNITORE < _AVERE_CLIENTE+_AVERE_FORNITORE
	
			_CASO_DI_COMPENSAZIONE="PAGARE A "
		ELSE
		
	*** COMPENSO TUTTO = NESSUNO PAGA E NESSUNO RICEVE
			_CASO_DI_COMPENSAZIONE="PAREGGIO"
		ENDIF
	
	ENDIF
	
	IF _CASO_DI_COMPENSAZIONE!="PAREGGIO"
	
		*** Il dare o avere č a favore del CLIENTE o del FORNITORE ?
		IF _DARE_CLIENTE+_AVERE_CLIENTE > _DARE_FORNITORE+_AVERE_FORNITORE
		*** E' DARE QUINDI DEVO INCASSARE DENARO
			
			_CASO_DI_COMPENSAZIONE=_CASO_DI_COMPENSAZIONE+"CLIENTE"
			
		ELSE
		*** E' AVERE QUINDI DEVO SPENDERE DENARO
		
			_CASO_DI_COMPENSAZIONE=_CASO_DI_COMPENSAZIONE+"FORNITORE"
		
		ENDIF
	
	ENDIF
	
	
	_TOT_DARE =_DARE_CLIENTE+_DARE_FORNITORE
	_TOT_AVERE=_AVERE_CLIENTE+_AVERE_FORNITORE
	
	***
	*** TOP UTILI PER LA COMPENSAZIONE
	***
	*** PUB_COMFOR   && TOP COMPENSAZIONE FORNITORE - USO SOLO QUELLA
	*** PUB_INCCLI	 && TOP INCASSO CLIENTE
	*** PUB_PAGAFOR  && TOP PAGAMENTO FORNITORE
	*** PUB_NCR      && PAGAMENTO NOTA CREDITO CLIENTE
	*** PUB_PAGANCR  && INCASSO NOTA CREDITO FORNITORE
	
	v_seek	= 'TOP' + PUB_COMCLI
	v_chiave = "codice"
	IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
		SELECT CUR_PARA
		_CODICE_CONTO_COMP_CLI =CONTO1
	ELSE
		WAIT WINDOW "Errore manca parametro TOP :"+CGE_TOPX
		_CODICE_CONTO_COMP_CLI ="111 INESISTENTE"
	ENDIF
	
	v_seek	= 'TOP' + PUB_COMFOR
	v_chiave = "codice"
	IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
		SELECT CUR_PARA
		_CODICE_CONTO_COMP_FOR =CONTO1
	ELSE
		WAIT WINDOW "Errore manca parametro TOP :"+CGE_TOPX
		_CODICE_CONTO_COMP_FOR ="111 INESISTENTE"
	ENDIF
			    
	
	*** ESAMINO I SINGOLI CASI
	
	DO CASE 
	
	******************************************************
	
		CASE _CASO_DI_COMPENSAZIONE = "PAGARE A FORNITORE"
			
			SELECT CPARTCOMP
			GO TOP
			DO WHILE !EOF()
			
				_DESCRIZIONE_PAGAMENTO=""
				
				_PARTITA_CONTO 	=""
				_PARTITA_DESCRI	=""
				_PARTITA_CLIFOR	=""		
				_PARTITA_TOP	=""
				_PARTITA_NPART  =NPART			
				_PARTITA_DARE	=AVERE
				_PARTITA_AVERE	=DARE
				_PARTITA_SALDO	=_PARTITA_DARE-_PARTITA_AVERE
				_PARTITA_DTSCAD =DTSCAD
				_PARTITA_COSATRATTA=COSATRATTA
				_PARTITA_GRADOIMPOR=GRADOIMPOR
				_PARTITA_FORMAPAGAM=FORMAPAGAM
				_PARTITA_TIPOCONTRA=TIPOCONTRA
				_PARTITA_CODACQ    =CODACQ 	  
				_PARTITA_PRIPAGA   =PRIPAGA   
				_PARTITA_NUMEROFATT=NUMEROFATT
				_PARTITA_DATAFATT  =DATAFATT
				
				
				_CONTROPARTITA_CONTO 	=""
				_CONTROPARTITA_DESCRI	=""
				_CONTROPARTITA_CLIFOR	=""		
				_CONTROPARTITA_TOP		=""
				_CONTROPARTITA_NPART    =_PARTITA_NPART

				
				IF DARE>AVERE
				*** LE PARTITE IN DARE 
				*** DEVONO ESSERE COMPENSATE 
					_PARTITA_CONTO 	=CONTO
					_PARTITA_DESCRI	=DESCRI
					_PARTITA_CLIFOR	=CLIFOR		
					_PARTITA_TOP	=PUB_COMFOR
	
					_CONTROPARTITA_CONTO 	=_CODICE_CONTO_COMP_FOR
					_CONTROPARTITA_DESCRI	=""
					_CONTROPARTITA_CLIFOR	=CLIFOR		
					_CONTROPARTITA_TOP		=PUB_COMFOR
					
					_DESCRIZIONE_PAGAMENTO="COMPENSAZIONE AUTOMATICA PAG-A-FOR-02"
	
				ELSE							
				*** LE PARTITE IN AVERE 
				*** DEVONO ESSERE COMPENSATE 
				*** SOLO SE IN _TOT_DARE HO ANCORA QUALCOSA
				*** PER COMPENSARLE
					
					IF _TOT_DARE>=AVERE
					*** HO ANCORA ABBASTANZA IN _TOT_DARE
					*** PER COMPENSARE QUESTA PARTITA
						_PARTITA_CONTO 	=CONTO
						_PARTITA_DESCRI	=DESCRI
						_PARTITA_CLIFOR	=CLIFOR		
						_PARTITA_TOP	=PUB_COMFOR
		
						_CONTROPARTITA_CONTO 	=_CODICE_CONTO_COMP_FOR
						_CONTROPARTITA_DESCRI	=""
						_CONTROPARTITA_CLIFOR	=CLIFOR		
						_CONTROPARTITA_TOP		=PUB_COMFOR
						
						*** SCALO DAL _TOT_DARE DISPONIBILE
						*** L'IMPORTO CHE HO USATO PER COMPENSARE
						_TOT_DARE = _TOT_DARE -AVERE
						
						_DESCRIZIONE_PAGAMENTO="COMPENSAZIONE AUTOMATICA PAG-A-FOR-03"
						
					ELSE
					*** NON HO ABBASTANZA IN _TOT_DARE
					*** PER COMPENSARE QUESTA PARTITA
					
						IF _TOT_DARE>0
						*** SE SONO ALLA SOGLIA DELLA COMPENSAZIONE
						*** OSSIA SE MI E' RIMASTO ANCORA QUALCOSA
						*** IN _TOT_DARE SOLO PER QUESTA PARTITA
						
							*** QUELLO CHE RIESCO LO COMPENSO
							_PARTITA_CONTO 	=CONTO
							_PARTITA_DESCRI	=DESCRI
							_PARTITA_CLIFOR	=CLIFOR		
							_PARTITA_TOP	=PUB_COMFOR
							_PARTITA_DARE	=_TOT_DARE
							_PARTITA_AVERE	= 0
							_PARTITA_SALDO	=_PARTITA_DARE-_PARTITA_AVERE
			
							_CONTROPARTITA_CONTO 	=_CODICE_CONTO_COMP_FOR
							_CONTROPARTITA_DESCRI	=""
							_CONTROPARTITA_CLIFOR	=CLIFOR		
							_CONTROPARTITA_TOP		=PUB_COMFOR
							
							_DESCRIZIONE_PAGAMENTO="COMPENSAZIONE AUTOMATICA PAG-A-FOR-SOGLIA"
							
							SELECT CESITOCOMP
							APPEND BLANK
							REPLACE	CONTO  WITH _PARTITA_CONTO 	,;
									DESCRI WITH _PARTITA_DESCRI	,;
									CLIFOR WITH _PARTITA_CLIFOR	,;
									DTSCAD WITH _PARTITA_DTSCAD ,;
									TOP	   WITH _PARTITA_TOP	,;
									NPART  WITH _PARTITA_NPART  ,;
									DARE   WITH _PARTITA_DARE	,;
									AVERE  WITH _PARTITA_AVERE	,;
									SALDO  WITH _PARTITA_SALDO	,;
									COSATRATTA WITH _PARTITA_COSATRATTA ,;
									GRADOIMPOR WITH _PARTITA_GRADOIMPOR ,;
									FORMAPAGAM WITH _PARTITA_FORMAPAGAM ,;
									TIPOCONTRA WITH _PARTITA_TIPOCONTRA ,;
									CODACQ 	   WITH _PARTITA_CODACQ 	,;
									PRIPAGA    WITH _PARTITA_PRIPAGA    ,;
									NUMEROFATT WITH _PARTITA_NUMEROFATT,;
									DATAFATT   WITH _PARTITA_DATAFATT,;
									DESMOV WITH _DESCRIZIONE_PAGAMENTO			
				
							APPEND BLANK
							REPLACE	CONTO  WITH _CONTROPARTITA_CONTO 	,;
									DESCRI WITH _CONTROPARTITA_DESCRI	,;
									CLIFOR WITH _CONTROPARTITA_CLIFOR	,;
									DTSCAD WITH _PARTITA_DTSCAD         ,;
									TOP	   WITH _CONTROPARTITA_TOP		,;
									NPART  WITH _CONTROPARTITA_NPART    ,;
									DARE   WITH _PARTITA_AVERE			,;
									AVERE  WITH _PARTITA_DARE			,;
									SALDO  WITH _PARTITA_AVERE-_PARTITA_DARE ,;
									COSATRATTA WITH _PARTITA_COSATRATTA ,;
									GRADOIMPOR WITH _PARTITA_GRADOIMPOR ,;
									FORMAPAGAM WITH _PARTITA_FORMAPAGAM ,;
									TIPOCONTRA WITH _PARTITA_TIPOCONTRA ,;
									CODACQ 	   WITH _PARTITA_CODACQ 	,;
									PRIPAGA    WITH _PARTITA_PRIPAGA    ,;
									NUMEROFATT WITH _PARTITA_NUMEROFATT,;
									DATAFATT   WITH _PARTITA_DATAFATT,;
									DESMOV WITH _DESCRIZIONE_PAGAMENTO
													
							_NUMERO_MOVIMENTI=_NUMERO_MOVIMENTI+1
						
						ENDIF _TOT_DARE>0
						
						*** QUELLO CHE AVANZA LO PAGO
						SELECT CPARTCOMP
	
						_PARTITA_CONTO 	=CONTO
						_PARTITA_DESCRI	=DESCRI
						_PARTITA_CLIFOR	=CLIFOR		
						_PARTITA_TOP	=PUB_PAGAFOR
						_PARTITA_DARE	= AVERE - _TOT_DARE
						_PARTITA_AVERE	= 0
						_PARTITA_SALDO	=_PARTITA_DARE-_PARTITA_AVERE
		
						_CONTROPARTITA_CONTO 	=_CODICE_CONTO_BANCA
						_CONTROPARTITA_DESCRI	=_DESCRI_CONTO_BANCA
						_CONTROPARTITA_CLIFOR	=CLIFOR		
						_CONTROPARTITA_TOP		=PUB_PAGAFOR
						
						_DESCRIZIONE_PAGAMENTO="PAGAMENTO A FORNITORE"
						
						_TOT_DARE=0
						
					ENDIF _TOT_DARE>=AVERE
				
				ENDIF DARE>AVERE
				
			
				SELECT CESITOCOMP
				APPEND BLANK
				REPLACE	CONTO  WITH _PARTITA_CONTO 	,;
						DESCRI WITH _PARTITA_DESCRI	,;
						CLIFOR WITH _PARTITA_CLIFOR	,;
						DTSCAD WITH _PARTITA_DTSCAD ,;
						TOP	   WITH _PARTITA_TOP	,;
						NPART  WITH _PARTITA_NPART  ,;
						DARE   WITH _PARTITA_DARE	,;
						AVERE  WITH _PARTITA_AVERE	,;
						SALDO  WITH _PARTITA_SALDO	,;
						COSATRATTA WITH _PARTITA_COSATRATTA ,;
						GRADOIMPOR WITH _PARTITA_GRADOIMPOR ,;
						FORMAPAGAM WITH _PARTITA_FORMAPAGAM ,;
						TIPOCONTRA WITH _PARTITA_TIPOCONTRA ,;
						CODACQ 	   WITH _PARTITA_CODACQ 	,;
						PRIPAGA    WITH _PARTITA_PRIPAGA    ,;
						NUMEROFATT WITH _PARTITA_NUMEROFATT,;
						DATAFATT   WITH _PARTITA_DATAFATT,;
						DESMOV WITH _DESCRIZIONE_PAGAMENTO			
	
				APPEND BLANK
				REPLACE	CONTO  WITH _CONTROPARTITA_CONTO 	,;
						DESCRI WITH _CONTROPARTITA_DESCRI	,;
						CLIFOR WITH _CONTROPARTITA_CLIFOR	,;
						DTSCAD WITH _PARTITA_DTSCAD ,;
						TOP	   WITH _CONTROPARTITA_TOP		,;
						NPART  WITH _CONTROPARTITA_NPART    ,;
