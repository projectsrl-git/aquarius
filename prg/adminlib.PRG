FUNCTION _OPERAT
******************************
* GESTIONE LIVELLO ACCESSO A INFORMAZIONI PER OPERATORE
* __DATO = CAMPO DA CONTROLLARE

PARA __DATO

v_seek	 = ALLTRIM(__dato)
v_chiave = "codice"
IF seek_std('Res_Oper',v_seek,v_chiave,'Res_Oper')
   SELECT Res_Oper
   PUB_PREZZI = NO_PREZZI
