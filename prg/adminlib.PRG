**********************************************************************
* -->> FUNZIONE CHE IDENTIFICA SE LA DATA IN OGGETTO E' RIBALTATA
* -->> IN QUESTO CASO LA RIPORTA IN FORMATO GG/MM/AAAA
**********************************************************************
FUNCTION GDATA  
**********************************************************************
PARA _DATA

OUT=_DATA

IF SUBSTR(_DATA,5,1)="/"
  OUT=RIBALTA2(_DATA)
ENDIF  

RETURN(OUT)

