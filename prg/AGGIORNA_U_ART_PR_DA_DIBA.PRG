
_RISP = MESSAGEBOX("Aggiornare i prezzi di costo e i tempi dell'anagrafica articoli e rivalutare i campi delle Di.Ba.?",4+32,"Attenzione")
IF _RISP = 6
ELSE
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF

_CONTA_GRUPPI_DIBA = 0

cSql = "SELECT * FROM U_DIS_TT ORDER BY DIT_GRUPPO"
IF !ExecCommand(cSql,"TMP_DIS_TT")
	return(.f.)
ENDIF
SELECT TMP_DIS_TT
GO TOP
SCAN
*!*		IF ALLTRIM(DIT_GRUPPO) = "T101.138"
*!*			SET STEP ON
*!*		ENDIF
	
	DO RIVALUTA_CAMPI_U_DIS_TT WITH "TMP_DIS_TT"
	SELECT TMP_DIS_TT
	SCATTER MEMVAR
	
	LOCAL _CODART
	_CODART = ALLTRIM(M.DIT_GRUPPO)
	
	WAIT WINDOWS "Aggiornamento Articolo " + _CODART + "  (" + ALLTRIM(STR(RECNO())) + " di " + ALLTRIM(STR(RECCOUNT())) + ")" NOWAIT
	
	x_cond = "art_codpri = '" + _CODART + "'"
	cSql = "SELECT * FROM U_ART_PR WHERE " + x_cond
	IF !ExecRW(cSql,"U_ART_PR","R")
		return(.f.)
	ENDIF
	SELECT U_ART_PR
	GO TOP
	IF !EOF()
		REPLACE ART_GRUPPO WITH .T.
		
		REPLACE ART_COSMAT WITH M.DIT_COSMAT
		REPLACE ART_COSLAI WITH M.DIT_COSLAI
		REPLACE ART_COSLAE WITH M.DIT_COSLAE
		REPLACE ART_COSATR WITH M.DIT_COSATR
		REPLACE ART_PRZCOS WITH M.DIT_COSTO
				
		REPLACE ART_ORELAV WITH M.DIT_ORELAV		
		REPLACE ART_OREATT WITH M.DIT_OREATT		
		REPLACE ART_OREIMP WITH M.DIT_OREIMP		
		REPLACE ART_SECIMP WITH M.DIT_SECIMP		
		REPLACE ART_SECLAV WITH M.DIT_SECLAV		
		REPLACE ART_SECATT WITH M.DIT_SECATT		
	ENDIF
	IF !ExecRW(cSql,"U_ART_PR","W")
		return(.f.)
	ENDIF
	
	x_cond = "dit_gruppo = '" + _CODART + "'"
	cSql = "SELECT * FROM U_DIS_TT WHERE " + x_cond
	IF !ExecRW(cSql,"U_DIS_TT","R")
		return(.f.)
	ENDIF
	SELECT U_DIS_TT
	GO TOP
	IF !EOF()
	
		_CONTA_GRUPPI_DIBA = _CONTA_GRUPPI_DIBA + 1
		
   		REPLACE DIT_COSLAI WITH M.DIT_COSLAI
   		REPLACE DIT_COSLAE WITH M.DIT_COSLAE
   		REPLACE DIT_COSMAT WITH M.DIT_COSMAT
   		REPLACE DIT_COSATR WITH M.DIT_COSATR
   
   		REPLACE DIT_RICLAI WITH M.DIT_RICLAI
   		REPLACE DIT_RICLAE WITH M.DIT_RICLAE
   		REPLACE DIT_RICMAT WITH M.DIT_RICMAT
   		REPLACE DIT_RICATR WITH M.DIT_RICATR
   
      	REPLACE DIT_COSTO  WITH M.DIT_COSTO
      	REPLACE DIT_PREZZO WITH M.DIT_PREZZO
      	
		REPLACE DIT_ORELAV WITH M.DIT_ORELAV
		REPLACE DIT_OREATT WITH M.DIT_OREATT
        REPLACE DIT_OREIMP WITH M.DIT_OREIMP
        
        REPLACE DIT_SECIMP WITH M.DIT_SECIMP
        REPLACE DIT_SECLAV WITH M.DIT_SECLAV
        REPLACE DIT_SECATT WITH M.DIT_SECATT
	        
		x_grup = "dis_gruppo = '" + ALLTRIM(_CODART) + "'"
		x_cond = x_grup
		cSql   = "SELECT * FROM U_DIS_DD WHERE " + x_cond + " order by dis_sequen"
		IF !ExecRW(cSql,"U_DIS_DD","R")
			return(.f.)
		ENDIF
		SELECT U_DIS_DD
		GO TOP
		SCAN
			IF ALLTRIM(DIS_ESPLOD) == 'X'
				LOOP
			ENDIF
			
			DO RIVALUTA_CAMPI_U_DIS_DD WITH "U_DIS_DD"
			SCATTER MEMVAR MEMO
			
			M.COSTO_TOT = M.DIS_COSTO * M.DIS_QTA
			M.PREZZO_TOT = M.DIS_PREZZO * M.DIS_QTA
			
			SELECT U_DIS_DD
			GATHER MEMVAR MEMO
			
			IF M.DIS_TIPO = 'A'
				x_cond = "art_codpri = '" + M.DIS_CODART + "'"
				cSql = "SELECT * FROM U_ART_PR WHERE " + x_cond
				IF !ExecRW(cSql,"U_ART_PR","R")
					return(.f.)
				ENDIF
				SELECT U_ART_PR
				GO TOP
				IF !EOF()
					REPLACE ART_GRUPPO WITH .F.
					
					REPLACE ART_PRZCOS WITH M.DIS_COSTO
							
					REPLACE ART_ORELAV WITH M.DIS_ORELAV		
					REPLACE ART_OREATT WITH M.DIS_OREATT		
					REPLACE ART_OREIMP WITH M.DIS_OREIMP		
					REPLACE ART_SECIMP WITH M.DIS_SECIMP		
					REPLACE ART_SECLAV WITH M.DIS_SECLAV		
					REPLACE ART_SECATT WITH M.DIS_SECATT		
				ENDIF
				IF !ExecRW(cSql,"U_ART_PR","W")
					return(.f.)
				ENDIF
			ENDIF
			
		ENDSCAN
		IF !ExecRW(cSql,"U_DIS_DD","W")
			return(.f.)
		ENDIF
		
	ENDIF
	IF !ExecRW(cSql,"U_DIS_TT","W")
		return(.f.)
	ENDIF
	
ENDSCAN

WAIT CLEAR

MESSAGEBOX("Totale gruppi Di.Ba. aggiornati: " + ALLTRIM(STR(_CONTA_GRUPPI_DIBA)),64,"Informazione")

