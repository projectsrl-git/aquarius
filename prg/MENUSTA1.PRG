*********************************************************************************************************************************
* XXX_FILIN     			= NOME FILE DI INPUT DA ELABORARE
* XXX_PREVIEW   			= FLAG .T. O .F. PER ANTEPRIMA
* XXX_STAMPA    			= FLAG .T. O .F. PER STAMPARE
* XXX_TIPO      			= PARAMETRO TIPO PER RICERCARE REPORT SU CERCAREPO
* XXX_PROGRAMMA 			= PARAMETRO NOME PROGRAMMA PER RICERCARE REPORT SU CERCAREPO
* XXX_REPORT    			= PARAMETRO NOME REPORT PER RICERCARE REPORT SU CERCAREPO
* XXX_OKXLS     			= PARAMETRO CHE ABILITA O DISABILITA LA POSSIBILITA' DI CONVERSIONI EXCEL  
* XXX_NON_CERCARE_IL_REPORT	= PARAMETRO PER NON RICERCARE IL REPORT IN QUANTO GIA' STATO PREDISPOSTO DALLA FASE PRECEDENTE 
*********************************************************************************************************************************

LPARAMETERS XXX_FILIN,XXX_PREVIEW,XXX_STAMPA,XXX_TIPO,XXX_PROGRAMMA,XXX_REPORT,[XXX_EMAIL],[XXX_PDF],XXX_OKXLS
*LPARAMETERS XXX_FILIN,XXX_PREVIEW,XXX_STAMPA,XXX_TIPO,XXX_PROGRAMMA,XXX_REPORT,[XXX_EMAIL],[XXX_PDF],XXX_OKXLS,XXX_NON_CERCARE_IL_REPORT

  
_NUM_PAR = PCOUNT()



*!*	IF _NUM_PAR <= 8
*!*	   XXX_OKXLS = .F.
*!*	   XXX_NON_CERCARE_IL_REPORT = .F.
*!*	ENDIF

*!*	IF _NUM_PAR <= 9
*!*	   XXX_NON_CERCARE_IL_REPORT = .F.
*!*	ENDIF


IF _NUM_PAR <= 8
   XXX_OKXLS = .F.
ENDIF


RELEASE YYY_FILIN,YYY_PREVIEW,YYY_STAMPA,YYY_TIPO,YYY_PROGRAMMA,YYY_REPORT,YYY_FILOUT,YYY_EMAIL,YYY_PDF,YYY_OKXLS
PUBLIC  YYY_FILIN,YYY_PREVIEW,YYY_STAMPA,YYY_TIPO,YYY_PROGRAMMA,YYY_REPORT,YYY_FILOUT,YYY_EMAIL,YYY_PDF,YYY_OKXLS
YYY_FILIN     = XXX_FILIN
YYY_PREVIEW   = XXX_PREVIEW
YYY_STAMPA    = XXX_STAMPA
YYY_TIPO      = XXX_TIPO
YYY_PROGRAMMA = XXX_PROGRAMMA
YYY_REPORT    = XXX_REPORT
YYY_EMAIL	  = XXX_EMAIL
*YYY_PDF		  = XXX_PDF 
YYY_OKXLS     = XXX_OKXLS  

*YYY_PDF = STRTRAN(XXX_PDF,".EXP",".PDF")
YYY_PDF = JUSTSTEM(JUSTFNAME(ALLTRIM(XXX_PDF)))  && ERASMO - 25/10/2017 - LE DIRECTORY E SOTTODIRECTORY VENGONO GESTITE NEL FORM\MENUSTA_EMAIL

*!*	RELEASE _DIRECTORY_PDF 
*!*	PUBLIC _DIRECTORY_PDF 
*!*	_KEY_PARA = "FSDEMAIL"
*!*	IF !EXECCOMMAND("SELECT * FROM PARA WHERE CODICE='"+_KEY_PARA+"' ORDER BY CODICE","CURS_PARA")
*!*	   RETURN .F.
*!*	ENDIF
*!*	SELECT CURS_PARA
*!*	GO TOP
*!*	IF !EOF()
*!*		_DIRECTORY_PDF = ALLTRIM(LIBERA)
*!*	ELSE
*!*		_DIRECTORY_PDF = ""	
*!*	ENDIF
*!*	IF !EMPTY(ALLTRIM(_DIRECTORY_PDF))
*!*		YYY_PDF = _DIRECTORY_PDF+"\"+JUSTFNAME(ALLTRIM(YYY_PDF))
*!*	ENDIF
   		
IF XXX_EMAIL=.T.
	YYY_EMAIL=.T.
ELSE
	YYY_EMAIL=.F.
ENDIF

*IF XXX_NON_CERCARE_IL_REPORT
IF PUB_NON_CERCARE_IL_REPORT_USA_QUELLO_CHE_TI_DICO_IO 
	DO FORM FORM\MENUSTA_EMAIL WITH YYY_FILIN,YYY_REPORT,YYY_PREVIEW,YYY_STAMPA,YYY_EMAIL,YYY_PDF,YYY_OKXLS
ELSE
	YYY_FILOUT    = CERCAREPO("XXX",YYY_PROGRAMMA,YYY_REPORT)
	IF YYY_FILOUT <> "NNN"
	   DO FORM FORM\MENUSTA_EMAIL WITH YYY_FILIN,YYY_FILOUT,YYY_PREVIEW,YYY_STAMPA,YYY_EMAIL,YYY_PDF,YYY_OKXLS
	ENDIF
ENDIF

RETURN


