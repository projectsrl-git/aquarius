LPARAMETERS _par_db_sorgente,_par_group_codsys

IF PCOUNT() >= 1
ELSE
	MESSAGEBOX("Parametri di ingresso insufficienti",16,"Attenzione")
	RETURN .F.
ENDIF

IF PCOUNT() >= 2
ELSE
	_par_group_codsys = ""
ENDIF

_CONTA_INS = 0
_CONTA_AGG = 0

_MSG_WARNINGS = ""

_LOG_CODSYS = IIF(EMPTY(_par_group_codsys),SYS(2015),_par_group_codsys)
_LOG_OGGETTO = "GIACENZE"
_LOG_DATA = RIBALTA2(DTOC(DATE()))
_LOG_ORA = TIME()
_LOG_DB_SORGENTE = _par_db_sorgente
_LOG_CODOPE = ALLTRIM(PUB_CODOPE)
_LOG_NOMOPE = ALLTRIM(PUB_NOMOPE)

_SEC_INI = SECONDS()

*** SCRITTURA RECORD TABELLA LOG_DBSYNC
cSql = "select * from LOG_DBSYNC where 1=0"
IF !ExecRW(cSql,"LOG_DBSYNC","R")
   return(.f.)
ENDIF
SELECT LOG_DBSYNC
APPEND BLANK
REPLACE CODSYS WITH _LOG_CODSYS
REPLACE OGGETTO WITH _LOG_OGGETTO
REPLACE DATA WITH _LOG_DATA
REPLACE ORA WITH _LOG_ORA
REPLACE DB_SORGENTE WITH _LOG_DB_SORGENTE
REPLACE ESITO WITH ""
REPLACE MESSAGGIO WITH "ELABORAZIONE"
REPLACE NRECINS WITH 0
REPLACE NRECAGG WITH 0
REPLACE TEMPO_IMPIEGATO WITH 0
REPLACE CODOPE WITH _LOG_CODOPE
REPLACE NOMOPE WITH _LOG_NOMOPE
	
IF !ExecRW(cSql,"LOG_DBSYNC","W")
   return(.f.)
ENDIF

*** COMPONGO I CURSORI DI APPOGGIO CHE CONTERRANNO I DATI DELLE GIACENZE
cSql = "select * from U_MAG_GG where 1=0"
