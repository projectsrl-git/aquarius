*** CARICO AUTOMATICO GIACENZE SU MAGAZZINO DI DESTINAZIONE
SELECT CU_MAG_GG
GO TOP
SCAN
	
	WAIT WINDOWS "Carico giacenza " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + " in corso (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT
	
	SCATTER MEMVAR MEMO
	
	x_cond = "MAG_UNIQUE = '" + M.MAG_UNIQUE + "'"
	cSql = "SELECT * FROM U_MAG_GG WHERE " + x_cond
	IF !ExecCommand(cSql,"CHK_MAG_GG")
		return(.f.)
	ENDIF
	SELECT CHK_MAG_GG
	GO TOP
	IF EOF()
		AQM_NUMMOV_LOCALE  = AQM_RILEVA_NUMERO_INTERNO()
		=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
		*** VALORIZZAZIONE VARIABILI CHE NON DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA
		AQM_DTDOCU = RIBALTA2(DTOC(DATE()))
		AQM_NUMDOC = "AUTO"
		AQM_CODCLI = ""
		AQM_CODFOR = "999999999"
		AQM_TOP    = "RE+"
		AQM_DTREGI = RIBALTA2(DTOC(DATE()))
		AQM_VALUTA = "EUR"
		AQM_CODMAG = "MPF"
		
		_YES_CAR = AQM_CARICA_MAGAZZINO()
		IF !_YES_CAR
			MESSAGEBOX("Si č verificato un errore generico durante il carico automatico del magazzino",16,"Attenzione",2)
			SELECT CU_MAG_GG
			LOOP
		ENDIF

		_CONTA_INS = _CONTA_INS + 1
		
		SELECT CU_MAG_GG
		REPLACE SELEZIONE WITH "==>"
	ENDIF
	
ENDSCAN


*** SCARICO AUTOMATICO GIACENZE DA MAGAZZINO SORGENTE
IF !SwicthDBConnection(ALLTRIM(_LOG_DB_SORGENTE))
   MESSAGEBOX("DataBase sorgente '" + _LOG_DB_SORGENTE + "' inesistente o non raggiungibile",16,"Attenzione")
   IF !SetHomeDB()
      RETURN(.f.)
   ENDIF
   RETURN .F.
ENDIF

SELECT CU_MAG_GG
GO TOP
SCAN
	
	WAIT WINDOWS "Scarico giacenza " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + " in corso (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT
	
	IF SELEZIONE = "==>"
	ELSE
		LOOP
	ENDIF
	
	SCATTER MEMVAR MEMO
	
	x_cond = "MAG_UNIQUE = '" + M.MAG_UNIQUE + "'"
	cSql = "SELECT * FROM U_MAG_GG WHERE " + x_cond
	IF !ExecCommand(cSql,"CHK_MAG_GG")
		IF !SetHomeDB()
			RETURN(.f.)
		ENDIF
		return(.f.)
	ENDIF
	SELECT CHK_MAG_GG
	GO TOP
	IF !EOF()
		AQM_NUMMOV_LOCALE  = AQM_RILEVA_NUMERO_INTERNO()
		=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
		*** VALORIZZAZIONE VARIABILI CHE NON DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA
		AQM_DTDOCU = RIBALTA2(DTOC(DATE()))
		AQM_NUMDOC = "AUTO"
		AQM_CODCLI = "999999999"
		AQM_CODFOR = ""
		AQM_TOP    = "RE-"
		AQM_DTREGI = RIBALTA2(DTOC(DATE()))
		AQM_VALUTA = "EUR"
		AQM_LEGSYS = SYS(2015)
		
		_YES_CAR = AQM_SCARICA_MAGAZZINO()
		IF !_YES_CAR
			MESSAGEBOX("Si č verificato un errore generico durante lo scarico automatico del magazzino",16,"Attenzione",2)
			SELECT CU_MAG_GG
			LOOP
		ENDIF
	ENDIF
	
ENDSCAN

IF !SetHomeDB()
	RETURN(.f.)
ENDIF


_MESSAGGIO = ""
IF _CONTA_INS > 0
	_MESSAGGIO = _MESSAGGIO + IIF(EMPTY(_MESSAGGIO),"",CHR(13)+CHR(10)) + "Totale giacenze inserite: " + ALLTRIM(STR(_CONTA_INS))
ELSE
	_MESSAGGIO = _MESSAGGIO + IIF(EMPTY(_MESSAGGIO),"",CHR(13)+CHR(10)) + "Nessuna giacenza inserita"
ENDIF
*!*	IF _CONTA_AGG > 0
*!*		_MESSAGGIO = _MESSAGGIO + IIF(EMPTY(_MESSAGGIO),"",CHR(13)+CHR(10)) + "Totale articoli aggiornati: " + ALLTRIM(STR(_CONTA_AGG))
*!*	ELSE
*!*		_MESSAGGIO = _MESSAGGIO + IIF(EMPTY(_MESSAGGIO),"",CHR(13)+CHR(10)) + "Nessun articolo aggiornato"
*!*	ENDIF

cSql = "select * from LOG_DBSYNC WHERE OGGETTO = '" + _LOG_OGGETTO + "' AND CODSYS = '" + _LOG_CODSYS + "'"
IF !ExecRW(cSql,"LOG_DBSYNC","R")
   return(.f.)
ENDIF
SELECT LOG_DBSYNC
GO TOP
IF !EOF()
	REPLACE ESITO WITH "OK"
	REPLACE MESSAGGIO WITH ALLTRIM(_MSG_WARNINGS) + IIF(EMPTY(_MSG_WARNINGS),"",CHR(13)+CHR(10)) + _MESSAGGIO
	REPLACE NRECINS WITH _CONTA_INS
	*REPLACE NRECAGG WITH _CONTA_AGG
	_SEC_FIN = SECONDS()
	REPLACE TEMPO_IMPIEGATO WITH ROUND(_SEC_FIN - _SEC_INI, 0)
ENDIF
IF !ExecRW(cSql,"LOG_DBSYNC","W")
   return(.f.)
ENDIF

WAIT CLEAR

IF EMPTY(ALLTRIM(_par_group_codsys))
	MESSAGEBOX(_MESSAGGIO,64,"Informazione",5000)
ENDIF

_OK_SYNC_GIACENZE = .T.
			
RETURN .T.
