*** ELABORAZIONE GIACENZE SU DB SORGENTE INSERITE RISPETTO ALL'ULTIMA SINCRONIZZAZIONE ANDATA A BUON FINE
WAIT WINDOWS "Lettura giacenze su db sorgente '" + _LOG_DB_SORGENTE + "' inseriti o modificati rispetto all'ultima sincronizzazione..." NOWAIT

_ULT_TS_SYNC_GIAC = ""
cSql   = "SELECT TOP 1 LAST_DATE FROM (SELECT DATA+ORA AS LAST_DATE FROM LOG_DBSYNC WHERE OGGETTO = '" + _LOG_OGGETTO + "' AND ESITO = 'OK' UNION SELECT '1950/01/0100:00:00' AS LAST_DATE) AS T ORDER BY LAST_DATE DESC"
IF !ExecCommand(cSql,"ULT_TS_SYNC_GIAC")
	return(.f.)
ENDIF
SELECT ULT_TS_SYNC_GIAC
GO TOP
_ULT_TS_SYNC_GIAC = LAST_DATE

IF !SwicthDBConnection(ALLTRIM(_LOG_DB_SORGENTE))
   MESSAGEBOX("DataBase sorgente '" + _LOG_DB_SORGENTE + "' inesistente o non raggiungibile",16,"Attenzione")
   IF !SetHomeDB()
      RETURN(.f.)
   ENDIF
   RETURN .F.
ENDIF

x_cond = "MAG_CODMAG = 'FRANCE' AND MAG_DATAGG+MAG_ORACAR > '" + _ULT_TS_SYNC_GIAC + "'"
cSql=""     
cNomeCursorSql="TMP_MAG_GG"
TEXT TO cSql NOSHOW
	SELECT GG.* FROM U_MAG_GG AS GG
	WHERE <<x_cond>>
	ORDER BY MAG_DATAGG,MAG_ORACAR
ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	IF !SetHomeDB()
		RETURN(.f.)
	ENDIF
	return(.F.)
ENDIF
SELECT TMP_MAG_GG
GO TOP
SCAN
	SCATTER MEMVAR MEMO
	M.SELEZIONE = ""
