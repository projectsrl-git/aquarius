**************************************************************************************
*  TRASFERIMENTO IN CONTABILITA GENERALE DEGLI INCASSI PUNTI DI VENDITA			  	 *
**************************************************************************************

PUBLIC PN_C,NREG,COMPENSO,TIVA,CIVA,TOP_TOP,V_CONPAG,XSD
COMPENSO = 0
TIVA     = 0
CIVA     = 0
TOP_TOP  = SPACE(03)

PUBLIC DATA_SCAD,TOP_CONT
DATA_SCAD = ""
TOP_CONT  = ""

WAIT WINDOWS 'Inizio Elaborazione Prego attendere......... ' NOWAIT

CREATE CURSOR W_FAT (W_CONTO C(13),     W_DA C(1),      W_IVA C(3),     W_IMPONI N(16,2), ;
                     W_IMPOSTA N(16,2), W_PUBBLI N(13), W_NUMDOC C(10), W_DTDOC C(10))
SELECT W_FAT        
INDEX ON W_CONTO+W_DA+W_IVA TAG DETTA
SET ORDER TO DETTA

CT      = 0
CTRELAB = 0
DATREG  = XDATA      && FORZA LA DATA DI REGISTRAZIONE CON LA DATA DIGITATA
PERDAL   = RIBALTA2(DATADAL)
PERAL    = RIBALTA2(DATAAL)
XSD      = 0

x_data = "cge_datsco >= '" + PERDAL + "'"
x_cond = x_data
Csql   = "select * from u_pdv_in where " + x_cond + " order by cge_datsco"
IF !ExecRW(Csql,"U_PDV_IN","R")
   return(.f.)
ENDIF
SELECT U_PDV_IN
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
    
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   
   IF CGE_OPE = "FAT" 
      SKIP +1
      LOOP
   ENDIF  
   
   IF CGE_CGE
      SKIP +1
      LOOP
   ENDIF  

   IF CGE_DATSCO > PERAL
      EXIT
   ENDIF  

   IF AGEDAL = SPACE(10) .OR. EMPTY(AGEDAL)
   ELSE
	  IF ALLTRIM(CGE_CODPDV) <> AGEDAL
	     SKIP +1
	     LOOP
	  ENDIF
   ENDIF
 
   CTRELAB = CTRELAB + 1 
 
   WAIT WINDOW  "Incassi Elaborati "+ALLTRIM(STR(CTRELAB,6,0)) NOWAIT

   DO REG_NUMRPN
  
   DO REG_NUMREG
  
   SELECT U_PDV_IN

   M.CONTO   = CGE_CONTO
   XCON      = CGE_CODPDV
   M.DTD     = CGE_DATSCO
   IF SUBSTR(M.DTD,3,1) = '/'
   ELSE
      M.DTD = RIBALTA2(M.DTD)
   ENDIF
   M.DOC     = SUBSTR(CGE_NUMSCO,1,6)
   M.OLFAT   = SUBSTR(CGE_NUMSCO,1,6)
   M.RAGSOC  = CGE_DESPDV
   DAVD      = "A"
   XVALUTA   = PUB_VALRIF				&& FORZATURA IN BASE A VALUTA DI RIFERIMENTO
   XCAMBIO   = 1
   V_TOTALE  = CAMBIO(XVALUTA,CGE_VALORE,XCAMBIO)
   M.NUMASS  = CGE_NUMASS
   M.BANCA   = CGE_BANCA
   DATA_PAGA = CGE_DATSCO  
   XCLI_COD  = CGE_CODPDV
   XXCODAGE  = CGE_CODPDV
   TOP_TOP   =  CGE_TOP
   V_CONPAG  = "101"               
   CIVA      = CGE_CODIVA
   TIVA      = 0
   XXCONTO   = CGE_CONTRO
  
   SELECT U_PDV_IN
  
   DO MOVCRINC WITH DAVD,V_TOTALE,0,'NO',M.CONTO,TOP_TOP,M.DOC,M.DTD,.T.,M.OLFAT,XVALUTA,XCAMBIO  &&TESTATA
   DO MOVCREAI WITH DAVD,V_TOTALE,0,'NO',M.CONTO,TOP_TOP,M.DOC,M.DTD,M.OLFAT,XVALUTA,XCAMBIO      &&INDICE
   DO MOVCRINC WITH "D",V_TOTALE,0,'NO',XXCONTO,TOP_TOP,M.DOC,M.DTD,.F.,M.OLFAT,XVALUTA,XCAMBIO   &&DETTAGLI
          
   SELECT U_PDV_IN
  
   REPLACE CGE_CGE WITH .T.
  
   XSD = XSD +1
   SKIP +1

ENDDO

IF !ExecRW(Csql,"U_PDV_IN","W")
   return(.f.)
ENDIF

WAIT WINDOWS 'Elaborati n. '+str(XSD,5,0)+' Incassi' 
WAIT WINDOWS 'Elaborazione completata ...' NOWAIT
=MESSAGEBOX("Trasferimento incassi pdv in contabilitŕ terminato correttamente",62,"ATTENZIONE")
RELEASE WINDOW DISPLAY
RETURN


