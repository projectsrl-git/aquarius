
SET DEFAULT TO &PUB_DIR

__connectString = PUB_NOMEDB
__connectString_DATABASE = SUBSTR(__connectString,AT("DATABASE=",__connectString),AT(';',SUBSTR(__connectString,AT("DATABASE=",__connectString)))-1)
_V_DBAL = STRTRAN(__connectString_DATABASE,"DATABASE=","")
__config_name = "conversioni_" + _V_DBAL + ".cfg"
*PERCORSO_TREVICALOR= "D:\Trevicalor\asterdat"
PERCORSO_TREVICALOR=legge_config(__config_name,"PERCORSO_ASTERDAT")						&& RICERCA VARIABILE
WAIT WINDOWS "PERCORSO ARCHIVI TREVICALOR: " + PERCORSO_TREVICALOR
SET DEFAULT TO &PERCORSO_TREVICALOR


RIT = MESSAGEBOX("PROCEDO CON IL COMPLETAMENTO ANAGRAFICHE CLIENTI (E-MAIL E TELEFONO, OVE VUOTI) DAI DATI DESTINATARIO CORRISPONDENZA IMPIANTI ?" + REPLICATE(CHR(13),2) + ;
		"Continuare?",4+32+256,"ATTENZIONE")

IF RIT = 7
   MESSAGEBOX("Operazione abbandonata",48,"Informazione")
   RETURN
ENDIF
	
_V_PERCORSO = PERCORSO_TREVICALOR

SET EXCLUSIVE ON

*!*	V_PATH = ALLTRIM(_V_PERCORSO)
*!*	SET DEFAULT TO &V_PATH
*!*	=OPENDB("MOVIARTI")
*!*	SELECT MOVIARTI
*!*	*INDEX ON ALLTRIM(CCODSCHE)+RIBALTA2(DTOC(CDATINT))+ALLTRIM(CCODART) TAG ID_RIC  ADDITIVE
*!*	INDEX ON CDATINT DESCENDING ADDITIVE TAG D_DATINT
*!*	*SET ORDER TO ID_RIC  
*!*	GO TOP

*!*	V_PATH = ALLTRIM(_V_PERCORSO)
*!*	SET DEFAULT TO &V_PATH
*!*	=OPENDB("MOVITEST")
*!*	SELECT MOVITEST
*!*	INDEX ON CDATINT DESCENDING ADDITIVE TAG D_DATINT
*!*	SET ORDER TO D_DATINT
*!*	GO TOP

V_PATH = ALLTRIM(_V_PERCORSO)
SET DEFAULT TO &V_PATH
=OPENDB("SCHEDETEST")									&& TESTATA IMPIANTI
SELECT SCHEDETEST
*INDEX ON ALLTRIM(CCODSCHE)  TAG ID_IMPI  ADDITIVE
*SET ORDER TO ID_IMPI  
GO TOP

*!*	V_PATH = ALLTRIM(_V_PERCORSO)
*!*	SET DEFAULT TO &V_PATH
*!*	=OPENDB("SCHEDE")										&& CALDAIE
*!*	SELECT SCHEDE
*!*	INDEX ON ALLTRIM(ID_PMKEY)  TAG ID_PKEY  ADDITIVE
*!*	INDEX ON ALLTRIM(CCODSCHE)  TAG ID_SCHE  ADDITIVE
*!*	SET ORDER TO ID_SCHE  
*!*	GO TOP


*!*	V_PATH = ALLTRIM(_V_PERCORSO)
*!*	SET DEFAULT TO &V_PATH
*!*	=OPENDB("SCHEDEBRU")									&& BRUCIATORI
*!*	SELECT SCHEDEBRU
*!*	INDEX ON ALLTRIM(ID_PMKEY)  TAG ID_PKEY  ADDITIVE
*!*	INDEX ON ALLTRIM(CCODSCHE)  TAG ID_SCHE  ADDITIVE
*!*	SET ORDER TO ID_SCHE  
*!*	GO TOP



WAIT WINDOWS "Elaborazione da archivio SCHEDETEST, attendere prego ....." NOWAIT


RELEASE _KEY_ID_PMKEY,_KEY_CCODSCHE 
PUBLIC _KEY_ID_PMKEY,_KEY_CCODSCHE 

_KEY_ID_PMKEY 	= ""					&& CHIAVE DI AGGANCIO DEI RECORD
_KEY_CCODSCHE 	= ""					&& CODICE IMPIANTO


_CT_IMP	= 0				&& CONTA IMPIANTI
_CT_AGG	= 0				&& CONTA ANAGRAFICHE AGGIORNATE


SELECT SCHEDETEST
GO TOP 
SCAN

	SCATTER MEMVAR MEMO
		
	WAIT WINDOWS "Impianto elaborato: " + M.ID_PMKEY NOWAIT
	
	_CT_IMP	= _CT_IMP + 1
	
	IF EMPTY(M.CCODCLI)
		SELECT SCHEDETEST
		LOOP
	ENDIF
	
	x_cond = "CLI_CODCLI = '" + TRC(PUB_LCL,ALLTRIM(M.CCODCLI)) + "'"
	Csql   = "SELECT * FROM U_CLI_AN WHERE " + x_cond
	IF !ExecRW(cSql,"U_CLI_AN","R")
		return(.f.)
	ENDIF
	SELECT U_CLI_AN
	GO TOP
	IF !EOF()
		IF EMPTY(ALLTRIM(CLI_TELEFO)) AND !EMPTY(ALLTRIM(M.CTELDES))
			REPLACE CLI_TELEFO WITH ALLTRIM(M.CTELDES)
			_CT_AGG	= _CT_AGG + 1
		ENDIF
		IF EMPTY(ALLTRIM(CLI_EMAIL)) AND !EMPTY(ALLTRIM(M.CNOTE1))
			REPLACE CLI_EMAIL WITH ALLTRIM(M.CNOTE1)
			_CT_AGG	= _CT_AGG + 1
		ENDIF
	ENDIF
	IF !ExecRW(cSql,"U_CLI_AN","W")
		return(.f.)
	ENDIF
	
ENDSCAN
 
SELECT SCHEDETEST
use

SET EXCLUSIVE OFF

WAIT WINDOWS "Impianti elaborati: " + STR(_CT_IMP,5,0) + CHR(13) + "Clienti aggiornati: " + STR(_CT_AGG,5,0)

=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

SET DEFAULT TO &PUB_DIR

RETURN
