****************************************************************************************
** PULIZIA CLIENTE IN GIACENZE E MOVIMENTI DI MAGAZZINO (PER ELABORAZIONI SCHEDULATE) **
****************************************************************************************

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO
PUBLIC V_TITOLO

V_TITOLO = ""
WAIT WINDOWS "ESECUZIONE PROGRAMMA PULIZIA CLIENTE IN GIACENZE E MOVIMENTI DI MAGAZZINO" TIMEOUT 3

_DATA_LIMITE_AMG = RIBALTA2(DTOC(DATE() - 30))

cSql = "UPDATE U_MAG_GG SET MAG_CLIENT = ''  WHERE MAG_CLIENT <> '' AND MAG_DATAGG <= '" + _DATA_LIMITE_AMG + "'"
IF !ExecCommand(cSql,"UPD_MAG_GG")
   return(.f.)
ENDIF

cSql = "UPDATE U_MAG_MO SET MOV_CODCLI = '', MOV_DESCLI = ''  WHERE MOV_CODCLI <> '' AND MOV_DTREGI <= '" + _DATA_LIMITE_AMG + "'"
IF !ExecCommand(cSql,"UPD_MAG_GG")
   return(.f.)
ENDIF



*!*	*** VARIABILI PUBBLICHE DI UTILIZZO IN PROCEDURE DI MAGAZZINO
*!*	RELEASE PUB_SPASCA,PUB_SCAPPT,PUB_CAUMOV,PUB_CAUVBA,PUB_VALU,PUB_CLISOC,PUB_MAGNO0,PUB_MPIU,PUB_ANNO
*!*	PUBLIC PUB_SPASCA,PUB_SCAPPT,PUB_CAUMOV,PUB_CAUVBA,PUB_VALU,PUB_CLISOC,PUB_MAGNO0,PUB_MPIU,PUB_ANNO
*!*	PUB_SPASCA = ""
*!*	PUB_SCAPPT = ""
*!*	PUB_CAUMOV = ""
*!*	PUB_CAUVBA = ""
*!*	PUB_VALU = ""
*!*	PUB_CLISOC = ""
*!*	PUB_MAGNO0 = ""
*!*	PUB_MPIU = ""
*!*	=AQUADOCU()
*!*	PUB_ANNO = SUBSTR(RIBALTA2(DTOC(DATE())),1,4)

*!*	*** RILEVO LE GIACENZE DELL'ARTICOLO DA SCARICARE
*!*	_GIACENZA = 0
*!*	_ww_codsoc = PUB_CODSOC
*!*	_ww_anaart = _CODART_SCA
*!*	_ww_codmag = _MAGA_SCA
*!*	_ww_prenot = .T.  && SOLO GIACENZE NON PRENOTATE
*!*	_ww_codint = ""
*!*	_ww_altezz = 0
*!*	_ww_lunghe = 0
*!*	_ww_fila_x = ""
*!*	_ww_pian_x = ""
*!*	_ww_ubic_x = ""
*!*	_ww_umrit  = ""
*!*	_ww_escl_mag_scarto = .T.
*!*	_GIACENZA = AQM_RILEVA_GIACENZE_DISPONIBILI(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x,_ww_umrit,_ww_escl_mag_scarto)

*!*	SELECT LOCAL_U_MAG_GG	
*!*	INDEX ON MAG_DATAGG+MAG_ORACAR TAG I_ORDINA
*!*	SET ORDER TO I_ORDINA
*!*	GO TOP

*!*	WAIT CLEAR

*!*	IF EOF()
*!*		*MESSAGEBOX("Nessuna giacenza trovata",48,"Attenzione")
*!*		WAIT WINDOWS "ESECUZIONE PROGRAMMA CONFLUENZA_GIACENZE: NESSUNA GIACENZA DA FAR CONFLUIRE" TIMEOUT 3
*!*		RETURN .F.
*!*	ENDIF

*!*	*** CREAZIONE CURSORE CHE CONTERRA' LA LISTA DELLE GIACENZE ELABORATE
*!*	CREATE CURSOR CUR_GIACENZE_ELAB (O_CODMAG C(6), O_CODART C(30), O_DESART C(100), O_UM C(6), O_GIACEN N(19,6), D_CODMAG C(6), D_CODART C(30), D_DESART C(100), D_UM C(6), D_GIACEN N(19,6))

*!*	IF USED("CU_MAG_GM")
*!*		SELECT CU_MAG_GM
*!*		USE
*!*	ENDIF
*!*	cSql   = "select (MAG_GIACEN - MAG_QTAIMP) AS MAG_GIAMAX, U_ART_PR.ART_UMMAGA AS MAG_UMMAGA, u_mag_gg.* from u_mag_gg " + ;
*!*	         "LEFT OUTER JOIN U_ART_PR ON U_MAG_GG.MAG_ANAART = U_ART_PR.ART_CODPRI where 1=0"
*!*	IF !ExecCommand(cSql,'CU_MAG_GM')
*!*	   return(.f.)
*!*	ENDIF

*!*	SELECT LOCAL_U_MAG_GG
*!*	GO TOP
*!*	SCAN
*!*		SCATTER MEMVAR MEMO
*!*		
*!*		M.MAG_UMMAGA = ""
*!*		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
*!*		x_codi = "ART_CODPRI = '" + M.MAG_ANAART + "'"
*!*		x_cond = x_soci + " and " + x_codi
*!*		cSql = "SELECT ART_UMMAGA FROM U_ART_PR WHERE " + x_cond	
*!*		IF !ExecCommand(cSql,"TMP_ART_PR")
*!*		   RETURN .F.
*!*		ENDIF
*!*		SELECT TMP_ART_PR
*!*		GO TOP
*!*		IF !EOF()
*!*			M.MAG_UMMAGA = ART_UMMAGA
*!*		ENDIF
*!*		
*!*		SELECT CU_MAG_GM
*!*		APPEND BLANK
*!*		GATHER MEMVAR MEMO
*!*		REPLACE SELEZIONE WITH "=>"
*!*		REPLACE MAG_GIACEN WITH MAG_GIACEN - MAG_QTAIMP
*!*	ENDSCAN
*!*	SELECT LOCAL_U_MAG_GG
*!*	USE

*!*	WAIT CLEAR

*!*	* DEFAULT CAUSALE DI CARICO: 	PUB_CAUMOV
*!*	* DEFAULT CAUSALE DI SCARICO: 	PUB_CAUVBA

*!*	AQM_NUMMOV_LOCALE  = AQM_RILEVA_NUMERO_INTERNO()

*!*	SELECT CU_MAG_GM
*!*	GO TOP
*!*	DO WHILE !EOF()
*!*		
*!*		SCATTER MEMVAR MEMO

*!*		*** VALORIZZAZIONE VARIABILI CHE DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA (LA QUANTITA' DA SCARICARE E' CONTENUTA IN CU_MAG_GM.MAG_GIACEN)
*!*		=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
*!*		=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
*!*		*** VALORIZZAZIONE VARIABILI CHE NON DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA
*!*		AQM_DTDOCU = RIBALTA2(DTOC(DATE()))
*!*		AQM_NUMDOC = "CONFLUENZA"
*!*		AQM_CODCLI = PUB_CLISOC
*!*		AQM_TOP    = PUB_CAUVBA
*!*		AQM_DTREGI = RIBALTA2(DTOC(DATE()))
*!*		AQM_VALUTA = PUB_VALU
*!*		AQM_COORD  = ""
*!*		AQM_UM     = M.MAG_UMMAGA
*!*		AQM_PREVEN = 0
*!*		AQM_IVAVEN = ""
*!*		*SET STEP ON
*!*		_OK_SCAR = AQM_SCARICA_MAGAZZINO(.F.)
*!*		IF _OK_SCAR
*!*		ELSE
*!*			MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze",16,"Attenzione")
*!*			*SELECT CU_MAG_GM
*!*			*SKIP +1
*!*			*LOOP
*!*			EXIT
*!*		ENDIF
*!*		
*!*		SELECT CUR_GIACENZE_ELAB
*!*		APPEND BLANK
*!*		REPLACE O_CODMAG WITH AQM_CODMAG
*!*		REPLACE O_CODART WITH AQM_ANAART
*!*		REPLACE O_DESART WITH AQM_DESART
*!*		REPLACE O_UM WITH AQM_UM
*!*		REPLACE O_GIACEN WITH AQM_GIACEN
*!*		REPLACE D_CODMAG WITH ""
*!*		REPLACE D_CODART WITH ""
*!*		REPLACE D_DESART WITH ""
*!*		REPLACE D_UM WITH ""
*!*		REPLACE D_GIACEN WITH 0
*!*		
*!*		
*!*		*** CARICO GIACENZA CON NUOVO CODICE ARTICOLO
*!*		IF EMPTY(_CODART_CAR) OR EMPTY(_MAGA_CAR)  && SE VOLUTAMENTE ARTICOLO E MAGAZZINO DI CARICO SONO VUOTI, VUOL DIRE CHE NON BISOGNA VOLUTAMENTE CARICARE IL MAGAZZINO
*!*			SELECT CU_MAG_GM
*!*			SKIP +1
*!*			LOOP
*!*		ENDIF
*!*		
*!*		SELECT CU_MAG_GM
*!*		SCATTER MEMVAR MEMO
*!*		
*!*		AQM_QTAMOV_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = M.MAG_GIACEN
*!*		
*!*		AQM_QTAMQ_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = M.MAG_QTAMQ  
*!*		AQM_QTAKG_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = M.MAG_QTAKG  	
*!*		AQM_QTAML_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = M.MAG_QTAML  
*!*		AQM_QTAMC_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = M.MAG_QTAMC  
*!*		
*!*		M.ID_UNIQUE = ""
*!*		LOCAL_LEGAME = M.MAG_LEGAME

*!*		=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
*!*		=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")		
*!*	    AQM_SAVE_LEGSYS 		= ""
*!*	    LOCAL_IDUNIQUE			= ""
*!*	    
*!*		AQM_TOP = PUB_CAUMOV
*!*	    AQM_UM = M.MAG_UMMAGA
*!*	    
*!*	    AQM_ANAART = _CODART_CAR
*!*	    AQM_CODART = _CODART_CAR
*!*	    AQM_DESART = ""
*!*		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
*!*		x_codi = "ART_CODPRI = '" + AQM_ANAART + "'"
*!*		x_cond = x_soci + " and " + x_codi
*!*		cSql = "SELECT ART_DESCR FROM U_ART_PR WHERE " + x_cond	
*!*		IF !ExecCommand(cSql,"TMP_ART_PR")
*!*		   RETURN .F.
*!*		ENDIF
*!*		SELECT TMP_ART_PR
*!*		GO TOP
*!*		IF !EOF()
*!*			AQM_DESART = ART_DESCR
*!*		ELSE
*!*			SELECT CU_MAG_GM
*!*			SKIP +1
*!*			LOOP
*!*		ENDIF
*!*	    
*!*	    AQM_CODMAG = _MAGA_CAR
*!*	    AQM_DESMAG = ""
*!*		x_codi = "CODICE = 'MAG" + _MAGA_CAR + "'"
*!*		x_cond = x_codi
*!*		cSql = "SELECT * FROM PARA WHERE " + x_cond	
*!*		IF !ExecCommand(cSql,"TMP_PARA")
*!*		   RETURN .F.
*!*		ENDIF
*!*		SELECT TMP_PARA
*!*		GO TOP
*!*		IF !EOF()
*!*			AQM_DESMAG = DESCRI
*!*		ELSE
*!*			SELECT CU_MAG_GM
*!*			SKIP +1
*!*			LOOP
*!*		ENDIF
*!*	 	
*!*	 	=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()
*!*	 	
*!*	 	LOCAL_DATAOGGI = RIBALTA2(DTOC(DATE()))
*!*	 	
*!*	 	AQM_GIACEN = M.MAG_GIACEN
*!*	 	AQM_NUMDOC = "CONFLUENZA"
*!*	 	AQM_DTDOCU = LOCAL_DATAOGGI
*!*	 	AQM_DTREGI = LOCAL_DATAOGGI
*!*	 	
*!*		ORIGINALE_AQM_GIACEN 	= AQM_GIACEN
*!*		ORIGINALE_AQM_QTAKG  	= AQM_QTAKG
*!*		ORIGINALE_AQM_QTAMQ  	= AQM_QTAMQ
*!*		ORIGINALE_AQM_QTAML  	= AQM_QTAML
*!*		ORIGINALE_AQM_QTAMC  	= AQM_QTAMC   

*!*		ORIGINALE_AQM_LEGAME	= AQM_LEGAME
*!*		ORIGINALE_AQM_NUMIDE 	= AQM_NUMIDE
*!*	    ORIGINALE_AQM_PREACQ    = AQM_PREACQ
*!*	    
*!*	    ORIGINALE_AQM_SC1    = AQM_SC1
*!*	    ORIGINALE_AQM_SC2    = AQM_SC2
*!*	    ORIGINALE_AQM_SC3    = AQM_SC3
*!*	    ORIGINALE_AQM_SC4    = AQM_SC4
*!*	    ORIGINALE_AQM_SC5    = AQM_SC5
*!*	    ORIGINALE_AQM_CODFOR = AQM_CODFOR
*!*		ORIGINALE_AQM_DESFOR = AQM_DESFOR
*!*		
*!*		=ACCESSO_PARAMETRO_TOP()														&& ACCESSI ANAGRAFICI
*!*		=ACCESSO_ANAGRAFICA_FORNITORE()
*!*		=ACCESSO_ANAGRAFICA_CLIENTE()
*!*		=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)
*!*		
*!*	    LOCAL_MOVIMENTO = "CREA-MOVIMENTO"							
*!*		=AQM_CREA_U_MAG_MO(LOCAL_MOVIMENTO,.F.)												&& CREA IL MOVIMENTO DI RICARICO DELLA QUANTITA ORIGNALE DELLA DDT
*!*	    
*!*		Csql = "select * from u_mag_gg where 1=0"
*!*		IF !ExecRW(Csql,"u_mag_gg","R")
*!*		   return(.f.)
*!*		ENDIF
*!*	    SELECT U_MAG_GG
*!*		AQM_GIACEN = AQM_QTAMOV_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT
*!*		AQM_QTAMQ = AQM_QTAMQ_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
*!*		AQM_QTAKG = AQM_QTAKG_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
*!*		AQM_QTAML = AQM_QTAML_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
*!*		AQM_QTAMC = AQM_QTAMC_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT  
*!*		=AQM_CREA()	
*!*		IF !ExecRW(cSql,"U_MAG_GG","W")													&& RICARICA LA GIACENZA SU U_MAG_GG	CON LA QUANTITA' IN PRECEDENZA MOVIMENTATA									
*!*		   return(.f.)
*!*		ENDIF
*!*		
*!*		SELECT CUR_GIACENZE_ELAB
*!*		REPLACE D_CODMAG WITH AQM_CODMAG
*!*		REPLACE D_CODART WITH AQM_ANAART
*!*		REPLACE D_DESART WITH AQM_DESART
*!*		REPLACE D_UM WITH AQM_UM
*!*		REPLACE D_GIACEN WITH AQM_GIACEN

*!*		SELECT CU_MAG_GM
*!*		SKIP +1
*!*	ENDDO



*!*	SELECT CUR_GIACENZE_ELAB
*!*	GO TOP
*!*	IF !EOF()

*!*		_PDF_REPORT_ 		= ALLTRIM(CERCAREPO("XXX","CONFLUENZA_GIACENZE","CONFLUENZA_GIACENZE.FRX"))
*!*		*_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA
*!*		_PDF_DESCRIZIONE_	= "CONFLUENZA_GIACENZE"+_PROGRESSIVO_PROGRAMMA
*!*		_PDF_SELECT_ 		= "CUR_GIACENZE_ELAB"

*!*		IF !EMPTY(_PDF_SUBDIR_)
*!*			=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
*!*		ELSE
*!*			=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
*!*		ENDIF

*!*		_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

*!*		_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 
*!*		
*!*		_ERRORE =.F.
*!*		DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI,_ID_EMAIL_DA_INVIARE
*!*	ENDIF

SELECT(_SAVE_SEL )
