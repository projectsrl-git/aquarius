RIT = MESSAGEBOX("Procedo con la conversione dell' anagrafica Agenti dalle tabelle CARD_AGENTI/CARD_CLIFO/CARD_CFVEN ?",292,"ATTENZIONE")
IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF


WAIT WINDOWS "Cancellazione vecchia anagrafica Agenti in corso..." NOWAIT

cSql = "DELETE FROM PARA WHERE CODICE LIKE 'AGE%'"
IF !ExecCommand(cSql,"DEL_PARA_AGE")
   return
ENDIF

cSql = "DELETE FROM U_AGE_AN"
IF !ExecCommand(cSql,"DEL_U_AGE_AN")
   return
ENDIF


WAIT WINDOWS "Conversione Anagrafica agenti in corso..." NOWAIT

*** AGGIORNAMENTO TABELLA DELL' Anagrafica agenti
_TOT_COUNT = 0
cSql = "SELECT * FROM CARD_AGENTI ORDER BY CODICE"
IF !ExecCommand(cSql,"CX_CARD_AGENTI")
	RETURN .F.
ENDIF
SELECT CX_CARD_AGENTI
GO TOP
SCAN

	SCATTER MEMVAR
	
	__AGE_CODSOC   = PUB_CODSOC
	__AGE_CODICE   = ALLTRIM(SUBSTR(ALLTRIM(M.CODICE),3,3))
	__AGE_RAGSOC   = ""
	__AGE_INDIRI   = ""
	__AGE_LOCALI   = ""
	__AGE_CAP      = ""
	__AGE_CF       = ""
	__AGE_PI       = ""
	__AGE_AUTO1    = ""
	__AGE_AUTO2    = ""
	__AGE_PROVVI   = M.PERCPROVVI
	__AGE_NUMDAL   = ""
	__AGE_NUMAL    = ""
	__AGE_ULTNFA   = ""
	__AGE_DEPOSI   = ""
	__AGE_DEPCOL   = ""
	__AGE_LISTIN   = ""
	__AGE_MECC     = ""
	__AGE_CONTO    = ""
	__AGE_PERRIT   = 0
	__AGE_PERIMP   = 0
	__AGE_CODIVA   = ""
	__AGE_ARROTA   = 0
	__AGE_PERENA   = 0
	__AGE_MASSIM   = 0
	__AGE_NUMFAT   = ""
	__AGE_LOCAGE   = ""
	__AGE_FATTOT   = 0
	__AGE_RAUINC   = .F.
	__AGE_EFFINC   = .F.
	__AGE_RBMINC   = .F.
	__AGE_RBMPER   = .F.
	__AGE_DIFPRZ   = .F.
	__AGE_VALUTA   = ""
	__AGE_CAMBIO   = 0
	__AGE_PROVIN   = ""
	__AGE_TRASME   = ""
	__AGE_DATINS   = SUBSTR(M.ULT_AGG,1,4) + '/' + SUBSTR(M.ULT_AGG,5,2) + '/' + SUBSTR(M.ULT_AGG,7,2)
	__AGE_IMPPRO   = 0
	__AGE_PROVMAT  = 0
	__AGE_BADG1    = 0
	__AGE_BADG2    = 0
	__AGE_SCAPROV0 = 0
	__AGE_SCAPROV1 = 0
	__AGE_SCAPROV2 = 0
	__AGE_SCAPROV3 = 0
	__AGE_SCAPROV4 = 0
	__AGE_SCAPROV5 = 0
	__AGE_SCAPROV6 = 0
	__AGE_SCAPROV7 = 0
	__AGE_SCAPROV8 = 0
	__AGE_SCAPROV9 = 0
	__AGE_PERSCA   = .F.
	__AGE_NOTRASP  = .F.
	
	x_soci = "CARD_CLIFO.TIPO = 'F'"
	x_codi = "CARD_CLIFO.CODICE = '" + ALLTRIM(M.CODFORNITO) + "'"
	x_cond = x_soci + " and " + x_codi 
	cSql = "SELECT CARD_CLIFO.*, CARD_CFVEN.ASSFIS FROM CARD_CLIFO " + ;
	       "LEFT OUTER JOIN CARD_CFVEN ON CARD_CLIFO.CODICE = CARD_CFVEN.CODCF AND CARD_CLIFO.TIPO = CARD_CFVEN.TIPO WHERE " + x_cond
	IF !ExecCommand(cSql,"CX_CARD_CLIFO")
		RETURN .F.
	ENDIF
	SELECT CX_CARD_CLIFO
	GO TOP
	IF !EOF()
		__AGE_RAGSOC   = ALLTRIM(RAGIONESOC)
		*__AGE_RAGSOC   = ALLTRIM(NOMEBREVE)
		__AGE_INDIRI   = IIF(!ISNULL(INDIR1),ALLTRIM(INDIR1),"")
		__AGE_LOCALI   = IIF(!ISNULL(COMUNE),ALLTRIM(COMUNE),"")
		__AGE_CAP      = IIF(!ISNULL(CAP),ALLTRIM(CAP),"")
		__AGE_PROVIN   = IIF(!ISNULL(PROVINCIA),ALLTRIM(PROVINCIA),"")
		__AGE_CF       = IIF(!ISNULL(COFI),ALLTRIM(COFI),"")
		__AGE_PI       = IIF(!ISNULL(PAIV),ALLTRIM(PAIV),"")
		__AGE_CODIVA   = IIF(!ISNULL(ASSFIS),ALLTRIM(ASSFIS),"")
		__AGE_VALUTA   = IIF(!ISNULL(CODVAL),ALLTRIM(ASSFIS),PUB_VALRIF)
	ENDIF
	
	cSql = "SELECT * FROM U_AGE_AN WHERE 1=0"
	IF !ExecRW(cSql,"U_AGE_AN","R")
		RETURN .F.
	ENDIF
	SELECT U_AGE_AN
	APPEND BLANK
	REPLACE AGE_CODSOC   WITH __AGE_CODSOC  
	REPLACE AGE_CODICE   WITH __AGE_CODICE  
	REPLACE AGE_RAGSOC   WITH __AGE_RAGSOC  
	REPLACE AGE_INDIRI   WITH __AGE_INDIRI  
	REPLACE AGE_LOCALI   WITH __AGE_LOCALI  
	REPLACE AGE_CAP      WITH __AGE_CAP     
	REPLACE AGE_CF       WITH __AGE_CF      
	REPLACE AGE_PI       WITH __AGE_PI      
	REPLACE AGE_AUTO1    WITH __AGE_AUTO1   
	REPLACE AGE_AUTO2    WITH __AGE_AUTO2   
	REPLACE AGE_PROVVI   WITH __AGE_PROVVI  
	REPLACE AGE_NUMDAL   WITH __AGE_NUMDAL  
	REPLACE AGE_NUMAL    WITH __AGE_NUMAL   
	REPLACE AGE_ULTNFA   WITH __AGE_ULTNFA  
	REPLACE AGE_DEPOSI   WITH __AGE_DEPOSI  
	REPLACE AGE_DEPCOL   WITH __AGE_DEPCOL  
	REPLACE AGE_LISTIN   WITH __AGE_LISTIN  
	REPLACE AGE_MECC     WITH __AGE_MECC    
	REPLACE AGE_CONTO    WITH __AGE_CONTO   
	REPLACE AGE_PERRIT   WITH __AGE_PERRIT  
	REPLACE AGE_PERIMP   WITH __AGE_PERIMP  
	REPLACE AGE_CODIVA   WITH __AGE_CODIVA  
	REPLACE AGE_ARROTA   WITH __AGE_ARROTA  
	REPLACE AGE_PERENA   WITH __AGE_PERENA  
	REPLACE AGE_MASSIM   WITH __AGE_MASSIM  
	REPLACE AGE_NUMFAT   WITH __AGE_NUMFAT  
	REPLACE AGE_LOCAGE   WITH __AGE_LOCAGE  
	REPLACE AGE_FATTOT   WITH __AGE_FATTOT  
	REPLACE AGE_RAUINC   WITH __AGE_RAUINC  
	REPLACE AGE_EFFINC   WITH __AGE_EFFINC  
	REPLACE AGE_RBMINC   WITH __AGE_RBMINC  
	REPLACE AGE_RBMPER   WITH __AGE_RBMPER  
	REPLACE AGE_DIFPRZ   WITH __AGE_DIFPRZ  
	REPLACE AGE_VALUTA   WITH __AGE_VALUTA  
	REPLACE AGE_CAMBIO   WITH __AGE_CAMBIO  
	REPLACE AGE_PROVIN   WITH __AGE_PROVIN  
	REPLACE AGE_TRASME   WITH __AGE_TRASME  
	REPLACE AGE_DATINS   WITH __AGE_DATINS  
	REPLACE AGE_IMPPRO   WITH __AGE_IMPPRO  
	REPLACE AGE_PROVMAT  WITH __AGE_PROVMAT 
	REPLACE AGE_BADG1    WITH __AGE_BADG1   
	REPLACE AGE_BADG2    WITH __AGE_BADG2   
	REPLACE AGE_SCAPROV0 WITH __AGE_SCAPROV0
	REPLACE AGE_SCAPROV1 WITH __AGE_SCAPROV1
	REPLACE AGE_SCAPROV2 WITH __AGE_SCAPROV2
	REPLACE AGE_SCAPROV3 WITH __AGE_SCAPROV3
	REPLACE AGE_SCAPROV4 WITH __AGE_SCAPROV4
	REPLACE AGE_SCAPROV5 WITH __AGE_SCAPROV5
	REPLACE AGE_SCAPROV6 WITH __AGE_SCAPROV6
	REPLACE AGE_SCAPROV7 WITH __AGE_SCAPROV7
	REPLACE AGE_SCAPROV8 WITH __AGE_SCAPROV8
	REPLACE AGE_SCAPROV9 WITH __AGE_SCAPROV9
	REPLACE AGE_PERSCA   WITH __AGE_PERSCA  
	REPLACE AGE_NOTRASP  WITH __AGE_NOTRASP 
	cSql = "SELECT * FROM U_AGE_AN WHERE 1=0"
	IF !ExecRW(cSql,"U_AGE_AN","W")
		RETURN .F.
	ENDIF
	
	
	cSql = "SELECT * FROM PARA WHERE 1=0"
	IF !ExecRW(cSql,"PARA","R")
		RETURN .F.
	ENDIF
	SELECT PARA
	GO TOP
	APPEND BLANK
	REPLACE CODICE WITH "AGE" + __AGE_CODICE
	REPLACE DESCRI WITH __AGE_RAGSOC
	REPLACE LIBERA WITH "Fornitore legato: " + ALLTRIM(M.CODFORNITO)
	REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))
	IF !ExecRW(cSql,"PARA","W")
		RETURN .F.
	ENDIF
		
	_TOT_COUNT = _TOT_COUNT + 1

ENDSCAN

*** AGGIUNTA AGENTE DIREZIONALE
__AGE_CODSOC = PUB_CODSOC
__AGE_CODICE = "000"
__AGE_RAGSOC = "DIREZIONALE"
cSql = "SELECT * FROM U_AGE_AN WHERE 1=0"
IF !ExecRW(cSql,"U_AGE_AN","R")
	RETURN .F.
ENDIF
SELECT U_AGE_AN
APPEND BLANK
REPLACE AGE_CODSOC   WITH __AGE_CODSOC 
REPLACE AGE_CODICE   WITH __AGE_CODICE 
REPLACE AGE_RAGSOC   WITH __AGE_RAGSOC 
cSql = "SELECT * FROM U_AGE_AN WHERE 1=0"
IF !ExecRW(cSql,"U_AGE_AN","W")
	RETURN .F.
ENDIF

cSql = "SELECT * FROM PARA WHERE 1=0"
IF !ExecRW(cSql,"PARA","R")
	RETURN .F.
ENDIF
SELECT PARA
GO TOP
APPEND BLANK
REPLACE CODICE WITH "AGE" + __AGE_CODICE
REPLACE DESCRI WITH __AGE_RAGSOC
REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))
IF !ExecRW(cSql,"PARA","W")
	RETURN .F.
ENDIF

WAIT CLEAR

MESSAGEBOX("Operazione terminata correttamente" + REPLICATE(CHR(13),2) + ;
	"Totale anagrafiche Agenti convertite: " + ALLTRIM(STR(_TOT_COUNT,10,0)),64,"Informazione")

RETURN


 