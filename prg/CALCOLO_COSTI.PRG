
DO SETLIB



*!*	ESPLODE LA DISTINTA RICALCOLANDO COSTI,RICAVI,TEMPI
*!*	SI_VIDEO 			= .F.
*!*	ricalcolo_costi 	= .T.
*!*	ricalcolo_ricavi 	= .T.
*!*	ricalcolo_tempi		= .T.
*!*	DO ALBERELLO WITH SI_VIDEO,M.DIT_GRUPPO,LIV_ESPL,_MAG,ricalcolo_costi,ricalcolo_ricavi,ricalcolo_tempi,analisi_dati		&& ESPLODE LA DISTINTA BASE CON IL RICALCOLO COSTI/RICAVI


*!*	ESPLODE LA DISTINTA SENZA FARE NULLA
LIV_ESPL 			= .F.
_MAG     			= "SEDE  "
SI_VIDEO 			= .F.
ricalcolo_costi 	= .F.
ricalcolo_ricavi 	= .F.
ricalcolo_tempi		= .F.
analisi_dati		= 1			&& dettaglio costi,ricavi,tempi per MENU_ALBERELLO



=DEFINISCE_WCALCOLO_COSTI()

M.DIT_GRUPPO		= "M_M_M_M_M_M_M_9_"
DO ALBERELLO WITH SI_VIDEO,M.DIT_GRUPPO,LIV_ESPL,_MAG,ricalcolo_costi,ricalcolo_ricavi,ricalcolo_tempi,analisi_dati			&& ESPLODE LA DISTINTA BASE CON IL RICALCOLO COSTI/RICAVI
CURSORE_INPUT = "WEXPLODE"
CURSORE_OUTPUT = "WCALCOLO_COSTI"
=CREA_LIVELLI_PER_CALCOLO_COSTI(CURSORE_INPUT,CURSORE_OUTPUT)  && COPIA WEXPLODE IN WCALCOLO_COSTI





M.DIT_GRUPPO		= "TEST_DB"
DO ALBERELLO WITH SI_VIDEO,M.DIT_GRUPPO,LIV_ESPL,_MAG,ricalcolo_costi,ricalcolo_ricavi,ricalcolo_tempi,analisi_dati			&& ESPLODE LA DISTINTA BASE CON IL RICALCOLO COSTI/RICAVI
CURSORE_INPUT = "WEXPLODE"
CURSORE_OUTPUT = "WCALCOLO_COSTI"
=CREA_LIVELLI_PER_CALCOLO_COSTI(CURSORE_INPUT,CURSORE_OUTPUT)  && COPIA WEXPLODE IN WCALCOLO_COSTI





SELECT WCALCOLO_COSTI
GO TOP
BROWSE NORMAL

