
WAIT WINDOWS "Estrazione movimenti per consumo carte impregnate..." NOWAIT

_V_DATADA = "01/01/"+PUB_ANNO
_V_DATAAL = "31/12/"+PUB_ANNO

_CONTINUA = .F.
DO FORM FORM\CONSUMO_CARTE_IMPREGNATE_SELDATE LINKED
IF !_CONTINUA
	MESSAGEBOX("Operazione abbandonata",48,"Informazione")
	RETURN .F.
ENDIF

cSql=""
cNomeCursorSql="ESTR_CARTE"
TEXT TO cSql NOSHOW

	SELECT
		ART_CODCOL AS COD_COLORE_CARTA,
		DESCOL AS DESCR_COLORE_CARTA,
		SUM(MOV_QTAMOV) AS QTA_NR_SCARICHI_PROD,
		SUM(MOV_QTAMQ) AS QTA_MQ_SCARICHI_PROD
	FROM (
		SELECT
			MOV_CODMAG,
			MOV_ANAART,
			ART_ALTEZZ,
			ART_LUNGHE,
			ART_DESCR,
			ART_CODCOL,
			COALESCE(PARA.DESCRI,'') AS DESCOL,
			MOV_TOP,
			MOV_QTAMOV,
			CAST((ART_ALTEZZ * ART_LUNGHE / 1000000 * MOV_QTAMOV) AS NUMERIC(10,2)) AS MOV_QTAMQ 
		FROM U_MAG_MO, U_ART_PR, PARA
		WHERE
			U_MAG_MO.MOV_ANAART = U_ART_PR.ART_CODPRI AND 
			'COL'+U_ART_PR.ART_CODCOL = PARA.CODICE AND 
			ART_CODMAT = '011' AND 
			MOV_DOCMOD = 0 AND 
			MOV_TOP = 'SCP' AND 
			MOV_DTREGI >= '<<RIBALTA2(_V_DATADA)>>' AND 
			MOV_DTREGI <= '<<RIBALTA2(_V_DATAAL)>>'
		) AS MAIN
	GROUP BY MAIN.ART_CODCOL,MAIN.DESCOL
	ORDER BY ART_CODCOL
		
ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql,.T.)
	return(.F.)
ENDIF
*** SE L'UTENTE HA ANNULLATO LA QUERY IL CURSORE POTREBBE NON ESISTERE, 
*** QUINDI NON PERMETTO DI ANDARE AVANTI
IF !USED("ESTR_CARTE")
	RETURN .F.
ENDIF

SELECT ESTR_CARTE
GO TOP
IF EOF()
	MESSAGEBOX("Nessun dato da estrarre per i filtri selezionati",64,"Informazione")
ELSE
	_TITOLO_EXCEL1 = "Consumo carte impregnate"
	_TITOLO_EXCEL2 = "Periodo di riferimento dal " + _V_DATADA + " al " + _V_DATAAL
	_TITOLO_EXCEL3 = ""
	_TOTALI_GENERALI = .T.
	DO ESTRXLS WITH "ESTR_CARTE",_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,_TOTALI_GENERALI
	
	MESSAGEBOX("Fine elaborazione",64,"Informazione")
ENDIF

