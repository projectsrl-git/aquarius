
CLEAR ALL
CLOSE ALL

SET MULTILOCKS ON
PUBLIC pub_sqlhd,pub_datawh
pub_sqlhd  = 0
pub_datawh = ""

SET PROCEDURE TO SQLLIB 	ADDITIVE

** Impostazione SET Iniziali
SET STATUS BAR OFF
SET AUTOSAVE ON
SET CENTURY ON
SET CLOCK STATUS

****** SET DATE TO GERMAN

SET DATE TO DMY

SET DELETED ON
SET ESCAPE OFF
SET EXACT ON
SET EXCLUSIVE OFF
SET HOURS TO 24
SET NEAR ON
SET REPROCESS TO AUTOMATIC
SET SAFETY OFF
SET TALK OFF
SET MARK TO "/"
SET DECIMAL TO 6  && GESTIONE EURO

** Aggancio librerie di procedure esterne
SET PROCEDURE TO LOOP_INCASSOLIB ADDITIVE

IF !FILE("SEMAFORO.INC")
	HD=FCREATE("SEMAFORO.INC")
	=FPUTS(HD,"PIPPO")
	=FCLOSE(HD)
    DO GESTIONE_LOOPINCASSO
    ERASE SEMAFORO.INC
ENDIF

CLOSE DATABASES ALL
CLOSE DATABASES
CLOSE DATA ALL
 
RETURN

