PUBLIC Y_CAMPO,V_CAMPO,_CTR
Y_CAMPO = ""
V_CAMPO = ""
_CTR    = 0

CREATE CURSOR TRANSITO (TRA_RECORD C(200))

SELECT TRANSITO
APPEND FROM &V_PATH SDF

*SELECT TRANSITO  
*gcTable = GETFILE('', 'Seleziona file piano mdei conti da convertire', 'Converti',0)
*IF empty(gcTable) .or. gcTable = ""
*   =MESSAGEBOX("Nessun file selezionato, operazione abbandonata",62,"ATTENZIONE")
*   RETURN
*ENDIF
*APPEND FROM &gcTable SDF
*GO TOP

DELETE FOR SUBSTR(TRA_RECORD,2,5) = "-----"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,3,7) = "Azienda"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,2) = "Ms"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,46,9) = "Pagamento"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,52,8) = "Telefono"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,4,1) = "."  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,100) = SPACE(100) ALL
GO TOP

V_CONTA = 0

SELECT TRANSITO
GO TOP
BROWSE NORMAL


DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF SUBSTR(TRA_RECORD,1,8) = SPACE(08)
      SKIP +1
      LOOP
   ENDIF

   M.FOR_CODSOC = '01'
   M.FOR_CODCLI = ALLTRIM(SUBSTR(TRA_RECORD,1,2)) +  ALLTRIM(SUBSTR(TRA_RECORD,4,5))    
   M.FOR_CODCLI = TRC(PUB_LCL,ALLTRIM(M.FOR_CODCLI))
   M.FOR_RAGSOC = ALLTRIM(SUBSTR(TRA_RECORD,11,40))      
   M.FOR_INDIR  = ALLTRIM(SUBSTR(TRA_RECORD,52,40))      
   M.FOR_LOCALI = ALLTRIM(SUBSTR(TRA_RECORD,93,22))
   M.FOR_PROVIN = ALLTRIM(SUBSTR(TRA_RECORD,116,2))
   M.FOR_PARIVA = ALLTRIM(SUBSTR(TRA_RECORD,119,11))
   M.FOR_CODFIS = ALLTRIM(SUBSTR(TRA_RECORD,136,16))
   M.FOR_FLGNOT = 'N'

   M.FOR_CONPAG = PUB_CPA
   M.FOR_CODIVA = PUB_IVA
   M.FOR_VALUTA = PUB_VALU
   M.FOR_NAZION = PUB_NAZI
   M.FOR_DATNEW = RIBALTA2(DTOC(DATE()))
   M.FOR_DATINS = RIBALTA2(DTOC(DATE()))

   M.FOR_DESPAG = SPACE(30)
   M.FOR_DESBAN = SPACE(29)
   M.FOR_TELEFO = SPACE(20)
   M.FOR_TELEX  = SPACE(20)
   M.FOR_FAX    = SPACE(20)

   M.FOR_BDAL 	= '0108'
   M.FOR_BAL 	= '3108'
   M.FOR_GG1 	= '1009'
   M.FOR_B2DAL  = '2012'
   M.FOR_B2AL 	= '3112'
   M.FOR_GG2 	= '1001'

   M.FOR_COSATRATTA 		= 'GENER'
   M.FOR_GRADOIMPORTANZA 	= 'PRIMA'
   M.FOR_FORMAPAGAMENTO 	= 'RIMES'
   M.FOR_TIPOCONTRATTO 		= 'SCADE'
   M.FOR_CODACQ	 			= '001'
   M.FOR_PRIPAGA			= '0500'

   SKIP +1
   IF EOF()
      DO VERIFICA_FORNITORE
      EXIT
   ENDIF

   IF SUBSTR(TRA_RECORD,1,8) <> SPACE(08)
      IF SUBSTR(TRA_RECORD,3,1) = SPACE(01)
         DO VERIFICA_FORNITORE
         SELECT TRANSITO
         LOOP
      ENDIF
   ENDIF
   
   IF SUBSTR(TRA_RECORD,46,6) <> SPACE(06)
      M.FOR_DESPAG = ALLTRIM(SUBSTR(TRA_RECORD,46,30))
      M.FOR_DESBAN = ALLTRIM(SUBSTR(TRA_RECORD,77,30))
   ELSE
      M.FOR_TELEFO = ALLTRIM(SUBSTR(TRA_RECORD,52,20))
      M.FOR_TELEX  = ALLTRIM(SUBSTR(TRA_RECORD,73,20))
      M.FOR_FAX    = ALLTRIM(SUBSTR(TRA_RECORD,94,20))
   ENDIF
   
   SKIP +1
   IF EOF()
      DO VERIFICA_FORNITORE
      EXIT
   ENDIF

   IF SUBSTR(TRA_RECORD,1,8) <> SPACE(08)
      IF SUBSTR(TRA_RECORD,3,1) = SPACE(01)
         DO VERIFICA_FORNITORE
         SELECT TRANSITO
         LOOP
      ENDIF
   ENDIF

   IF SUBSTR(TRA_RECORD,46,6) <> SPACE(06)
      M.FOR_DESPAG = ALLTRIM(SUBSTR(TRA_RECORD,46,30))
      M.FOR_DESBAN = ALLTRIM(SUBSTR(TRA_RECORD,77,30))
   ELSE
      M.FOR_TELEFO = ALLTRIM(SUBSTR(TRA_RECORD,52,20))
      M.FOR_TELEX  = ALLTRIM(SUBSTR(TRA_RECORD,73,20))
      M.FOR_FAX    = ALLTRIM(SUBSTR(TRA_RECORD,94,20))
   ENDIF

   DO VERIFICA_FORNITORE

   SELECT TRANSITO      
   SKIP +1
    
    EXIT
    
    
ENDDO

cSql = "select * from u_cnt_an where cnt_tipo = 'FOR'"
IF !ExecRW(cSql,"U_CNT_AN","R")
   return(.f.)
ENDIF
SELECT U_CNT_AN
REPLACE CNT_DATFIN WITH RIBALTA2(DTOC(DATE()))
REPLACE CNT_ORAFIN WITH TIME()
REPLACE CNT_NUMREC WITH V_CONTA
IF !ExecRW(cSql,"U_CNT_AN","W")
   return(.f.)
ENDIF

=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

RETURN

   
*********************
PROCEDURE TOGLI_PUNTI
*********************

YY      = LEN(V_CAMPO)
XX      = 1
Y_CAMPO =  ' '
DO WHILE .T.
   IF XX > YY
      EXIT
   ENDIF
   IF SUBSTR(V_CAMPO,XX,1) = '.' 
   ELSE
      Y_CAMPO = Y_CAMPO + SUBSTR(V_CAMPO,XX,1) 
   ENDIF
   XX = XX + 1
ENDDO

RETURN


****************************
PROCEDURE VERIFICA_FORNITORE
****************************

x_soci = "for_codsoc = '" + M.FOR_CODSOC + "'"
x_codi = "for_codcli = '" + M.FOR_CODCLI + "'"
x_cond = x_soci + " and " + x_codi
cSql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
IF !ExecRW(cSql,"u_for_an","R")
   return
ENDIF
SELECT u_for_an
IF EOF()
   m.id_unique = ""
   APPEND BLANK
ENDIF

M.FOR_RAGSOC = UPPER(M.FOR_RAGSOC)
M.FOR_RAGSOC = APITOSPA(M.FOR_RAGSOC)
M.FOR_INDIR  = UPPER(M.FOR_INDIR)
M.FOR_INDIR  = APITOSPA(M.FOR_INDIR)
M.FOR_LOCALI = UPPER(M.FOR_LOCALI)
M.FOR_LOCALI = APITOSPA(M.FOR_LOCALI)
M.FOR_PROVIN = UPPER(M.FOR_PROVIN)
M.FOR_CODFIS = APITOSPA(M.FOR_CODFIS)

REPLACE FOR_CODSOC WITH M.FOR_CODSOC
REPLACE FOR_CODCLI WITH M.FOR_CODCLI
REPLACE FOR_RAGSOC WITH M.FOR_RAGSOC
REPLACE FOR_INDIR  WITH M.FOR_INDIR
REPLACE FOR_LOCALI WITH M.FOR_LOCALI
REPLACE FOR_PROVIN WITH M.FOR_PROVIN
REPLACE FOR_PARIVA WITH M.FOR_PARIVA
REPLACE FOR_CODFIS WITH M.FOR_CODFIS
REPLACE FOR_TELEFO WITH M.FOR_TELEFO
REPLACE FOR_TELEX  WITH M.FOR_TELEX
REPLACE FOR_FAX    WITH M.FOR_FAX
REPLACE FOR_VALUTA WITH M.FOR_VALUTA
REPLACE FOR_NAZION WITH M.FOR_NAZION
REPLACE FOR_DATNEW WITH RIBALTA2(DTOC(DATE()))
REPLACE FOR_DATINS WITH RIBALTA2(DTOC(DATE()))
REPLACE FOR_CONPAG WITH M.FOR_CONPAG
REPLACE FOR_CODIVA WITH M.FOR_CODIVA
REPLACE FOR_FLGTRA WITH .T.


 REPLACE FOR_BDAL 	WITH '0108'
 REPLACE FOR_BAL 	WITH '3108'
 REPLACE FOR_GG1 	WITH '1009'
 REPLACE FOR_B2DAL  WITH '2012'
 REPLACE FOR_B2AL 	WITH '3112'
 REPLACE FOR_GG2 	WITH '1001'

 REPLACE FOR_COSATRATTA 		WITH 'GENER'
 REPLACE FOR_GRADOIMPORTANZA 	WITH 'PRIMA'
 REPLACE FOR_FORMAPAGAMENTO 	WITH 'RIMES'
 REPLACE FOR_TIPOCONTRATTO 		WITH 'SCADE'
 REPLACE FOR_CODACQ	 			WITH '001'
 REPLACE FOR_PRIPAGA			WITH '0500'

IF !ExecRW(cSql,"u_for_an","W")
   return
ENDIF

V_CONTA = V_CONTA + 1

_CTR = _CTR +1
WAIT WINDOWS "RECORDS SCRITTI : "+STR(_CTR,10,0) NOWAIT

RETURN