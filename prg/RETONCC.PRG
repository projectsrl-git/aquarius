DEFINE WINDOW WSELESOC;
AT 0,0 SIZE 20,100;
SYSTEM CLOSE NOGROW FLOAT;
FONT 'Courier New',8
MOVE WINDOW WSELESOC CENTER

CREATE CURSOR DETTBOL (AGGANC C(10),CODCLI C(10),CODART C(30),DESART C(40),DATSCA C(10), NUMORD C(06),;
                       DATORD C(10),QTAORD N(10,3),QTAEVA N(10,3),QTADEV N(10,3), INTRAS C(10), ;
                       UM C(2),IVA C(3),MAGA C(6),DATCON C(10),;
                       PREZZO N(17,3),SC1 N(8,3),SC2 N(8,3),SC3 N(8,3),PRZNET N(17,3),VALORE N(17,3),VALUTA C(3,0),CAMBIO N(17,10), ;
                       CODTAG C(03), DESTAG C(30), CODCOL C(03), DESCOL C(30))

IF DATADAL = SPACE(10) .OR. DATADAL = '  /  /    ' 
   DATADAL = '01/01/' + PUB_ANNOP
ENDIF   
IF DATAAL = SPACE(10) .OR. DATAAL = '  /  /    ' 
   DATAAL = '31/12/' + PUB_ANNO
ENDIF   

IF !ExecCommand("select * from u_bol_tt where 0=1","u_bol_tt")
   return(.f.)
ENDIF
SELECT U_BOL_TT
HH=AFIELDS(TRAN_BOL)
CREATE CURSOR CBOL_TT FROM ARRAY TRAN_BOL

=_ELABOL1("DATA",DATADAL,DATAAL,PUB_ANNO,SPACE(06),"  ",CLIDAL,SPACE(03))

V_EVASIONE = 0
V_EVASPARZ = 0

SELECT CBOL_TT
GO TOP

DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   
   AGGA    = TAGGANCIO
   VNUMORD = ORD_NUMORD
   VDATORD = ORD_DATORD
   VINTRAS = ORD_INTRAS
   VVALUTA = ORD_VALUTA
   VCAMBIO = ORD_CAMBIO
   VCODCLI = ORD_CODCLI

   x_cond = "daggancio = '" + ALLTRIM(AGGA) + "'"
   Csql   = "select * from u_bol_dd where " + x_cond + " order by daggancio,ord_sequen"
   IF !ExecCommand(cSql,"CU_BOL_DD")
      return(.f.)
   ENDIF
   SELECT CU_BOL_DD
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF ("*** COMMENTO ***" $ ORD_DESART)
         SKIP +1
         LOOP
      ENDIF      
      IF ARTDAL = SPACE(16)
      ELSE
         IF ORD_CODART < ARTDAL
            SKIP +1
            LOOP
         ENDIF 
      ENDIF
      IF ARTAL = SPACE(16)
      ELSE
         IF ORD_CODART > ARTAL
            SKIP +1
            LOOP
         ENDIF  
      ENDIF

      VDATSCA = ORD_DATCON 
      VCODART = ORD_CODART
      VDESART = ORD_DESART
      VQTAORD = ORD_QTAORD
      VQTAEVA = ORD_QTAEV
      VQTADEV = 0
      VVALORE = ORD_VALORE
      VPREZZO = ORD_PREZZO
      VSC1    = ORD_SC1
      VSC2    = ORD_SC2
      VSC3    = ORD_SC3
      VPRZNET = ORD_PRZNET
      VUM     = ORD_UM
      VIVA    = ORD_IVA
      VMAGA   = ORD_MAGA
      VDATCON = ORD_DATCON
      VCODCOL = ORD_CODCOL
      VDESCOL = ORD_DESCOL
      VCODTAG = ORD_CODTAG
      VDESTAG = ORD_DESTAG

      SELECT DETTBOL 
      APPEND BLANK
      REPLACE AGGANC  WITH AGGA
      REPLACE CODART  WITH VCODART
      REPLACE DESART  WITH VDESART
      REPLACE DATSCA  WITH VDATSCA
      REPLACE NUMORD  WITH VNUMORD
      REPLACE DATORD  WITH VDATORD
      REPLACE INTRAS  WITH VINTRAS
      REPLACE QTAORD  WITH VQTAORD
      REPLACE QTAEVA  WITH VQTAEVA
      REPLACE QTADEV  WITH VQTADEV
      REPLACE VALORE  WITH VVALORE
      REPLACE VALUTA  WITH VVALUTA
      REPLACE CAMBIO  WITH VCAMBIO
      REPLACE PREZZO  WITH VPREZZO
      REPLACE SC1     WITH VSC1
      REPLACE SC2     WITH VSC2
      REPLACE SC3     WITH VSC3
      REPLACE PRZNET  WITH VPRZNET
      REPLACE CODCLI  WITH VCODCLI
      REPLACE UM      WITH VUM
      REPLACE IVA     WITH VIVA
      REPLACE MAGA    WITH VMAGA
      REPLACE DATCON  WITH VDATCON
      REPLACE CODTAG  WITH VCODTAG
      REPLACE DESTAG  WITH VDESTAG
      REPLACE CODCOL  WITH VCODCOL
      REPLACE DESCOL  WITH VDESCOL
   
      SELECT CU_BOL_DD
      SKIP +1

   ENDDO

   SELECT CBOL_TT
   SKIP +1
   
ENDDO   

SELECT DETTBOL
GO TOP
IF EOF()
   RELEASE WINDOWS WSELESOC
   OK_PROC = .F.
   RETURN
ENDIF

SELECT DETTBOL
GO TOP
INDEX ON CODART + RIBALTA2(DATSCA) TAG I_DETTBOL
SET ORDER TO I_DETTBOL
GO TOP

BROWSE FIELDS CODART:16:H='CODICE ARTICOLO':R, ;
              DESART:35:H='DESCRIZIONE':R    , ;
              DATSCA:12:H='DATA SCAD.':R    , ;
              NUMORD:10:H='N.D.D.T.':R    , ;
              INTRAS:12:H='DATA DDT.':R    , ;
              DATORD:12:H='DATA REG.':R    , ;
              QTAORD:12:H='SPEDITO':R       , ; 
              QTADEV:12:H='DA RENDERE' TITLE 'Elenco dettagli D.D.T. cliente: '+RAGSOC NOMENU NODELETE WINDOW WSELESOC

* AGGIORNA CURSORE FINALE SU BASE ARTICOLI SELEZIONATI

SELECT DETTBOL
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF QTADEV > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF      

   SCATTER MEMVAR MEMO   

   SELECT CURSBOL
   APPEND BLANK
   GATHER MEMVAR MEMO
         
   SELECT DETTBOL
   SKIP +1              

ENDDO

RELEASE WINDOWS WSELESOC

RETURN

************************
FUNCTION INDATA
************************
IF DATADAL = SPACE(10) .OR. DATADAL = '  /  /    ' 
   DATADAL = '01/01/' + PUB_ANNO
ENDIF   
IF DATAAL = SPACE(10) .OR. DATAAL = '  /  /    ' 
   DATAAL = '31/12/' + PUB_ANNO
ENDIF   

IF ORD_DATORD>=RIBALTA2(DATADAL) .AND. ORD_DATORD<=RIBALTA2(DATAAL)
   OUT = .T.
ELSE
   OUT = .F.
ENDIF

RETURN(OUT)