DO SETLIB


=DEF_VIP000()						&& DEFINISCE I CURSORE PER LA GESTIONE DEI PARTITARI/CLIENTI/FORNITORI

*!*	FORAL   	= "2010000000515" 		&& CODICE FORNITORE VALOTA

_CF="C"

*!*	TUTTE LE PARTITE DEL FORNITORE / CLIENTE APERTE
IF _CF  = "C"
	_ARCH_IN	= "PART_CLI"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
ELSE
	_ARCH_IN	= "PART_FOR"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
ENDIF

_CONTO		= "TUTTI"			  	&& CODICE DEL CLIENTE/FORNITORE
***_CONTO="2110100000053"
_DATADAL	= "01/01/1990"			&& PERIODO DI ESTRAZIONE DELLE PARTITE DAL
_DATAAL		= "31/12/2999"			&& PERIODO DI ESTRAZIONE DELLE PARTITE AL
_PARTITA	= 0				 		&& NUMERO DI PARTITA , SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
_NUMREGI	= ""			 		&& NUMERO DI REGISTRAZIONE ,SE INDICATA ESTRAE SOLO LA PARTITA DEL CLIENTE O DEL FORNITORE ALRIMENTI TUTTE
_CURSORE    = "SCADE"		 		&& NOME DEL CURSORE DI RITORNO CONTENENTE LE PARITE
_DTSCADE	= "31/12/2011"         && RITORNA TUTTE LE PARTITE SCADUTE SINO ALLA DATA COMPRESA
_DTASCAD	= ""	          		&& RITORNA TUTTE LE PARTITE CHE SCADRANNO DALA DATA INDICATA , ALTRIMENTI TUTTE
_SOLOSALDO	= "SCADENZE" 			&& RITORNA SOLO IL SALDO DELLA PARTITA , ALTRIMENTI TUTTE
_ORDINE		= 8 				 	&& ORDINE DI ANNO / NUMERO PARTITA / DATA DI SCADENZA
_OPENCLOSE	= 2						&& 2 : RITORNA SOLO I MOVIMENTI DI DETTAGLIO DELLE PARTITE ANCORA APERTE
_SOLO_RIBA_ = 0

=CERCA_PARTITE(_CF,_ARCH_IN,_CONTO,_DATADAL,_DATAAL,_PARTITA,_NUMREGI,_CURSORE,_DTSCADE,_DTASCAD,_SOLOSALDO,_ORDINE,_OPENCLOSE,_SOLO_RIBA_)  

SELECT SCADE
GO TOP
BROWSE NORMAL
SUM NDARE TO _NDARE
SUM NAVERE TO _NAVERE 
COUNT TO _NUMRIGHE

? _ARCH_IN+" DARE="+ALLTRIM(STR(_NDARE,13,2))+" - AVERE="+ALLTRIM(STR(_NAVERE,13,2))+" - SALDO="+ALLTRIM(STR(_NDARE-_NAVERE,13,2))+" - NUMRIGHE="+ALLTRIM(STR(_NUMRIGHE))




