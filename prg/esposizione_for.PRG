** PROCEDURA PER LA VERIFICA DELL'ESPOSIZIONE MENSILE SUGLI ACQUISTI
**

** Cursore per memorizzare i dati dell'esposizione mensile
**
** PRIMO RECORD   : CONTIENE IL TOTALE DELL'ESPOSIZIONE ESPRESSO IN SCADUTO DAL MESE CORRENTE-1 A SCADERE DAL MESE CORRENTE IN POI PER I DODICI MESI SUCCESSIVI A QUELLO CORRENTE
** SECONDO RECORD : CONTIENE IL VALORE DELL'ORDINE D'ACQUISTO CON IVA
** TERZO RECORD   : TOTALE DEI DUE PRIMI RECORD

LPARAMETERS P_DATA,P_CPA,P_IMPORTO,P_VALUTA


CREATE CURSOR cu_esposizione_for (;
  VAL_SCADUTO      N(17,3), ;
  VAL_ASCAD01      N(17,3), ;
  VAL_ASCAD02      N(17,3), ;
  VAL_ASCAD03      N(17,3), ;
  VAL_ASCAD04      N(17,3), ;
  VAL_ASCAD05      N(17,3), ;
  VAL_ASCAD06      N(17,3), ;
  VAL_ASCAD07      N(17,3), ;
  VAL_ASCAD08      N(17,3), ;
  VAL_ASCAD09      N(17,3), ;
  VAL_ASCAD10      N(17,3), ;
  VAL_ASCAD11      N(17,3), ;
  VAL_ASCAD12      N(17,3), ;
  VAL_SIGNIFICATO_RIGA  C(3))

** imposto il significato delle tre righe del cursore
SELECT cu_esposizione_for 
APPEND BLANK
REPLACE VAL_SIGNIFICATO_RIGA  WITH "Exp"
APPEND BLANK
REPLACE VAL_SIGNIFICATO_RIGA  WITH "Acq"
APPEND BLANK
REPLACE VAL_SIGNIFICATO_RIGA  WITH "Tot"
GO top 

SELECT CU_ESPOSIZIONE_FOR 
INDEX ON VAL_SIGNIFICATO_RIGA  TAG RIGA
SET ORDER TO RIGA
 
RELEASE __VERIFICA_ESPOZIONE_ACQUISTI_MENSILI
PUBLIC __VERIFICA_ESPOZIONE_ACQUISTI_MENSILI
__VERIFICA_ESPOZIONE_ACQUISTI_MENSILI = "ESPOSIZIONE MENSILE ACQUISTI : ORDINE IN SOFFERENZA DI PAGAMENTO" 
 
 
DO VALORI_ESPOSIZIONE_DA_SCADENZIARIO

DO VALORI_ESPOSIZIONE_DA_SCADENZE_ORDINE WITH P_DATA,P_CPA,P_IMPORTO,P_VALUTA

DO VALORI_ESPOSIZIONE_TOTALE

DO FORM FORM\esposizione_for WITH "Esposizione mensile acquisti" LINKED


*******************************************************************
PROCEDURE VALORI_ESPOSIZIONE_DA_SCADENZIARIO
*******************************************************************

=UNDEF_VIP000()
=DEF_VIP000()		&& DEFINISCE I CURSORE PER LA GESTIONE INCASSI CLIENTI


SCD_FORDAL=''
SCD_FORAL=''
SCD_VOPENCLOSE=2
SCD_VTUTTI="TUTTI"
SCD_VDTSCDAL="01/01/1990"
SCD_VDTSCAL="31/12/2999"
SCD_VSOLORIBA=0
SCD_VELA_AGEN_=""
SCD_SOLOSALDO="SCADENZE"
SCD_VTIPOPA=.F.
SCD_VPARTITA=0
SCD_INCLUDE_CONTABILITA_PREVISIONALE=0

CARICA_PARTITE_DAL_AL('F',;
	SCD_FORDAL,;
	SCD_FORAL,;
	SCD_VOPENCLOSE,;
	SCD_VTUTTI,;
	SCD_VDTSCDAL,;
	SCD_VDTSCAL,;
	SCD_VSOLORIBA,;
	SCD_VELA_AGEN_,;
	SCD_SOLOSALDO,;
	SCD_VTIPOPA,;
	SCD_VPARTITA,;
	SCD_INCLUDE_CONTABILITA_PREVISIONALE)  





SELECT CU_ESPOSIZIONE_FOR 
SEEK "Exp"

SELECT SCADE
GO TOP 

_MESE_OGGI=SUBSTR(DTOC(DATE()),4,2)
_ANNO_OGGI=SUBSTR(DTOC(DATE()),7,4)
_VAL_MESE_OGGI=VAL(_ANNO_OGGI+_MESE_OGGI)

*** DTSCAD
*** NSALDO
SCAN 

	_SALDO_SCADENZA=-NSALDO

	_MESE_SCADENZA=SUBSTR(DTSCAD,4,2)
	_ANNO_SCADENZA=SUBSTR(DTSCAD,7,4)

	_VAL_MESE_SCADENZA=VAL(_ANNO_SCADENZA+_MESE_SCADENZA)
	_DELTA_MESE= _VAL_MESE_SCADENZA-_VAL_MESE_OGGI
	_CAMPO_ESPOSIZIONE=""
	
	DO CASE
		
		CASE _DELTA_MESE<=0
			_CAMPO_ESPOSIZIONE="VAL_SCADUTO"
		
		CASE _DELTA_MESE>0 AND _DELTA_MESE<=12
			_CAMPO_ESPOSIZIONE="VAL_ASCAD"+PADL(ALLTRIM(STR(_DELTA_MESE,2,0)),2,"0")
		
		CASE _DELTA_MESE>12
			_CAMPO_ESPOSIZIONE="VAL_ASCAD12"
			
	ENDCASE		
	
	
	SELECT CU_ESPOSIZIONE_FOR 
	REPLACE &_CAMPO_ESPOSIZIONE WITH &_CAMPO_ESPOSIZIONE + _SALDO_SCADENZA
		
	
	SELECT SCADE

ENDSCAN

SELECT CU_ESPOSIZIONE_FOR 
GO TOP

RETURN


*******************************************************************
PROCEDURE VALORI_ESPOSIZIONE_DA_SCADENZE_ORDINE 
*******************************************************************
LPARAMETERS P_DATA,P_CPA,P_IMPORTO,P_VALUTA

DATA_SCAD   = SPACE(10)
PUBLIC VET_DAL[2],VET_AL[2],VET_DAY[2]
VET_DAL[1]= "0000"      
VET_DAL[2]= "0000"
VET_AL[1] = "0000"
VET_AL[2] = "0000" 
VET_DAY[1]= "0000" 
VET_DAY[2]= "0000"
___FLAG_POSALL = .F.		&& 2010-08-04 sergio posticipi per tutto l'anno
___CLIENTE     = ""		&& 2010-08-04 sergio posticipi per tutto l'anno

V_CONPAG     = CPA
V_TUTTO      = TRANCHE("PARA",P_CPA,RIBALTA2(P_DATA),P_IMPORTO,VET_DAL,VET_AL,VET_DAY,P_VALUTA,___FLAG_POSALL,___CLIENTE)    && 2010-08-04 sergio posticipi per tutto l'anno



SELECT CU_ESPOSIZIONE_FOR 
SEEK "Acq"


SELECT CU_TRANK
GO TOP

_MESE_OGGI=SUBSTR(DTOC(DATE()),4,2)
_ANNO_OGGI=SUBSTR(DTOC(DATE()),7,4)
_VAL_MESE_OGGI=VAL(_ANNO_OGGI+_MESE_OGGI)

*** TK_DSCAD
*** TK_IMP_SCAD
SCAN 

	_SALDO_SCADENZA=TK_IMP_SCAD

	_MESE_SCADENZA=SUBSTR(TK_DSCAD,4,2)
	_ANNO_SCADENZA=SUBSTR(TK_DSCAD,7,4)

	_VAL_MESE_SCADENZA=VAL(_ANNO_SCADENZA+_MESE_SCADENZA)
	_DELTA_MESE= _VAL_MESE_SCADENZA-_VAL_MESE_OGGI
	_CAMPO_ESPOSIZIONE=""
	
	DO CASE
		
		CASE _DELTA_MESE<=0
			_CAMPO_ESPOSIZIONE="VAL_SCADUTO"
		
		CASE _DELTA_MESE>0 AND _DELTA_MESE<=12
			_CAMPO_ESPOSIZIONE="VAL_ASCAD"+PADL(ALLTRIM(STR(_DELTA_MESE,2,0)),2,"0")
		
		CASE _DELTA_MESE>12
			_CAMPO_ESPOSIZIONE="VAL_ASCAD12"
			
	ENDCASE		
	
	
	SELECT CU_ESPOSIZIONE_FOR 
	REPLACE &_CAMPO_ESPOSIZIONE WITH &_CAMPO_ESPOSIZIONE + _SALDO_SCADENZA
		
	
	SELECT CU_TRANK

ENDSCAN



SELECT CU_ESPOSIZIONE_FOR 
GO TOP

RETURN


*******************************************************************
PROCEDURE VALORI_ESPOSIZIONE_TOTALE
*******************************************************************

SELECT CU_ESPOSIZIONE_FOR 
SEEK "Acq"
  
_ACQ_VAL_SCADUTO = VAL_SCADUTO 
_ACQ_VAL_ASCAD01 = VAL_ASCAD01
_ACQ_VAL_ASCAD02 = VAL_ASCAD02
_ACQ_VAL_ASCAD03 = VAL_ASCAD03
_ACQ_VAL_ASCAD04 = VAL_ASCAD04
_ACQ_VAL_ASCAD05 = VAL_ASCAD05
_ACQ_VAL_ASCAD06 = VAL_ASCAD06
_ACQ_VAL_ASCAD07 = VAL_ASCAD07
_ACQ_VAL_ASCAD08 = VAL_ASCAD08
_ACQ_VAL_ASCAD09 = VAL_ASCAD09
_ACQ_VAL_ASCAD10 = VAL_ASCAD10
_ACQ_VAL_ASCAD11 = VAL_ASCAD11
_ACQ_VAL_ASCAD12 = VAL_ASCAD12


SELECT CU_ESPOSIZIONE_FOR 
SEEK "Exp"
_EXP_VAL_SCADUTO = VAL_SCADUTO 
_EXP_VAL_ASCAD01 = VAL_ASCAD01
_EXP_VAL_ASCAD02 = VAL_ASCAD02
_EXP_VAL_ASCAD03 = VAL_ASCAD03
_EXP_VAL_ASCAD04 = VAL_ASCAD04
_EXP_VAL_ASCAD05 = VAL_ASCAD05
_EXP_VAL_ASCAD06 = VAL_ASCAD06
_EXP_VAL_ASCAD07 = VAL_ASCAD07
_EXP_VAL_ASCAD08 = VAL_ASCAD08
_EXP_VAL_ASCAD09 = VAL_ASCAD09
_EXP_VAL_ASCAD10 = VAL_ASCAD10
_EXP_VAL_ASCAD11 = VAL_ASCAD11
_EXP_VAL_ASCAD12 = VAL_ASCAD12


SELECT CU_ESPOSIZIONE_FOR 
SEEK "Tot"

REPLACE VAL_SCADUTO WITH _ACQ_VAL_SCADUTO+_EXP_VAL_SCADUTO 
REPLACE VAL_ASCAD01 WITH _ACQ_VAL_ASCAD01+_EXP_VAL_ASCAD01
REPLACE VAL_ASCAD02 WITH _ACQ_VAL_ASCAD02+_EXP_VAL_ASCAD02
REPLACE VAL_ASCAD03 WITH _ACQ_VAL_ASCAD03+_EXP_VAL_ASCAD03
REPLACE VAL_ASCAD04 WITH _ACQ_VAL_ASCAD04+_EXP_VAL_ASCAD04
REPLACE VAL_ASCAD05 WITH _ACQ_VAL_ASCAD05+_EXP_VAL_ASCAD05
REPLACE VAL_ASCAD06 WITH _ACQ_VAL_ASCAD06+_EXP_VAL_ASCAD06
REPLACE VAL_ASCAD07 WITH _ACQ_VAL_ASCAD07+_EXP_VAL_ASCAD07
REPLACE VAL_ASCAD08 WITH _ACQ_VAL_ASCAD08+_EXP_VAL_ASCAD08
REPLACE VAL_ASCAD09 WITH _ACQ_VAL_ASCAD09+_EXP_VAL_ASCAD09
REPLACE VAL_ASCAD10 WITH _ACQ_VAL_ASCAD10+_EXP_VAL_ASCAD10
REPLACE VAL_ASCAD11 WITH _ACQ_VAL_ASCAD11+_EXP_VAL_ASCAD11
REPLACE VAL_ASCAD12 WITH _ACQ_VAL_ASCAD12+_EXP_VAL_ASCAD12


SELECT CU_ESPOSIZIONE_FOR 
GO TOP 

RETURN
      



