*************************************
* SITUAZIONE_SCORTE_MINIME
*************************************

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

*!*	RELEASE V_TITOLO,V_GIORNI_PRECEDENTI
*!*	PUBLIC V_TITOLO,V_GIORNI_PRECEDENTI

*!*	V_GIORNI_PRECEDENTI = _GIORNI_PRECEDENTI

*!*	V_TITOLO = "Giacenze alla data"

WAIT WINDOWS "ESEGUE PROGRAMMA SITUAZIONE_SCORTE_MINIME" TIMEOUT 3

*###### DA FORM\PDM_SITGIAC.cerca_giacen ################################################################################################################################################

RELEASE _V_FILTRI,_V_DATAAL,_V_OPZDAT
PUBLIC _V_FILTRI,_V_DATAAL,_V_OPZDAT
*_V_FILTRI = "FILTRI DI ELABORAZIONE: " + CHR(13) + "   GIACENZE ALLA DATA " + _V_DATAAL
_V_FILTRI = ""  && ERASMO 09/07/2024
_V_DATAAL = ""
_V_OPZDAT = .T.

LOCAL _DIRECTORY_PDF,_NOME_REPORT

_DIRECTORY_PDF=LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")  && RICERCA PERCORSO
IF !DIRECTORY(_DIRECTORY_PDF)
	*MESSAGEBOX("Directory '" + JUSTDRIVE(_DIRECTORY_PDF) + "' inesistente" + CHR(13) + CHR(13) + ;
		"Non sarŕ possibile creare correttamente i files PDF",48,"Attenzione")
	RETURN .F.
ENDIF	

_NOME_REPORT = _DIRECTORY_PDF + "\" + "SITUAZIONE_SCORTE_MINIME_" + SYS(2015) + ".XLSX"

SET PROCEDURE TO PRG\APPLILIB ADDITIVE
SET PROCEDURE TO PRG\XLSLIB	ADDITIVE
SET PROCEDURE TO PRG\AQMLIB	ADDITIVE  && ERASMO - 24/10/2025

WAIT WINDOW "ATTENDERE PREGO: creazione report excel in corso..." NOWAIT

RELEASE PUB_ANNO,PUB_CARORF,PUB_DECQTA,PUB_SKART,PUB_FORMAR,PUB_BOLLA,PUB_MAGPDMVERS,PUB_SCPPDMSPED,PUB_SPASCA,PUB_SCAPPT,PUB_INTXLS,PUB_PRDISP,PUB_CLISOC
PUBLIC PUB_ANNO,PUB_CARORF,PUB_DECQTA,PUB_SKART,PUB_FORMAR,PUB_BOLLA,PUB_MAGPDMVERS,PUB_SCPPDMSPED,PUB_SPASCA,PUB_SCAPPT,PUB_INTXLS,PUB_PRDISP,PUB_CLISOC
PUB_ANNO = SUBSTR(DTOC(DATE()),7,4)
PUB_CARORF = ""
PUB_DECQTA = 0
PUB_SKART = .F.
PUB_FORMAR = ""
PUB_BOLLA = ""
PUB_MAGPDMVERS = ""
PUB_SCPPDMSPED = ""
PUB_SPASCA = ""
PUB_SCAPPT = ""
PUB_INTXLS = .F.
PUB_PRDISP = .F.
*PUB_CLISOC = AZI_CODCLI
PUB_CLISOC = ""  && ERASMO - 28/06/2024

Csql = "SELECT * FROM U_AZI_AN"
IF !ExecCommand(cSql,'CU_AZI_AN')
	return(.f.)
ENDIF
SELECT CU_AZI_AN
GO TOP
IF !EOF()
	PUB_CARORF = AZI_CARORF
	PUB_DECQTA = AZI_DECQTA
	PUB_SKART = AZI_SKART
	PUB_FORMAR = AZI_FORMAR
	PUB_BOLLA = AZI_BOLLA
	PUB_CLISOC = AZI_CODCLI  && ERASMO - 28/06/2024
ENDIF

Csql = "SELECT * FROM U_AZI_PA"
IF !ExecCommand(cSql,'CU_AZI_PA')
	return(.f.)
ENDIF
SELECT CU_AZI_PA
GO TOP
IF !EOF()
	PUB_MAGPDMVERS = AZI_MAGPDMVERS
	PUB_SPASCA = AZI_SPASCA
	PUB_SCAPPT = AZI_SCAPPT
	PUB_PRDISP = AZI_PRDISP
ENDIF

Csql = "SELECT * FROM U_AZI_PB"
IF !ExecCommand(cSql,'CU_AZI_PB')
	return(.f.)
ENDIF
SELECT CU_AZI_PB
GO TOP
IF !EOF()
	PUB_SCPPDMSPED = AZI_SCPPDMSPED
	PUB_INTXLS = AZI_INTXLS 
ENDIF
SET STEP ON
DO FORM FORM\MENU_SCORMI_STA WITH _NOME_REPORT

*!*	RELEASE PROCEDURE PRG\APPLILIB 
*!*	RELEASE PROCEDURE PRG\XLSLIB

_FILE_DA_ALLEGARE = JUSTFNAME(_NOME_REPORT)

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 

_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
