************************************************************************
PROCEDURE TROVA10
************************************************************************
PARAMETERS CODE10,QTA10
PRIVATE CODE10,REK10,GRU10,QTA10
CNT=CNT+1



x_codi = "dis_gruppo = '" + CODE10 + "'"
cSql   = "SELECT * FROM u_dis_dd WHERE " + x_codi + " order by dis_gruppo,dis_sequen"
IF !ExecCommand(cSql,"U_DIS_DD_L10")
   return(.f.)
ENDIF
SELECT U_DIS_DD_L10
GO TOP

DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP
      LOOP
   ENDIF

   IF _non_esplode_i_componenti
	   IF DIS_ESPLOD = "X"
	      SKIP
	      LOOP
	   ENDIF 
   ENDIF 

   _V_CODART = DIS_CODART
   V_TIPO    = DIS_TIPO
   _V_DESCRI = DIS_DESCRI
   _V_COSTO  = DIS_COSTO
   _V_PREZZO = DIS_PREZZO
   V_QTA     = DIS_QTA
   V_EXP     = DIS_ESPLOD
   V_PERC    = DIS_PERC
   V_QTACO2  = DIS_QTACO2
   _V_DES2   = DIS_DSNOCQ

   _V_COSLAI = DIS_COSLAI 
   _V_COSLAE = DIS_COSLAE 
   _V_COSMAT = DIS_COSMAT 
   _V_COSATR = DIS_COSATR 

   _V_RICLAI = DIS_RICLAI 
   _V_RICLAE = DIS_RICLAE  
   _V_RICMAT = DIS_RICMAT 
   _V_RICATR = DIS_RICATR 

   _V_ORELAV = DIS_ORELAV 
   _V_OREATT = DIS_OREATT  
   _V_OREIMP = DIS_OREIMP 

   _V_SECIMP = DIS_SECIMP 
   _V_SECLAV = DIS_SECLAV 
   _V_SECATT = DIS_SECATT 

   _V_EXP    = DIS_ESPLOD
   _V_COMSOS = DIS_COMSOS
   _V_FASELA = DIS_FASELA


   _V_SYSDD  = DIS_SYSDD
 
   _V_MAGA	 = DIS_MAGA

   IF !EMPTY(_CERCA_COMPONENTE) 
   		IF ALLTRIM(_V_CODART) = ALLTRIM(_CERCA_COMPONENTE)
   				PUB_COMPONTENTE_TROVATO = .T.						&& IL COMPONENTE ESISTE NELLA DISTITA BASE ESPLOSA
   		ENDIF
   ENDIF

    
   SELECT WEXPLODE
   APPEND BLANK
   REPLACE WCOD WITH _V_CODART
   REPLACE WDES WITH _V_DESCRI
   REPLACE WDES2 WITH _V_DES2
   REPLACE WCOS WITH _V_COSTO
   REPLACE WPRZ WITH _V_PREZZO
   REPLACE WTIP WITH V_TIPO
   REPLACE WLIV WITH CNT
   REPLACE WQTA WITH V_QTA
   V_XTREE = REPLICATE('-',WLIV)
   REPLACE TREE WITH V_XTREE + SPACE(WLIV) + WCOD
   V_QUANTI = ROUND((V_QTA * QTA10),7)
   REPLACE WQTAT WITH V_QUANTI
   REPLACE WCOST WITH ROUND((_V_COSTO*V_QUANTI),2)
   REPLACE WPRZT WITH ROUND((_V_PREZZO*V_QUANTI),2)
   REPLACE WPERC WITH V_PERC
   REPLACE WQTACO2 WITH V_QTACO2

   REPLACE WEXP	 	WITH _V_EXP    
   REPLACE WCOMSOS  WITH _V_COMSOS 
   REPLACE WFASELA	WITH _V_FASELA 


   IF _RICALCOLA_COSTI
       =RICALCOLA_COSTI_MP_LIVELLO_L10(_V_CODART,V_TIPO)
   ENDIF


   REPLACE WCOSLAI WITH _V_COSLAI 			&& COSTI DI PRODUZIONE
   REPLACE WCOSLAE WITH _V_COSLAE 
   REPLACE WCOSMAT WITH _V_COSMAT 
   REPLACE WCOSATR WITH _V_COSATR 

   IF _RICALCOLA_RICAVI
       =RICALCOLA_RICAVI_MP_LIVELLO_L10(_V_CODART,V_TIPO)
   ENDIF

   REPLACE WRICLAI WITH _V_RICLAI 			&& RICAVI DI PRODUZIONE 
   REPLACE WRICLAE WITH _V_RICLAE  
   REPLACE WRICMAT WITH _V_RICMAT 
   REPLACE WRICATR WITH _V_RICATR 

   IF _RICALCOLA_TEMPI
       =RICALCOLA_TEMPI_LIVELLO_L10(_V_CODART,V_TIPO)
   ENDIF

   REPLACE WORELAV WITH _V_ORELAV 			&& TEMPI DI PRODUZIONE 
   REPLACE WOREATT WITH _V_OREATT  
   REPLACE WOREIMP WITH _V_OREIMP 

   REPLACE WSECIMP WITH _V_SECIMP 			&& TEMPI IN SECONDI DI PRODUZIONE 
   REPLACE WSECLAV WITH _V_SECLAV 
   REPLACE WSECATT WITH _V_SECATT 

   REPLACE WSYSDD  WITH _V_SYSDD

   REPLACE WMAGA   WITH _V_MAGA 	

   REPLACE WGRUPPO WITH _G_CODART
   REPLACE WDESGRU WITH _G_DESCRI 
     

   =CERCA_ANAGRAFICA_ARTICOLI(_V_CODART)

   SELECT U_DIS_DD_L10
   
   IF DIS_TIPO=='G'
   
		   DO PLAYWAV WITH "BLIP.WAV" 

		 		   XDESCRI=CHR(13)+"NON E' PIU' POSSIBILE CONTINUARE "
		   SET CLASSLIB TO "proj_lib.vcx" additive
		   oForm=CreateObject("MsgErr") 
		   oform.edit1.Value=""+XDESCRI+CHR(13)+;
					  "LIVELLI GESTITI : 1O "+CHR(13)+;			  
					  ""
		   oform.Show
		   RELEASE oForm 
   
*!*	      REK10=RECNO()
*!*	      GRU10=CODE
*!*	      SALVA_GRUPPO_DISTINTA_L10 = DIS_CODART      
*!*	      =TROVA11(DIS_CODART,V_QUANTI)
*!*	      SELECT U_DIS_DD_L10
*!*	      GOTO REK10
*!*	      =AGGIORNA_TOTALE_COSTI_RICAVI_TEMPI(SALVA_GRUPPO_DISTINTA_L10,"U_DIS_DD_L10","L11")	&& AGGIORNA IL TOTALE COSTO/RICAVO APPENA RICALCOLATO PER IL GRUPPO IN ELABORAZIOE
*!*	      CODE=GRU10
   ENDIF
   
   SKIP +1

ENDDO

=AGGIORNA_U_DIS_DD(SALVA_GRUPPO_DISTINTA_L10,"U_DIS_DD_L10")

CNT=CNT-1

RETURN







************************************************************************
FUNCTION RICALCOLA_COSTI_MP_LIVELLO_L00
************************************************************************
*!*	RIPORTA SU WEXPLODE I COSTI DALL'ANAGRAFICA ARTICOLI PER LE MATERIE PRIME
PARAMETERS ___CODART,___TIPO



SS=STR(SELECT())

IF _RICALCOLA_COSTI 
ELSE
	SELECT &SS
	RETURN
ENDIF

IF ___TIPO <> 'A'
    SELECT &SS
	RETURN
ENDIF

	
	x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
	x_codi = "art_codpri = '" + ALLTRIM(___CODART) + "'"
	x_cond = x_soci + " and " + x_codi
	Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
	IF !ExecCommand(cSql,"_cur_articoli")
	   return(.f.)
	ENDIF
	SELECT _cur_articoli
	GO TOP
	IF EOF()
		   _RICALCOLA_COSLAI 	= 0 
		   _RICALCOLA_COSLAE 	= 0
		   _RICALCOLA_COSMAT 	= 0
		   _RICALCOLA_COSATR 	= 0
	ELSE
		   _RICALCOLA_COSLAI 	= ART_COSLAI   
		   _RICALCOLA_COSLAE 	= ART_COSLAE
		   _RICALCOLA_COSMAT 	= ART_COSMAT
		   _RICALCOLA_COSATR 	= ART_COSATR
	ENDIF



    _ART_COS_TOTALE	= _RICALCOLA_COSLAI + _RICALCOLA_COSLAE + _RICALCOLA_COSMAT + _RICALCOLA_COSATR 
    IF _ART_COS_TOTALE = 0		&& RIPRISTINA IL COSTO DELLA DISTINTA ALTRIMENTI ESSENDO A ZERO , AZZERA IL COSTO DELLA DISTINTA BASE
		   _RICALCOLA_COSLAI 	= _V_COSLAI 
		   _RICALCOLA_COSLAE 	= _V_COSLAE 
		   _RICALCOLA_COSMAT 	= _V_COSMAT 
		   _RICALCOLA_COSATR 	= _V_COSATR 
    ENDIF
 	

    SELECT WEXPLODE

    REPLACE WCOSLAI WITH _RICALCOLA_COSLAI 			&& COSTI DA ANAGRAFICA ARTICOLI
    REPLACE WCOSLAE WITH _RICALCOLA_COSLAE 
    REPLACE WCOSMAT WITH _RICALCOLA_COSMAT 
    REPLACE WCOSATR WITH _RICALCOLA_COSATR 


    _V_COSTO  		= _RICALCOLA_COSLAI + _RICALCOLA_COSLAE + _RICALCOLA_COSMAT + _RICALCOLA_COSATR 
 	_COS_TOTALE		= _V_COSTO  
 	 
    
    REPLACE WCOS    WITH _V_COSTO
    REPLACE WCOST   WITH ROUND((_V_COSTO*V_QTA),2)

 	    
    ** RICALCOLA IL COSTO TOTALE IN FUNZIONE DELLA QUANTITA'
	L00_RICALCOLA_COSLAI = L00_RICALCOLA_COSLAI + ROUND((_RICALCOLA_COSLAI*V_QTA),2) 		&& COSTI DI PRODUZIONE MATERIE PRIME A LIVELLO 00
	L00_RICALCOLA_COSLAE = L00_RICALCOLA_COSLAE + ROUND((_RICALCOLA_COSLAE*V_QTA),2) 
	L00_RICALCOLA_COSMAT = L00_RICALCOLA_COSMAT + ROUND((_RICALCOLA_COSMAT*V_QTA),2) 
	L00_RICALCOLA_COSATR = L00_RICALCOLA_COSATR + ROUND((_RICALCOLA_COSATR*V_QTA),2) 
	L00_COS_TOTALE		 = L00_COS_TOTALE + ROUND((_V_COSTO*V_QTA),2)


	IF _RICALCOLA_COSTI
	    
	    SELECT U_DIS_DD_L00

        REPLACE DIS_COSLAI WITH _RICALCOLA_COSLAI
        REPLACE DIS_COSLAE WITH _RICALCOLA_COSLAE
        REPLACE DIS_COSMAT WITH _RICALCOLA_COSMAT 
        REPLACE DIS_COSATR WITH _RICALCOLA_COSATR
        REPLACE DIS_COSTO  WITH _COS_TOTALE

	    

	ENDIF


    
    
SELECT &SS

RETURN

