	L10_OREATT		=da_secondi_a_ore_minuti_secondi(L10_SEC_ATT+_SEC_ATT)	&& TOTALE HH:MM:SS DI ATTREZZAGGIO
	L10_SECATT  	=da_ore_minuti_secondi_a_secondi(L10_OREATT)    		&& TOTALE SECONDI CALCOLATI DI LAVORAZIONE

	L10_SECIMP   	=L10_SECLAV + L10_SECATT					 			&& TOTALE SECONDI CALCOLATI DI LAVORAZIONE + ATTREZZAGGIO
	L10_OREIMP  	=da_secondi_a_ore_minuti_secondi(L10_SECIMP)			&& TOTALE ORE CALCOLATE DI LAVORAZIONE + ATTREZZAGGIO

 
    
SELECT &SS

RETURN




