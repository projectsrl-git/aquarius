		   _RICALCOLA_RICMAT 	= _V_RICMAT 
		   _RICALCOLA_RICATR 	= _V_RICATR 
    ENDIF

    SELECT WEXPLODE

    REPLACE WRICLAI WITH _RICALCOLA_RICLAI 			&& PREZZI DI RICAVO DA ANAGRAFICA ARTICOLI
    REPLACE WRICLAE WITH _RICALCOLA_RICLAE 
    REPLACE WRICMAT WITH _RICALCOLA_RICMAT 
    REPLACE WRICATR WITH _RICALCOLA_RICATR 


    _V_PREZZO  		= _RICALCOLA_RICLAI + _RICALCOLA_RICLAE + _RICALCOLA_RICMAT + _RICALCOLA_RICATR 
 	_RIC_TOTALE		= _V_PREZZO      
    
    REPLACE WPRZ    WITH _V_PREZZO
    REPLACE WPRZT   WITH ROUND((_V_PREZZO*V_QTA),2)
  
    ** RICALCOLA IL PREZZO TOTALE IN FUNZIONE DELLA QUANTITA'
	L10_RICALCOLA_RICLAI = L10_RICALCOLA_RICLAI + ROUND((_RICALCOLA_RICLAI*V_QTA),2) 		&& PREZZI DI RICAVO DI PRODUZIONE MATERIE PRIME A LIVELLO 00
	L10_RICALCOLA_RICLAE = L10_RICALCOLA_RICLAE + ROUND((_RICALCOLA_RICLAE*V_QTA),2) 
	L10_RICALCOLA_RICMAT = L10_RICALCOLA_RICMAT + ROUND((_RICALCOLA_RICMAT*V_QTA),2) 
	L10_RICALCOLA_RICATR = L10_RICALCOLA_RICATR + ROUND((_RICALCOLA_RICATR*V_QTA),2) 
	L10_RIC_TOTALE		 = L10_RIC_TOTALE + ROUND((_V_PREZZO*V_QTA),2)

	IF _RICALCOLA_RICAVI
	    
	    SELECT U_DIS_DD_L10
	    
        REPLACE DIS_RICLAI WITH _RICALCOLA_RICLAI
        REPLACE DIS_RICLAE WITH _RICALCOLA_RICLAE
        REPLACE DIS_RICMAT WITH _RICALCOLA_RICMAT 
        REPLACE DIS_RICATR WITH _RICALCOLA_RICATR
        REPLACE DIS_PREZZO WITH _RIC_TOTALE

	ENDIF
    
    
SELECT &SS

RETURN




