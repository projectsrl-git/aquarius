*!*	_____________________________________________________________________________________
*!*	ESEMPIO DI IMPOSTAZIONE DEI PARAMETRI PER ESEGUIRE L'ESPLOSIONE A VIDEO DELLA RICETTA
*!*	=====================================================================================
*!*	
*!*	TIPO_CALCOLO 						= 0
*!*	LIV_ESPL 							= .F.
*!*	_MAG     							= m.art_maga	&& codice magazzino
*!*	analisi_dati						= 1				&& dettaglio costi,ricavi,tempi per MENU_ALBERELLO
*!*	si_giacenze							= .T.			&& non mostra giacenze i magazzino
*!*	cerca_componente					= ""			&& usato da menu_disove per verificare se esiste il ompoente desiderato nella ricetta
*!*	_non_esplode_i_componenti_fantasma	= .F.			&& non esplode i componenti fantasma
*!*	ricalcolo_costi 					= .F.			&& no costi/ricavi/tempi
*!*	ricalcolo_ricavi 					= .F.			&& no costi/ricavi/tempi
*!*	ricalcolo_tempi						= .F.			&& no costi/ricavi/tempi
*!*	ricalcolo_costi_ricavi 				= .F.			&& no costi/ricavi/tempi
*!*	ricalcolo_tempi_costi_ricavi 		= .F.			&& no costi/ricavi/tempi
*!*	solo_costi_e_tempi_produttivi 		= .F.			&& no costi/ricavi/tempi	
*!*	SI_VIDEO 							= .T.			&& mostra a video
*!*	si_giacenze							= .T.			&& non mostra giacenze i magazzino
*!*	
*!*	DO ALBERELLO WITH SI_VIDEO,m.art_cddiba,LIV_ESPL,_MAG,ricalcolo_costi,ricalcolo_ricavi,ricalcolo_tempi,analisi_dati,si_giacenze,cerca_componente,_non_esplode_i_componenti_fantasma			&& ESPLODE LA DISTINTA BASE CON IL RICALCOLO COSTI/RICAVI
*!*	
*!*	

***************************************************************************
PROCEDURE ALBERELLO
***************************************************************************
*
*	_ANALISI_DATI	:	1	mostra i dettagli dei costi,ricavi,tempi
*					:   
*					:
*		output		:   PUB_COMPONTENTE_TROVATO = .T. se il componente richiesto esiste nella distinta base (WHERE USE)
*					:
*					:   
*					:
*
PARA SI_VIDEO,XXGRUPPO,LIV_ESPL,_MAG,_RICALCOLA_COSTI,_RICALCOLA_RICAVI,_RICALCOLA_TEMPI,_ANALISI_DATI,_SI_GIACENZE,_CERCA_COMPONENTE,_NON_ESPLODE_I_COMPONENTI

**=> ERASMO - INIZIO 06/06/2013
*** SOSTITUZIONE PROCEDURA "ALBERELLO" CON PROCEDURA RICORSIVA "ALBERO_DIBA" PRESENTE IN PRG\DISTINTA_BASE_LIB.PRG
IF PCOUNT() >= 3
ELSE
	LIV_ESPL = 128  && NUMERO MASSIMO DI RICHIAMI RICORSIVI NIDIFICATI SUPPORTATI IN VFP9
ENDIF

IF TYPE("LIV_ESPL") <> 'N'
	LIV_ESPL = 128
ENDIF

DO ALBERO_DIBA WITH SI_VIDEO,XXGRUPPO,LIV_ESPL

RETURN
**=> ERASMO - FINE 06/06/2013

_N_PAR = PARAMETERS()
IF _N_PAR = 2
   LIV_ESPL = .F.
   _MAG = ""
   _RICALCOLA_COSTI 					= .F.
   _RICALCOLA_RICAVI					= .F.
   _RICALCOLA_TEMPI 					= .F.
   _ANALISI_DATI						= 1
   _SI_GIACENZE							= .T.  
   _CERCA_COMPONENTE 					= ""
   _NON_ESPLODE_I_COMPONENTI			= .F.
ENDIF
IF _N_PAR = 3
   _MAG = ""
   _RICALCOLA_COSTI 					= .F.
   _RICALCOLA_RICAVI					= .F.
   _RICALCOLA_TEMPI 					= .F.
   _ANALISI_DATI						= 1
   _SI_GIACENZE							= .T. 
   _CERCA_COMPONENTE 					= ""   
   _NON_ESPLODE_I_COMPONENTI			= .F.
ENDIF
IF _N_PAR = 4
   _RICALCOLA_COSTI 					= .F.
   _RICALCOLA_RICAVI					= .F.
   _RICALCOLA_TEMPI 					= .F.
   _ANALISI_DATI						= 1
   _SI_GIACENZE							= .T.   
   _CERCA_COMPONENTE 					= ""
   _NON_ESPLODE_I_COMPONENTI			= .F.
ENDIF
IF _N_PAR = 5
   _RICALCOLA_RICAVI					= .F.
   _RICALCOLA_TEMPI 					= .F.
   _ANALISI_DATI						= 1
   _SI_GIACENZE							= .T.   
   _CERCA_COMPONENTE 					= ""
   _NON_ESPLODE_I_COMPONENTI			= .F.
ENDIF
IF _N_PAR = 6
   _RICALCOLA_TEMPI 					= .F.
   _ANALISI_DATI						= 1
   _CERCA_COMPONENTE 					= ""
   _NON_ESPLODE_I_COMPONENTI			= .F.
ENDIF
IF _N_PAR = 7
   _ANALISI_DATI						= 1
   _SI_GIACENZE							= .T.   
   _CERCA_COMPONENTE 					= ""
   _NON_ESPLODE_I_COMPONENTI			= .F.
ENDIF
IF _N_PAR = 8
   _SI_GIACENZE							= .T.   
   _CERCA_COMPONENTE 					= ""
   _NON_ESPLODE_I_COMPONENTI			= .F.
ENDIF
IF _N_PAR = 9
   _CERCA_COMPONENTE 					= ""
   _NON_ESPLODE_I_COMPONENTI			= .F.
ENDIF
IF _N_PAR = 10
   _NON_ESPLODE_I_COMPONENTI			= .F.
ENDIF


=IMPOSTA_VARIABILI_ESPLOSIONE_DISTINTA()					&& DEFINISCE LE VARIABII PER L'ESPLOSIONE DELLA DISTINTA BASE


IF LIV_ESPL = .F.
   v_seek	= 'NUM'+'LDB'+'LIV'
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      LIV_ESPLN = VAL(SUBSTR(LIBERA,1,2))
      IF LIV_ESPLN > 98
         LIV_ESPLN = 98
      ENDIF         
   ELSE
      LIV_ESPLN = 98
   ENDIF
ELSE
   LIV_ESPLN = 98
ENDIF
IF LIV_ESPLN < 1
   LIV_ESPLN = 98
ENDIF         
LIV_ESPLN = LIV_ESPLN + 1


=DEFINISCE_WEXPLODE()										&& DEFINISCE IL CURSORE PER L'ESPLOSIONE DELLA DISTINTA BASE



*!*														 	LIVELLO 0 													####
*!*	################################################### 	LIVELLO 0 		################################################
*!*														 	LIVELLO 0 													####

x_soci = "dit_codsoc = '" + PUB_CODSOC + "'"
x_codi = "dit_gruppo = '" + ALLTRIM(XXGRUPPO) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_dis_tt where " + x_cond + " order by dit_codsoc,dit_gruppo"
IF !ExecCommand(cSql,"K_DIS_TT")
   return(.f.)
ENDIF


SELECT K_DIS_TT
GO TOP
IF EOF()
   RETURN
ENDIF

SCATTER MEMVAR MEMO

_G_CODART=DIT_GRUPPO
_G_DESCRI=DIT_DESCRI


_V_CODART=DIT_GRUPPO
_V_DESCRI=DIT_DESCRI
_V_COSTO =DIT_COSTO
_V_PREZZO=DIT_PREZZO

_V_COSLAI=DIT_COSLAI 
_V_COSLAE=DIT_COSLAE 
_V_COSMAT=DIT_COSMAT 
_V_COSATR=DIT_COSATR 

_V_RICLAI=DIT_RICLAI 
_V_RICLAE=DIT_RICLAE  
_V_RICMAT=DIT_RICMAT 
_V_RICATR=DIT_RICATR 

_V_ORELAV=DIT_ORELAV 
_V_OREATT=DIT_OREATT  
_V_OREIMP=DIT_OREIMP 

_V_SECIMP=DIT_SECIMP 
_V_SECLAV=DIT_SECLAV 
_V_SECATT=DIT_SECATT 

_V_SYSTT =DIT_SYSTT

_V_MAGA	 =DIT_MAGA

_V_NOTE  =DIT_NOTE
	
CNT=1

SELECT WEXPLODE
APPEND BLANK

REPLACE WCOD    WITH _V_CODART
REPLACE WDES    WITH _V_DESCRI
REPLACE WDES2   WITH _V_DESCRI 
REPLACE WCOS    WITH _V_COSTO
REPLACE WPRZ    WITH _V_PREZZO
REPLACE WTIP    WITH "T"
REPLACE WLIV    WITH CNT
REPLACE WQTA    WITH 1
REPLACE TREE    WITH _V_CODART
REPLACE WQTAT   WITH 1
REPLACE WCOST   WITH _V_COSTO
REPLACE WPRZT   WITH _V_PREZZO

REPLACE WCOSLAI WITH _V_COSLAI 			&& COSTI DI PRODUZIONE
REPLACE WCOSLAE WITH _V_COSLAE 
REPLACE WCOSMAT WITH _V_COSMAT 
REPLACE WCOSATR WITH _V_COSATR 

REPLACE WRICLAI WITH _V_RICLAI 			&& RICAVI DI PRODUZIONE 
REPLACE WRICLAE WITH _V_RICLAE  
REPLACE WRICMAT WITH _V_RICMAT 
REPLACE WRICATR WITH _V_RICATR 

REPLACE WORELAV WITH _V_ORELAV 			&& TEMPI DI PRODUZIONE 
REPLACE WOREATT WITH _V_OREATT  
REPLACE WOREIMP WITH _V_OREIMP 

REPLACE WSECIMP WITH _V_SECIMP 			&& TEMPI IN SECONDI DI PRODUZIONE 
REPLACE WSECLAV WITH _V_SECLAV 
REPLACE WSECATT WITH _V_SECATT 

REPLACE WSYSDD  WITH _V_SYSTT 			&& SYS DELLA TESTATA DISTINTA

REPLACE WMAGA   WITH _V_MAGA 			

REPLACE WGRUPPO WITH _G_CODART
REPLACE WDESGRU WITH _G_DESCRI

REPLACE WTNOTE  WITH _V_NOTE  


=CERCA_ANAGRAFICA_ARTICOLI(_V_CODART)


DO TROVA WITH XXGRUPPO


=AGGIORNA_TOTALE_COSTI_RICAVI_GRUPPO_BASE(XXGRUPPO)




* RIELABORA IL CURSORE CON I COMPONENTI
*
* PER OGNI ARTICOLO :
* ACCEDE AL MAGAZZINO PER PRELEVARE LA GIACENZA E L'IMPEGNATO
* EFFETTUA IL CALCOLO DELLA DISPONIBILITA'
* RIAGGIORNA IL CURSORE STESSO
* MOSTRA A VIDEO IL CURSORE  (TUTTI I COMPONENTI O SOLO I NON DISPONIBILI?)

RELEASE _qtgiac,_qtimpe
PUBLIC  _qtgiac,_qtimpe


SELECT WEXPLODE
GO TOP

PUB_NUMERO_LIVELLI_DB = 1			&& DETERMINA IL NUMERO DI LIVELLI DELLA DISTINTA BSASE

DO WHILE !EOF()



	SELECT WEXPLODE
    ARTI=WCOD

    IF WLIV > PUB_NUMERO_LIVELLI_DB 			&& DETERMINA IL NUMERO DI LIVELLI DELLA DISTINTA BSASE
		PUB_NUMERO_LIVELLI_DB  = WLIV 
    ENDIF

	IF _SI_GIACENZE

		_cdarti = WCOD
		_cdmaga = _MAG
		_cdforn = SPACE(10)
		_qtgiac = 0
		_qtimpe = 0

		DO rileva_giacenza WITH _cdarti,_cdmaga,_cdforn

	    V_GIACEN = _qtgiac
		V_IMPORD = _qtimpe 
		V_DISPON = _qtgiac + _qtimpe 
		
		SELECT WEXPLODE

		REPLACE WGIA WITH V_GIACEN
		REPLACE WIMP WITH V_IMPORD
		REPLACE WDIS WITH V_DISPON

	    REPLACE WCOST WITH ROUND((WQTA*WCOS),6)
	    REPLACE WPRZT WITH ROUND((WQTA*WPRZ),6)
	
	ENDIF
		
	SELECT WEXPLODE
	SKIP+1

ENDDO	

SELECT WEXPLODE
PUN = RECCOUNT()
K   = SPACE(0)

SELECT WEXPLODE
GO TOP
DELETE FOR WLIV > LIV_ESPLN ALL
GO TOP


IF SI_VIDEO


	SELEZIONA_ESPOSIZIONE_COLONNE	= 1
	CURSORE_DA_VISUALIZZARE 		= "wexplode"
	GRUPPO_DISTINTA					= XXGRUPPO
	DESCRIZIONE_GRUPPO_DISTINTA 	= _G_DESCRI
    _NON_ESPLODE_I_COMPONENTI_FANTASMA = _NON_ESPLODE_I_COMPONENTI 

	DO FORM FORM\MENU_ALBERELLO WITH _ANALISI_DATI,SELEZIONA_ESPOSIZIONE_COLONNE,CURSORE_DA_VISUALIZZARE,GRUPPO_DISTINTA,DESCRIZIONE_GRUPPO_DISTINTA,_NON_ESPLODE_I_COMPONENTI_FANTASMA LINKED


ENDIF


=RILASCIA_VARIABILI_ESPLOSIONE_DISTINTA()					&& RILASCIA LE VARIABII PER L'ESPLOSIONE DELLA DISTINTA BASE


RETURN


************************************************************************
PROCEDURE TROVA
************************************************************************
PARAMETERS CODE
PRIVATE CODE,REK,GRU



CNT = CNT + 1


x_codi = "dis_gruppo = '" + ALLTRIM(CODE) + "'"
cSql   = "SELECT * FROM U_DIS_DD WHERE " + x_codi + " order by dis_gruppo,dis_sequen"
IF !ExecCommand(cSql,"U_DIS_DD_L00")
   return(.f.)
ENDIF


SELECT U_DIS_DD_L00
GO TOP

DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP
      LOOP
   ENDIF

   IF _non_esplode_i_componenti
	   IF DIS_ESPLOD = "X"
	      SKIP
	      LOOP
	   ENDIF 
   ENDIF 


   SCATTER MEMVAR MEMO


   _V_CODART = DIS_CODART
   V_TIPO    = DIS_TIPO
   _V_DESCRI = DIS_DESCRI
   _V_COSTO  = DIS_COSTO
   _V_PREZZO = DIS_PREZZO
   V_QTA     = DIS_QTA
   V_EXP     = DIS_ESPLOD
   V_PERC    = DIS_PERC
   V_QTACO2  = DIS_QTACO2
   _V_DES2   = DIS_DSNOCQ

   _V_COSLAI = DIS_COSLAI 
   _V_COSLAE = DIS_COSLAE 
   _V_COSMAT = DIS_COSMAT 
   _V_COSATR = DIS_COSATR 

   _V_RICLAI = DIS_RICLAI 
   _V_RICLAE = DIS_RICLAE  
   _V_RICMAT = DIS_RICMAT 
   _V_RICATR = DIS_RICATR 

   _V_ORELAV = DIS_ORELAV 
   _V_OREATT = DIS_OREATT  
   _V_OREIMP = DIS_OREIMP 

   _V_SECIMP = DIS_SECIMP 
   _V_SECLAV = DIS_SECLAV 
   _V_SECATT = DIS_SECATT 

   _V_EXP    = DIS_ESPLOD
   _V_COMSOS = DIS_COMSOS
   _V_FASELA = DIS_FASELA

   _V_SYSDD  = DIS_SYSDD
 
   _V_MAGA	 = DIS_MAGA

   IF !EMPTY(_CERCA_COMPONENTE) 
   		IF ALLTRIM(_V_CODART) = ALLTRIM(_CERCA_COMPONENTE)
   				PUB_COMPONTENTE_TROVATO = .T.						&& IL COMPONENTE ESISTE NELLA DISTITA BASE ESPLOSA
   		ENDIF
   ENDIF
   
      
   SELECT WEXPLODE
   APPEND BLANK
   REPLACE WCOD  WITH _V_CODART
   REPLACE WDES  WITH _V_DESCRI
   REPLACE WDES2 WITH _V_DES2
   REPLACE WCOS  WITH _V_COSTO
   REPLACE WPRZ  WITH _V_PREZZO
   REPLACE WTIP  WITH V_TIPO
   REPLACE WLIV  WITH CNT
   REPLACE WQTA  WITH V_QTA
   V_XTREE = REPLICATE('-',WLIV)
   REPLACE TREE  WITH V_XTREE + SPACE(WLIV) + WCOD
   REPLACE WQTAT WITH V_QTA
   REPLACE WCOST WITH ROUND((_V_COSTO*V_QTA),2)
   REPLACE WPRZT WITH ROUND((_V_PREZZO*V_QTA),2)
   REPLACE WPERC WITH V_PERC
   REPLACE WQTACO2 WITH V_QTACO2

   REPLACE WEXP	 	WITH _V_EXP    
   REPLACE WCOMSOS  WITH _V_COMSOS 
   REPLACE WFASELA	WITH _V_FASELA 

   IF _RICALCOLA_COSTI
       =RICALCOLA_COSTI_MP_LIVELLO_L00(_V_CODART,V_TIPO)
   ENDIF


   REPLACE WCOSLAI WITH _V_COSLAI 			&& COSTI DI PRODUZIONE
   REPLACE WCOSLAE WITH _V_COSLAE 
   REPLACE WCOSMAT WITH _V_COSMAT 
   REPLACE WCOSATR WITH _V_COSATR 


   IF _RICALCOLA_RICAVI
       =RICALCOLA_RICAVI_MP_LIVELLO_L00(_V_CODART,V_TIPO)
   ENDIF


   REPLACE WRICLAI WITH _V_RICLAI 			&& RICAVI DI PRODUZIONE 
   REPLACE WRICLAE WITH _V_RICLAE  
   REPLACE WRICMAT WITH _V_RICMAT 
   REPLACE WRICATR WITH _V_RICATR 

   IF _RICALCOLA_TEMPI
       =RICALCOLA_TEMPI_LIVELLO_L00(_V_CODART,V_TIPO)
   ENDIF

   REPLACE WORELAV WITH _V_ORELAV 			&& TEMPI DI PRODUZIONE 
   REPLACE WOREATT WITH _V_OREATT  
   REPLACE WOREIMP WITH _V_OREIMP 

   REPLACE WSECIMP WITH _V_SECIMP 			&& TEMPI IN SECONDI DI PRODUZIONE 
   REPLACE WSECLAV WITH _V_SECLAV 
   REPLACE WSECATT WITH _V_SECATT 

   REPLACE WSYSDD  WITH _V_SYSDD

   REPLACE WMAGA   WITH _V_MAGA 	

   REPLACE WGRUPPO WITH _G_CODART
   REPLACE WDESGRU WITH _G_DESCRI 
     
   =CERCA_ANAGRAFICA_ARTICOLI(_V_CODART)

   SELECT U_DIS_DD_L00
   
   IF DIS_TIPO=='G'
      REK=RECNO()
      GRU=CODE
      SALVA_GRUPPO_DISTINTA_L00 = DIS_CODART
      =TROVA1(DIS_CODART,V_QTA)
      SELECT U_DIS_DD_L00
      GOTO REK
      =AGGIORNA_TOTALE_COSTI_RICAVI_TEMPI(SALVA_GRUPPO_DISTINTA_L00,"U_DIS_DD_L00","L01")	&& AGGIORNA IL TOTALE COSTO/RICAVO APPENA RICALCOLATO PER IL GRUPPO IN ELABORAZIOE
      CODE=GRU
   ENDIF

   SELECT U_DIS_DD_L00   
   SKIP +1

ENDDO

=AGGIORNA_U_DIS_DD(SALVA_GRUPPO_DISTINTA_L00,"U_DIS_DD_L00")


CNT=CNT-1


RETURN

************************************************************************
PROCEDURE TROVA1
************************************************************************
PARAMETERS CODE1,QTA1
PRIVATE CODE1,REK1,GRU1,QTA1
CNT=CNT+1


x_codi = "dis_gruppo = '" + ALLTRIM(CODE1) + "'"
cSql   = "SELECT * FROM u_dis_dd WHERE " + x_codi + " order by dis_gruppo,dis_sequen"
IF !ExecCommand(cSql,"U_DIS_DD_L01")
   return(.f.)
ENDIF
SELECT U_DIS_DD_L01
GO TOP

DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP
      LOOP
   ENDIF

   IF _non_esplode_i_componenti
	   IF DIS_ESPLOD = "X"
	      SKIP
	      LOOP
	   ENDIF 
   ENDIF 

   _V_CODART = DIS_CODART
   V_TIPO    = DIS_TIPO
   _V_DESCRI = DIS_DESCRI
   _V_COSTO  = DIS_COSTO
   _V_PREZZO = DIS_PREZZO
   V_QTA     = DIS_QTA
   V_EXP     = DIS_ESPLOD
   V_PERC    = DIS_PERC
   V_QTACO2  = DIS_QTACO2
   _V_DES2   = DIS_DSNOCQ

   _V_COSLAI = DIS_COSLAI 
   _V_COSLAE = DIS_COSLAE 
   _V_COSMAT = DIS_COSMAT 
   _V_COSATR = DIS_COSATR 

   _V_RICLAI = DIS_RICLAI 
   _V_RICLAE = DIS_RICLAE  
   _V_RICMAT = DIS_RICMAT 
   _V_RICATR = DIS_RICATR 

   _V_ORELAV = DIS_ORELAV 
   _V_OREATT = DIS_OREATT  
   _V_OREIMP = DIS_OREIMP 

   _V_SECIMP = DIS_SECIMP 
   _V_SECLAV = DIS_SECLAV 
   _V_SECATT = DIS_SECATT 

   _V_EXP    = DIS_ESPLOD
   _V_COMSOS = DIS_COMSOS
   _V_FASELA = DIS_FASELA

   _V_SYSDD  = DIS_SYSDD

   _V_MAGA	 = DIS_MAGA

   IF !EMPTY(_CERCA_COMPONENTE) 
   		IF ALLTRIM(_V_CODART) = ALLTRIM(_CERCA_COMPONENTE)
   				PUB_COMPONTENTE_TROVATO = .T.						&& IL COMPONENTE ESISTE NELLA DISTITA BASE ESPLOSA
   		ENDIF
   ENDIF
 
    
   SELECT WEXPLODE
   APPEND BLANK
   REPLACE WCOD  WITH _V_CODART
   REPLACE WDES  WITH _V_DESCRI
   REPLACE WDES2 WITH _V_DES2
   REPLACE WCOS  WITH _V_COSTO
   REPLACE WPRZ  WITH _V_PREZZO
   REPLACE WTIP  WITH V_TIPO
   REPLACE WLIV  WITH CNT
   REPLACE WQTA  WITH V_QTA
   V_XTREE = REPLICATE('-',WLIV)
   REPLACE TREE  WITH V_XTREE + SPACE(WLIV) + WCOD
   V_QUANTI = ROUND((V_QTA * QTA1),7)
   REPLACE WQTAT WITH V_QUANTI
   REPLACE WCOST WITH ROUND((_V_COSTO*V_QUANTI),2)
   REPLACE WPRZT WITH ROUND((_V_PREZZO*V_QUANTI),2)
   REPLACE WPERC WITH V_PERC
   REPLACE WQTACO2 WITH V_QTACO2

   REPLACE WEXP	 	WITH _V_EXP    
   REPLACE WCOMSOS  WITH _V_COMSOS 
   REPLACE WFASELA	WITH _V_FASELA 


   IF _RICALCOLA_COSTI
       =RICALCOLA_COSTI_MP_LIVELLO_L01(_V_CODART,V_TIPO)
   ENDIF

   REPLACE WCOSLAI WITH _V_COSLAI 			&& COSTI DI PRODUZIONE
   REPLACE WCOSLAE WITH _V_COSLAE 
   REPLACE WCOSMAT WITH _V_COSMAT 
   REPLACE WCOSATR WITH _V_COSATR 


   IF _RICALCOLA_RICAVI
       =RICALCOLA_RICAVI_MP_LIVELLO_L01(_V_CODART,V_TIPO)
   ENDIF


   REPLACE WRICLAI WITH _V_RICLAI 			&& RICAVI DI PRODUZIONE 
   REPLACE WRICLAE WITH _V_RICLAE  
   REPLACE WRICMAT WITH _V_RICMAT 
   REPLACE WRICATR WITH _V_RICATR 

   IF _RICALCOLA_TEMPI
       =RICALCOLA_TEMPI_LIVELLO_L01(_V_CODART,V_TIPO)
   ENDIF

   REPLACE WORELAV WITH _V_ORELAV 			&& TEMPI DI PRODUZIONE 
   REPLACE WOREATT WITH _V_OREATT  
