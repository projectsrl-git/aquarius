***************************************************************************** 
FUNCTION DEFINISCE_WCALCOLO_COSTI
***************************************************************************** 

CREATE CURSOR WTOTALI_RICETTA (WKEY C(10), WGRUPPO C(30), WDESGRU C(40), WCOD  C(30),  WDES C(40),    WCOS N(17,3), WPRZ N(17,3),   ;
                        WTIP  C(1) ,  WLIV N(4) ,    WQTA N(17,7), WGIA N(9,2) ,  ;
                        WIMP  N(9,2), WDIS N(9,2),   TREE C(100),  WEXP C(1),      ;
                        WQTAT N(17,7), WCOST N(17,3), WPRZT N(17,3), WPERC N(7,3), ;
                        WCOSLAI N(17,3), ;
                        WCOSLAE N(17,3), ;
                        WCOSMAT N(17,3), ;
                        WCOSATR N(17,3), ;
                        WRICLAI N(17,3), ;
                        WRICLAE N(17,3), ;
                        WRICMAT N(17,3), ;
                        WRICATR N(17,3), ;
                        WORELAV C(11), ;
                        WOREATT C(11), ;
                        WOREIMP C(11), ;
                        WSECIMP N(17,3), ;
                        WSECLAV N(17,3), ;
                        WSECATT N(17,3), ;
                        WQTACO2 N(11,7), WDES2 C(40),WFASELA C(8),WMAGA C(6),WSYSDD C(10),WTIPART C(1),WDESTIPA C(30),WTNOTE M)

INDEX ON WGRUPPO  TAG I_GRUPPO ADDITIVE
INDEX ON (ALLTRIM(WKEY)) DESCENDING  TAG I_LIVELLI ADDITIVE
SET ORDER TO I_LIVELLI 


CREATE CURSOR WCALCOLO_COSTI (WKEY C(10), WGRUPPO C(30), WDESGRU C(40), WCOD  C(30),  WDES C(40),    WCOS N(17,3), WPRZ N(17,3),   ;
                        WTIP  C(1) ,  WLIV N(4) ,    WQTA N(17,7), WGIA N(9,2) ,  ;
                        WIMP  N(9,2), WDIS N(9,2),   TREE C(100),  WEXP C(1),      ;
                        WQTAT N(17,7), WCOST N(17,3), WPRZT N(17,3), WPERC N(7,3), ;
                        WCOSLAI N(17,3), ;
                        WCOSLAE N(17,3), ;
                        WCOSMAT N(17,3), ;
                        WCOSATR N(17,3), ;
                        WRICLAI N(17,3), ;
                        WRICLAE N(17,3), ;
                        WRICMAT N(17,3), ;
                        WRICATR N(17,3), ;
                        WORELAV C(11), ;
                        WOREATT C(11), ;
                        WOREIMP C(11), ;
                        WSECIMP N(17,3), ;
                        WSECLAV N(17,3), ;
                        WSECATT N(17,3), ;
                        WTORELAV C(11), ;
                        WTOREATT C(11), ;
                        WTOREIMP C(11), ;
                        WTSECIMP N(17,3), ;
                        WTSECLAV N(17,3), ;
                        WTSECATT N(17,3), ;
                        WTCOSLAI N(17,3), ;
                        WTCOSLAE N(17,3), ;
                        WTCOSMAT N(17,3), ;
                        WTCOSATR N(17,3), ;
                        WTCOSTOT N(17,3), ;
                        WTRICLAI N(17,3), ;
                        WTRICLAE N(17,3), ;
                        WTRICMAT N(17,3), ;
                        WTRICATR N(17,3), ;
                        WTRICTOT N(17,3), ;
                        WQTACO2 N(11,7), WDES2 C(40),WFASELA C(8),WMAGA C(6),WSYSDD C(10),WTIPART C(1),WDESTIPA C(30),WTNOTE M)

INDEX ON WGRUPPO  TAG I_GRUPPO ADDITIVE
INDEX ON (ALLTRIM(WKEY)) DESCENDING  TAG I_LIVELLI ADDITIVE
SET ORDER TO I_LIVELLI 


RETURN


***************************************************************************** 
FUNCTION CREA_LIVELLI_PER_CALCOLO_COSTI
***************************************************************************** 
PARA _CURSORE_INPUT,_CURSORE_OUTPUT


SS=STR(SELECT())


SELECT &_CURSORE_INPUT
GO TOP

DO WHILE .NOT. EOF()

	IF DELETED()
		SELECT &_CURSORE_INPUT
		SKIP +1
		LOOP
	ENDIF

	SCATTER MEMVAR MEMO
	


	__WLI  = STR(M.WLIV,4,0)
	__WLIV = STRTRAN(__WLI," ","0")

	
	M.WKEY = __WLIV  + M.WTIP 
	
	SELECT &_CURSORE_OUTPUT
	APPEND BLANK
	GATHER MEMVAR MEMO

	SELECT &_CURSORE_INPUT
	SKIP +1

ENDDO


SELECT &SS

RETURN



***************************************************************************** 
FUNCTION AGGIORNA_COSTI_RICAVI
***************************************************************************** 
PARA _CODICE_ARTICOLO,_QTA_,_SYSDD


SSXXX=STR(SELECT())

	x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
	x_codi = "art_codpri = '" + ALLTRIM(_CODICE_ARTICOLO) + "'"
	x_cond = x_soci + " and " + x_codi
	Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
	IF !ExecCommand(cSql,"_cur_articoli_")
	   return(.f.)
	ENDIF
	SELECT _cur_articoli_
	GO TOP
	IF EOF()
		   _RICALCOLA___RICLAI 	= 0 
		   _RICALCOLA___RICLAE 	= 0
		   _RICALCOLA___RICMAT 	= 0
		   _RICALCOLA___RICATR 	= 0
		   _RICALCOLA___COSLAI 	= 0 
		   _RICALCOLA___COSLAE 	= 0
		   _RICALCOLA___COSMAT 	= 0
		   _RICALCOLA___COSATR 	= 0

	ELSE
		   _RICALCOLA___RICLAI 	= ART_RICLAI   
		   _RICALCOLA___RICLAE 	= ART_RICLAE
		   _RICALCOLA___RICMAT 	= ART_RICMAT
		   _RICALCOLA___RICATR 	= ART_RICATR
		   _RICALCOLA___COSLAI 	= ART_COSLAI   
		   _RICALCOLA___COSLAE 	= ART_COSLAE
		   _RICALCOLA___COSMAT 	= ART_COSMAT
		   _RICALCOLA___COSATR 	= ART_COSATR
	ENDIF



	x_cond= "dis_sysdd = '" + ALLTRIM(_SYSDD) + "'"
	Csql   = "select * from u_dis_dd where " + x_cond + " order by dis_gruppo"
	IF !ExecCommand(cSql,"U_DIS_DD")
	   return(.f.)
	ENDIF

   	SELECT U_DIS_DD
	IF !EOF()

		REPLACE DIS_COSLAI WITH _RICALCOLA___COSLAI 	
		REPLACE DIS_COSLAE WITH _RICALCOLA___COSLAE 	
		REPLACE DIS_COSMAT WITH _RICALCOLA___COSMAT 	
		REPLACE DIS_COSATR WITH _RICALCOLA___COSATR 	

		REPLACE DIS_RICLAI WITH _RICALCOLA___RICLAI 	 
		REPLACE DIS_RICLAE WITH _RICALCOLA___RICLAE 	 
		REPLACE DIS_RICMAT WITH _RICALCOLA___RICMAT 	 
		REPLACE DIS_RICATR WITH _RICALCOLA___RICATR 	

	    _COS___TOTALE	= _RICALCOLA___COSLAI + _RICALCOLA___COSLAE + _RICALCOLA___COSMAT + _RICALCOLA___COSATR 

	    _RIC___TOTALE	= _RICALCOLA___RICLAI + _RICALCOLA___RICLAE + _RICALCOLA___RICMAT + _RICALCOLA___RICATR 
	  

		REPLACE DIS_COSTO  WITH _COS___TOTALE
		REPLACE DIS_PREZZO WITH _RIC___TOTALE

		IF !ExecRW("","U_DIS_DD","W")
		   return(.f.)
		ENDIF
	 

	ENDIF



SELECT &SSXXX

RETURN


****************************************************************************************
FUNCTION CERCA_ANAGRAFICA_ARTICOLI
****************************************************************************************
PARAMETERS ___CODART


SS=STR(SELECT())

	
	x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
	x_codi = "art_codpri = '" + ALLTRIM(___CODART) + "'"
	x_cond = x_soci + " and " + x_codi
	Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
	IF !ExecCommand(cSql,"__cur__articoli")
	   return(.f.)
	ENDIF
	SELECT __cur__articoli
	GO TOP
	IF EOF()
		   _WTIPART  	= " "
	ELSE
		   _WTIPART   	= ART_TIPART     
	ENDIF

    SELECT WEXPLODE

    REPLACE WTIPART WITH _WTIPART   			
    
    DO CASE 
    	CASE WTIPART = "P"
    		REPLACE WDESTIPA WITH "PRODUZIONE INTERNA"
    	CASE WTIPART = "A"
    		REPLACE WDESTIPA WITH "ACQUISTATO"
    	CASE WTIPART = "L"
    		REPLACE WDESTIPA WITH "C/Lavoro"
		OTHERWISE
    		REPLACE WDESTIPA WITH ""
    ENDCASE
    
   
    
SELECT &SS

RETURN


****************************************************************************************
FUNCTION SALVA_TOTALE_RICETTA
****************************************************************************************
* DA CURSORE WCALCOLO_COSTI , SI SALVA I TOTALI DELLA RICETTA IN WTOTALI_RICETTA 
SS=STR(SELECT())



SELECT WCALCOLO_COSTI
SET ORDER TO I_GRUPPO
GO TOP

DO WHILE .NOT.EOF()

    IF DELETED()
       SELECT WCALCOLO_COSTI
       SKIP +1
	   LOOP
    ENDIF


	SCATTER MEMVAR MEMO
		
	IF WTIP = "T"
		
		SELECT WTOTALI_RICETTA 
		APPEND BLANK
		GATHER MEMVAR MEMO
	
	ENDIF


	SELECT WCALCOLO_COSTI
	SKIP +1

ENDDO


SELECT &SS


RETURN




****************************************************************************************
FUNCTION CERCA_TOTALE_RICETTA
****************************************************************************************
* RICERCA IL TOTALE DELLA RICETTA IN WTOTALI_RICETTA 
PARAMETERS ___CODGRU,___TCORI

SS=STR(SELECT())

TIPO_COSTO_RICAVO = 0


SELECT WTOTALI_RICETTA 
SET ORDER TO I_GRUPPO
GO TOP

DO WHILE .NOT.EOF()

    IF DELETED()
       SELECT WTOTALI_RICETTA 
       SKIP +1
	   LOOP
    ENDIF

    IF ALLTRIM(___CODGRU) <> ALLTRIM(WGRUPPO)
       SELECT WTOTALI_RICETTA 
       SKIP +1
	   LOOP
    ENDIF

	DO CASE 
	
		** COSTI
		CASE ___TCORI = "COSMAT"
			TIPO_COSTO_RICAVO = WCOSMAT
			EXIT

		CASE ___TCORI = "COSLAI"
			TIPO_COSTO_RICAVO = WCOSLAI
			EXIT

		CASE ___TCORI = "COSLAE"
			TIPO_COSTO_RICAVO = WCOSLAE
			EXIT

		CASE ___TCORI = "COSATR"
			TIPO_COSTO_RICAVO = WCOSATR
			EXIT


		CASE ___TCORI = "COSTOT"          
			TIPO_COSTO_RICAVO = WCOSMAT + WCOSLAI + WCOSLAE + WCOSATR
			EXIT

		** RICAVI
		CASE ___TCORI = "RICMAT"
			TIPO_COSTO_RICAVO = WRICMAT
			EXIT

		CASE ___TCORI = "RICLAI"
			TIPO_COSTO_RICAVO = WRICLAI
			EXIT

		CASE ___TCORI = "RICLAE"
			TIPO_COSTO_RICAVO = WRICLAE
			EXIT

		CASE ___TCORI = "RICATR"
			TIPO_COSTO_RICAVO = WRICATR
			EXIT

		CASE ___TCORI = "RICTOT"          
			TIPO_COSTO_RICAVO = WRICMAT + WRICLAI + WRICLAE + WRICATR
			EXIT

		CASE ___TCORI = "COSTI_RICAVI"          
	        DB_WTCOSLAI = WCOSLAI 
	        DB_WTCOSLAE = WCOSLAE 
	        DB_WTCOSMAT = WCOSMAT  
	        DB_WTCOSATR = WCOSATR  
	        DB_WTCOSTOT = WCOSMAT + WCOSLAI + WCOSLAE + WCOSATR 
	        
	        DB_WTRICLAI = WRICLAI  
	        DB_WTRICLAE = WRICLAE  
	        DB_WTRICMAT = WRICMAT  
	        DB_WTRICATR = WRICATR
			DB_WTRICTOT = WRICMAT + WRICLAI + WRICLAE + WRICATR
			DB_NOTE     = WTNOTE  

            DB_WTORELAV = WORELAV 
            DB_WTOREATT = WOREATT 
            DB_WTOREIMP = WOREIMP 
                        
            DB_WTSECIMP = WSECIMP 
            DB_WTSECLAV = WSECLAV 
            DB_WTSECATT = WSECATT 

			EXIT

		
	ENDCASE
		


	SELECT WTOTALI_RICETTA 
	SKIP +1

ENDDO

SELECT &SS

RETURN(TIPO_COSTO_RICAVO)


