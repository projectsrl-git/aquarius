**********************
* ARTICOLI_SOTTOSCORTA
**********************

LPARAMETERS _PAR_CODMAG,_PAR_CODMAT

IF PCOUNT() < 1
	_PAR_CODMAG = ''
ENDIF

IF PCOUNT() < 2
	_PAR_CODMAT = ''
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO
PUBLIC V_TITOLO

V_TITOLO = "Scorte minime - articoli sottoscorta" + ;
	IIF(!EMPTY(_PAR_CODMAG),CHR(13) + "Mag. " + ALLTRIM(_PAR_CODMAG), "") + ;
	IIF(!EMPTY(_PAR_CODMAT),CHR(13) + "Cod. mat. " + ALLTRIM(_PAR_CODMAT), "")

WAIT WINDOWS "ESEGUE PROGRAMMA ARTICOLI_SOTTOSCORTA" TIMEOUT 3

*##########################################################################################################################################

CREATE CURSOR CU_SCO_MI (SCO_CODART C(30),   SCO_DESART C(50),   SCO_CODMAT C(03),   SCO_DESMAT C(50),  ;
                         SCO_ALTEZZ N(5,0),  SCO_LUNGHE N(15,0), SCO_UMMAGA C(3),    SCO_UNIMIS C(3),   SCO_SCORMI N(13,2),;
                         SCO_GIACEN N(17,2), SCO_GIAIMP N(17,2), SCO_ORDFOR N(17,2), SCO_SUBSCO N(17,2),;
                         SCO_TIPART C(02),   SCO_ORDINT N(17,2), SELEZIONE C(03))
                           
SELECT CU_SCO_MI
INDEX ON SCO_TIPART+SCO_CODART+SCO_CODMAT+STR(SCO_ALTEZZ,5,0)+STR(SCO_LUNGHE,5,0)+SCO_UMMAGA+STR(SCO_SUBSCO,17,2) 	TAG I_CODART ADDITIVE
INDEX ON SCO_TIPART+SCO_CODMAT+SCO_CODART+STR(SCO_ALTEZZ,5,0)+STR(SCO_LUNGHE,5,0)+SCO_UMMAGA+STR(SCO_SUBSCO,17,2)	TAG I_CODMAT ADDITIVE
INDEX ON SCO_TIPART+STR(SCO_ALTEZZ,5,0)+SCO_CODART+SCO_CODMAT+STR(SCO_LUNGHE,5,0)+SCO_UMMAGA+STR(SCO_SUBSCO,17,2)	TAG I_ALTEZZ ADDITIVE
INDEX ON SCO_TIPART+STR(SCO_LUNGHE,5,0)+SCO_CODART+SCO_CODMAT+STR(SCO_ALTEZZ,5,0)+SCO_UMMAGA+STR(SCO_SUBSCO,17,2) 	TAG I_LUNGHE ADDITIVE
INDEX ON SCO_TIPART+SCO_UMMAGA+STR(SCO_LUNGHE,5,0)+SCO_CODART+SCO_CODMAT+STR(SCO_ALTEZZ,5,0)+STR(SCO_SUBSCO,17,2)	TAG I_UMMAGA ADDITIVE
INDEX ON SCO_TIPART+STR(SCO_SUBSCO,17,2)+SCO_CODART+SCO_CODMAT+STR(SCO_ALTEZZ,5,0)+STR(SCO_LUNGHE,5,0)+SCO_UMMAGA 	TAG I_SUBSCO ADDITIVE

INDEX ON SCO_TIPART+SCO_CODART+SCO_CODMAT+STR(SCO_ALTEZZ,5,0)+STR(SCO_LUNGHE,5,0)+SCO_UMMAGA+STR(SCO_SUBSCO,17,2) 	TAG D_CODART DESCENDING ADDITIVE
INDEX ON SCO_TIPART+SCO_CODMAT+SCO_CODART+STR(SCO_ALTEZZ,5,0)+STR(SCO_LUNGHE,5,0)+SCO_UMMAGA+STR(SCO_SUBSCO,17,2)	TAG D_CODMAT DESCENDING ADDITIVE
INDEX ON SCO_TIPART+STR(SCO_ALTEZZ,5,0)+SCO_CODART+SCO_CODMAT+STR(SCO_LUNGHE,5,0)+SCO_UMMAGA+STR(SCO_SUBSCO,17,2)	TAG D_ALTEZZ DESCENDING ADDITIVE
INDEX ON SCO_TIPART+STR(SCO_LUNGHE,5,0)+SCO_CODART+SCO_CODMAT+STR(SCO_ALTEZZ,5,0)+SCO_UMMAGA+STR(SCO_SUBSCO,17,2) 	TAG D_LUNGHE DESCENDING ADDITIVE
INDEX ON SCO_TIPART+SCO_UMMAGA+STR(SCO_LUNGHE,5,0)+SCO_CODART+SCO_CODMAT+STR(SCO_ALTEZZ,5,0)+STR(SCO_SUBSCO,17,2)	TAG D_UMMAGA DESCENDING ADDITIVE
INDEX ON SCO_TIPART+STR(SCO_SUBSCO,17,2)+SCO_CODART+SCO_CODMAT+STR(SCO_ALTEZZ,5,0)+STR(SCO_LUNGHE,5,0)+SCO_UMMAGA 	TAG D_SUBSCO DESCENDING ADDITIVE

RELEASE _V_CODART,_V_DESART,_V_CODMAG,_V_DESMAG,_V_CODMAT,_V_DESMAT,_V_OPZSOT,_V_OPZORD1,_V_OPZORD3,_V_OPZSCM
PUBLIC  _V_CODART,_V_DESART,_V_CODMAG,_V_DESMAG,_V_CODMAT,_V_DESMAT,_V_OPZSOT,_V_OPZORD1,_V_OPZORD3,_V_OPZSCM

_V_CODART  = ""
_V_DESART  = ""
_V_CODMAG  = _PAR_CODMAG
_V_DESMAG  = ""
_V_CODMAT  = _PAR_CODMAT
_V_DESMAT  = ""
_V_OPZSOT  = .T.
_V_OPZORD1 = 1
_V_OPZORD3 = 1
_V_OPZSCM  = .T.

RELEASE _V_OPZTIP,_VV_SCORMI,_VV_GIACEN,_VV_GIAIMP,_VV_ORDFOR,_VV_ORDINT
PUBLIC  _V_OPZTIP,_VV_SCORMI,_VV_GIACEN,_VV_GIAIMP,_VV_ORDFOR,_VV_ORDINT
_V_OPZTIP  = 3
_VV_SCORMI = .T.
_VV_GIACEN = .T.
_VV_GIAIMP = .T.
_VV_ORDFOR = .T.
_VV_ORDINT = .F.


RELEASE _REP_OPZSCM,_REP_OPZSOT,_REP_OPZTIP,_REP_SCORMI,_REP_GIACEN,_REP_GIAIMP,_REP_ORDFOR,_REP_ORDINT
PUBLIC  _REP_OPZSCM,_REP_OPZSOT,_REP_OPZTIP,_REP_SCORMI,_REP_GIACEN,_REP_GIAIMP,_REP_ORDFOR,_REP_ORDINT
_REP_OPZSCM = _V_OPZSCM
_REP_OPZSOT = _V_OPZSOT
_REP_OPZTIP = _V_OPZTIP
_REP_SCORMI = _VV_SCORMI 
_REP_GIACEN = _VV_GIACEN 
_REP_GIAIMP = _VV_GIAIMP 
_REP_ORDFOR = _VV_ORDFOR 
_REP_ORDINT = _VV_ORDINT 


PUB_CLISOC = ""
IF !ExecCommand("select * from u_azi_an","u_azi_an")
   return
ENDIF
SELECT u_azi_an
GO TOP
IF !EOF()
	PUB_CLISOC = AZI_CODCLI
ENDIF

PUB_SPASCA = ""
PUB_SCAPPT = ""
IF !ExecCommand("select * from u_azi_pa","u_azi_pa")
   return
ENDIF
SELECT u_azi_pa
GO TOP
IF !EOF()
	PUB_SPASCA = AZI_SPASCA
	PUB_SCAPPT = AZI_SCAPPT
ENDIF

SELECT CU_SCO_MI
SET ORDER TO
ZAP

***CREAZIONE CURSORE DEGLI ARTICOLI DA ELABORARE
x_codi = "art_codsoc = '" + PUB_CODSOC + "'"
x_arti = IIF(EMPTY(_V_CODART),"1=1","art_codpri = '" + ALLTRIM(_V_CODART) + "'")
x_maga = IIF(EMPTY(_V_CODMAG),"1=1","art_maga = '" + ALLTRIM(_V_CODMAG) + "'")
x_cmat = IIF(EMPTY(_V_CODMAT),"1=1","art_codmat = '" + ALLTRIM(_V_CODMAT) + "'")
x_smin = IIF(_V_OPZSCM,"ART_SCORMI > 0","1=1")
x_cond = x_codi + " and " + x_arti + " and " + x_maga + " and " + x_cmat + " and " + x_smin
x_cond = STRTRAN(x_cond," and 1=1","")
cSql = "select * from u_art_pr where " + x_cond + " order by art_codpri"
IF !ExecCommand(cSql,"CU_ART_PR")
	return(.f.)
ENDIF

WAIT WINDOW "Elaborazione Articoli - Prego Attendere..." NOWAIT 

SELECT CU_ART_PR
GO TOP
DO WHILE .T.

	IF EOF()
		EXIT
	ENDIF
	
	IF DELETED()
		SKIP +1
		LOOP
	ENDIF

	SCATTER MEMVAR MEMO
	
	_XX_CODART = M.ART_CODPRI
	_XX_DESART = M.ART_DESCR
	_XX_CODMAT = M.ART_CODMAT
	_XX_DESMAT = M.ART_DESMAT
	_XX_ALTEZZ = M.ART_ALTEZZ
	_XX_LUNGHE = M.ART_LUNGHE
	_XX_UNIMIS = M.ART_UNIMIS	
	_XX_UMMAGA = M.ART_UMMAGA
	_XX_SCORMI = M.ART_SCORMI
	
	_XX_GIACEN = 0
	_XX_GIAIMP = 0
	_XX_ORDFOR = 0
	_XX_SUBSCO = 0
	
	_XX_TIPART = ""

	V_TIPO = CERCATIPO(M.ART_CODPRI)
	
	IF V_TIPO = "1" .AND. (M.ART_ALTEZZ + M.ART_LUNGHE) = 0
		&& SE PRESENTI RECORD SU U_SCO_MI PRENDO QUELLE INFORMAZIONI PER ALTEZZA,LUNGHEZZA E
		&& SCORTA MINIMA, ALTRIMENTI PRENDO QUESTE INFORMAZIONI SOLO DALL'ANAGRAFICA ARTICOLI
		x_codi = "sco_codart = '" + ALLTRIM(_XX_CODART) + "'"
		x_alte = "sco_altezz = sco_altezz"
		x_lung = "sco_lunghe = sco_lunghe"
		x_cond = x_codi + " and " + x_alte + " and " + x_lung 
		cSql	= "select * from U_SCO_MI where " + x_cond + " order by sco_codart,sco_altezz,sco_lunghe"
		IF !ExecCommand(cSql,"CUR_SCO_MI")
			return(.f.)
		ENDIF
		SELECT CUR_SCO_MI
		GO TOP
		IF EOF()
			SELECT CU_SCO_MI
			APPEND BLANK
			REPLACE SCO_CODART WITH _XX_CODART 
			REPLACE SCO_DESART WITH _XX_DESART 
			REPLACE SCO_CODMAT WITH _XX_CODMAT 
			REPLACE SCO_DESMAT WITH _XX_DESMAT 
			REPLACE SCO_ALTEZZ WITH _XX_ALTEZZ 
			REPLACE SCO_LUNGHE WITH _XX_LUNGHE 
			REPLACE SCO_UMMAGA WITH _XX_UMMAGA 
			REPLACE SCO_UNIMIS WITH _XX_UNIMIS
			REPLACE SCO_SCORMI WITH _XX_SCORMI 
			REPLACE SCO_GIACEN WITH _XX_GIACEN 
			REPLACE SCO_GIAIMP WITH _XX_GIAIMP 
			REPLACE SCO_ORDFOR WITH _XX_ORDFOR 
			REPLACE SCO_SUBSCO WITH _XX_SUBSCO			
			REPLACE SCO_TIPART WITH _XX_TIPART
		ELSE
			SELECT CUR_SCO_MI
			SCAN
				_XX_ALTEZZ = SCO_ALTEZZ
				_XX_LUNGHE = SCO_LUNGHE
				_XX_SCORMI = SCO_SCORMI
				SELECT CU_SCO_MI
				APPEND BLANK
				REPLACE SCO_CODART WITH _XX_CODART 
				REPLACE SCO_DESART WITH _XX_DESART 
				REPLACE SCO_CODMAT WITH _XX_CODMAT 
				REPLACE SCO_DESMAT WITH _XX_DESMAT 
				REPLACE SCO_ALTEZZ WITH _XX_ALTEZZ 
				REPLACE SCO_LUNGHE WITH _XX_LUNGHE 
				REPLACE SCO_UMMAGA WITH _XX_UMMAGA 
				REPLACE SCO_UNIMIS WITH _XX_UNIMIS
				REPLACE SCO_SCORMI WITH _XX_SCORMI 
				REPLACE SCO_GIACEN WITH _XX_GIACEN 
				REPLACE SCO_GIAIMP WITH _XX_GIAIMP 
				REPLACE SCO_ORDFOR WITH _XX_ORDFOR 
				REPLACE SCO_SUBSCO WITH _XX_SUBSCO  
				REPLACE SCO_TIPART WITH _XX_TIPART
			ENDSCAN
		ENDIF
	ELSE
		SELECT CU_SCO_MI
		APPEND BLANK
		REPLACE SCO_CODART WITH _XX_CODART 
		REPLACE SCO_DESART WITH _XX_DESART 
		REPLACE SCO_CODMAT WITH _XX_CODMAT 
		REPLACE SCO_DESMAT WITH _XX_DESMAT 
		REPLACE SCO_ALTEZZ WITH _XX_ALTEZZ 
		REPLACE SCO_LUNGHE WITH _XX_LUNGHE 
		REPLACE SCO_UMMAGA WITH _XX_UMMAGA 
		REPLACE SCO_UNIMIS WITH _XX_UNIMIS
		REPLACE SCO_SCORMI WITH _XX_SCORMI 
		REPLACE SCO_GIACEN WITH _XX_GIACEN 
		REPLACE SCO_GIAIMP WITH _XX_GIAIMP 
		REPLACE SCO_ORDFOR WITH _XX_ORDFOR 
		REPLACE SCO_SUBSCO WITH _XX_SUBSCO				 
		REPLACE SCO_TIPART WITH _XX_TIPART
	ENDIF
	
	SELECT CU_ART_PR
	SKIP +1
ENDDO

SELECT CU_SCO_MI
GO TOP
DO WHILE .T.

	IF EOF()
		EXIT
	ENDIF

	IF DELETED()
		SKIP +1
		LOOP
	ENDIF
	
	SCATTER MEMVAR MEMO
	
	WAIT WINDOW "Elaborazione articolo " + ALLTRIM(M.SCO_CODART) + " (" + ALLTRIM(STR(RECNO())) + ;
					" di " + ALLTRIM(STR(RECCOUNT())) + ")  -  Prego Attendere..." NOWAIT 
	
	_XX_GIACEN = 0
	_XX_GIAIMP = 0
	_XX_ORDFOR = 0
	_XX_ORDINT = 0	
	_XX_SUBSCO = 0
	
	_X_CODART = M.SCO_CODART	
	_X_CODMAT = M.SCO_CODMAT
	_X_ALTEZZ = M.SCO_ALTEZZ
	_X_LUNGHE = M.SCO_LUNGHE
	
	_X_UNIMIS = M.SCO_UNIMIS
	_X_UMMAGA = M.SCO_UMMAGA
	
	
	*** CERCO GIACENZA E QUANTITA' IMPEGNATA
	_GIACENZA = 0
	_ww_codsoc = PUB_CODSOC
	_ww_anaart = _X_CODART 
	_ww_codmag = IIF(EMPTY(_V_CODMAG),"",ALLTRIM(_V_CODMAG))
	_ww_prenot = .F.  && ANCHE GIACENZE PRENOTATE
	_ww_codint = ""
	_ww_altezz = _X_ALTEZZ 
	_ww_lunghe = _X_LUNGHE 
	_ww_fila_x = ""
	_ww_pian_x = ""
	_ww_ubic_x = ""
	_XX_GIACEN = AQM_RILEVA_GIACENZE_DISPONIBILI(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x)
	_XX_GIAIMP = AQM_RILEVA_QTA_IMPEGNATA(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x)
	
	
	*** CERCO QUANTITA' ORDINATA A FORNITORE
	x_clse = "ord_chiuso = 0"
	x_saco = "ord_salcon <> 'S'"
	x_cart = "ord_codart = '" + ALLTRIM(_X_CODART) + "'"
	x_alte = IIF(_X_ALTEZZ=0,"1=1","ord_altezz = " + ALLTRIM(STR(_X_ALTEZZ,6,0)))
	x_lung = IIF(_X_LUNGHE=0,"1=1","ord_lunghe = " + ALLTRIM(STR(_X_LUNGHE,5,0)))
	x_cond = x_clse + " and " + x_saco + " and " + x_cart + " and " + x_alte + " and " + x_lung 
	x_cond = STRTRAN(x_cond," and 1=1","")
	cSql   = "select * from u_orf_dd where " + x_cond
	IF !ExecCommand(cSql,"CU_ORF_DD")
		return(.f.)
	ENDIF	
	SELECT CU_ORF_DD
	GO TOP
	IF EOF()
	ELSE
		SCAN
			_V_DIFFQTA = 0
			
			_X_QTAORD = ORD_QTAORD
			_X_QTARES = ORD_QTAORD - ORD_QTAEV
			_X_QTAKG = ORD_QTAKG
			_X_QTAMQ = ORD_QTAMQ
			_X_QTAML = ORD_QTAML
			_X_QTAMC = ORD_QTAMC
			_X_QTANR = ORD_NUMBOB
			IF ALLTRIM(ORD_UM) == 'KG'
				_X_QTAKG = ORD_QTAORD
			ENDIF
			IF ALLTRIM(ORD_UM) == 'MQ'
				_X_QTAMQ = ORD_QTAORD
			ENDIF
			IF ALLTRIM(ORD_UM) == 'ML'
				_X_QTAML = ORD_QTAORD
			ENDIF
			IF ALLTRIM(ORD_UM) == 'MC'
				_X_QTAMC = ORD_QTAORD
			ENDIF
			IF ALLTRIM(ORD_UM) == 'NR'
				_X_QTANR = ORD_QTAORD
			ENDIF
					
			*** ESPRIMO LA QUANTITA' RESIDUA NELL'ORDINE A FORNITORE IN UNITA' DI MISURA DI MAGAZZINO
			DO CASE
				CASE _X_UNIMIS == _X_UMMAGA AND ALLTRIM(ORD_UM) == _X_UMMAGA
					_V_DIFFQTA = _X_QTARES
				
				CASE _X_UMMAGA = 'KG'
					_V_DIFFQTA = ROUND(_X_QTARES * _X_QTAKG / _X_QTAORD, PUB_DECQTA)
					
				CASE _X_UMMAGA = 'MQ'
					_V_DIFFQTA = ROUND(_X_QTARES * _X_QTAMQ / _X_QTAORD, PUB_DECQTA)
					
				CASE _X_UMMAGA = 'ML'
					_V_DIFFQTA = ROUND(_X_QTARES * _X_QTAML / _X_QTAORD, PUB_DECQTA)
					
				CASE _X_UMMAGA = 'MC'
					_V_DIFFQTA = ROUND(_X_QTARES * _X_QTAMC / _X_QTAORD, PUB_DECQTA)
					
				CASE _X_UMMAGA = 'NR'
					_V_DIFFQTA = ROUND(_X_QTARES * _X_QTANR / _X_QTAORD, 0)
			ENDCASE
			
			_XX_ORDFOR = _XX_ORDFOR + IIF(_V_DIFFQTA <= 0,0,_V_DIFFQTA)
		ENDSCAN
	ENDIF
	
	
	*** CERCO QUANTITA' NEGLI ORDINI INTERNI
	x_ccli = "ors_codcli = '" + PUB_CLISOC + "'"
	x_clse = "ord_chiuso = 0"
	x_saco = "ord_salcon <> 'S'"
	x_cart = "ord_codart = '" + ALLTRIM(_X_CODART) + "'"
	x_alte = IIF(_X_ALTEZZ=0,"1=1","ord_altezz = " + ALLTRIM(STR(_X_ALTEZZ,6,0)))	
	x_lung = IIF(_X_LUNGHE=0,"1=1","ord_lunghe = " + ALLTRIM(STR(_X_LUNGHE,5,0)))
	x_cond = x_ccli + " and " + x_clse + " and " + x_saco + " and " + x_cart + " and " + x_alte + " and " + x_lung 
	x_cond = STRTRAN(x_cond," and 1=1","")
	cSql   = "select * from u_ord_dd where " + x_cond
	IF !ExecCommand(cSql,"CU_ORD_DD")
		return(.f.)
	ENDIF	
	SELECT CU_ORD_DD
	GO TOP
	IF EOF()
	ELSE
		SCAN
			_V_DIFFQTA = ORD_QTAORD - ORD_QTAEV
			_XX_ORDINT = _XX_ORDINT + IIF(_V_DIFFQTA <= 0,0,_V_DIFFQTA)
		ENDSCAN
	ENDIF
	
	*** CALCOLO IL SOTTO SCORTA
	_XX_SUBSCO = (IIF(_VV_SCORMI,M.SCO_SCORMI,0) - ((IIF(_VV_GIACEN,_XX_GIACEN,0) - IIF(_VV_GIAIMP,_XX_GIAIMP,0)) + ;
					  IIF(_VV_ORDFOR,_XX_ORDFOR,0) + IIF(_VV_ORDINT,_XX_ORDINT,0)))
	
	SELECT CU_SCO_MI  
	REPLACE SCO_GIACEN WITH _XX_GIACEN 
	REPLACE SCO_GIAIMP WITH _XX_GIAIMP 
	REPLACE SCO_ORDFOR WITH _XX_ORDFOR 
	REPLACE SCO_ORDINT WITH _XX_ORDINT 
	REPLACE SCO_SUBSCO WITH _XX_SUBSCO 
	REPLACE SELEZIONE  WITH SPACE(10)	 
		
	SELECT CU_SCO_MI
	SKIP +1

ENDDO

*** OPZIONE TUTTI/SOLO SOTTOSCORTA
SELECT CU_SCO_MI
IF _V_OPZSOT
	DELETE FOR SCO_SUBSCO <= 0
ENDIF

SET ORDER TO I_CODART
*SET ORDER TO D_SUBSCO
GO TOP

*DO PRG\MENUSTA WITH "CU_SCO_MI",.T.,.F.,"XXX","SCORMI_STA","SCORMI_STA.FRX",.T.

*#############################################################################################################################################################
_PDF_REPORT_ 		=ALLTRIM(CERCAREPO("XXX","SCORMI_STA","SCORMI_STA.FRX"))
_PDF_DESCRIZIONE_	= "Articoli sottoscorta"+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "CU_SCO_MI"

IF !EMPTY(_PDF_SUBDIR_ )
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
