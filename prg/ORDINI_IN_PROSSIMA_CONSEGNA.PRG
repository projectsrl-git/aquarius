************************************
* ORDINI IN PROSSIMA CONSEGNA
************************************
LPARAMETERS _CENTRO_COSTO,_GIORNI_PRECEDENTI,_TITOLO,_STAMPA_RIEPILOGO,_STAMPA_DETTAGLIO

IF PCOUNT()<5
	RETURN .F.
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO,V_GIORNI_PRECEDENTI
PUBLIC V_TITOLO,V_GIORNI_PRECEDENTI

V_GIORNI_PRECEDENTI = _GIORNI_PRECEDENTI
V_TITOLO	= _TITOLO

WAIT WINDOWS "ESEGUE PROGRAMMA ORDINI IN PROSSIMA CONSEGNA" TIMEOUT 3
 
IF _STAMPA_RIEPILOGO
 
*!*		*** REPORT RIEPILOGO
*!*		cSql=""     
*!*		cNomeCursorSql="CU_ORDINATO"
*!*		TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

*!*			SELECT 	
*!*				CODICE_STATO,
*!*				STATO,
*!*				CODICE_CLIENTE,
*!*				CLIENTE,
*!*				NUM_ORDINE,
*!*				DATA_ORDINE_RIBALTATA, 
*!*				DATA_ORDINE,
*!*				CENTRO_COSTO,
*!*				DESCRIZIONE_CENTRO_COSTO,
*!*				DATA_CONSEGNA_RIBALTATA,
*!*				DATA_CONSEGNA,
*!*				MOTIVAZIONE,
*!*				SUM(VALORE) AS VALORE
*!*			FROM ORDINI_IN_PROSSIMA_CONSEGNA_E_NON_CONSEGNATI
*!*			WHERE <<_CENTRO_COSTO>>
*!*				AND DATA_ORDINE_RIBALTATA = CASE 
*!*						WHEN STATO = 'SPEDITO' THEN  convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111) 
*!*						ELSE DATA_ORDINE_RIBALTATA
*!*					END 
*!*				AND DATA_CONSEGNA_RIBALTATA = CASE 
*!*						WHEN STATO = 'SCADUTO' THEN  convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111) 
*!*						ELSE DATA_CONSEGNA_RIBALTATA
*!*					END  
*!*			GROUP BY CODICE_STATO,STATO,CENTRO_COSTO,DESCRIZIONE_CENTRO_COSTO,CODICE_CLIENTE,CLIENTE,NUM_ORDINE,DATA_ORDINE_RIBALTATA,DATA_ORDINE,DATA_CONSEGNA_RIBALTATA,DATA_CONSEGNA,MOTIVAZIONE
*!*			ORDER BY CODICE_STATO,DESCRIZIONE_CENTRO_COSTO,CLIENTE,NUM_ORDINE,MOTIVAZIONE

*!*		ENDTEXT					&& FINE SCRITTURA QUERY
	
	
	**=> ERASMO/FABIANO - INIZIO 28/04/2015
	*** REPORT RIEPILOGO
	cSql=""     
	cNomeCursorSql="CU_ORDINATO"
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

         SELECT      
              CODICE_STATO,
              STATO,
              CODICE_CLIENTE,
              CLIENTE,
              NUM_ORDINE,
              DATA_ORDINE_RIBALTATA, 
              DATA_ORDINE,
              TIPOLOGIA,
              LOCALITA_DESTINAZIONE,
              CENTRO_COSTO,
              DESCRIZIONE_CENTRO_COSTO,
              DATA_CONSEGNA_RIBALTATA,
              DATA_CONSEGNA,
              MOTIVAZIONE,
              SUM(VALORE) AS VALORE
        FROM ORDINI_IN_PROSSIMA_CONSEGNA_E_NON_CONSEGNATI
        WHERE <<_CENTRO_COSTO>>
              AND ((STATO = 'SPEDITO' AND DATA_CONSEGNA_RIBALTATA = convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111) ) OR STATO = 'SCADUTO' OR STATO = 'IN CONSEGNA') 
        GROUP BY CODICE_STATO,STATO,CENTRO_COSTO,DESCRIZIONE_CENTRO_COSTO,CODICE_CLIENTE,CLIENTE,NUM_ORDINE,DATA_ORDINE_RIBALTATA,
              DATA_ORDINE,TIPOLOGIA,LOCALITA_DESTINAZIONE,DATA_CONSEGNA_RIBALTATA,DATA_CONSEGNA,MOTIVAZIONE
		ORDER BY CODICE_STATO,DESCRIZIONE_CENTRO_COSTO,CLIENTE,NUM_ORDINE,MOTIVAZIONE

	ENDTEXT					&& FINE SCRITTURA QUERY           
	**=> ERASMO/FABIANO - FINE 28/04/2015

	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF


	SELECT CU_ORDINATO

	_PDF_REPORT_ 		=ALLTRIM(CERCAREPO("XXX","ORDINI_IN_PROSSIMA_CONSEGNA","ORDINI_IN_PROSSIMA_CONSEGNA.FRX"))
	_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA 
	_PDF_SELECT_ 		= "CU_ORDINATO"

	IF !EMPTY(_PDF_SUBDIR_ )
		=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
	ELSE
		=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
	ENDIF

	_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

	_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 
	
ENDIF



*** REPORT DETTAGLIO
IF _STAMPA_DETTAGLIO

*!*		cSql=""     
*!*		cNomeCursorSql="CU_ORDINATO"
*!*		TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

*!*			SELECT 	* 
*!*			FROM ORDINI_IN_PROSSIMA_CONSEGNA_E_NON_CONSEGNATI
*!*			WHERE <<_CENTRO_COSTO>>
*!*				AND DATA_ORDINE_RIBALTATA = CASE 
*!*						WHEN STATO = 'SPEDITO' THEN  convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111) 
*!*						ELSE DATA_ORDINE_RIBALTATA
*!*					END 
*!*				AND DATA_CONSEGNA_RIBALTATA = CASE 
*!*						WHEN STATO = 'SCADUTO' THEN  convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111) 
*!*						ELSE DATA_CONSEGNA_RIBALTATA
*!*					END		
*!*			ORDER BY CODICE_STATO,DESCRIZIONE_CENTRO_COSTO,CLIENTE,NUM_ORDINE

*!*		ENDTEXT					&& FINE SCRITTURA QUERY
		
	**=> ERASMO/FABIANO - INIZIO 28/04/2015
	cSql=""     
	cNomeCursorSql="CU_ORDINATO"
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

		SELECT 	* 
		FROM ORDINI_IN_PROSSIMA_CONSEGNA_E_NON_CONSEGNATI
		WHERE <<_CENTRO_COSTO>>
			AND ((STATO = 'SPEDITO' AND DATA_CONSEGNA_RIBALTATA = convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111) ) OR STATO = 'SCADUTO' OR STATO = 'IN CONSEGNA')
		ORDER BY CODICE_STATO,DESCRIZIONE_CENTRO_COSTO,CLIENTE,NUM_ORDINE
		
	ENDTEXT					&& FINE SCRITTURA QUERY           
	**=> ERASMO/FABIANO - FINE 28/04/2015
	

	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF

	SELECT CU_ORDINATO

	_PDF_REPORT_		= ALLTRIM(CERCAREPO("XXX","ORDINI_IN_PROSSIMA_CONSEGNA_DETTAGLIO","ORDINI_IN_PROSSIMA_CONSEGNA_DETTAGLIO.FRX"))
	_PDF_DESCRIZIONE_	= "Dettaglio - "+V_TITOLO+_PROGRESSIVO_PROGRAMMA 
	_PDF_SELECT_ 		= "CU_ORDINATO"
 
 	V_TITOLO = "Dettaglio - "+V_TITOLO

	IF !EMPTY(_PDF_SUBDIR_ )
		=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
	ELSE
		=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
	ENDIF

	_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

	_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 

ENDIF


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
