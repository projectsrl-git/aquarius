_SCHEDULED_CODSYS = SYS(2015)
DO PRG\ECOMMERCE_IMPORTA_CLIENTI_CARD WITH _SCHEDULED_CODSYS

_ERRORE = .T.
_CORPO_MAIL = V_TITOLO
_OK_INVIO_AMM = .F.
_OK_INVIO_ADV = .F.
Csql = "SELECT * FROM LOG_ECOMMERCE WHERE CODSYS = '" + _SCHEDULED_CODSYS + "' AND PROCEDURA = 'IMPORT_CLIENTI' ORDER BY DATA,ORA,SUBSTRING(MESSAGGIO,1,100)"
IF !ExecCommand(cSql,'TMP_LOG_ECOMMERCE')
	return(.f.)
ENDIF
SELECT TMP_LOG_ECOMMERCE
GO TOP
_CORPO_LOG = ""
SCAN	
	_CORPO_LOG = ALLTRIM(_CORPO_LOG) + IIF(!EMPTY(_CORPO_LOG),REPLICATE(CHR(13)+CHR(10),2),"") + RIBALTA2(DATA) + " - " + ORA + ": " + ALLTRIM(MESSAGGIO)
	IF ALLTRIM(MESSAGGIO) = 'Procedura terminata'
		_ERRORE = .F.
	ENDIF
	
	IF SUBSTR(MESSAGGIO,1,26) = "2 - Inserito nuovo Cliente" OR SUBSTR(MESSAGGIO,1,26) = "2 - Aggiornato Cliente"
		_OK_INVIO_AMM = .T.
	ENDIF
*!*		IF SUBSTR(MESSAGGIO,1,22) = "3 - Caricamento Ordine"
*!*			_OK_INVIO_ADV = .T.
*!*		ENDIF
ENDSCAN
GO TOP
SCAN
	IF ALLTRIM(ESITO) = 'KO'
		_ERRORE = .T.
	ENDIF
ENDSCAN

_CORPO_MAIL = _CORPO_MAIL + REPLICATE(CHR(13)+CHR(10),2) + ALLTRIM(_CORPO_LOG)

