#DEFINE TIPO_RECORD_PARTITA			"1"
#DEFINE TIPO_RECORD_CONTRO_PARTITA	"2"

PARAMETERS _PARA_TABELLA_DI_PARTENZA

RELEASE _TABELLA_DI_PARTENZA
PUBLIC  _TABELLA_DI_PARTENZA

LOCAL 	_ID_PARTITA

IF PCOUNT()>=1
	_TABELLA_DI_PARTENZA = _PARA_TABELLA_DI_PARTENZA
ELSE
	_TABELLA_DI_PARTENZA = "PAGAMENTI"
ENDIF

DO IMPOSTA_COMAREA	
		
*** IMPOSTA I DATI DELLA PARTITA SELEZIONATA	
SELECT &_TABELLA_DI_PARTENZA

_ID_PARTITA			= ID_PARTITA
PUB_PARTITA_CONTO	= CODFOR
PUB_PARTITA_DESCRI	= RAGSOC
PUB_PARTITA_DARE	= NDARE
PUB_PARTITA_AVERE	= NAVERE

*** CARICA TUTTE LE PARTITE RELATIVE ALLA PARTITA SELEZIONATA
SELECT AGGIUNTIVI
SET ORDER TO PARTCONTRO

GO TOP

DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF

	IF ID_PARTITA>_ID_PARTITA
		EXIT
	ENDIF

	IF ID_PARTITA<>_ID_PARTITA
		SKIP
		LOOP
	ENDIF
	
	DO VALORIZZA_CAMPI_MASCHERA	
		
	SELECT 	AGGIUNTIVI
	SKIP
ENDDO


*** ESEGUE ELABORAZIONE NUOVI DATI

DO FORM FORM\TESORERIA_AGGIUNTIVI LINKED

*** AGGIORNA I DATI
IF PUB_FLAG_AGGIORNA_DATI

	DO PULISCE_CURSOR_AGGIUNTIVI_PER_QUESTA_PARTITA
	
	DO AGGIORNA_CURSOR
	
ENDIF
	
DO RILASCIA_COMAREA

RETURN

* FINE TESORERIA_AGGIUNTIVI
****************************************


****************************************
PROCEDURE PULISCE_CURSOR_AGGIUNTIVI_PER_QUESTA_PARTITA
****************************************
SELECT &_TABELLA_DI_PARTENZA

_ID_PARTITA=ID_PARTITA

*** ELIMINA TUTTE LE PARTITE AGGIUNTIVE RELATIVE ALLA PARTITA SELEZIONATA
SELECT AGGIUNTIVI
DELETE FOR ID_PARTITA=_ID_PARTITA

*FINE PROCEDURE PULISCE_CURSOR_AGGIUNTIVI_PER_QUESTA_PARTITA
****************************************


****************************************
PROCEDURE VALORIZZA_CAMPI_MASCHERA
****************************************
LOCAL	_CMD,;
		_ID_CAMPO_MASCHERA,;
		_PARTITA_CONTROPARTITA

SELECT AGGIUNTIVI

_ID_CAMPO_MASCHERA		=SUBSTR(SELEZIONE,1,2)
_PARTITA_CONTROPARTITA	=SUBSTR(SELEZIONE,3,1)


DO CASE

	CASE _PARTITA_CONTROPARTITA=TIPO_RECORD_PARTITA
		_CMD="PUB_PARTITA_AGG"+_ID_CAMPO_MASCHERA+"_CONTO	= CODFOR"
		&_CMD
		_CMD="PUB_PARTITA_AGG"+_ID_CAMPO_MASCHERA+"_DESCRI	= RAGSOC"
		&_CMD
		_CMD="PUB_PARTITA_AGG"+_ID_CAMPO_MASCHERA+"_DARE	= NDARE "
		&_CMD
		_CMD="PUB_PARTITA_AGG"+_ID_CAMPO_MASCHERA+"_AVERE	= NAVERE"
		&_CMD
	
	CASE _PARTITA_CONTROPARTITA=TIPO_RECORD_CONTRO_PARTITA
		_CMD="PUB_CONTRO_AGG"+_ID_CAMPO_MASCHERA+"_CONTO	= CODFOR"
		&_CMD
		_CMD="PUB_CONTRO_AGG"+_ID_CAMPO_MASCHERA+"_DESCRI	= RAGSOC"
		&_CMD
		_CMD="PUB_CONTRO_AGG"+_ID_CAMPO_MASCHERA+"_DARE		= NDARE "
		&_CMD
		_CMD="PUB_CONTRO_AGG"+_ID_CAMPO_MASCHERA+"_AVERE	= NAVERE"
		&_CMD
	
ENDCASE

RETURN
* FINE PROCEDURE VALORIZZA_CAMPI_MASCHERA
****************************************


****************************************
PROCEDURE AGGIORNA_CURSOR
****************************************
LOCAL	I,;
		_CMD,;
		_ID_CAMPO_MASCHERA,;
		_PARTITA_CONTROPARTITA,;
		_CODICE_CONTO,;
		_RAGSOC,;
		_DARE,;
		_AVERE,;
		_SALDO

FOR I = 1 TO 5

	_ID_CAMPO_MASCHERA	=	"0"+ALLTRIM(STR(I))
	
	*** TRATTO LA PARTITA
	***
	
	_PARTITA_CONTROPARTITA=TIPO_RECORD_PARTITA

	_CMD="_PARTITA_CODICE_CONTO	= PUB_PARTITA_AGG"+_ID_CAMPO_MASCHERA+"_CONTO "
	&_CMD
	_CMD="_PARTITA_RAGSOC		= PUB_PARTITA_AGG"+_ID_CAMPO_MASCHERA+"_DESCRI"
	&_CMD
	_CMD="_PARTITA_DARE			= PUB_PARTITA_AGG"+_ID_CAMPO_MASCHERA+"_DARE  "
	&_CMD
	_CMD="_PARTITA_AVERE		= PUB_PARTITA_AGG"+_ID_CAMPO_MASCHERA+"_AVERE "
	&_CMD
	_PARTITA_SALDO				= _PARTITA_DARE- _PARTITA_AVERE                                           

	IF EMPTY(_PARTITA_CODICE_CONTO)
		LOOP
	ENDIF
			
	*** LEGGO TUTTI I DATI RELATIVI ALLA PARTITA A CUI VOGLIO AGGIUNGERE IMPORTI
	SELECT &_TABELLA_DI_PARTENZA
	SCATTER MEMVAR 
	
	SELECT AGGIUNTIVI
	SET ORDER TO PARTCONTRO
	
	*** I RECORD AGGIUNTIVI DEVO RISPECCHIARE PERFETTAMENTE I DATI DELLA PARTITA DI PARTENZA...
	APPEND BLANK
	GATHER MEMVAR
	
	*** ... TRANNE CHE PER IMPORTI, CODICI CONTO E DESCRIZIONI DELLE PARTITE E CONTRO-PARTITE AGGIUNTE
	
	REPLACE	;
		SELEZIONE	WITH 	_ID_CAMPO_MASCHERA+_PARTITA_CONTROPARTITA,;	&& IDENTIFICA A QUALE CAMPO DELLA MASCHERA E' ASSOCIATO IL RECORD CHE STO SCRIVENDO
		CODFOR		WITH	_PARTITA_CODICE_CONTO,;
		RAGSOC		WITH	_PARTITA_RAGSOC,;
		NDARE		WITH	_PARTITA_DARE,;
		NAVERE		WITH	_PARTITA_AVERE,;
		NSALDO		WITH	_PARTITA_SALDO
		
		
	*** TRATTO LA CONTROPARTITA
	***
	
	_PARTITA_CONTROPARTITA=TIPO_RECORD_CONTRO_PARTITA
	
	_CMD="_CONTROPARTITA_CODICE_CONTO= PUB_CONTRO_AGG"+_ID_CAMPO_MASCHERA+"_CONTO   "
	&_CMD
	_CMD="_CONTROPARTITA_RAGSOC		= PUB_CONTRO_AGG"+_ID_CAMPO_MASCHERA+"_DESCRI  "
	&_CMD
	_CMD="_CONTROPARTITA_DARE		= PUB_CONTRO_AGG"+_ID_CAMPO_MASCHERA+"_DARE    "
	&_CMD
	_CMD="_CONTROPARTITA_AVERE		= PUB_CONTRO_AGG"+_ID_CAMPO_MASCHERA+"_AVERE   "
	&_CMD
	_CONTROPARTITA_SALDO			= _CONTROPARTITA_DARE- _CONTROPARTITA_AVERE
	
	*** LEGGO TUTTI I DATI RELATIVI ALLA PARTITA A CUI VOGLIO AGGIUNGERE IMPORTI
	SELECT &_TABELLA_DI_PARTENZA
	SCATTER MEMVAR 
	
	SELECT AGGIUNTIVI
	SET ORDER TO PARTCONTRO
	
	*** I RECORD AGGIUNTIVI DEVO RISPECCHIARE PERFETTAMENTE I DATI DELLA PARTITA DI PARTENZA...
	APPEND BLANK
	GATHER MEMVAR
	
	
	REPLACE	;
		SELEZIONE	WITH 	_ID_CAMPO_MASCHERA+_PARTITA_CONTROPARTITA,;	&& IDENTIFICA A QUALE CAMPO DELLA MASCHERA E' ASSOCIATO IL RECORD CHE STO SCRIVENDO
		CODFOR		WITH	_CONTROPARTITA_CODICE_CONTO,;
		RAGSOC		WITH	_CONTROPARTITA_RAGSOC,;
		NDARE		WITH	_CONTROPARTITA_DARE,;
		NAVERE		WITH	_CONTROPARTITA_AVERE,;
		NSALDO		WITH	_CONTROPARTITA_SALDO
			
NEXT


RETURN
* FINE PROCEDURE AGGIORNA_CURSOR
****************************************


