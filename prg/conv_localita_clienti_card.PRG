*** CANCELLAZIONE DEI RECORD DELLA TABELLA ZONE SQL 


		WAIT WINDOWS "ATTENDERE PREGO, CANCELLAZIONE VECCHIA TABELLA localitŕ consegna clienti" NOWAIT
		cSql = "delete from U_LOC_AN where LOC_CF = 'C' "
		IF !ExecCommand(cSql,"U_LOC_AN")
		   return(.f.)
		ENDIF




******** DEFINISCE LE VARIABILI E CREA IL CURSORE DI SUPPORTO
RELEASE _PROGRESSIVO_LOC
PUBLIC _PROGRESSIVO_LOC
_PROGRESSIVO_LOC = 0

RELEASE __DATINS,_CTR
PUBLIC __DATINS,_CTR
__DATINS = DTOC(DATE())
_CTR = 0

=DEFINISCE_VARIABILI()


		gcFile = GETFILE('TXT', '', 'Browse', 1, 'Seleziona')

		IF EMPTY(gcFile)
			MESSAGEBOX("Nessun file selezionato",64,"Informazione")
			SET DEFAULT TO &PUB_DIR  
			
			RETURN
		ENDIF



		WAIT WINDOWS "Selezionato file TESTO >>>>>>>>>>> "+gcFile 		

		CREATE CURSOR IMPORTATXT (CAMPO1  c(200),;
			CAMPO2   c(200))

			
		
		APPEND FROM (gcFile) TYPE sdf		



***** ELABORA IL CURSORE transito PER CREARE IL CURSORE STP

SELECT IMPORTATXT
GO TOP 


DO WHILE !EOF()

    IF DELETED()
       SELECT IMPORTATXT   && scarto i record cancellati
       SKIP +1
       LOOP
    ENDIF 
    
    
    IF EMPTY(ALLTRIM(SUBSTR(CAMPO1,01,01)))
       SELECT IMPORTATXT   && scarto il record 
       SKIP +1
       LOOP
    ENDIF 
    
    
 
    IF SUBSTR(CAMPO1,01,06) = "Attivo"
       SELECT IMPORTATXT   && scarto il record 
       SKIP +1
       LOOP
    ENDIF     
  
  
    IF SUBSTR(CAMPO1,01,05) = "99999"
       SELECT IMPORTATXT   && scarto il record 
       SKIP +1
       LOOP
    ENDIF       
  
  
    DO CASE
		CASE SUBSTR(CAMPO1,01,08) = "CLIENTE:"
    		=CARICA_DATI_CLIENTE()		    
    
		CASE SUBSTR(CAMPO1,01,13) = "Destinazione:"
     		=CARICA_DATI_DESTINAZIONE()		    

 		CASE SUBSTR(CAMPO1,01,10) = "Indirizzo:"
     		=CARICA_DATI_INDIRIZZO()	
     		
 		CASE SUBSTR(CAMPO1,01,09) = "Telefono:"
     		=CARICA_DATI_TELEFONO_FAX()	
  
   
    ENDCASE
    
   
    	
    SELECT IMPORTATXT
	SKIP

ENDDO


	 
=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

SET DEFAULT TO &PUB_DIR

RETURN

***********************************
FUNCTION CARICA_DATI_CLIENTE
***********************************

SELECT IMPORTATXT
=DEFINISCE_VARIABILI()

_PROGRESSIVO_LOC = 0 && RIPARTE DA UN NUOVO PROGRESSIVO 
   
M.CODICE1 	 =SUBSTR(CAMPO1,15,09)
M.LOC_CODCLI =ALLTRIM(CONV_CLEAR(APITOSPA(ALLTRIM(M.CODICE1)))) 

*!*	IF M.LOC_CODCLI = '100100006'
*!*	SET STEP ON 
*!*	ENDIF
 
M.LOC_RAGSOC =ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,51,90))))	
M.LOC_RAGSOC =CONV_CLEAR(APITOSPA(ALLTRIM(M.LOC_RAGSOC))) 




M.ID_UNIQUE      = ""
M.LOC_CODSOC     = PUB_CODSOC
M.LOC_CF         = "C"						&& CLIENTE
M.LOC_TRASME     = SPACE(02)
M.LOC_DATINS     = RIBALTA2(DTOC(DATE()))
M.SELEZIONE      = SPACE(10)   	
M.LOC_VARIE      = ""
M.LOC_INDIRI     = ""	
M.LOC_CAP        = ""	
M.LOC_LOCALI     = ""
M.LOC_ATTENZIONE = ""
M.LOC_PROVIN     = ""
M.LOC_GGEVAS     = 0




RETURN

********************************* 
FUNCTION CARICA_DATI_DESTINAZIONE
*********************************

SELECT IMPORTATXT

_PROGRESSIVO_LOC = _PROGRESSIVO_LOC + 1
M.LOC_CODLOC 	 = STR(_PROGRESSIVO_LOC,3,0) 
IF LEN(ALLTRIM(M.LOC_CODLOC)) = 1
	M.LOC_CODLOC = "00"+ALLTRIM(M.LOC_CODLOC)
ENDIF

IF LEN(ALLTRIM(M.LOC_CODLOC)) = 2
	M.LOC_CODLOC = "0"+ALLTRIM(M.LOC_CODLOC)
ENDIF



RETURN


********************************* 
FUNCTION CARICA_DATI_INDIRIZZO
*********************************

SELECT IMPORTATXT
M.LOC_INDIRI =ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,14,36))))	
M.LOC_INDIRI =CONV_CLEAR(APITOSPA(ALLTRIM(M.LOC_INDIRI))) 

M.LOC_CAP =ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,140,6))))	
M.LOC_CAP =CONV_CLEAR(APITOSPA(ALLTRIM(M.LOC_CAP))) 


M.LOC_LOCALI =ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,157,36)))) 
M.LOC_LOCALI =ALLTRIM(CONV_CLEAR(APITOSPA(ALLTRIM(M.LOC_LOCALI)))) 
**M.LOC_LOCALI =STRTRAN(M.LOC_LOCALI,"`","'")	&& ABBIAMO COMUNI CONTENETE APICE : SI DEVE AGGIORNARE L'ARCHIVIO COMUNI

M.LOC_ATTENZIONE =ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,193,7)))) + ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO2,1,29))))	
M.LOC_ATTENZIONE =CONV_CLEAR(APITOSPA(ALLTRIM(M.LOC_ATTENZIONE))) 

M.LOC_PROVIN = ""
M.LOC_GGEVAS = 0

IF !EXECCOMMAND("SELECT * FROM COMUNI WHERE COMUNE='"+M.LOC_LOCALI+"' AND CAP='"+M.LOC_CAP+"'  ORDER BY COMUNE ","CURS_COMUNI")
   RETURN .F.
ENDIF
SELECT CURS_COMUNI
GO TOP
IF !EOF()
	M.LOC_PROVIN = CURS_COMUNI.PROVINCIA
ELSE
	IF !EXECCOMMAND("SELECT * FROM COMUNI WHERE COMUNE='"+M.LOC_LOCALI+"'  ORDER BY COMUNE ","CURS_COMUNI")
	   RETURN .F.
	ENDIF
	SELECT CURS_COMUNI
	GO TOP
	IF !EOF()
		M.LOC_PROVIN = CURS_COMUNI.PROVINCIA
	ENDIF
ENDIF



RETURN

********************************* 
FUNCTION CARICA_DATI_TELEFONO_FAX
*********************************


S_CARD_LOC_S=STR(SELECT())

SELECT IMPORTATXT
_TELEFONO = ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,15,15)))) + "-" + ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,51,25))))
_TELEFON2 = ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,15,15)))) + ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,51,25))))

_FAX      = ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,193,7)))) + "-" + ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO2,1,29))))
_FAX2     = ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO1,193,7)))) + ALLTRIM(APITOSPA(ALLTRIM(SUBSTR(CAMPO2,1,29))))

M.LOC_VARIE = ""
IF !EMPTY(ALLTRIM(_TELEFON2))
	M.LOC_VARIE = "TEL: " + _TELEFONO 
ENDIF

IF !EMPTY(ALLTRIM(_FAX2))
	M.LOC_VARIE = M.LOC_VARIE + " FAX: " + _FAX
ENDIF


M.LOC_VARIE =CONV_CLEAR(APITOSPA(ALLTRIM(M.LOC_VARIE))) 



M.LOC_CODSOC = PUB_CODSOC
M.LOC_TRASME = SPACE(02)
M.LOC_DATINS = RIBALTA2(DTOC(DATE()))
M.SELEZIONE  = SPACE(10)   	


SELECT CU_LOC_AN					&& CREAZIONE DEL CURSORE STP PER IL SUCCESSIVO AGGIORNAMENTO IN AMBIENTE SQL
APPEND BLANK
GATHER MEMVAR MEMO 						&& EFFETTUA LA REPLACE NEL CURSORE STP FOX SOSTITUENDO LE REPLACE DI OGNI SINGOLO CAMPO 


	 
****** AGGIORNA TABELLA U_LOC_AN  SQL
IF !ExecRW('','U_LOC_AN','I','','CU_LOC_AN')
   return(.f.)
ENDIF


****** DEFINIZIONE DEI CURSORI STP
cSql = "Select * from U_LOC_AN where 1=0"
IF !ExecCommand(cSql,"CU_LOC_AN")
   return(.f.)
ENDIF
SELECT CU_LOC_AN
	 
_CTR = _CTR +1
WAIT WINDOWS "RECORDS SCRITTI : "+STR(_CTR,10,0) NOWAIT


SELECT &S_CARD_LOC_S


RETURN

