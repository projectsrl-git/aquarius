PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
REPLACE CHIAVE_R  WITH "TOC"
REPLACE RIGAT     WITH SPACE(50)
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 888888

RETURN


*************************
PROCEDURE OK_SPOOL 
*************************

SELECT IVA_CL
GO TOP

DO WHILE .T. 

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
  	  SKIP +1
	  LOOP 
   ENDIF

   IF ALLTRIM(CHIAVE_R) = "TOC"
      RIGA_STA = RIGAT
   ELSE
      RIGA_STA = RIGA
   ENDIF
      
   SELECT IVA_STA
   APPEND BLANK
   REPLACE RIGAT WITH RIGA_STA

   SELECT IVA_CL
   SKIP +1

ENDDO

SELECT IVA_STA 
GO TOP

IF OK_FORMATO = 3
   DO CREA_SPOOL WITH "IVA_STA","IVA ACQUISTI CEE (A4): "+MESE+"/"+PUB_ANNO
ELSE
   IF OK_FORMATO = 2 OR OK_FORMATO = 1
      DO CREA_SPOOL WITH "IVA_STA","IVA ACQUISTI CEE (A3): "+MESE+"/"+PUB_ANNO
   ENDIF
ENDIF

RELEASE WINDOW DISPLAY

RETURN


*************************
PROCEDURE OK_FATAGE 
*************************

IF !ExecCommand("select * from u_azi_an","u_azi_an")
   return(.f.)
ENDIF
SELECT U_AZI_AN
GO TOP
IF !EOF()
   IF AZI_NFAGE = "S" 
	  OK_NFAGE = .T.
   ELSE	  
	  OK_NFAGE = .F.
   ENDIF	  
ELSE
   OK_NFAGE = .F.
   WAIT WINDOW "Per cortesia codifica il parametro bollati iva"
ENDIF

RETURN


**********************************************
PROCEDURE CERCA_NUMERO_PROTOCOLLO_DI_PARTENZA
**********************************************
* DETTAGLIO BOLLATO IVA *

x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
x_anno = "iva_anno = '" + PUB_ANNO + "'"
x_mese = "iva_mese < '" + MESE + "'"
x_cond = x_soci + " and " + x_anno  + " and " + x_mese
*CSQL   = "select * from u_iva_cl where " + x_cond + " order by iva_codsoc,iva_anno,iva_mese,iva_numdoc"
*CSQL   = "select * from u_iva_cl where " + x_cond + " order by iva_codsoc,iva_anno,iva_mese,iva_chiave"  && ERASMO - 15/11/2017
CSQL   = "select * from " + IIF(_OK_LIQDTDOC,"U_IVA_CL_DTDOC","U_IVA_CL") + " AS U_IVA_CL where " + x_cond + " order by iva_codsoc,iva_anno,iva_mese,iva_chiave"  && ERASMO - 11/04/2023	 
IF !ExecCommand(CSQL,"xx_ivacl")
   RETURN (.f.)
ENDIF 
SELECT xx_ivacl
GO TOP

ULTIMO_NUMERO_REGISTRO_COMPENSATIVO = 0

CTRELAB=0

CHIAVE_PRE = 0  && ERASMO - 15/11/2017

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SELECT xx_ivacl
      SKIP +1
   	  LOOP
   ENDIF	
   
   IF IVA_FATNOT = "C"     && NON ELABORA I MOVIMENTI IVA CORRISPETTIVI
      SELECT xx_ivacl
      SKIP +1
   	  LOOP
   ENDIF
   

   v_seek	= 'TOP'+ALLTRIM(IVA_TOP)
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      CEE   	= SUBSTR(LIBERA,23,1)
   ELSE
      CEE    	= SPACE(1)
   ENDIF

   IF CEE = 'E' OR CEE = 'R' && ELABORA SOLO LE FATTURE ACQUISTO CEE / EXTRA CEE / REVERSE CHANGE 
   ELSE
      SELECT xx_ivacl
      SKIP +1
   	  LOOP
   ENDIF
  
  
   *ULTIMO_NUMERO_REGISTRO_COMPENSATIVO = ULTIMO_NUMERO_REGISTRO_COMPENSATIVO + 1
   **=> ERASMO - INIZIO 15/11/2017
   SELECT xx_ivacl
   IF CHIAVE_PRE <> IVA_CHIAVE
      ULTIMO_NUMERO_REGISTRO_COMPENSATIVO = ULTIMO_NUMERO_REGISTRO_COMPENSATIVO + 1
   ENDIF
   CHIAVE_PRE = IVA_CHIAVE
   **=> ERASMO - FINE 15/11/2017
   
   SELECT xx_ivacl
   SKIP +1

ENDDO

