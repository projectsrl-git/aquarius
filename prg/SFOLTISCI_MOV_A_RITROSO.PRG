
_DATA_SALDO_MOVIMENTI = "01/01/2017"

_DATA_SALDO_MOVIMENTI = PJ_INPUTBOX("Inserire la data per la creazione del saldo movimenti","Selezione data saldo movimenti",_DATA_SALDO_MOVIMENTI)
IF EMPTY(_DATA_SALDO_MOVIMENTI)
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF
IF VALID_DATA(_DATA_SALDO_MOVIMENTI)
   _DATA_SALDO_MOVIMENTI=OK_DATA(_DATA_SALDO_MOVIMENTI)       
ELSE
	MESSAGEBOX('Data non valida',16,'*** ATTENZIONE ***') 
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF

_RISP = MESSAGEBOX("Continuare con lo sfoltimento dei movimenti di magazzino creando un saldo movimenti al " + _DATA_SALDO_MOVIMENTI + ;
				" partendo dalle giacenze attuali, considerando tutti i movimenti da oggi andando a ritroso e cancellando tutti i movimenti precedenti?",4+32+256,"Attenzione")
IF _RISP = 6
ELSE
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF

IF USED("CUR_SALDI_MOV")
	SELECT CUR_SALDI_MOV
	USE
ENDIF
cSql = "SELECT * FROM U_MAG_MO WHERE 1=0"
IF !ExecCommand(cSql,"CUR_SALDI_MOV")
   return(.f.)
ENDIF
INDEX ON ALLTRIM(MOV_CODMAG)+ALLTRIM(MOV_CODART)+ALLTRIM(MOV_LEGAME) TAG I_INDEX ADDITIVE

WAIT WINDOWS "Ricerca giacenze in corso..." NOWAIT

*** RIEMPIMENTO CURSORE CON SALDI AD OGGI (GIACENZE)
x_giac = "MAG_GIACEN > 0"
x_cond = x_giac
cSql = "SELECT * FROM U_MAG_GG WHERE " + x_cond
IF !ExecCommand(cSql,"ACT_MAG_GG")
   return(.f.)
ENDIF
SELECT ACT_MAG_GG
GO TOP
SCAN
	WAIT WINDOWS "Elaborazione saldo movimenti ad oggi da giacenza " + ALLTRIM(STR(RECNO())) + " di " + ALLTRIM(STR(RECCOUNT())) + " in corso..." NOWAIT
	_CODMAG = ALLTRIM(MAG_CODMAG)
	_CODART = ALLTRIM(MAG_CODART)
	_LEGAME = ALLTRIM(MAG_LEGAME)
	
	SELECT CUR_SALDI_MOV
	SCATTER MEMVAR MEMO BLANK
	
	SELECT ACT_MAG_GG
	SCATTER MEMVAR MEMO
	
	M.MOV_CODSOC 		= M.MAG_CODSOC
	M.MOV_NUMIDE 		= M.MAG_NUMIDE
	M.MOV_LEGAME 		= M.MAG_LEGAME
	M.MOV_UNIQUE 		= M.MAG_UNIQUE
	M.MOV_DTREGI 		= M.MAG_DATAGG					&& DATA 1° CARICO DELLA GIACENZA CHE STO MOVIMENTANDO
	M.MOV_ORAMOV 		= M.MAG_ORACAR					&& ORA 1° CARICO DELLA GIACENZA CHE STO MOVIMENTANDO
	M.MOV_DTDOCU 		= ""								&& DOV'E' LA DATA DOCUMENTO IN U_MAG_GG ???
	M.MOV_NUMDOC 		= ""								&& DOV'E' IL NUMERO DOCUMENTO IN U_MAG_GG ???
	M.MOV_CODART 		= M.MAG_CODART					&& CODICE ARTICOLO+NUMERO IDENTIFICATIVO DEL PRODOTTO PER IL MAGAZZINO	
	M.MOV_ANAART 		= M.MAG_ANAART					&& CODICE ARTICOLO E BASTA DI ANAGRAFICA ARTICOLI
	M.MOV_CODMAG 		= M.MAG_CODMAG					&& CODICE MAGAZZINO
	M.MOV_UM     		= ""								&& NON C'E' UNITA' DI MISURA IN U_MAG_GG - DEVE ESSERE CONSIDERATA U_ART_PR.ART_UMMAGA
	M.MOV_CODFOR 		= M.MAG_FORNIT					&& CODICE FORNITORE PER CARICHI								*CARICO*
	M.MOV_CODCLI 		= ""								&& CODICE CLIENTE PER SCARICHI
	M.MOV_QTAMOV 		= M.MAG_GIACEN					&& QUANTITA' DA SCARICARE PER UNITA' DI MISURA DI MAGAZZINO MEMORIZZATA NELLA VARIABILE M.MAG_GIACEN
	M.MOV_QTAMQ 		= M.MAG_QTAMQ
	M.MOV_QTAML 		= M.MAG_QTAML
	M.MOV_QTAKG 		= M.MAG_QTAKG
	M.MOV_QTAMC 		= M.MAG_QTAMC
	M.MOV_NUMORF 		= ""								&& NUMERO ORDINE A FORNITORE
	M.MOV_DATORF 		= ""								&& DATA ORDINE A FORNITORE
	M.MOV_PREACQ 		= M.MAG_PRZCON					&& PREZZO DI ACQUISTO										*CARICO*
	M.MOV_FILA_N 		= M.MAG_FILA_N					&& MAGAZZINO A LOCAZIONI : FILA
	M.MOV_PIAN_N 		= M.MAG_PIAN_N					&& MAGAZZINO A LOCAZIONI : PIANO
	M.MOV_UBIC_N 		= M.MAG_UBIC_N					&& MAGAZZINO A LOCAZIONI : UBICAZIONE
	M.MOV_FILA_X 		= M.MAG_FILA_X 					&& MAGAZZINO A LOCAZIONI : FILA	
	M.MOV_PIAN_X 		= M.MAG_PIAN_X					&& MAGAZZINO A LOCAZIONI : PIANO
	M.MOV_UBIC_X 		= M.MAG_UBIC_X					&& MAGAZZINO A LOCAZIONI : UBICAZIONE
	M.MOV_DTREGI 		= ""								&& DATA REGISTRAZIONE
	M.MOV_VALUTA 		= PUB_VALRIF
	M.MOV_COORD  		= ""
	M.MOV_CODPDV 		= M.MAG_CODPDV					&& CODICE PUNTO DI VENDITA
	M.MOV_UM     		= ""								&& UNITA' DI MISURA
	M.MOV_NRLINT 		= M.MAG_NRLINT					&& NUMERO LOTTO INTERNO
	M.MOV_ALTEZZ 		= M.MAG_ALTEZZ					&& ALTEZZA PRODOTTO
	M.MOV_LUNGHE 		= M.MAG_LUNGHE					&& LUNGHEZZA PRODOTTO
	M.MOV_SPESSO 		= M.MAG_SPESSO					&& SPESSORE PRODOTTO
	M.MOV_NRDBOB 		= M.MAG_NRDBOB					&& NUMERO BOBINA
	M.MOV_PREVEN 		= 0								&& PREZZO DI VENDITA
	M.MOV_SCONTO 		= M.MAG_SC1						&& SCONTO DI VENDITA
	M.MOV_SC1    		= M.MAG_SC1						&& SCONTO DI VENDITA
	M.MOV_SC2    		= M.MAG_SC2						&& 2° SCONTO DI VENDITA
	M.MOV_SC3    		= M.MAG_SC3						&& 3° SCONTO DI VENDITA
	M.MOV_IVAVEN 		= ""								&& IVA
	M.MOV_CODTAG 		= ""								&& CODICE TAGLIA 
	M.MOV_DESTAG 		= ""								&& DESCRIZIONE TAGLIA
	M.MOV_CODMAT 		= M.MAG_CODMAT					&& CODICE MATERIALE
	M.MOV_DESMAT 		= M.MAG_DESMAT					&& DESCRIZIONE MATERIALE
	M.MOV_CODCOL 		= M.MAG_CODCOL					&& CODICE COLORE
	M.MOV_DESCOL 		= M.MAG_DESCOL					&& DESCRIZIONE COLORE		
	M.MOV_SERIE  		= M.MAG_SERIE					&& MAGAZZINO FISCALE : SERIE
	M.MOV_AAPROD 		= M.MAG_AAPROD					&& MAGAZZINO FISCALE : ANNO DI PRODUZIONE
	M.MOV_SERBOL 		= M.MAG_SERBOL					&& MAGAZZINO FISCALE : SERIE BOLLETTA
	M.MOV_SERNUM 		= M.MAG_SERNUM					&& MAGAZZINO FISCALE : NUMERO DI SERIE
	M.MOV_NUMEDA 		= M.MAG_NUMEDA					&& MAGAZZINO FISCALE : NUMERO DA
	M.MOV_NUMEAL 		= M.MAG_NUMEAL					&& MAGAZZINO FISCALE : NUMERO A
	M.MOV_CBFISC 		= M.MAG_CBFISC					&& MAGAZZINO FISCALE : CODICE A BARRE FISCALE
	M.MOV_NOTVAR 		= ""								&& NOTE
	M.MOV_NUMMOV 		= ""								&& CARICO SCARICO *?*
	M.MOV_LEGSYS 		= M.MAG_LEGSYS					&& OPPURE TENIAMO IL LEGSYS DELLA GIACENZA ORIGINALE (PUO' SERVIRE IN CASO DI AGGIORNAMENTO PREZZI DA MENU_BFO000) ???
	M.MOV_CDAFOR 		= M.MAG_CDAFOR
	M.MOV_OINFOR 		= M.MAG_OINFOR
	M.MOV_PINFOR 		= M.MAG_PINFOR
	M.MOV_DTPFOR 		= M.MAG_DTPFOR
	M.MOV_TRAFOR 		= M.MAG_TRAFOR
	M.MOV_NBAFOR 		= M.MAG_NBAFOR
	M.MOV_BDAFOR 		= M.MAG_BDAFOR
	M.MOV_BALFOR 		= M.MAG_BALFOR
	M.MOV_PNKFOR 		= M.MAG_PNKFOR
	M.MOV_SERIAL 		= M.MAG_SERIAL  
	M.MOV_DATORI 		= ""
	M.MOV_FORNSUPP 		= M.MAG_FORNSUPP
	M.MOV_DTSCAD 		= M.MAG_DTSCAD
	M.MOV_MATRICOLA 	= M.MAG_MATRICOLA
	M.MOV_LOTPRD 		= M.MAG_LOTPRD
	
	SELECT CUR_SALDI_MOV
	SET ORDER TO I_INDEX
	GO TOP
	SEEK _CODMAG+_CODART+_LEGAME
	IF FOUND()
		REPLACE MOV_QTAMOV WITH MOV_QTAMOV + M.MOV_QTAMOV
		REPLACE MOV_FILA_N WITH M.MOV_FILA_N 
		REPLACE MOV_PIAN_N WITH M.MOV_PIAN_N 
		REPLACE MOV_UBIC_N WITH M.MOV_UBIC_N 
		REPLACE MOV_FILA_X WITH M.MOV_FILA_X 
		REPLACE MOV_PIAN_X WITH M.MOV_PIAN_X 
		REPLACE MOV_UBIC_X WITH M.MOV_UBIC_X 
	ELSE
		APPEND BLANK
		DO U_MAG_MO
		REPLACE MOV_TOP WITH PUB_CAUMOV
		REPLACE MOV_SEGNO WITH '+'
		REPLACE MOV_NUMDOC WITH "SALDO DA SFOLT."
		REPLACE MOV_DTDOCU WITH RIBALTA2(_DATA_SALDO_MOVIMENTI)
		REPLACE MOV_DTREGI WITH RIBALTA2(_DATA_SALDO_MOVIMENTI)
		REPLACE MOV_ORAMOV WITH "00:00:00"
	ENDIF
	
ENDSCAN

*** RIEMPIMENTO CURSORE CON MOVIMENTI A RITROSO, FINO ALLA DATA SELEZIONATA
WAIT WINDOWS "Ricerca movimenti dal " + _DATA_SALDO_MOVIMENTI + " in corso..." NOWAIT

x_dtrg = "MOV_DTREGI >= '" + RIBALTA2(_DATA_SALDO_MOVIMENTI) + "'"
x_cond = x_dtrg 
cSql   = "SELECT * FROM U_MAG_MO WHERE " + x_cond + " ORDER BY MOV_DTREGI DESC"
IF !ExecCommand(cSql,"TMP_MAG_MO")
   return(.f.)
ENDIF
SELECT TMP_MAG_MO
GO TOP
SCAN
	WAIT WINDOWS "Elaborazione saldo movimenti al " + _DATA_SALDO_MOVIMENTI + " da movimento " + ALLTRIM(STR(RECNO())) + " di " + ALLTRIM(STR(RECCOUNT())) + " in corso..." NOWAIT
	
	IF MOV_GIANEG
		LOOP
	ENDIF
	
	SCATTER MEMVAR MEMO
	SELECT CUR_SALDI_MOV
	SET ORDER TO I_INDEX
	GO TOP
	SEEK _CODMAG+_CODART+_LEGAME
	IF FOUND()
		REPLACE MOV_QTAMOV WITH MOV_QTAMOV + M.MOV_QTAMOV + IIF(M.MOV_SEGNO='-',M.MOV_QTAMOV,-1*M.MOV_QTAMOV)
		REPLACE MOV_FILA_N WITH M.MOV_FILA_N 
		REPLACE MOV_PIAN_N WITH M.MOV_PIAN_N 
		REPLACE MOV_UBIC_N WITH M.MOV_UBIC_N 
		REPLACE MOV_FILA_X WITH M.MOV_FILA_X 
		REPLACE MOV_PIAN_X WITH M.MOV_PIAN_X 
		REPLACE MOV_UBIC_X WITH M.MOV_UBIC_X 
	ELSE
		APPEND BLANK
		DO U_MAG_MO
		REPLACE MOV_TOP WITH PUB_CAUMOV
		REPLACE MOV_QTAMOV WITH IIF(MOV_SEGNO='-',MOV_QTAMOV,-1*MOV_QTAMOV)
		REPLACE MOV_SEGNO WITH '+'
		REPLACE MOV_NUMDOC WITH "SALDO DA SFOLT."
		REPLACE MOV_DTDOCU WITH RIBALTA2(_DATA_SALDO_MOVIMENTI)
		REPLACE MOV_DTREGI WITH RIBALTA2(_DATA_SALDO_MOVIMENTI)
		REPLACE MOV_ORAMOV WITH "00:00:00"
	ENDIF
ENDSCAN


WAIT WINDOWS "Completamento elaborazione saldo movimenti al " + _DATA_SALDO_MOVIMENTI + " in corso..." NOWAIT
SELECT CUR_SALDI_MOV
DELETE FOR MOV_QTAMOV = 0
GO TOP
_conta = 0
SCAN
	_conta = _conta + 1
	x_lega = "MOV_LEGAME = '" + MOV_LEGAME + "'"
	x_segn = "MOV_SEGNO = '+'"
	x_cond = x_lega + " and " + x_segn
	cSql = "SELECT TOP 1 MOV_VALUTA, MOV_PREACQ FROM U_MAG_MO WHERE " + x_cond + " ORDER BY MOV_DTREGI, MOV_ORAMOV"
	IF !ExecCommand(Csql,"TMP_MAG_MO")
	   return(.f.)
	ENDIF
	SELECT TMP_MAG_MO
	IF !EOF()
		_VALUTA = MOV_VALUTA
		_PREACQ = MOV_PREACQ
		
		SELECT CUR_SALDI_MOV
		REPLACE MOV_VALUTA WITH _VALUTA
		REPLACE MOV_PREACQ WITH _PREACQ 
	ENDIF
	
	IF MOV_QTAMOV > 0
		REPLACE MOV_SEGNO WITH '+'
	ELSE
		REPLACE MOV_SEGNO WITH '-'
	ENDIF
	REPLACE MOV_QTAMOV WITH ABS(MOV_QTAMOV)
ENDSCAN
GO TOP

