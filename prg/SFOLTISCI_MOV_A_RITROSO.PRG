WAIT WINDOWS "Inserimento movimenti di saldo al " + _DATA_SALDO_MOVIMENTI + " in corso..." NOWAIT

IF !ExecRW('','U_MAG_MO','I','','CUR_SALDI_MOV')
   return(.f.)
ENDIF

