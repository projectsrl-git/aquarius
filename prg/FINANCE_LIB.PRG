    

***********************************************************************************
PROCEDURE SITUAZIONE_FINANZIARIA
***********************************************************************************
** PARAMETRI DA GESTIRE :
**
**     _CF  		=  C  SE CLIENTE , F SE FORNITORE
**     _CONTO		=  CODICE DEL CONTO CLIENTE / FORNITORE (COMPRENSIVO DEL SOTTOGRUPPO)
**      			=  SE IL CAMPO CONTIENE IL VALORE "TUTTI" ESTRAE TUTTE LE PARTITE APERTE DI TUTTI I FORNITORI ALLA SCADENZA
**     _DATADAL,_DATAAL 
**                  = INTERVALLO DI DATE PER DATA DOCUMENTO
**     _DATA_SCAD_DAL,_DATA_SCAD_AL
**                  = INTERVALLO DI DATE PER DATA SCADENZA
**     _OPZIONE     = "TUTTI"                   : ESTRAE TUTTI I CLIENTI ANCHE SE NON HANNO INSOLUTI
**     				= "SOLO_CLIENTI_INSOLVENTI" : ESTRAE SOLO I CLIENTI CHE HANNO EMESSO UN INSOLUTO NEL PERIODO SELEZIONATO


PARA _CF,_CONTO,_DATADAL,_DATAAL,_DATA_SCAD_DAL,_DATA_SCAD_AL,_OPZIONE     

IF PCOUNT()<7
	MESSAGEBOX("Manca un parametro per SITUAZIONE_FINANZIARIA",48,"Attenzione")
	RETURN
ENDIF

DO FIN_CERCA_PARTITE WITH _CF,_CONTO

DO CREA_CURSORI_PER_ANALISI_SITUAZIONE_FINANZIARIA WITH _DATADAL,_DATAAL,_DATA_SCAD_DAL,_DATA_SCAD_AL,_OPZIONE  

*!*	SELECT SCADE
*!*	GO TOP
*!*	SUM (NDARE - NAVERE) FOR (FLAG_NATURA='P' AND FLAG_RIBA_TOP <>'S') AND (RIBALTA2(DTDOC) >=RIBALTA2(_DATADAL) AND RIBALTA2(DTDOC)<=RIBALTA2(_DATAAL)) TO _SOMMA

DO DETTAGLI_SITUAZIONE_FINANZIARIA WITH _DATADAL,_DATAAL,_DATA_SCAD_DAL,_DATA_SCAD_AL,_OPZIONE  

DO CALCOLO_PERCENTUALI_REPORT_FINALI 
	

* FINE PROCEDURE SITUAZIONE_FINANZIARIA
***********************************************************************************

****************************************
FUNCTION DEF_PARTI
****************************************
** DEFINISCE I CURSORI PER LA GESTIONE FINANZIATIA CLIENTI/FORNITORI


IF USED("RIE_FIN")
	SELECT RIE_FIN
	ZAP
	USE	
ENDIF

CREATE CURSOR RIE_FIN ;
	(CODFOR C(10),COD_CONTO C(13),RAGSOC C(30), ;
	 SHOW_DET_FAT L, ;
	 SHOW_DET_RIC L, ;
	 SHOW_DET_INS L, ;	
	 SHOW_DET_RIC_INCA L, ;	  
	 SHOW_DET_INS_INCA L, ;	 
	 IMP_FAT_INSC N(17,3), ;
	 IMP_FAT_RIBA N(17,3), ;
	 IMP_FAT_BONI N(17,3), ;	 
	 IMP_RIC_INSC N(17,3), ;
	 IMP_RIC_INCA N(17,3), ;
	 IMP_RIC_NOINCA N(17,3),;	 
	 PERC_RIC_INCA N(10,3), ;
	 IMP_INS_RICEV N(17,3), ;
	 IMP_INS_PAGA N(17,3), ;
	 IMP_INS_NOINCA N(17,3),;	 
	 PERC_INS_NOPAG N(17,3), ;
	 IMP_ALTRI_PAG N(17,3), ;
	 IMP_BON_SING N(17,3), ;
	 TOT_INCASSATO N(17,3), ;
	 PERC_INCA_TOT N(17,3))

SELECT RIE_FIN
INDEX ON ALLTRIM(CODFOR) 							TAG CODFOR
INDEX ON PERC_RIC_INCA 	 			 	  			TAG RB_INC_A
INDEX ON PERC_RIC_INCA 	DESCENDING		 	  		TAG RB_INC_D
INDEX ON PERC_INS_NOPAG 				 	  		TAG INSOLV_A
INDEX ON PERC_INS_NOPAG DESCENDING		 	  		TAG INSOLV_D
INDEX ON PERC_INCA_TOT 					 	  		TAG INCASS_A
INDEX ON PERC_INCA_TOT 	DESCENDING		 	  		TAG INCASS_D
INDEX ON IMP_INS_RICEV 					 	  		TAG INSOLU_A
INDEX ON IMP_INS_RICEV 	DESCENDING		 	  		TAG INSOLU_D
SET ORDER TO INSOLV_D



SELECT RIE_FIN 
ZAP
INDEX ON ALLTRIM(CODFOR) 							TAG CODFOR
INDEX ON PERC_RIC_INCA 	 			 	  			TAG RB_INC_A
INDEX ON PERC_RIC_INCA 	DESCENDING		 	  		TAG RB_INC_D
INDEX ON PERC_INS_NOPAG 				 	  		TAG INSOLV_A
INDEX ON PERC_INS_NOPAG DESCENDING		 	  		TAG INSOLV_D
INDEX ON PERC_INCA_TOT 					 	  		TAG INCASS_A
INDEX ON PERC_INCA_TOT 	DESCENDING		 	  		TAG INCASS_D
INDEX ON IMP_INS_RICEV 					 	  		TAG INSOLU_A
INDEX ON IMP_INS_RICEV 	DESCENDING		 	  		TAG INSOLU_D
SET ORDER TO INSOLV_D




IF USED("DET_FIN")
	SELECT DET_FIN
	ZAP
	USE	
ENDIF


CREATE CURSOR DET_FIN ;
	(TIPO_DET C(03),RAGSOC C(30),CONTABILITA_PREVISIONALE C(1),NPART N(10,0), DTREG C(10), NREG C(08), TIPODOC C(10), NUMDOC C(10), DTDOC C(10), DTSCAD C(10), CPA C(10), ;
	 VALUTA C(3), DARE C(15),AVEREX C(15), NUMPRO C(4), DESMOV C(50),DESMOV1 C(50),NPARTO N(10,0), CAMBIO N(15,10), ;
	 IMPVAL N(11,4),NDARE N(17,3),NAVERE N(17,3),NSALDO N(17,3),INDICE C(30),NFAT C(08),V_SALDO C(15), ;
	 ANNOK C(04), NPROGK N(5,0), CODFOR C(10), dtscade d(8),INDIRI C(40),LOCALI C(40),DTUSOL C(4),NUMSOL N(3,0),GGESPOS N(14,0), CORPO Memo, ;
	 COSATRATTA C(5),GRADOIMPORTANZA C(5),FORMAPAGAMENTO C(5),TIPOCONTRATTO C(5),CODACQ C(3),PRIPAGA C(4), BANCAFOR C(5), ANOMAX C(3),SYS_PARTI C(10) , KEY_UNIQUE C(36),;
	 TIPOOPE C(10),FLAG_NATURA C(1),FLAG_RIBA C(1),FLAG_RIBA_TOP C(1), DTPOSTRIBA C(10), SELEZIONE C(3),TIPOPA C(10), BLOCCO L, STORIA M, SHOW_PART L, COD_CONTO C(13), ;
	 PARTITA_APERTA L, INSOLUTO_NON_PAGATO L,;
	 INCASSATO L)

    	

SELECT DET_FIN
INDEX ON ALLTRIM(CODFOR) + RIBALTA2(DTSCAD) 	TAG SCADENZA
INDEX ON VAL(INDICE) 							TAG DTREG 
INDEX ON RIBALTA2(DTDOC)+NUMDOC 				TAG DOCUM
SET ORDER TO DTREG




SELECT DET_FIN
ZAP
INDEX ON ALLTRIM(CODFOR) + RIBALTA2(DTSCAD) 	TAG SCADENZA
INDEX ON VAL(INDICE) 							TAG DTREG 
INDEX ON RIBALTA2(DTDOC)+NUMDOC 				TAG DOCUM
SET ORDER TO DTREG




RETURN



***********************************************************************************
PROCEDURE FIN_CERCA_PARTITE
***********************************************************************************
**
** CREA IL CURSORE SCADE CONTENETE LE PARTITE DEI CLIENTI O DEI FORNITORI
**
** ESTRARE LE PARTITE DEI CLIENTI O DEI FORNITORI SEGUENDO LE SEGUENTI REGOLE :
**
** PARAMETRI DA GESTIRE :
**
**     _CF  		=  C  SE CLIENTE , F SE FORNITORE
**     _CONTO		=  CODICE DEL CONTO CLIENTE / FORNITORE (COMPRENSIVO DEL SOTTOGRUPPO)
**      			=  SE IL CAMPO CONTIENE IL VALORE "TUTTI" ESTRAE TUTTE LE PARTITE APERTE DI TUTTI I FORNITORI ALLA SCADENZA

PARA _CF,_CONTO

IF _CF  = "C"
	VARCHIVIO	= "PART_CLI"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
ELSE
	VARCHIVIO	= "PART_FOR"	 		&& PART_CLI = PARTITARIO CLIENTI , PART_FOR = PARTITARIO FORNITORI
ENDIF
			
AABBSXS  = SELECT()

DO DEF_VIP000
DO DEF_PARTI

AFIELDS( _ARRAY_SALDI_APERTI_CHIUSI ,"SALDI_APERTI_CHIUSI" )		
CREATE CURSOR SALDI_SCADENZE FROM ARRAY _ARRAY_SALDI_APERTI_CHIUSI  
SELECT SALDI_SCADENZE 												
INDEX ON ALLTRIM(CODFOR)+ALLTRIM(STR(NPART,10,0))+DTSCAD TAG DTSCAD && INDICE PER CODICE CLI/FOR + NR.PARTITA + DATA SCADENZA 
SET ORDER TO DTSCAD													

M.DDARE    = 0
M.AAVERE   = 0
XTCSALDO   = 0
TDARE      = 0
TAVERE     = 0
TSALDO     = 0
SALDO_PREC = 0
_RISPOSTA  = .T.

*!*	** DEFINIZIONE CURSORI
=DEF_EURO()		&& DEFINISCE IL CURSORE PER LA GESTIONE DEI PARTITARI

*!*	** ACCESSO AI PARTITARI CLIENTI / FORNITORI
IF EMPTY(_CONTO) OR ALLTRIM(UPPER(_CONTO))="TUTTI"
	x_codi = ""
ELSE
	x_codi = "AND par_codcli = '" + ALLTRIM(_CONTO) + "'"
ENDIF

	
WAIT WINDOW "ATTENDERE PREGO... estrazione partitario in corso" NOWAIT

cSql=""     
cNomeCursorSql="CURS_PART"
SOTTOGEN("ITA")


** SERGIO 18/12/2021 INIZIO
IF PUB_CONTOSIMILCEE 
	_START_COD_CLI=PUB_GRUPPOCF+1
	_START_COD_FOR=PUB_GRUPPOCF+1
   
ELSE
	_START_COD_CLI=LEN(PUB_CC)+1
	_START_COD_FOR=LEN(PUB_FF)+1
ENDIF
** SERGIO 18/12/2021 FINE  

	
IF _CF  = "C"        && VERIFICA SE CLIENTE

	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
   		SELECT 	COALESCE(CL.CLI_RAGSOC,PA.PAR_RAGSOC) AS CLI_RAGSOC,
   				COALESCE(CL.CLI_CAP,'') AS CLI_CAP,
   				COALESCE(CL.CLI_INDIR,'') AS CLI_INDIR,
   				COALESCE(CL.CLI_LOCALI,'') AS CLI_LOCALI,
   				COALESCE(CL.CLI_AGE,'') AS CLI_AGE,
   				COALESCE(CL.CLI_AGE,'') AS AGENTE,
				PA.PAR_TIPFAT  AS TIPOOPE ,
				COALESCE(SUBSTRING(PARTOP.LIBERA,2,1),'')  AS FLAG_NATURA ,
				COALESCE(SUBSTRING(PARTOP.LIBERA,10,1),'')  AS FLAG_RIBA_TOP ,
				COALESCE(SUBSTRING(PAR.LIBERA,10,1),'')  AS FLAG_RIBA,
   				PA.* 
   		FROM PART_CLI AS PA 
   		LEFT OUTER JOIN U_CLI_AN AS CL 	
   		ON SUBSTRING(PA.PAR_CODCLI,<<_START_COD_CLI>>,LEN(PA.PAR_CODCLI))=CL.CLI_CODCLI 
   		LEFT OUTER JOIN PARA AS PAR
   		ON PAR.CODICE='CPA'+PA.PAR_CODPAG 
   		LEFT OUTER JOIN PARA AS PARTOP
   		ON PARTOP.CODICE='TOP'+PA.PAR_TIPFAT  
   		WHERE PAR_CODSOC = '<<PUB_CODSOC>>'
	        AND PAR_NPROG <> 100 <<x_codi>> 
        ORDER BY PAR_CODSOC,PAR_CODCLI,PAR_NPART

	ENDTEXT					&& FINE SCRITTURA QUERY
ELSE

	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
   		SELECT 	COALESCE(FO.FOR_RAGSOC,'PA.PAR_RAGSOC') AS FOR_RAGSOC,
   				COALESCE(FO.FOR_CAP,'') AS FOR_CAP,
   				COALESCE(FO.FOR_INDIR,'') AS FOR_INDIR,
   				COALESCE(FO.FOR_LOCALI,'') AS FOR_LOCALI,
   				COALESCE(FO.FOR_BAE,'') AS FOR_BAE,
				PA.PAR_TIPFAT  AS TIPOOPE ,
				COALESCE(SUBSTRING(PARTOP.LIBERA,2,1),'')  AS FLAG_NATURA ,
				COALESCE(SUBSTRING(PARTOP.LIBERA,10,1),'')  AS FLAG_RIBA_TOP ,
				COALESCE(SUBSTRING(PAR.LIBERA,10,1),'')  AS FLAG_RIBA,
   				PA.*
   		FROM PART_FOR AS PA 
   		LEFT OUTER JOIN U_FOR_AN AS FO	
   		ON SUBSTRING(PA.PAR_CODCLI,<<_START_COD_FOR>>,LEN(PA.PAR_CODCLI))=FO.FOR_CODCLI 
   		LEFT OUTER JOIN PARA AS PAR
   		ON PAR.CODICE='CPA'+PA.PAR_CODPAG 
   		LEFT OUTER JOIN PARA AS PARTOP
   		ON PARTOP.CODICE='TOP'+PA.PAR_TIPFAT  
   		WHERE PAR_CODSOC = '<<PUB_CODSOC>>' 
	        AND PAR_NPROG <> 100 <<x_data>> <<x_codi>> <<x_agen>> <<x_npart>> <<x_nreg>> 
        ORDER BY PAR_CODSOC,PAR_CODCLI,PAR_NPART 

	ENDTEXT					&& FINE SCRITTURA QUERY

ENDIF

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT CURS_PART
GO TOP

WAIT WINDOW "ATTENDERE PREGO... verifica partite estratte" NOWAIT


DO WHILE !EOF()

   SELECT CURS_PART
   
*!*	   IF PAR_NPART!=102537
*!*	   		SELECT CURS_PART
*!*	   		SKIP 
*!*	   		LOOP
*!*	   ENDIF

   
   M.DTREG       = RIBALTA2(PAR_DTREG)
   M.NREG        = PAR_NREG
   M.NFAT        = PAR_NUMFAT
   M.INDICE      = ALLTRIM(PAR_CODCLI)+ALLTRIM(STR(PAR_NPART,10,0))+STRTRAN(PAR_DTSCAD,"/","")
   M.DESMOV      				= PAR_DESMOV
   M.DESMOV1     				= PAR_DESMO1
   M.CAMBIO      				= PAR_CAMBIO
   M.IMPVAL      				= PAR_IMPVAL
   M.VALUTA      				= PAR_VALUTA
   M.NPART       				= PAR_NPART
   M.NPARTO      				= PAR_NPARTO
   M.CPA         				= PAR_CODPAG
   M.ANNOK       				= PAR_ANNO
   M.NPROGK     				= PAR_NPROG
   M.CONTABILITA_PREVISIONALE 	= PAR_CONTABILITA_PREVISIONALE

	** SERGIO 18/12/2021 INIZIO
	IF PUB_CONTOSIMILCEE 
	   M.CODFOR 					= SCORPRA_CODICE_CLIENTE_FORNITORE_SE_SIMILCEE(PAR_CODCLI)
	ELSE
	   M.CODFOR 					= SUBSTR(PAR_CODCLI,PUB_SOTTOG,PUB_CONTO)
	ENDIF
	** SERGIO 18/12/2021 FINE  
	   
   
   M.COD_CONTO					= PAR_CODCLI
   M.cosatratta 				= PAR_cosatratta
   M.gradoimportanza			= PAR_gradoimportanza
   M.formapagamento				= PAR_formapagamento
   M.tipocontratto				= PAR_tipocontratto		
   M.codacq						= PAR_codacq
   M.pripaga					= PAR_pripaga
   M.indiri						= ""
   M.locali						= ""
   M.SYS_PARTI					= SYS_PARTI
   M.BANCAFOR                   = PAR_BANCA
   M.ANOMAX						= PAR_ANOMAX
   M.ID_UNIQUE					= ID_UNIQUE  		 	&& SIMONE - 27/03/2009     

   M.FLAG_RIBA   				= FLAG_RIBA  			&& FABIANO 30/12/2011 - VALE 'X' SE LE CONDIZIONI DI PAGAMENTO SONO RIBA
   M.FLAG_RIBA_TOP 				= FLAG_RIBA_TOP			&& FABIANO 06/03/2012 - VALE 'S' SE IL TOP E' DI TIPO RIBA
   M.FLAG_NATURA   				= FLAG_NATURA       	&& FABIANO 30/12/2011 - VALE 'S' SE TOP FATTURE CLI/FOR
   M.TIPOOPE   				    = TIPOOPE   			&& FABIANO 30/12/2011 - TOP DELLA SCADENZA
   M.TIPOPA  				    = PAR_TIPOPA 			&& FABIANO 08/01/2012 - PROCEDURA RECUPERO CREDITI
   M.BLOCCO                     = PAR_BLOCCO            && FABIANO 08/01/2012 - PAGAMENTO BLOCCATO
   M.STORIA                     = PAR_STORIA            && FABIANO 08/01/2012 - IDENTIFICA LA SITUAZIONE DELLA PARTITA   
   
   M.RAGSOC = ""
   M.indiri = ""
   M.locali = ""
   _X_AGE_  = ""
   
   IF _CF  = "C"        && VERIFICA SE CLIENTE
      M.RAGSOC      = CLI_RAGSOC
	  M.indiri		= CLI_CAP + " - " + ALLTRIM(CLI_INDIR)
	  M.locali		= ALLTRIM(CLI_LOCALI)
      _X_AGE_       = CLI_AGE		  
   ELSE	   
      M.RAGSOC      = FOR_RAGSOC
	  M.indiri		= FOR_CAP + " - " + ALLTRIM(FOR_INDIR)
	  M.locali		= ALLTRIM(FOR_LOCALI)
      IF EMPTY(M.BANCAFOR)
		  M.BANCAFOR = FOR_BAE
      ENDIF
   ENDIF
   
   
   SELECT CURS_PART
   
   IF EMPTY(M.DTREG)
      M.DTREG = REPLICATE(" " ,10)
   ENDIF

   IF _CF  = "C"					&& CLIENTI
      M.NUMPRO      = PAR_NPROT
      M.NUMDOC      = PAR_NPROT
   ELSE								&& FORNITORI
      M.NUMPRO      = SPACE(06)
      M.NUMDOC      = PAR_NUMFAT
   ENDIF

*!*	   SP  = LEN(ALLTRIM(M.NUMDOC))
*!*	   _SP = (7 - SP)
*!*	   M.NUMDOC = REPLICATE(" " ,_SP)+ ALLTRIM(M.NUMDOC)
   M.NUMDOC = PADL(ALLTRIM(M.NUMDOC),10,SPACE(1))


   M.DTDOC       = RIBALTA2(PAR_DTFAT)
   IF EMPTY(M.DTDOC)
      M.DTDOC = REPLICATE(" " ,10)
   ENDIF
       
   PR   = PAR_NPROG-100
   WTF  = PAR_TIPFAT
   DAT  = RIBALTA2(PAR_DATPAG)
   DA   = 0     && IMPORTO TRANCHE DARE
   TA   = 0      
   AV   = 0     && IMPORTO TRANCHE AVERE
   NAT   =  PAR_TMOV    && PRENDE LA NATURA DEL MOVIMENTO DAL DATABASE 
   SELECT CURS_PART
   DDOC   = RIBALTA2(PAR_DTFAT)
      
   IF _CF  = "C"     				   && CLIENTE  : FATT = DARE
		IF NAT = "D"
       		DA   = PAR_FATT
			DS   = RIBALTA2(PAR_DTSCAD)
		ELSE
            AV   = PAR_FATT
		    DS   = RIBALTA2(PAR_DTSCAD)
		ENDIF
	ELSE
         IF NAT = "A"				       && FORNITORE : FATT= AVERE   
            AV   = PAR_FATT
            DS   = RIBALTA2(PAR_DTSCAD)
         ELSE
            DA   = PAR_FATT
		    DS   = RIBALTA2(PAR_DTSCAD)
         ENDIF
	ENDIF
      
    IF M.VALUTA = PUB_VALRIF
		X_VAL_D = DA
		X_VAL_A = AV
	ELSE
    	 IF PUB_VALRIF = 'EUR'		
            X_VAL_D = TEURO(M.VALUTA,DA,DDOC)    
            X_VAL_A = TEURO(M.VALUTA,AV,DDOC)    
         ELSE										
            X_VAL_D = TLIRE(M.VALUTA,DA,DDOC)    	
            X_VAL_A = TLIRE(M.VALUTA,AV,DDOC)    	
         ENDIF										
	ENDIF

	M.DDARE  = M.DDARE + X_VAL_D
	M.AAVERE = M.AAVERE + X_VAL_A 

	TDARE   = TDARE + X_VAL_D
	TAVERE  = TAVERE + X_VAL_A
      
    M.DTPOSTRIBA=""
			
	*** FABIANO 30/12/2011
	*** SE E' UNA RIBA CONTROLLO LA SCADENZA POSTICIPATA
	***IF M.FLAG_RIBA ='X' AND M.FLAG_NATURA<>'S' 
	IF M.FLAG_RIBA ='X' 
		*** CONTROLLO DATA SCADENZA DS - GG/MM/AAAAA
    	M.DTPOSTRIBA  = DTOC(CTOD(DS)+PUB_GGRIBA)
	ELSE
		M.DTPOSTRIBA  = DS
	ENDIF
			
    SELECT SCADE
    APPEND BLANK 
    GATHER MEMVAR
      
    REPLACE DTREG   					WITH M.DTREG 
    REPLACE NREG    					WITH M.NREG
    REPLACE INDICE  					WITH M.INDICE 
    REPLACE NUMDOC  					WITH M.NUMDOC  
    REPLACE NUMPRO  					WITH M.NUMPRO
    REPLACE DTDOC   					WITH M.DTDOC
    REPLACE DESMOV  					WITH M.DESMOV
    REPLACE DESMOV1 					WITH M.DESMOV1
    REPLACE CAMBIO  					WITH M.CAMBIO
    REPLACE IMPVAL  					WITH M.IMPVAL
    REPLACE VALUTA  					WITH M.VALUTA
    REPLACE CODFOR  					WITH M.CODFOR
    REPLACE RAGSOC  					WITH M.RAGSOC
	REPLACE cosatratta 					WITH M.cosatratta
	REPLACE gradoimportanza				WITH M.gradoimportanza
	REPLACE formapagamento				WITH M.formapagamento
	REPLACE tipocontratto				WITH M.tipocontratto		
	REPLACE codacq						WITH M.codacq
	REPLACE pripaga						WITH M.pripaga
	REPLACE indiri 				  		WITH M.indiri
	REPLACE locali						WITH M.locali
	REPLACE SYS_PARTI					WITH M.SYS_PARTI
	REPLACE BANCAFOR                  	WITH M.BANCAFOR          
	REPLACE anomax	                	WITH m.anomax    
	REPLACE KEY_UNIQUE 					WITH M.ID_UNIQUE		&& SIMONE - 27/03/2009
	REPLACE FLAG_RIBA					WITH M.FLAG_RIBA
	REPLACE DTPOSTRIBA                	WITH M.DTPOSTRIBA
	REPLACE FLAG_NATURA               	WITH M.FLAG_NATURA
	REPLACE TIPOOPE                   	WITH M.TIPOOPE  
	REPLACE TIPOPA                    	WITH M.TIPOPA            && FABIANO 08/01/2012 - PROCEDURA RECUPERO CREDITI
	REPLACE BLOCCO                    	WITH M.BLOCCO            && FABIANO 08/01/2012 - PAGAMENTO BLOCCATO
	REPLACE STORIA                    	WITH M.STORIA            && FABIANO 08/01/2012 - IDENTIFICA LA SITUAZIONE DELLA PARTITA 
  
    IF EMPTY(DS)
         REPLACE DTSCAD WITH REPLICATE(" " ,10)
    ELSE
         REPLACE DTSCAD WITH DS
         REPLACE DTSCADE WITH CTOD(DS)
    ENDIF
      

    N_SALDO 	 = DA - AV
    SALDO_PREC = SALDO_PREC + N_SALDO
    N_SALDO 	 = SALDO_PREC
    
    _SA = 15 - LEN(ALLTRIM(STR(N_SALDO,15,3)))
    
    REPLACE V_SALDO WITH REPLICATE(" " ,_SA) + ALLTRIM(STR(N_SALDO,15,3))
    REPLACE NSALDO  WITH NSALDO
         
    _WT = 3 - LEN(ALLTRIM(WTF))
    REPLACE TIPODOC WITH REPLICATE(" " ,_WT) + ALLTRIM(WTF)
      
    IF DA = 0
       REPLACE DARE  WITH REPLICATE(" " ,11)
       REPLACE NDARE WITH 0
    ELSE  
       _DA = 15 - LEN(ALLTRIM(STR(DA,15,3)))
       REPLACE DARE  WITH REPLICATE(" " ,_DA) + ALLTRIM(STR(DA,15,3))
       REPLACE NDARE WITH DA
    ENDIF   
    
    IF AV = 0
       REPLACE AVEREX WITH REPLICATE(" " ,15)
       REPLACE NAVERE WITH 0
    ELSE  
       _AV = 15 - LEN(ALLTRIM(STR(AV,15,3)))
       REPLACE AVEREX WITH REPLICATE(" " ,_AV) + ALLTRIM(STR(AV,15,3))
       REPLACE NAVERE WITH AV
    ENDIF   

	SELECT CURS_PART
	SKIP +1

ENDDO

SELECT(AABBSXS)
RETURN



***************************************************************************************
PROCEDURE DETTAGLI_SITUAZIONE_FINANZIARIA 
***************************************************************************************
* FABIANO 08/04/2012
***************************************************************************************
PARAMETERS _DATADAL,_DATAAL,_DATA_SCAD_DAL,_DATA_SCAD_AL,_OPZIONE

LOCAL _CURRENT_SELECT,_TIPO_DET,_INCASSATO
_CURRENT_SELECT= SELECT()
_TIPO_DET=""
_INCASSATO=.F.

SELECT DET_FIN
ZAP
SET ORDER TO SCADENZA

SELECT SCADE
GO TOP


*** CLASSIFICO I DETTAGLI 
DO WHILE !EOF()
	
	*** SE LA DATA DEL DOCUMENTO E' ESTERNA ALL'INTERVALLO 
	*** NON CONSIDERO QUESTA RIGA
	IF RIBALTA2(DTDOC)<RIBALTA2(_DATADAL) OR RIBALTA2(DTDOC)>RIBALTA2(_DATAAL)
		SELECT SCADE
		SKIP
		LOOP
	ENDIF	
	
	*** SE LA DATA DI SCADENZA E' ESTERNA ALL'INTERVALLO 
	*** NON CONSIDERO QUESTA RIGA
	IF RIBALTA2(DTSCAD )<RIBALTA2(_DATA_SCAD_DAL) OR RIBALTA2(DTSCAD )>RIBALTA2(_DATA_SCAD_AL)
		SELECT SCADE
		SKIP
		LOOP
	ENDIF	
	
	IF _OPZIONE ="SOLO_CLIENTI_INSOLVENTI"
		SELECT SCADE 
		_SEEK = ALLTRIM(CODFOR)
		SELECT CLIENTI_CON_INSOLUTO
		SET ORDER TO CODFOR
		SEEK _SEEK
		IF !FOUND()	&& NON HO NESSUN INSOLUTO SU QUESTO CLIENTE NEL PERIODO IMPOSTATO
			SELECT SCADE
			SKIP
			LOOP		
		ENDIF
	ENDIF 

		
	SELECT SCADE 
	
	_TIPO_DET=""
	_INCASSATO=.F.

	*** (A)  FATTURE EMESSE NEL PERIODO
	IF FLAG_NATURA='S' 
		_TIPO_DET= 'FAT'
		
		DO AGGIORNO_DETTAGLI_SITUAZIONE_FINANZIARIA WITH _TIPO_DET,_INCASSATO
		SELECT SCADE 
		SKIP 
		LOOP
	ENDIF
	
	*** (E)  INSOLUTI RICEVUTI NEL PERIODO
	IF FLAG_NATURA='I' 
		_TIPO_DET= 'INS'
		
		*** DETERMINO SE E' INCASSATO
		SELECT SCADE
		_SEEK = RIBALTA2(DTSCAD)+ALLTRIM(CODFOR)+ALLTRIM(STR(NPART,10,0))
		_DTPOSTRIBA = DTPOSTRIBA
		_DTSCAD     = DTSCAD
		
		SELECT SCADENZE_APERTE_CHIUSE 
		SEEK _SEEK 
		IF FOUND()
			IF SALDO=0
				*** SE E' CHIUSO CON UN BONIFICO E' INCASSATO
				SELECT SCADENZE_CON_BONIFICO
				SEEK _SEEK 
				IF FOUND()
					*** STABILISCO SE GIA' INCASSATO
					IF RIBALTA2(_DTSCAD)>RIBALTA2(_DATAAL)				
						_INCASSATO=.F.  							&& (G)  INSOLUTI DA INCASSARE NEL PERIODO
					ELSE
						_INCASSATO=.T.  							&& (F)  INSOLUTI INCASSATI NEL PERIODO
					ENDIF
				ELSE
				*** SE E' CHIUSO CON UNA RIBA E' INCASSATO SOLO SE LA RIBA E' SCADUTA
					*** STABILISCO SE GIA' INCASSATA
					IF RIBALTA2(_DTPOSTRIBA)>RIBALTA2(_DATAAL)				
						_INCASSATO=.F.  							&& (G)  INSOLUTI DA INCASSARE NEL PERIODO
					ELSE
						_INCASSATO=.T.  							&& (F)  INSOLUTI INCASSATI NEL PERIODO
					ENDIF
				ENDIF
			ELSE
				_INCASSATO=.F.								&& (G)  INSOLUTI DA INCASSARE NEL PERIODO
			ENDIF
		ELSE
			_INCASSATO=.F.								&& (G)  INSOLUTI DA INCASSARE NEL PERIODO
		ENDIF
		
		SELECT SCADE 
		
		DO AGGIORNO_DETTAGLI_SITUAZIONE_FINANZIARIA WITH _TIPO_DET,_INCASSATO
		SELECT SCADE 
		SKIP 
		LOOP
	ENDIF
	
	*** (B)  RIBA EMESSE NEL PERIODO
	IF FLAG_RIBA_TOP ='S'
	
		_TIPO_DET= 'RIC'
		
		*** STABILISCO SE GIA' INCASSATA
		IF RIBALTA2(DTPOSTRIBA)>RIBALTA2(_DATAAL)				
			_INCASSATO=.F.  							&& (D)  RIBA DA INCASSARE NEL PERIODO
		ELSE
			_INCASSATO=.T.  							&& (C)  RIBA INCASSATE NEL PERIODO
		ENDIF
		DO AGGIORNO_DETTAGLI_SITUAZIONE_FINANZIARIA WITH _TIPO_DET,_INCASSATO
		
		SELECT SCADE 
		SKIP 
		LOOP
	ENDIF
	
	*** PAGAMENTO CON BONIFICO O ALTRO (TUTTO ECCETTO RIBA)
	IF FLAG_NATURA='P' AND FLAG_RIBA_TOP <>'S'
		_TIPO_DET= 'BON'
		
		_CODFOR = CODFOR
		_RAGSOC = RAGSOC
		_SALDO  = NDARE - NAVERE
		SELECT RIE_FIN
		SET ORDER TO CODFOR
		SEEK _CODFOR

		IF !FOUND()
			APPEND BLANK 
			REPLACE CODFOR WITH _CODFOR
			REPLACE RAGSOC WITH _RAGSOC
		ENDIF
		REPLACE IMP_ALTRI_PAG WITH IMP_ALTRI_PAG + _SALDO  
		
		SELECT SCADE 
		*** STABILISCO SE GIA' INCASSATO IN BASE ALL'ANALISI DEL PERIODO
		IF RIBALTA2(DTSCAD)>RIBALTA2(_DATAAL)				
			
			*** SE IL BONIFICO ESISTE
			*** MA STO ANALIZZANDO UN PERIODO NON INERENTE A QUESTA SCADENZA
			*** NON DEVO CONSIDERARLO
			*** E' COME SE NON ESISTESSE ANCORA IN QUEL MOMENTO (STO ANDANDO INDIETRO NEL TEMPO)
			***
		
			*** BONIFICO FATTO MA NON COMPRESO NEL PERIODO IN ANALISI PER CUI LO SCARTO !!!!!!
			*** BONIFICO FATTO MA NON COMPRESO NEL PERIODO IN ANALISI PER CUI LO SCARTO !!!!!!
			*** BONIFICO FATTO MA NON COMPRESO NEL PERIODO IN ANALISI PER CUI LO SCARTO !!!!!!
			*** BONIFICO FATTO MA NON COMPRESO NEL PERIODO IN ANALISI PER CUI LO SCARTO !!!!!!
			*** BONIFICO FATTO MA NON COMPRESO NEL PERIODO IN ANALISI PER CUI LO SCARTO !!!!!!
		
		
		
		ELSE
		
			*** BONIFICO FATTO E COMPRESO NEL PERIODO IN ANALISI PER CUI LO ANALIZZO !!!!!!
			*** BONIFICO FATTO E COMPRESO NEL PERIODO IN ANALISI PER CUI LO ANALIZZO !!!!!!
			*** BONIFICO FATTO E COMPRESO NEL PERIODO IN ANALISI PER CUI LO ANALIZZO !!!!!!
			*** BONIFICO FATTO E COMPRESO NEL PERIODO IN ANALISI PER CUI LO ANALIZZO !!!!!!
		
		
			*** LO CONSIDERO COME "ALTRO-BONIFICO" SOLO SE NON E' UN PAGAMENTO DI INSOLUTO
			*** PERCHE' I PAGAMENTI DI INSOLUTI LO HO GIA' CONTEGGIATI QUANDO HO ANALIZZATO GLI INSOLUTI
			***
			***		
			*** PER CUI :
			
				*** VERIFICO SE IL BONIFICO CHIUDE UNA SCADENZA DI UN INSOLUTO
				SELECT SCADE
				_SEEK = RIBALTA2(DTSCAD)+ALLTRIM(CODFOR)+ALLTRIM(STR(NPART,10,0))
				SELECT SCADENZE_CON_INSOLUTO
				SET ORDER TO SCADENZA
				SEEK _SEEK 
				IF FOUND()
					**** QUESTO BONIFICO PAGA UN INSOLUTO : LO SCARTO !!!!!!
					**** QUESTO BONIFICO PAGA UN INSOLUTO : LO SCARTO !!!!!!
					**** QUESTO BONIFICO PAGA UN INSOLUTO : LO SCARTO !!!!!!
					**** QUESTO BONIFICO PAGA UN INSOLUTO : LO SCARTO !!!!!!

				ELSE
					**** OK ALTRO BONIFICO : LO TENGO !!!!!!!!
					**** OK ALTRO BONIFICO : LO TENGO !!!!!!!!
					**** OK ALTRO BONIFICO : LO TENGO !!!!!!!!
					**** OK ALTRO BONIFICO : LO TENGO !!!!!!!!
						
					_INCASSATO=.T.  							&& (H)  BONIFICI O ALTRI PAGAMENTI (TUTTO ECCETTO RIBA)
					DO AGGIORNO_DETTAGLI_SITUAZIONE_FINANZIARIA WITH _TIPO_DET,_INCASSATO
				ENDIF

		ENDIF		
		
		SELECT SCADE 
		SKIP 
		LOOP
	ENDIF
	
	IF EMPTY(_TIPO_DET)
		*** NON SONO RIUSCITO A CLASSIFICARE QUESTO DETTAGLIO
		*** LO SCARTO
		SELECT SCADE
		SKIP
		LOOP
	ENDIF
		
	SELECT SCADE
	SKIP 
ENDDO



SELECT(_CURRENT_SELECT)
RETURN
* FINE PROCEDURE DETTAGLI_SITUAZIONE_FINANZIARIA 
***************************************************************************************


***************************************************************************************
PROCEDURE AGGIORNO_DETTAGLI_SITUAZIONE_FINANZIARIA 
***************************************************************************************
PARAMETERS _TIPO_DET,_INCASSATO

SELECT SCADE

SCATTER MEMVAR MEMO 
SELECT DET_FIN
APPEND BLANK 
GATHER MEMVAR MEMO

REPLACE TIPO_DET 	WITH _TIPO_DET
REPLACE INCASSATO 	WITH _INCASSATO
REPLACE NSALDO 		WITH NDARE - NAVERE

*** RAGGRUPPO I DETTAGLI NEL CURSORE RIE_FIN
DO RAGGRUPPO_DETTAGLI_SITUAZIONE_FINANZIARIA


SELECT SCADE 

* FINE PROCEDURE AGGIORNO_DETTAGLI_SITUAZIONE_FINANZIARIA 
***************************************************************************************

***************************************************************************************
PROCEDURE RAGGRUPPO_DETTAGLI_SITUAZIONE_FINANZIARIA 
***************************************************************************************
* FABIANO 08/04/2012
***************************************************************************************
LOCAL _CODFOR,_NDARE,_NAVERE,_NSALDO,_TIPO_DET,_INCASSATO,_RAGSOC,_FLAG_RIBA_CPA

SELECT DET_FIN
_CODFOR=CODFOR
_NDARE=NDARE
_NAVERE=NAVERE
_NSALDO=NDARE-NAVERE
_TIPO_DET = TIPO_DET
_INCASSATO= INCASSATO
_RAGSOC = RAGSOC
	
SELECT SCADE
_FLAG_RIBA_CPA = FLAG_RIBA
	
SELECT RIE_FIN
SET ORDER TO CODFOR
SEEK _CODFOR

IF !FOUND()
	APPEND BLANK 
	REPLACE CODFOR WITH _CODFOR
	REPLACE RAGSOC WITH _RAGSOC
ENDIF

DO CASE 
	CASE _TIPO_DET ='FAT'
		REPLACE IMP_FAT_INSC WITH IMP_FAT_INSC + _NSALDO
		
		IF _FLAG_RIBA_CPA ="X"
			REPLACE IMP_FAT_RIBA WITH IMP_FAT_RIBA + _NSALDO
		ELSE
			REPLACE IMP_FAT_BONI WITH IMP_FAT_BONI + _NSALDO
		ENDIF
		
	CASE _TIPO_DET ='RIC'
		
		*** PRENDO L'IMPORTO DELLA RICEVUTA IN VALORE ASSOLUTO 
		*** PERCHE' E' UN PAGAMENTO QUINDI NEGATIVO (AVERE)
		_NSALDO=ABS(_NSALDO)
		
		REPLACE IMP_RIC_INSC WITH IMP_RIC_INSC + _NSALDO
		
		IF _INCASSATO 
			REPLACE IMP_RIC_INCA WITH IMP_RIC_INCA + _NSALDO
		ELSE 
			REPLACE IMP_RIC_NOINCA WITH IMP_RIC_NOINCA + _NSALDO
		ENDIF
		
	CASE _TIPO_DET ='INS'
	
		REPLACE IMP_INS_RICEV WITH IMP_INS_RICEV + _NSALDO
	
		IF _INCASSATO 
			REPLACE IMP_INS_PAGA WITH IMP_INS_PAGA + _NSALDO
		ELSE
			REPLACE IMP_INS_NOINCA WITH  IMP_INS_NOINCA + _NSALDO
		ENDIF
				
	CASE _TIPO_DET ='BON'
		*** PRENDO L'IMPORTO DEL BONIFICO IN VALORE ASSOLUTO
		*** PERCHE' E' UN PAGAMENTO QUINDI NEGATIVO (AVERE)
		_NSALDO=ABS(_NSALDO)
		
		REPLACE IMP_BON_SING WITH IMP_BON_SING + _NSALDO
ENDCASE		

*** ad ogni riga inserita/aggiornata aggiorni il totale incassato e le percentuali

REPLACE PERC_RIC_INCA WITH CALCOLA_PERCENTUALI(IMP_RIC_INCA,IMP_RIC_INSC)

REPLACE PERC_INS_NOPAG WITH CALCOLA_PERCENTUALI((IMP_INS_RICEV -IMP_INS_PAGA ),IMP_INS_RICEV)

****          IMPORTO RICEVUTE INCASSARE
****        + IMPORTO INSOLUTI INCASSATI
****        + IMPORTO BONIFICI O ALTRI PAGAMENTI
****       ========================================
****           TOTALE INCASSATO

__INCASSATO = IMP_RIC_INCA + IMP_INS_PAGA + IMP_BON_SING
REPLACE TOT_INCASSATO WITH __INCASSATO 

****          IMPORTO RICEVUTE EMESSE
****        + IMPORTO INSOLUTI RICEVUTI
****        + IMPORTO FATTURE CON CPA BONIFICO
****       ========================================
****           TOTALE EMESSO

__EMESSO = IMP_RIC_INSC + IMP_INS_RICEV + IMP_FAT_BONI

****                         TOTALE INCASSATO  
**** PERCENTUALE INCASSATO = ----------------  * 100
****                         TOTALE EMESSO

REPLACE PERC_INCA_TOT WITH CALCOLA_PERCENTUALI(__INCASSATO  , __EMESSO  )

SELECT DET_FIN

RETURN
* FINE PROCEDURE RAGGRUPPO_DETTAGLI_SITUAZIONE_FINANZIARIA 
***************************************************************************************




***************************************************************************************
PROCEDURE CREA_CURSORI_PER_ANALISI_SITUAZIONE_FINANZIARIA
***************************************************************************************
PARAMETERS _DATADAL,_DATAAL,_DATA_SCAD_DAL,_DATA_SCAD_AL,_OPZIONE  

********** CURSORE SCADENZE CON BONIFICO
WAIT WINDOW "ATTENDERE PREGO... analizza scadenze con bonifici" NOWAIT
SELECT CODFOR,NPART,DTSCAD,TIPODOC ;
FROM SCADE ;
WHERE FLAG_RIBA_TOP ='N' AND FLAG_NATURA='P' ;
GROUP BY CODFOR,NPART,DTSCAD,TIPODOC ;
INTO CURSOR SCADENZE_CON_BONIFICO

SELECT SCADENZE_CON_BONIFICO
INDEX ON RIBALTA2(DTSCAD)+ALLTRIM(CODFOR)+ALLTRIM(STR(NPART,10,0))	TAG  SCADENZA
SET ORDER TO SCADENZA
GO TOP


********** CURSORE SCADENZE CON RELATIVI SALDI
WAIT WINDOW "ATTENDERE PREGO... analizza saldi scadenze" NOWAIT
SELECT CODFOR,NPART,DTSCAD,SUM(SALDO) AS SALDO ;
 FROM ;
(SELECT CODFOR,;
	NPART,;
	DTSCAD,;
	(NDARE - NAVERE) AS SALDO ;
FROM SCADE ) AS SC1 ;
GROUP BY CODFOR,NPART,DTSCAD ;
INTO CURSOR SCADENZE_APERTE_CHIUSE 

SELECT SCADENZE_APERTE_CHIUSE 
INDEX ON RIBALTA2(DTSCAD)+ALLTRIM(CODFOR)+ALLTRIM(STR(NPART,10,0))	TAG  SCADENZA
SET ORDER TO SCADENZA
GO TOP


********** CURSORE PARTITE CON RELATIVI SALDI
WAIT WINDOW "ATTENDERE PREGO... analizza saldi partite" NOWAIT
SELECT CODFOR,NPART,SUM(SALDO) AS SALDO ;
 FROM ;
(SELECT CODFOR,;
	NPART,;
	(NDARE - NAVERE) AS SALDO ;
FROM SCADE ) AS SC1 ;
GROUP BY CODFOR,NPART;
INTO CURSOR PARTITE_APERTE_CHIUSE 

SELECT PARTITE_APERTE_CHIUSE 
INDEX ON ALLTRIM(CODFOR)+ALLTRIM(STR(NPART,10,0))	TAG  PARTITA
SET ORDER TO PARTITA
GO TOP


********** CURSORE SCADENZE CON INSOLUTO
WAIT WINDOW "ATTENDERE PREGO... analizza scadenze con insoluti" NOWAIT
SELECT CODFOR,NPART,DTSCAD,TIPODOC ;
FROM SCADE ;
WHERE FLAG_NATURA='I' ;
GROUP BY CODFOR,NPART,DTSCAD,TIPODOC ;
INTO CURSOR SCADENZE_CON_INSOLUTO

SELECT SCADENZE_CON_INSOLUTO
INDEX ON RIBALTA2(DTSCAD)+ALLTRIM(CODFOR)+ALLTRIM(STR(NPART,10,0))	TAG  SCADENZA
SET ORDER TO SCADENZA
GO TOP

********** CURSORE PARTITE CON SCADENZE FUTURE
WAIT WINDOW "ATTENDERE PREGO... analizza partite con scadenze successive al "+_DATAAL NOWAIT
SELECT CODFOR,NPART ;
FROM SCADE ;
WHERE RIBALTA2(DTPOSTRIBA)>RIBALTA2(_DATAAL) ;
GROUP BY CODFOR,NPART ;
INTO CURSOR PARTITE_CON_SCADENZE_FUTURE

SELECT PARTITE_CON_SCADENZE_FUTURE
INDEX ON ALLTRIM(CODFOR)+ALLTRIM(STR(NPART,10,0))	TAG  PARTITA
SET ORDER TO PARTITA
GO TOP


***** SE NON DEVO TRATTARE SOLO I CLIENTI INSOLVENTI
***** NON CREO IL PROSSIMO CURSORE DEI CLIENTI_CON_INSOLUTO
***** PERCHE' APPESANTISCE L'ELABORAZIONE
IF _OPZIONE  ="TUTTI"
	RETURN
ENDIF

********** CURSORE CLIENTI CON INSOLUTO
WAIT WINDOW "ATTENDERE PREGO... analizza clienti con insoluti nel periodo richiesto" NOWAIT
SELECT CODFOR ;
FROM SCADE ;
WHERE FLAG_NATURA='I' ;
	AND (RIBALTA2(DTDOC)>=RIBALTA2(_DATADAL) AND  RIBALTA2(DTDOC)<=RIBALTA2(_DATAAL)) ;
	AND (RIBALTA2(DTSCAD)>=RIBALTA2(_DATA_SCAD_DAL) AND RIBALTA2(DTSCAD )<=RIBALTA2(_DATA_SCAD_AL)) ;
GROUP BY CODFOR  ;
INTO CURSOR CLIENTI_CON_INSOLUTO

SELECT CLIENTI_CON_INSOLUTO
INDEX ON ALLTRIM(CODFOR) TAG CODFOR
SET ORDER TO CODFOR

RETURN


*****************************************************
PROCEDURE CALCOLO_PERCENTUALI_REPORT_FINALI 
*****************************************************
*	CALCOLO DELLE PERCENTUALI REPORT *
*****************************************************			
RELEASE PERC_RIC_INCA_TT, PERC_INS_NOPAG_TT,PERC_INCA_TOT_TT
PUBLIC PERC_RIC_INCA_TT, PERC_INS_NOPAG_TT,PERC_INCA_TOT_TT 

PERC_RIC_INCA_TT =0
PERC_INS_NOPAG_TT =0
PERC_INCA_TOT_TT =0


SELECT RIE_FIN
GO TOP

SUM IMP_ALTRI_PAG TO IMP_ALTRI_PAG_TT

*****WAIT WINDOW STR(IMP_ALTRI_PAG_TT)

SUM IMP_RIC_INSC TO IMP_RIC_INSC_TT
SUM IMP_RIC_INCA TO IMP_RIC_INCA_TT

PERC_RIC_INCA_TT=CALCOLA_PERCENTUALI(IMP_RIC_INCA_TT,IMP_RIC_INSC_TT)
	
SUM IMP_INS_RICEV TO IMP_INS_RICEV_TT
SUM IMP_INS_PAGA  TO IMP_INS_PAGA_TT 

PERC_INS_NOPAG_TT= CALCOLA_PERCENTUALI( IMP_INS_RICEV_TT-IMP_INS_PAGA_TT , IMP_INS_RICEV_TT)


****          IMPORTO RICEVUTE INCASSARE
****        + IMPORTO INSOLUTI INCASSATI
****        + IMPORTO BONIFICI O ALTRI PAGAMENTI
****       ========================================
****           TOTALE INCASSATO

SUM IMP_BON_SING TO IMP_BON_SING_TT
SUM IMP_FAT_BONI TO IMP_FAT_BONI_TT 

__INCASSATO_TT = IMP_RIC_INCA_TT+ IMP_INS_PAGA_TT + IMP_BON_SING_TT

****          IMPORTO RICEVUTE EMESSE
****        + IMPORTO INSOLUTI RICEVUTI
****        + IMPORTO FATTURE CON CPA BONIFICO
****       ========================================
****           TOTALE EMESSO

__EMESSO_TT = IMP_RIC_INSC_TT + IMP_INS_RICEV_TT+ IMP_FAT_BONI_TT 

****                         TOTALE INCASSATO  
**** PERCENTUALE INCASSATO = ----------------  * 100
****                         TOTALE EMESSO

PERC_INCA_TOT_TT =CALCOLA_PERCENTUALI( __INCASSATO_TT , __EMESSO_TT)


RETURN


*****************************************************
*	CALCOLO DELLE PERCENTUALI DI DETTAGLIO E TOTALI *
*****************************************************			
FUNCTION CALCOLA_PERCENTUALI

PARA _NUMERATORE,_DENOMINATORE

_PERC_RITORNO = 0

IF _DENOMINATORE > 0		
	_PERC_RITORNO 	= _NUMERATORE / _DENOMINATORE*100
ENDIF

RETURN(_PERC_RITORNO)

* FINE PROCEDURE CREA_CURSORI_PER_ANALISI_SITUAZIONE_FINANZIARIA
***************************************************************************************