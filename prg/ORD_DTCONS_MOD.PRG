
RELEASE _V_DATADA,_V_DATAAL,_V_CODMAG,_V_DESMAG
PUBLIC _V_DATADA,_V_DATAAL,_V_CODMAG,_V_DESMAG

_V_DATADA = "01/01/"+PUB_ANNO
_V_DATAAL = "31/12/"+PUB_ANNO
_V_CODOPE = ""
_V_DESOPE = ""

_CONTINUA = .F.
DO FORM FORM\ORD_DTCONS_MOD_SEL_FILTRI LINKED
IF !_CONTINUA
	MESSAGEBOX("Operazione abbandonata",48,"Informazione")
	RETURN .F.
ENDIF

WAIT WINDOWS "Estrazione ordini con data consegna modificata..." NOWAIT

cSql=""
cNomeCursorSql="TMP_ORDINI"
TEXT TO cSql NOSHOW
	SELECT *,
			CASE 
				--WHEN (DATA_CONSEGNA <> '' AND DATA_CONSEGNA <> '31/12/2999' AND DATA_CONSEGNA_INIZIALE <> '') 
				WHEN (DATA_CONSEGNA <> '' AND DATA_CONSEGNA <> '31/12/2999' AND dbo.ribalta2(DATA_CONSEGNA) >= '2000/01/01' AND 
						DATA_CONSEGNA_INIZIALE <> '' AND DATA_CONSEGNA_INIZIALE <> '31/12/2999' AND dbo.ribalta2(DATA_CONSEGNA_INIZIALE) >= '2000/01/01')  -- ERASMO - 01/02/2023
					THEN DATEDIFF(DAY, CONVERT(DATETIME,DBO.RIBALTA2(DATA_CONSEGNA_INIZIALE),111), CONVERT(DATETIME,DBO.RIBALTA2(DATA_CONSEGNA),111)) 
				ELSE 0 
			END AS GG_RITARDO 
	FROM (
		SELECT 	
			ORS_CODCLI AS COD_CLIENTE,
			ORS_RAGSOC AS RAG_SOCIALE,
			ORS_NUMORD AS NUM_ORDINE,
			ORS_DATORD AS DATA_ORDINE,
			ORD_CODART AS COD_ARTICOLO,
			ORD_DESART AS DES_ARTICOLO,
			ORD_SEQUEN AS NR_RIGA,
			DBO.RIBALTA2(ORD_DATCON) AS DATA_CONSEGNA,
			(SELECT TOP 1 VALORE_PREC FROM LOG_EVENTI WHERE TIPO_EVENTO='ORDINI' AND CAMPO_MODIFICATO='DATA CONSEGNA' AND DATA_EVENTO BETWEEN '<<RIBALTA2(_V_DATADA)>>' AND '<<RIBALTA2(_V_DATAAL)>>' AND COD_USER='<<_V_CODOPE)>>' 
				AND DESCRIZIONE NOT LIKE 'ARTICOLO .%' AND ORS_NUMORD+DBO.RIBALTA2(ORS_DATORD)+ORD_CODART = SUBSTRING(GRUPPO_EVENTO,8,6)+SUBSTRING(GRUPPO_EVENTO,19,10)+SUBSTRING(DESCRIZIONE,10,CHARINDEX(' (',DESCRIZIONE,0)-10) 
				ORDER BY DATA_EVENTO DESC) AS DATA_CONSEGNA_INIZIALE,
			DBO.RIBALTA2(
			(SELECT TOP 1 DATA_EVENTO FROM LOG_EVENTI WHERE TIPO_EVENTO='ORDINI' AND CAMPO_MODIFICATO='DATA CONSEGNA' AND DATA_EVENTO BETWEEN '<<RIBALTA2(_V_DATADA)>>' AND '<<RIBALTA2(_V_DATAAL)>>' AND COD_USER='<<_V_CODOPE)>>' 
				AND DESCRIZIONE NOT LIKE 'ARTICOLO .%' AND ORS_NUMORD+DBO.RIBALTA2(ORS_DATORD)+ORD_CODART = SUBSTRING(GRUPPO_EVENTO,8,6)+SUBSTRING(GRUPPO_EVENTO,19,10)+SUBSTRING(DESCRIZIONE,10,CHARINDEX(' (',DESCRIZIONE,0)-10) 
				ORDER BY DATA_EVENTO DESC)
				) AS DATA_EVENTO,
			ORD_VALORE AS VALORE,
			CASE ORD_CHIUSO WHEN 1 THEN 'SI' ELSE '' END AS CHIUSO
		FROM U_ORD_DD AS DD
		WHERE ORD_DESART <> '*** COMMENTO ***' AND ORS_NUMORD+DBO.RIBALTA2(ORS_DATORD)+ORD_CODART IN 
			(SELECT SUBSTRING(GRUPPO_EVENTO,8,6)+SUBSTRING(GRUPPO_EVENTO,19,10)+SUBSTRING(DESCRIZIONE,10,CHARINDEX(' (',DESCRIZIONE,0)-10) AS CHIAVE FROM LOG_EVENTI WHERE TIPO_EVENTO='ORDINI' AND CAMPO_MODIFICATO='DATA CONSEGNA' 
			AND DATA_EVENTO BETWEEN '<<RIBALTA2(_V_DATADA)>>' AND '<<RIBALTA2(_V_DATAAL)>>' AND COD_USER='<<_V_CODOPE)>>' AND DESCRIZIONE NOT LIKE 'ARTICOLO .%' )
	) AS MAIN
	ORDER BY DATA_ORDINE,NUM_ORDINE,NR_RIGA
ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql,.T.)
	return(.F.)
ENDIF
*** SE L'UTENTE HA ANNULLATO LA QUERY IL CURSORE POTREBBE NON ESISTERE, 
*** QUINDI NON PERMETTO DI ANDARE AVANTI
IF !USED(cNomeCursorSql)
	RETURN .F.
ENDIF

SELECT &cNomeCursorSql
GO TOP
IF EOF()
	MESSAGEBOX("Nessun dato da estrarre per i filtri selezionati",64,"Informazione")
ELSE
	_TITOLO_EXCEL1 = "Estrazione ordini con data consegna modificata dall'operatore " + ALLTRIM(_V_DESOPE)
	_TITOLO_EXCEL2 = "Periodo di riferimento dal " + _V_DATADA + " al " + _V_DATAAL
	_TITOLO_EXCEL3 = ""
	_TOTALI_GENERALI = .T.
	DO ESTRXLS WITH cNomeCursorSql,_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,_TOTALI_GENERALI
	
	MESSAGEBOX("Fine elaborazione",64,"Informazione")
ENDIF

