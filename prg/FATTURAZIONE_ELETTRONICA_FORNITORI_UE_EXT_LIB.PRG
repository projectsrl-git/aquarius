******************************************************************************
PROCEDURE CREA_CURSOR_RIEPILOGO_IVA_FAF
******************************************************************************
*!*	CREATE CURSOR RIEPILOGO_IVA (NR_RIGA N(4,0), DATIRIEPILOGOALIQUOTAIVA N(10,2), DATIRIEPILOGONATURA C(30), DATIRIEPILOGOIMPONIBILEIMPORTO N(19,2), DATIRIEPILOGOIMPOSTA N(19,2), ;
*!*		DATIRIEPILOGOESIGIBILITAIVA C(1), DATIRIEPILOGOSPESEACCESSORIE C(254), DATIRIEPILOGOARROTONDAMENTO C(50), CODICE_IVA C(3), TIPO_SPESE_ACCESSORIE C(10), DATIRIEPILOGORIFERIMENTONORMATIVO C(254))  && ERASMO - 14/12/2020
*!*		
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT
		CODICE_IVA,
		CASE RTRIM(LTRIM(SUBSTRING(IVA.LIBERA,1,3)))
			WHEN '' THEN 0.00
			ELSE COALESCE(CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC(6,2)),0.00)
		END AS DATIRIEPILOGOALIQUOTAIVA,
		CASE RTRIM(LTRIM(SUBSTRING(IVA.LIBERA,1,3)))
			WHEN '' THEN '<Natura>'+RTRIM(SUBSTRING(IVA.LIBERA,145,4))+'</Natura>'
			ELSE CASE WHEN CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC (3,0)) = 0 THEN '<Natura>'+RTRIM(SUBSTRING(IVA.LIBERA,145,4))+'</Natura>' ELSE '' END
		END AS DATIRIEPILOGONATURA,		
		DATIRIEPILOGOIMPONIBILEIMPORTO,
		DATIRIEPILOGOIMPOSTA,
		CASE
			WHEN IVA.NOIVACARCLI = 'S' THEN 'S'
			ELSE 'I'
		END AS DATIRIEPILOGOESIGIBILITAIVA,
		CAST('' AS VARCHAR(254)) AS DATIRIEPILOGOSPESEACCESSORIE,
		CAST('' AS VARCHAR(10)) AS TIPO_SPESE_ACCESSORIE,		
		CASE RTRIM(LTRIM(SUBSTRING(IVA.LIBERA,1,3)))
			WHEN '' THEN '<RiferimentoNormativo>'+RTRIM(COALESCE(DESCRI,''))+'</RiferimentoNormativo>'
			ELSE CASE WHEN CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC (3,0)) = 0 THEN '<RiferimentoNormativo>'+RTRIM(COALESCE(DESCRI,''))+'</RiferimentoNormativo>' ELSE '' END
		END AS DATIRIEPILOGORIFERIMENTONORMATIVO,
		--'' AS DATIRIEPILOGOARROTONDAMENTO
		CAST('' AS VARCHAR(254)) AS DATIRIEPILOGOARROTONDAMENTO  -- ERASMO - 11/10/2023
	FROM (
		SELECT
			ORD_IVA AS CODICE_IVA,
			SUM(ORD_VALORE) AS DATIRIEPILOGOIMPONIBILEIMPORTO,
			SUM(ORD_IMPOST) AS DATIRIEPILOGOIMPOSTA
		FROM U_FAF_DD WHERE DAGGANCIO = '<<_TAGGANCIO>>'
		GROUP BY ORD_IVA
		) AS MAIN
	LEFT OUTER JOIN PARA AS IVA ON IVA.CODICE = 'IVA'+MAIN.CODICE_IVA
	ORDER BY CODICE_IVA
ENDTEXT					&& FINE SCRITTURA QUERY
IF !ExecPreparedCommand(cSql,"RIEPILOGO_IVA")
	return(.F.)
ENDIF
SELECT RIEPILOGO_IVA
GO TOP
IF EOF()
	MESSAGEBOX("Dettagli fattura '" + _NUMERO_FATTURA + "' non trovati",16,"Attenzione")
	RETURN .F.
ENDIF

SELECT RIEPILOGO_IVA
GO TOP
SCAN
    IF DATIRIEPILOGOALIQUOTAIVA = 0
    	IF EMPTY(DATIRIEPILOGONATURA)
    		MESSAGEBOX("Codificare la Natura esenzione per il codice iva " + ALLTRIM(CODICE_IVA) + CHR(13) + "(Fattura n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA+")",16,"Attenzione")
    		_YES_CONTINUA = .F.
    		RETURN .F.
    	ENDIF
    ENDIF
ENDSCAN

RETURN
* FINE PROCEDURE CREA_CURSOR_RIEPILOGO_IVA_FAF
******************************************************************************


******************************************************************************
PROCEDURE CREA_CURSOR_DETTAGLI_PAGAMENTO_FAF
******************************************************************************
CREATE CURSOR DETTAGLI_PAGAMENTO (NR_RIGA N(4,0), DETTAGLIOPAGAMENTOMODALITAPAGAMENTO C(4), DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO C(10), DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO N(10,2), DETTAGLIOPAGAMENTOIBAN C(40))

*!*	SELECT CU_AZIENDA_PB
*!*	GO TOP
*!*	_DETTAGLIOPAGAMENTOMODALITAPAGAMENTO_DEFAULT = ALLTRIM(AZI_MODPAG)
*!*	*_DETTAGLIOPAGAMENTOIBAN_DEFAULT = ALLTRIM(AZI_IBAN)
*!*	_DETTAGLIOPAGAMENTOIBAN_DEFAULT = IIF(LEN(ALLTRIM(AZI_IBAN))=27,"<IBAN>"+ALLTRIM(AZI_IBAN)+"</IBAN>","")  && ERASMO - 23/01/2019

*!*	**=> ERASMO - INIZIO 07/03/2019
*!*	** PARAMETRO AZIENDALE "Non inserire mai l'IBAN nel file XML" 
*!*	IF PUB_FENOIBAN
*!*		_DETTAGLIOPAGAMENTOIBAN_DEFAULT = ""
*!*	ENDIF
*!*	**=> ERASMO - FINE 07/03/2019

*!*	SELECT HEADER_FATTURA_ELETTRONICA
*!*	GO TOP
*!*	IF EOF()
*!*		RETURN
*!*	ENDIF
*!*	_XX_DATORD = ORD_DATORD
*!*	_XX_NUMORD = ORD_NUMORD
*!*	_XX_CODCLI = ORD_CODCLI

*!*	x_soci = "ord_codsoc = '" + PUB_CODSOC + "'"
*!*	x_dord = "ord_datord = '" + _XX_DATORD + "'"
*!*	x_nord = "ord_numord = '" + _XX_NUMORD + "'"
*!*	x_agga = "taggancio = '" + _TAGGANCIO + "'"
*!*	*x_cond = x_soci + " and " + x_dord + " and " + x_nord
*!*	x_cond = x_soci + " and " + x_dord + " and " + x_nord + " and " + x_agga  && ERASMO - 06/02/2019
*!*	cSql   = "select * from U_FAT_TT where " + x_cond
*!*	IF !ExecCommand(cSql,"CU_FAT_TT")
*!*		return(.f.)
*!*	ENDIF
*!*	SELECT CU_FAT_TT
*!*	DELETE FOR ORD_CODCLI <> _XX_CODCLI
*!*	GO TOP
*!*	SCATTER MEMVAR MEMO

*!*	IF USED("XU_FAT_DD")
*!*		SELECT XU_FAT_DD
*!*		USE
*!*	ENDIF

*!*	IF !ExecCommand("select * from U_FAT_DD where 0=1","XU_FAT_DD")
*!*	   return(.f.)
*!*	ENDIF

*!*	IF USED("U_DOC_DD")
*!*		SELECT U_DOC_DD
*!*		USE
*!*	ENDIF

*!*	SELECT XU_FAT_DD
*!*	SET FILTER TO
*!*	SET ORDER TO
*!*	ZAP

*!*	** RIEMPIE IL CURSORE DI TUTTI I DETTAGLI DOCUMENTO  --------------------------------------------------------------*
*!*	x_agga = "daggancio = '" + M.TAGGANCIO + "'"
*!*	x_cond = x_agga
*!*	Csql = "select * from U_FAT_DD where " + x_cond + " order by ord_sequen"  
*!*	IF !ExecCommand(cSql,"U_DOC_DD")
*!*		return(.f.)
*!*	ENDIF
*!*	SELECT U_DOC_DD
*!*	GO TOP

*!*	DO WHILE .T.

*!*		IF EOF()
*!*			EXIT
*!*		ENDIF

*!*		IF DELETED()
*!*			SKIP +1
*!*			LOOP
*!*		ENDIF
*!*		
*!*		SCATTER MEMVAR MEMO
*!*		
*!*		SELECT XU_FAT_DD
*!*		APPEND BLANK
*!*		
*!*		M.ORS_NUMORD = M.ORD_NUMORD 
*!*		M.ORS_DATORD = M.ORD_DATORD 
*!*		M.ORS_CODCLI = M.ORD_CODCLI		 
*!*		
*!*		DO U_FAT_DD
*!*			
*!*		SELECT U_DOC_DD
*!*		SKIP +1

*!*	ENDDO

*!*	SELECT CU_FAT_TT
*!*	GO TOP
*!*	SCATTER MEMVAR MEMO

*!*	*########## INIZIO - DA RISTAMPELIB.PRG
*!*	CREATE CURSOR PERIODI;
*!*	   (DSCAD C(10),IMP_SCAD N(15,3),NUM_TRAN N(5))
*!*	   
*!*	***==>  CREA TRANCHE 

*!*	PUBLIC VET_DAL[2],VET_AL[2],VET_DAY[2]

*!*	x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
*!*	x_codi = "cli_codcli = '" + ALLTRIM(M.ORD_CODCLI) + "'"
*!*	x_cond = x_soci + " and " + x_codi   
*!*	cSql = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
*!*	IF !ExecCommand(cSql,"CUR_CLIENTI")
*!*	   RETURN .F.
*!*	ENDIF
*!*	SELECT CUR_CLIENTI
*!*	GO TOP   
*!*	IF EOF()
*!*	   DL_LINGUA = ""
*!*	   VET_DAL[1]= "0000"
*!*	   VET_DAL[2]= "0000"
*!*	   VET_AL[1] = "0000"
*!*	   VET_AL[2] = "0000"
*!*	   VET_DAY[1]= "0000"
*!*	   VET_DAY[2]= "0000"
*!*	   ___FLAG_POSALL = .F.		&& 2010-08-04 sergio posticipi per tutto l'anno
*!*	   ___CLIENTE     = ""		&& 2010-08-04 sergio posticipi per tutto l'anno 
*!*	ELSE
*!*	   DL_LINGUA = CLI_LINGUA
*!*	   VET_DAL[1]= CLI_BDAL
*!*	   VET_DAL[2]= CLI_B2DAL
*!*	   VET_AL[1] = CLI_BAL
*!*	   VET_AL[2] = CLI_B2AL
*!*	   VET_DAY[1]= CLI_GG1
*!*	   VET_DAY[2]= CLI_GG2
*!*	   ___FLAG_POSALL = CLI_POSALL		&& 2010-08-04 sergio posticipi per tutto l'anno
*!*	   ___CLIENTE     = M.ORD_CODCLI		&& 2010-08-04 sergio posticipi per tutto l'anno   
*!*	ENDIF

*!*	SELECT XU_FAT_DD
*!*	GO TOP

*!*	RELEASE __T_IMPON,__T_IMPOS   
*!*	PUBLIC  __T_IMPON,__T_IMPOS   
*!*	__T_IMPON	= M.ORD_IMPONIB
*!*	__T_IMPOS   = M.ORD_IMPOSTA  

*!*	V_DATASCAD = M.ORD_DATORD
*!*	V_PAG = M.ORD_CPA
*!*	TOT_FATT = M.ORD_VALORE
*!*	V_VALUTA = M.ORD_VALUTA

*!*	V_TUTTO = TRANCHE("PARA",V_PAG,V_DATASCAD,TOT_FATT,VET_DAL,VET_AL,VET_DAY,V_VALUTA,___FLAG_POSALL,___CLIENTE,__T_IMPON,__T_IMPOS)

*!*	=CREA_SCADENZE()



*!*	*** SE CONDIZIONE DI PAGAMENTO SPECIALE, A SECONDA DEL VALORE DI PUB_SSPORD:
*!*	*** 1 - RIGENERA IL COMMENTO CON I RIFERIMENTI ALLE SCADENZE SPECIALI
*!*	*** 2 - RIPORTA RIFERIMENTI ALLE SCADENZE SPECIALI NEI VETTORI RELATIVI ALLA GESTIONE DELLE SCADENZE
*!*	IF checkConSpe(V_PAG)
*!*		=SCADENZE_SPECIALI(M.TIPRENDO,.F.,.F.,.T.,"XU_FAT_DD",.F.)
*!*		SELECT XU_FAT_DD
*!*	    DELETE FOR DAGGANCIO = 'EOF'
*!*		APPEND BLANK
*!*		REPLACE DAGGANCIO  WITH 'EOF'
*!*		REPLACE ORD_SEQUEN WITH 99999
*!*		   
*!*		REPLACE ORS_NUMORD WITH M.ORD_NUMORD
*!*		REPLACE ORS_DATORD WITH M.ORD_DATORD
*!*		REPLACE ORS_CODCLI WITH M.ORD_CODCLI   
*!*	ENDIF
*!*	*########## FINE - DA RISTAMPELIB.PRG

*!*	*!*	FOR _I = 1 TO 7
*!*	*!*		IF !EMPTY(DATA(_I)) AND IMPORTO(_I) > 0
*!*	*!*			SELECT DETTAGLI_PAGAMENTO
*!*	*!*			APPEND BLANK
*!*	*!*			REPLACE NR_RIGA WITH _I
*!*	*!*			REPLACE DETTAGLIOPAGAMENTOMODALITAPAGAMENTO WITH _DETTAGLIOPAGAMENTOMODALITAPAGAMENTO_DEFAULT
*!*	*!*			REPLACE DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO WITH SUBSTR(DATA(_I),7,4) + '-' + SUBSTR(DATA(_I),4,2) + '-' + SUBSTR(DATA(_I),1,2)
*!*	*!*			REPLACE DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO WITH IMPORTO(_I)
*!*	*!*			REPLACE DETTAGLIOPAGAMENTOIBAN WITH _DETTAGLIOPAGAMENTOIBAN_DEFAULT
*!*	*!*		ENDIF
*!*	*!*	ENDFOR

*!*	**=> ERASMO - INIZIO 17/01/2019
*!*	IF checkConSpe(V_PAG)
*!*		SELECT CUR_SCADENZE
*!*		GO TOP
*!*		_NR_RIGA = 0
*!*		SCAN
*!*			_NR_RIGA = _NR_RIGA + 1
*!*			_ORD_RIBA = ORD_RIBA
*!*			_ORD_DTSCAD = ORD_DTSCAD
*!*			_ORD_TRANCH = ORD_TRANCH
*!*			SELECT DETTAGLI_PAGAMENTO
*!*			APPEND BLANK
*!*			REPLACE NR_RIGA WITH _NR_RIGA
*!*			REPLACE DETTAGLIOPAGAMENTOMODALITAPAGAMENTO WITH IIF(_ORD_RIBA,'MP12',_DETTAGLIOPAGAMENTOMODALITAPAGAMENTO_DEFAULT)
*!*			REPLACE DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO WITH SUBSTR(_ORD_DTSCAD,7,4) + '-' + SUBSTR(_ORD_DTSCAD,4,2) + '-' + SUBSTR(_ORD_DTSCAD,1,2)
*!*			REPLACE DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO WITH _ORD_TRANCH
*!*			REPLACE DETTAGLIOPAGAMENTOIBAN WITH _DETTAGLIOPAGAMENTOIBAN_DEFAULT
*!*		ENDSCAN
*!*	ELSE
*!*		FOR _I = 1 TO 7
*!*			IF !EMPTY(DATA(_I)) AND IMPORTO(_I) > 0
*!*				SELECT DETTAGLI_PAGAMENTO
*!*				APPEND BLANK
*!*				REPLACE NR_RIGA WITH _I
*!*				REPLACE DETTAGLIOPAGAMENTOMODALITAPAGAMENTO WITH _DETTAGLIOPAGAMENTOMODALITAPAGAMENTO_DEFAULT
*!*				REPLACE DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO WITH SUBSTR(DATA(_I),7,4) + '-' + SUBSTR(DATA(_I),4,2) + '-' + SUBSTR(DATA(_I),1,2)
*!*				REPLACE DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO WITH IMPORTO(_I)
*!*				REPLACE DETTAGLIOPAGAMENTOIBAN WITH _DETTAGLIOPAGAMENTOIBAN_DEFAULT
*!*			ENDIF
*!*		ENDFOR
*!*	ENDIF
*!*	**=> ERASMO - FINE 17/01/2019

*!*	**=> ERASMO - INIZIO 06/08/2019
*!*	*** SE CLIENTE CON IVA SPLIT PAYMENT (SCISSIONE PAGAMENTI, IVA A CARICO CLIENTE), RAGGRUPPO IN UN UNICO PAGAMENTO CON ALL'INTERNO IL SOLO IMPONIBILE
*!*	SELECT HEADER_FATTURA_ELETTRONICA
*!*	GO TOP
*!*	IF !EOF()
*!*		IF ESIGIBILITA_IVA = "S"  && SCISSIONE PAGAMENTI
*!*			_NR_RIGA = 1
*!*			_DETTAGLIOPAGAMENTOMODALITAPAGAMENTO = ""
*!*			_DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO = ""
*!*			_DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO = IMPORTO_PAGAMENTO
*!*			_DETTAGLIOPAGAMENTOIBAN = ""
*!*			
*!*			SELECT DETTAGLI_PAGAMENTO
*!*			GO TOP
*!*			SCAN
*!*				IF !EMPTY(DETTAGLIOPAGAMENTOMODALITAPAGAMENTO)
*!*					_DETTAGLIOPAGAMENTOMODALITAPAGAMENTO = DETTAGLIOPAGAMENTOMODALITAPAGAMENTO
*!*				ENDIF
*!*				IF !EMPTY(DETTAGLIOPAGAMENTOIBAN)
*!*					*_DETTAGLIOPAGAMENTOIBAN = _DETTAGLIOPAGAMENTOIBAN
*!*					_DETTAGLIOPAGAMENTOIBAN = DETTAGLIOPAGAMENTOIBAN  && ERASMO - 21/02/2020
*!*				ENDIF
*!*				
*!*				IF EMPTY(_DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO)
*!*					_DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO = DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO
*!*				ELSE
*!*					IF _DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO < DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO
*!*						_DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO = DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO
*!*					ENDIF
*!*				ENDIF
*!*			ENDSCAN
*!*			
*!*			SELECT DETTAGLI_PAGAMENTO
*!*			ZAP
*!*			APPEND BLANK
*!*			REPLACE NR_RIGA WITH _NR_RIGA 
*!*			REPLACE DETTAGLIOPAGAMENTOMODALITAPAGAMENTO WITH _DETTAGLIOPAGAMENTOMODALITAPAGAMENTO
*!*			REPLACE DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO WITH _DETTAGLIOPAGAMENTODATASCADENZAPAGAMENTO
*!*			REPLACE DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO WITH _DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO
*!*			REPLACE DETTAGLIOPAGAMENTOIBAN WITH _DETTAGLIOPAGAMENTOIBAN
*!*		ENDIF
*!*	ENDIF
*!*	**=> ERASMO - FINE 06/08/2019	

RETURN
* FINE PROCEDURE CREA_CURSOR_DETTAGLI_PAGAMENTO_FAF
******************************************************************************


******************************************************************************
PROCEDURE AGGIUNGI_RIGA_SPESE_ACCESSORIE_CURSOR_BODY_FATTURA_ELETTRONICA_FAF
******************************************************************************
LPARAMETERS _par_ImponibileSP,__par_ImpostaSP,_par_CodIvaSP,_par_DescrRiga

_X_NUM_ALIQ = 0
_X_NATURA = ""
v_seek 	 = 'IVA'+_par_CodIvaSP
v_chiave  = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   _X_ALIQ = SUBSTR(LIBERA,1,3)
   _X_NUM_ALIQ = VAL(_X_ALIQ)
   _X_NATURA = SUBSTR(LIBERA,145,4)
ENDIF
    
_DETTAGLIOLINEENATURAIVA = ""
*IF __par_ImpostaSP = 0
IF _X_NUM_ALIQ = 0  && ERASMO - 12/06/2020
	IF EMPTY(_X_NATURA)
		MESSAGEBOX("Codificare la Natura esenzione per il codice iva " + ALLTRIM(_par_CodIvaSP) + CHR(13) + "(Fattura n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA+")",16,"Attenzione")
		_YES_CONTINUA = .F.
		RETURN .F.
	ENDIF
	_DETTAGLIOLINEENATURAIVA = "<Natura>"+ALLTRIM(_X_NATURA)+"</Natura>"
ENDIF

SELECT FatturaElettronica
GO BOTTOM
_NR_RIGA = NR_RIGA + 1			&& ERASMO - 14/01/2019
APPEND BLANK					&& ERASMO - 14/01/2019
REPLACE NR_RIGA WITH _NR_RIGA	&& ERASMO - 14/01/2019
REPLACE ORD_QTAORD WITH 1
REPLACE CODICE_TIPO WITH 'ART'
REPLACE CODICE_VALORE WITH "."
REPLACE ORD_CODART WITH "."
REPLACE ORD_DESART WITH _par_DescrRiga
REPLACE ORD_PREZZO WITH _par_ImponibileSP
*REPLACE ORD_SC1 WITH 0
REPLACE IMPORTO_SCONTO WITH 0
REPLACE ORD_PRZNET WITH _par_ImponibileSP
REPLACE ORD_VALORE WITH _par_ImponibileSP
REPLACE DETTAGLIOLINEEALIQUOTAIVA WITH ROUND(_X_NUM_ALIQ,2)
REPLACE DETTAGLIOLINEENATURAIVA WITH _DETTAGLIOLINEENATURAIVA 
REPLACE DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE WITH ""
REPLACE DETTAGLIOLINEETIPOCESSIONEPRESTAZIONE WITH "<TipoCessionePrestazione>AC</TipoCessionePrestazione>"  && SPESE ACCESSORIE
REPLACE ORD_IVA WITH _par_CodIvaSP  && ERASMO - 01/04/2019

RETURN
* FINE PROCEDURE AGGIUNGI_RIGA_SPESE_ACCESSORIE_CURSOR_BODY_FATTURA_ELETTRONICA_FAF
******************************************************************************

**=> ERASMO - INIZIO 20/05/2022
******************************************************************************
PROCEDURE CONVERSIONE_IN_VALUTA_RIFERIMENTO_FAF
******************************************************************************
SELECT HEADER_FATTURA_ELETTRONICA
GO TOP
IF EOF()
	RETURN
ENDIF

IF ORD_VALUTA = PUB_VALRIF
	RETURN
ENDIF

_X_CAMBIO = ORD_CAMBIO
IF _X_CAMBIO = 1
	RETURN
ENDIF

REPLACE ORD_VALUTA WITH ALLTRIM(PUB_VALRIF)
REPLACE ORD_VALORE WITH ORD_VALORE * _X_CAMBIO
REPLACE IMPORTOTOTALEDOCUMENTO WITH IMPORTOTOTALEDOCUMENTO * _X_CAMBIO
REPLACE IMPORTO_PAGAMENTO WITH IMPORTO_PAGAMENTO * _X_CAMBIO
REPLACE ORD_IMPONIB WITH ORD_IMPONIB * _X_CAMBIO
REPLACE ORD_IMPOSTA WITH ORD_IMPOSTA * _X_CAMBIO


CREATE CURSOR TOT_DOC_RIEP_IVA (IMPORTO N(19,6), ALIQUOTA N(5,2), NATURA C(20), CODICE_IVA C(3), TIPO_SPESE_ACCESSORIE C(10))
INDEX ON ALLTRIM(STR(ALIQUOTA,5,2))+ALLTRIM(CODICE_IVA)+ALLTRIM(TIPO_SPESE_ACCESSORIE) TAG I_RAGGR

SELECT FatturaElettronica
GO TOP
SCAN
	IF ORD_CODART = "*** COMMENTO ***"
		LOOP
	ENDIF
	REPLACE ORD_PREZZO WITH ORD_PREZZO * _X_CAMBIO
	REPLACE ORD_PRZNET WITH ORD_PREZZO
	REPLACE ORD_VALORE WITH ORD_PRZNET * ORD_QTAORD
	
*!*		*** RICOSTRUISCO LA STRINGA DEGLI SCONTI
*!*		_STRINGA_SCONTO = ""
*!*		IF IMPORTO_SCONTO <> 0
*!*			IF ((IMPORTO_SCONTO*100)-FLOOR(IMPORTO_SCONTO*100) <> 0) OR IMPORTO_SCONTO < 0  && SE LO SCONTO HA PIU' DI 2 DECIMALI OPPURE STO TRATTANDO UNO IMPORTO SCONTO NEGATIVO ALLORA INSERISCO LE PERCENTUALI DI SCONTO 
*!*				IF ORD_SC1 > 0
*!*					_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC1,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
*!*				ENDIF
*!*				IF ORD_SC2 > 0
*!*					_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC2,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
*!*				ENDIF
*!*				IF ORD_SC3 > 0
*!*					_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC3,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
*!*				ENDIF
*!*				IF ORD_SC4 > 0
*!*					_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC4,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
*!*				ENDIF
*!*				IF ORD_SC5 > 0
*!*					_STRINGA_SCONTO = ALLTRIM(_STRINGA_SCONTO) + "<ScontoMaggiorazione><Tipo>SC</Tipo><Percentuale>" + STRTRAN(ALLTRIM(STR(ORD_SC5,6,2)),',','.') + "</Percentuale></ScontoMaggiorazione>"
*!*				ENDIF
*!*			ELSE
*!*				_STRINGA_SCONTO = "<ScontoMaggiorazione><Tipo>SC</Tipo><Importo>" + STRTRAN(ALLTRIM(STR(IMPORTO_SCONTO,15,2)),',','.') + "</Importo></ScontoMaggiorazione>"
*!*			ENDIF
*!*		ENDIF
*!*		REPLACE DETTAGLIOLINEESCONTOMAGGIORAZIONE WITH _STRINGA_SCONTO
	
	_IMPORTO = ORD_VALORE 
	_CODICE_IVA = ORD_IVA
	_DETTAGLIOLINEEALIQUOTAIVA = DETTAGLIOLINEEALIQUOTAIVA
	_DETTAGLIOLINEENATURAIVA = DETTAGLIOLINEENATURAIVA
	_TIPO_SPESE_ACCESSORIE = ""
	IF ALLTRIM(ORD_DESART) == "SPESE ACCESSORIE"
		_TIPO_SPESE_ACCESSORIE = "SPTRAS"
	ENDIF
	IF ALLTRIM(ORD_DESART) == "SPESE INCASSO"
		_TIPO_SPESE_ACCESSORIE = "SPINCA"
	ENDIF
	_SEEK = ALLTRIM(STR(_DETTAGLIOLINEEALIQUOTAIVA,5,2))+ALLTRIM(_CODICE_IVA)+ALLTRIM(_TIPO_SPESE_ACCESSORIE)
	SELECT TOT_DOC_RIEP_IVA
	SET ORDER TO I_RAGGR
	GO TOP
	SEEK _SEEK
	IF !FOUND()
		APPEND BLANK
		REPLACE IMPORTO WITH _IMPORTO 
		REPLACE ALIQUOTA WITH _DETTAGLIOLINEEALIQUOTAIVA 
		REPLACE NATURA WITH _DETTAGLIOLINEENATURAIVA 
		REPLACE CODICE_IVA WITH _CODICE_IVA 
		REPLACE TIPO_SPESE_ACCESSORIE WITH _TIPO_SPESE_ACCESSORIE 
	ELSE
		REPLACE IMPORTO WITH IMPORTO + _IMPORTO 
	ENDIF
ENDSCAN

SELECT RIEPILOGO_IVA
GO TOP
SCAN
	REPLACE DATIRIEPILOGOIMPONIBILEIMPORTO WITH DATIRIEPILOGOIMPONIBILEIMPORTO * _X_CAMBIO
	REPLACE DATIRIEPILOGOIMPOSTA WITH DATIRIEPILOGOIMPOSTA * _X_CAMBIO
	IF !EMPTY(DATIRIEPILOGOSPESEACCESSORIE)
		_NEW_SPESEACCESSORIE = VAL(STRTRAN(STRTRAN(STRTRAN(DATIRIEPILOGOSPESEACCESSORIE,"<SpeseAccessorie>",""),"</SpeseAccessorie>",""),".",",")) * _X_CAMBIO
		_DATIRIEPILOGOSPESEACCESSORIE = "<SpeseAccessorie>"+STRTRAN(ALLTRIM(STR(ROUND(_NEW_SPESEACCESSORIE,2),10,2)),",",".")+"</SpeseAccessorie>"
		REPLACE DATIRIEPILOGOSPESEACCESSORIE WITH _DATIRIEPILOGOSPESEACCESSORIE
	ENDIF
	
	*** INSERIMENTO EVENTUALE ARROTONDAMENTO PER CORRISPONDENZA CON SOMMA DEI DETTAGLI FATTURA
	_ARROTONDAMENTO = 0
	_CODICE_IVA = CODICE_IVA
	_DATIRIEPILOGOIMPONIBILEIMPORTO = DATIRIEPILOGOIMPONIBILEIMPORTO 
	_DATIRIEPILOGOALIQUOTAIVA = DATIRIEPILOGOALIQUOTAIVA
	_DATIRIEPILOGONATURA = DATIRIEPILOGONATURA
	_TIPO_SPESE_ACCESSORIE = TIPO_SPESE_ACCESSORIE
	_IMPORTO = 0
	
	_SEEK = ALLTRIM(STR(_DETTAGLIOLINEEALIQUOTAIVA,5,2))+ALLTRIM(_CODICE_IVA)+ALLTRIM(_TIPO_SPESE_ACCESSORIE)
	SELECT TOT_DOC_RIEP_IVA
	SET ORDER TO I_RAGGR
	GO TOP
	SEEK _SEEK
	IF FOUND()
		_IMPORTO = ROUND(IMPORTO,2)
	ENDIF
	
	IF _IMPORTO <> _DATIRIEPILOGOIMPONIBILEIMPORTO
		_ARROTONDAMENTO = _DATIRIEPILOGOIMPONIBILEIMPORTO - _IMPORTO
	ENDIF
	
	IF _ARROTONDAMENTO <> 0
		_DATIRIEPILOGOARROTONDAMENTO = "<Arrotondamento>"+STRTRAN(ALLTRIM(STR(ROUND(_ARROTONDAMENTO,2),10,2)),",",".")+"</Arrotondamento>"
		SELECT RIEPILOGO_IVA
		REPLACE DATIRIEPILOGOARROTONDAMENTO WITH _DATIRIEPILOGOARROTONDAMENTO
	ENDIF
	
ENDSCAN

SELECT DETTAGLI_PAGAMENTO
GO TOP
SCAN
	REPLACE DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO WITH DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO * _X_CAMBIO
ENDSCAN


RETURN
* FINE CONVERSIONE_IN_VALUTA_RIFERIMENTO_FAF
******************************************************************************
**=> ERASMO - FINE 20/05/2022

