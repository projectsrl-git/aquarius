******************************************************************************
PROCEDURE CREA_CURSOR_HEADER_FATTURA_ELETTRONICA_FAF
******************************************************************************
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY TT.ORD_NUMORD)) AS NUMERIC(4,0)) AS NR_RIGA,
		TT.TAGGANCIO,
		TT.ORD_VALORE,
		TT.ORD_VALORE AS IMPORTOTOTALEDOCUMENTO,
		CASE
			WHEN (SELECT COUNT(*) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' AND ORD_IVA IN 
				(SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND NOIVACARCLI = 'S')) > 0 THEN 'S'
			ELSE 'I'
		END AS ESIGIBILITA_IVA,
		CASE
			WHEN (SELECT COUNT(*) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' AND ORD_IVA IN 
				(SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND NOIVACARCLI = 'S')) > 0 THEN ORD_IMPONIB
			ELSE ORD_VALORE
		END AS IMPORTO_PAGAMENTO,
		ORD_IMPONIB,
		ORD_IMPOSTA,
		SUBSTRING(TT.ORD_INDIRI,1,60) AS ORD_INDIRI,
		CASE 
			WHEN SUBSTRING(TT.ORD_CODNAZ,1,2) <> 'IT' AND (TT.ORD_CAP = '' OR ISNUMERIC(TT.ORD_CAP) = 0) THEN '99999'
			ELSE (CASE WHEN len(rtrim(TT.ORD_CAP)) < 5 THEN replicate('0', 5 - len(rtrim(TT.ORD_CAP))) ELSE '' END) + SUBSTRING(rtrim(TT.ORD_CAP),1,5)
		END AS ORD_CAP,
		CAST('' AS VARCHAR(20)) AS CEDENTEPRESTATORESEDECAP,
		SUBSTRING(TT.ORD_LOCALI,1,60) AS ORD_LOCALI,
		TT.ORD_PROVIN,
--		CASE
--			WHEN (SELECT RTRIM(COALESCE(CODPGO,'')) FROM PARA WHERE CODICE = 'IVA'+(COALESCE((SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' ORDER BY ORD_SEQUEN),''))) <> ''
--				THEN (SELECT RTRIM(COALESCE(CODPGO,'')) FROM PARA WHERE CODICE = 'IVA'+(COALESCE((SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' ORDER BY ORD_SEQUEN),'')))  -- DA PARAMETRO IVA PRIMA RIGA DETTAGLI
--			WHEN (SELECT RTRIM(COALESCE(SUBSTRING(LIBERA,84,4),'')) FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS) <> '' THEN (SELECT RTRIM(SUBSTRING(LIBERA,84,4)) FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS)  -- DA PARAMETRO TOP
--			--WHEN (SELECT COALESCE(SUBSTRING(LIBERA,11,1),'') FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS) = 'S' THEN 'TD04'   -- NOTA DI CREDITO
--			--WHEN (SELECT COALESCE(SUBSTRING(LIBERA,78,1),'') FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS) = 'S' THEN 'TD05'   -- NOTA DI DEBITO 
--			ELSE 'TD??' 
--		END AS TIPODOCUMENTO,
		TT.ORD_TDXML AS TIPODOCUMENTO,
		SUBSTRING(TT.ORD_DATORD,1,4)+'-'+SUBSTRING(TT.ORD_DATORD,6,2)+'-'+SUBSTRING(TT.ORD_DATORD,9,2) AS DatiGeneraliDocumentoData,
		TT.ORD_NREGIS,
		TT.ORD_NUMORD AS DatiGeneraliDocumentoNumero,
		TT.ORD_VALUTA,
		TT.ORD_PARIVA,
		SUBSTRING(TT.ORD_RAGSOC,1,80) AS ORD_RAGSOC,
		--CASE RTRIM(TT.ORD_IDSDI)
		--	WHEN '' THEN (
		--		CASE SUBSTRING(TT.ORD_CODNAZ,1,2)
		--			WHEN 'IT' THEN '0000000' 
		--			ELSE 'XXXXXXX' 
		--		END) 
		--	ELSE RTRIM(TT.ORD_IDSDI)
		--END AS ORD_IDSDI,
		--TT.ORD_BANCA,
		TT.ORD_CODCLI,
		TT.ORD_RIFCDF,
		TT.ORD_CPA,
		TT.ORD_CAUS,
		TT.ORD_NUMORD,
		TT.ORD_DATORD,
		CASE SUBSTRING(TT.ORD_CODNAZ,1,2) WHEN 'IT' THEN 'IT' ELSE (SELECT RTRIM(LIBERA) FROM PARA WHERE CODICE = 'STA'+TT.ORD_CODNAZ) END AS ORD_IDPAESE,
		CAST('' AS TEXT) AS ALLEGATI,
		CASE RTRIM(TT.ORD_PROVIN) WHEN '' THEN '' ELSE ('<Provincia>'+RTRIM(TT.ORD_PROVIN)+'</Provincia>') END AS CEDENTEPRESTATORESEDEPROVINCIA,
		CASE SUBSTRING(TT.ORD_CODNAZ,1,2)
			WHEN 'IT' THEN 
				CASE
					WHEN RTRIM(TT.ORD_PARIVA) = RTRIM((SELECT FOR_PARIVA FROM U_FOR_AN WHERE FOR_CODCLI = TT.ORD_CODCLI)) THEN '<IdFiscaleIVA><IdPaese>IT</IdPaese><IdCodice>'+RTRIM(TT.ORD_PARIVA)+'</IdCodice></IdFiscaleIVA>'
					WHEN RTRIM(TT.ORD_PARIVA) = RTRIM((SELECT FOR_CODFIS FROM U_FOR_AN WHERE FOR_CODCLI = TT.ORD_CODCLI)) THEN '<CodiceFiscale>'+RTRIM(TT.ORD_PARIVA)+'</CodiceFiscale>'
					ELSE '<IdFiscaleIVA><IdPaese>IT</IdPaese><IdCodice>'+RTRIM(TT.ORD_PARIVA)+'</IdCodice></IdFiscaleIVA>'
				END
				ELSE '<IdFiscaleIVA><IdPaese>'+(SELECT RTRIM(LIBERA) FROM PARA WHERE CODICE = 'STA'+TT.ORD_CODNAZ)+'</IdPaese><IdCodice>' +
					CASE
						WHEN SUBSTRING(TT.ORD_PARIVA,1,2) = (SELECT LIBERA FROM PARA WHERE CODICE = 'STA'+TT.ORD_CODNAZ) THEN RTRIM(SUBSTRING(TT.ORD_PARIVA,3,18))
						ELSE RTRIM(TT.ORD_PARIVA)
					END + '</IdCodice></IdFiscaleIVA>'
		END AS CEDENTEPRESTATOREDATIANAGRAFICIIDFISCALEIVA,
		CASE
			WHEN TT.ORD_BOVIRT > 0 THEN ('<DatiBollo><BolloVirtuale>SI</BolloVirtuale><ImportoBollo>'+RTRIM(CAST(TT.ORD_BOVIRT AS VARCHAR(15)))+'</ImportoBollo></DatiBollo>')
			ELSE ''
		END AS DATIGENERALIDOCUMENTODATIBOLLOBOLLOVIRTUALE,
		--TT.ORD_NUMLEI,
		--TT.ORD_DATLEI,
		TT.ORD_CAMBIO,
		SPACE(50) AS DATIGENERALIDOCUMENTOARROTONDAMENTO
		--CAST(TT.ORD_FECAUS AS VARCHAR(254)) AS DATIGENERALIDOCUMENTOCAUSALE,
		--TT.ORD_NRPLEI,
		--TT.ORD_DTPLEI,
		--TT.ORD_NUMCOC,
		--TT.ORD_DATCOC
	FROM U_FAF_TT AS TT
	WHERE TT.TAGGANCIO='<<_TAGGANCIO>>'
	
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"HEADER_FATTURA_ELETTRONICA")
	return(.F.)
ENDIF

SELECT HEADER_FATTURA_ELETTRONICA
GO TOP

*SCAN
	
	**=> ERASMO - INIZIO 20/05/2022
	IF TYPE("PUB_CONTOSIMILCEE") == "L"
	ELSE
		PUB_CONTOSIMILCEE = .F.
	ENDIF
	
	IF !EMPTY(ORD_RIFCDF)  && FORNITORE DI RIFERIMENTO ALL'AUTOFATTURA
		x_soci = "FOR_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "FOR_CODCLI = '" + ORD_RIFCDF + "'"
		x_cond = x_soci + " and " + x_codi
		cSql = "select *,CASE SUBSTRING(U_FOR_AN.FOR_NAZION,1,2) WHEN 'IT' THEN 'IT' ELSE (SELECT RTRIM(LIBERA) FROM PARA WHERE CODICE = 'STA'+U_FOR_AN.FOR_NAZION) END AS FOR_IDPAESE from U_FOR_AN where " + x_cond
		IF !ExecCommand(cSql,"TMP_FOR_AN")
		   RETURN .F.
		ENDIF
		SELECT TMP_FOR_AN
		GO TOP
		IF !EOF()
			_ORD_RAGSOC 	= FOR_RAGSOC
			_ORD_INDIRI 	= FOR_INDIR
			_ORD_LOCALI 	= FOR_LOCALI
			_ORD_CAP		= FOR_CAP
			_CEDENTEPRESTATORESEDEPROVINCIA = FOR_PROVIN
			_ORD_IDPAESE	= FOR_IDPAESE
			_ORD_PARIVA		= IIF(_ORD_IDPAESE = "IT", FOR_PARIVA, FOR_IVACEE)
			IF SUBSTR(_ORD_PARIVA,1,2) = _ORD_IDPAESE
				_ORD_PARIVA = SUBSTR(TT.ORD_PARIVA,3,18)
			ENDIF			
			_CEDENTEPRESTATOREDATIANAGRAFICIIDFISCALEIVA = '<IdFiscaleIVA><IdPaese>'+RTRIM(_ORD_IDPAESE)+'</IdPaese><IdCodice>'+RTRIM(_ORD_PARIVA)+'</IdCodice></IdFiscaleIVA>'
			
			SELECT HEADER_FATTURA_ELETTRONICA
			REPLACE ORD_RAGSOC WITH _ORD_RAGSOC 
			REPLACE ORD_INDIRI WITH _ORD_INDIRI 
			REPLACE ORD_LOCALI WITH _ORD_LOCALI 
			REPLACE ORD_CAP WITH _ORD_CAP
			REPLACE CEDENTEPRESTATORESEDEPROVINCIA WITH _CEDENTEPRESTATORESEDEPROVINCIA
			REPLACE ORD_IDPAESE WITH _ORD_IDPAESE
			REPLACE CEDENTEPRESTATOREDATIANAGRAFICIIDFISCALEIVA WITH _CEDENTEPRESTATOREDATIANAGRAFICIIDFISCALEIVA
		ENDIF
	ENDIF
	SELECT HEADER_FATTURA_ELETTRONICA
	**=> ERASMO - FINE 20/05/2022
	
	IF !EMPTY(ALLTRIM(ORD_CAP))
		REPLACE CEDENTEPRESTATORESEDECAP WITH '<CAP>'+ALLTRIM(ORD_CAP)+'</CAP>'
	ELSE
		REPLACE CEDENTEPRESTATORESEDECAP WITH '<CAP>00000</CAP>'
	ENDIF
	
	REPLACE ORD_INDIRI WITH PARSE_STRING_XML(ORD_INDIRI)
	REPLACE ORD_LOCALI WITH PARSE_STRING_XML(ORD_LOCALI)
	REPLACE ORD_RAGSOC WITH PARSE_STRING_XML(ORD_RAGSOC)
	
	IF EMPTY(ORD_IDPAESE)
		MESSAGEBOX("Inserire il Codice Nazione per la fattura n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA,16,"Attenzione")
		_YES_CONTINUA = .F.
		RETURN .F.
	ENDIF
	IF EMPTY(ORD_RAGSOC)
		MESSAGEBOX("Inserire la Ragione Sociale per la fattura n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA,16,"Attenzione")
		_YES_CONTINUA = .F.
		RETURN .F.
	ENDIF
	IF EMPTY(ORD_INDIRI)
		MESSAGEBOX("Inserire l'Indirizzo per la fattura n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA,16,"Attenzione")
		_YES_CONTINUA = .F.
		RETURN .F.
	ENDIF
	IF EMPTY(ORD_CAP)
		MESSAGEBOX("Inserire il CAP per la fattura n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA,16,"Attenzione")
		_YES_CONTINUA = .F.
		RETURN .F.
	ENDIF
	IF EMPTY(ORD_LOCALI)
		MESSAGEBOX("Inserire la Localitŕ per la fattura n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA,16,"Attenzione")
		_YES_CONTINUA = .F.
		RETURN .F.
	ENDIF
	
	**=> ERASMO - INIZIO 27/05/2022
	*!*	Per le note di credito emesse dal C/P finalizzate a rettificare una fattura trasmessa in cui non č indicata
	*!*	l’imposta in quanto il debitore d’imposta č il C/C, quest’ultimo puň integrare la nota di credito
	*!*	ricevuta con il valore dell’imposta utilizzando la medesima tipologia di documento trasmessa allo
	*!*	SDI per integrare la prima fattura ricevuta (ossia nei casi in cui č prevista la trasmissione allo SDI di
	*!*	un documento integrativo o di un’autofattura con i codici da TD16 a TD19), indicando gli importi
	*!*	con segno negativo e non deve utilizzare il documento TD04. Analoga modalitŕ di trasmissione potrŕ
	*!*	essere adoperata per rettificare, in diminuzione, un precedente documento trasmesso con le Tipologie
	*!*	documento TD22 e TD23.
	SELECT HEADER_FATTURA_ELETTRONICA
	IF _NOTACC
		REPLACE ORD_VALORE WITH -1 * ORD_VALORE		
		REPLACE IMPORTOTOTALEDOCUMENTO WITH -1 * IMPORTOTOTALEDOCUMENTO
		REPLACE IMPORTO_PAGAMENTO WITH -1 * IMPORTO_PAGAMENTO
		REPLACE ORD_IMPONIB WITH -1 * ORD_IMPONIB
		REPLACE ORD_IMPOSTA WITH -1 * ORD_IMPOSTA
	ENDIF
	SELECT HEADER_FATTURA_ELETTRONICA
	**=> ERASMO - FINE 20/05/2022
	
GO TOP

