	SELECT
		CASE ORD_RIFNFF WHEN '' THEN ORD_NUMORD ELSE ORD_RIFNFF END AS DATIFATTURECOLLEGATEIDDOCUMENTO,
		CASE ORD_RIFDFF WHEN '' THEN REPLACE(ORD_DATOR2,'/','-') ELSE REPLACE(ORD_RIFDFF,'/','-') END AS DATIFATTURECOLLEGATEDATA
