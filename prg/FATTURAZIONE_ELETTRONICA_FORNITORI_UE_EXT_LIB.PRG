
********************************************************************************************************
PROCEDURE CREA_FATTURA_ELETTRONICA_FORNITORI_UE_EXT
*
* SINTASSI:
*
* CREA_FATTURA_ELETTRONICA('000001','2014',SYS(5)+SYS(2003)+'\FATTURE_ELETTRONICHE'
*
********************************************************************************************************
PARAMETERS _NUMERO_FATTURA,_ANNO_FATTURA,_DIRECTORY_DI_CREAZIONE,_TAGGANCIO,_NOTACC
   
LOCAL POSIZIONE_INIZIO_DETTAGLI,POSIZIONE_FINE_DETTAGLI,POSIZIONE_INIZIO_DDT,POSIZIONE_FINE_DDT
LOCAL POSIZIONE_INIZIO_ORDINE,POSIZIONE_FINE_ORDINE,POSIZIONE_INIZIO_RIEPILOGO_IVA,POSIZIONE_FINE_RIEPILOGO_IVA

IF PCOUNT()<5
	MESSAGEBOX("Parametri insufficienti per la creazione della fattura elettronica",48,"Attenzione")
	RETURN .f.
ENDIF

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT MOV_NREGIS FROM INDICE WHERE MOV_ANNO = '<<_ANNO_FATTURA>>' AND MOV_NUMPRO = '<<_TAGGANCIO>>'
ENDTEXT					&& FINE SCRITTURA QUERY
IF !ExecPreparedCommand(cSql,"TMP_INDICE")
	return(.F.)
ENDIF
SELECT TMP_INDICE
GO TOP
IF EOF()
	MESSAGEBOX("Registrazione contabile non trovata",16,"Attenzione")
	DO CHIUDI_CURSORI
	RETURN .F.
ENDIF
_cNumeroRegistrazione = ALLTRIM(TOGLI_CARATTERI_SPECIALI(ALLTRIM(MOV_NREGIS)))

IF FILE("fattura_elettronica_fornitore_ue_ext.xml")	  && Esiste il file? 
ELSE
	MESSAGEBOX("File fattura_elettronica_fornitore_ue_ext.xml non presente nella directory di AQUARIUS. Il file č necessario per creare le fatture elettroniche.";
		+CHR(13)+"Contattare assistenza",48,"Errore creazione XML fatturazione elettronica")

	DO CHIUDI_CURSORI
	
	RETURN .F.
ENDIF

WAIT WINDOWS "CREAZIONE FILE DI FATTURA ELETTRONICA IN CORSO..." NOWAIT

_YES_CONTINUA = .T.
_FORMATO_TRASMISSIONE = ""

DO CREA_CURSOR_HEADER_FATTURA_ELETTRONICA_FAF

DO CREA_CURSOR_DATI_AZIENDA_FAF

DO CREA_CURSOR_BODY_FATTURA_ELETTRONICA_FAF

*DO CREA_CURSOR_RIFERIMENTI_DDT_FAF

DO CREA_CURSOR_RIFERIMENTI_FAT_COLL_FAF

DO CREA_CURSOR_RIEPILOGO_IVA_FAF

DO CREA_CURSOR_DETTAGLI_PAGAMENTO_FAF

DO CONTROLLI_FORMALI

DO CONVERSIONE_IN_VALUTA_RIFERIMENTO_FAF

IF !_YES_CONTINUA
	DO CHIUDI_CURSORI_FAF
	WAIT CLEAR
	RETURN .F.
ENDIF

*** crea il file xml: per ora č vuoto e nei passi successivi vengono aggiunti i vari elementi
SELECT CU_AZIENDA
_PIVA=ALLTRIM(AZI_PIVA)
DO CASE
	CASE PUB_FEPROGR = 1  && Progressivo alfanumerico per nomenclatura file - Usa Numero fattura (NUMERO REGISTRAZIONE) ridotto a 5 caratteri
		*_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+"F"+PADL(SUBSTR(ALLTRIM(_cNumeroRegistrazione),1,4),5,'0')+".xml"
		*_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+"F"+PADL(SUBSTR(ALLTRIM(_cNumeroRegistrazione),1,5),5,'0')+".xml"  && ERASMO - 28/07/2022
		**=> ERASMO - INIZIO 06/07/2023
		IF LEN(ALLTRIM(_cNumeroRegistrazione)) >= 5
			_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+"F"+PADL(SUBSTR(ALLTRIM(_cNumeroRegistrazione),1,5),5,'0')+".xml"
		ELSE
			_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+"F"+PADL(SUBSTR(ALLTRIM(_cNumeroRegistrazione),1,4),4,'0')+".xml"
		ENDIF			
		**=> ERASMO - FINE 06/07/2023
		
	CASE PUB_FEPROGR = 2  && Progressivo alfanumerico per nomenclatura file - Usa codice random alfanumerico di 5 caratteri
		_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+RIGHT(SYS(2015),5)+".xml"
	
	OTHERWISE
		_FILE_FATTURA_XML = _DIRECTORY_DI_CREAZIONE+"\IT"+_PIVA+"_"+RIGHT(SYS(2015),5)+".xml"
ENDCASE


STRTOFILE("",_FILE_FATTURA_XML ,0)

_FATTURA_ELETTRONICA_COMPLETA=FILETOSTR("fattura_elettronica_fornitore_ue_ext.xml")

_FATTURA_ELETTRONICA_COMPLETA=SOSTITUISCE_CAMPI_CURSOR_SU_TESTO_FAF("CU_AZIENDA",_FATTURA_ELETTRONICA_COMPLETA)
_FATTURA_ELETTRONICA_COMPLETA=SOSTITUISCE_CAMPI_CURSOR_SU_TESTO_FAF("CU_AZIENDA_PB",_FATTURA_ELETTRONICA_COMPLETA)
_FATTURA_ELETTRONICA_COMPLETA=SOSTITUISCE_CAMPI_CURSOR_SU_TESTO_FAF("CU_AZIENDA_PC",_FATTURA_ELETTRONICA_COMPLETA)


**** FATTURE COLLEGATE
POSIZIONE_INIZIO_FAT_COLL	=ATC("<DatiFattureCollegate>",_FATTURA_ELETTRONICA_COMPLETA)
POSIZIONE_FINE_FAT_COLL		=ATC("</DatiFattureCollegate>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiFattureCollegate>")+1

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,1,POSIZIONE_INIZIO_FAT_COLL-1)
APPEND_XML_FILE_FAF("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)    

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_FAT_COLL,POSIZIONE_FINE_FAT_COLL-POSIZIONE_INIZIO_FAT_COLL+1)
APPEND_XML_FILE_FAF("RIFERIMENTI_FAT_COLL",_STRING_XML,_FILE_FATTURA_XML)


*!*	**** DDT
*!*	POSIZIONE_INIZIO_DDT	=ATC("<DatiDDT>",_FATTURA_ELETTRONICA_COMPLETA)
*!*	POSIZIONE_FINE_DDT		=ATC("</DatiDDT>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiDDT>")  

*!*	*!*	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,1,POSIZIONE_INIZIO_DDT-1)
*!*	*!*	APPEND_XML_FILE_FAF("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML )    

*!*	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_DDT,POSIZIONE_FINE_DDT-POSIZIONE_INIZIO_DDT)
*!*	APPEND_XML_FILE_FAF("RIFERIMENTI_DDT",_STRING_XML,_FILE_FATTURA_XML)
*!*	**** DDT

POSIZIONE_INIZIO_DETTAGLI	=ATC("<DettaglioLinee>",_FATTURA_ELETTRONICA_COMPLETA)
POSIZIONE_FINE_DETTAGLI		=ATC("</DettaglioLinee>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DettaglioLinee>")

*_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_DDT+1,POSIZIONE_INIZIO_DETTAGLI-POSIZIONE_FINE_DDT-1)
_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_FAT_COLL+1,POSIZIONE_INIZIO_DETTAGLI-POSIZIONE_FINE_FAT_COLL-1)
APPEND_XML_FILE_FAF("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_DETTAGLI,POSIZIONE_FINE_DETTAGLI-POSIZIONE_INIZIO_DETTAGLI)
APPEND_XML_FILE_FAF("FatturaElettronica",_STRING_XML,_FILE_FATTURA_XML)

**** RIEPILOGO IVA
POSIZIONE_INIZIO_RIEPILOGO_IVA	=ATC("<DatiRiepilogo>",_FATTURA_ELETTRONICA_COMPLETA)
POSIZIONE_FINE_RIEPILOGO_IVA	=ATC("</DatiRiepilogo>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiRiepilogo>")  

_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_RIEPILOGO_IVA,POSIZIONE_FINE_RIEPILOGO_IVA-POSIZIONE_INIZIO_RIEPILOGO_IVA)
APPEND_XML_FILE_FAF("RIEPILOGO_IVA",_STRING_XML,_FILE_FATTURA_XML)

SELECT DETTAGLI_PAGAMENTO
GO TOP
IF !EOF()
	POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO	=ATC("<DettaglioPagamento>",_FATTURA_ELETTRONICA_COMPLETA)
	POSIZIONE_FINE_DETTAGLIOPAGAMENTO	=ATC("</DettaglioPagamento>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DettaglioPagamento>")  

	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_RIEPILOGO_IVA,POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO-POSIZIONE_FINE_RIEPILOGO_IVA)
	APPEND_XML_FILE_FAF("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)

	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO,POSIZIONE_FINE_DETTAGLIOPAGAMENTO-POSIZIONE_INIZIO_DETTAGLIOPAGAMENTO)
	APPEND_XML_FILE_FAF("DETTAGLI_PAGAMENTO",_STRING_XML,_FILE_FATTURA_XML)
	
	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_DETTAGLIOPAGAMENTO)
	APPEND_XML_FILE_FAF("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)
ELSE
	POSIZIONE_FINE_DATIBENISERVIZI =ATC("</DatiBeniServizi>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiBeniServizi>")
	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_RIEPILOGO_IVA,POSIZIONE_FINE_DATIBENISERVIZI-POSIZIONE_FINE_RIEPILOGO_IVA)
	APPEND_XML_FILE_FAF("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)
	
	POSIZIONE_FINE_DATIPAGAMENTO =ATC("</DatiPagamento>",_FATTURA_ELETTRONICA_COMPLETA)+LEN("</DatiPagamento>") 
	_STRING_XML=SUBSTR(_FATTURA_ELETTRONICA_COMPLETA,POSIZIONE_FINE_DATIPAGAMENTO)
	APPEND_XML_FILE_FAF("HEADER_FATTURA_ELETTRONICA",_STRING_XML,_FILE_FATTURA_XML)
ENDIF

x_agga = "MOV_NUMPRO = '" + _TAGGANCIO + "'"
x_cond = x_agga
cSql   = "UPDATE INDICE SET MOV_FILEXML = '" + ALLTRIM(_FILE_FATTURA_XML) + "' where " + x_cond
IF !ExecCommand(cSql,'UPD_FAF_TT')
   return(.f.)
ENDIF

WAIT WINDOW "CREAZIONE FATTURA ELETTRONICA FORNITORE "+_FILE_FATTURA_XML+" TERMINATA CORRETTAMENTE" TIMEOUT 1

DO CHIUDI_CURSORI_FAF

RETURN .T.

* FINE PROCEDURE CREA_FATTURA_ELETTRONICA
***************************************


