*!*		      V_BANAP = ALLTRIM(V_IBANFOR)	&& >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> IBAN BANCA NOSTRA DA ANAGRAFICA CLIENTE U_CLI_AN
*!*		      *IF EMPTY(ALLTRIM(V_CODICE_SWIFT)) 
*!*		      *ELSE
*!*		      *   V_BANAP = V_BANAP + '  -  BIC/SWIFT : ' + ALLTRIM(V_CODICE_SWIFT)
