******************************************************************************
PROCEDURE CREA_CURSOR_BODY_FATTURA_ELETTRONICA_FAF
******************************************************************************
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY DD.ORD_SEQUEN)) AS NUMERIC(10,0)) AS NR_RIGA,
		DD.ORD_QTAORD,
		'ART' AS CODICE_TIPO,
		--DD.ORD_CODART AS CODICE_VALORE,
		--DD.ORD_CODART AS ORD_CODART,
		--DD.ORD_DESART AS ORD_DESART,
		CASE DD.ORD_CDAPRD WHEN '' THEN DD.ORD_CODART ELSE DD.ORD_CDAPRD END AS CODICE_VALORE,  -- ERASMO - 02/08/2022
		CASE DD.ORD_CODART WHEN '' THEN DD.ORD_CODART ELSE DD.ORD_CDAPRD END AS ORD_CODART,  -- ERASMO - 02/08/2022
		CASE DD.ORD_DSAPRD WHEN '' THEN DD.ORD_DESART ELSE DD.ORD_DSAPRD END AS ORD_DESART,  -- ERASMO - 02/08/2022
		DD.ORD_PREZZO AS ORD_PREZZO,
		DD.ORD_PRZNET AS ORD_PRZNET,
		DD.ORD_VALORE AS ORD_VALORE,
		CASE RTRIM(LTRIM(SUBSTRING(IVA.LIBERA,1,3)))
			WHEN '' THEN 0.00
			ELSE COALESCE(CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC(6,2)),0.00)
		END AS DettaglioLineeAliquotaIVA,
		CASE RTRIM(LTRIM(SUBSTRING(IVA.LIBERA,1,3)))
			WHEN '' THEN '<Natura>'+RTRIM(SUBSTRING(IVA.LIBERA,145,4))+'</Natura>'
			ELSE CASE WHEN CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC (3,0)) = 0 THEN '<Natura>'+RTRIM(SUBSTRING(IVA.LIBERA,145,4))+'</Natura>' ELSE '' END
		END AS DETTAGLIOLINEENATURAIVA,
		--SUBSTRING(IVA.LIBERA,1,3),
		CAST('' AS VARCHAR(100)) AS DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE,
		SPACE(254) AS DETTAGLIOLINEETIPOCESSIONEPRESTAZIONE,
		DD.ORD_IVA
	FROM U_FAF_DD AS DD
	LEFT OUTER JOIN U_FAF_TT AS TT
	ON DD.DAGGANCIO=TT.TAGGANCIO
	LEFT OUTER JOIN PARA AS IVA
	ON 'IVA'+DD.ORD_IVA = IVA.CODICE
	LEFT OUTER JOIN U_ART_PR AS PR
	ON DD.ORD_CODART = PR.ART_CODPRI
	WHERE TT.TAGGANCIO='<<_TAGGANCIO>>'
	ORDER BY DD.ORD_SEQUEN

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"FatturaElettronica")
	return(.F.)
ENDIF

SELECT FatturaElettronica
INDEX ON NR_RIGA TAG I_NR_RIGA

SELECT FatturaElettronica
GO TOP
SCAN
	_ORD_DESART = ALLTRIM(ORD_DESART)
	_ORD_DESART = PARSE_STRING_XML(_ORD_DESART)
	REPLACE ORD_DESART WITH _ORD_DESART
	IF !EMPTY(ALLTRIM(DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE))
		REPLACE DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE WITH '<RiferimentoAmministrazione>'+PARSE_STRING_XML(ALLTRIM(DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE))+'</RiferimentoAmministrazione>'
	ELSE
		REPLACE DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE WITH ""
	ENDIF
ENDSCAN
GO TOP

RETURN
* FINE PROCEDURE CREA_CURSOR_BODY_FATTURA_ELETTRONICA_FAF
******************************************************************************


