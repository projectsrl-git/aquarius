RIT = MESSAGEBOX("Procedo con il completamento delle anagrafice clienti fornitori da CARD_CLIFO ?",292,"ATTENZIONE")
IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF



**** =CREA_TABELLA_ZONE()

*** ELABORA CARD_CLIFO
_TOT_COUNT = 0
cSql = "SELECT * FROM CARD_CLIFO ORDER BY CODICE"
IF !ExecCommand(cSql,"CX_CARD_CLIFO")
	RETURN .F.
ENDIF
SELECT CX_CARD_CLIFO
GO TOP
SCAN

	WAIT WINDOWS "Completa anagrafica clienti/fornitori " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + ;
		" (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 
		
	SCATTER MEMVAR


 
	DO CASE 

		CASE M.TIPO = 'C'

			=ELABORA_CARD_CFVEN()
			=AGGIORNA_ANAGRAFICA_CLIENTI()
		
		CASE M.TIPO = 'F'
	
			=ELABORA_CARD_CFVEN()
			=AGGIORNA_ANAGRAFICA_FORNITORI()	

	
	ENDCASE
	
	
	
	_TOT_COUNT = _TOT_COUNT + 1

ENDSCAN


WAIT CLEAR

MESSAGEBOX("Operazione terminata correttamente" + REPLICATE(CHR(13),2) + ;
	"Totale Clienti/Fornitori elaborati: " + ALLTRIM(STR(_TOT_COUNT,10,0)),64,"Informazione")

RETURN


***************************
FUNCTION ELABORA_CARD_CFVEN
***************************



RELEASE M.ZONA,M.CODPORTO,M.MOD_SPEDI,M.NUM_LETT,M.DATA_ARRIV,M.NUMLETT,M.DATA_LETT,M.CCOSTO,M.FATIVASOSP,M.CLI_SOSIMP,M.SC_COSTO,M.SC_RICAVO
PUBLIC M.ZONA,M.CODPORTO,M.MOD_SPEDI,M.NUM_LETT,M.DATA_ARRIV,M.NUMLETT,M.DATA_LETT,M.CCOSTO,M.FATIVASOSP,M.CLI_SOSIMP,M.SC_COSTO,M.SC_RICAVO
  
RELEASE M.CODABIPR,M.CODCABPR,M.CONTCORR,M.CIN,M.BIC,M.CODIBAN,M.E_MAILL,M.ASSFIS,M.ASSFIS_ORIGINALE 	
PUBLIC M.CODABIPR,M.CODCABPR,M.CONTCORR,M.CIN,M.BIC,M.CODIBAN,M.E_MAILL,M.ASSFIS,M.ASSFIS_ORIGINALE 
 
 
x_codi  = "codcf = '" + CONV_CLEAR(M.CODICE) + "'"  
cSql="SELECT * FROM CARD_CFVEN WHERE " + x_codi + " order by codcf"
IF !ExecCommand(cSql,"CARD_CFVEN_CU")
	RETURN .F.
ENDIF
SELECT CARD_CFVEN_CU
GO TOP
IF !EOF()

    IF 	!ISNULL(ASSFIS)
  	    M.ASSFIS        	= ALLTRIM(CARDIOLINE_DECODIFICA_CODICE_IVA(ASSFIS))
        M.ASSFIS_ORIGINALE 	= ASSFIS
    ELSE
    	M.ASSFIS        	= PUB_IVA
        M.ASSFIS_ORIGINALE 	= PUB_IVA
    ENDIF

    M.E_MAILL       = LOWER(CONV_CLEAR(E_MAILL))
	M.CODABIPR		= CONV_CLEAR(CODABIPR)
	M.CODCABPR		= CONV_CLEAR(CODCABPR)
	M.CONTCORR		= CONV_CLEAR(CONTCORR)
	M.CIN			= CONV_CLEAR(CIN)
	M.BIC			= CONV_CLEAR(BIC)
	M.CODIBAN		= CONV_CLEAR(CODIBAN)

    M.SC_COSTO      = CONV_CLEAR(SC_COSTO)
    M.SC_RICAVO     = CONV_CLEAR(SC_RICAVO)
    M.FATIVASOSP    = CONV_CLEAR(FATIVASOSP)
    M.CCOSTO        = CONV_CLEAR(CCOSTO)
	M.ZONA 			= CONV_CLEAR(ZONA)
	M.CODPORTO		= CONV_CLEAR(CODPORTO)
	M.MOD_SPEDI		= CONV_CLEAR(MOD_SPEDI)
	IF ISNULL(NUM_LETT)
		_NUM_LETT		= 0
	ELSE
		_NUM_LETT		= NUM_LETT
	ENDIF 
	_DATA_ARRIV		= CONV_CLEAR(DATA_ARRIV)
	IF ISNULL(NUMLETT)
		_NUMLETT		= ''
	ELSE
		_NUMLETT		= NUMLETT
	ENDIF 
	_DATA_LETT		= CONV_CLEAR(DATA_LETT)
ELSE

    M.ASSFIS        	= ""
    M.ASSFIS_ORIGINALE 	= "" 
    M.E_MAILL       	= ""
	M.CODABIPR			= ""
	M.CODCABPR			= ""
	M.CONTCORR			= ""
	M.CIN				= ""
	M.BIC				= ""
	M.CODIBAN			= ""

    M.FATIVASOSP    	= ""
    M.SC_COSTO      	= ""
    M.SC_RICAVO     	= ""
    M.CCOSTO        	= ""
	M.ZONA 				= "1"
	M.CODPORTO			= "EXW"
	M.MOD_SPEDI			= "STR"
	_NUM_LETT			= 0
	_DATA_ARRIV			= ""
	_NUMLETT			= ''
	_DATA_LETT			= ""
ENDIF

DO CASE

	CASE ALLTRIM(M.MOD_SPEDI) = 'AER'
		M.MOD_SPEDI = 'A'

	CASE ALLTRIM(M.MOD_SPEDI) = 'AMA'
		M.MOD_SPEDI = 'E'

	CASE ALLTRIM(M.MOD_SPEDI) = 'FER'
		M.MOD_SPEDI = 'F'

	CASE ALLTRIM(M.MOD_SPEDI) = 'NAV'
		M.MOD_SPEDI = 'N'

	CASE ALLTRIM(M.MOD_SPEDI) = 'POS'
		M.MOD_SPEDI = 'P'

	CASE ALLTRIM(M.MOD_SPEDI) = 'STR'
		M.MOD_SPEDI = 'S'

	OTHERWISE
		M.MOD_SPEDI = 'S'

ENDCASE 


IF	_NUM_LETT	= 0
	M.NUM_LETT = ''
ELSE
	M.NUM_LETT = STR(_NUM_LETT,8,0)
ENDIF

IF	EMPTY(_DATA_ARRIV)	
	M.DATA_ARRIV = ""
ELSE
	M.DATA_ARRIV = 	_DATA_ARRIV
ENDIF

IF	_NUMLETT	= ''
	M.NUMLETT = ''
ELSE
	M.NUMLETT = _NUMLETT
ENDIF

IF	EMPTY(_DATA_LETT)	
	M.DATA_LETT= ""
ELSE
	M.DATA_LETT = 	_DATA_LETT
ENDIF


IF 	EMPTY(M.CODPORTO)
	M.CODPORTO		= "EXW"
ENDIF


IF EMPTY(M.ZONA)
	M.ZONA 			= "1"
ENDIF

IF M.FATIVASOSP = 'S'
	M.CLI_SOSIMP = 'FVS'		&& SOSPENSIONE IVA
ELSE
	M.CLI_SOSIMP = ''		
ENDIF


RETURN

*************************************
FUNCTION AGGIORNA_ANAGRAFICA_CLIENTI
*************************************
  
 
x_codi  = "cli_codcli = '" + CONV_CLEAR(M.CODICE) + "'"  
cSql="SELECT * FROM U_CLI_AN WHERE " + x_codi + " order by CLI_CODCLI"
IF !ExecRW(cSql,"U_CLI_AN","R")
   RETURN .F.
ENDIF

__CODPAG = ALLTRIM(CARDIOLINE_DECODIFICA_CODICE_CPA(CONV_CLEAR(M.CODPAG)))



SELECT U_CLI_AN
IF !EOF()
  
	REPLACE CLI_VALUTA 	WITH IIF(CONV_CLEAR(M.CODVAL) <> '',CONV_CLEAR(M.CODVAL),'EUR') 
	REPLACE CLI_CONPAG 	WITH IIF(__CODPAG  <> '',__CODPAG,PUB_CPA) 
	***REPLACE CLI_ZONA 	WITH M.ZONA
	REPLACE CLI_PORTO 	WITH M.CODPORTO
	REPLACE CLI_CLIES  	WITH M.NUM_LETT 
	=CAMBIADT(M.DATA_ARRIV,"CLI_DTCLES")
	REPLACE CLI_NSES   	WITH M.NUMLETT
	=CAMBIADT(M.DATA_LETT,"CLI_DTNSES")
    REPLACE CLI_CCOST1 	WITH M.CCOSTO 
    REPLACE CLI_SOSIMP 	WITH M.CLI_SOSIMP 
    REPLACE CLI_RICERC 	WITH  CONV_CLEAR(M.NOMEBREVE)
    REPLACE CLI_CONTO1 	WITH M.SC_RICAVO		&& CONTO CONTABILE
    REPLACE CLI_EMAIL   WITH M.E_MAILL
    REPLACE CLI_CODIVA  WITH M.ASSFIS   
    =VERIFICA_ESISTENZA_IVA_IN_PARA(CLI_CODIVA,M.ASSFIS_ORIGINALE)

    _ZONA=VERIFICA_ESISTENZA_STA_IN_PARA(CLI_NAZION)
	REPLACE CLI_ZONA 	WITH _ZONA


    __RIBA=CERCA_RIBA(CLI_CONPAG)
    SELECT U_CLI_AN

   
    
    IF __RIBA
    
		REPLACE CLI_BAE			WITH ALLTRIM(M.CODABIPR)+ ALLTRIM(M.CODCABPR)  
		REPLACE CLI_CODCHE		WITH SUBSTR(M.CODIBAN,3,2)  
		REPLACE CLI_CODCIN		WITH ALLTRIM(M.CIN)  
		REPLACE CLI_CODABI		WITH ALLTRIM(M.CODABIPR)  
		REPLACE CLI_CODCAB		WITH ALLTRIM(M.CODCABPR)  
		REPLACE CLI_NUMCC		WITH ALLTRIM(M.CONTCORR)  
		REPLACE CLI_CDIBAN		WITH ALLTRIM(M.CODIBAN)  

    ELSE
    
		REPLACE CLI_BAEFOR		WITH ALLTRIM(M.CODABIPR)+ ALLTRIM(M.CODCABPR)  
		REPLACE CLI_CHEFOR		WITH SUBSTR(M.CODIBAN,3,2)  
		REPLACE CLI_CINFOR		WITH ALLTRIM(M.CIN)  
		REPLACE CLI_ABIFOR		WITH ALLTRIM(M.CODABIPR)  
		REPLACE CLI_CABFOR		WITH ALLTRIM(M.CODCABPR)  
		REPLACE CLI_NCCFOR		WITH ALLTRIM(M.CONTCORR)  
		REPLACE CLI_IBAFOR		WITH ALLTRIM(M.CODIBAN)  
		REPLACE CLI_BSWFOR		WITH ALLTRIM(M.BIC)  
    
    ENDIF
    


ENDIF 

IF !ExecRW('','U_CLI_AN','W','','U_CLI_AN')
   return(.f.)
ENDIF


x_codi  = "cli_codcli = '" + CONV_CLEAR(M.CODICE) + "'"  
cSql="SELECT * FROM U_ANA_CL WHERE " + x_codi + " order by CLI_CODCLI"
IF !ExecRW(cSql,"U_ANA_CL","R")
   RETURN .F.
ENDIF

SELECT U_ANA_CL
IF !EOF()

	REPLACE CLI_TISPE WITH M.MOD_SPEDI
 
ENDIF 

IF !ExecRW('','U_ANA_CL','W','','U_ANA_CL')
   return(.f.)
ENDIF



RETURN


**************************************
FUNCTION AGGIORNA_ANAGRAFICA_FORNITORI
**************************************


*!*	IF CONV_CLEAR(M.CODICE) = '410160910'
*!*		SET STEP ON 
*!*	ENDIF 
  
x_codi  = "for_codcli = '" + CONV_CLEAR(M.CODICE) + "'"  
cSql="SELECT * FROM U_for_AN WHERE " + x_codi + " order by for_CODCLI"
IF !ExecRW(cSql,"U_for_AN","R")
   RETURN .F.
ENDIF

__CODPAG = CARDIOLINE_DECODIFICA_CODICE_CPA(CONV_CLEAR(M.CODPAG))


SELECT U_for_AN
IF !EOF()


	REPLACE FOR_VALUTA 	WITH IIF(CONV_CLEAR(M.CODVAL) <> '',CONV_CLEAR(M.CODVAL),'EUR') 
	REPLACE FOR_CONPAG 	WITH IIF(__CODPAG  <> '',__CODPAG,PUB_CPA) 
	****REPLACE FOR_ZONA 	WITH M.ZONA
	REPLACE FOR_PORTO 	WITH M.CODPORTO
	REPLACE FOR_TISPE 	WITH M.MOD_SPEDI
	REPLACE FOR_CLIES  	WITH M.NUM_LETT 
	=CAMBIADT(M.DATA_ARRIV,"FOR_DTCLES")
	REPLACE FOR_NSES  	WITH M.NUMLETT
	=CAMBIADT(M.DATA_LETT,"FOR_DTNSES")
    REPLACE FOR_CCOST1 	WITH M.CCOSTO 		&& CENTRO DI COSTO
    REPLACE FOR_CONTO1 	WITH M.SC_COSTO		&& CONTO CONTABILE
    REPLACE FOR_EMAIL  	WITH M.E_MAILL
    REPLACE FOR_CODIVA  WITH M.ASSFIS   
    =VERIFICA_ESISTENZA_IVA_IN_PARA(FOR_CODIVA,M.ASSFIS_ORIGINALE)


	REPLACE FOR_COSATRATTA 		WITH  ALLTRIM(PUB_COSATRATTA)
	REPLACE FOR_GRADOIMPORTANZA WITH  ALLTRIM(PUB_GRADOIMPORTANZA)
	REPLACE FOR_FORMAPAGAMENTO 	WITH  ALLTRIM(PUB_FORMAPAGAMENTO)
    REPLACE FOR_TIPOCONTRATTO 	WITH  ALLTRIM(PUB_TIPOCONTRATTO)
	REPLACE FOR_CODACQ 			WITH  ALLTRIM(PUB_CONAQUISTO)	
	REPLACE FOR_PRIPAGA 		WITH  ALLTRIM(PUB_PRIORITAPAGAMENTO)	
    REPLACE FOR_RICERC 			WITH  CONV_CLEAR(M.NOMEBREVE)

    _ZONA=VERIFICA_ESISTENZA_STA_IN_PARA(FOR_NAZION)
	REPLACE FOR_ZONA 	WITH _ZONA


    __RIBA=CERCA_RIBA(FOR_CONPAG)
    SELECT U_FOR_AN
    
    IF __RIBA
    
		REPLACE FOR_BAE			WITH ALLTRIM(M.CODABIPR)+ ALLTRIM(M.CODCABPR)  
		REPLACE FOR_CODCHE		WITH SUBSTR(M.CODIBAN,3,2)  
		REPLACE FOR_CODCIN 		WITH ALLTRIM(M.CIN)  
		REPLACE FOR_CODABI		WITH ALLTRIM(M.CODABIPR)  
		REPLACE FOR_CODCAB		WITH ALLTRIM(M.CODCABPR)  
		REPLACE FOR_NUMCOC		WITH ALLTRIM(M.CONTCORR)  
		*REPLACE FOR_BIC			WITH ALLTRIM(M.BIC)  
		REPLACE FOR_CDIBAN		WITH ALLTRIM(M.CODIBAN)  

    ELSE
    
		REPLACE FOR_BA2			WITH ALLTRIM(M.CODABIPR)+ ALLTRIM(M.CODCABPR)  
		REPLACE FOR_BA2CHK		WITH SUBSTR(M.CODIBAN,3,2)  
		REPLACE FOR_BA2CIN		WITH ALLTRIM(M.CIN)  
		REPLACE FOR_BA2ABI		WITH ALLTRIM(M.CODABIPR)  
		REPLACE FOR_BA2CAB		WITH ALLTRIM(M.CODCABPR)  
		REPLACE FOR_BA2CC		WITH ALLTRIM(M.CONTCORR)  
		*REPLACE FOR_BIC			WITH ALLTRIM(M.BIC)  
		REPLACE FOR_BA2IBA		WITH ALLTRIM(M.CODIBAN)  
    
    ENDIF
    
    
    

ENDIF 

IF !ExecRW('','U_for_AN','W','','U_for_AN')
   return(.f.)
ENDIF



RETURN



*******************************************
FUNCTION VERIFICA_ESISTENZA_STA_IN_PARA
*******************************************
LPARAMETERS _CODNAZ__

*!*	IF _CODNAZ__ = 'BEG'
*!*	SET STEP ON 
*!*	ENDIF

AABBCCS    = SELECT()

x_cond = "CODICE = 'STA" + ALLTRIM(_CODNAZ__) + "'"
cSql = "SELECT * FROM PARA WHERE " + x_cond
IF !ExecCommand(cSql,"PARA")
	RETURN .F.
ENDIF
SELECT PARA
GO TOP
IF !EOF()
	_ZONA___ = ALLTRIM(LIBERA)
ELSE
	_ZONA___ = ""
ENDIF



SELECT(AABBCCS)

RETURN (_ZONA___)



*******************************************
FUNCTION VERIFICA_ESISTENZA_IVA_IN_PARA
*******************************************
LPARAMETERS _CODIVA__,_CODIVA__ORIGINALE__

AABBCCS    = SELECT()

x_cond = "CODICE = 'IVA" + ALLTRIM(_CODIVA__) + "'"
cSql = "SELECT * FROM PARA WHERE " + x_cond
IF !ExecRW(cSql,"PARA","R")
	RETURN .F.
ENDIF
SELECT PARA
GO TOP
IF EOF()

	** ACCEASSO A CARD_TABIVA PER PRELEVARE LE INFORMAZIONI DEL CODICE IVA MANCANTE

    x_cond = "CODICE = '" + ALLTRIM(_CODIVA__ORIGINALE__) + "'"
	cSql = "SELECT * FROM CARD_TABIVA WHERE " + x_cond
	IF !ExecCommand(cSql,"CX_CARD_TABIVA")
		RETURN .F.
	ENDIF
	SELECT CX_CARD_TABIVA
	GO TOP	
	IF !EOF()
		M.DESCRIZION = CONV_CLEAR(APITOSPA(ALLTRIM(DESCRIZION)))
	    _CONTO_CLI = "44010001" && DA 6 PER 13
	    _CONTO_FOR = "12040001" && DA 29 PER 13
	   	M.LIBERA	=""
		M.LIBERA1 	=ALLTRIM(STR(PERCENTIVA,3,0)) && PERCENTUALE IVA
		
		IF LEN(M.LIBERA1) = 1
			M.LIBERA1 = "00"+M.LIBERA1
		ENDIF

		IF LEN(M.LIBERA1) = 2
			M.LIBERA1 = "0"+M.LIBERA1
		ENDIF
        
	    LEN_LIBERA  =LEN(M.LIBERA1)
	    M.LIBERA3   =M.LIBERA1+REPLICATE("_" ,(5-LEN_LIBERA))+_CONTO_CLI 

	    LEN_LIBERA  =LEN(M.LIBERA3)
	    M.LIBERA4   =M.LIBERA3+REPLICATE("_" ,(28-LEN_LIBERA))+_CONTO_FOR
	    M.LIBERA4   =STRTRAN(M.LIBERA4,"_"," ")
	    M.LIBERA4   =ALLTRIM(M.LIBERA4)
		
	    *004  2092201                1011101________________________________________________________________I         100 
	    IF PERCDETRAZ > 0		
	    	IF PERCDETRAZ = 100
	    		M.LIBERA     = M.LIBERA4
	    	ELSE					&& IVA INDEDUCIBILE
			    LEN_LIBERA   = LEN(M.LIBERA4)
			    M.LIBERA5    = M.LIBERA4+REPLICATE("_" ,(99-LEN_LIBERA))+"I         "+STR(PERCDETRAZ,3,0)
			    M.LIBERA5    = STRTRAN(M.LIBERA5,"_"," ")
		        M.LIBERA5    = ALLTRIM(M.LIBERA5)	    
			    M.LIBERA     = M.LIBERA5
			ENDIF
		ELSE
		    M.LIBERA     	 = M.LIBERA4
	    ENDIF
			
		
	ELSE
		M.DESCRIZION = "CODICE IVA DA VERIFICARE *********"
	    _CONTO_CLI  = "44010001" && DA 6 PER 13
	    _CONTO_FOR  = "12040001" && DA 29 PER 13
	   	M.LIBERA	= ""
	   	_PERCENTIVA = 22
		M.LIBERA1 	= ALLTRIM(STR(_PERCENTIVA,3,0)) && PERCENTUALE IVA
		IF LEN(M.LIBERA1) = 1
			M.LIBERA1 = "00"+M.LIBERA1
		ENDIF
		IF LEN(M.LIBERA1) = 2
			M.LIBERA1 = "0"+M.LIBERA1
		ENDIF
 	    LEN_LIBERA  =LEN(M.LIBERA1)
	    M.LIBERA3   =M.LIBERA1+REPLICATE("_" ,(5-LEN_LIBERA))+_CONTO_CLI 
	    LEN_LIBERA  =LEN(M.LIBERA3)
	    M.LIBERA4   =M.LIBERA3+REPLICATE("_" ,(28-LEN_LIBERA))+_CONTO_FOR
	    M.LIBERA4   =STRTRAN(M.LIBERA4,"_"," ")
	    M.LIBERA4   =ALLTRIM(M.LIBERA4)
		M.LIBERA    =M.LIBERA4	
	
	ENDIF

    ** CREA TABELLA IVA MANCANTE
    SELECT PARA
	APPEND BLANK
	REPLACE CODICE WITH "IVA" + ALLTRIM(_CODIVA__)
	REPLACE DESCRI WITH ALLTRIM(M.DESCRIZION)
	REPLACE LIBERA WITH M.LIBERA
	REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))





ENDIF



IF !ExecRW(cSql,"PARA","W")
	RETURN .F.
ENDIF



SELECT(AABBCCS)

RETURN




**************************
FUNCTION CREA_TABELLA_ZONE
**************************

*WAIT WINDOWS "ATTENDERE PREGO, CANCELLAZIONE VECCHIA TABELLA ZONE" NOWAIT
cSql = "delete from PARA where CODICE LIKE 'ZON%' "
IF !ExecCommand(cSql,"PARA")
   return(.f.)
ENDIF

*** AGGIORNAMENTO TABELLA DELLE ZONE
_TOT_COUNT = 0
cSql = "SELECT * FROM CARD_TAZOCO ORDER BY CODICE"
IF !ExecCommand(cSql,"CX_CARD_TAZOCO")
	RETURN .F.
ENDIF
SELECT CX_CARD_TAZOCO
GO TOP
SCAN

	SCATTER MEMVAR

	x_codi = "CODICE = 'ZON" + SUBSTR(M.CODICE,1,1) + "'"
	x_cond = x_codi
	cSql = "SELECT * FROM PARA WHERE " + x_cond
	IF !ExecRW(cSql,"PARA","R")
		RETURN .F.
	ENDIF
	SELECT PARA
	GO TOP
	IF EOF()
		APPEND BLANK
		REPLACE CODICE WITH "ZON" + SUBSTR(M.CODICE,1,1)
		REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))
	ENDIF
	
	REPLACE DESCRI WITH ALLTRIM(M.DESCRIZION)
	REPLACE LIBERA WITH ""
	
	IF !ExecRW(cSql,"PARA","W")
		RETURN .F.
	ENDIF
	
	SELECT CX_CARD_TAZOCO
		
ENDSCAN




RETURN


********************
FUNCTION CERCA_RIBA
********************
PARA  _CPAX

SCPAS=SELECT()

v_seek	 = 'CPA'+_CPAX
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   IF SUBSTR(LIBERA,10,1) = "X"
      _RIBA_ = .T.
   ELSE
      _RIBA_ = .F.   
   ENDIF
ELSE
   _RIBA_ = .F.   
ENDIF

SELECT(SCPAS)
RETURN(_RIBA_)





