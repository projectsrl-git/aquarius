
LPARAMETERS _par_directory

_SCREEN.Visible = .F.

IF PCOUNT() = 0
	WAIT windows "Parametro Directory non passato" TIMEOUT 2
	RETURN .F.
ENDIF

IF EMPTY(_par_directory)
	WAIT windows "Parametro Directory non valido" TIMEOUT 2
	RETURN .F.
ELSE
	IF !DIRECTORY(_par_directory,1)
		WAIT windows "Parametro Directory non valido" TIMEOUT 2
		RETURN .F.
	ENDIF
ENDIF

