_FILE_AMBIENTE_PRODUZIONE = "__AMBIENTEPROD__"

IF !FILE(_FILE_AMBIENTE_PRODUZIONE)
	*** MOSTRA SEMPRE TUTTI GLI ERRORI
ELSE
	*** SCRITTURA FILE DI LOG ERRORI SOLO SE APPOSITO FILE PRESENTE, ALTRIMENTI NON SCRIVE GLI ERRORI
	_FILE_ATTIVA_SCRITTURA_LOG = SYS(5)+SYS(2003)+'\'+"__MESSERROLOG__"
	IF FILE(_FILE_ATTIVA_SCRITTURA_LOG)
