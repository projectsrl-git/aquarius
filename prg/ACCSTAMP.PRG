*************************************************************
* PROGRAMMA DI ESTRAZIONE DATI PER STAMPA MODULO DI ACCONTO *
*************************************************************

RELEASE XXX_ACCONT,XXX_NUMSCO,XXX_CODCLI,XXX_RAGSOC,XXX_TELEFO,XXX_EMAIL,XXX_CODART,  ;
        XXX_DESART,XXX_QTAORD,XXX_PRZNET,XXX_AUTORE,XXX_EDITOR,XXX_CODIVA,XXX_ACCRES, ;
        XXX_QTAACC
PUBLIC  XXX_ACCONT,XXX_NUMSCO,XXX_CODCLI,XXX_RAGSOC,XXX_TELEFO,XXX_EMAIL,XXX_CODART,  ;
        XXX_DESART,XXX_QTAORD,XXX_PRZNET,XXX_AUTORE,XXX_EDITOR,XXX_CODIVA,XXX_ACCRES, ;
        XXX_QTAACC
XXX_ACCONT = 0
XXX_NUMSCO = ""
XXX_CODCLI = ""
XXX_RAGSOC = ""
XXX_TELEFO = ""
XXX_EMAIL  = ""
XXX_CODART = ""
XXX_DESART = ""
XXX_QTAORD = 0
XXX_PRZNET = 0
XXX_AUTORE = ""
XXX_EDITOR = ""
XXX_CODIVA = ""
XXX_ACCRES = 0
XXX_QTAACC = 0

* CREO CURSORE PER RACCOLTA DATI
CREATE CURSOR CUR_STAMPA ;
  (STM_CODART C(30), STM_DESART C(40), STM_QTAORD N(10,2), STM_PRZNET N(17,6), ;
   STM_CODIVA C(03), STM_QTAACC N(10,2))
   
* PRELEVO DATI PER STAMPA
SELECT CU_ORD_DD
GO TOP

x_soci = "ord_codsoc = '" + PUB_CODSOC + "'"
x_tagg = "taggancio = '" + DAGGANCIO + "'"
x_cond = x_soci + " and " + x_tagg
cSql   = "select * from u_ord_tt where " + x_cond + " order by ord_codsoc,taggancio"
IF !ExecCommand(cSql,"CUR_TESTATA")
   RETURN .F.
ENDIF 
SELECT CUR_TESTATA
GO TOP
IF !EOF()
   XXX_NUMORD = ORD_NUMORD
   XXX_ACCONT = ORD_ACCONT
   XXX_DATACC = ORD_DATACC
   XXX_NUMSCO = ORD_NUMSCO
   XXX_CODCLI = ORD_CODCLI   
   XXX_RAGSOC = ORD_RAGSOC
   XXX_ACCRES = ORD_ACCRES
ENDIF

SELECT CU_ORD_DD
GO TOP

DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   
   SCATTER MEMVAR MEMO
      
   XXX_CODART = M.ORD_CODART
   XXX_DESART = M.ORD_DESART
   XXX_QTAORD = M.ORD_QTAORD
   XXX_QTAACC = M.ORD_QTAACC
   XXX_PRZNET = M.ORD_PRZNET
   XXX_CODIVA = M.ORD_IVA
      
   SELECT CUR_STAMPA
   APPEND BLANK
   REPLACE STM_CODART WITH XXX_CODART
   REPLACE STM_DESART WITH XXX_DESART   
   REPLACE STM_QTAORD WITH XXX_QTAORD
   REPLACE STM_PRZNET WITH XXX_PRZNET
   REPLACE STM_CODIVA WITH XXX_CODIVA
   REPLACE STM_QTAACC WITH XXX_QTAACC 

   SELECT CU_ORD_DD
   SKIP +1

ENDDO

SELECT CUR_STAMPA
GO TOP

IF !EOF()
   IF PUB_ARRIVO = 'ECASH'
      _Z_REPORT  = "REPORT\ACCSTAMP"
      REPORT FORM &_Z_REPORT NOEJECT NOCONSOLE TO PRINTER PROMPT
   ELSE     
      DO PRG\MENUSTA WITH "CUR_STAMPA",.T.,.T.,"XXX","ACCSTAMP","ACCSTAMP.FRX"
   ENDIF
ELSE
   =MESSAGEBOX("Nessun dato da stampare",64,"*** INFORMAZIONE ***")
ENDIF

RETURN