******************************************************************************
PROCEDURE CONTROLLA_DATI_LIQUIDAZIONE_TRIMESTRALE_LIPE
******************************************************************************

PUB_ERRORI_LIPE 		= .F.
PUB_ELENCO_ERORI_LIPE 	= ""

*IF LEN(ALLTRIM(M.AZI_CODFIS_DICHIAR)) <> 16
IF !(LEN(ALLTRIM(M.AZI_CODFIS_DICHIAR)) = 16 OR LEN(ALLTRIM(M.AZI_CODFIS_DICHIAR)) = 11)  && ERASMO - 15/04/2025
	PUB_ERRORI_LIPE = .T.
	PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "CODICE FISCALE DICHIARANTE ERRATO: " + ALLTRIM(M.AZI_CODFIS_DICHIAR) + CHR(13)
ENDIF

IF LEN(ALLTRIM(M.AZI_PIVA)) <> 11
	PUB_ERRORI_LIPE = .T.
	PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "PARTITA IVA DICHIARANTE ERRATA: " + ALLTRIM(M.AZI_PIVA) + CHR(13)
ENDIF

IF VAL(PUB_ANNO) > 2017
ELSE
	PUB_ERRORI_LIPE = .T.
	PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "ANNO IMPOSTA ERRATO: " + ALLTRIM(PUB_ANNO) + CHR(13)
ENDIF

IF !EMPTY(ALLTRIM(M.AZI_CODFIS_DICHIAR)) 
	IF EMPTY(M.AZI_CARICA_DICHIAR)
		PUB_ERRORI_LIPE = .T.
		PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "CODICE CARICA DICHIARANTE MANCANTE: " + ALLTRIM(M.AZI_CARICA_DICHIAR) + CHR(13)
	ENDIF
ENDIF

IF EMPTY(ALLTRIM(M.AZI_FIRMA_DICHIAR)) 
	PUB_ERRORI_LIPE = .T.
	PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "FIRMA CONTRIBUENTE MANCANTE: " + ALLTRIM(M.AZI_FIRMA_DICHIAR) + CHR(13)
ENDIF

*!*	IF LEN(ALLTRIM(M.AZI_CODFIS_INTERM)) <> 16
*!*		PUB_ERRORI_LIPE = .T.
*!*		PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "FIRMA CONTRIBUENTE MANCANTE: " + ALLTRIM(M.AZI_CODFIS_INTERM) + CHR(13)
*!*	ENDIF
**=> ERASMO - INIZIO 06/05/2024
IF LEN(ALLTRIM(M.AZI_CODFIS_INTERM)) <> 16 AND LEN(ALLTRIM(M.AZI_CODFIS_INTERM)) <> 11
	PUB_ERRORI_LIPE = .T.
	PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "CODICE FISCALE INTERMEDIARIO ERRATO: " + ALLTRIM(M.AZI_CODFIS_INTERM) + CHR(13)
ENDIF
**=> ERASMO - FINE 06/05/2024

IF !EMPTY(ALLTRIM(M.AZI_CODFIS_INTERM)) 
	IF VAL(M.AZI_IMPEGNO_CONTR) = 1 OR VAL(M.AZI_IMPEGNO_CONTR) = 2
	ELSE
		PUB_ERRORI_LIPE = .T.
		PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "TIPO IMPEGNO ERRATO: " + ALLTRIM(M.AZI_IMPEGNO_CONTR) + CHR(13)
	ENDIF
ENDIF


IF EMPTY(DATA_IMPEGNO) .OR. DATA_IMPEGNO = SPACE(10) .OR. DATA_IMPEGNO= '  /  /    '
	PUB_ERRORI_LIPE = .T.
	PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "DATA IMPEGNO ERRATA: " + ALLTRIM(DATA_IMPEGNO) + CHR(13)
ENDIF

IF !EMPTY(ALLTRIM(M.AZI_CODFIS_INTERM)) 
	IF EMPTY(ALLTRIM(M.AZI_FIRMA_INTERM)) 
		PUB_ERRORI_LIPE = .T.
		PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "FIRMA INTERMEDIARIO MANCANTE: " + ALLTRIM(M.AZI_FIRMA_INTERM) + CHR(13)
	ENDIF
ELSE 
	PUB_ERRORI_LIPE = .T.
	PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "FIRMA INTERMEDIARIO MANCANTE: " + ALLTRIM(M.AZI_FIRMA_INTERM) + CHR(13)
	**M.AZI_FIRMA_INTERM = "" && SE NON E' PRESENTE IL CODICE FISCALE LA DATA NON E' DA CONSIDERARE
ENDIF



IF VAL(M.AZI_FLAG_CONFERMA) = 1  
ELSE
	PUB_ERRORI_LIPE = .T.
	PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "FLAG DI CONFERMA DIVERSO DA 1: " + ALLTRIM(M.AZI_FLAG_CONFERMA) + CHR(13)
ENDIF

** SERGIO 23/03/2023 INIZIO CONTROLLO NON PIU' VALIDO IN QUANTO COMUNQUE IL PROGRAMMA SI COMPORTA NEI CALCOLI ELABORANDO IL SINGOLO MESE
*!*	IF OK_TRIM = 1 OR  OK_TRIM = 2 OR  OK_TRIM = 3 OR  OK_TRIM = 4  OR  OK_TRIM = 5 
*!*	ELSE 
*!*		PUB_ERRORI_LIPE = .T.
*!*		PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "TRIMESTRE ERRATO PUO' ESSERE 1,2,3,4: " + STR(OK_TRIM,1,0) + CHR(13)
*!*	ENDIF 
** SERGIO 23/03/2023 FINE CONTROLLO NON PIU' VALIDO IN QUANTO COMUNQUE IL PROGRAMMA SI COMPORTA NEI CALCOLI ELABORANDO IL SINGOLO MESE

IF !EMPTY(M.AZI_LIQUIDA_GRUPPO)
	IF LIPE_TOTALE_ATTIVO <> 0
		PUB_ERRORI_LIPE = .T.
		PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "TOTALE ATTIVO NON PUO' ESSERE GESTITO SE LIQUIDAZIONE GRUPPO: " + ALLTRIM(STR(LIPE_TOTALE_ATTIVO,12,2)) + CHR(13)
		**LIPE_TOTALE_ATTIVO = 0 && TOTALE ATTIVO NON PUO' ESSERE GESTITO SE LIQUIDAZIONE GRUPPO
	ENDIF
ENDIF


IF !EMPTY(M.AZI_LIQUIDA_GRUPPO)
	IF LIPE_TOTALE_PASSIVO <> 0
		PUB_ERRORI_LIPE = .T.
		PUB_ELENCO_ERORI_LIPE = PUB_ELENCO_ERORI_LIPE + "TOTALE PASSIVO NON PUO' ESSERE GESTITO SE LIQUIDAZIONE GRUPPO: " + ALLTRIM(STR(LIPE_TOTALE_PASSIVO,12,2)) + CHR(13)
		**LIPE_TOTALE_PASSIVO = 0 && TOTALE ATTIVO NON PUO' ESSERE GESTITO SE LIQUIDAZIONE GRUPPO
	ENDIF
ENDIF


IF !EMPTY(M.AZI_LIQUIDA_GRUPPO)
	LIPE_INTERESSI_DOVUTI   = 0				&& INTERESSI = 0 IN QUANTO SI TRATTA DI LIQUIDAZIOE DI GRUPPO
ENDIF

IF OK_TRIM = 4  OR  OK_TRIM = 5 
	LIPE_INTERESSI_DOVUTI   = 0				&& INTERESSI = 0 IN QUANTO SI TRATTA DI LIQUIDAZIOE DI GRUPPO
ENDIF



RETURN




******************************************************************************
PROCEDURE APPEND_XML_FILE_LIPE
******************************************************************************

LPARAMETERS P_CURSOR,P_XML_STRING,P_XML_FILE

