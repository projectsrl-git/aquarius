	TT_LIPE_IVA_CREDITO_ANNO_PRECEDENTE 	= TT_LIPE_IVA_CREDITO_ANNO_PRECEDENTE 		+  	CU_LIPE_IVA_CREDITO_ANNO_PRECEDENTE 
	TT_LIPE_DEBITO_PERIODO_PRECEDENTE 		= TT_LIPE_DEBITO_PERIODO_PRECEDENTE  		+  	CU_LIPE_DEBITO_PERIODO_PRECEDENTE  
	TT_LIPE_VERSAMENTI_AUTO_UE 				= TT_LIPE_VERSAMENTI_AUTO_UE 				+  	CU_LIPE_VERSAMENTI_AUTO_UE 
	TT_LIPE_CREDITI_IMPOSTA 				= TT_LIPE_CREDITI_IMPOSTA 					+  	CU_LIPE_CREDITI_IMPOSTA 
