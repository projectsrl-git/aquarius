FUNCTION CERCA_IVA_CREDITO_MESE_ANNO_PRECEDENTE_MODULO_TRIMESTRE
****************************************************************
* CARICA L'IVA A CREDITO DURANTE LA GESTIONE DEL MODULO TRIMESTRE: SU U_IVA_CR VIENE MEMORIZZATO AUTOMATICAMENTE L'IVA DA RECUPERARE 
* SUL PRIMO MESE DEL TRIMESTRE AD ECCEZZIONE DEL PRIMO TRIMESTRE 
SS= SELECT()

RELEASE _DARIPO 
PUBLIC _DARIPO 
_DARIPO = 0
EXTRAI  = 0

** IL PROGRAMMA RIEPILOGHI IVA CON FUNZIONE DI AGGIORNAMENTO DELL'IVA DA RECUPERARE, SE USATO CON OPZIONE TRIMESTRE DIGITANDO IL NUMEO DEL TRIMESTRE, 
** CONTROAGGIORNA LA TABELLA U_IVA_CR MEMORIZZANDO L'VA DA RECUPERARE DEL TRIMESTRE PRECEDENTE IN IVA_GIUGNO/IVA_SETTEM/IVA_DICEMB


* >>>>>>> PRELIEVO DELL'IVA DA RECUPERARE NEL MESE
x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
x_anno = "iva_anno = " + PUB_ANNO
x_cond = x_soci + " and " + x_anno
CSQL   = "select * from u_iva_cr where " + x_cond + " order by iva_codsoc,iva_anno" 
IF !ExecCommand(CSQL,"u_iva_cr")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_CR
GO TOP
IF !EOF()
   IF LIPE_OK_TRIM = 1
      LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = 0	&& IVA_GENNAI
   ENDIF
   IF LIPE_OK_TRIM = 2
      LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_GIUGNO		&& IVA_APRILE  
   ENDIF
   IF LIPE_OK_TRIM = 3
      LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_SETTEM		&& IVA_LUGLIO 
   ENDIF
   IF LIPE_OK_TRIM = 4
      LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_DICEMB		&& IVA_OTTOBR 
   ENDIF
ELSE
   LIPE_IVA_CREDITO_PERIODO_PRECEDENTE  = 0 
ENDIF 

* >>>>>>> CARICA L'IVA DA RECUPERARE DELL'ANNO PRECEDENTE
IF !EOF()

   IF LIPE_OK_TRIM = 1
     LIPE_IVA_CREDITO_ANNO_PRECEDENTE   = IVA_01RECU + IVA_02RECU + IVA_03RECU
   ENDIF
   IF LIPE_OK_TRIM = 2
      LIPE_IVA_CREDITO_ANNO_PRECEDENTE  = IVA_04RECU + IVA_05RECU + IVA_06RECU
   ENDIF
   IF LIPE_OK_TRIM = 3
      LIPE_IVA_CREDITO_ANNO_PRECEDENTE  = IVA_07RECU + IVA_08RECU + IVA_09RECU
   ENDIF
   IF LIPE_OK_TRIM = 4
      LIPE_IVA_CREDITO_ANNO_PRECEDENTE  = IVA_10RECU + IVA_11RECU + IVA_12RECU
   ENDIF


ELSE

   LIPE_IVA_CREDITO_ANNO_PRECEDENTE  = 0 
   EXTRAI  = 0 
   
ENDIF !EOF()



IF EXTRAI >= 0
   EXTRAI=EXTRAI*(-1) 
ENDIF


SELECT(SS)

RETURN 
** 01/04/2023 SERGIO FINE

