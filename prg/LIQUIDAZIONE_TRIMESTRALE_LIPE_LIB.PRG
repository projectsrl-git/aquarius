
********************************************************************************************************
FUNCTION ELABORA_LIQUIDAZIONE_TRIMESTRALE_LIPE
********************************************************************************************************

LOCAL _DIRECTORY_DI_CREAZIONE

SS_LIPE=STR(SELECT())

RELEASE DATA_IMPEGNO
PUBLIC DATA_IMPEGNO
DATA_IMP = OK_DATA(DTOC(DATE()))
DATA_IMPEGNO = SUBSTR(DATA_IMP,1,2)+SUBSTR(DATA_IMP,4,2)+SUBSTR(DATA_IMP,7,4)		&& FORMATO GGMMAAAA


** ########################################### DETERMINA I PARAMETRI AZIENDALI/LIPE #####################################

x_cond = "azi_codsoc = '" + pub_codsoc + "'"
cSql="SELECT * FROM u_azi_an WHERE " + x_cond  
IF !ExecCommand(cSql,"u_azi_an_cu")
    return(.f.)
ENDIF
SELECT u_azi_an_cu
GO TOP 
IF RECCOUNT() > 0
	M.AZI_PIVA		 	=  ALLTRIM(AZI_PIVA)
ELSE
	M.AZI_PIVA		 	=  ""  
ENDIF

x_cond = "azi_codsoc = '" + pub_codsoc + "'"
cSql="SELECT * FROM u_azi_pc WHERE " + x_cond  
IF !ExecCommand(cSql,"u_azi_pc_cu")
    return(.f.)
ENDIF
SELECT u_azi_pc_cu
GO TOP 
IF RECCOUNT() > 0

     M.AZI_FORNITURA		 =  ALLTRIM(AZI_FORNITURA)			&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_COD_FORNITURA	 =  ALLTRIM(AZI_COD_FORNITURA)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_LIQUIDA_GRUPPO	 =  ALLTRIM(AZI_LIQUIDA_GRUPPO)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_CODFIS_DICHIAR	 =  ALLTRIM(AZI_CODFIS_DICHIAR)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_CARICA_DICHIAR	 =  ALLTRIM(AZI_CARICA_DICHIAR)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_FIRMA_DICHIAR	 =  ALLTRIM(AZI_FIRMA_DICHIAR)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_CODFIS_INTERM	 =  ALLTRIM(AZI_CODFIS_INTERM)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)	
     M.AZI_IMPEGNO_CONTR	 =  ALLTRIM(AZI_IMPEGNO_CONTR)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_FIRMA_INTERM		 =  ALLTRIM(AZI_FIRMA_INTERM)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_FLAG_CONFERMA	 =  ALLTRIM(AZI_FLAG_CONFERMA)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)		 
     M.AZI_NUM_MODULO		 =  ALLTRIM(AZI_NUM_MODULO)			&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)

ENDIF


** ################################################## DETERMINA DATI XML #############################################

DO CALCOLA_VARIABILI_IVA									&& CALCOLA IL VALORE DELLE VARIABILI IVA

** ################################################## CONTROLLO DATI XML #############################################

PUB_ERRORI_LIPE = .F.
=CONTROLLA_DATI_LIQUIDAZIONE_TRIMESTRALE_LIPE()		 
IF PUB_ERRORI_LIPE 
   RETURN .F.
ENDIF

** ################################# SALVATAGGIO VARIABILI XML NEL CURSORE SE MODULO MESE #############################

DO SALVATAGGIO_VARIABILI_CALCOLATE							&& SALVATAGGIO DELLE VARIABILI CALCOLATE NEL CURSORE DI SUPPORTO SIA PER LA GESTIOME MENSILE CHE TRIMESTRALE

** ################################################## CREAZIONE FILE XML #############################################



SELECT &SS_LIPE
RETURN .T.



********************************************************************************************************
FUNCTION CREA_LIQUIDAZIONE_TRIMESTRALE_LIPE_DOPO_MODIFICHE_UTENTE
********************************************************************************************************

LPARAMETERS _DIRECTORY_DI_CREAZIONE
*LOCAL _DIRECTORY_DI_CREAZIONE

SS_LIPE=STR(SELECT())


IF PUB_TIPO_MODULO_LIPE = 1								&& MODULO TRIMESTRALE

	IF FILE("liquidazione_trimestrale_lipe.xml")	  	&& ESISTE IL FILE? 
	ELSE
		MESSAGEBOX("File LIQUIDAZIONE_TRIMESTRALE_LIPE.XML non presente nella directory di AQUARIUS. Il file č necessario per creare la liquidazione iva LIPE modulo TRIMESTRE";
			+CHR(13)+"Contattare assistenza",48,"Errore creazione XML liquidazione trimestrale")
		RETURN .F.
	ENDIF

	IF LIPE_OK_CREA_LIPE
		WAIT WINDOWS "Creazione file XML per la liquidazione IVA LIPE modulo TRIMESTRE..." NOWAIT
	ELSE
		WAIT WINDOWS "Elaborazione dati per la liquidazione IVA LIPE modulo TRIMESTRE..." NOWAIT
	ENDIF


ELSE													&& MODULO MENSILE

	IF FILE("liquidazione_trimestrale_lipe_mese.xml")	&& ESISTE IL FILE? 
	ELSE
		MESSAGEBOX("File LIQUIDAZIONE_TRIMESTRALE_LIPE_MESE.XML non presente nella directory di AQUARIUS. Il file č necessario per creare la liquidazione iva LIPE modulo MESE ";
			+CHR(13)+"Contattare assistenza",48,"Errore creazione XML liquidazione trimestrale")
		RETURN .F.
	ENDIF

	
	IF LIPE_OK_CREA_LIPE
		WAIT WINDOWS "Creazione file XML per la liquidazione IVA LIPE modulo MESE..." NOWAIT
	ELSE
		WAIT WINDOWS "Elaborazione dati per la liquidazione IVA LIPE modulo MESE..." NOWAIT
	ENDIF

ENDIF


** ############################################## DETERMINA IL PROGRESSIVO FILE #########################################

IF LIPE_OK_CREA_LIPE
	v_seek= 'NUMLIP'+PUB_CODSOC
	v_chiave= "codice"
	cSql="select * from para where " + v_chiave + " = '" + v_seek + "'"
	IF !ExecRW(cSql,"PARA","R")
		return(.f.)
	ENDIF
	SELECT PARA
	IF RECCOUNT() <> 0
		V2=VAL(SUBSTR(LIBERA,1,7)) + 1
	 	REPLACE LIBERA WITH SUBSTR(STR(V2,7,0),1,7)
		_PROG_FILE_XML = ALLTRIM(SUBSTR(STR(V2,7,0),1,7))
	ELSE
		RIT = MSGBOX('Parametro numero progressivo file XML (LIPE) non trovato','ATTENZIONE',31)
		RETURN
	ENDIF
	IF !ExecRW(cSql,"PARA","W")
	 return(.f.)
	ENDIF
ELSE
	_PROG_FILE_XML = ""
ENDIF

** ############################################## DETERMINA DIRECTORY FILE #########################################

*!*	V_SEEK   = 'FSDXLI'
*!*	V_CHIAVE = 'CODICE'
*!*	IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
*!*	   SELECT CUR_PARA
*!*	   	_DIRECTORY_DI_CREAZIONE	= ALLTRIM(LIBERA)+"\"+PUB_ANNO
*!*	ELSE
*!*	   	_DIRECTORY_DI_CREAZIONE = "\DOC_AQUARIUS\IVA_TRIMESTRALE_XML_LIPE\"+PUB_ANNO
*!*	ENDIF

** ########################################### DETERMINA I PARAMETRI AZIENDALI/LIPE #####################################

x_cond = "azi_codsoc = '" + pub_codsoc + "'"
cSql="SELECT * FROM u_azi_an WHERE " + x_cond  
IF !ExecCommand(cSql,"u_azi_an_cu")
    return(.f.)
ENDIF
SELECT u_azi_an_cu
GO TOP 
IF RECCOUNT() > 0
	M.AZI_PIVA		 	=  ALLTRIM(AZI_PIVA)
ELSE
	M.AZI_PIVA		 	=  ""  
ENDIF

x_cond = "azi_codsoc = '" + pub_codsoc + "'"
cSql="SELECT * FROM u_azi_pc WHERE " + x_cond  
IF !ExecCommand(cSql,"u_azi_pc_cu")
    return(.f.)
ENDIF
SELECT u_azi_pc_cu
GO TOP 
IF RECCOUNT() > 0

     M.AZI_FORNITURA		 =  ALLTRIM(AZI_FORNITURA)			&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_COD_FORNITURA	 =  ALLTRIM(AZI_COD_FORNITURA)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_LIQUIDA_GRUPPO	 =  ALLTRIM(AZI_LIQUIDA_GRUPPO)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_CODFIS_DICHIAR	 =  ALLTRIM(AZI_CODFIS_DICHIAR)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_CARICA_DICHIAR	 =  ALLTRIM(AZI_CARICA_DICHIAR)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_FIRMA_DICHIAR	 =  ALLTRIM(AZI_FIRMA_DICHIAR)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_CODFIS_INTERM	 =  ALLTRIM(AZI_CODFIS_INTERM)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)	
     M.AZI_IMPEGNO_CONTR	 =  ALLTRIM(AZI_IMPEGNO_CONTR)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_FIRMA_INTERM		 =  ALLTRIM(AZI_FIRMA_INTERM)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)
     M.AZI_FLAG_CONFERMA	 =  ALLTRIM(AZI_FLAG_CONFERMA)		&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)		 
     M.AZI_NUM_MODULO		 =  ALLTRIM(AZI_NUM_MODULO)			&& SERGIO - 15/02/2023 Liquidazione iva trimestrale in formato XML (LIPE)

ENDIF


** ################################################ COMPONE IL NOME DEL FILE #########################################

_CHR = 5
_PROGRESSIVO = TRC(_CHR,_PROG_FILE_XML)


IF PUB_TIPO_MODULO_LIPE = 1								&& MODULO TRIMESTRALE
	_LIPE=FILETOSTR("liquidazione_trimestrale_lipe.xml")
ELSE													&& MODULO MENSILE
	_LIPE=FILETOSTR("liquidazione_trimestrale_lipe_mese.xml")
ENDIF


_PERCORSO_E_FILE = _DIRECTORY_DI_CREAZIONE+ "\IT" + M.AZI_PIVA + "_LI_" + ALLTRIM(_PROGRESSIVO) + ".XML"

** ################################################## DETERMINA DATI XML #############################################

DO IMPOSTA_VARIABILI_FISSE								&& AGGIORNA IL FILE XML ATTRIBUENDO LE VARIABILI FISSE																																	

** ################################################## CREAZIONE FILE XML #############################################


IF LIPE_OK_CREA_LIPE 

	IF PUB_TIPO_MODULO_LIPE = 2							&& MODULO MENSILE
		
		DO IMPOSTA_VARIABILI_DINAMICHE_MODULO_MESE		&& AGGIORNA IL FILE XML MODULO MESE ATTRIBUENDO LE VARIABILI DINAMICHE DOPO CREAZIONE CURSORE DI SUPPORTO
		STRTOFILE(_LIPE,_PERCORSO_E_FILE,0)				&& SCRITTURA FILE XML LIPE SU DISCO

	ELSE
	
		DO SOMMA_VARIABILI_CALCOLATE					&& SOMMA VARIABILI CALCOLATE RELATIVE AI MESI DEL TRIMESTRE DA MOSTRARE A VIDEO
		DO RICALCOLA_TRIMESTRE 

		DO IMPOSTA_VARIABILI_DINAMICHE_MODULO_TRIMESTRE	&& AGGIORNA IL FILE XML MODULO TRIMESTRE ATTRIBUENDO LE VARIABILI DINAMICHE
		STRTOFILE(_LIPE,_PERCORSO_E_FILE,0)				&& SCRITTURA FILE XML LIPE SU DISCO
		
	ENDIF	
	
	
	
ENDIF 



SELECT &SS_LIPE
RETURN .T.


