LIPE_CREDITI_IMPOSTA 				= TT_LIPE_CREDITI_IMPOSTA 					 
LIPE_ACCONTI 						= TT_LIPE_ACCONTI 							 
LIPE_INTERESSI_DOVUTI				= TT_LIPE_INTERESSI_DOVUTI					 



SELECT &SS_LIPE4
RETURN .T.



******************************************************************************
PROCEDURE CALCOLA_VARIABILI_IVA
******************************************************************************

SS_LIPE2=STR(SELECT())



** VP4 = IVA ESIGIBILE (IVA CLIENTI)
LIPE_IVA_ESIGIBILE  = IIF(OK_ARR, OK_ARROTB((TC_TOTIVA_LIPE+TE_TOTIVA_LIPE+TCS_TOTIVA_LIPE),PUB_VALRIF) ,(TC_TOTIVA_LIPE+TE_TOTIVA_LIPE+TCS_TOTIVA_LIPE))	&& IVA CLIENTI

** VP5 = IVA DETRATTA (IVA FORNITORI)
IF PUB_PRORATA
    LIPE_IVA_DETRATTA  = IIF(OK_ARR, OK_ARROTB((IVA_PRORATA_DETRAIBILE),PUB_VALRIF) ,(IVA_PRORATA_DETRAIBILE))	&& IVA PRORATA
ELSE
	LIPE_IVA_DETRATTA  = IIF(OK_ARR, OK_ARROTB((TF_TOTIVA_LIPE),PUB_VALRIF) ,(TF_TOTIVA_LIPE))					&& IVA ACQUISTI
ENDIF

** VP6 = IVA DOVUTA (differenza tra i righi VP4 e VP5 nel caso in cui tale differenza sia positiva)
LIPE_IVA_DOVUTA = LIPE_IVA_ESIGIBILE - LIPE_IVA_DETRATTA														&& IVA CLIENTI - IVA FORNITORI 

** VP6 = IVA CREDITO(differenza tra i righi VP4 e VP5 e nel caso in cui tale differenza sia negativa riportarla in valore assoluto)
IF LIPE_IVA_DOVUTA < 0
	LIPE_IVA_CREDITO = ABS(LIPE_IVA_DOVUTA)
	LIPE_IVA_DOVUTA  = 0
ENDIF

** VP8 = IVA CREDITO PERIODO PRECEDENTE >>>> LIPE_IVA_CREDITO_PERIODO_PRECEDENTE
** VP9 = IVA CREDITO ANNO PRECEDENTE    >>>> LIPE_IVA CREDITO ANNO PRECEDENTE 
** VP10 = IVA VERSAMENTO AUTO UE        >>>> LIPE_VERSAMENTI_AUTO_UE
** VP11 = IVA CREDITI IMPOSTA           >>>> LIPE_CREDITI_IMPOSTA
** VP13 = ACCONTI DOVUTI                >>>> LIPE_ACCONTI    


*!*	dato A = (IvaDovuta - IvaCredito + DebitoPrecedente + InteressiDovuti - CreditiImposta - CreditoPeriodoPrecedente - CreditoAnnoPrecedente - VersamentiAutoUE - Acconto )
*!*	se A > 0
*!*	ImportoDaVersare = A	e	ImportoACredito = 0 

*!*	se A < 0
*!*	ImportoACredito = -A	e	ImportoDaVersare = 0 

*!*	se A = 0
*!*	ImportoDaVersare = 0	e	ImportoACredito = 0


** VP14 IMPORTO IVA DA VERSARE colonna 1 = (VP6, col. 1    +                VP7             +        VP12    ) – (VP6, col. 2       +                  VP8                +                 VP9              +          VP10           +         VP11         + VP13, col. 2)
LIPE_IMPORTO_DA_VERSARE                  = (LIPE_IVA_DOVUTA + LIPE_DEBITO_PERIODO_PRECEDENTE + LIPE_INTERESSI_DOVUTI) - (LIPE_IVA_CREDITO + LIPE_IVA_CREDITO_PERIODO_PRECEDENTE + LIPE_IVA_CREDITO_ANNO_PRECEDENTE + LIPE_VERSAMENTI_AUTO_UE + LIPE_CREDITI_IMPOSTA + LIPE_ACCONTI)   

IF LIPE_IMPORTO_DA_VERSARE = 0
	LIPE_IMPORTO_DA_VERSARE = 0
	LIPE_IMPORTO_A_CREDITO  = 0
ELSE 
	IF LIPE_IMPORTO_DA_VERSARE > 0
		LIPE_IMPORTO_DA_VERSARE = LIPE_IMPORTO_DA_VERSARE		&& IMPORTO CALCOLATO COSI' COME E'	 
		LIPE_IMPORTO_A_CREDITO  = 0								&& IMPORTO A CREDITO A ZERO
	ELSE 
		LIPE_IMPORTO_A_CREDITO  = ABS(LIPE_IMPORTO_DA_VERSARE)  && VALORE ASSOLUTO
		LIPE_IMPORTO_DA_VERSARE = 0								&& IMPORTO DA VERSARE A ZERO
	ENDIF
ENDIF


* TEST ULTERIOR: SE LIPE_TOTALE_ATTIVO E LIPE_TOTALE_PASSIVO = 0 NON DEVO NE VERSARE NE RICEVERE
IF LIPE_TOTALE_ATTIVO = 0 AND LIPE_TOTALE_PASSIVO = 0
	LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = 0
	LIPE_IMPORTO_DA_VERSARE = 0
	LIPE_IMPORTO_A_CREDITO  = 0
ENDIF


SELECT &SS_LIPE2
RETURN .T.


******************************************************************************
PROCEDURE RICALCOLA_TRIMESTRE
******************************************************************************

SS_LIPE2=STR(SELECT())



** VP4 = IVA ESIGIBILE (IVA CLIENTI)

** VP5 = IVA DETRATTA (IVA FORNITORI)
** VP6 = IVA DOVUTA (differenza tra i righi VP4 e VP5 nel caso in cui tale differenza sia positiva)
LIPE_IVA_CREDITO = 0
LIPE_IVA_DOVUTA = LIPE_IVA_ESIGIBILE - LIPE_IVA_DETRATTA		&& IVA CLIENTI - IVA FORNITORI 

** VP6 = IVA CREDITO(differenza tra i righi VP4 e VP5 e nel caso in cui tale differenza sia negativa riportarla in valore assoluto)
IF LIPE_IVA_DOVUTA < 0
	LIPE_IVA_CREDITO = ABS(LIPE_IVA_DOVUTA)
	LIPE_IVA_DOVUTA  = 0
ENDIF


** VP8 = IVA CREDITO PERIODO PRECEDENTE >>>> LIPE_IVA_CREDITO_PERIODO_PRECEDENTE
LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = 0

** VP9 = IVA CREDITO ANNO PRECEDENTE    >>>> LIPE_IVA CREDITO ANNO PRECEDENTE 
LIPE_IVA_CREDITO_ANNO_PRECEDENTE    = 0

DO CERCA_IVA_CREDITO_MESE_ANNO_PRECEDENTE_MODULO_TRIMESTRE


** VP10 = IVA VERSAMENTO AUTO UE        >>>> LIPE_VERSAMENTI_AUTO_UE
** VP11 = IVA CREDITI IMPOSTA           >>>> LIPE_CREDITI_IMPOSTA
** VP13 = ACCONTI DOVUTI                >>>> LIPE_ACCONTI    


*!*	dato A = (IvaDovuta - IvaCredito + DebitoPrecedente + InteressiDovuti - CreditiImposta - CreditoPeriodoPrecedente - CreditoAnnoPrecedente - VersamentiAutoUE - Acconto )
*!*	se A > 0
*!*	ImportoDaVersare = A	e	ImportoACredito = 0 

*!*	se A < 0
*!*	ImportoACredito = -A	e	ImportoDaVersare = 0 

*!*	se A = 0
*!*	ImportoDaVersare = 0	e	ImportoACredito = 0


** VP14 IMPORTO IVA DA VERSARE colonna 1 = (VP6, col. 1    +                VP7             +        VP12    ) – (VP6, col. 2       +                  VP8                +                 VP9              +          VP10           +         VP11         + VP13, col. 2)
LIPE_IMPORTO_DA_VERSARE                  = (LIPE_IVA_DOVUTA + LIPE_DEBITO_PERIODO_PRECEDENTE + LIPE_INTERESSI_DOVUTI) - (LIPE_IVA_CREDITO + LIPE_IVA_CREDITO_PERIODO_PRECEDENTE + LIPE_IVA_CREDITO_ANNO_PRECEDENTE + LIPE_VERSAMENTI_AUTO_UE + LIPE_CREDITI_IMPOSTA + LIPE_ACCONTI)   


IF LIPE_IMPORTO_DA_VERSARE = 0
	LIPE_IMPORTO_DA_VERSARE = 0
	LIPE_IMPORTO_A_CREDITO  = 0
ELSE 
	IF LIPE_IMPORTO_DA_VERSARE > 0
		LIPE_IMPORTO_DA_VERSARE = LIPE_IMPORTO_DA_VERSARE		&& IMPORTO CALCOLATO COSI' COME E'	 
		LIPE_IMPORTO_A_CREDITO  = 0								&& IMPORTO A CREDITO A ZERO
	ELSE 
		LIPE_IMPORTO_A_CREDITO  = ABS(LIPE_IMPORTO_DA_VERSARE)  && VALORE ASSOLUTO
		LIPE_IMPORTO_DA_VERSARE = 0								&& IMPORTO DA VERSARE A ZERO
	ENDIF
ENDIF


* TEST ULTERIOR: SE LIPE_TOTALE_ATTIVO E LIPE_TOTALE_PASSIVO = 0 NON DEVO NE VERSARE NE RICEVERE
IF LIPE_TOTALE_ATTIVO = 0 AND LIPE_TOTALE_PASSIVO = 0
	LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = 0
	LIPE_IMPORTO_DA_VERSARE = 0
	LIPE_IMPORTO_A_CREDITO  = 0
ENDIF


SELECT &SS_LIPE2
RETURN .T.





