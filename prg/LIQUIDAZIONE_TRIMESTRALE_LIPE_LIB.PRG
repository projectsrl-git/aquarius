	_XML_STRING = STRTRAN(_XML_STRING ,"#NUMERO_RIGA#"  ,ALLTRIM(STR(_NUMERO_RIGA,4,0)))   

	_XML_STRING =SOSTITUISCE_CAMPI_CURSOR_SU_TESTO(P_CURSOR,_XML_STRING )

	STRTOFILE(_XML_STRING ,P_XML_FILE,1)
	
ENDSCAN

RETURN


* FINE PROCEDURE CONTROLLA_DATI_LIQUIDAZIONE_TRIMESTRALE_LIPE
*************************************************************

** 22/03/2023 SERGIO INIZIO
**********************************************************
FUNCTION CERCA_IVA_CREDITO_ANNO_PRECEDENTE_MESE_PRECEDENTE
**********************************************************

SS= SELECT()

RELEASE _DARIPO 
PUBLIC _DARIPO 
_DARIPO = 0

*!*	IF PUB_TIPO_MODULO_LIPE = 1  && SOLO SE MODULO TRIMESTRALE
*!*		IF LIPE_MODULO = 0	&& ELABORO L'IVA DA RECUPERARE SOLO DURANTE L'ACCESSO DEL PRIMO MESE COME FA LIQUIDA CON FUNZIONE CERCA
*!*		ELSE
*!*			SELECT(SS)
*!*			RETURN
*!*		ENDIF
*!*	ENDIF



* >>>>>>> PRELIEVO DELL'IVA DA RECUPERARE NEL MESE
x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
x_anno = "iva_anno = " + PUB_ANNO
x_cond = x_soci + " and " + x_anno
CSQL   = "select * from u_iva_cr where " + x_cond + " order by iva_codsoc,iva_anno" 
IF !ExecCommand(CSQL,"u_iva_cr")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_CR
GO TOP
IF !EOF()
   IF OK_TRIM = 0
      IF VAL(SUBSTR(__dtdal,4,2)) = 1
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_GENNAI
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 2
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_FEBBRA
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 3
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_MARZO
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 4
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_APRILE
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 5
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_MAGGIO
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 6
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_GIUGNO
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 7
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_LUGLIO
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 8
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_AGOSTO
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 9
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_SETTEM
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 10
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_OTTOBR
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 11
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_NOVEMB
      ENDIF
      IF VAL(SUBSTR(__dtdal,4,2)) = 12
         LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_DICEMB
      ENDIF
   ENDIF
   IF OK_TRIM = 1
      LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_GENNAI + IVA_FEBBRA + IVA_MARZO
   ENDIF
   IF OK_TRIM = 2
      LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_APRILE + IVA_MAGGIO + IVA_GIUGNO
   ENDIF
   IF OK_TRIM = 3
      LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_LUGLIO + IVA_AGOSTO + IVA_SETTEM
   ENDIF
   IF OK_TRIM = 4
      LIPE_IVA_CREDITO_PERIODO_PRECEDENTE = IVA_OTTOBR + IVA_NOVEMB + IVA_DICEMB
   ENDIF
