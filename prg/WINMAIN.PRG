****************************************************************************
* WINMAIN.PRG
****************************************************************************

SET SYSMENU TO
SET SYSMENU AUTOMATIC

*** CREO CURSORE CON MENU DI PRIMO LIVELLO
cSql=""     
cNomeCursorSql="CPRIMO_LIVELLO"	

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 
		TBL_MENU.*,
		'N' AS VISIBILE
	FROM TBL_MENU 
	WHERE LIVELLO_MENU=1
	ORDER BY ORDINE
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	MESSAGEBOX("ERRORE NELLA CREZIONE DEL MENU DI PRIMO LIVELLO",48,"Creazione menu")
	RETURN 
ENDIF

SELECT CPRIMO_LIVELLO

*** CREO CURSORE CON MENU DI SECONDO LIVELLO

cSql=""     
cNomeCursorSql="CSECONDO_LIVELLO"	

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 
		T2L.*,
		'N' AS VISIBILE
	FROM TBL_MENU AS T2L
	LEFT OUTER JOIN TBL_MENU AS T1L
	ON T2L.MENU = T1L.MENU AND T1L.LIVELLO_MENU=1
	WHERE T2L.LIVELLO_MENU=2
	ORDER BY T1L.ORDINE*100+T2L.ORDINE
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	MESSAGEBOX("ERRORE NELLA CREZIONE DEL MENU DI SECONDO LIVELLO",48,"Creazione menu")
	RETURN 
ENDIF

SELECT CSECONDO_LIVELLO


*** CREO CURSORE CON OPZIONI ATTIVATE PER L'UTENTE

cSql=""     
cNomeCursorSql="CTBL_MENU"	

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT 
	*
	FROM TBL_MENU 
	WHERE UTENTI LIKE '%.<<PUB_CODOPE>>.%'
	AND LIVELLO_MENU=0
	ORDER BY MENU,ORDINE
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	MESSAGEBOX("ERRORE NELLA CREZIONE DEL MENU DI SECONDO LIVELLO",48,"Creazione menu")
	RETURN 
ENDIF

SELECT CTBL_MENU
GO TOP
DO WHILE !EOF()

	_MENU=ALLTRIM(MENU)
	SELECT CSECONDO_LIVELLO
	GO TOP
	DO WHILE !EOF()
	
		IF VISIBILE ='S'
			SELECT CSECONDO_LIVELLO
			SKIP
			LOOP
		ENDIF
		

		IF !EMPTY(VISIBILE_SE) 
			IF !EVALUATE(ALLTRIM(VISIBILE_SE ))
				REPLACE VISIBILE WITH 'N'
				SELECT CSECONDO_LIVELLO
				SKIP
				LOOP				
			ENDIF		
		
		ENDIF
		
		
		IF !('SUBMENU' $ UPPER(COMANDO))
			REPLACE VISIBILE WITH 'S'
			SKIP
			LOOP			
		ENDIF
		
		IF "'"+_MENU+"'" $ COMANDO
			REPLACE VISIBILE WITH 'S'
			EXIT
		ENDIF
		
		SELECT CSECONDO_LIVELLO
		SKIP
	ENDDO

	
	SELECT CTBL_MENU
	SKIP
ENDDO

SELECT CSECONDO_LIVELLO
GO TOP
DO WHILE !EOF()

	IF LABEL="\-"
		SELECT CSECONDO_LIVELLO	
		SKIP
		LOOP
	ENDIF	

	IF VISIBILE <> 'S'
		SELECT CSECONDO_LIVELLO	
		SKIP
		LOOP
	ENDIF
	
	_MENU=ALLTRIM(MENU)
	
	SELECT CPRIMO_LIVELLO
	GO TOP
	DO WHILE !EOF()

		IF !EMPTY(	VISIBILE_SE )
			IF !EVALUATE(ALLTRIM(VISIBILE_SE ))
				REPLACE VISIBILE WITH 'N'
				SELECT CPRIMO_LIVELLO
				SKIP
				LOOP				
			ENDIF
		ENDIF
	
		
		IF VISIBILE ='S'
			SELECT CPRIMO_LIVELLO
			SKIP
			LOOP
		ENDIF
		
		IF _MENU=MENU
			REPLACE VISIBILE WITH 'S'
			EXIT
		ENDIF
		
		SELECT CPRIMO_LIVELLO
		SKIP
	ENDDO

	SELECT CSECONDO_LIVELLO
	SKIP
	
ENDDO

_PRIMO_MENU=""

*** CREA PRIMO LIVELLO DI MENU
SELECT CPRIMO_LIVELLO
GO TOP 
DO WHILE !EOF()

	IF VISIBILE<>'S'
		_MENU=MENU
		SELECT CSECONDO_LIVELLO 
		REPLACE VISIBILE WITH 'N' FOR MENU=_MENU
		SELECT CPRIMO_LIVELLO
		SKIP
		LOOP
	ENDIF
	
	_KEY=SUBSTR(LABEL,1,1)
	
	_DEFINE="DEFINE PAD _PAD_"+ALLTRIM(MENU)+" OF _MSYSMENU PROMPT '"+ALLTRIM(LABEL)+"' COLOR SCHEME 3 KEY ALT+"+_KEY
	&_DEFINE
	
	_ONPAD="ON PAD _PAD_"+ALLTRIM(MENU)+" OF _MSYSMENU ACTIVATE POPUP "+ALLTRIM(MENU)
	&_ONPAD
	
	_DEFINE_POPUP="DEFINE POPUP "+ALLTRIM(MENU)+" MARGIN RELATIVE SHADOW COLOR SCHEME 4"
	&_DEFINE_POPUP
	
	IF _PRIMO_MENU =""
		_PRIMO_MENU = ALLTRIM(MENU)
	ENDIF
	
	SKIP
ENDDO

_ULTIMA_VOCE_PRIMO_MENU=0

*** CREA SECONDO LIVELLO DI MENU
SELECT CSECONDO_LIVELLO
GO TOP 

_MENU_ATTUALE=ALLTRIM(MENU)
_INSERIRE_DIVISORIO=.F.

DO WHILE !EOF()

	IF VISIBILE<>'S'
		SKIP
		LOOP
	ENDIF

	IF _MENU_ATTUALE==ALLTRIM(MENU)
		IF _INSERIRE_DIVISORIO
			_DEFINE_BAR ="DEFINE BAR "+ALLTRIM(STR(ORDINE-1))+" OF "+ALLTRIM(MENU)+" PROMPT '\-' "
			&_DEFINE_BAR 		
		ENDIF
	ELSE
		_MENU_ATTUALE=ALLTRIM(MENU)
	ENDIF

	IF ALLTRIM(LABEL)="\-"
		_INSERIRE_DIVISORIO=.T.
		SKIP
		LOOP
	ELSE
		_INSERIRE_DIVISORIO=.F.
	ENDIF
		
	_DEFINE_BAR="DEFINE BAR "+ALLTRIM(STR(ORDINE))+" OF "+ALLTRIM(MENU)+" PROMPT '"+ALLTRIM(LABEL)+"' PICTURE '"+ALLTRIM(ICONA)+"'"
	&_DEFINE_BAR
	
	_ON_SELECTION="ON SELECTION BAR "+ALLTRIM(STR(ORDINE))+" OF "+ALLTRIM(MENU)+" "+ALLTRIM(COMANDO)
	&_ON_SELECTION
	
	IF  ALLTRIM(MENU)=_PRIMO_MENU 
		_ULTIMA_VOCE_PRIMO_MENU=ORDINE
	ENDIF
	
	SKIP
ENDDO

_DEFINE_BAR ="DEFINE BAR "+ALLTRIM(STR(_ULTIMA_VOCE_PRIMO_MENU+1))+" OF clienti PROMPT '\-' "
&_DEFINE_BAR 
	
_DEFINE_BAR ="DEFINE BAR "+ALLTRIM(STR(_ULTIMA_VOCE_PRIMO_MENU+2))+" OF clienti PROMPT 'Fine lavoro' KEY CTRL+F1, 'CTRL+F1' PICTURE 'bmp\ambiente\ztoolbar\_termina.bmp' "
&_DEFINE_BAR 	
	
_ON_SELECTION_BAR_TERMINA="ON SELECTION BAR "+ALLTRIM(STR(_ULTIMA_VOCE_PRIMO_MENU+2))+" OF "+ALLTRIM(_PRIMO_MENU)+" DO FINE_LAVORO"
&_ON_SELECTION_BAR_TERMINA


RETURN


*********************************************************
PROCEDURE FINE_LAVORO
*********************************************************
IF !FILE("SVILUPPO.TB")
	DO PLAYWAV WITH "PROMEMOR.WAV"
	DO PLAYWAV WITH ""
ENDIF
CLEAR EVENTS
