PROCEDURE RIEPILOGO_DETTAGLI_FLGREGOLA2_COMMESSA
******************************************************************************
*** GESTIONE STAMPA DETTAGLI FATTURA RIEPILOGATI IN UNA SOLA RIGA SE CODIFICATO IN APPOSITA OPZIONE COMMESSA

SELECT HEADER_FATTURA_ELETTRONICA
GO TOP
IF !EMPTY(ALLTRIM(ORD_NUMCOC)) .AND. !EMPTY(ALLTRIM(ORD_DATCOC))
ELSE
	RETURN
ENDIF

_FLGREGOLA2 = .F.
x_ncoc = "codice = '" + ALLTRIM(ORD_NUMCOC) + "'"
x_dcoc = "d_data = '" + RIBALTA2(ORD_DATCOC) + "'"
x_cond = x_ncoc + " and " + x_dcoc 
Csql	= "select FLGREGOLA2 from commessa_tt where " + x_cond
IF !ExecCommand(cSql,"FLG_COMMESSA_TT")
	return(.f.)
ENDIF
SELECT FLG_COMMESSA_TT
GO TOP
IF !EOF()
	_FLGREGOLA2 = FLGREGOLA2
ENDIF
IF _FLGREGOLA2 
	SELECT * FROM FatturaElettronica ORDER BY NR_RIGA INTO CURSOR FatturaElettronica_temp READWRITE
	
	* CONSIDERO IL PRIMO RECORD VALORIZZATO COME BASE PER COSTRUIRE ALCUNI CAMPI DEL RECORD RIEPILOGATIVO
	SELECT FatturaElettronica_temp
	GO TOP
	SCAN
		IF CODICE_VALORE <> '*** COMMENTO ***'
			SCATTER MEMVAR MEMO
			EXIT
		ENDIF
	ENDSCAN
	
	* ELIMINO TUTTE LE RIGHE FATTURA ELETTRONICA CON RIFERIMENTO A SOGGETTI RISORSE
	DELETE FROM FatturaElettronica_temp WHERE !EMPTY(ALLTRIM(ORD_CODSOG))
	
	* ELIMINO TUTTE LE RIGHE FATTURA ELETTRONICA CON COMMENTI "-"
	DELETE FROM FatturaElettronica_temp WHERE CODICE_VALORE = '*** COMMENTO ***' AND ALLTRIM(ORD_DESART) = '-'
	
	* RINUMERO LE RIGHE FATTURA ELETTRONICA E CONTEMPORANEAMENTE SCALO DAL VALORE TOTALE DOCUMENTO GLI IMPORTI RIMANENTI DIVERSI DAI SOGGETTI RISORSE
	_DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE = 0
	SELECT RIEPILOGO_IVA
	GO TOP
	SCAN
		_DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE = _DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE + DATIRIEPILOGOIMPONIBILEIMPORTO
	ENDSCAN
	GO TOP
	
	SELECT FatturaElettronica_temp
	_NR_RIGA = 0
	GO TOP
	SCAN
		_NR_RIGA = _NR_RIGA + 1
		REPLACE NR_RIGA WITH _NR_RIGA
		_DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE = _DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE - ORD_VALORE
	ENDSCAN
	_DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE = ROUND(_DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE,2)
	
	* INSERISCO RECORD RIEPILOGATIVO NEL CURSORE TEMPORANEO 
	SELECT FatturaElettronica_temp
	APPEND BLANK
	GATHER MEMVAR MEMO
	_NR_RIGA = _NR_RIGA + 1
	REPLACE NR_RIGA WITH _NR_RIGA
	REPLACE ORD_QTAORD WITH 1
	REPLACE CODICE_TIPO WITH "ART"
	REPLACE CODICE_VALORE WITH "."
	REPLACE ORD_CODART WITH "."
	REPLACE ORD_DESART WITH PARSE_STRING_XML("RIEPILOGO ATTIVITŔ SVOLTE")
	REPLACE ORD_PREZZO WITH _DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE
	REPLACE IMPORTO_SCONTO WITH 0
	REPLACE ORD_SC1 WITH 0
	REPLACE ORD_SC2 WITH 0
	REPLACE ORD_SC3 WITH 0
	REPLACE ORD_SC4 WITH 0
	REPLACE ORD_SC5 WITH 0
	REPLACE DETTAGLIOLINEESCONTOMAGGIORAZIONE WITH ""
	REPLACE ORD_PRZNET WITH _DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE
	REPLACE ORD_VALORE WITH _DATIRIEPILOGOIMPONIBILEIMPORTO_TOTALE
	REPLACE DettaglioLineeAliquotaIVA WITH M.DettaglioLineeAliquotaIVA 
	REPLACE DETTAGLIOLINEENATURAIVA WITH M.DETTAGLIOLINEENATURAIVA 
	REPLACE DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE WITH M.DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE 
	REPLACE DETTAGLIOLINEETIPOCESSIONEPRESTAZIONE WITH ""
	REPLACE ORD_IVA WITH M.ORD_IVA
	REPLACE ORD_CODSOG WITH ""
	
	* SOSTITUISCO I DETTAGLI FATTURA ELETTRONICA CON I RECORD DEL CURSORE TEMPORANEO
	SELECT FatturaElettronica
	ZAP
	INSERT INTO FatturaElettronica SELECT * FROM FatturaElettronica_Temp
	
	* ELIMINO PER SEMPLIFICAZIONE TUTTI I RIFERIMENTI DDT
	SELECT RIFERIMENTI_DDT
	ZAP
	
	* ELIMINO PER SEMPLIFICAZIONE TUTTI I RIFERIMENTI ORDINI
	SELECT RIFERIMENTI_ORDINE
	ZAP		
ENDIF

ENDPROC
