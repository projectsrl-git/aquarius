******************************************************************************
PROCEDURE CREA_CURSOR_RIEPILOGO_IVA
******************************************************************************
RELEASE IVA1,IVA2,IVA3,IVA4,IVA5,IMPO1,IMPO2,IMPO3,IMPO4,IMPO5,IMPOS1,IMPOS2,IMPOS3,IMPOS4,IMPOS5
RELEASE V_SPINCA,V_SPTRAS
RELEASE DIVA1,DIVA2,DIVA3,DIVA4,DIVA5
RELEASE PIVA1,PIVA2,PIVA3,PIVA4,PIVA5
RELEASE M.T_OMAGGIO,M.I_OMAGGIO
RELEASE _CNT_PUBBLI,_CNT_ARTICOLI,PUB_TOTPOLIECO 
RELEASE _CNT_OMAGGI,_IMPONIBILE_POLIECO,_IMPOSTA_POLIECO
RELEASE MATPUB
RELEASE V_SPESE,V_IMPSP,V_ALRID
RELEASE NETTO
RELEASE V_IVASPTRAS

IVA1      = ""
IVA2      = ""
IVA3      = ""
IVA4      = ""
IVA5      = ""

IMPO1     = 0
IMPO2     = 0
IMPO3     = 0
IMPO4     = 0
IMPO5     = 0

IMPOS1    = 0
IMPOS2    = 0
IMPOS3    = 0
IMPOS4    = 0
IMPOS5    = 0

V_SPINCA  = 0
V_SPTRAS  = 0

DIVA1     = ""
DIVA2     = ""
DIVA3     = ""
DIVA4     = ""
DIVA5     = ""

PIVA1     = ""
PIVA2     = ""
PIVA3     = ""
PIVA4     = ""
PIVA5     = ""

M.T_OMAGGIO = 0
M.I_OMAGGIO = 0

_CNT_PUBBLI 	= 0		&& CONTATORE DI ARTICOLI PUBBLICITARI
_CNT_ARTICOLI 	= 0		&& CONTATORE DI ARTICOLI DI VENDITA
PUB_TOTPOLIECO  = 0		&& CALCOLO POLIECO

_CNT_OMAGGI 		= 0		&& CONTATORE DI ARTICOLI OMAGGIO CON IVA A CARICO AZIENDA
_IMPONIBILE_POLIECO = 0
_IMPOSTA_POLIECO    = 0 

MATPUB = 0   && MATERIALE PUBBLICITARIO

V_SPESE = 0
V_IMPSP = 0
V_ALRID = ""

NETTO = 0

V_IVASPTRAS = ""


*CREATE CURSOR RIEPILOGO_IVA (NR_RIGA N(4,0), DATIRIEPILOGOALIQUOTAIVA N(10,2), DATIRIEPILOGONATURA C(20), DATIRIEPILOGOIMPONIBILEIMPORTO N(19,2), DATIRIEPILOGOIMPOSTA N(19,2), DATIRIEPILOGOESIGIBILITAIVA C(1), DATIRIEPILOGOSPESEACCESSORIE C(254))
*CREATE CURSOR RIEPILOGO_IVA (NR_RIGA N(4,0), DATIRIEPILOGOALIQUOTAIVA N(10,2), DATIRIEPILOGONATURA C(20), DATIRIEPILOGOIMPONIBILEIMPORTO N(19,2), DATIRIEPILOGOIMPOSTA N(19,2), ;
	DATIRIEPILOGOESIGIBILITAIVA C(1), DATIRIEPILOGOSPESEACCESSORIE C(254), DATIRIEPILOGOARROTONDAMENTO C(50))  && ERASMO - 08/02/2019
*!*	CREATE CURSOR RIEPILOGO_IVA (NR_RIGA N(4,0), DATIRIEPILOGOALIQUOTAIVA N(10,2), DATIRIEPILOGONATURA C(20), DATIRIEPILOGOIMPONIBILEIMPORTO N(19,2), DATIRIEPILOGOIMPOSTA N(19,2), ;
*!*		DATIRIEPILOGOESIGIBILITAIVA C(1), DATIRIEPILOGOSPESEACCESSORIE C(254), DATIRIEPILOGOARROTONDAMENTO C(50), CODICE_IVA C(3), TIPO_SPESE_ACCESSORIE C(10))  && ERASMO - 01/04/2019
*!*	CREATE CURSOR RIEPILOGO_IVA (NR_RIGA N(4,0), DATIRIEPILOGOALIQUOTAIVA N(10,2), DATIRIEPILOGONATURA C(20), DATIRIEPILOGOIMPONIBILEIMPORTO N(19,2), DATIRIEPILOGOIMPOSTA N(19,2), ;
*!*		DATIRIEPILOGOESIGIBILITAIVA C(1), DATIRIEPILOGOSPESEACCESSORIE C(254), DATIRIEPILOGOARROTONDAMENTO C(50), CODICE_IVA C(3), TIPO_SPESE_ACCESSORIE C(10), DATIRIEPILOGORIFERIMENTONORMATIVO C(254))  && ERASMO - 22/05/2020
CREATE CURSOR RIEPILOGO_IVA (NR_RIGA N(4,0), DATIRIEPILOGOALIQUOTAIVA N(10,2), DATIRIEPILOGONATURA C(30), DATIRIEPILOGOIMPONIBILEIMPORTO N(19,2), DATIRIEPILOGOIMPOSTA N(19,2), ;
	DATIRIEPILOGOESIGIBILITAIVA C(1), DATIRIEPILOGOSPESEACCESSORIE C(254), DATIRIEPILOGOARROTONDAMENTO C(50), CODICE_IVA C(3), TIPO_SPESE_ACCESSORIE C(10), DATIRIEPILOGORIFERIMENTONORMATIVO C(254))  && ERASMO - 14/12/2020
	
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	--SELECT TT.ORD_CODCLI AS TT_CODCLI, TT.ORD_SPBOLL AS TT_ORD_SPBOLL, TT.ORD_SPTRAS AS TT_ORD_SPTRAS, DD.* FROM U_FAT_DD AS DD
	SELECT TT.ORD_CODCLI AS TT_CODCLI, TT.ORD_SPBOLL AS TT_ORD_SPBOLL, TT.ORD_SPTRAS AS TT_ORD_SPTRAS, TT.T_ENPACL, DD.* FROM U_FAT_DD AS DD  -- ERASMO - 19/12/2025
	LEFT OUTER JOIN U_FAT_TT AS TT
	ON DD.DAGGANCIO=TT.TAGGANCIO
	--LEFT OUTER JOIN PARA AS IVA
	--ON 'IVA'+DD.ORD_IVA = IVA.CODICE
	--LEFT OUTER JOIN U_ART_PR AS PR
	--ON DD.ORD_CODART = PR.ART_CODPRI
	--WHERE DD.ORD_QTAORD>0 AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'
	WHERE DD.ORD_QTAORD>0 AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>' AND TT.TAGGANCIO='<<_TAGGANCIO>>'  -- ERASMO - 06/02/2019
	ORDER BY DD.ORD_SEQUEN
ENDTEXT					&& FINE SCRITTURA QUERY
IF !ExecPreparedCommand(cSql,"TMP_FAT_DD")
	return(.F.)
ENDIF
SELECT TMP_FAT_DD
GO TOP
IF EOF()
	MESSAGEBOX("Dettagli fattura '" + _NUMERO_FATTURA + "' non trovati",16,"Attenzione")
	RETURN .F.
ENDIF

V_CODCLI = TT_CODCLI
V_SPINCA = TT_ORD_SPBOLL   && SPESE INCASSO
V_SPTRAS = TT_ORD_SPTRAS   && SPESE TRASPORTO

v_seek	= PUB_CODSOC + V_CODCLI
v_chiave = "cli_codsoc+cli_codcli"
IF seek_std('u_cli_an',v_seek,v_chiave,'CUR_CLIENTE')
   SELECT CUR_CLIENTE
   V_ALRID = CLI_ALRID
ENDIF

v_seek	= PUB_CODSOC + V_CODCLI
v_chiave = "cli_codsoc+cli_codcli"
IF seek_std('u_ana_cl',v_seek,v_chiave,'CUR_ANA_CL')
   SELECT CUR_ANA_CL
   V_IVASPTRAS = CLI_IVASPTRAS
ENDIF

SELECT TMP_FAT_DD
GO TOP
COD_IVA = ""
DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
      SELECT TMP_FAT_DD
      SKIP +1
      LOOP
   ENDIF

   COD_IVA = ORD_IVA
   IMPONIB = ORD_VALORE
   DES_ART = SUBSTR(ORD_DESART,1,16)

   IF ALLTRIM(ORD_DESART) <> "*** COMMENTO ***"   && CONTO SOLO LE RIGHE CHE NON SONO COMMENTI
	   IF SUBSTR(ORD_CODART,1,7) <> 'POLIECO'
	   		_CNT_ARTICOLI = _CNT_ARTICOLI + 1
	   ENDIF
   ENDIF   
   IF SUBSTR(ORD_CODART,1,7) = 'POLIECO'
   		PUB_TOTPOLIECO = PUB_TOTPOLIECO + ORD_VALORE
   ENDIF   


   * VERIFICA SE DEVE STAMPARE LA RIGA IN MODO SINTETICO
   =VERYSIN("TMP_FAT_DD")

   IF ORD_PUBBLI = "S"			 && MATERIALE PUBBLICITARIO SI PAGA SOLO IVA
      MATPUB   = MATPUB + IMPONIB
      _CNT_PUBBLI = _CNT_PUBBLI + 1		
   ENDIF

   v_seek 	 = 'IVA'+COD_IVA
   v_chiave  = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      ALIQ = SUBSTR(LIBERA,1,3)
      NUM_ALIQ = VAL(ALIQ)
   ELSE
      NUM_ALIQ = 0
   ENDIF
   SELECT TMP_FAT_DD

   IMPOSTA = (IMPONIB * NUM_ALIQ) / 100
   
   IF ORD_PUBBLI = "O"						&& CONTA ARTICOLO OMAGGIO
	   _CNT_OMAGGI = _CNT_OMAGGI + 1		
   ENDIF

   IF SUBSTR(ORD_CODART,1,7) = 'POLIECO' 	&& CALCOLO IMPONIBILE E IMPOSTA POLIECO
 		_IMPONIBILE_POLIECO = _IMPONIBILE_POLIECO + IMPONIB
		_IMPOSTA_POLIECO    = _IMPOSTA_POLIECO    + IMPOSTA  	   
   ENDIF
   
   IF ORD_PUBBLI = "O"			&& MATERIALEIN OMAGGIO CON IVA A CARICO AZIENDA
      M.T_OMAGGIO = M.T_OMAGGIO + IMPONIB
      M.I_OMAGGIO = M.I_OMAGGIO + IMPOSTA
      *** ERASMO - 18/01/2019 - IN CASO DI FATTURAZIONE ELETTRONICA GLI ARTICOLI OMAGGIO E PUBBLICITARI ENTRANO COMUNQUE NEL CALCOLO DEL RIEPILOGO IVA
      *SKIP +1
      *LOOP
   ENDIF

   IF ((IVA1 = SPACE(3)) .OR. (IVA1 = COD_IVA)) .AND. (DES_ART <> ('*** COMMENTO ***'))
      IVA1   = COD_IVA
      IMPO1  = IMPO1+IMPONIB
      IMPOS1 = IMPOS1 + IMPOSTA
   ELSE
      IF ((IVA2 = SPACE(3)) .OR. (IVA2 = COD_IVA))  .AND. (DES_ART <> ('*** COMMENTO ***'))
         IVA2   = COD_IVA
         IMPO2  = IMPO2+IMPONIB
         IMPOS2 = IMPOS2 + IMPOSTA
      ELSE
         IF ((IVA3 = SPACE(3)) .OR. (IVA3 = COD_IVA)) .AND. (DES_ART <> ('*** COMMENTO ***'))
            IVA3   = COD_IVA
            IMPO3  = IMPO3+IMPONIB
            IMPOS3 = IMPOS3 + IMPOSTA
         ELSE
            IF ((IVA4 = SPACE(3)) .OR. (IVA4 = COD_IVA)) .AND. (DES_ART <> ('*** COMMENTO ***'))
               IVA4   = COD_IVA
               IMPO4  = IMPO4+IMPONIB
               IMPOS4 = IMPOS4 + IMPOSTA
            ELSE
               IF ((IVA5 = SPACE(3)) .OR. (IVA5 = COD_IVA)) .AND. (DES_ART <> ('*** COMMENTO ***'))
                  IVA5   = COD_IVA
                  IMPO5  = IMPO5+IMPONIB
                  IMPOS5 = IMPOS5 + IMPOSTA
               ENDIF
            ENDIF
         ENDIF
      ENDIF
   ENDIF

   SELECT TMP_FAT_DD
   SKIP +1

ENDDO


*** SOMMA SPESE DI TRASPORTO + INCASSO
_lImponibileSPINCA = 0
_lImpostaSPINCA = 0
_lCodIvaSPINCA = ""
IF PUB_NOIVASPINC
	V_SPESE = V_SPTRAS	&& NON DEVE SOMMARE LE SPESE DI INCASSO PERCHE' SU QUELLE NON SI CALCOLANO IMPOSTE
	IF V_SPINCA > 0
		_lImponibileSPINCA = V_SPINCA
		_lImpostaSPINCA = 0
		_lCodIvaSPINCA = PUB_IVASPINC
		**=> ERASMO - INIZIO 23/06/2023
		IF EMPTY(_lCodIvaSPINCA)
			MESSAGEBOX("Inserire il Codice iva spese bolli/incasso riba in esenzione nei parametri aziendali",16,"Attenzione")
			_YES_CONTINUA = .F.
			RETURN .F.
		ENDIF
		**=> ERASMO - FINE 23/06/2023
		*AGGIUNGI_RIGA_SPESE_ACCESSORIE_CURSOR_BODY_FATTURA_ELETTRONICA(_lImponibileSPINCA,_lImpostaSPINCA,_lCodIvaSPINCA,"SPESE INCASSO")
		AGGIUNGI_RIGA_SPESE_ACCESSORIE_CURSOR_BODY_FATTURA_ELETTRONICA(_lImponibileSPINCA,_lImpostaSPINCA,_lCodIvaSPINCA,"SPESE BOLLI/INCASSO")  && ERASMO - 23/06/2023
	ENDIF
ELSE
	V_SPESE = V_SPINCA + V_SPTRAS
ENDIF


PUB_IVADEF = CERCA_IVA_DEFAULT("TMP_FAT_DD","CODICE")  
PUB_ALIQ = CERCA_IVA_DEFAULT("TMP_FAT_DD","ALIQUOTA")  


** --- 4) SE CLIENTE EXTRA CEE GESTISCE IL CODICE IVA SPESE TRASPORTO SE E' STATO CODIFICATI IN ANAGRAFICA CLIENTI ----------------------- *
PIVA1TRA = ""
DIVA_SPESE_TRASPORTO = ""
SAY_IVA_SPESE_TRASPORTO = ""
ALIQTRA = ""
_lCodIvaSP = ""
IF !EMPTY(V_IVASPTRAS)
	_lCodIvaSP  = V_IVASPTRAS
	v_seek 	  = 'IVA'+V_IVASPTRAS
	v_chiave  = "codice"
	IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
	   SELECT CUR_PARA
	   PIVA1TRA	= SUBSTR(LIBERA,1,03)
	   DIVA_SPESE_TRASPORTO	= ALLTRIM(SUBSTR(DESCRI,1,80))
	   SAY_IVA_SPESE_TRASPORTO = DIVA_SPESE_TRASPORTO
       ALIQTRA 	= SUBSTR(LIBERA,1,3)
       NUM_ALIQ = VAL(ALIQTRA)
	   * -------------------------------------------------------------------------- descrizioni in lingua ----------- 'IVA' ---------- *
		DL_TIPODES 		= 'IVA'
		DL_CODICE  		= V_IVASPTRAS
		_DESCR_LINGUA 	= CERCA_DESCRIZIONI_IN_LINGUA(DL_TIPODES,DL_LINGUA,DL_CODICE)
	    IF !EMPTY(_DESCR_LINGUA)
			DIVA_SPESE_TRASPORTO  = _DESCR_LINGUA
		    SAY_IVA_SPESE_TRASPORTO = _DESCR_LINGUA
	    ENDIF
	   * -------------------------------------------------------------------------- descrizioni in lingua ----------  'IVA' ---------- *
    ELSE
       ALIQTRA  = ""
       NUM_ALIQ = 0
       SAY_IVA_SPESE_TRASPORTO = ""
	ENDIF

    V_IMPSP = V_SPESE * (NUM_ALIQ/100)

ELSE
    
	** VERIFICA CHE PERCENTUALE IVA ATTRIBUIRE AL COSTO DEL TRASPORTO :
	** ----------------------------------------------------------------
	** --- 1) SE CLIENTE IN ESENZIONE %PERCENTUALE IVA SUL TRASPORTO E' = 0
	** --- 2) SE CLIENTE CON IVA NON IMPONIBILE (OSSIA PERCENTUALE ULTIMA ALIQUOTA IVA = 0) ANCHE LA %PERCENTUALE IVA SUL TRASPORTO E' = 0
	** --- 3) SE CLIENTE CON IVA IMPONIBILE LA %PERCENTUALE IVA SUL TRASPORTO E' = ALLA %PERCENTUALE IVA DI DEFAULT STANDARD (SE CI SONO DIVERSE ALIQUOTE NE CONSIDERA UNA E NON LA MEDIA)
	** --- 4) SE CLIENTE ETRA CEE GESTISCE IL CODICE IVA SPESE TRASPORTO SE E' STATO CODIFICATI IN ANAGRAFICA CLIENTI

	IF !EMPTY(V_ALRID)
		_lCodIvaSP = V_ALRID
	   	V_IMPSP = 0		 							&& --- 1) SE CLIENTE IN ESENZIONE %PERCENTUALE IVA SUL TRASPORTO E' = 0
	ELSE
		IF NUM_ALIQ = PUB_ALIQ						&& PERCENTUALE DELL'ULTIMA ALIQUOTA IVA PRESENTE NEGLI ARTICOLI
