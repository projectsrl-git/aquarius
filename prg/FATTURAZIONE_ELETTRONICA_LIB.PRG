					WHEN 'IT' THEN '0000000' 
					ELSE 'XXXXXXX' 
				END) 
			ELSE RTRIM(TT.ORD_IDSDI)
		END AS ORD_IDSDI ,  -- ERASMO - 21/01/2019
		CASE RTRIM(TT.ORD_EPEC) WHEN '' THEN '' ELSE ('<PECDestinatario>'+RTRIM(TT.ORD_EPEC)+'</PECDestinatario>') END AS ORD_EPEC ,  -- ERASMO - 07/11/2018
		TT.ORD_BANCA ,  -- ERASMO - 07/11/2018
		TT.ORD_CODCLI , -- ERASMO - 07/11/2018
		TT.ORD_CPA ,    -- ERASMO - 07/11/2018
		TT.ORD_CAUS ,   -- ERASMO - 07/11/2018
		TT.ORD_NUMORD ,   -- ERASMO - 15/01/2019
