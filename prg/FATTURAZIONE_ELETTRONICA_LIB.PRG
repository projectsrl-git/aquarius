******************************************************************************
PROCEDURE CREA_CURSOR_RIFERIMENTI_DDT
******************************************************************************
*_COND_COMMENTI = IIF(PUB_FECOMM,""," AND DD.ORD_QTAORD>0")  && ERASMO - 22/01/2019
*_COND_COMMENTI = IIF(!PUB_FECOMM," AND DD.ORD_QTAORD>0",IIF(PUB_OPZFECOMM = 2," AND (DD.ORD_QTAORD>0 OR ORD_CODICE <> '')",""))  && ERASMO - 25/02/2021
_COND_COMMENTI = IIF(!PUB_FECOMM," AND DD.ORD_QTAORD>0",IIF(PUB_OPZFECOMM = 3," AND (DD.ORD_QTAORD>0 OR (DD.ORD_CODICE <> '' AND DD.ORD_CODICE IN (SELECT NOT_CODICE FROM NOTE_COM WHERE NOT_FEXML = 1)))", ;
	IIF(PUB_OPZFECOMM = 2," AND (DD.ORD_QTAORD>0 OR DD.ORD_CODICE <> '')","")))  && ERASMO - 25/08/2021

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY DD.ORD_SEQUEN)) AS NUMERIC(4,0)) AS NR_RIGA,  -- ERASMO - 14/01/2019
		DD.ORS_NUMDDT AS DATIDDTNUMERODDT,
		SUBSTRING(DD.ORS_DATDDT,1,4)+'-'+SUBSTRING(DD.ORS_DATDDT,6,2)+'-'+SUBSTRING(DD.ORS_DATDDT,9,2) AS DATIDDTDATA,
		DD.ORD_DESART  -- ERASMO - 22/01/2019
	FROM U_FAT_DD AS DD
	LEFT OUTER JOIN U_FAT_TT AS TT
	ON DD.DAGGANCIO=TT.TAGGANCIO
	--WHERE DD.ORD_QTAORD>0 AND DD.ORS_NUMDDT<>'' AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'
	--WHERE DD.ORD_QTAORD>0 AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'  -- ERASMO - 14/01/2019
	--WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'  <<_COND_COMMENTI>>  -- ERASMO - 22/01/2019
	WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>' AND TT.TAGGANCIO='<<_TAGGANCIO>>'  <<_COND_COMMENTI>>  -- ERASMO - 06/02/2019
	ORDER BY DD.ORD_SEQUEN

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"RIFERIMENTI_DDT")
	return(.F.)
ENDIF

**=> ERASMO - INIZIO 14/01/2019
SELECT RIFERIMENTI_DDT
DELETE FOR EMPTY(DATIDDTNUMERODDT)
DELETE FOR ORD_DESART = '*** COMMENTO ***'  && ERASMO - 22/01/2019
GO TOP
**=> ERASMO - FINE 14/01/2019

RETURN
* FINE PROCEDURE CREA_CURSOR_RIFERIMENTI_DDT
******************************************************************************


**=> ERASMO - INIZIO 07/11/2018
******************************************************************************
PROCEDURE CREA_CURSOR_RIFERIMENTI_ORDINE
******************************************************************************
*_COND_COMMENTI = IIF(PUB_FECOMM,""," AND DD.ORD_QTAORD>0")  && ERASMO - 22/01/2019
*_COND_COMMENTI = IIF(!PUB_FECOMM," AND DD.ORD_QTAORD>0",IIF(PUB_OPZFECOMM = 2," AND (DD.ORD_QTAORD>0 OR ORD_CODICE <> '')",""))  && ERASMO - 25/02/2021
_COND_COMMENTI = IIF(!PUB_FECOMM," AND DD.ORD_QTAORD>0",IIF(PUB_OPZFECOMM = 3," AND (DD.ORD_QTAORD>0 OR (DD.ORD_CODICE <> '' AND DD.ORD_CODICE IN (SELECT NOT_CODICE FROM NOTE_COM WHERE NOT_FEXML = 1)))", ;
	IIF(PUB_OPZFECOMM = 2," AND (DD.ORD_QTAORD>0 OR DD.ORD_CODICE <> '')","")))  && ERASMO - 25/08/2021

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY DD.ORD_SEQUEN)) AS NUMERIC(4,0)) AS NR_RIGA,  -- ERASMO - 14/01/2019
		TT.ORD_NUMORC AS DATIORDINEACQUISTOIDDOCUMENTO,
		REPLACE(TT.ORD_DATORC,'/','-') AS DATIORDINEACQUISTODATA,
		DD.ORS_NUMORC AS DATIORDINEACQUISTOIDDOCUMENTO_DD,
		REPLACE(DD.ORS_DATORC,'/','-') AS DATIORDINEACQUISTODATA_DD,
		CASE WHEN (CL.CLI_PA = 1 AND CL.CLI_IDNSO <> '') THEN '<CodiceCommessaConvenzione>#' + RTRIM(CL.CLI_IDNSO) + '#</CodiceCommessaConvenzione>' ELSE '' END AS CodiceCommessaConvenzione,  -- ERASMO - 16/02/2021
		CASE WHEN TT.ORD_CIG<>'' THEN '<CodiceCIG>'+RTRIM(TT.ORD_CIG)+'</CodiceCIG>' ELSE '' END AS CodiceCIG,
		CASE WHEN TT.ORD_CUP<>'' THEN '<CodiceCUP>'+RTRIM(TT.ORD_CUP)+'</CodiceCUP>' ELSE '' END AS CodiceCUP,
		DD.ORD_SYSFAT AS ORD_SYSFAT,
		DD.ORD_DESART,  -- ERASMO - 22/01/2019
		DD.ORD_LEGSYS AS ORD_LEGSYS,  -- ERASMO - 08/09/2020
		CAST('' AS VARCHAR(50)) AS DATIORDINEACQUISTONUMITEM,  -- ERASMO - 08/09/2020
		DD.ORS_NORCLI,									-- ERASMO - 10/02/2026
		REPLACE(DD.ORS_DORCLI,'/','-') AS ORS_DORCLI,	-- ERASMO - 10/02/2026
		DD.ORS_ITMORC									-- ERASMO - 10/02/2026
	FROM U_FAT_DD AS DD
	LEFT OUTER JOIN U_FAT_TT AS TT ON DD.DAGGANCIO=TT.TAGGANCIO
	LEFT OUTER JOIN U_ANA_CL AS CL ON CL.CLI_CODCLI = TT.ORD_CODCLI
	--WHERE DD.ORD_QTAORD>0 AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'
	--WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'  <<_COND_COMMENTI>>  -- ERASMO - 22/01/2019
	WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>' AND TT.TAGGANCIO='<<_TAGGANCIO>>'  <<_COND_COMMENTI>>  -- ERASMO - 06/02/2019
	ORDER BY DD.ORD_SEQUEN

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"RIFERIMENTI_ORDINE")
	return(.F.)
ENDIF

SELECT RIFERIMENTI_ORDINE
DELETE FOR ORD_DESART = '*** COMMENTO ***'  && ERASMO - 22/01/2019
GO TOP
SCAN	
	_NUMORD = DATIORDINEACQUISTOIDDOCUMENTO_DD
	_DATORD = STRTRAN(DATIORDINEACQUISTODATA_DD,"-","/")
	_SYSFAT = ORD_SYSFAT
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
		SELECT 
			ORD_NUMORC,
			REPLACE(ORD_DATORC,'/','-') AS ORD_DATORC,
			CASE WHEN ORD_CIG<>'' THEN '<CodiceCIG>'+RTRIM(ORD_CIG)+'</CodiceCIG>' ELSE '' END AS ORD_CIG,
			CASE WHEN ORD_CUP<>'' THEN '<CodiceCUP>'+RTRIM(ORD_CUP)+'</CodiceCUP>' ELSE '' END AS ORD_CUP,
			CASE WHEN (ORD_IDNSO <> '') THEN '<CodiceCommessaConvenzione>#' + RTRIM(ORD_IDNSO) + '#</CodiceCommessaConvenzione>' ELSE '' END AS ORD_IDNSO  -- ERASMO - 13/04/2021
		FROM U_ORD_TT
		LEFT OUTER JOIN U_ORD_T2 ON U_ORD_T2.TAGGANCIO = U_ORD_TT.TAGGANCIO  -- ERASMO - 13/04/2021
		WHERE U_ORD_TT.ORD_NUMORD='<<_NUMORD>>' AND U_ORD_TT.ORD_DATORD='<<_DATORD>>'
	ENDTEXT					&& FINE SCRITTURA QUERY
	IF !ExecPreparedCommand(cSql,"TMP_ORD_TT")
		return(.F.)
	ENDIF
	SELECT TMP_ORD_TT
	GO TOP
	IF !EOF()
		SELECT TMP_ORD_TT
		IF !EMPTY(ORD_NUMORC) AND !EMPTY(ORD_DATORC)
			_NUMORC = ORD_NUMORC
			_DATORC = ORD_DATORC
			SELECT RIFERIMENTI_ORDINE
			REPLACE DATIORDINEACQUISTOIDDOCUMENTO WITH _NUMORC
			REPLACE DATIORDINEACQUISTODATA WITH _DATORC
		ENDIF
		SELECT TMP_ORD_TT
		IF !EMPTY(ORD_CIG)
			_CIG = ORD_CIG
			SELECT RIFERIMENTI_ORDINE
			REPLACE CodiceCIG WITH _CIG
		ENDIF
		SELECT TMP_ORD_TT
		IF !EMPTY(ORD_CUP)
			_CUP = ORD_CUP
			SELECT RIFERIMENTI_ORDINE
			REPLACE CodiceCUP WITH _CUP
		ENDIF
		**=> ERASMO - INIZIO 13/04/2021
		SELECT TMP_ORD_TT
		IF !EMPTY(ORD_IDNSO)
			_CodiceCommessaConvenzione = ORD_IDNSO
			SELECT RIFERIMENTI_ORDINE
			REPLACE CodiceCommessaConvenzione WITH _CodiceCommessaConvenzione
		ENDIF
		**=> ERASMO - FINE 13/04/2021
		
		**=> ERASMO - INIZIO 10/02/2026
		*** ATTRIBUZIONE RIFERIMENTI ORDINE IN BASE ALL'ORDINE AQUARIUS LEGATO
		SELECT RIFERIMENTI_ORDINE
		_LEGSYS = ORD_LEGSYS
		TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
			SELECT 
				ORD_LEGSYS
			FROM U_ORD_DD
			WHERE DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORD_TT WHERE ORD_NUMORD='<<_NUMORD>>' AND ORD_DATORD='<<_DATORD>>') AND ORD_DESART <> '*** COMMENTO ***' AND ORD_CODART <> ''
			ORDER BY ORD_SEQUEN
		ENDTEXT					&& FINE SCRITTURA QUERY
		IF !ExecPreparedCommand(cSql,"TMP_ORD_DD")
			return(.F.)
		ENDIF
		_NUMITEM = 0
		_FOUND = .F.
		SELECT TMP_ORD_DD
		GO TOP
		SCAN
			_NUMITEM = _NUMITEM + 1
			IF _LEGSYS = ORD_LEGSYS
				_FOUND = .T.
				EXIT
			ENDIF
		ENDSCAN
		IF _FOUND
			SELECT RIFERIMENTI_ORDINE
			DO CASE
				CASE _FORMATO_TAG_DatiOrdineAcquistoNumItem = "Z3"
					REPLACE DATIORDINEACQUISTONUMITEM WITH PADL(ALLTRIM(STR(_NUMITEM,20,0)),3,'0')	&& 3 CIFRE CON ZERI A SINISTRA (001)
					
				CASE _FORMATO_TAG_DatiOrdineAcquistoNumItem = "Z5"
					REPLACE DATIORDINEACQUISTONUMITEM WITH PADL(ALLTRIM(STR(_NUMITEM,20,0)),5,'0')	&& 5 CIFRE CON ZERI A SINISTRA (001)
					
				OTHERWISE
					REPLACE DATIORDINEACQUISTONUMITEM WITH ALLTRIM(STR(_NUMITEM,20,0))				&& NUMERICO SEMPLICE
			ENDCASE			
		ENDIF
		**=> ERASMO - FINE 10/02/2026
	ELSE
		IF !EMPTY(_SYSFAT)
			TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
				SELECT 
					ORD_NUMORC,
					CASE
						WHEN LTRIM(RTRIM(ORD_DATORC)) = '/  /' THEN ''
						WHEN SUBSTRING(ORD_DATORC,3,1) = '/' AND SUBSTRING(ORD_DATORC,6,1) = '/' THEN REPLACE(DBO.RIBALTA2(ORD_DATORC),'/','-')
						ELSE REPLACE(ORD_DATORC,'/','-')
					END AS ORD_DATORC,
					CASE WHEN ORD_CIG<>'' THEN '<CodiceCIG>'+RTRIM(ORD_CIG)+'</CodiceCIG>' ELSE '' END AS ORD_CIG,
					CASE WHEN ORD_CUP<>'' THEN '<CodiceCUP>'+RTRIM(ORD_CUP)+'</CodiceCUP>' ELSE '' END AS ORD_CUP
				FROM BUDGET_CONS
				WHERE ORD_SYSFAT='<<_SYSFAT>>'
			ENDTEXT					&& FINE SCRITTURA QUERY
			IF !ExecPreparedCommand(cSql,"TMP_BUDGET_CONS")
				return(.F.)
			ENDIF
			SELECT TMP_BUDGET_CONS
			GO TOP
			IF !EOF()
				SELECT TMP_BUDGET_CONS
*!*					IF !EMPTY(ORD_NUMORC) AND !EMPTY(ORD_DATORC)
*!*						_NUMORC = ORD_NUMORC
*!*						_DATORC = ORD_DATORC
*!*						SELECT RIFERIMENTI_ORDINE
*!*						REPLACE DATIORDINEACQUISTOIDDOCUMENTO WITH _NUMORC 
*!*						REPLACE DATIORDINEACQUISTODATA WITH _DATORC 
*!*					ENDIF
				**=> ERASMO - INIZIO 06/05/2021
				_NUMORC = ORD_NUMORC
				_DATORC = ORD_DATORC
				SELECT RIFERIMENTI_ORDINE
				REPLACE DATIORDINEACQUISTOIDDOCUMENTO WITH _NUMORC 
				REPLACE DATIORDINEACQUISTODATA WITH _DATORC 
				**=> ERASMO - FINE 06/05/2021
				
				SELECT TMP_BUDGET_CONS
				IF !EMPTY(ORD_CIG)
					_CIG = ORD_CIG
					SELECT RIFERIMENTI_ORDINE
					REPLACE CodiceCIG WITH _CIG
				ENDIF
				SELECT TMP_BUDGET_CONS
				IF !EMPTY(ORD_CUP)
					_CUP = ORD_CUP
					SELECT RIFERIMENTI_ORDINE
					REPLACE CodiceCUP WITH _CUP
				ENDIF
			ENDIF
		ENDIF
	ENDIF
		
*!*		**=> ERASMO - INIZIO 08/09/2020
*!*		SELECT RIFERIMENTI_ORDINE
*!*		_LEGSYS = ORD_LEGSYS
*!*		TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
*!*			SELECT 
*!*				ORD_LEGSYS
*!*			FROM U_ORD_DD
*!*			WHERE DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORD_TT WHERE ORD_NUMORD='<<_NUMORD>>' AND ORD_DATORD='<<_DATORD>>')
*!*			ORDER BY ORD_SEQUEN
*!*		ENDTEXT					&& FINE SCRITTURA QUERY
*!*		IF !ExecPreparedCommand(cSql,"TMP_ORD_DD")
*!*			return(.F.)
*!*		ENDIF
*!*		_NUMITEM = 0
*!*		_FOUND = .F.
*!*		SELECT TMP_ORD_DD
*!*		GO TOP
*!*		SCAN
*!*			_NUMITEM = _NUMITEM + 1
*!*			IF _LEGSYS = ORD_LEGSYS
*!*				_FOUND = .T.
*!*				EXIT
*!*			ENDIF
*!*		ENDSCAN
*!*		IF _FOUND
*!*			SELECT RIFERIMENTI_ORDINE
*!*			REPLACE DATIORDINEACQUISTONUMITEM WITH ALLTRIM(STR(_NUMITEM,20,0))
*!*		ENDIF
*!*		**=> ERASMO - FINE 08/09/2020
	
	**=> ERASMO - INIZIO 10/02/2026
	*** ATTRIBUZIONE RIFERIMENTI ORDINE IN BASE AI RIFERIMENTI DIGITATI MANUALMENTE NEI CAMPI SPECIFICI
	SELECT RIFERIMENTI_ORDINE
	IF !EMPTY(ALLTRIM(ORS_NORCLI))
		SELECT RIFERIMENTI_ORDINE
		REPLACE DATIORDINEACQUISTOIDDOCUMENTO WITH ALLTRIM(ORS_NORCLI)
		REPLACE DATIORDINEACQUISTODATA WITH ORS_DORCLI
		REPLACE DATIORDINEACQUISTONUMITEM WITH ALLTRIM(ORS_ITMORC)
	ENDIF
	**=> ERASMO - FINE 10/02/2026
	
ENDSCAN

**=> ERASMO - INIZIO 14/01/2019
*** INCLUDO INIZIO E FINE TAG NELLA DATA ORDINE, IN QUANTO LA DATA POTREBBE NON ESSERE PRESENTE, E NON E' OBBLIGATORIA
SELECT RIFERIMENTI_ORDINE
GO TOP
SCAN
*!*		IF !EMPTY(DATIORDINEACQUISTODATA)
*!*			REPLACE DATIORDINEACQUISTODATA WITH "<Data>"+DATIORDINEACQUISTODATA+"</Data>"
*!*		ENDIF
	**=> ERASMO - INIZIO 28/01/2019
	IF !EMPTY(ALLTRIM(DATIORDINEACQUISTODATA))
		REPLACE DATIORDINEACQUISTODATA WITH "<Data>"+DATIORDINEACQUISTODATA+"</Data>"
	ELSE
		REPLACE DATIORDINEACQUISTODATA WITH ""
	ENDIF
	**=> ERASMO - FINE 28/01/2019
	**=> ERASMO - INIZIO 28/02/2019
	IF !EMPTY(ALLTRIM(DATIORDINEACQUISTOIDDOCUMENTO))
		REPLACE DATIORDINEACQUISTOIDDOCUMENTO WITH PARSE_STRING_XML(ALLTRIM(DATIORDINEACQUISTOIDDOCUMENTO))
	ELSE
		REPLACE DATIORDINEACQUISTOIDDOCUMENTO WITH ""
	ENDIF
	**=> ERASMO - FINE 28/02/2019
	**=> ERASMO - INIZIO 08/09/2020
	IF !EMPTY(ALLTRIM(DATIORDINEACQUISTONUMITEM))
		REPLACE DATIORDINEACQUISTONUMITEM WITH "<NumItem>"+ALLTRIM(DATIORDINEACQUISTONUMITEM)+"</NumItem>"
	ELSE
		REPLACE DATIORDINEACQUISTONUMITEM WITH ""
	ENDIF
	**=> ERASMO - FINE 08/09/2020
ENDSCAN
GO TOP
**=> ERASMO - FINE 14/01/2019

SELECT RIFERIMENTI_ORDINE
*DELETE FOR EMPTY(DATIORDINEACQUISTOIDDOCUMENTO+DATIORDINEACQUISTODATA+CodiceCIG+CodiceCUP)
DELETE FOR EMPTY(DATIORDINEACQUISTOIDDOCUMENTO)  && ERASMO - 14/01/2019
GO TOP

RETURN
* FINE PROCEDURE CREA_CURSOR_RIFERIMENTI_ORDINE
******************************************************************************
**=> ERASMO - FINE 07/11/2018


******************************************************************************
PROCEDURE APPEND_XML_FILE
******************************************************************************

LPARAMETERS P_CURSOR,P_XML_STRING,P_XML_FILE

LOCAL _XML_STRING

SELECT &P_CURSOR
GO TOP

_NUMERO_RIGA=0

SCAN 

	_XML_STRING = P_XML_STRING

	*_NUMERO_RIGA= _NUMERO_RIGA+1
	_NUMERO_RIGA = NR_RIGA  && ERASMO - 14/01/2019
	
	*_XML_STRING = STRTRAN(_XML_STRING ,"#NUMERO_RIGA#"  ,ALLTRIM(STR(_NUMERO_RIGA,2,0)))
	_XML_STRING = STRTRAN(_XML_STRING ,"#NUMERO_RIGA#"  ,ALLTRIM(STR(_NUMERO_RIGA,4,0)))  && ERASMO - 07/11/2018

	_XML_STRING =SOSTITUISCE_CAMPI_CURSOR_SU_TESTO(P_CURSOR,_XML_STRING )

	STRTOFILE(_XML_STRING ,P_XML_FILE,1)
	
ENDSCAN

RETURN
* FINE PROCEDURE APPEND_XML_FILE
******************************************************************************


******************************************************************************
PROCEDURE SOSTITUISCE_CAMPI_CURSOR_SU_TESTO
******************************************************************************

LPARAMETERS P_CURSOR,P_XML_STRING

LOCAL _XML_STRING

_XML_STRING = P_XML_STRING

SELECT &P_CURSOR

SCATTER MEMVAR MEMO

_NUMERO_CAMPI=AFIELDS(_ARRAY_CAMPI_CURSOR)

FOR nCount  = 1 TO _NUMERO_CAMPI
	_NOME_CAMPO="M."+ALLTRIM(_ARRAY_CAMPI_CURSOR(nCount ,1))
	_NOME_TAG  ="#"+ALLTRIM(_ARRAY_CAMPI_CURSOR(nCount ,1))+"#"
	
	DO CASE
		 *CASE _ARRAY_CAMPI_CURSOR(nCount ,2) = "C"
		 CASE _ARRAY_CAMPI_CURSOR(nCount ,2) $ "C;M"  && ERASMO - 07/11/2018
			_VALORE_CAMPO=EVALUATE("ALLTRIM("+_NOME_CAMPO+")")
		 CASE _ARRAY_CAMPI_CURSOR(nCount ,2) = "N"
		 	_DIMENSIONE= _ARRAY_CAMPI_CURSOR(nCount ,3)
		 	_DECIMALI= _ARRAY_CAMPI_CURSOR(nCount ,4)
		 	IF _DECIMALI>0
				_VALORE_CAMPO=EVALUATE("STRTRAN(ALLTRIM(STR("+_NOME_CAMPO+","+STR(_DIMENSIONE,3,0)+",2)),',','.')")
				*IF _NOME_CAMPO = "M.ORD_PREZZO"
				IF _NOME_CAMPO = "M.ORD_PREZZO"
					_VALORE_CAMPO=EVALUATE("STRTRAN(ALLTRIM(STR("+_NOME_CAMPO+","+STR(_DIMENSIONE,3,0)+",6)),',','.')")
				ENDIF
				**=> ERASMO - INIZIO 14/01/2019
*!*					IF _NOME_CAMPO = "M.IMPORTO_SCONTO" AND M.IMPORTO_SCONTO > 0
*!*						_VALORE_CAMPO=EVALUATE("STRTRAN(ALLTRIM(STR("+_NOME_CAMPO+","+STR(_DIMENSIONE,3,0)+",6)),',','.')")
*!*					ENDIF
				IF _NOME_CAMPO = "M.ORD_QTAORD"
					_VALORE_CAMPO=EVALUATE("STRTRAN(ALLTRIM(STR("+_NOME_CAMPO+","+STR(_DIMENSIONE,3,0)+",4)),',','.')")
				ENDIF
				**=> ERASMO - FINE 14/01/2019
			ELSE
				_VALORE_CAMPO=EVALUATE("ALLTRIM(STR("+_NOME_CAMPO+","+STR(_DIMENSIONE,3,0)+",0))")
			ENDIF					
			
	ENDCASE
	
	_XML_STRING= STRTRAN(_XML_STRING,_NOME_TAG  ,_VALORE_CAMPO)
	
ENDFOR

RETURN _XML_STRING

