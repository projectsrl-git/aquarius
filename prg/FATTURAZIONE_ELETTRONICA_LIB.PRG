******************************************************************************
PROCEDURE CREA_CURSOR_HEADER_FATTURA_ELETTRONICA
******************************************************************************
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY TT.ORD_NUMORD)) AS NUMERIC(4,0)) AS NR_RIGA,  -- ERASMO - 14/01/2019
		TT.TAGGANCIO,  -- ERASMO - 14/12/2018
		TT.ORD_VALORE,
		TT.ORD_VALORE+ROUND(TT.I_OMAGGIO,2)+ROUND(TT.T_OMAGGIO,2) AS IMPORTOTOTALEDOCUMENTO,  -- ERASMO - 18/01/2019
		CASE --ORD_CAUS
			--WHEN 'FVS' THEN
			--	CASE
			--		WHEN (SELECT COUNT(*) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' AND ORD_IVA = 'SP') > 0 THEN 'S'
			--		ELSE 'D'
			--	END
			--ELSE 'I'
			WHEN (SELECT COUNT(*) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' AND ORD_IVA IN 
				(SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND NOIVACARCLI = 'S')) > 0 THEN 'S'  -- ERASMO - 07/11/2018
			ELSE 'I'  -- ERASMO - 07/11/2018
		END AS ESIGIBILITA_IVA,
		CASE
