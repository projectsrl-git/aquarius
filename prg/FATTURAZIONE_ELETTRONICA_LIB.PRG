		--TT.ord_numorc AS DatiOrdineAcquistoIdDocumento,
		TT.ORD_VALUTA ,
		TT.ORD_PARIVA ,
		--TT.ORD_RAGSOC ,
		SUBSTRING(TT.ORD_RAGSOC,1,80) AS ORD_RAGSOC,  -- ERASMO - 21/01/2019
