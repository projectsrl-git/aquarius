	SCAN
		_FULLPATH = _V_PATH_DESTIN + "\" + ALLTRIM(FILENAME)
		
		IF FILE(ALLTRIM(_FULLPATH))
			*_NOME_ALLEGATO = JUSTFNAME(ALLTRIM(_FULLPATH))
			_NOME_ALLEGATO = PARSE_STRING_XML(JUSTFNAME(ALLTRIM(_FULLPATH)))  && ERASMO - 02/04/2021
			_FILE_ALLEGATO_STR_BASE64BINARY = STRCONV(FILETOSTR(ALLTRIM(_FULLPATH)),13)
			SELECT HEADER_FATTURA_ELETTRONICA
			GO TOP
			REPLACE ALLEGATI WITH IIF(!EMPTY(ALLEGATI),RTRIM(ALLEGATI)+CHR(10)+SPACE(8),"")+"<Allegati>"+CHR(10)+SPACE(12)+"<NomeAttachment>"+_NOME_ALLEGATO+"</NomeAttachment>"+CHR(10)+SPACE(12)+;
				"<Attachment>"+_FILE_ALLEGATO_STR_BASE64BINARY+"</Attachment>"+CHR(10)+SPACE(8)+"</Allegati>"
		ENDIF
		
	ENDSCAN
ENDIF
**=> ERASMO - FINE 14/12/2018

RETURN
