						'<CodiceFiscale>'+RTRIM((SELECT CLI_CODFIS FROM U_CLI_AN WHERE CLI_CODCLI = TT.ORD_CODCLI))+'</CodiceFiscale>'																								-- ERASMO - 09/08/2019
					WHEN RTRIM(TT.ORD_PARIVA) = RTRIM((SELECT CLI_PARIVA FROM U_CLI_AN WHERE CLI_CODCLI = TT.ORD_CODCLI)) THEN '<IdFiscaleIVA><IdPaese>IT</IdPaese><IdCodice>'+RTRIM(TT.ORD_PARIVA)+'</IdCodice></IdFiscaleIVA>'	-- ERASMO - 16/01/2019
					WHEN RTRIM(TT.ORD_PARIVA) = RTRIM((SELECT CLI_CODFIS FROM U_CLI_AN WHERE CLI_CODCLI = TT.ORD_CODCLI)) THEN '<CodiceFiscale>'+RTRIM(TT.ORD_PARIVA)+'</CodiceFiscale>'											-- ERASMO - 16/01/2019
					ELSE '<IdFiscaleIVA><IdPaese>IT</IdPaese><IdCodice>'+RTRIM(TT.ORD_PARIVA)+'</IdCodice></IdFiscaleIVA>'																											-- ERASMO - 16/01/2019
				END																																																					-- ERASMO - 16/01/2019
				--ELSE '<IdFiscaleIVA><IdPaese>'+(SELECT RTRIM(LIBERA) FROM PARA WHERE CODICE = 'STA'+TT.ORD_CODNAZ)+'</IdPaese><IdCodice>'+RTRIM(TT.ORD_PARIVA)+'</IdCodice></IdFiscaleIVA>'											-- ERASMO - 16/01/2019
				ELSE '<IdFiscaleIVA><IdPaese>'+(SELECT RTRIM(LIBERA) FROM PARA WHERE CODICE = 'STA'+TT.ORD_CODNAZ)+'</IdPaese><IdCodice>' +
					CASE
						WHEN SUBSTRING(TT.ORD_PARIVA,1,2) = (SELECT LIBERA FROM PARA WHERE CODICE = 'STA'+TT.ORD_CODNAZ) THEN RTRIM(SUBSTRING(TT.ORD_PARIVA,3,18))
						ELSE RTRIM(TT.ORD_PARIVA)
					END + '</IdCodice></IdFiscaleIVA>'  -- ERASMO - 30/09/2021
		END AS CESSIONARIOCOMMITTENTEDATIANAGRAFICIIDFISCALEIVA,
		CASE
			WHEN TT.ORD_BOVIRT > 0 THEN ('<DatiBollo><BolloVirtuale>SI</BolloVirtuale><ImportoBollo>'+RTRIM(CAST(TT.ORD_BOVIRT AS VARCHAR(15)))+'</ImportoBollo></DatiBollo>')
			ELSE ''
		END AS DATIGENERALIDOCUMENTODATIBOLLOBOLLOVIRTUALE,  -- ERASMO - 04/02/2019
		TT.ORD_NUMLEI,  -- ERASMO - 04/02/2019
		TT.ORD_DATLEI,  -- ERASMO - 04/02/2019
		TT.ORD_CAMBIO,  -- ERASMO - 06/02/2019
		SPACE(50) AS DATIGENERALIDOCUMENTOARROTONDAMENTO,  -- ERASMO - 08/02/2019
		--TT.ORD_FECAUS AS DATIGENERALIDOCUMENTOCAUSALE,  -- ERASMO - 28/02/2019
		CAST(TT.ORD_FECAUS AS VARCHAR(254)) AS DATIGENERALIDOCUMENTOCAUSALE,  -- ERASMO - 11/05/2021
		TT.ORD_NRPLEI,  -- ERASMO - 06/09/2019
		TT.ORD_DTPLEI,  -- ERASMO - 06/09/2019
		TT.ORD_NUMCOC,  -- ERASMO - 07/05/2021
		TT.ORD_DATCOC,   -- ERASMO - 07/05/2021
		TT.T_RA,														-- ERASMO - 22/11/2023
		AN.CLI_RA,														-- ERASMO - 22/11/2023
		CAST('' AS VARCHAR(200)) AS DATIGENERALIDOCUMENTODATIRITENUTA,	-- ERASMO - 22/11/2023
		COALESCE(CL.CLI_IDSDI,'') AS CLI_IDSDI,  -- ERASMO/SERGIO - 03/06/2025
		TT.T_ENPACL,																						-- ERASMO - 19/12/2025
		AN.CLI_ENPACL,																						-- ERASMO - 19/12/2025
		COALESCE((SELECT CAST(SUBSTRING(LIBERA,1,3) AS NUMERIC(6,2)) FROM PARA WHERE CODICE = 'IVA'+
			(SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO)),0) AS ALIQ_IVA_ENPACL,		-- ERASMO - 19/12/2025
		COALESCE((SELECT RTRIM(SUBSTRING(LIBERA,145,4)) FROM PARA WHERE CODICE = 'IVA'+
			(SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO)),'') AS NATURA_IVA_ENPACL,	-- ERASMO - 19/12/2025
		COALESCE((SELECT SUM(ORD_VALORE) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO 
			AND ORD_DESART <> '*** COMMENTO ***' AND ORD_CODART IN 
			(SELECT ART_CODPRI FROM U_ART_PR WHERE ART_CODMAT NOT IN 
				(SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'MAT%' 
					AND DESIVA LIKE '%NON_CALCOLA_RITENUTA_ACCONTO:S%'))),0) AS IMPONIB_ENPACL,				-- ERASMO - 19/12/2025
		CAST('' AS VARCHAR(254)) AS DATIGENERALIDOCUMENTODATICASSAPREVIDENZIALE,							-- ERASMO - 19/12/2025
		COALESCE(AN.CLI_PERSMA,'') AS FORMATO_TAG_NumItem		-- ERASMO - 10/02/2026
	FROM U_FAT_TT AS TT
	LEFT OUTER JOIN U_CLI_AN AS AN ON TT.ORD_CODCLI = AN.CLI_CODCLI   -- ERASMO - 22/11/2023
	LEFT OUTER JOIN U_ANA_CL AS CL ON TT.ORD_CODCLI = CL.CLI_CODCLI   -- ERASMO/SERGIO - 03/06/2025
	--WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'
	WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>' AND TT.TAGGANCIO='<<_TAGGANCIO>>'  -- ERASMO - 06/02/2019
	
ENDTEXT					&& FINE SCRITTURA QUERY

