		--CASE WHEN (SELECT COALESCE(SUBSTRING(LIBERA,11,1),'') FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS) = 'S' THEN 'TD04' ELSE 'TD01' END AS TIPODOCUMENTO,  -- ERASMO - 22/09/2015
		CASE
			WHEN (SELECT RTRIM(COALESCE(SUBSTRING(LIBERA,84,4),'')) FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS) <> '' THEN (SELECT RTRIM(SUBSTRING(LIBERA,84,4)) FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS)  -- DA PARAMETRO TOP - ERASMO - 24/03/2020
			WHEN (SELECT COALESCE(SUBSTRING(LIBERA,11,1),'') FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS) = 'S' THEN 'TD04'   -- NOTA DI CREDITO
			WHEN (SELECT COALESCE(SUBSTRING(LIBERA,78,1),'') FROM PARA WHERE CODICE = 'TOP'+TT.ORD_CAUS) = 'S' THEN 'TD05'   -- NOTA DI DEBITO 
			--WHEN (SELECT TOP 1 COALESCE(RTRIM(AZI_CODCLI),'') FROM U_AZI_AN) = RTRIM(TT.ORD_CODCLI) THEN 'TD20'   -- AUTOFATTURA (CLIENTE AZIENDA) - ERASMO - 27/02/2019
			WHEN ((SELECT TOP 1 COALESCE(RTRIM(AZI_CODCLI),'') FROM U_AZI_AN) = RTRIM(TT.ORD_CODCLI) OR ((SELECT COUNT(*) FROM U_FAT_DD WHERE DAGGANCIO = TT.TAGGANCIO AND ORD_PUBBLI = 'O') > 0)) THEN 'TD27'   -- fattura per autoconsumo o per cessioni gratuite senza rivalsa - ERASMO - 26/10/2020
			ELSE 'TD01' 
		END AS TIPODOCUMENTO,  -- ERASMO - 22/09/2015
		SUBSTRING(TT.ORD_DATORD,1,4)+'-'+SUBSTRING(TT.ORD_DATORD,6,2)+'-'+SUBSTRING(TT.ORD_DATORD,9,2) AS DatiGeneraliDocumentoData,
		TT.ORD_NUMORD AS DatiGeneraliDocumentoNumero,
