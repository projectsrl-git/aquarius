***********************************************************************************
PROCEDURE MODIFICA_CURSOR_BODY_FATTURA_ELETTRONICA_DESCRIZIONI_MAGGIORI_DI_1000_CHR
***********************************************************************************
*** GESTIONE RIGHE CON DESCRIZIONI MAGGIORI DI 1000 CARATTERI (INTEGRATE DEI CAMPI ORD_NOTE E ORD_NOTEBO)

DO WHILE .T.
	SELECT * FROM FatturaElettronica WHERE LEN(RTRIM(ORD_DESART)) > 1000 INTO CURSOR TMP_FatturaElettronica_DESART_1000
	SELECT TMP_FatturaElettronica_DESART_1000
	GO TOP
	
	IF EOF()
		EXIT
	ENDIF
	
	SCAN
		_ACT_NR_RIGA = NR_RIGA
		
		_LIMIT = 1000
		_I = _LIMIT
		DO WHILE _I > 0
			IF SUBSTR(ORD_DESART,_I,1) = " " OR SUBSTR(ORD_DESART,_I,1) = CHR(13) OR SUBSTR(ORD_DESART,_I,1) = CHR(10)
				EXIT
			ENDIF
			_I = _I - 1
		ENDDO
		IF _I > 0
			_LIMIT = _I
		ENDIF
		
		UPDATE FatturaElettronica SET ORD_DESART = SUBSTR(ORD_DESART,1,_LIMIT) WHERE NR_RIGA = _ACT_NR_RIGA
		UPDATE FatturaElettronica SET NR_RIGA = NR_RIGA + 1 WHERE NR_RIGA > _ACT_NR_RIGA
		UPDATE RIFERIMENTI_DDT SET NR_RIGA = NR_RIGA + 1 WHERE NR_RIGA > _ACT_NR_RIGA
		UPDATE RIFERIMENTI_ORDINE SET NR_RIGA = NR_RIGA + 1 WHERE NR_RIGA > _ACT_NR_RIGA
		
		SELECT TMP_FatturaElettronica_DESART_1000
		SCATTER MEMVAR MEMO
		
		SELECT FatturaElettronica
		APPEND BLANK
		GATHER MEMVAR MEMO
		REPLACE NR_RIGA WITH _ACT_NR_RIGA + 1
		REPLACE ORD_QTAORD WITH 0
		REPLACE CODICE_TIPO WITH M.CODICE_TIPO
		REPLACE CODICE_VALORE WITH M.CODICE_VALORE
		REPLACE ORD_CODART WITH M.ORD_CODART
		REPLACE ORD_DESART WITH "CONTINUO DESCRIZIONE:" + CHR(13) + CHR(10) + SUBSTR(ORD_DESART,_LIMIT+1)
		REPLACE ORD_PREZZO WITH 0
		REPLACE IMPORTO_SCONTO WITH 0
		REPLACE ORD_SC1 WITH 0
		REPLACE ORD_SC2 WITH 0
		REPLACE ORD_SC3 WITH 0
		REPLACE ORD_SC4 WITH 0
		REPLACE ORD_SC5 WITH 0
		REPLACE DETTAGLIOLINEESCONTOMAGGIORAZIONE WITH ""
		REPLACE ORD_PRZNET WITH 0
		REPLACE ORD_VALORE WITH 0
		REPLACE DettaglioLineeAliquotaIVA WITH M.DettaglioLineeAliquotaIVA 
		REPLACE DETTAGLIOLINEENATURAIVA WITH M.DETTAGLIOLINEENATURAIVA 
		REPLACE DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE WITH M.DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE 
		REPLACE DETTAGLIOLINEETIPOCESSIONEPRESTAZIONE WITH M.DETTAGLIOLINEETIPOCESSIONEPRESTAZIONE
		REPLACE ORD_IVA WITH M.ORD_IVA
		REPLACE ORD_CODSOG WITH ""
		
		**=> ERASMO - INIZIO 11/02/2025
		TABLEUPDATE(.T.,.T.,"FatturaElettronica")
		TABLEUPDATE(.T.,.T.,"RIFERIMENTI_DDT")
		TABLEUPDATE(.T.,.T.,"RIFERIMENTI_ORDINE")
		**=> ERASMO - FINE 11/02/2025
	ENDSCAN
ENDDO

ENDPROC
**=> ERASMO - FINE 26/06/2021