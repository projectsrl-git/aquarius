******************************************************************************
PROCEDURE CREA_CURSOR_BODY_FATTURA_ELETTRONICA
******************************************************************************
*_COND_COMMENTI = IIF(PUB_FECOMM,""," AND DD.ORD_QTAORD>0")  && ERASMO - 22/01/2019
*_COND_COMMENTI = IIF(!PUB_FECOMM," AND DD.ORD_QTAORD>0",IIF(PUB_OPZFECOMM = 2," AND (DD.ORD_QTAORD>0 OR ORD_CODICE <> '')",""))  && ERASMO - 25/02/2021
_COND_COMMENTI = IIF(!PUB_FECOMM," AND DD.ORD_QTAORD>0",IIF(PUB_OPZFECOMM = 3," AND (DD.ORD_QTAORD>0 OR (DD.ORD_CODICE <> '' AND DD.ORD_CODICE IN (SELECT NOT_CODICE FROM NOTE_COM WHERE NOT_FEXML = 1)))", ;
	IIF(PUB_OPZFECOMM = 2," AND (DD.ORD_QTAORD>0 OR DD.ORD_CODICE <> '')","")))  && ERASMO - 25/08/2021

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		CAST((ROW_NUMBER() OVER (ORDER BY DD.ORD_SEQUEN)) AS NUMERIC(4,0)) AS NR_RIGA,  -- ERASMO - 14/01/2019
		--DD.ORD_QTAORD,
		--CASE WHEN DD.ORD_UMCLI = '' THEN DD.ORD_QTAORD ELSE DD.ORD_QTACLI END AS ORD_QTAORD,  -- ERASMO - 24/05/2023
		CASE WHEN DD.ORD_DESART = '*** COMMENTO ***' THEN 0 ELSE (CASE WHEN DD.ORD_UMCLI = '' THEN DD.ORD_QTAORD ELSE DD.ORD_QTACLI END) END AS ORD_QTAORD,  -- ERASMO - 03/10/2025
		--CASE WHEN COALESCE(PR.ART_SERIE,'') <> '' THEN ART_SERIE ELSE 'ART' END AS CODICE_TIPO,
		--CASE WHEN COALESCE(PR.ART_CATBEN,'') <> '' THEN ART_CATBEN ELSE DD.ORD_CODART END AS CODICE_VALORE,
		CASE WHEN ((SELECT AZI_PRDISP FROM U_AZI_PA) = 1) AND COALESCE(PR.ART_SERIE,'') <> '' THEN ART_SERIE ELSE 'ART' END AS CODICE_TIPO,
		--CASE WHEN ((SELECT AZI_PRDISP FROM U_AZI_PA) = 1) AND COALESCE(PR.ART_CATBEN,'') <> '' THEN ART_CATBEN ELSE DD.ORD_CODART END AS CODICE_VALORE,
		--CASE WHEN (DD.ORD_CODART='' AND DD.ORD_DESART='*** COMMENTO ***') THEN '*** COMMENTO ***' 
		--	WHEN ((SELECT AZI_PRDISP FROM U_AZI_PA) = 1) AND COALESCE(PR.ART_CATBEN,'') <> '' THEN ART_CATBEN ELSE DD.ORD_CODART END AS CODICE_VALORE,  -- ERASMO - 22/01/2019
		CASE WHEN (DD.ORD_CODART='' AND DD.ORD_DESART='*** COMMENTO ***') THEN '*** COMMENTO ***' 
			WHEN ((SELECT AZI_PRDISP FROM U_AZI_PA) = 1) AND COALESCE(PR.ART_CATBEN,'') <> '' THEN ART_CATBEN ELSE 
				(CASE WHEN ((SELECT AZI_CDAPRD FROM U_AZI_PA) = 1 AND DD.ORD_CDAPRD <> '') THEN DD.ORD_CDAPRD ELSE DD.ORD_CODART END) END AS CODICE_VALORE,  -- ERASMO - 11/07/2019
		--DD.ORD_CODART,
		CASE WHEN ((SELECT AZI_CDAPRD FROM U_AZI_PA) = 1 AND DD.ORD_CDAPRD <> '') THEN DD.ORD_CDAPRD ELSE DD.ORD_CODART END AS ORD_CODART,  -- ERASMO - 11/07/2019
		--DD.ORD_DESART,
		--CASE DD.ORD_DESART WHEN '' THEN '-' ELSE DD.ORD_DESART END AS ORD_DESART,  -- ERASMO - 09/01/2019
		--CASE DD.ORD_DESART WHEN '' THEN '-' WHEN '*** COMMENTO ***' THEN SUBSTRING(ORD_NOTE,1,1000) ELSE DD.ORD_DESART END AS ORD_DESART,  -- ERASMO - 22/01/2019
		--CASE DD.ORD_DESART 
		--	WHEN '' THEN '-' 
		--	WHEN '*** COMMENTO ***' THEN
		--		CASE WHEN RTRIM(CAST(SUBSTRING(ORD_NOTE,1,1000) AS VARCHAR(1000))) <> '' THEN SUBSTRING(ORD_NOTE,1,1000) ELSE '-' END
		--	ELSE DD.ORD_DESART 
		--END AS ORD_DESART,  -- ERASMO - 01/02/2019
		CASE (CASE WHEN ((SELECT AZI_CDAPRD FROM U_AZI_PA) = 1 AND DD.ORD_DSAPRD <> '') THEN DD.ORD_DSAPRD ELSE DD.ORD_DESART END) 
			WHEN '' THEN '-' 
			WHEN '*** COMMENTO ***' THEN
				--CASE WHEN RTRIM(CAST(SUBSTRING(ORD_NOTE,1,1000) AS VARCHAR(1000))) <> '' THEN SUBSTRING(ORD_NOTE,1,1000) ELSE '-' END
				CASE WHEN RTRIM(CAST(SUBSTRING(ORD_NOTE,1,100) AS VARCHAR(100))) <> '' THEN SUBSTRING(ORD_NOTE,1,8000) ELSE '-' END  	-- ERASMO - 25/06/2021
			--ELSE (CASE WHEN ((SELECT AZI_CDAPRD FROM U_AZI_PA) = 1 AND DD.ORD_DSAPRD <> '') THEN DD.ORD_DSAPRD ELSE DD.ORD_DESART END) 
			ELSE RTRIM((CASE WHEN ((SELECT AZI_CDAPRD FROM U_AZI_PA) = 1 AND DD.ORD_DSAPRD <> '') THEN DD.ORD_DSAPRD ELSE DD.ORD_DESART END)) 									-- ERASMO - 28/09/2020
				--+ (CASE RTRIM(ORD_DES2) WHEN '' THEN '' ELSE CHAR(13)+CHAR(10)+RTRIM(ORD_DES2) END)  																						-- ERASMO - 28/09/2020
				+ (CASE WHEN COALESCE((SELECT AZI_FENODES2 FROM U_AZI_PC),0) = 1 THEN '' ELSE (CASE RTRIM(ORD_DES2) WHEN '' THEN '' ELSE CHAR(13)+CHAR(10)+RTRIM(ORD_DES2) END) END)	-- ERASMO - 27/05/2021
				--+ (CASE RTRIM(CAST(SUBSTRING(ORD_NOTEBO,1,1000) AS VARCHAR(1000))) WHEN '' THEN '' ELSE CHAR(13)+CHAR(10)+RTRIM(CAST(SUBSTRING(ORD_NOTEBO,1,1000) AS VARCHAR(1000))) END)  	-- ERASMO - 28/09/2020
				--+ (CASE RTRIM(CAST(SUBSTRING(ORD_NOTEBO,1,1000) AS VARCHAR(1000))) WHEN '' THEN '' WHEN RTRIM(ORD_DESART) THEN '' ELSE CHAR(13)+CHAR(10)+RTRIM(CAST(SUBSTRING(ORD_NOTEBO,1,1000) AS VARCHAR(1000))) END)  	-- ERASMO - 07/05/2021
				+ (CASE RTRIM(CAST(SUBSTRING(ORD_NOTEBO,1,100) AS VARCHAR(100))) WHEN '' THEN '' WHEN RTRIM(ORD_DESART) THEN '' ELSE CHAR(13)+CHAR(10)+RTRIM(CAST(SUBSTRING(ORD_NOTEBO,1,8000) AS VARCHAR(8000))) END)  	-- ERASMO - 25/06/2021
		END AS ORD_DESART,  -- ERASMO - 11/07/2019
		--DD.ORD_PREZZO,
		--CASE WHEN DD.ORD_PARENT > 0 THEN 0 ELSE (DD.ORD_PREZZO + DD.ORD_PRZACC) END AS ORD_PREZZO,  -- ERASMO - 05/05/2020
		--CASE WHEN DD.ORD_UMCLI <> '' THEN DD.ORD_PRECLI WHEN DD.ORD_PARENT > 0 THEN 0 ELSE (DD.ORD_PREZZO + DD.ORD_PRZACC) END AS ORD_PREZZO,  -- ERASMO - 24/05/2023
		CASE WHEN DD.ORD_DESART = '*** COMMENTO ***' THEN 0 ELSE (CASE WHEN DD.ORD_UMCLI <> '' THEN DD.ORD_PRECLI WHEN DD.ORD_PARENT > 0 THEN 0 ELSE (DD.ORD_PREZZO + DD.ORD_PRZACC) END) END AS ORD_PREZZO,  -- ERASMO - 03/10/2025
		--DD.ORD_SC1,
		--DD.ORD_PREZZO - DD.ORD_PRZNET AS IMPORTO_SCONTO,
		CASE WHEN DD.ORD_PARENT > 0 THEN 0 ELSE (DD.ORD_PREZZO + DD.ORD_PRZACC) - (DD.ORD_PRZNET + DD.ORD_PRNACC) END AS IMPORTO_SCONTO,  -- ERASMO - 05/05/2020
		--(DD.ORD_PREZZO - DD.ORD_PRZNET) * DD.ORD_QTAORD AS IMPORTO_SCONTO,
		--DD.ORD_SC1,  -- ERASMO - 15/01/2019
		--DD.ORD_SC2,  -- ERASMO - 15/01/2019
		--DD.ORD_SC3,  -- ERASMO - 15/01/2019
		--DD.ORD_SC4,  -- ERASMO - 15/01/2019
		--DD.ORD_SC5,  -- ERASMO - 15/01/2019
		CASE WHEN DD.ORD_PARENT > 0 THEN 0 ELSE DD.ORD_SC1 END AS ORD_SC1,  -- ERASMO - 05/05/2020
		CASE WHEN DD.ORD_PARENT > 0 THEN 0 ELSE DD.ORD_SC2 END AS ORD_SC2,  -- ERASMO - 05/05/2020
		CASE WHEN DD.ORD_PARENT > 0 THEN 0 ELSE DD.ORD_SC3 END AS ORD_SC3,  -- ERASMO - 05/05/2020
		CASE WHEN DD.ORD_PARENT > 0 THEN 0 ELSE DD.ORD_SC4 END AS ORD_SC4,  -- ERASMO - 05/05/2020
		CASE WHEN DD.ORD_PARENT > 0 THEN 0 ELSE DD.ORD_SC5 END AS ORD_SC5,  -- ERASMO - 05/05/2020
		CAST('' AS TEXT) AS DETTAGLIOLINEESCONTOMAGGIORAZIONE,
		--DD.ORD_PRZNET,
		CASE WHEN DD.ORD_PARENT > 0 THEN 0 ELSE DD.ORD_PRZNET + DD.ORD_PRNACC END AS ORD_PRZNET,  -- ERASMO - 05/05/2020
		--DD.ORD_VALORE,
		CASE WHEN DD.ORD_PARENT > 0 THEN 0 ELSE DD.ORD_VALORE + DD.ORD_VALACC END AS ORD_VALORE,  -- ERASMO - 05/05/2020
		--CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC(6,2)) AS DettaglioLineeAliquotaIVA,
		CASE WHEN DD.ORD_DESART = '*** COMMENTO ***' THEN (SELECT COALESCE(CAST(SUBSTRING(LIBERA,1,3) AS NUMERIC(6,2)),0.00) FROM PARA 
															WHERE CODICE = 'IVA'+(SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = DD.DAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' ORDER BY DAGGANCIO,ORD_SEQUEN))
			ELSE COALESCE(CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC(6,2)),0.00) 
		END AS DettaglioLineeAliquotaIVA,  -- ERASMO - 22/01/2019
		--CASE WHEN CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC (3,0)) = 0 THEN '<Natura>'+RTRIM(SUBSTRING(IVA.LIBERA,145,4))+'</Natura>' ELSE '' END AS DETTAGLIOLINEENATURAIVA,
		CASE WHEN DD.ORD_DESART = '*** COMMENTO ***' THEN 
				CASE WHEN (SELECT RTRIM(SUBSTRING(LIBERA,145,4)) FROM PARA WHERE CODICE = 'IVA'+(SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = DD.DAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' ORDER BY DAGGANCIO,ORD_SEQUEN)) = '' THEN '' 
					ELSE '<Natura>'+(SELECT RTRIM(SUBSTRING(LIBERA,145,4)) FROM PARA WHERE CODICE = 'IVA'+(SELECT TOP 1 ORD_IVA FROM U_FAT_DD WHERE DAGGANCIO = DD.DAGGANCIO AND ORD_DESART <> '*** COMMENTO ***' ORDER BY DAGGANCIO,ORD_SEQUEN)) +'</Natura>'
				END
			WHEN CAST(SUBSTRING(IVA.LIBERA,1,3) AS NUMERIC (3,0)) = 0 THEN '<Natura>'+RTRIM(SUBSTRING(IVA.LIBERA,145,4))+'</Natura>' ELSE '' 
		END AS DETTAGLIOLINEENATURAIVA,  -- ERASMO - 22/01/2019
		CAST(
			CASE
				WHEN DD.ORD_SYSFAT <> '' AND COALESCE((SELECT TOP 1 ORD_RIFAMMFE FROM BUDGET_CONS WHERE ORD_SYSFAT = DD.ORD_SYSFAT),'') <> ''
					THEN SUBSTRING(RTRIM(COALESCE((SELECT TOP 1 ORD_RIFAMMFE FROM BUDGET_CONS WHERE ORD_SYSFAT = DD.ORD_SYSFAT),'')),1,20)
				WHEN TT.ORD_RIFAMMFE <> '' THEN SUBSTRING(RTRIM(ORD_RIFAMMFE),1,20)
				ELSE ''
			END AS VARCHAR(100)) AS DETTAGLIOLINEERIFERIMENTOAMMINISTRAZIONE,
		SPACE(254) AS DETTAGLIOLINEETIPOCESSIONEPRESTAZIONE,
		DD.ORD_IVA,  -- ERASMO - 01/04/2019
		DD.ORD_CODSOG,  -- ERASMO - 07/05/2021
		SPACE(254) AS DETTAGLIOLINEEALTRIDATIGESTIONALI,  -- ERASMO - 12/01/2022
		SPACE(100) AS DETTAGLIOLINEERITENUTA,	-- ERASMO - 22/11/2023
		TT.T_RA AS T_RA							-- ERASMO - 22/11/2023
	FROM U_FAT_DD AS DD
	LEFT OUTER JOIN U_FAT_TT AS TT
	ON DD.DAGGANCIO=TT.TAGGANCIO
	LEFT OUTER JOIN PARA AS IVA
	ON 'IVA'+DD.ORD_IVA = IVA.CODICE
	LEFT OUTER JOIN U_ART_PR AS PR
	ON DD.ORD_CODART = PR.ART_CODPRI
	--WHERE DD.ORD_QTAORD>0 AND TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'
	--WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>'  <<_COND_COMMENTI>>  -- ERASMO - 22/01/2019
	WHERE TT.ORD_NUMORD='<<_NUMERO_FATTURA>>' AND TT.ORD_ANNO='<<_ANNO_FATTURA>>' AND TT.TAGGANCIO='<<_TAGGANCIO>>'  <<_COND_COMMENTI>>  -- ERASMO - 06/02/2019
	ORDER BY DD.ORD_SEQUEN

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"FatturaElettronica")
	return(.F.)
ENDIF

