*** SE FATTURA CON RITENUTA D'ACCONTO, DETRAGGO L'IMPORTO DELLA RITENUTA DAL CURSORE DEI PAGAMENTI
SELECT HEADER_FATTURA_ELETTRONICA
GO TOP
IF !EOF()
	IF T_RA > 0
		
		_n_Importo_Ritenuta_da_scalare = T_RA
			
		SELECT DETTAGLI_PAGAMENTO
		GO TOP
		SCAN
			
			IF _n_Importo_Ritenuta_da_scalare > 0
			ELSE
				EXIT
			ENDIF
			
			IF DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO >= _n_Importo_Ritenuta_da_scalare
				REPLACE DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO WITH DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO - _n_Importo_Ritenuta_da_scalare
				_n_Importo_Ritenuta_da_scalare = 0
				EXIT
			ELSE
				_n_Importo_Ritenuta_da_scalare = _n_Importo_Ritenuta_da_scalare - DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO
				REPLACE DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO WITH 0
			ENDIF
		ENDSCAN
		
		SELECT DETTAGLI_PAGAMENTO
		DELETE FOR DETTAGLIOPAGAMENTOIMPORTOPAGAMENTO = 0
		
	ENDIF
ENDIF
