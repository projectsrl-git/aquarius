PROCEDURE CREA_CURSOR_DATI_AZIENDA
******************************************************************************
*!*	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

*!*		SELECT * FROM U_AZI_AN

*!*	ENDTEXT					&& FINE SCRITTURA QUERY

**=> ERASMO - INIZIO 08/01/2019
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT AZI_CODFIS,AZI_PIVA,AZI_RAGSOC,AZI_INDIRI,AZI_CAP,AZI_LOCALI,AZI_TELEFO,AZI_FAX,
		CASE WHEN AZI_TELEFO = '' THEN '' ELSE '<Telefono>'+RTRIM(AZI_TELEFO)+'</Telefono>' END AS CEDENTEPRESTATORECONTATTITELEFONO,
		CASE WHEN AZI_FAX = '' THEN '' ELSE '<Fax>'+RTRIM(AZI_FAX)+'</Fax>' END AS CEDENTEPRESTATORECONTATTIFAX
	FROM U_AZI_AN

ENDTEXT					&& FINE SCRITTURA QUERY
**=> ERASMO - FINE 08/01/2019

IF !ExecPreparedCommand(cSql,"CU_AZIENDA")
	return(.F.)
ENDIF

**=> ERASMO - INIZIO 07/11/2018
SELECT CU_AZIENDA
GO TOP
REPLACE AZI_RAGSOC WITH PARSE_STRING_XML(AZI_RAGSOC)
REPLACE AZI_INDIRI WITH PARSE_STRING_XML(AZI_INDIRI)
REPLACE AZI_LOCALI WITH PARSE_STRING_XML(AZI_LOCALI)
**=> ERASMO - FINE 07/11/2018

**==> SERGIO 02/11/2018 - INIZIO
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT AZI_IDPAESE,AZI_PIVAIN,AZI_FORTRA,AZI_CODEORI,AZI_ALBO,AZI_PRVALBO,AZI_NUMISALBO,AZI_DTALBO,AZI_REGIMEFI,
		AZI_NRCIVICO,AZI_PROVINCIA,AZI_NAZION,AZI_UFFICIO,AZI_NRREA,AZI_CAPITSO,AZI_SOCIOU,AZI_STATOL,AZI_EMAIL,AZI_IDPAESEIN,
		AZI_PIVAIN,AZI_RAGSOCIN,AZI_SOGGEMIN,AZI_CONPAG,AZI_MODPAG,AZI_IBAN,AZI_IBANFAT,
		CASE WHEN AZI_CODEORI = '' THEN '' ELSE '<CodEORI>'+RTRIM(AZI_CODEORI)+'</CodEORI>' END AS CEDENTEPRESTATOREDATIANAGRAFICIANAGRAFICACODEORI,
		CASE WHEN AZI_CAPITSO = 0 THEN '' ELSE '<CapitaleSociale>'+CAST(CAST(AZI_CAPITSO AS NUMERIC(16,2)) AS VARCHAR(20))+'</CapitaleSociale>' END AS CEDENTEPRESTATOREISCRIZIONEREACAPITALESOCIALE,
		CASE WHEN AZI_ALBO = '' THEN '' ELSE '<AlboProfessionale>'+RTRIM(AZI_ALBO)+'</AlboProfessionale>' END AS CEDENTEPRESTATOREDATIANAGRAFICIALBOPROFESSIONALE,
		CASE WHEN AZI_PRVALBO = '' THEN '' ELSE '<ProvinciaAlbo>'+RTRIM(AZI_PRVALBO)+'</ProvinciaAlbo>' END AS CEDENTEPRESTATOREDATIANAGRAFICIPROVINCIAALBO,
		CASE WHEN AZI_NUMISALBO = '' THEN '' ELSE '<NumeroIscrizioneAlbo>'+RTRIM(AZI_NUMISALBO)+'</NumeroIscrizioneAlbo>' END AS CEDENTEPRESTATOREDATIANAGRAFICINUMEROISCRIZIONEALBO,
		CASE WHEN AZI_DTALBO = '' THEN '' ELSE '<DataIscrizioneAlbo>'+RTRIM(AZI_DTALBO)+'</DataIscrizioneAlbo>' END AS CEDENTEPRESTATOREDATIANAGRAFICIDATAISCRIZIONEALBO
	FROM U_AZI_PB

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"CU_AZIENDA_PB")
	return(.F.)
ENDIF
**==> SERGIO 02/11/2018 - FINE

**=> ERASMO - INIZIO 07/11/2018
SELECT CU_AZIENDA_PB
GO TOP
REPLACE AZI_UFFICIO WITH PARSE_STRING_XML(AZI_UFFICIO)
REPLACE AZI_SOGGEMIN WITH PARSE_STRING_XML(AZI_SOGGEMIN)
REPLACE AZI_RAGSOCIN WITH PARSE_STRING_XML(AZI_RAGSOCIN)

_ORD_IDSDI = ""
_ORD_CAUS = ""
_ORD_CODCLI = ""
SELECT HEADER_FATTURA_ELETTRONICA
GO TOP
IF !EOF()
	_ORD_IDSDI = ALLTRIM(ORD_IDSDI)
	_ORD_CAUS = ALLTRIM(ORD_CAUS)
	_ORD_CODCLI = ALLTRIM(ORD_CODCLI)
ENDIF

*!*	IF LEN(_ORD_IDSDI) <= 6
*!*		SELECT CU_AZIENDA_PB
*!*		GO TOP
*!*		REPLACE AZI_FORTRA WITH "FPA12"
*!*	ENDIF
*!*	IF LEN(_ORD_IDSDI) = 7
*!*		SELECT CU_AZIENDA_PB
*!*		GO TOP
*!*		REPLACE AZI_FORTRA WITH "FPR12"
*!*	ENDIF

_FORMATO_TRASMISSIONE = "FPR12"
*!*	IF _ORD_CAUS = "FVS"  && FORZATURA PER CARDIOLINE
*!*		_FORMATO_TRASMISSIONE = "FPA12"
*!*	ELSE
	v_seek	= PUB_CODSOC + _ORD_CODCLI
	v_chiave = "cli_codsoc+cli_codcli"
	IF seek_std('u_ana_cl',v_seek,v_chiave,'CL_CLIENTE')
	   SELECT CL_CLIENTE
	   IF CLI_PA
	      _FORMATO_TRASMISSIONE = "FPA12"
	   ENDIF
	ENDIF
*!*	ENDIF

IF (EMPTY(_ORD_IDSDI) OR ALLTRIM(_ORD_IDSDI) $ '0000000#XXXXXXX') AND _FORMATO_TRASMISSIONE = "FPA12"
	MESSAGEBOX("Codice Destinatario obbligatorio per la fattura PA n°"+_NUMERO_FATTURA+"/"+_ANNO_FATTURA,16,"Attenzione")
	_YES_CONTINUA = .F.
	RETURN .F.
ENDIF

SELECT CU_AZIENDA_PB
GO TOP
REPLACE AZI_FORTRA WITH _FORMATO_TRASMISSIONE

SELECT HEADER_FATTURA_ELETTRONICA
GO TOP
IF !EOF()
	v_seek 	 = 'CPA'+ALLTRIM(ORD_CPA)
	v_chiave = "codice"
	IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
	   SELECT CUR_PARA
	   _PAGANT = SUBSTR(LIBERA,252,1)
	   _SCADEN = ALLTRIM(SUBSTR(LIBERA,11,239))
	   _RATE = OCCURS(SPACE(1),_SCADEN)
	   SELECT CU_AZIENDA_PB
	   GO TOP
	   IF _RATE > 1
	      REPLACE AZI_CONPAG WITH "TP01"  && pagamento a rate
	   ELSE
	      IF _PAGANT = "S"
	         REPLACE AZI_CONPAG WITH "TP03"  && anticipo
	      ELSE
	         REPLACE AZI_CONPAG WITH "TP02"  && pagamento completo
	      ENDIF
	   ENDIF
	ENDIF
ENDIF
**=> ERASMO - FINE 07/11/2018

DO CERCA_IBAN_FATTURA_CLIENTE  && ERASMO - 07/11/2018

*!*	**=> ERASMO - INIZIO 14/01/2019
*!*	SELECT CU_AZIENDA_PB
