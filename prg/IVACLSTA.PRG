*************************
PROCEDURE IVAERA 
*************************
*RECUPERO IVA PRECEDENTE*
  
x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
x_anno = "iva_anno = " + ANNO
x_cond = x_soci + " and " + x_anno
CSQL   = "select * from u_iva_cr where " + x_cond + " order by iva_codsoc,iva_anno" 
IF !ExecCommand(CSQL,"u_iva_cr")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_CR
GO TOP
IF !EOF()
   IF OK_TRIM = 0
      IF VAL(MESE) = 1
         E_IMPOST = IVA_GENNAI
      ENDIF
      IF VAL(MESE) = 2
         E_IMPOST = IVA_FEBBRA
      ENDIF
      IF VAL(MESE) = 3
         E_IMPOST = IVA_MARZO
      ENDIF
      IF VAL(MESE) = 4
         E_IMPOST = IVA_APRILE
      ENDIF
      IF VAL(MESE) = 5
         E_IMPOST = IVA_MAGGIO
      ENDIF
      IF VAL(MESE) = 6
         E_IMPOST = IVA_GIUGNO
      ENDIF
      IF VAL(MESE) = 7
         E_IMPOST = IVA_LUGLIO
      ENDIF
      IF VAL(MESE) = 8
         E_IMPOST = IVA_AGOSTO
      ENDIF
      IF VAL(MESE) = 9
         E_IMPOST = IVA_SETTEM
      ENDIF
      IF VAL(MESE) = 10
         E_IMPOST = IVA_OTTOBR
      ENDIF
      IF VAL(MESE) = 11
         E_IMPOST = IVA_NOVEMB
      ENDIF
      IF VAL(MESE) = 12
         E_IMPOST = IVA_DICEMB
      ENDIF
   ENDIF
   IF OK_TRIM = 1
      E_IMPOST = IVA_GENNAI + IVA_FEBBRA + IVA_MARZO
   ENDIF
   IF OK_TRIM = 2
      E_IMPOST = IVA_APRILE + IVA_MAGGIO + IVA_GIUGNO
   ENDIF
   IF OK_TRIM = 3
      E_IMPOST = IVA_LUGLIO + IVA_AGOSTO + IVA_SETTEM
   ENDIF
   IF OK_TRIM = 4
      E_IMPOST = IVA_OTTOBR + IVA_NOVEMB + IVA_DICEMB
   ENDIF
ELSE
   E_IMPOST  = 0 
ENDIF 
SELECT IVA_CL
   
RETURN


*************************
PROCEDURE OK_SPOOL 
*************************

SELECT IVA_CL
GO TOP

DO WHILE .T. 

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
  	  SKIP +1
	  LOOP 
   ENDIF

   IF ALLTRIM(CHIAVE_R) = "TOC"
      RIGA_STA = RIGAT
   ELSE
      RIGA_STA = RIGA
   ENDIF
      
   SELECT IVA_STA
   APPEND BLANK
   REPLACE RIGAT WITH RIGA_STA

   SELECT IVA_CL
   SKIP +1

ENDDO

SELECT IVA_STA 
GO TOP

IF OK_FORMATO = 3
   DO CREA_SPOOL WITH "IVA_STA","IVA CLIENTI (A4): "+MESE+"/"+PUB_ANNO
ELSE
   IF OK_FORMATO = 2 OR OK_FORMATO = 1
	  DO CREA_SPOOL WITH "IVA_STA","IVA CLIENTI (A3): "+MESE+"/"+PUB_ANNO
   ENDIF
ENDIF

RELEASE WINDOW DISPLAY

RETURN


