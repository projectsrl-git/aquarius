		   IF CEE = 'E' OR CEE = 'R' OR CEE = 'A' && ERASMO - 19/12/2017 - SCARTA LE FATTURE ACQUISTO CEE / EXTRA CEE / REVERSE CHARGE / AUTOFATTURE, IN QUANTO GESTITE NELL'UNICO BOLLATO IVA REGISTRO COMPENSATIVO
		      SELECT U_IVA_CS
