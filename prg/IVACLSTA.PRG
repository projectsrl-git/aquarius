	  _REVERSECHANGE_IMPONI = V_IMPONI 
	  _REVERSECHANGE_IMPOST = V_IMPOST 
   ENDIF

   IF IND_100 = 'S'	.OR. "*" $ V_CODIVA	 && IMPOSTE INDEDUCIBILI  
	  RIGA_D = V_CODIVA + "  " + V_FATNOT + " " + SUBSTR(V_DESIVA,1,42) +  " | " +SPACE(18)+ " | " +SPACE(18)
