*************************
PROCEDURE IVADET 
*************************
* DETTAGLIO BOLLATO IVA *

x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
x_anno = "iva_anno = '" + PUB_ANNO + "'"
x_mese = "iva_mese = '" + MESE + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_mese
CSQL   = "select * from u_iva_cl where " + x_cond + " order by iva_codsoc,iva_anno,iva_mese" 
IF !ExecCommand(CSQL,"u_iva_cl")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_CL
GO TOP

CTRELAB=0

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SELECT U_IVA_CL
      SKIP +1
   	  LOOP
   ENDIF	

   IF IVA_FATNOT = "C"      	&& NON ELABORA I MOVIMENTI IVA CORRISPETTIVI 
   	  SELECT U_IVA_CL
   	  SKIP +1
   	  LOOP
   ENDIF

   IF PUB_CESCOM				&& REGISTRO IVA CESSIONI COMPENSATIVE ATTIVATO !!!!
	   v_seek	= 'TOP'+ALLTRIM(IVA_TOP)
	   v_chiave = "codice"
	   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
	      SELECT CUR_PARA
	      CEE   	= SUBSTR(LIBERA,23,1)
	   ELSE
	      CEE    	= SPACE(1)
	   ENDIF
	   *IF CEE = 'E' OR CEE = 'R' && SCARTA LE FATTURE ACQUISTO CEE / EXTRA CEE / REVERSE CHARGE IN QUANTO GESTITE NELL'UNICO BOLLATO IVA REGISTRO COMPENSATIVO
	   IF CEE = 'E' OR CEE = 'R' OR CEE = 'A' && ERASMO - 19/12/2017 - SCARTA LE FATTURE ACQUISTO CEE / EXTRA CEE / REVERSE CHARGE / AUTOFATTURE, IN QUANTO GESTITE NELL'UNICO BOLLATO IVA REGISTRO COMPENSATIVO
	      SELECT U_IVA_CL
	      SKIP +1
	   	  LOOP
	   ENDIF
   ELSE
	   IF !EMPTY(IVA_NUMCEE)    	&& NON ELABORA I MOVIMENTI DI ACQUISTI CEE
	      SELECT U_IVA_CL
	      SKIP +1
	   	  LOOP
	   ENDIF
   ENDIF


   SELECT U_IVA_CL

   IF PUB_NFATDIFFERITA
	   IF IVA_BOLLATOIVA = "D"   && NON ELABORA I MOVIMENTI RELATIVI ALLE FATTURE CREATE AUTOMATICAMENTE DA DDT
	      SKIP +1
	   	  LOOP
	   ENDIF
   ENDIF

   SCATTER MEMVAR MEMO
 
   SELECT ANNI_TMP
   APPEND BLANK
   GATHER MEMVAR MEMO

   CTRELAB=CTRELAB+1
   =CONTATORE("Movimenti Iva",CTRELAB)

   SELECT U_IVA_CL
   SKIP +1

ENDDO


