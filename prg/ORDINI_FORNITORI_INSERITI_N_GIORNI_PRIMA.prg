******************************************
* ORDINI_FORNITORI_INSERITI_N_GIORNI_PRIMA
******************************************

LPARAMETERS _NR_GIORNI

IF PCOUNT()<1
	_NR_GIORNI = 0
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO
PUBLIC V_TITOLO

_V_DATORD = DTOC(DATE() - _NR_GIORNI)

V_TITOLO = "Ordini fornitori inseriti il " + _V_DATORD

WAIT WINDOWS "ESEGUE PROGRAMMA ORDINI_FORNITORI_INSERITI_N_GIORNI_PRIMA" TIMEOUT 3

*** REPORT RIEPILOGO
cSql=""     
cNomeCursorSql="CU_ORDINATO_FORNITORE"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
		
	SELECT * FROM (
		SELECT 	
			CODICE_FORNITORE,
			FORNITORE,
			NUM_ORDINE,
			DATA_ORDINE_RIBALTATA, 
			DATA_ORDINE,
			CODICE_ARTICOLO,
			DESCRIZIONE_ARTICOLO,
			UM,
			QTA_ORDINATA,
			CENTRO_COSTO,
			DESCRIZIONE_CENTRO_COSTO,
			DATA_CONSEGNA_RIBALTATA,
			DATA_CONSEGNA,
			VALORE
		FROM (
			SELECT T1.*, COALESCE(CCO.CON_DESCR,'') AS DESCRIZIONE_CENTRO_COSTO FROM (
			SELECT
				TT.ORD_CODCLI AS CODICE_FORNITORE,
				TT.ORD_RAGSOC AS FORNITORE,
				TT.ORD_NUMORD AS NUM_ORDINE,
				TT.ORD_DATORD AS DATA_ORDINE_RIBALTATA,
				SUBSTRING(TT.ORD_DATORD,9,2)+'/'+SUBSTRING(TT.ORD_DATORD,6,2)+'/'+SUBSTRING(TT.ORD_DATORD,1,4) AS DATA_ORDINE,
				DD.ORD_CCODET AS CENTRO_COSTO,
				DD.ORD_CODART AS CODICE_ARTICOLO,
				DD.ORD_DESART AS DESCRIZIONE_ARTICOLO,
				DD.ORD_DATCON AS DATA_CONSEGNA_RIBALTATA,
				SUBSTRING(DD.ORD_DATCON,9,2)+'/'+SUBSTRING(DD.ORD_DATCON,6,2)+'/'+SUBSTRING(DD.ORD_DATCON,1,4) AS DATA_CONSEGNA,
				DD.ORD_UM AS UM,
				DD.ORD_QTAORD AS QTA_ORDINATA,
				DD.ORD_VALORE*TT.ORD_CAMBIO AS VALORE
			FROM U_ORF_TT AS TT
			LEFT OUTER JOIN U_ORF_DD AS DD
			ON TT.TAGGANCIO=DD.DAGGANCIO
			WHERE 
				DD.ORD_QTAORD>0
				AND DD.ORD_CHIUSO=0 
				AND TT.ORD_CHIUSO=0
				--AND TT.ORD_FLGCON=1
				AND TT.ORD_DATORD = '<<RIBALTA2(_V_DATORD)>>'
				AND TT.ORD_TIPOLOGIA NOT IN (SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'TPO%' AND CODPGO='ANNULLATO')
			) AS T1
			LEFT OUTER JOIN (SELECT DISTINCT CON_CONTO, CON_DESCR FROM  CCOSTO) AS CCO ON T1.CENTRO_COSTO = CON_CONTO
			) AS MAIN
		) AS MAIN2
	ORDER BY FORNITORE,DATA_ORDINE_RIBALTATA,NUM_ORDINE,CODICE_ARTICOLO,DATA_CONSEGNA_RIBALTATA

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


SELECT CU_ORDINATO_FORNITORE
GO TOP

LOCAL _DIRECTORY_PDF,_NOME_REPORT

_DIRECTORY_PDF=LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")  && RICERCA PERCORSO
IF !DIRECTORY(_DIRECTORY_PDF)
	*MESSAGEBOX("Directory '" + JUSTDRIVE(_DIRECTORY_PDF) + "' inesistente" + CHR(13) + CHR(13) + ;
		"Non sarŕ possibile creare correttamente i files PDF",48,"Attenzione")
	RETURN .F.
ENDIF

RELEASE PUB_INTXLS
PUBLIC PUB_INTXLS
PUB_INTXLS = ""
IF !ExecCommand("select * from u_azi_pb","u_azi_pb")
   return
ENDIF
SELECT u_azi_pb
GO TOP
IF !EOF()
	PUB_INTXLS = AZI_INTXLS
ENDIF

_NOME_REPORT = _DIRECTORY_PDF + "\" + "ORDINI_FORNITORI_INSERITI_N_GIORNI_PRIMA" + SYS(2015) + ".XLSX"

SET PROCEDURE TO PRG\APPLILIB ADDITIVE
SET PROCEDURE TO PRG\XLSLIB	ADDITIVE

WAIT WINDOW "ATTENDERE PREGO: creazione report excel in corso..." NOWAIT

_TITOLO_EXCEL1 = V_TITOLO
_TITOLO_EXCEL2 = ""
_TITOLO_EXCEL3 = ""
_TOTALI_GENERALI = .T.
DO ESTRXLS WITH "CU_ORDINATO_FORNITORE",_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,_TOTALI_GENERALI,.F.,.F.,_NOME_REPORT

_ALLEGATI = ""
_FILE_DA_ALLEGARE = JUSTFNAME(_NOME_REPORT)
_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
