************************************
* PRODOTTI_IN_SCADENZA
************************************

LPARAMETERS _PAR_NR_GIORNI_AVVISO_DEFAULT

IF PCOUNT() = 0
	_PAR_NR_GIORNI_AVVISO_DEFAULT = 0
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO
PUBLIC V_TITOLO

V_TITOLO = "Prodotti in scadenza e scaduti"

WAIT WINDOWS "ESEGUE PROGRAMMA PRODOTTI_IN_SCADENZA" TIMEOUT 3

*** REPORT RIEPILOGO
cSql=""     
cNomeCursorSql="CU_GIACENZE"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
	SELECT
		AN.ART_TIPSCA,
		COALESCE(TS.DESCRI,'') AS DES_TIPSCA,
		GG.MAG_DATAGG,
		GG.MAG_ORACAR,
		GG.MAG_CODMAG,
		GG.MAG_ANAART,
		PR.ART_DESCR,
		PR.ART_UMMAGA,
		GG.MAG_GIACEN,
		GG.MAG_SERIAL,
		GG.MAG_DTSCAD,
		AN.ART_NGSAVV
	FROM U_MAG_GG AS GG
	LEFT OUTER JOIN U_ART_PR AS PR ON PR.ART_CODPRI = GG.MAG_ANAART
	LEFT OUTER JOIN U_ART_AN AS AN ON AN.ART_CODPRI = PR.ART_CODPRI
	LEFT OUTER JOIN PARA AS TS ON TS.CODICE = 'TSC'+AN.ART_TIPSCA
	WHERE 
		GG.MAG_GIACEN > 0 AND
		GG.MAG_DTSCAD <> '' AND
		GG.MAG_DTSCAD <= convert(varchar, DATEADD(day, (CASE WHEN AN.ART_NGSAVV > 0 THEN AN.ART_NGSAVV ELSE <<_PAR_NR_GIORNI_AVVISO_DEFAULT>> END), GETDATE()), 111)
			
	ORDER BY AN.ART_TIPSCA,GG.MAG_CODMAG,GG.MAG_ANAART,GG.MAG_DATAGG,GG.MAG_ORACAR		
	
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT CU_GIACENZE
GO TOP
IF EOF()
	RETURN
ENDIF

*DO PRG\MENUSTA WITH "CU_GIACENZE",.T.,.F.,"XXX","PRODOTTI_IN_SCADENZA","PRODOTTI_IN_SCADENZA.FRX",.T.

_PDF_REPORT_ 		=ALLTRIM(CERCAREPO("XXX","PRODOTTI_IN_SCADENZA","PRODOTTI_IN_SCADENZA.FRX"))
_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "CU_GIACENZE"

IF !EMPTY(_PDF_SUBDIR_ )
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )

