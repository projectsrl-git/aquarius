**********************************************************
PROCEDURE BLOCCA_DETTAGLI_ORDINI
**********************************************************

	cSql=""     
	cNomeCursorSql="BLOCCA_ORD_DD"
			
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	UPDATE U_ORD_DD SET ORD_INPROD=1		
	  WHERE ORD_CODSYS IN ( 
	    SELECT DISTINCT PR5_ORDSYS FROM U_PRD_D5 WHERE PJ_PRGPRD1='<<PUB_PJ_PRGPRD1>>' AND PR5_ORDSYS!='' ) 
          AND ORD_DESART!='*** COMMENTO ***'
	      AND ORD_INPROD=0
	
	ENDTEXT					&& FINE SCRITTURA QUERY
	
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF


	************************************************
	*** SIMONE - 2008/11/07 - INIZIO
	************************************************
		*** IMPOSTA A "DA RIVALUTARE" LE RIGHE ORDINE
		************************************************
		cSql_1=""     
		cNomeCursorSql_1="DETT_ORD_PRG"
		TEXT TO cSql_1 NOSHOW
			select DISTINCT PR5_NUMORD,PR5_DATORD,PR5_CODART,PR5_ALTEZZ,PR5_LUNGHE,PR5_ORDSYS
			FROM U_PRD_D5
			WHERE PJ_PRGPRD1='<<PUB_PJ_PRGPRD1>>' 
			AND PR5_ORDSYS!='' 
		ENDTEXT
		IF !ExecPreparedCommand(cSql_1,cNomeCursorSql_1)
			return(.F.)
		ENDIF	
	
	
		SELECT DETT_ORD_PRG
		GO TOP
		DO WHILE !EOF()
		
			__NUM_RT_DA_PROD = 0
		
			SELECT DETT_ORD_PRG
			_NUM_ORD = ALLTRIM(DETT_ORD_PRG.PR5_NUMORD)
			_DAT_ORD = ALLTRIM(DETT_ORD_PRG.PR5_DATORD)
			_ART_ORD = ALLTRIM(DETT_ORD_PRG.PR5_CODART)				
			_ART_ALT = DETT_ORD_PRG.PR5_ALTEZZ
			_ART_LUN = DETT_ORD_PRG.PR5_LUNGHE
			_ORD_SYS = ALLTRIM(DETT_ORD_PRG.PR5_ORDSYS)				

			*** CONTO I ROTOLI GIA' PROGRAMMATI
			***
			cSql_2=""     
			cNomeCursorSql_2="ROT_PROG"
			TEXT TO cSql_2 NOSHOW
				SELECT count(pr5_numord) AS PROGRAMMATI
				FROM U_prd_D5 
				WHERE PR5_NUMORD = '<<_NUM_ORD>>'
				AND PR5_DATORD = '<<_DAT_ORD>>'
				AND PR5_CODART = '<<_ART_ORD>>'
				AND PR5_ALTEZZ = <<_ART_ALT>>
				AND PR5_LUNGHE = <<_ART_LUN>>								
			ENDTEXT
			IF !ExecPreparedCommand(cSql_2,cNomeCursorSql_2)
				return(.F.)
			ENDIF	


			*** CONTO I ROTOLI ORDINATI
			***
			cSql_3=""     
			cNomeCursorSql_3="ROT_ORDI"
			TEXT TO cSql_3 NOSHOW
				SELECT ORD_NUMBOB AS ORDINATI
				FROM U_ORD_DD 
				WHERE ORS_NUMORD = '<<_NUM_ORD>>'
				AND ORS_DATORD = '<<_DAT_ORD>>'
				AND ORD_CODART = '<<_ART_ORD>>'
				AND ORD_ALTEZZ = <<_ART_ALT>>
				AND ORD_LUNGHE = <<_ART_LUN>>												
				AND ORD_DESART!='*** COMMENTO ***'
			ENDTEXT
			IF !ExecPreparedCommand(cSql_3,cNomeCursorSql_3)
				return(.F.)
			ENDIF	

		
			*** CONFRONTO LE DUE GRANDEZZE OTTENUTE PRIMA E IMPOSTO IL NUMERO DI ROTOLI ANCORA DA PROGRAMMARE
			***
			SELECT ROT_PROG
			__NUM_RT_PRG = ROT_PROG.PROGRAMMATI

			SELECT ROT_ORDI		
			__NUM_RT_ORD = ROT_ORDI.ORDINATI
		
		
			IF __NUM_RT_ORD > __NUM_RT_PRG 
				__NUM_RT_DA_PROD =  __NUM_RT_ORD - __NUM_RT_PRG 
			ENDIF
		

		
			*** AGGIORNO IL VALORE DEI ROTOLI ANCORA DA PRODURRE
			*** SOLO SE IL VALORE E' MAGGIORE DI ZERO
			***
			IF __NUM_RT_DA_PROD > 0
			
				**** IMPOSTO IL NUMERO DI ROTOLI DA PRODURRE
				cSql_4=""     
				cNomeCursorSql_4="DA_RIVALUTARE"
				TEXT TO cSql_4 NOSHOW
					UPDATE U_ORD_DD
					SET ORD_DARIV = 1,
						ORD_DAPROD = <<__NUM_RT_DA_PROD>> 
					WHERE ORD_CODSYS = '<<_ORD_SYS>>'			
				ENDTEXT
				IF !ExecPreparedCommand(cSql_4,cNomeCursorSql_4)
					return(.F.)
				ENDIF		
			
			ELSE
			
				**** NON AVANZANO ROTOLI DA PRODURRE
				cSql_5=""     
				cNomeCursorSql_5="DA_RIVALUTARE"
				TEXT TO cSql_5 NOSHOW
					UPDATE U_ORD_DD
					SET ORD_DARIV = 0,
						ORD_DAPROD = 0
					WHERE ORD_CODSYS = '<<_ORD_SYS>>'			
				ENDTEXT
				IF !ExecPreparedCommand(cSql_5,cNomeCursorSql_5)
					return(.F.)
				ENDIF		
				
			ENDIF
		
		
			SELECT DETT_ORD_PRG
			SKIP + 1
			
		ENDDO
	
