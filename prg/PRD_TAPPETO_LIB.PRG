	V_ORD_NUMORD = M.ORD_NUMORD 
	V_ORD_DATORD = M.ORD_DATORD 
	
	***********************************
	***MEMORIZZO DATI DI TESTATA NEL DB
	***********************************
	IF !ExecRW("Select * from u_ord_tt where 1=0","U_ORD_TT","R")
