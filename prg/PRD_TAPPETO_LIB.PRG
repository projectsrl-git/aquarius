**********************************************************
PROCEDURE STORE_ALL_TABLES
**********************************************************
	LOCAL ;
		_ALTEZZA,;
		_FASCIA,;
		_FASCIA_ATTUALE,;
		_NUMERO_BOBINE,;
		_CONTATORE_FASCE,;
		_CONTATORE_BARRE,;
		_CONTATORE_ROTOLI,;
		_LUNGHEZZA_TOTALE_SPALMATURA,;
		_UNIMIS,;
		_CODART_BOBINA,;
		_DESART_BOBINA,;
		_SPESSO_BOBINA,;
		_QTA_ADESIVO_PER_ARTICOLO_FINALE,;
		_QTA_ADESIVO_PER_BOBINA_MADRE,;
		_PR3_QTADGI
	    

	WAIT WINDOW "SALVATAGGIO PROGRAMMA DI PRODUZIONE: aggiornamento dati " NOWAIT
	
	*** CANCELLO TUTTI I DATI DEL PIANO DI PRODUZIONE ATTUALE
	*** PER POI RISCRIVERLI CON I DATI NUOVI
	***
	DO RESET_LIVELLI
	
	SELECT CAMBI_BOBINA
	SET ORDER TO BOBINA
	GO TOP

	_ALTEZZA=0
	_FASCIA=0
	_FASCIA_ATTUALE=0
	_NUMERO_BOBINE=0
	_CONTATORE_FASCE=0
	_CONTATORE_BARRE=0
	_CONTATORE_ROTOLI=0
	_LUNGHEZZA_TOTALE_SPALMATURA=0
	_UNIMIS="MQ"
	_CODART_BOBINA=""
	_DESART_BOBINA=""
	_SPESSO_BOBINA=0
	_QTA_ADESIVO_PER_ARTICOLO_FINALE=0
	_QTA_ADESIVO_PER_BOBINA_MADRE=0
	_PR3_QTADGI=0
	

	DO WHILE !EOF()
	
		IF DELETED()
		    SELECT CAMBI_BOBINA
			SKIP
			LOOP
		ENDIF
		
		*******************************************************
		*** INIZIO AGGIORNAMENTO U_PRD_D2
		*******************************************************
		
		*** aggiorna raggruppamenti fascia su U_PRD_D2
		***
		SELECT CAMBI_BOBINA
		
		_SEZIONE_INIZIALE=SEZINI
		_SEZIONE_FINALE=SEZFIN
	
		SELECT SEZIONI
		SET ORDER TO SEZIONE
		
		SEEK _SEZIONE_INIZIALE
		IF !FOUND()
			WAIT WINDOW "NON TROVATA SEZIONE INIZIALE "+STR(_SEZIONE_INIZIALE)		
		    SELECT CAMBI_BOBINA
			SKIP
			LOOP
		ENDIF
				
		_ALTEZZA=ALTEZ
		_GRP_PROD=GRP_PROD

		*** CALCOLA_FASCIA CREA UN CURSORE FASCE CHE CONTIENE I DATI DELLA BOBINA CHE ANDRO' AD UTILIZZARE
		*** E' UNA SELECT SU U_ART_PR
		***		
		_FASCIA=CALCOLA_FASCIA(_ALTEZZA,_GRP_PROD)
		IF _FASCIA<0
			***MESSAGEBOX("Altezza BOBINA = "+ALLTRIM(STR(_ALTEZZA))+" mm non consentita per le fasce disponibili in magazzino.",48,"ATTENZIONE")
			SELECT CAMBI_BOBINA
			SKIP
			LOOP
		ENDIF
	    
		SELECT FASCE
		_CODART_BOBINA=ART_CODPRI
		_DESART_BOBINA=ART_DESCR
		_SPESSO_BOBINA=ART_SPESSO
		
		*** FINE CALCOLO BONINA PER FASCIA
		
		SELECT CAMBI_BOBINA
		
		*** aggiorna U_PRD_D2 solo se cambio fascia
		***
		IF _FASCIA <> _FASCIA_ATTUALE
		
			_CONTATORE_FASCE =_CONTATORE_FASCE+1
			
			_STR_FASCIA          = STR_FILL_ZERO(_FASCIA,5)
			_STR_CONTATORE_FASCE = STR_FILL_ZERO(_CONTATORE_FASCE,3)
			
			_PJ_PRGPRD2 = "FASCIA_"+_STR_CONTATORE_FASCE+"_"+_STR_FASCIA
			
			SELECT U_PRD_D2
			
			IF !EOF()
				REPLACE PR2_NUMBOB WITH _NUMERO_BOBINE
			ENDIF
			
			APPEND BLANK
	
			REPLACE PJ_PRGPRD1 WITH PUB_PJ_PRGPRD1
			REPLACE PJ_PRGPRD2 WITH _PJ_PRGPRD2
			REPLACE PR2_FASCIA WITH _FASCIA
			REPLACE PR2_SEQUEN WITH _STR_CONTATORE_FASCE
	
			*** CALCOLO DATA DI PRODUZIONE DELLA SEQUENZA/FASCIA		
			_TIMESTAMP_FASCIA=CALCOLA_DATA_ORA_DA_SEZIONE(_SEZIONE_INIZIALE)
    
		    _PR2_DATSEQ = RIBALTA2(SUBSTR(_TIMESTAMP_FASCIA,1,10))

			REPLACE PR2_DATSEQ WITH _PR2_DATSEQ
			
			REPLACE PR2_CODADE WITH PUB_CODICE_ADESIVO
			REPLACE PR2_DESADE WITH PUB_DESCRI_ADESIVO
			REPLACE PR2_SPEBOB WITH _SPESSO_BOBINA
			
			REPLACE PR2_UNIMIS WITH _UNIMIS
			REPLACE PR2_CODART WITH _CODART_BOBINA
			REPLACE PR2_DESART WITH _DESART_BOBINA
			
			IF _TUTTE_ROTOLI_GIA_PRONTI_A_MAGAZZINO
				REPLACE PR2_STASEQ WITH PUB_STATO_PROGRAMMA_EVADIBILE
			ELSE
				IF _TUTTE_BARRE_GIA_PRONTE_A_MAGAZZINO
					REPLACE PR2_STASEQ WITH PUB_STATO_PROGRAMMA_TAGLIABILE
				ELSE
			    	REPLACE PR2_STASEQ WITH PUB_STATO_PROGRAMMA_IN_PROGRAMMAZIONE
			    ENDIF
		    ENDIF			
			
			_FASCIA_ATTUALE=_FASCIA
			_NUMERO_BOBINE=0
		ENDIF
		
		*******************************************************
		*** FINE AGGIORNAMENTO U_PRD_D2
		*******************************************************
		
		_NUMERO_BOBINE=_NUMERO_BOBINE+1
		
		
		*******************************************************
		*** INIZIO AGGIORNAMENTO U_PRD_D3
		*******************************************************


		SELECT CAMBI_BOBINA

		_LUNGHEZZA_BOBINA_ATTUALE=LUNGH
		_BOBINA_ATTUALE = BOBINA
		_QTA_ADESIVO_PER_BOBINA_MADRE=QTA_ADESIVO
		_PR3_QTADGI=QTADGI
		
		_PJ_PRGPRD3 = ID
		_PR3_PROGRE=STR_FILL_ZERO(_BOBINA_ATTUALE,5)

		_CODINT	 =""
		_ALTCAR  =0
		_LUNCAR  =0
		_SPECAR  =0
		_INMAGA  =.F.

*!*	###############################################################################################
*!*	  COMMENTATO ERASMO/SIMONE - 10/02/2010 - INIZIO
*!*      - EFFETTUARE LE SELECT SUL CURSORE IN CUI SELEZIONO LE BOBINE IN GIACENZA DA UTILIZZARE
*!*      - IL CURSORE DA UTILIZZARE E' "BOBINE_DISPONIBILI"
*!*	###############################################################################################

*!*			*** AGGIORNA U_MAG_GG PER PRENOTARE LA GIACENZA

*!*			cSql = "SELECT TOP 1 * FROM U_MAG_GG WHERE MAG_ANAART = '"+ALLTRIM(_CODART_BOBINA)+"' AND MAG_LUNGHE="+ALLTRIM(STR(_LUNGHEZZA_BOBINA_ATTUALE))+" AND MAG_ALTEZZ="+ALLTRIM(STR(_FASCIA_ATTUALE))+" AND MAG_SPESSO="+ALLTRIM(STR(_SPESSO_BOBINA))+" AND MAG_PRENOT=0 AND MAG_GIACEN>0" 
*!*			IF !ExecRW(cSql,"U_MAG_GG","R")
*!*				return(.f.)
*!*			ENDIF
*!*				
*!*			SELECT U_MAG_GG
*!*			GO TOP
*!*			DO WHILE !EOF()
*!*				
*!*				_CODINT  =MAG_CODART
*!*				_ALTCAR  =MAG_ALTEZZ
*!*				_LUNCAR  =MAG_LUNGHE
*!*				_SPECAR  =MAG_SPESSO					
*!*				_INMAGA  =.T.
*!*				
*!*				REPLACE MAG_PRENOT WITH .T.
*!*				
*!*				SELECT U_MAG_GG
*!*				SKIP
*!*					
*!*			ENDDO
*!*			
*!*			IF !ExecRW("","U_MAG_GG","W")
*!*				return(.f.)
*!*			ENDIF
*!*			*** FINE AGGIORNA U_MAG_GG PER PRENOTARE LA GIACENZA
*!*	######################################################################################			
*!*	  COMMENTATO ERASMO/SIMONE - 10/02/2010 - FINE
*!*	######################################################################################
		
		SELECT U_PRD_D3
		
		APPEND BLANK
		REPLACE PJ_PRGPRD1 WITH PUB_PJ_PRGPRD1
		
		REPLACE PJ_PRGPRD2 WITH _PJ_PRGPRD2
		
		REPLACE PJ_PRGPRD3 WITH _PJ_PRGPRD3
		REPLACE PR3_PROGRE WITH _PR3_PROGRE

		REPLACE PR3_CODBOB WITH _CODART_BOBINA
		REPLACE PR3_DESBOB WITH _DESART_BOBINA
		
		REPLACE PR3_ALTEZZ WITH _FASCIA_ATTUALE
		REPLACE PR3_LUNGHE WITH _LUNGHEZZA_BOBINA_ATTUALE
		REPLACE PR3_SPESSO WITH _SPESSO_BOBINA
		
		REPLACE PR3_CODINT WITH _CODINT
		REPLACE PR3_INMAGA WITH _INMAGA
		
		REPLACE PR3_ALTCAR WITH _ALTCAR 
		REPLACE PR3_LUNCAR WITH _LUNCAR 
		REPLACE PR3_SPECAR WITH _SPECAR 
		REPLACE PR3_CODADE WITH PUB_CODICE_ADESIVO
		REPLACE PR3_DESADE WITH PUB_DESCRI_ADESIVO
		REPLACE PR3_CDADIN WITH ""
		REPLACE PR3_QUANTI WITH _QTA_ADESIVO_PER_BOBINA_MADRE
		REPLACE PR3_QTACAR WITH 0 
		REPLACE PR3_QTADGI WITH _PR3_QTADGI 
		
		
			
		*******************************************************
		*** FINE AGGIORNAMENTO U_PRD_D3
		*******************************************************
		

		*******************************************************
		*** INIZIO AGGIORNAMENTO U_PRD_D4
		*******************************************************
		
		SELECT SEZIONI
		SET ORDER TO SEZIONE
		SEEK _SEZIONE_INIZIALE
		IF !FOUND()
			WAIT WINDOW "NON TROVATA SEZIONE INIZIALE "+STR(_SEZIONE_INIZIALE)
		    SELECT CAMBI_BOBINA
			SKIP
			LOOP
		ENDIF
		
		_PJ_PRGPRD4=""
		
		DO WHILE !EOF()
		
		
			**** FABIANOXXX
			IF !_TUTTE_BARRE_GIA_PRONTE_A_MAGAZZINO 
				IF SEZIONE >_SEZIONE_FINALE
					EXIT
				ENDIF
			ENDIF
		
			IF DELETED()
