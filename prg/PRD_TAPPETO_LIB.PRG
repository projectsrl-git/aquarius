**********************************************************
PROCEDURE ELABORA_DATE_CONSEGNA
**********************************************************

	_SEZIONE_ATTUALE=0	
	SELECT TAPPETO
	SET ORDER TO SEZIONE
	GO TOP

	DO WHILE !EOF()
		
		IF DELETED()
			SKIP
			LOOP
		ENDIF

		IF _SEZIONE_ATTUALE<>SEZIONE
			
			_SEZIONE_ATTUALE=SEZIONE
					
			*** CALCOLO LUNGHEZZA PRODOTTA		
			SELECT SEZIONI
				
			_ALIAS=SYS(2015)
			SELECT SUM(LUNGH) AS LUNGH FROM SEZIONI WHERE SEZIONE<_SEZIONE_ATTUALE INTO CURSOR &_ALIAS
			SELECT &_ALIAS
			
			IF EOF()	
				_LUNGHEZZA_PRODOTTA=0
			ELSE
				_LUNGHEZZA_PRODOTTA=LUNGH
			ENDIF
			
			SELECT &_ALIAS
			USE
			
			SELECT TAPPETO

		ENDIF
		
		_MINUTI=ROUND(_LUNGHEZZA_PRODOTTA/VELOCITA_SPALM,0)
		
		_TIMESTAMP_PRODUZIONE	=CALCOLA_DATA_ORA(_MINUTI)
		_DATA_PREVISTA_PRODUZIONE=RIBALTA2(SUBSTR(_TIMESTAMP_PRODUZIONE,1,10))
		
		_D_DATA_EFFETTIVA_CONSEGNA=CTOD(RIBALTA2(_DATA_PREVISTA_PRODUZIONE))+GGEVAS
		_GIORNI_DIFFERENZA=_D_DATA_EFFETTIVA_CONSEGNA-CTOD(RIBALTA2(DTCONS))
		
		REPLACE DTPRPR WITH _DATA_PREVISTA_PRODUZIONE
		REPLACE DTCEFF WITH RIBALTA2(DTOC(_D_DATA_EFFETTIVA_CONSEGNA))
		
		IF !ISNULL(_GIORNI_DIFFERENZA) AND TYPE("_GIORNI_DIFFERENZA")='N'
			IF _GIORNI_DIFFERENZA>=-99 AND _GIORNI_DIFFERENZA<=999
				REPLACE GGDIFF WITH _GIORNI_DIFFERENZA
			ENDIF
		ENDIF
		
		SELECT TAPPETO
		SKIP
		
	ENDDO
	
* FINE PROCEDURE ELABORA_DATE_CONSEGNA
**********************************************************

	
**********************************************************
PROCEDURE CREA_CAMBI_BOBINA
**********************************************************

LOCAL _SEZIONE_INIZIALE,_SEZIONE_PRECEDENTE,_LUNGHEZZA_BOBINA_STANDARD,_LUNGHEZZA_BOBINA,_PROGR_BOBINA,_ALTEZZA_BOBINA_CORRENTE,_ALTEZZA_BARRA_INIZIALE,_RESTO_DELLA_DIVISIONE_PER_DIECI

_LUNGHEZZA_BOBINA_STANDARD=LUNGHEZZA_BOBINA
_LUNGHEZZA_BOBINA=0
_SEZIONE_INIZIALE=1
_SEZIONE_PRECEDENTE=0
_PROGR_BOBINA=1
_GRUPPO_PRODUTTIVO=""


***DO PREPARA_SELEZIONE_BOBINE_DISPONIBILI

SELECT SEZIONI
SET ORDER TO SEZIONE
_ALTEZZA_BARRA_INIZIALE=DECINA_SUPERIORE(ALTEZ)

GO TOP

DO WHILE !EOF()

	IF !EMPTY(CODINT)
		SKIP
		LOOP
	ENDIF


	_LUNGHEZZA_BOBINA_STANDARD=LUNGHEZZA_DI_CAMBIO_BOBINA(_ALTEZZA_BARRA_INIZIALE)
	IF _LUNGHEZZA_BOBINA+LUNGH>_LUNGHEZZA_BOBINA_STANDARD
		
		TERMINA_BOBINA_DISPONIBILE(_ALTEZZA_BARRA_INIZIALE)
		
		ADD_CAMBIO_BOBINA(_PROGR_BOBINA,_SEZIONE_INIZIALE,_SEZIONE_PRECEDENTE,_LUNGHEZZA_BOBINA_STANDARD,_ALTEZZA_BARRA_INIZIALE)
		_LUNGHEZZA_BOBINA=0
		_SEZIONE_INIZIALE=SEZIONE
		_SEZIONE_PRECEDENTE=0
		_PROGR_BOBINA=_PROGR_BOBINA+1
		
		_ALTEZZA_BARRA_INIZIALE=DECINA_SUPERIORE(ALTEZ)
		
	ENDIF
	
	SELECT SEZIONI
	
	_LUNGHEZZA_BOBINA=_LUNGHEZZA_BOBINA+LUNGH
	_SEZIONE_PRECEDENTE=SEZIONE	
	REPLACE BOBINA WITH _PROGR_BOBINA
	REPLACE PATTERN WITH "BOB"+ALLTRIM(STR( _PROGR_BOBINA))+ALLTRIM(PATTERN)
	
	SKIP
	
ENDDO



*** AGGIUNGO L'ULTIMO CAMBIO BOBINA ALLA FINE DEL GIRO DELLE SEZIONI
***

TERMINA_BOBINA_DISPONIBILE(_ALTEZZA_BARRA_INIZIALE)
ADD_CAMBIO_BOBINA(_PROGR_BOBINA,_SEZIONE_INIZIALE,_SEZIONE_PRECEDENTE,_LUNGHEZZA_BOBINA,_ALTEZZA_BARRA_INIZIALE)


SELECT BOBINE_DISPONIBILI
SET ORDER TO MAG_ALTEZZ
GO TOP
***brow normal


IF _TUTTE_BARRE_GIA_PRONTE_A_MAGAZZINO OR _TUTTE_ROTOLI_GIA_PRONTI_A_MAGAZZINO
ELSE

	*** AGGIUNGO UNA SEZIONE DI CHIUSURA DELLA BOBINA DESTINATA AD ORDINI INTERNI
	SELECT CAMBI_BOBINA
	GO TOP

	DO WHILE !EOF()
	
		IF DELETED()
			SKIP
			LOOP
		ENDIF

		_SEZIONE_INIZIALE_BOBINA = SEZINI
		_SEZIONE_FINALE_BOBINA   = SEZFIN
		_LUNGHEZZA_BOBINA        = LUNGH
		_BOBINA                  = BOBINA
		_ALTEZZA_BOBINA_CORRENTE = ALTEZ
		_RECNO                   = RECNO()	

		_LUNGHEZZA_BARRA_ORDINE_INTERNO=_LUNGHEZZA_BOBINA_STANDARD-_LUNGHEZZA_BOBINA
		
		IF _LUNGHEZZA_BARRA_ORDINE_INTERNO>0
		
			SELECT CAMBI_BOBINA
			REPLACE NUMBARRE WITH NUMBARRE +1
			
			*** ORA AGISCO SU TUTTI I CAMBI BOBINA
			REPLACE SEZFIN WITH SEZFIN+1 FOR BOBINA >=_BOBINA
		    REPLACE SEZINI WITH SEZINI+1 FOR BOBINA > _BOBINA 
		
			SELECT TAPPETO
			REPLACE SEZIONE WITH SEZIONE+1 FOR SEZIONE > _SEZIONE_FINALE_BOBINA 
			_SEZIONE_FINALE_BOBINA   = _SEZIONE_FINALE_BOBINA+1
			
			SELECT SEZIONI
			REPLACE SEZIONE WITH SEZIONE+1 FOR BOBINA > _BOBINA 
			
			SELECT SEZIONI
			APPEND BLANK
			REPLACE SEZIONE	   WITH _SEZIONE_FINALE_BOBINA,;
			        ALTEZ	   WITH _ALTEZZA_BOBINA_CORRENTE,;
				    LUNGH	   WITH _LUNGHEZZA_BARRA_ORDINE_INTERNO,;
					FLGMULTI   WITH .F.,;
				    FLGVIEW    WITH .T.,;
				    PATTERN    WITH "BOB"+ALLTRIM(STR( _BOBINA)),;
				    BOBINA     WITH _BOBINA,;
				    NUMSEZRAGG WITH 0
				    
			SELECT TAPPETO
			SET ORDER TO SEZIONE
			SEEK _SEZIONE_FINALE_BOBINA-1
			_CODART=CODART
			_DESART=DESART
			_GRP_PROD=GRP_PROD
			
			APPEND BLANK
			REPLACE NUMORD  WITH SYS(2015),;
					SEZIONE WITH _SEZIONE_FINALE_BOBINA,;
					ALTEZ  WITH _ALTEZZA_BOBINA_CORRENTE,;
					LUNGH  WITH _LUNGHEZZA_BARRA_ORDINE_INTERNO,;
					RAGSOC WITH PUB_RAGSOC_ORDINI_INTERNI,;
					CODCLI WITH PUB_CODCLI_ORDINI_INTERNI,;
					CODART WITH _CODART,;
					DESART WITH _DESART,;
				    DATORD WITH RIBALTA2(DTOC(DATE())),;	
				    DTCONS WITH RIBALTA2(DTOC(DATE())) ,;		&& FABIANO 14/07/2008
				    GRP_PROD WITH _GRP_PROD,;
				    CESTINO WITH .F.,;
				    ADESIVO WITH PUB_CODICE_ADESIVO,;
				    GGEVAS WITH 0,;								&& E' UN ORDINE INTERNO
				    ORD_CODSYS WITH ''							&& E' IL SYS CHE ANDRA' SULL'ORDINE INTERNO
		    
	    
		ENDIF
			    		
		SELECT CAMBI_BOBINA
		GO _RECNO
		SKIP
		
	ENDDO

ENDIF

PUB_QTA_ADESIVO=CALCOLA_QTA_ADESIVO_TOTALE()
		
