PROCEDURE CONTROLLA_DISPONBILITA_BARRE_ROTOLI
**********************************************************
LOCAL _SEZIONE,_ALIAS

_ESISTONO_BARRE_GIA_PRONTE_A_MAGAZZINO=.F.
_TUTTE_BARRE_GIA_PRONTE_A_MAGAZZINO=.T.

_ESISTONO_ROTOLI_GIA_PRONTI_A_MAGAZZINO=.F.
_TUTTE_ROTOLI_GIA_PRONTI_A_MAGAZZINO=.T.


DO CONTROLLA_DISPONBILITA_ROTOLI

IF !_TUTTE_ROTOLI_GIA_PRONTI_A_MAGAZZINO
	DO CONTROLLA_DISPONBILITA_BARRE
ENDIF

_ESISTE_QUALCOSA_DA_SPALMARE =.F.

SELECT SEZIONI
SET ORDER TO SEZIONE
GO TOP
DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF

	IF SPALMARE
		_ESISTE_QUALCOSA_DA_SPALMARE=.T.
		EXIT
	ENDIF
	
	SELECT SEZIONI
	SKIP
ENDDO

DO IMPOSTA_I_FLAG_DI_CONTROLLO_DELLA_DISPONIBILITA

