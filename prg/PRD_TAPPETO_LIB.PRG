**********************************************************
PROCEDURE CREA_LE_BARRE
**********************************************************
LOCAL _ALTEZZA_ROTOLO,;
	  _LUNGHEZZA_ROTOLO

	  
* 1) raggruppo i rotoli per altezza e lunghezza (indipendentemente dal numero d'ordine)
* 2) conto i rotoli per raggruppamento
*
* Ad esempio
*
* ================================
*  H	 L	   NR.ROTOLI   
* ================================
* 1010	1000	87		  
* 1210	1000	45		  
* 1170	1000	46		  
*
DO TABELLA_RAGGRUPPAMENTO_ROTOLI

DO SCOMPONGO_ROTOLI_RAGGRUPPATI_IN_ROTOLI_SINGOLI
* Nel cursore PROGPROD ci sono tante righe quanti sono i rotoli
*

DO PREPARA_SELEZIONE_BOBINE_DISPONIBILI

IF FLAG_OTTIMIZZAZIONE

	DO OTTIMIZZA_ROTOLI_IN_ALTEZZA

ENDIF


SELECT DISTINCT ID_SEQUEN,PASSO,NUMBARRE ;
FROM SEQUENZE_DD ;
WHERE ALLTRIM(ID_SEQUEN)=ALLTRIM(PUB_ID_SEQUEN) ;
ORDER BY PASSO INTO CURSOR PASSI_SEQUENZA

****SELECT * FROM SEQUENZE_DD WHERE ALLTRIM(ID_SEQUEN)=ALLTRIM(PUB_ID_SEQUEN) 
	
SELECT PASSI_SEQUENZA
GO TOP

_PASSO     = ""

_ALTEZZA_ROTOLO_OLD = 0

DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	
	IF _PASSO<>PASSO
		_ALTEZZA_ROTOLO_OLD = 0
	ENDIF
	
	_PASSO						=PASSO
	_ID_SEQUEN					=ID_SEQUEN
	_NUMBARRE   				=NUMBARRE

	SELECT SEQUENZE_DD

		
	FOR I = 1 TO _NUMBARRE
	
		SELECT SEQUENZE_DD
		SET ORDER TO ID_SEQUEN
		SEEK   _ID_SEQUEN+_PASSO
	
		DO WHILE !EOF()
		
			IF DELETED()
				SKIP
				LOOP
			ENDIF
			
			IF PASSO<> _PASSO
				EXIT
			ENDIF
			
			_ALTEZZA_ROTOLO		=ALTEZ
			_LUNGHEZZA_ROTOLO	=LUNGH
		
			SELECT PROGPROD
			SET ORDER TO DISPONI	&& ORDINAMENTO CON CONDIZIONE SUL FLAG GIA_MESSO
			GO TOP
			SEEK _ALTEZZA_ROTOLO
			
			IF !FOUND()
				SELECT SEQUENZE_DD
				SKIP				
				LOOP
			ENDIF
			
			DO WHILE !EOF()
				
				IF DELETED()	
					SKIP
					LOOP
				ENDIF
				
				IF GIA_MESSO
					SKIP
					LOOP
				ENDIF
				
				IF _LUNGHEZZA_ROTOLO<> LUNGH
					SKIP
					LOOP
				ENDIF

				*** ESCO APPENA TROVO UN ROTOLO CHE MI SODDISFA				
				EXIT
			ENDDO
			
			DO DISPONI_SINGOLO_ROTOLO WITH _ALTEZZA_ROTOLO_OLD
		
			SELECT PROGPROD
			REPLACE GIA_MESSO WITH .T.
			
			SELECT SEQUENZE_DD
			SKIP
			
		ENDDO
	
	NEXT
	
	SELECT PASSI_SEQUENZA
	_ALTEZZA_ROTOLO_OLD = _ALTEZZA_ROTOLO
	SKIP
	
ENDDO




DO PUSH_TUNING

* FINE PROCEDURE CREA_LE_BARRE
**********************************************************


**********************************************************
PROCEDURE DISPONI_SINGOLO_ROTOLO
**********************************************************

LPARAMETERS _ALTEZZA_ROTOLO_OLD

LOCAL _NUMORD,;
	  _DTCONS,;
	  _ALTEZ,;
	  _LUNGH,;
	  _QTA,;
	  _RAGSOC,;
	  _DATORD,;
	  _CODCLI,;
	  _CODICE_SEZIONE_VALIDO,;
	  _SCARTO,;
	  _ALTEZZA_GIA_OCCUPATA_NELLA_BARRA,;
	  _ALTEZZA_ANCORA_DISPONIBILE_NELLA_BARRA
	  

SELECT PROGPROD

_NUMORD      = NUMORD
_DTCONS      = DTCONS
_ALTEZ       = ALTEZ
_LUNGH       = LUNGH
_QTA         = QTA
_RAGSOC	     = RAGSOC
_DATORD      = DATORD
_CODCLI      = CODCLI 
_CODART      = CODART
_DESART      = DESART
_GRP_PROD    = GRP_PROD
_MICROFORATO = MICROFORATO
_ADESIVO     = ADESIVO
_GGEVAS      = GGEVAS 
_ORD_CODSYS	 = ORD_CODSYS
_SPESS       = SPESS
_CODINT      = CODINT

DO BLOCCA_ARTICOLO_CON_GIACENZA WITH _CODART,_ALTEZ,_LUNGH,_SPESS

_CODICE_SEZIONE_VALIDO=0

SELECT SEZIONI
SET ORDER TO ALTEZ
GO TOP
	
DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	IF LUNGH<>_LUNGH
		SKIP
		LOOP
	ENDIF
	
	*** TROVA UNA SEZIONE (O BARRA) GIA' CREATA CHE SIA CANDIDATA A CONTENERE
	*** IL MIO ROTOLO CHE STO ELABORANDO
	*** OSSIA ALTA MENO DELL'ALTEZZA DELLA BOBINA MADRE SOTRATTA DELL'ALTEZZA DEL ROTOLO
	*** E LUNGA COME IL ROTOLO
	***
	
	***_ALTEZZA_GIA_OCCUPATA_NELLA_BARRA      = ALTEZ + SCARTO + SCARTO_TAGLIO
	
* 	IF _ALTEZZA_ROTOLO_OLD>0 AND ALTEZ<>_ALTEZZA_ROTOLO_OLD
* 		SKIP 
* 		LOOP
* 	ENDIF
	
	_ALTEZZA_GIA_OCCUPATA_NELLA_BARRA      = ALTEZ 
	_ALTEZZA_ANCORA_DISPONIBILE_NELLA_BARRA= ALTEZZA_BOBINA - _ALTEZZA_GIA_OCCUPATA_NELLA_BARRA
	
	IF _ALTEZZA_ANCORA_DISPONIBILE_NELLA_BARRA >= _ALTEZ
		_CODICE_SEZIONE_VALIDO=SEZIONE
		EXIT
	ENDIF
	
	SKIP 

ENDDO

*** NON TROVA NESSUNA SEZIONE (O BARRA) GIA' CREATA CHE SIA CANDIDATA A CONTENERE
*** IL MIO ROTOLO CHE STO ELABORANDO
***
IF _CODICE_SEZIONE_VALIDO=0

	SELECT SEZIONI
	SET ORDER TO SEZIONE
	GO BOTT
	_CODICE_SEZIONE_VALIDO=SEZIONE+1

	*** creo una nuova sezione (O BARRA)
	*** di lunghezza opportuna
	***
	APPEND BLANK
	REPLACE SEZIONE WITH _CODICE_SEZIONE_VALIDO
	REPLACE LUNGH   WITH _LUNGH
	*** AGGIUNGO LO SCARTO NELLA SEZIONE (O BARRA) DATO DA
	*** SCARTO LATERALE (CIMOSA) + SCARTO DI TAGLIO
	***
	REPLACE SCARTO   WITH SCARTO_LATERALE - SCARTO_TAGLIO
	REPLACE ALTEZ    WITH SCARTO_LATERALE - SCARTO_TAGLIO
	REPLACE GRP_PROD WITH _GRP_PROD
	
ENDIF

*** aggiorna la tabella delle SEZIONI (O BARRE)
***
SELECT SEZIONI
REPLACE ALTEZ WITH ALTEZ +_ALTEZ + SCARTO_TAGLIO
*** AGGIUNGO LO SCARTO NELLA SEZIONE (O BARRA) DATO DA
*** SCARTO PRECEDENTE + SCARTO DI TAGLIO PER IL NUOVO TAGLIO
***
REPLACE SCARTO WITH SCARTO + SCARTO_TAGLIO		
		
*** AGGIORNO IL CURSORE TEMPORANEO DEI ROTOLI
*** 
SELECT TAPPETO_TMP0 
APPEND BLANK
REPLACE NUMORD WITH _NUMORD,;
		DTCONS WITH _DTCONS,;
		SEZIONE WITH _CODICE_SEZIONE_VALIDO,;
		ALTEZ WITH _ALTEZ,;
		LUNGH WITH _LUNGH,;
		RAGSOC WITH _RAGSOC,;
		CODCLI WITH _CODCLI,;
        DATORD WITH _DATORD,;
        CODART WITH _CODART,;
        CODINT WITH _CODINT,;
		DESART WITH _DESART,;
        CESTINO WITH .F.,;
		GRP_PROD WITH _GRP_PROD,;
		MICROFORATO WITH _MICROFORATO,;
		ADESIVO WITH _ADESIVO,;
		GGEVAS WITH _GGEVAS ,;
		ORD_CODSYS WITH _ORD_CODSYS
		
				
* FINE PROCEDURE DISPONI_SINGOLO_ROTOLO
**********************************************************


