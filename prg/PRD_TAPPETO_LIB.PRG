**********************************************************
PROCEDURE IMPOSTA_I_FLAG_DI_CONTROLLO_DELLA_DISPONIBILITA
**********************************************************

*** CONTROLLO BARRE

_TUTTE_BARRE_GIA_PRONTE_A_MAGAZZINO=.T.
_ESISTONO_BARRE_GIA_PRONTE_A_MAGAZZINO=.F.

SELECT SEZIONI
GO TOP
DO WHILE !EOF()
	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	IF EMPTY(CODINT) OR ALLTRIM(CODINT)="COMPLETA" 
		_TUTTE_BARRE_GIA_PRONTE_A_MAGAZZINO=.F.
	ELSE
		_ESISTONO_BARRE_GIA_PRONTE_A_MAGAZZINO=.T.
	ENDIF
	
	SELECT SEZIONI
	SKIP
ENDDO

*** CONTROLLO ROTOLI

_TUTTE_ROTOLI_GIA_PRONTI_A_MAGAZZINO=.T.
_ESISTONO_ROTOLI_GIA_PRONTI_A_MAGAZZINO=.F.

SELECT TAPPETO_TMP0
GO TOP
DO WHILE !EOF()
	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	IF EMPTY(CODINT)
		_TUTTE_ROTOLI_GIA_PRONTI_A_MAGAZZINO=.F.
	ELSE
		_ESISTONO_ROTOLI_GIA_PRONTI_A_MAGAZZINO=.T.
	ENDIF
	
	SELECT TAPPETO_TMP0
	SKIP
ENDDO


* FINE PROCEDURE IMPOSTA_I_FLAG_DI_CONTROLLO_DELLA_DISPONIBILITA
**********************************************************

**********************************************************
PROCEDURE CONTROLLA_DISPONBILITA_ROTOLI
**********************************************************
LOCAL _BARRA_COMPLETA,_BARRA_ATTUALE

LOCAL _SWWS
_SWWS=SELECT()

_BARRA_COMPLETA=.T.
_BARRA_ATTUALE = -1

SELECT TAPPETO_TMP0
SET ORDER TO SEZIONE
GO TOP

DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF

	IF SEZIONE!=_BARRA_ATTUALE
		IF _BARRA_COMPLETA

			**** SEGNALO CHE LA BARRA NON E' DA SPALMARE
			**** E GLI METTO UN CODICE INTERNO FITTIZIO CHE MI INDICA CHE E' COMPLETA
			**** QUESTO MI E' INDISPENSABILE PER L'AVANZAMENTO SPALMATURA
			****
			DO IMPOSTA_BARRA_NON_DA_SPALMARE WITH _BARRA_ATTUALE,"COMPLETA"

			
		ELSE

			**** SEGNALO CHE LA BARRA E' DA SPALMARE
			****
			DO IMPOSTA_BARRA_DA_SPALMARE WITH _BARRA_ATTUALE
		
			**** ELIMINO TUTTI I CODICI INTERNI CHE HO ASSEGNATO PER QUELLA BARRA
			****
			DO SPRENOTA_UNA_BARRA_DAL_CURSORE_PRENOTAZIONI WITH _BARRA_ATTUALE
			
			**** TOLGO TUTTI I CODICI INTERNI DAI CAMPI CODINT NEL TAPPETO
			****
			DO TOLGO_TUTTI_I_CODICI_INTERNI_DAL_TAPPETO_PER_BARRA WITH _BARRA_ATTUALE
			
		ENDIF
	
		_BARRA_COMPLETA=.T.
		_BARRA_ATTUALE= SEZIONE
	ENDIF
	
	_CODART=CODART
	_SPESS =SPESS
	_ALTEZ =ALTEZ
	_LUNGH =LUNGH
	_CODINT=""
			
	_CODINT=CONTROLLA_A_MAGAZZINO_ROTOLI_E_BARRE_E_CONFRONTA_CON_PRENOTATI(_CODART,_SPESS,_ALTEZ,_LUNGH)
	
	*** SE SEISTE A MAGAZZINO UN ROTOLO CON LE STESSE CARATTERISTICHE  
	*** DI QUELLO CHE STO CONSIDERANDO
	***
	IF !EMPTY(_CODINT)
		DO AGGIUNGI_PRENOTAZIONE_MAGAZZINO WITH _CODINT,_BARRA_ATTUALE
		
		SELECT TAPPETO_TMP0
		REPLACE CODINT WITH _CODINT
			
		_ESISTONO_ROTOLI_GIA_PRONTI_A_MAGAZZINO=.T.
	ELSE
		_TUTTE_ROTOLI_GIA_PRONTI_A_MAGAZZINO=.F.
		_BARRA_COMPLETA=.F.	
	ENDIF
	

	SELECT TAPPETO_TMP0
	SKIP	
	
ENDDO


*********** GESTIONE ULTIMO ROTOLO *****************
IF _BARRA_COMPLETA

	**** SEGNALO CHE LA BARRA NON E' DA SPALMARE
	**** E GLI METTO UN CODICE INTERNO FITTIZIO CHE MI INDICA CHE E' COMPLETA
	**** QUESTO MI E' INDISPENSABILE PER L'AVANZAMENTO SPALMATURA
	****
	DO IMPOSTA_BARRA_NON_DA_SPALMARE WITH _BARRA_ATTUALE,"COMPLETA"

	
ELSE

	**** SEGNALO CHE LA BARRA E' DA SPALMARE
	****
	DO IMPOSTA_BARRA_DA_SPALMARE WITH _BARRA_ATTUALE

	**** ELIMINO TUTTI I CODICI INTERNI CHE HO ASSEGNATO PER QUELLA BARRA
	****
	DO SPRENOTA_UNA_BARRA_DAL_CURSORE_PRENOTAZIONI WITH _BARRA_ATTUALE
	
	**** TOLGO TUTTI I CODICI INTERNI DAI CAMPI CODINT NEL TAPPETO
	****
	DO TOLGO_TUTTI_I_CODICI_INTERNI_DAL_TAPPETO_PER_BARRA WITH _BARRA_ATTUALE
	
ENDIF
*********** GESTIONE ULTIMO ROTOLO *****************

SELECT(_SWWS)
* FINE PROCEDURE CONTROLLA_DISPONBILITA_ROTOLI
**********************************************************


**********************************************************
PROCEDURE CONTROLLA_DISPONBILITA_BARRE
**********************************************************
LOCAL _BARRA_ATTUALE

LOCAL _SWWS
_SWWS=SELECT()

_BARRA_ATTUALE = -1

SELECT TAPPETO_TMP0
SET ORDER TO SEZIONE
GO TOP

DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	*** SE LA BARRA NON E' DA SPALMARE
	*** PERCHE' HO GIA' TUTTI I ROTOLI A MAGAZZINO
	*** LA SALTO
	***
	IF !BARRA_DA_SPALMARE(SEZIONE)
		SKIP
		LOOP			
	ENDIF
		
	IF SEZIONE!=_BARRA_ATTUALE
		SELECT TAPPETO_TMP0
		_CODART=CODART
		_SPESS =M.SPESSORE_BOBINA
	
		_BARRA_ATTUALE=SEZIONE
		SELECT SEZIONI
		SET ORDER TO SEZIONE
		SEEK _BARRA_ATTUALE
	
		_ALTEZ=DECINA_SUPERIORE(ALTEZ)
		
		_LUNGH=LUNGH
		
		_CODINT=CONTROLLA_A_MAGAZZINO_ROTOLI_E_BARRE_E_CONFRONTA_CON_PRENOTATI(_CODART,_SPESS,_ALTEZ,_LUNGH)
		
		IF !EMPTY(_CODINT)
		
			DO AGGIUNGI_PRENOTAZIONE_MAGAZZINO WITH _CODINT,_BARRA_ATTUALE
				
			SELECT SEZIONI
			REPLACE CODINT WITH _CODINT
			
			_ESISTONO_BARRE_GIA_PRONTE_A_MAGAZZINO=.T.
		ELSE 
			_TUTTE_BARRE_GIA_PRONTE_A_MAGAZZINO=.F.		
		ENDIF

	ENDIF
	
	SELECT TAPPETO_TMP0
	SKIP	
	
ENDDO

