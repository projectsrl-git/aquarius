**********************************************************
PROCEDURE SCOMPONGO_ROTOLI_RAGGRUPPATI_IN_ROTOLI_SINGOLI
**********************************************************
LOCAL _ALIAS

_ALIAS=SYS(2015)
SELECT * FROM PROGPROD INTO CURSOR &_ALIAS

SELECT PROGPROD
ZAP

SELECT &_ALIAS
GO TOP


DO WHILE !EOF()
	
	IF DELETED()	
		SKIP
		LOOP
	ENDIF
	
	_QTA 	  = QTA
	_C_ALTEZZ = STR_FILL_ZERO(ALTEZ,5)
	_C_LUNGHE = STR_FILL_ZERO(LUNGH,5)
	_C_SPESSO = STR_FILL_ZERO(SPESS,5)
	
	_ALTEZ    =ALTEZ
	_LUNGH    =LUNGH
	_SPESS    =SPESS
	_CODART   =CODART
	
	SCATTER MEMVAR MEMO
	
	FOR I=1 TO _QTA	
	
		SELECT PROGPROD
		APPEND BLANK
		GATHER MEMVAR MEMO
		
		REPLACE QTA WITH 1
		REPLACE C_ALTEZZ WITH _C_ALTEZZ
		REPLACE C_LUNGHE WITH _C_LUNGHE
		REPLACE C_SPESSO WITH _C_SPESSO
		
		_CODINT=CONTROLLA_A_MAGAZZINO_ROTOLI_E_BARRE_E_CONFRONTA_CON_PRENOTATI(_CODART,_SPESS,_ALTEZ,_LUNGH)
		
		REPLACE CODINT WITH _CODINT

	NEXT
	
	SELECT &_ALIAS
	SKIP
	
ENDDO

SELECT &_ALIAS
USE

* FINE PROCEDURE SCOMPONGO_ROTOLI_RAGGRUPPATI_IN_ROTOLI_SINGOLI
**********************************************************

**********************************************************
PROCEDURE BLOCCA_ARTICOLO_CON_GIACENZA
**********************************************************
	LPARAMETERS _CODART,_ALTEZ,_LUNGH,_SPESS
	
	LOCAL cSql,_ALIAS
	
	LOCAL _SWWS
	_SWWS=SELECT()
	
	_ALIAS="CU_MAG_GG"
	cSql = "SELECT * FROM U_MAG_GG WHERE MAG_ANAART='"+ALLTRIM(_CODART)+"' AND MAG_ALTEZZ='"+ALLTRIM(STR(_ALTEZ))+"' AND MAG_LUNGHE='"+ALLTRIM(STR(_LUNGH))+"' AND MAG_SPESSO='"+ALLTRIM(STR(_SPESS))+"' AND MAG_GIACEN>0 AND MAG_PRENOT=0 "
	IF !Execcommand(cSql,_ALIAS)
		return(.f.)
	ENDIF
		
	SELECT &_ALIAS
	GO TOP
	IF !EOF()
			
		cSql = "UPDATE U_MAG_GG SET MAG_PRENOT=1 WHERE id_unique='"+ALLTRIM(id_unique)+"' "
		IF !Execcommand(cSql,_ALIAS)
		    SELECT(_SWWS)
			return(.f.)
		ENDIF
	ENDIF
	
	SELECT &_ALIAS
	USE
	
    SELECT(_SWWS)

