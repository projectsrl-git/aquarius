**********************************************************
PROCEDURE STAMPA_RIEPILOGO_ORDINI
**********************************************************

	IF EMPTY(PUB_PJ_PRGPRD1)
		MESSAGEBOX("Salvare/Creare un piano di produzione abbinato al tappeto corrente",48,"Attenzione!")
		RETURN
	ENDIF
	
	IF VELOCITA_SPALM=0
		MESSAGEBOX("Valorizzare la velocita' di spalmatura",48,"Attenzione!")
		RETURN
	ENDIF

	cSql=""     
	cNomeCursorSql="CUR_ORDINI"
			
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
		SELECT TT.TAGGANCIO,
			   TT.ORD_NUMORD,
			   TT.ORD_DATORD,
			   TT.ORD_CODCLI,
			   TT.ORD_RAGSOC,
			   TT.ORD_VALORE,
			   DD.ORD_NUMBOB AS DD_QTAROT,
			   (SELECT SUM(ORD_NUMBOB) FROM U_ORD_DD WHERE DAGGANCIO=TT.TAGGANCIO AND ORD_INPROD = 1) AS ORD_QTAROT,			   
			   (SELECT SUM(ORD_QTAORD) FROM U_ORD_DD WHERE DAGGANCIO=TT.TAGGANCIO AND ORD_INPROD = 1) AS ORD_QTAMQ,
			   (SELECT MIN(ORD_DATCON) FROM U_ORD_DD WHERE DAGGANCIO=TT.TAGGANCIO AND ORD_INPROD = 1) AS ORD_DTCONS,
			   DD.ORD_DATCON AS DD_DTCONS,	
		       DD.ORD_CODART,
			   DD.ORD_ALTEZZ,
			   DD.ORD_LUNGHE,
			   DD.ORD_INPROD,
			   DD.ORD_CODSYS,			   
               DD.ORD_UM,
               DD.ORD_IVA,
               CAST(SUBSTRING(IVA.LIBERA,1,3) AS INT) AS PERC_IVA,
               DD.ORD_DESART,
               DD.ORD_QTAORD,
		       COALESCE(LOC.LOC_GGEVAS,LOC.LOC_GGEVAS,'0') AS CLI_GGEVAS 
		FROM U_ORD_TT AS TT
		LEFT OUTER JOIN U_LOC_AN AS LOC
		ON LOC.LOC_CODCLI=TT.ORD_CODCLI AND LOC_CODLOC=TT.ORD_CODLOC  
		LEFT OUTER JOIN U_ORD_DD AS DD
		ON DD.DAGGANCIO=TT.TAGGANCIO AND DD.ORD_DESART!='*** COMMENTO ***'
        LEFT OUTER JOIN PARA AS IVA
        ON IVA.CODICE = 'IVA'+RTRIM(DD.ORD_IVA)
        WHERE RTRIM(ORD_NUMORD)+ORD_DATORD IN (SELECT RTRIM(PR5_NUMORD)+PR5_DATORD FROM U_PRD_D5 WHERE PJ_PRGPRD1='<<PUB_PJ_PRGPRD1>>') 
        	AND TT.ORD_CODCLI!='<<PUB_CLISOC>>'
        ORDER BY TAGGANCIO
			
	ENDTEXT					&& FINE SCRITTURA QUERY
	
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF

	
