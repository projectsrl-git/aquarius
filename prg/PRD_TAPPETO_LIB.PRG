**********************************************************
PROCEDURE CREA_CURSORE_DELLE_BOBINE_DISPONIBILI
**********************************************************
PARAMETERS _ARTICOLO_BOBINA

LOCAL _SWWS
_SWWS=SELECT()

_D_CODMAG = IIF(EMPTY(ALLTRIM(PUB_CARORF)),'SEDE',ALLTRIM(PUB_CARORF))

*** INSERISCO NUOVO PIANO DI PRODUZIONE
cSql=""     
cNomeCursorSql=SYS(2015)
		
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT MAG_CODART,MAG_ANAART,MAG_LUNGHE,MAG_ALTEZZ,MAG_GIACEN,MAG_QTAIMP,MAG_PRENOT 
	FROM U_MAG_GG
	WHERE MAG_ANAART IN (<<_ARTICOLO_BOBINA>>) 
	AND MAG_PRENOT=0 
	AND MAG_CODMAG='<<_D_CODMAG>>'
	ORDER BY MAG_ALTEZZ,MAG_LUNGHE DESC
	
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT BOBINE_DISPONIBILI
GO TOP
DELETE ALL


SELECT &cNomeCursorSql
GO TOP
DO WHILE !EOF()

	SCATTER MEMVAR
	
	SELECT BOBINE_DISPONIBILI
	APPEND BLANK
	
	GATHER MEMVAR
	REPLACE SELEZIONE WITH ""
	
	SELECT &cNomeCursorSql
	SKIP
		
ENDDO

SELECT &cNomeCursorSql
USE


SELECT BOBINE_DISPONIBILI
GO TOP

SELECT(_SWWS)

RETURN
	
* FUNCTION CREA_CURSORE_DELLE_BOBINE_DISPONIBILI
**********************************************************	



**********************************************************
FUNCTION LUNGHEZZA_DI_CAMBIO_BOBINA
**********************************************************

PARAMETERS _ALTEZZA_BARRA_INIZIALE

LOCAL _SWWS,_LUNGHEZZA_CAMBIO_BOBINA
_SWWS=SELECT()


_LUNGHEZZA_CAMBIO_BOBINA=LUNGHEZZA_BOBINA

SELECT BOBINE_DISPONIBILI

GO TOP
DO WHILE !EOF()
	IF !EMPTY(SELEZIONE) 
		IF _ALTEZZA_BARRA_INIZIALE<=MAG_ALTEZZ
			***WAIT WINDOW "SELEZIONATA" NOWAIT
			_LUNGHEZZA_CAMBIO_BOBINA=MAG_LUNGHE
			EXIT
		ELSE
			***WAIT WINDOW "NON SELEZIONATA" NOWAIT
		ENDIF
	ENDIF
	
	SKIP
		
ENDDO


SELECT(_SWWS)

RETURN _LUNGHEZZA_CAMBIO_BOBINA
	
* FUNCTION LUNGHEZZA_DI_CAMBIO_BOBINA
**********************************************************	


**********************************************************
FUNCTION TERMINA_BOBINA_DISPONIBILE
**********************************************************

PARAMETERS _ALTEZZA_BARRA_INIZIALE

LOCAL _SWWS,_LUNGHEZZA_CAMBIO_BOBINA
_SWWS=SELECT()

SELECT BOBINE_DISPONIBILI
GO TOP
DO WHILE !EOF()
	IF !EMPTY(SELEZIONE) 
		IF _ALTEZZA_BARRA_INIZIALE<=MAG_ALTEZZ
			***WAIT WINDOW "TERMINATA" NOWAIT
			REPLACE  SELEZIONE WITH "==>"
			EXIT
		ELSE
			***WAIT WINDOW "NON TERMINATA" NOWAIT
		ENDIF
	ENDIF
	
	SKIP
		
ENDDO

SELECT(_SWWS)
	
* FUNCTION TERMINA_BOBINA_DISPONIBILE
**********************************************************	



**********************************************************
FUNCTION PREPARA_SELEZIONE_BOBINE_DISPONIBILI
**********************************************************

SELECT PROGPROD
SET ORDER TO ROTOLI
GO TOP 

_GRUPPO_PRODUTTIVO=""
_ELENCO_GRUPPI_PRODUTTIVI=""

DO WHILE !EOF()

	IF !EMPTY(CODINT)
		SKIP
		LOOP
	ENDIF

	IF ALLTRIM(GRP_PROD)!=ALLTRIM(_GRUPPO_PRODUTTIVO)
		_GRUPPO_PRODUTTIVO=ALLTRIM(GRP_PROD)
		IF _ELENCO_GRUPPI_PRODUTTIVI!=""
			_ELENCO_GRUPPI_PRODUTTIVI=_ELENCO_GRUPPI_PRODUTTIVI+","
		ENDIF
		_ELENCO_GRUPPI_PRODUTTIVI=_ELENCO_GRUPPI_PRODUTTIVI+"'"+_GRUPPO_PRODUTTIVO+"'"
	ENDIF
	
	SKIP
	
ENDDO

***WAIT WINDOW _ELENCO_GRUPPI_PRODUTTIVI


***************************************************** INIZIO
***
*** SIMONE - 08/04/2009 - TEST PARACULO PER NON INCORRERE IN : ERRORE CURSORE STP CON CODICE SYS() 
***                       LA CREAZIONE DI QUESTO CURSORE E' DENTRO ALLA PROCEDURA 
***

IF !EMPTY(ALLTRIM(_ELENCO_GRUPPI_PRODUTTIVI))

	DO CREA_CURSORE_DELLE_BOBINE_DISPONIBILI WITH  _ELENCO_GRUPPI_PRODUTTIVI

	SELECT BOBINE_DISPONIBILI
	SET ORDER TO MAG_ALTEZZ
	GO TOP

ELSE

	SELECT BOBINE_DISPONIBILI
	GO TOP
	DELETE ALL
	SELECT BOBINE_DISPONIBILI
	GO TOP

ENDIF
***
***************************************************** FINE

***brow normal

* PROCEDURE PREPARA_SELEZIONE_BOBINE_DISPONIBILI
**********************************************************	