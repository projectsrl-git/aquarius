**********************************************************	
PROCEDURE CALCOLA_QTA_ADESIVO_TOTALE
**********************************************************	
	LOCAL ;
		_QTA_ADESIVO_TOTALE,;
		_QTA_ADESIVO_PER_BOBINA_MADRE,;
		_QTA_ADESIVO_PER_ARTICOLO_FINALE,;
		_CODART,;
		_SEZIONE_INIZIALE,;
		_FASCIA,;
		_ALTEZZA_BOBINA_ATTUALE,;
		_LUNGHEZZA_BOBINA_ATTUALE,;
		_PJ_PRGPRD3
	
	*** PUSH SELECT
	LOCAL _SWWS,_OWWO,_RWWR
	_SWWS=SELECT()
	_OWWO=ORDER()
	_RWWR=RECNO()
	*** PUSH SELECT	
	
	_QTA_ADESIVO_TOTALE=0
	_SEZIONE_INIZIALE=0
	_QTA_ADESIVO_PER_BOBINA_MADRE=0
	_QTA_ADESIVO_PER_ARTICOLO_FINALE=0
	_CODART=""
	_FASCIA=0
	_ALTEZZA_BOBINA_ATTUALE=0
	_LUNGHEZZA_BOBINA_ATTUALE=0
	_PJ_PRGPRD3=""
	

	SELECT CAMBI_BOBINA
	SET ORDER TO BOBINA
	GO TOP
	
	DO WHILE !EOF()
		
		IF DELETED()
			SKIP
			LOOP
		ENDIF
		
		_SEZIONE_INIZIALE=SEZINI
		_LUNGHEZZA_BOBINA_ATTUALE=LUNGH
		_PJ_PRGPRD3="BOBINA_"+STR_FILL_ZERO(BOBINA,5)		
	
		SELECT SEZIONI
		SET ORDER TO SEZIONE
		
		SEEK _SEZIONE_INIZIALE
		_ALTEZZA_BOBINA_ATTUALE=ALTEZ		
		_GRP_PROD              =GRP_PROD
		
		*** CALCOLA_FASCIA CREA UN CURSORE FASCE CHE CONTIENE I DATI DELLA BOBINA CHE ANDRO' AD UTILIZZARE
		*** E' UNA SELECT SU U_ART_PR
		***		
		_FASCIA=CALCOLA_FASCIA(_ALTEZZA_BOBINA_ATTUALE,_GRP_PROD)
		IF _FASCIA<0
			***MESSAGEBOX("Altezza BOBINA = "+ALLTRIM(STR(_ALTEZZA_BOBINA_ATTUALE))+" mm non consentita per le fasce disponibili in magazzino.",48,"ATTENZIONE")
			SELECT CAMBI_BOBINA
			SKIP
			LOOP
		ENDIF
		
		SELECT FASCE
		_CODART_BOBINA=ART_CODPRI
		_DESART_BOBINA=ART_DESCR
		_SPESSO_BOBINA=ART_SPESSO
	    
		SELECT TAPPETO
		SET ORDER TO SEZIONE
		SEEK _SEZIONE_INIZIALE
		_CODART= ALLTRIM(CODART)
		
		_QTA_ADESIVO_PER_ARTICOLO_FINALE=CALCOLA_QTA_ADESIVO_PER_ARTICOLO_FINALE(_CODART)
		_PR3_QTADGI=AGGIORNA_QTA_ADESIVO_IN_GIACENZA(_QTA_ADESIVO_PER_ARTICOLO_FINALE)
		_QTA_ADESIVO_PER_BOBINA_MADRE=TROVA_MQ_DA_AL(_FASCIA, _LUNGHEZZA_BOBINA_ATTUALE,1) * _QTA_ADESIVO_PER_ARTICOLO_FINALE 
		_QTA_ADESIVO_TOTALE=_QTA_ADESIVO_TOTALE+_QTA_ADESIVO_PER_BOBINA_MADRE
		
		SELECT CAMBI_BOBINA
		
		REPLACE QTA_ADESIVO WITH _QTA_ADESIVO_PER_BOBINA_MADRE
		REPLACE QTADGI WITH _PR3_QTADGI
		REPLACE CODBOB WITH _CODART_BOBINA
		REPLACE DESBOB WITH _DESART_BOBINA
		REPLACE SPESS  WITH _SPESSO_BOBINA
		REPLACE ALTEZ  WITH _ALTEZZA_BOBINA_ATTUALE 
		REPLACE ID 	   WITH _PJ_PRGPRD3
		
		SKIP
			
	ENDDO
	
    *** POP SELECT
    SELECT(_SWWS)
	SET ORDER TO &_OWWO
	IF _RWWR<RECCOUNT()
		GO _RWWR
	ELSE
		GO BOTTOM
	ENDIF
	*** POP SELECT
			
	RETURN _QTA_ADESIVO_TOTALE
	
* FINE PROCEDURE CALCOLA_QTA_ADESIVO_TOTALE
**********************************************************	


**********************************************************
PROCEDURE TAPPETO2DB
**********************************************************
	LOCAL FLAG_NUOVO_PIANO, FLAG_SALVA_PIANO

	FLAG_NUOVO_PIANO=.F.
	FLAG_SALVA_PIANO=.F.
	
	
	*** č valorizzato il numero di piano?
	***
	IF !EMPTY(PUB_PR1_NUMPIA)
	*** e' un piano giŕ esistente
	***
		IF 6!=MESSAGEBOX("Aggiornare il PROGRAMMA DI PRODUZIONE "+ALLTRIM(PUB_PR1_NUMPIA)+"?",4+32,"Aggiornamento piano di produzione")
		*** non aggiorno il piano 
		***
		
			IF 6=MESSAGEBOX("Inserire nuovo PROGRAMMA DI PRODUZIONE ?",4+32,"Aggiornamento piano di produzione")	
			*** inserire nuovo piano 
			***
				
				FLAG_NUOVO_PIANO=.T.
				FLAG_SALVA_PIANO=.T.
				  
			ENDIF
			
		ELSE
		*** aggiorno il piano 
		***
			FLAG_SALVA_PIANO=.T.
			FLAG_NUOVO_PIANO=.F.
		ENDIF
	ELSE
	*** il piano non esiste
	*** ne creo uno nuovo
	
		FLAG_NUOVO_PIANO=.T.
		FLAG_SALVA_PIANO=.T.
		
	ENDIF

	IF FLAG_NUOVO_PIANO	
	
		PUB_PR1_DATPIA=RIBALTA2(DTOC(DATE()))

		*** CALCOLO IL NUMERO DEL NUOVO PIANO DI PRODUZIONE
		***		
	**** SIMONE cSql = "select COUNT(*) as ultimo from U_PRD_D1 where SUBSTRING(PR1_DATPIA,1,4) = '"+PUB_ANNO+"'" 
		cSql = "select MAX(PR1_NUMPRG) as ultimo from U_PRD_D1 where SUBSTRING(PR1_DATPIA,1,4) = '"+PUB_ANNO+"'" 		
	    IF !ExecCommand(CSQL,"U_PRD_D1")
	       RETURN (.f.)
	    ENDIF  
	    
	    SELECT U_PRD_D1

	    __ULTIMO = ultimo
	    
	    IF ISNULL(ultimo)
	    	__ULTIMO = '00000'     
	    ENDIF
	    
		PUB_PR1_NUMPIA=STR_FILL_ZERO(VAL(__ULTIMO)+1,5)
		PUB_PJ_PRGPRD1="PIANO_PROD_"+PUB_PR1_NUMPIA+"_"+SUBSTR(PUB_PR1_DATPIA,1,4)+SYS(2015)
		
		*** INSERISCO NUOVO PIANO DI PRODUZIONE
		cSql=""     
		cNomeCursorSql="U_PRD_D1"
				
		TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
		
		INSERT INTO U_PRD_D1 (PJ_PRGPRD1,PR1_NUMPIA,PR1_DATPIA,PR1_NUMPRG,PR1_DATPRG) VALUES ('<<PUB_PJ_PRGPRD1>>','<<PUB_PR1_NUMPIA>>','<<PUB_PR1_DATPIA>>','<<PUB_PR1_NUMPIA>>','<<PUB_PR1_DATPIA>>')
			
		ENDTEXT					&& FINE SCRITTURA QUERY
		
		IF !ExecPreparedCommand(cSql,cNomeCursorSql)
			return(.F.)
		ENDIF
		
	ENDIF
	
	IF FLAG_SALVA_PIANO
	
		DO STORE_ALL_TABLES

	ENDIF
	
	RETURN FLAG_SALVA_PIANO
	
* FINE PROCEDURE TAPPETO2DB
**********************************************************


**********************************************************
PROCEDURE GENERA_ORDINE_INTERNO
**********************************************************

	****************************************
	***INIZIALIZZO VARIABILI "M." DI TESTATA
	****************************************
	Csql = "select * from u_ord_tt where 1=0"
	IF !ExecCommand(cSql,"CU_ORD_TT")
	   return(.f.)
	ENDIF
	SELECT CU_ORD_TT
	GO TOP
	SCATTER MEMVAR MEMO
	
	M.ORD_CODOPE = PUB_NOMOPE
	M.TAGGANCIO  = STR(NEWPROG('NUMORD'),10)
	_X_TAGGA     = M.TAGGANCIO 
	M.ORD_CODSOC = PUB_CODSOC
	M.ORD_CODSYS = SYS(2015) 
	
	*DO GESTIONE_RIEPILOGO WITH 'INS','ORD',ORD_CAUS,SPACE(10)	&& INSERIMENTO NUOVI RIEPILOGHI SU U_VEN_CL
	
	***AGGIORNO IL NUMERO ORDINE
	IF !PUB_NORD 				&& SE VERO NON GESTISCE IL NUMERO ORDINE CLIENTE
	   SS=SELECT()
	   v_seek   = ACCESS_YEAR('NUMORD'+PUB_CODSOC)
	   v_chiave = "codice"
	   cSql="select * from para where " + v_chiave + " = '" + v_seek + "'"
	   IF !ExecRW(cSql,"PARA","R")
	      return(.f.)
	   ENDIF
	   SELECT PARA
	   IF RECCOUNT() <> 0
	      V2=VAL(SUBSTR(LIBERA,1,7)) + 1
	      REPLACE LIBERA WITH SUBSTR(STR(V2,7,0),1,7)
	      M.ORD_NUMORD = ALLTRIM(SUBSTR(STR(V2,7,0),1,7))
	   ELSE
	      RIT = MSGBOX('Parametro numero ordine non trovato','ATTENZIONE',31)
	      SELECT(SS)
	      RETURN
	   ENDIF
	   IF !ExecRW(cSql,"PARA","W")
	      return(.f.)
	   ENDIF
	   SELECT(SS)
	ENDIF
	PUB_LNO      = 6
