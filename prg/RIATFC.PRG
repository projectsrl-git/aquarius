*****************
PROCEDURE CALCIVA
*****************
SELECT W_FAT
GO TOP

TOTALE_DOCUMENTO_RICALCOLATO = 0 
 
DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF
   
   VALIVA = W_IMPONI * IVAREAL(W_IVA)
   CIVA   = W_IVA
  
   IF XVALUTA = "ITL" .OR.  XVALUTA = "LIT"
      VALIVA	=	ROUND((VALIVA+.49),0)
   ELSE
      VALIVA	=	ROUND((VALIVA+.0000),2)
   ENDIF
   
   TIVA  = TIVA + VALIVA
   REPLACE    W_IMPOSTA WITH VALIVA
   
   
*!*	   V_TOTALE = V_TOTALE + VALIVA
   TOTALE_DOCUMENTO_RICALCOLATO = TOTALE_DOCUMENTO_RICALCOLATO + W_IMPONI + VALIVA
   
	**=> ERASMO - INIZIO 29/05/2023
	*** GESTIONE IVA INDETRAIBILE
	SELECT W_FAT
	IMPOSTA = W_IMPOSTA
	IMPONI = W_IMPONI
	

	** 13/07/2023 SERGIO INIZIO: MANCA L'ACCESSO ALLA TABELLA IVA 
    v_seek	 = 'IVA'+IVA
    v_chiave = "codice"
    IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
    ELSE
       PUB_ERRORE=MESSAGEBOX('Codice iva non esistente'+CHR(13)+;
                             'in arhivio parametri',64,'*** ATTENZIONE ***')
    ENDIF
	** 13/07/2023 SERGIO FINE: MANCA L'ACCESSO ALLA TABELLA IVA 
	
	SELECT CUR_PARA
	LIB     = VAL(SUBSTR(LIBERA,1,3))
	PERIVAI = VAL(SUBSTR(LIBERA,110,3))
	TIPOIVA = SUBSTR(LIBERA,100,1)
	SCARTO  = 0
	
	IF PERIVAI = 0
	    SELECT W_FAT 	&& 13/07/2023 SERGIO MANCAVA LA SELECT PER CUI FACEVA DANNI
		SKIP +1
		LOOP
	ENDIF
	
	IVINDE = IMPOSTA * (PERIVAI/100)
	IF XVALUTA = "ITL" .OR. XVALUTA="LIT"
	   IVINDE   =ROUND(IVINDE,0)
	ELSE
	   IVINDE   =ROUND(IVINDE,2)
	ENDIF

	RIPORTO = IMPOSTA - IVINDE
	IMPOSTA = IVINDE                              && IMPOSTA INDEDUCIBILE

	IF RIPORTO = 0
	   RIPORTO = IMPOSTA
	   IMPOSTA = 0                                && IMPOSTA INDEDUCIBILE 100%
	ENDIF
	
	IMPONI = IMPONI + RIPORTO
	
	SELECT W_FAT
	REPLACE W_IMPONI WITH IMPONI
	REPLACE W_IMPOSTA WITH IMPOSTA
	**=> ERASMO - FINE 29/05/2023
   
   SKIP +1
ENDDO

RETURN


