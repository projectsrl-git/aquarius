**********************************************************
PROCEDURE CREA_W_FAT_CON_DIVERSE_RIGHE_COMMESSA_ATTRIBUITE
**********************************************************
*!*	LA FATTURA CONTIENE ALMENO DUE RIGHE CON DUE NUMERI DI COMMESSA
*!*	ATTRIBUITI , E' QUINDI NECESSARIO NEL CURSORE W_FAT PIU' RIGHE 
*!*	CON RELATIVI IMPORTI E NUMERO DI COMMESSA ORIGINARIAMENTE ATTRIBUITO

_____SELE=SELECT()


__NUMERO_COMMESSA  = ""

SELECT CU_RIA_DD
GO TOP


DO WHILE !EOF()

	_CONDET = ORD_CONDET
	_CCODET = ORD_CCODET
	_DESCRI = ALLTRIM(ORD_DESART)  && ERASMO - 24/04/2015
	
	_DETT_CONTO  = CONTO 
	_DETT__CCOSTO = ___CCOSTO

	IF !EMPTY(_CCODET )
		_DETT__CCOSTO =_CCODET 
	ENDIF	

	jNUMERO_COMMESSA  	= ORD_NUCOM  

    IF ORD_SPESE = 'S' OR ORD_SPESE = 'C'
    ELSE

	    jVALORE				= ORD_VALORE + ORD_CONTRIB	&& SERGIO 2028/09/30 ALTRIMENTI NON SOMMA I CONTRIBUTI DEL 4% C.M.P.A.I.A
	    jIVA 				= ORD_IVA
	    
	    
		IF !EMPTY(_CONDET)
			_DETT_CONTO  =	_CONDET
		ENDIF
	    
	    ** GESTIONE COMPENSI COMPRENSIVI DI C.O.M.P.A.I.A.
	    SELECT W_FAT
	    SEEK _DETT_CONTO  + ALLTRIM(_DETT__CCOSTO ) + 'D' +jIVA
	    IF FOUND()
	      REPLACE W_IMPONI WITH W_IMPONI + jVALORE
	    ELSE
	      APPEND BLANK 
	      REPLACE W_IMPONI WITH jVALORE
		  REPLACE W_CONTO  WITH _DETT_CONTO  
	      REPLACE W_CCOSTO WITH _DETT__CCOSTO 
		  REPLACE W_IVA    WITH jIVA
		  REPLACE W_DA     WITH 'D'
		  REPLACE W_NUCOM  WITH jNUMERO_COMMESSA
		  REPLACE W_DESCRI WITH _DESCRI  && ERASMO - 24/04/2015
	    ENDIF
	    
	    SELECT CU_RIA_DD
	    SKIP
	    LOOP	
    ENDIF

	SELECT CU_RIA_DD
    IF ORD_SPESE = 'S'	
    
    	_DETT_CONSPE   	= VEDIFOR1(V_CODCLI)					&& PRELEVA CONTO SPESE SOSTENUTE
	    
		IF !EMPTY(_CONDET)
			_DETT_CONSPE   =	_CONDET
		ENDIF

	   VALSPE   	= ORD_VALORE								&& VALORE DELLE SPESE SOSTENUTE
	   IVASPE   	= ORD_IVA									&& CODICE IVA SPESE

	   ** GESTIONE SPESE SOSTENUTE 
	   SELECT W_FAT
	   SEEK _DETT_CONSPE   + ALLTRIM(_DETT__CCOSTO ) + 'D' +IVASPE   
	   IF FOUND()
	      REPLACE W_IMPONI WITH W_IMPONI + VALSPE   
	   ELSE
	      APPEND BLANK 
	      REPLACE W_IMPONI WITH VALSPE   
		  REPLACE W_CONTO  WITH _DETT_CONSPE   
          REPLACE W_CCOSTO WITH _DETT__CCOSTO 
		  REPLACE W_IVA    WITH IVASPE   
		  REPLACE W_DA     WITH 'D'
	      REPLACE W_NUCOM  WITH jNUMERO_COMMESSA
	      REPLACE W_DESCRI WITH _DESCRI  && ERASMO - 24/04/2015
	   ENDIF
	   
	    SELECT CU_RIA_DD
	    SKIP
	    LOOP	   
    ENDIF 	


	SELECT CU_RIA_DD
    IF ORD_SPESE = 'C'	
    
	   VALCASPR   	= ORD_VALORE								&& VALORE DELLA CASSA PREVIDENZA
	   IVACASPR   	= ORD_IVA									&& CODICE IVA CASSA PREVIDENZA
	   _DETT_CONCASPR   	= VEDIFOR1(V_CODCLI)				&& PRELEVA CONTO CASSA PREVIDENZA

		IF !EMPTY(_CONDET)
			_DETT_CONCASPR   =	_CONDET
		ENDIF    
    
	   ** GESTIONE CASSA PREVIDENZA 
	   SELECT W_FAT
