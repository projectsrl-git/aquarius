   **=> ERASMO/FABIANO - INIZIO 24/04/2015
   IF PUB_PRDISP  && SOLO AZIENDA CON TIPO PROD. DISPOSITIVI MEDICALI
      XDESF=M.DSCR
   ENDIF
   **=> ERASMO/FABIANO - FINE 24/04/2015
    
   DO movcreat WITH DAVD,TOTALE_DOCUMENTO_RICALCOLATO ,0,'NO',M.CONTO,TOP_TOP,M.DOC,M.DTD,M.OLFAT,XVALUTA,XCAMBIO	&&TESTATA
  
   DO movcreai WITH DAVD,TOTALE_DOCUMENTO_RICALCOLATO ,0,'NO',M.CONTO,TOP_TOP,M.DOC,M.DTD,M.OLFAT,XVALUTA,XCAMBIO	&&INDICE
   
   
   SELECT W_FAT
   GO TOP


   X_TOTALE = 0

 
   DO WHILE .T.
 
      IF EOF()
         EXIT
      ENDIF 

 	  Z_CONTO  				= W_CONTO
	  Z_NATURA 				= DAVA
	  Z_CODGRU 				= ''
	  Z_CODCCO 				= W_CCOSTO
	  Z_VALORE 				= W_IMPONI
	  Z_PERCEN 				= 100
	  Z_NDOC  				= M.DOC
	  Z_TOP    				= TOP_TOP
	  Z_IVA    				= W_IVA
	  Z_CAMBIO 				= XCAMBIO
	  Z_VALUTA 				= XVALUTA
	  Z_PUBBLI 				= W_PUBBLI
      Z__NUMERO_COMMESSA 	= W_NUCOM
      Z_DESCRI				= W_DESCRI  && ERASMO - 24/04/2015
       

      X_TOTALE = X_TOTALE + (W_IMPONI + W_IMPOSTA)
      IF (V_TOTALE - X_TOTALE) > 0 .AND. (V_TOTALE - X_TOTALE) <= 1
         REPLACE W_IMPOSTA WITH  W_IMPOSTA + DIFF_TOT
         DIFF_TOT  = 0
      ENDIF     
  

      OLD_DESF=XDESF
*!*	      XDESF="FOR:"+ALLTRIM(SUBSTR(M.CONTO,5,9))+" N.F:"+M.OLFAT+" DEL "+M.DTD
*!*	      XDESF="FOR:"+ALLTRIM(SUBSTR(M.RAGSOC,1,10))+" N.F:"+M.OLFAT+" DEL "+M.DTD
      XDESF="FAT. NR.: " + ALLTRIM(M.OLFAT)+ " DEL " + RIBALTA2(M.DTD) + " DI " + ALLTRIM(M.RAGSOC)	&& SERGIO 2019/02/09: IMPOSTO QUESTO FORMATO ALLINEANDOLO ALLA PRIMA NOTA E FATTURA ELETTRONICA IMPORTATA
     
      
      **=> ERASMO/FABIANO - INIZIO 24/04/2015
      IF PUB_PRDISP  && SOLO AZIENDA CON TIPO PROD. DISPOSITIVI MEDICALI
         XDESF=Z_DESCRI
      ENDIF
      **=> ERASMO/FABIANO - FINE 24/04/2015


      DO movcrea WITH DAVA,W_IMPONI,W_IMPOSTA,W_IVA,W_CONTO,TOP_TOP,M.DOC,M.DTD,M.OLFAT,XVALUTA,XCAMBIO,Z__NUMERO_COMMESSA  	&&DET ACQUISTO

	  IF !EMPTY(Z_CODCCO)
		  Z_CONTOP = X_CONTOP
		  DO CREA_CENTRI_DI_COSTO_DALLE_FATTURE_PROFESSIONISTI WITH Z_CONTO,Z_NATURA ,Z_CODGRU,Z_CODCCO,Z_VALORE,Z_PERCEN,Z_NDOC,Z_TOP,Z_IVA,Z_CAMBIO,Z_VALUTA,Z_PUBBLI,Z_CONTOP 
		  Z_CODCCO = ""
	  ENDIF	

      Z__NUMERO_COMMESSA = ''
      DO movcrea WITH DAVA,W_IMPOSTA,0,W_IVA,CON_IVA,TOP_TOP,M.DOC,M.DTD,M.OLFAT,XVALUTA,XCAMBIO,Z__NUMERO_COMMESSA  			&&DET IVA
      
      
      
      SELECT W_FAT
 	  SKIP +1
   
   ENDDO
   
	** 20/07/2022 SERGIO INIZIO: GESTIONE PLAFOND IVA FORNITORI PROFESSIONISTI
	SELECT CORPO_MOV_SAVE
	SET ORDER TO I_SEQUEN
	GO TOP
	=AGGIORNAMENTO_PLAFOND_IVA_FORNITORI_PROFESSIONISTI()
	** 20/07/2022 SERGIO FINE: GESTIONE PLAFOND IVA FORNITORI PROFESSIONISTI   
   
   
   
   SELECT U_RIA_TT
   REPLACE ORD_FLGFTC WITH .T.
   REPLACE ORD_DATFTC WITH ribalta2(XDATA)
   REPLACE ORD_CHIUSO WITH .T.
 
   CT = CT +1
   SKIP +1

ENDDO

IF !ExecRW(Csql,"U_RIA_TT","W")
   return(.f.)
ENDIF

