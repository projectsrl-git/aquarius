** 20/07/2022 SERGIO INIZIO: GESTIONE PLAFOND IVA FORNITORI PROFESSIONISTI
***********************************************************
FUNCTION AGGIORNAMENTO_PLAFOND_IVA_FORNITORI_PROFESSIONISTI
***********************************************************
SELE_XX=SELECT()


SELECT CORPO_MOV_SAVE
SET ORDER TO I_SEQUEN
GO TOP
IF EOF()
	RETURN	&& NESSUN AGGIORNAMENTO
ENDIF

IF PUB_PLAFACQ OR PUB_PLAFACQF
ELSE  
	RETURN(.T.)  
ENDIF

* PREPARO LE VARIABILI PER IL RICHIAMO DELLE ROUTNE ESISTENTI
FATTURA   = "S"  		&& TRATTA SOLO LE FATTURE DI ACQUISTO
VER_CONTO = "F"   		&& TRATTA SOLO I FORNITORI
_CODICE_FORNITORE = ALLTRIM(PUB_CONTO_FORNITORE)


_ANNO_PLAFOND = PUB_ANNO
IF PUB_PLADFA
	SELECT CORPO_MOV_SAVE
	SET ORDER TO I_SEQUEN
	GO TOP
	_ANNO_PLAFOND = SUBSTR(DTDOCUM,7,4)	&& DATA DOCUMENTO DELLA PRIMA NOTA ORIGINALE
	*_ANNO_PLAFOND = SUBSTR(DATADOC,7,4)	&& DATA DOCUMENTO DELLA PRIMA NOTA ORIGINALE
ENDIF

IF PUB_PLAFACQF 								&& VERIFICA SE ATTIVA GESTIONE PLAFOND IVA PER FORNITORE
	SELECT CORPO_MOV_SAVE
 	DO REG_PLAFOND_FORNITORI_RITENUTE_ACCONTO	&& SE ATTIVA LA GESTIONE DEL PLAFOND PER FORNITORE AGGIORNA U_IVA_FE
ENDIF

	
IF PUB_PLAFACQ
	DO REG_PLAFOND_RITENUTE_ACCONTO				&& CONTROAGGIORNA ARCHIVIO IVA ACQUISTI IN ESENZIONE IVA E RICALCOLA IL PLAFOND RESIDUO DI TUTTI I FORNITORI
ENDIF


**==> Cursore di salvataggio prima nota originale per gestire le esenzioni iva sui prodotti acquistati al fine del calcolo del plafond residuo
CREATE CURSOR CORPO_MOV_SAVE ;
       (DTREGIS C(10),DTDOCUM C(10),CONTO C(13),DESCRIC C(40),CECO C(13),DARE N(14,3),AVERE N(14,3),IVA C(3),	        				;
        IMPOSTA N(13,3),IMPOSTA_D N(16,3),IMPOSTA_A N(16,3),NATURA C(1),SEQUEN N(15))
INDEX ON SEQUEN TAG I_SEQUEN ADDITIVE
SELECT CORPO_MOV_SAVE
SET ORDER TO I_SEQUEN
GO TOP



SELECT(SELE_XX)
RETURN(.T.)











