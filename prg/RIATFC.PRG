********************
PROCEDURE CREA_W_FAT
********************


    ** GESTIONE COMPENSI COMPRENSIVI DI C.O.M.P.A.I.A.
    SELECT W_FAT
    SEEK CONTO + ALLTRIM(___CCOSTO) + 'D' +IVA
    IF FOUND()
      REPLACE W_IMPONI WITH W_IMPONI + VALORE
    ELSE
      APPEND BLANK 
      REPLACE W_IMPONI WITH VALORE
	  REPLACE W_CONTO  WITH CONTO
      REPLACE W_CCOSTO WITH ___CCOSTO
	  REPLACE W_IVA    WITH IVA
	  REPLACE W_DA     WITH 'D'
	  REPLACE W_NUCOM  WITH __NUMERO_COMMESSA
    ENDIF
 	      
    IF VALSPE <> 0	
	   ** GESTIONE SPESE SOSTENUTE 
	   SELECT W_FAT
	   SEEK CONSPE + ALLTRIM(___CCOSTO) + 'D' +IVASPE   
	   IF FOUND()
	      REPLACE W_IMPONI WITH W_IMPONI + VALSPE   
	   ELSE
	      APPEND BLANK 
	      REPLACE W_IMPONI WITH VALSPE   
		  REPLACE W_CONTO  WITH CONSPE   
          REPLACE W_CCOSTO WITH ___CCOSTO
		  REPLACE W_IVA    WITH IVASPE   
		  REPLACE W_DA     WITH 'D'
	      REPLACE W_NUCOM  WITH ''
	   ENDIF
   ENDIF 	



   IF VALCASPR   <> 0	
	   ** GESTIONE CASSA PREVIDENZA 
	   SELECT W_FAT
	   SEEK CONCASPR  + ALLTRIM(___CCOSTO) + 'D' +IVACASPR   
	   IF FOUND()
	      REPLACE W_IMPONI WITH W_IMPONI + VALCASPR   
	   ELSE
	      APPEND BLANK 
	      REPLACE W_IMPONI WITH VALCASPR   
		  REPLACE W_CONTO  WITH CONCASPR   
          REPLACE W_CCOSTO WITH ___CCOSTO
		  REPLACE W_IVA    WITH IVACASPR   
		  REPLACE W_DA     WITH 'D'
	      REPLACE W_NUCOM  WITH ''
	   ENDIF
   ENDIF 	

 	



RETURN

