*********** PER RICERCA *************


CREATE CURSOR APPOGGIO ;
	(NOMEFILE_A C(100), DATACRE_A C(10), ORACRE_A C(10), DIMENSIONE_A N(10))


CREATE CURSOR DOC_R ;
	(NOMEFILE_R C(100), DATACRE_R C(10), ORACRE_R C(10), DIMENSIONE_R N(10))


INDEX ON RIBALTA2(DATACRE_R) TAG I_DATA_R ADDITIVE
INDEX ON ORACRE_R TAG I_ORACRE_R ADDITIVE
INDEX ON DIMENSIONE_R TAG I_DIME_R ADDITIVE
INDEX ON NOMEFILE_R TAG D_NOME_R DESC ADDITIVE 
INDEX ON RIBALTA2(DATACRE_R) TAG D_DATA_R DESC ADDITIVE 
INDEX ON ORACRE_R TAG D_ORACRE_R DESC ADDITIVE 
INDEX ON DIMENSIONE_R TAG D_DIME_R DESC ADDITIVE 
INDEX ON NOMEFILE_R TAG I_NOME_R ADDITIVE

***************************************
		
CREATE CURSOR DOCUMENTI ;
	(PERCORSO C(250), NOMEFILE C(240), DATACRE C(10), DIMENSIONE N(10), ;
		ORACRE C(10))

INDEX ON RIBALTA2(DATACRE) TAG I_DATA ADDITIVE
INDEX ON ORACRE TAG I_ORACRE ADDITIVE
INDEX ON DIMENSIONE TAG I_DIME ADDITIVE
INDEX ON NOMEFILE TAG D_NOME DESC ADDITIVE 
INDEX ON RIBALTA2(DATACRE) TAG D_DATA DESC ADDITIVE 
INDEX ON ORACRE TAG D_ORACRE DESC ADDITIVE 
INDEX ON DIMENSIONE TAG D_DIME DESC ADDITIVE
INDEX ON ALLTRIM(UPPER(NOMEFILE)) TAG I_NOME ADDITIVE


GO TOP

NDOC = ADIR(MADOC,'*.*')
=ASORT(MADOC,1)


FOR DOC = 1 TO NDOC
  M.NOMEFILE 	= MADOC[DOC,1]
  M.DIMENSIONE 	= MADOC[DOC,2]
  M.DATACRE		= MADOC[DOC,3]
  M.ORACRE		= MADOC[DOC,4]  
  M.PERCORSO	= ALLTRIM(FULLPATH(M.NOMEFILE))
  SELECT DOCUMENTI
  APPEND BLANK
  GATHER MEMVAR MEMO
ENDFOR

SELECT DOCUMENTI
SET ORDER TO I_NOME
GO TOP






****************** PER ARGOMENTO ******************

CREATE CURSOR LISTA_AR ;
	(NOMEFILE_AR C(100),datacre C(10))

INDEX ON NOMEFILE_AR TAG D_NOME_AR DESC ADDITIVE 
INDEX ON RIBALTA2(DATACRE) TAG I_DATA ADDITIVE
