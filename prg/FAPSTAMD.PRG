*************************
PROCEDURE STAMPA_DETTAGLI		&& STAMPA DETTAGLI
*************************

SELECT CU_FAP_DD
GO TOP

DO WHILE .T.

   IF EOF()
     EXIT
   ENDIF

   * Note

   IF ALLTRIM(DAGGANCIO) = "EOF"
     SELECT CU_FAP_DD
     SKIP
     LOOP
   ENDIF

   V_CA       = ALLTRIM(ORD_CODICE)

   =ESPL_UGUA()				&& GESTIONE UGUALI A DX PER TESTI AUTOMATICI


   IF ALLTRIM(ORD_DESART)="*** COMMENTO ***"
     DO ESPL_COMM WITH 40	&& il parametro corrisponde al numero di caratteri che si vogliono
     						&& assegnare al commento
     SELECT CU_FAP_DD
     SKIP
     LOOP
   ENDIF

   * Codice Articolo

   SELECT CU_FAP_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 3
   V_CAMPO    = ALLTRIM(ORD_CODART)

   IF SUBSTR(V_CAMPO,1,1) = "." .OR.  SUBSTR(V_CAMPO,1,1) = "/"
     V_CAMPO = " "
   ENDIF

   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

   * Descrizione

   SELECT CU_FAP_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 11
   V_CAMPO    = ALLTRIM(SUBSTR(ORD_DESART,1,33))
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

   * Quantitŕ

   SELECT CU_FAP_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 44
   V_CAMPO    = ALLTRIM(STR(ORD_QTAORD,7,2))
   V_CAMPO    = PADL(V_CAMPO, 9, ' ')
   *V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),7,2))
   IF SUBSTR(V_CA,1,3) = ".SC"
      V_CAMPO= "  "
   ENDIF

   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

   * Prezzo

   SELECT CU_FAP_DD

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 52
   *V_CAMPO    = ALLTRIM(STR(ORD_PREZZO,11,2))
   V_CAMPO    = ALLTRIM(STR(ORD_PRZNET,11,2))
   *V_CAMPO    = PADL(V_CAMPO, 10, ' ')

   IF V_VALUTA = "ITL" .OR. V_VALUTA = "LIT"
	     V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),11,0))
   ELSE
	   IF V_VALUTA = "EUR"
	     V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),12,6))
	   ELSE
	     V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),11,2))
	   ENDIF
   ENDIF

   IF SUBSTR(V_CA,1,3) = ".SC"
      V_CAMPO= "  "
   ENDIF


   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

   * Importo

   SELECT CU_FAP_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 68
   V_CAMPO    = ALLTRIM(STR(ORD_VALORE,11,2))
   *V_CAMPO    = PADL(V_CAMPO, 15, ' ')

   IF V_VALUTA = "ITL" .OR. V_VALUTA = "LIT"
     V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),11,0))
   ELSE
     V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),11,2))
   ENDIF

   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

   * IVA

   SELECT CU_FAP_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 85
   V_CAMPO    = ALLTRIM(ORD_IVA)

   IF SUBSTR(V_CA,1,3) = ".SC"
      V_CAMPO= "  "
   ENDIF

   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

   * Ulteriore descrizione articolo se fattura export

   IF  M.ORD_CODNAZ  <> "ITA"
	   V_NUMDET = V_NUMDET + 1
	   V_NUMRIG = V_NUMRIG + 1
	   SELECT CU_FAP_DD
	   V_PAGINA   = V_NUMPAG
	   V_RIGA     = V_NUMRIG
	   V_COLONNA  = 11
	   V_CAMPO    = ALLTRIM(SUBSTR(ORD_DES2,1,33))
	   V_LENCAMPO = LEN(V_CAMPO)
	   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO
   ENDIF



   IF V_NUMRIG >= _TOT_RIGHE+START_DE

     V_NUMRIG = V_NUMRIG + 1

     SELECT CU_FAP_DD
     V_PAGINA   = V_NUMPAG
     V_RIGA     = V_NUMRIG
     V_COLONNA  = 1
     *V_CAMPO    = "" + ""
     V_CAMPO    = ""
     V_LENCAMPO = LEN(V_CAMPO)
     DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

     DO STAMPA_TESTATA
     V_NUMDET=0
     V_NUMRIG=START_DE - 1

   ENDIF


   V_NUMDET = V_NUMDET + 1
   V_NUMRIG = V_NUMRIG + 1


   SELECT CU_FAP_DD

   SKIP +1
   LOOP

ENDDO



