*************************
FUNCTION ESPL_COMM
*************************
PARA _NUM_CAR

_SSXX=SELECT()
_RECORDXXX=RECNO()

POSIZIONE=0
PARZIALE =0
RIGA	   =""
V_NOTE=ORD_NOTE

LUNGH_MEMO=LEN(ALLTRIM(V_NOTE))

DO WHILE .T.

  POSIZIONE=POSIZIONE+1
  PARZIALE =PARZIALE+1

  CARATTERE=SUBSTR(V_NOTE,POSIZIONE,1)

****** TERMINO UNA RIGA PERCHE':
****** FINITO COMMENTO

  IF POSIZIONE >= LUNGH_MEMO
    RIGA=RIGA+CARATTERE
    V_PAGINA   = V_NUMPAG
    V_RIGA     = V_NUMRIG
    V_COLONNA  = 11
    V_CAMPO    = RIGA
    V_LENCAMPO = LEN(V_CAMPO)
    DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

    DO ESPL_VACO

    IF V_NUMRIG >= _TOT_RIGHE+START_DE

      V_NUMRIG = V_NUMRIG + 1
      SELECT CU_FAP_DD
      V_PAGINA   = V_NUMPAG
      V_RIGA     = V_NUMRIG
      V_COLONNA  = 1
      *V_CAMPO    = "" + ""
      V_CAMPO    = ""
      V_LENCAMPO = LEN(V_CAMPO)
      DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

      DO ESPL_VACO

      DO STAMPA_TESTATA

      V_NUMDET=0
      V_NUMRIG=START_DE - 1
    ENDIF

    V_NUMDET = V_NUMDET + 1
    V_NUMRIG = V_NUMRIG + 1

    EXIT
  ENDIF


****** TERMINO UNA RIGA PERCHE':
****** RAGGIUNTO NUM MAX DI CARATTERI PER RIGA PER UN COMMENTO  (40)

  IF PARZIALE >= _NUM_CAR
    RIGA=RIGA+CARATTERE

    V_PAGINA   = V_NUMPAG
    V_RIGA     = V_NUMRIG
    V_COLONNA  = 11
    V_CAMPO    = RIGA
    V_LENCAMPO = LEN(V_CAMPO)
    DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

    DO ESPL_VACO

    RIGA	  =""
    RIGA_SPEZZ=""
    PARZIALE=0
    ULTIMOSPAZIO=.F.
    NUM_SPAZI=OCCURS(" ",SUBSTR(V_NOTE,POSIZIONE+1,40))

    IF V_NUMRIG >= _TOT_RIGHE+START_DE
      V_NUMRIG = V_NUMRIG + 1
      SELECT CU_FAP_DD
      V_PAGINA   = V_NUMPAG
      V_RIGA     = V_NUMRIG
      V_COLONNA  = 1
      *V_CAMPO    = "" + ""
      V_CAMPO    = ""
      V_LENCAMPO = LEN(V_CAMPO)
      DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

      DO ESPL_VACO

      DO STAMPA_TESTATA
      V_NUMDET=0
      V_NUMRIG=START_DE - 1
    ENDIF

    V_NUMDET = V_NUMDET + 1
    V_NUMRIG = V_NUMRIG + 1

    LOOP
  ENDIF


****** TERMINO UNA RIGA PERCHE':
****** TROVO IL CARATTERE "A CAPO"

  IF CARATTERE=CHR(13)
    POSIZIONE=POSIZIONE+1				&& SALTA IL CARATTERE FINE RECORD PER NON VISUALIZZARLO

    V_PAGINA   = V_NUMPAG
    V_RIGA     = V_NUMRIG
    V_COLONNA  = 11
    V_CAMPO    = RIGA
    V_LENCAMPO = LEN(V_CAMPO)
    DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

    DO ESPL_VACO

    RIGA	  =""
    RIGA_SPEZZ=""
    PARZIALE=0
    ULTIMOSPAZIO=.F.
    NUM_SPAZI=OCCURS(" ",SUBSTR(V_NOTE,POSIZIONE+1,40))

    IF V_NUMRIG >= _TOT_RIGHE+START_DE
      V_NUMRIG = V_NUMRIG + 1
      SELECT CU_FAP_DD
      V_PAGINA   = V_NUMPAG
      V_RIGA     = V_NUMRIG
      V_COLONNA  = 1
      *V_CAMPO    = "" + ""
      V_CAMPO    = ""
      V_LENCAMPO = LEN(V_CAMPO)
      DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

      DO ESPL_VACO

      DO STAMPA_TESTATA
      V_NUMDET=0
      V_NUMRIG=START_DE - 1
    ENDIF

    V_NUMDET = V_NUMDET + 1
    V_NUMRIG = V_NUMRIG + 1

    LOOP
  ENDIF

  RIGA=RIGA+CARATTERE

ENDDO

