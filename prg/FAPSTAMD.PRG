********************************************************
*	STAMPA FATTURE IN FORMATO DOS TRAMITE SPOOLER
********************************************************
PARA _XXX_OPT

_N_PAR  = PARAMETERS()

IF _N_PAR   = 0
  _TIPO_OP = ""
ELSE
  _TIPO_OP = _XXX_OPT
ENDIF

RELEASE V_NUMPAG,V_NUMRIG,V_NUMDET,START_TE,START_DE,ROT_PAG,_TOT_RIGHE,SAY_PORTO
PUBLIC  V_NUMPAG,V_NUMRIG,V_NUMDET,START_TE,START_DE,ROT_PAG,_TOT_RIGHE,SAY_PORTO

V_NUMPAG = 0
V_NUMRIG = 90
V_NUMDET = 90
START_TE = 4
START_DE = 16
START_TO = 48
ROT_PAG  = 28
_TOT_RIGHE=28
V_TOTRIG = 66
SAY_PORTO = ""

NUMPRO=TAGGANCIO
SELECT CU_FAP_DD

DO STAMPAMOD
SELECT CU_FAP_DD

ANCORA = 1

** CREAZIONE CURSORE PER PAGINA/RIGA

CREATE CURSOR FILE_STA (STA_PAGINA N(4), STA_RIGA N(4), STA_RECORD C(132))
INDEX ON STR(STA_PAGINA,4,0) + STR(STA_RIGA,3,0) TAG FILE_IND ADDITIVE
SELECT FILE_STA
SET ORDER TO FILE_IND
GO TOP

IF V_NUMDET > ROT_PAG
   DO STAMPA_TESTATA
   V_NUMRIG = START_DE
   V_NUMDET = 0
ENDIF

DO STAMPA_DETTAGLI

DO STAMPA_TOTALI


****** INIZIO: SISTEMA IL SALTO PAGINA QUANDO L'ULTIMA PAGINA E' VUOTA
****** FABIANO LUNEDI' 25/10/1999

****** PRIMA PARTE
****** QUESTA ROUTINE CONTA LE PAGINE E CONTA I DETTAGLI DELL'ULTIMA PAGINA
SELECT FILE_STA
GO BOTTOM
CTRL_PAG=STA_PAGINA		&& ULTIMA PAGINA
CTRL_DET=0

GO TOP

DO WHILE !EOF()

  IF STA_PAGINA<CTRL_PAG		&& ARRIVO FINO ALL'ULTIMA PAGINA
    SKIP
    LOOP
  ENDIF

  IF STA_RIGA<START_DE			&& SE NON SONO ANCORA ARRIVATO AI DETTAGLI SALTO RIGA
    SKIP
    LOOP
  ENDIF

  IF STA_RIGA>=START_TO			&& SE SONO GIA' AI TOTALI ESCO DAL CICLO
    EXIT
  ENDIF

  IF !EMPTY(STA_RECORD)
    CTRL_DET=CTRL_DET+1
  ENDIF

  SELECT FILE_STA
  SKIP

ENDDO

***	CTRL_PAG ADESSO CONTIENE L'ULTIMA PAGINA
*** CTRL_DET ADESSO CONTIENE I DETTAGLI DELL'ULTIMA PAGINA

****** SECONDA PARTE
****** QUESTA ROUTINE TOGLIE L'ULTIMA PAGINA SE NON CONTIENE DETTAGLI

DO CASE

  CASE CTRL_DET=0				&& HO TROVATO CHE NELL'ULTIMA PAGINA NON CI SONO DETTAGLI
  								&& ALLORA SPOSTO I TOTALI NELLA PENULTIMA PAGINA E CREO UNA FATTURA
  								&& DI UNA RIGA IN MENO....	FABIANO

    SELECT FILE_STA
    GO TOP
    DO WHILE !EOF()

     IF STA_PAGINA<CTRL_PAG		&& ARRIVO FINO ALL'ULTIMA PAGINA SENZA FARE NIENTE
       SKIP
       LOOP
     ENDIF

     IF STA_RIGA<START_TO		&& ARRIVO FINO AI TOTALI DELL'ULTIMA PAGINA CANCELLANDO
								&& TUTTO QUELLO CHE C'E' PRIMA
       DELETE
       SKIP
       LOOP
     ENDIF

     REPLACE STA_PAGINA WITH STA_PAGINA-1 && SPOSTO I TOTALI SULLA PENULTIMA PAGINA

     SELECT FILE_STA
     SKIP

   ENDDO

ENDCASE


****** FINE: SISTEMA IL SALTO PAGINA QUANDO L'ULTIMA PAGINA E' VUOTA
****** FABIANO LUNEDI' 25/10/1999


SELECT FILE_STA
GO TOP

DO PJCOMPLETA WITH V_TOTRIG

DO RILA_VAR    && RELEASE DI TUTTE LE VARIABILI

SELECT FILE_STA
GO TOP

CREATE CURSOR FILE_PRT (PRT_RIGA C(132))
SELECT FILE_PRT
GO TOP

SELECT FILE_STA
SET ORDER TO FILE_IND
GO TOP

IF   _TIPO_OP = "RISTAMPA"
	DO WHILE .T.
	   IF EOF()
	      EXIT
	   ENDIF
	   IF DELETED()
	     SKIP
	     LOOP
	   ENDIF
	   V_RECORD = STA_RECORD
	   SELECT FATT_PRT
	   APPEND BLANK
	   REPLACE PRT_RIGA WITH V_RECORD
	   SELECT FILE_STA
	   SKIP +1
	ENDDO
ELSE
	
	GO BOTTOM
	DELETE			&& CANCELLA ULTIMA RIGA PER LA STAMPA SUCCESSIVA

	GO TOP

	DO WHILE .T.
	   IF EOF()
	      EXIT
	   ENDIF
	   IF DELETED()
	     SKIP
	     LOOP
	   ENDIF
	   V_RECORD = STA_RECORD
	   SELECT FILE_PRT
	   APPEND BLANK
	   REPLACE PRT_RIGA WITH V_RECORD
	   SELECT FILE_STA
	   SKIP +1
	ENDDO
    IF  TI_PX  = "S"			&& VERIFICA SE NOTA CREDITO
		DO CREA_SPOOL WITH "FILE_PRT","NOTA CRED. "+ALLTRIM(M.ORD_NUMORD)+" - "+M.ORD_DATORD
    ELSE
		DO CREA_SPOOL WITH "FILE_PRT","FATTURA PROFORMA N. "+ALLTRIM(M.ORD_NUMORD)+" - "+M.ORD_DATORD
	ENDIF
	=MESSAGEBOX("FINE ELABORAZIONE. PROCEDI CON LA STAMPA TRAMITE LO SPOOLER",62,"ATTENZIONE")
ENDIF

RELEASE WINDOW DISPLAY

RELEASE V_NUMPAG,V_NUMRIG,V_NUMDET,START_TE,START_DE,ROT_PAG,_TOT_RIGHE

RETURN


