     ELSE
	     V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),11,2))
     ENDIF

  ENDIF
  V_LENCAMPO = LEN(V_CAMPO)
  DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO


  * Codice Iva

  V_PAGINA   = V_NUMPAG
  V_RIGA     = V_NUMRIG
  V_COLONNA  = 17
  V_CAMPO    = PIVA4
  V_LENCAMPO = LEN(V_CAMPO)
  DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO


  * Imposta

  V_PAGINA   = V_NUMPAG
  V_RIGA     = V_NUMRIG
  V_COLONNA  = 21
  IF IMPOS4 = 0
     IF IMPO4=0
       V_CAMPO    = ""
     ELSE
       V_CAMPO    = SUBSTR(GET_DES("IVA",IVA4),1,14)
     ENDIF
  ELSE
     V_CAMPO    = ALLTRIM(STR(IMPOS4,11,2))

	 IF V_VALUTA = "ITL" .OR. V_VALUTA = "LIT"
	     V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),11,0))
     ELSE
	     V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),11,2))
     ENDIF


  ENDIF
  V_LENCAMPO = LEN(V_CAMPO)
  DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO


** IMPOSTA NUOVA RIGA
  V_NUMRIG = V_NUMRIG+1


** IMPOSTA NUOVA RIGA
  V_NUMRIG = V_NUMRIG+1


** IMPOSTA NUOVA RIGA
* V_NUMRIG = V_NUMRIG+1


  * Descrizione del porto

  V_PAGINA   = V_NUMPAG
  V_RIGA     = V_NUMRIG
  V_COLONNA  = 21
  V_CAMPO    = GET_DES("POR",M.ORD_PORTO)
  V_LENCAMPO = LEN(V_CAMPO)
  DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

  * Tipo di valuta

  V_PAGINA   = V_NUMPAG
  V_RIGA     = V_NUMRIG
  V_COLONNA  = 61
  V_CAMPO    = ALLTRIM(V_VALUTA)
  V_LENCAMPO = LEN(V_CAMPO)
  DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

  * Totale Fattura

  V_PAGINA   = V_NUMPAG
  V_RIGA     = V_NUMRIG
  V_COLONNA  = 71
  V_CAMPO    = ALLTRIM(STR(TOT_FATT,11,2))

  IF V_VALUTA = "ITL" .OR. V_VALUTA = "LIT"
	  V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),11,0))
  ELSE
	  V_CAMPO    = PUNTINI(STR(VAL(V_CAMPO),11,2))
  ENDIF

  V_LENCAMPO = LEN(V_CAMPO)
  DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO

RETURN

