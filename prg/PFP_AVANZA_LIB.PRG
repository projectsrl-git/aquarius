***********************************************************************
PROCEDURE PFP_START_BANCALI
***********************************************************************

RELEASE _W_NUMBAN
PUBLIC _W_NUMBAN
_W_NUMBAN = ""

IF USED("CUR_BANCALI")
	SELECT CUR_BANCALI
	USE
ENDIF

CREATE CURSOR CUR_BANCALI (IDBANC C(10), CODCLI C(10), RAGSOC C(80), NUMBAN N(3,0), MISURE C(25), ALTBAN N(10,0), LARBAN N(10,0), LOCKED L, PREESISTENTE L, CODIMB C(3), DESIMB C(50))
SELECT CUR_BANCALI 
INDEX ON CODCLI TAG I_CODCLI ADDITIVE
INDEX ON IDBANC TAG I_IDBANC ADDITIVE
SELECT CUR_BANCALI 
ZAP

ENDPROC


***********************************************************************
PROCEDURE PFP_RIPRENDI_BANCALE
***********************************************************************

LPARAMETERS _PAR_SEL

IF PCOUNT() = 0
   _PAR_SEL = ""
ENDIF

_RITORNO = .F.

_W_NUMBAN = ""
SELECT CUR_BANCALI
DELETE FOR !LOCKED

UPDATE CU_PROD_CARICHI SET NUMBAN = 0, IDBANC = '' WHERE EMPTY(ALLTRIM(CODINT))
UPDATE SEL_PROD_CARICHI SET NUMBAN = 0, IDBANC = '' WHERE EMPTY(ALLTRIM(CODINT))

SELECT DISTINCT CODCLI FROM CU_PROD_CARICHI WHERE EMPTY(ALLTRIM(CODINT)) AND !EMPTY(NUMORD) INTO CURSOR TMP_CLIENTI
SELECT TMP_CLIENTI
GO TOP
IF EOF()
   XDESCRI = "ATTENZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun rotolo da tagliare a cui associare un bancale esistente"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   RETURN .F.
ENDIF
SCAN
   _CODCLI = CODCLI
   _RAGSOC = ""
   SELECT CUR_BANCALI
   APPEND BLANK
   REPLACE IDBANC WITH ""
   REPLACE CODCLI WITH _CODCLI
   REPLACE RAGSOC WITH _RAGSOC
   REPLACE NUMBAN WITH 0
   REPLACE MISURE WITH ""
   REPLACE ALTBAN WITH 0
   REPLACE LARBAN WITH 0
   REPLACE LOCKED WITH .F.
   REPLACE PREESISTENTE WITH .F.
   REPLACE CODIMB WITH ""
   REPLACE DESIMB WITH ""
ENDSCAN

SELECT CUR_BANCALI
SET FILTER TO !LOCKED
GO TOP
IF EOF()
   XDESCRI = "ATTENZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun bancale da gestire"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   SELECT CUR_BANCALI
   SET FILTER TO
   RETURN .F.
ENDIF

SELECT CUR_BANCALI
GO TOP
SCAN
   IF NUMBAN > 0
      LOOP
   ENDIF
   _IDBANC = ""
   _CODCLI = CODCLI
   _RAGSOC = RAGSOC
   _NUMBAN = 0
   _MISURE = ""
   _ALTBAN = 0 
   _LARBAN = 0 
   _CODIMB = ""
   _DESIMB = "" 
   x_clie = "PROD_ORDINI.CODCLI = '" + _CODCLI + "'"
   x_nban = "PROD_CARICHI.NUMBAN > 0"
   x_idbn = "PROD_CARICHI.IDBANC <> ''"
   x_stat = "PROD_CARICHI.STABAN = '01'"
   x_fddt = "PROD_CARICHI.FLGDDT = 0"
   x_npck = "PROD_CARICHI.NUMPCK = ''"
   x_cond = x_clie + " and " + x_nban + " and " + x_idbn + " and " + x_stat + " and " + x_fddt + " and " + x_npck            
   Csql   = "SELECT SELEZIONE, CODCLI, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB, SUM(NUMROT) AS TOTROT FROM ( " + CHR(13) + ;
            "SELECT SPACE(10) AS SELEZIONE, PROD_ORDINI.CODCLI AS CODCLI, IDBANC, NUMBAN, STABAN, DESCRI AS DESSTA, ALTBAN, LARBAN, CODIMB, DESIMB, " + CHR(13) + ;
            "LTRIM(STR(ALTBAN)) + ' X ' + LTRIM(STR(LARBAN)) AS MISURE, COUNT(*) AS NUMROT, 'ROTOLI IN PRODUZIONE' AS TIPO_ROTOLI FROM PROD_CARICHI " + CHR(13) + ;
            "LEFT OUTER JOIN PARA ON PARA.CODICE = ('STB' + PROD_CARICHI.STABAN) " + CHR(13) + ;
            "LEFT OUTER JOIN PROD_ORDINI ON PROD_ORDINI.IDPRG = PROD_CARICHI.IDPRG AND PROD_ORDINI.CODSYS = PROD_CARICHI.SYSORD " + CHR(13) + ;
            "WHERE " + x_cond + CHR(13) + ;
            "GROUP BY CODCLI, IDBANC, NUMBAN, STABAN, ALTBAN, LARBAN, DESCRI, CODIMB, DESIMB " + CHR(13) + ;
            ") AS T1 GROUP BY SELEZIONE, CODCLI, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB"
   IF !ExecCommand(Csql,"SEL_BANCALI")
  	 return(.f.)
   ENDIF
   SELECT SEL_BANCALI
   GO TOP
   IF EOF()
      XDESCRI = "INFORMAZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun bancale in lavorazione per il cliente " + ALLTRIM(_CODCLI)
      MESSAGGIO_GROSSO_BLU(XDESCRI)
      
      SELECT CUR_BANCALI
      DELETE
      
   ELSE
      IF RECCOUNT() = 1 .AND. _PAR_SEL <> "SEL"
         REPLACE SELEZIONE WITH '==>'
         NumeroRecordLetti = 1
      ELSE
         DO prg\aq_browseview WITH "SEL_BANCALI","Selezionare il bancale per il cliente " + ALLTRIM(_CODCLI),;
                                   "NUMBAN:N.Bancale,W:5;DESSTA:Stato,W:55;MISURE:Dimensioni,W:20;TOTROT:TOT Rotoli,W:8;",600,755,.F.,.T.
      ENDIF
      IF NumeroRecordLetti = 0
         XDESCRI = "INFORMAZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun bancale selezionato per il cliente " + ALLTRIM(_CODCLI)
         MESSAGGIO_GROSSO_BLU(XDESCRI)
      ELSE
         SELECT SEL_BANCALI
         GO TOP
         DO WHILE .T.
            IF EOF()
               EXIT
            ENDIF
            IF DELETED()
               SKIP +1
               LOOP
            ENDIF
            IF ALLTRIM(SELEZIONE) = '==>'
               _IDBANC = IDBANC
               _NUMBAN = NUMBAN
               _MISURE = MISURE
               _ALTBAN = ALTBAN
               _LARBAN = LARBAN
               _CODIMB = CODIMB 
               _DESIMB = DESIMB 
               _RITORNO = .T.
               EXIT
            ENDIF
            SKIP +1
         ENDDO
         SELECT CUR_BANCALI
         REPLACE IDBANC WITH _IDBANC
         REPLACE NUMBAN WITH _NUMBAN
         REPLACE MISURE WITH _MISURE
         REPLACE ALTBAN WITH _ALTBAN
         REPLACE LARBAN WITH _LARBAN
         REPLACE PREESISTENTE WITH .T.
         REPLACE CODIMB WITH _CODIMB
         REPLACE DESIMB WITH _DESIMB
      ENDIF
   ENDIF
ENDSCAN

_W_NUMBAN = ""
SELECT CUR_BANCALI
GO TOP
SCAN
   IF DELETED()
      LOOP
   ENDIF
   IF NUMBAN > 0
      _W_NUMBAN = IIF(EMPTY(ALLTRIM(_W_NUMBAN)),ALLTRIM(STR(NUMBAN,3,0)),_W_NUMBAN + "-" + ALLTRIM(STR(NUMBAN,3,0)))
      _NUMBAN = NUMBAN 
      _IDBANC = IDBANC 
      _CODCLI = CODCLI
      _ALTBAN = ALTBAN
      _LARBAN = LARBAN
      _CODIMB = CODIMB 
      _DESIMB = DESIMB 
      UPDATE SEL_PROD_CARICHI SET NUMBAN = _NUMBAN, IDBANC = _IDBANC, ALTBAN = _ALTBAN, LARBAN = _LARBAN, CODIMB = _CODIMB, DESIMB = _DESIMB WHERE CODCLI = _CODCLI
   ENDIF
ENDSCAN

SELECT SEL_PROD_CARICHI
GO TOP

RETURN _RITORNO


***********************************************************************
PROCEDURE PFP_RIPRENDI_BANCALE_ROTOLI_GIA_TAGLIATI
***********************************************************************

_RITORNO = .F.

SELECT DISTINCT CODCLI, IDBANC FROM CU_PROD_CARICHI WHERE !EMPTY(ALLTRIM(CODINT)) AND !EMPTY(NUMORD) INTO CURSOR TMP_CLIBAN
SELECT TMP_CLIBAN
GO TOP
SCAN
   _IDBANC = IDBANC
   _CODCLI = CODCLI
   _RAGSOC = ""
   SELECT CUR_BANCALI
   APPEND BLANK
   REPLACE IDBANC WITH _IDBANC
   REPLACE CODCLI WITH _CODCLI
   REPLACE RAGSOC WITH _RAGSOC
   REPLACE NUMBAN WITH 0
   REPLACE MISURE WITH ""
   REPLACE ALTBAN WITH 0
   REPLACE LARBAN WITH 0
   REPLACE LOCKED WITH .F.
   REPLACE CODIMB WITH ""
   REPLACE DESIMB WITH ""
   REPLACE PREESISTENTE WITH .T.
ENDSCAN

SELECT CUR_BANCALI
GO TOP
IF EOF()
   RETURN .F.
ENDIF

SELECT CUR_BANCALI
GO TOP
SCAN
   IF NUMBAN > 0
      LOOP
   ENDIF
   _IDBANC = IDBANC
   _CODCLI = CODCLI
   _RAGSOC = RAGSOC
   _NUMBAN = 0
   _MISURE = ""
   _ALTBAN = 0 
   _LARBAN = 0  
   _CODIMB = ""
   _DESIMB = ""
   x_clie = "PROD_ORDINI.CODCLI = '" + _CODCLI + "'"
   x_idbn = "PROD_CARICHI.IDBANC = '" + _IDBANC + "'"
   x_cond = x_clie + " and " + x_idbn
   Csql   = "SELECT TOP 1 IDBANC, NUMBAN, STABAN, DESCRI AS DESSTA, ALTBAN, LARBAN, CODIMB, DESIMB, " + ;
            "LTRIM(STR(ALTBAN)) + ' X ' + LTRIM(STR(LARBAN)) AS MISURE, 'ROTOLI IN PRODUZIONE' AS TIPO_ROTOLI FROM PROD_CARICHI " + ;
            "LEFT OUTER JOIN PARA ON PARA.CODICE = ('STB' + PROD_CARICHI.STABAN) " + ;
            "LEFT OUTER JOIN PROD_ORDINI ON PROD_ORDINI.IDPRG = PROD_CARICHI.IDPRG AND PROD_ORDINI.CODSYS = PROD_CARICHI.SYSORD " + CHR(13) + ;
            "WHERE " + x_cond
   IF !ExecCommand(Csql,"TMP_BANCALI")
  	 return(.f.)
   ENDIF
   SELECT TMP_BANCALI
   GO TOP
   IF EOF()
   ELSE
      _NUMBAN = NUMBAN
      _MISURE = MISURE
      _ALTBAN = ALTBAN
      _LARBAN = LARBAN
      _STABAN = STABAN
      _CODIMB = CODIMB 
      _DESIMB = DESIMB 
      _RITORNO = .T.
      SELECT CUR_BANCALI
      REPLACE NUMBAN WITH _NUMBAN
      REPLACE MISURE WITH _MISURE
      REPLACE ALTBAN WITH _ALTBAN
      REPLACE LARBAN WITH _LARBAN
      IF _STABAN <> "01"
         REPLACE LOCKED WITH .T.
      ENDIF
      REPLACE PREESISTENTE WITH .T.
      REPLACE CODIMB WITH _CODIMB 
      REPLACE DESIMB WITH _DESIMB 
   ENDIF
ENDSCAN


_W_NUMBAN = ""
SELECT CUR_BANCALI
GO TOP
SCAN
   IF DELETED()
      LOOP
   ENDIF
   IF NUMBAN > 0
      _W_NUMBAN = IIF(EMPTY(ALLTRIM(_W_NUMBAN)),ALLTRIM(STR(NUMBAN,3,0)),_W_NUMBAN + "-" + ALLTRIM(STR(NUMBAN,3,0)))
   ENDIF
ENDSCAN

RETURN _RITORNO


***********************************************************************
PROCEDURE PFP_INIZIO_BANCALE
***********************************************************************

_W_NUMBAN = ""

SELECT CUR_BANCALI
DELETE FOR !LOCKED

_W_NUMBAN = ""

SELECT CUR_BANCALI
DELETE FOR !LOCKED

UPDATE SEL_PROD_CARICHI SET NUMBAN = 0, IDBANC = '' WHERE EMPTY(ALLTRIM(CODINT))

SELECT DISTINCT CODCLI, RAGSOC FROM SEL_PROD_CARICHI WHERE EMPTY(ALLTRIM(CODINT)) AND !EMPTY(CODSYS) AND !EMPTY(NUMORD) INTO CURSOR TMP_CLIENTI
SELECT TMP_CLIENTI
GO TOP
IF EOF()
   XDESCRI = "ATTENZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun rotolo da tagliare a cui associare un nuovo bancale"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   RETURN .F.
ENDIF
SCAN
   _CODCLI = CODCLI
   _RAGSOC = ALLTRIM(RAGSOC)
   _NUMBAN = 1
   
   *** CERCO IL PRIMO NUMERO BANCALI LIBERO PER QUEL CLIENTE (TRA TUTTI I BANCALI IN LAVORAZIONE / PRONTI PER IMBALLO / INCOMPLETI)
   x_clie = "PROD_ORDINI.CODCLI = '" + _CODCLI + "'"
   x_nban = "PROD_CARICHI.NUMBAN > 0"
   x_idbn = "PROD_CARICHI.IDBANC <> ''"
   x_stat = "PROD_CARICHI.STABAN IN ('01','02','03')"
   x_fddt = "PROD_CARICHI.FLGDDT = 0"
   x_npck = "PROD_CARICHI.NUMPCK = ''"
   x_cond = x_clie + " and " + x_nban + " and " + x_idbn + " and " + x_stat + " and " + x_fddt + " and " + x_npck            
   Csql   = "SELECT SELEZIONE, CODCLI, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB, SUM(NUMROT) AS TOTROT FROM ( " + CHR(13) + ;
            "SELECT SPACE(10) AS SELEZIONE, PROD_ORDINI.CODCLI AS CODCLI, IDBANC, NUMBAN, STABAN, DESCRI AS DESSTA, ALTBAN, LARBAN, CODIMB, DESIMB, " + CHR(13) + ;
            "LTRIM(STR(ALTBAN)) + ' X ' + LTRIM(STR(LARBAN)) AS MISURE, COUNT(*) AS NUMROT, 'ROTOLI IN PRODUZIONE' AS TIPO_ROTOLI FROM PROD_CARICHI " + CHR(13) + ;
            "LEFT OUTER JOIN PARA ON PARA.CODICE = ('STB' + PROD_CARICHI.STABAN) " + CHR(13) + ;
            "LEFT OUTER JOIN PROD_ORDINI ON PROD_ORDINI.IDPRG = PROD_CARICHI.IDPRG AND PROD_ORDINI.CODSYS = PROD_CARICHI.SYSORD " + CHR(13) + ;
            "WHERE " + x_cond + CHR(13) + ;
            "GROUP BY CODCLI, IDBANC, NUMBAN, STABAN, ALTBAN, LARBAN, DESCRI, CODIMB, DESIMB " + CHR(13) + ;
            ") AS T1 GROUP BY SELEZIONE, CODCLI, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB " + CHR(13) + ;
            "ORDER BY NUMBAN DESC"
	IF !ExecCommand(Csql,"CHK_BANCALI")
		return(.f.)
	ENDIF
	SELECT CHK_BANCALI
	GO TOP
	IF !EOF()
		_NUMBAN = NUMBAN + 1
	ENDIF
   
   SELECT CUR_BANCALI
   APPEND BLANK
   REPLACE IDBANC WITH SUBSTR(SYS(2015),2)
   REPLACE CODCLI WITH _CODCLI
   REPLACE RAGSOC WITH _RAGSOC
   REPLACE NUMBAN WITH _NUMBAN
   REPLACE MISURE WITH ""
   REPLACE ALTBAN WITH 0
   REPLACE LARBAN WITH 0
   REPLACE PREESISTENTE WITH .F.
   REPLACE CODIMB WITH ""
   REPLACE DESIMB WITH ""
ENDSCAN

SELECT CUR_BANCALI
SET FILTER TO !LOCKED
GO TOP
IF EOF()
   XDESCRI = "ATTENZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun bancale da gestire"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   SELECT CUR_BANCALI
   SET FILTER TO
   RETURN .F.
ENDIF

_OK_NEWBAN = .F.

DO FORM FORM\PFP_TAGLIO_NEWBAN LINKED

IF _OK_NEWBAN
ELSE
   SELECT CUR_BANCALI
   ZAP
ENDIF


SELECT CUR_BANCALI
GO TOP
SCAN
	IF !EMPTY(ALLTRIM(MISURE))
		_ALTBAN = VAL(ALLTRIM(SUBSTR(UPPER(MISURE),1,AT('X',UPPER(MISURE))-1)))
		_LARBAN = VAL(ALLTRIM(SUBSTR(UPPER(MISURE),AT('X',UPPER(MISURE))+1)))
	 	REPLACE ALTBAN WITH _ALTBAN 
	 	REPLACE LARBAN WITH _LARBAN 
	ENDIF
ENDSCAN


_W_NUMBAN = ""
SELECT CUR_BANCALI
GO TOP
SCAN
   IF DELETED()
      LOOP
   ENDIF
   IF NUMBAN > 0
      _W_NUMBAN = IIF(EMPTY(ALLTRIM(_W_NUMBAN)),ALLTRIM(STR(NUMBAN,3,0)),_W_NUMBAN + "-" + ALLTRIM(STR(NUMBAN,3,0)))
      _NUMBAN = NUMBAN 
      _IDBANC = IDBANC 
      _CODCLI = CODCLI
      _ALTBAN = ALTBAN
      _LARBAN = LARBAN
      _CODIMB = CODIMB 
      _DESIMB = DESIMB 
      UPDATE SEL_PROD_CARICHI SET NUMBAN = _NUMBAN, IDBANC = _IDBANC, ALTBAN = _ALTBAN, LARBAN = _LARBAN, LARBAN = _LARBAN, CODIMB = _CODIMB, DESIMB = _DESIMB WHERE CODCLI = _CODCLI
   ENDIF
ENDSCAN

SELECT SEL_PROD_CARICHI
GO TOP

ENDPROC


***********************************************************************
PROCEDURE PFP_BANCALE_INCOMPLETO
***********************************************************************
        
x_clie = "PROD_ORDINI.CODCLI <> '" + TRC(PUB_LCL,ALLTRIM(IS_CODINT())) + "'"
x_nban = "PROD_CARICHI.NUMBAN > 0"
x_idbn = "PROD_CARICHI.IDBANC <> ''"
x_stat = "PROD_CARICHI.STABAN = '01'"
x_fddt = "PROD_CARICHI.FLGDDT = 0"
x_npck = "PROD_CARICHI.NUMPCK = ''"
x_cond = x_clie + " and " + x_nban + " and " + x_idbn + " and " + x_stat + " and " + x_fddt + " and " + x_npck            
Csql   = "SELECT SELEZIONE, CODCLI, RAGSOC, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB, SUM(NUMROT) AS TOTROT, RTRIM(RAGSOC)+' ('+RTRIM(CODCLI)+')' AS CLIENTE FROM ( " + CHR(13) + ;
         "SELECT SPACE(10) AS SELEZIONE, PROD_ORDINI.CODCLI AS CODCLI, PROD_ORDINI.RAGSOC AS RAGSOC, IDBANC, NUMBAN, STABAN, DESCRI AS DESSTA, ALTBAN, LARBAN, CODIMB, DESIMB, " + CHR(13) + ;
         "LTRIM(STR(ALTBAN)) + ' X ' + LTRIM(STR(LARBAN)) AS MISURE, COUNT(*) AS NUMROT, 'ROTOLI IN PRODUZIONE' AS TIPO_ROTOLI FROM PROD_CARICHI " + CHR(13) + ;
         "LEFT OUTER JOIN PARA ON PARA.CODICE = ('STB' + PROD_CARICHI.STABAN) " + CHR(13) + ;
         "LEFT OUTER JOIN PROD_ORDINI ON PROD_ORDINI.IDPRG = PROD_CARICHI.IDPRG AND PROD_ORDINI.CODSYS = PROD_CARICHI.SYSORD " + CHR(13) + ;
         "WHERE " + x_cond + CHR(13) + ;
         "GROUP BY CODCLI, RAGSOC, IDBANC, NUMBAN, STABAN, ALTBAN, LARBAN, DESCRI, CODIMB, DESIMB " + CHR(13) + ;
         ") AS T1 GROUP BY SELEZIONE, CODCLI, RAGSOC, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB"
IF !ExecCommand(Csql,"SEL_BANCALI_DA_INCOM")
   return(.f.)
ENDIF
SELECT SEL_BANCALI_DA_INCOM
GO TOP
IF EOF()
   XDESCRI = "ATTENZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun bancale da impostare come incompleto"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   RETURN .F.
ENDIF

DO prg\aq_browseview WITH "SEL_BANCALI_DA_INCOM","Selezionare il bancale da impostare come incompleto",;
                          "CLIENTE:Cliente,W:20;NUMBAN:N.Bancale,W:5;DESSTA:Stato,W:55;MISURE:Dimensioni,W:20;TOTROT:TOT Rotoli,W:8;",600,900,.F.,.T.
IF NumeroRecordLetti = 0
   XDESCRI = "INFORMAZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun bancale selezionato"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   RETURN .F.
ENDIF

_MESSAGGIO = CHR(13)+"ATTENZIONE"+CHR(10)+CHR(10)+CHR(10)+CHR(10)+"Impostare il bancale selezionato come incompleto?"
IF MESSAGGIO_GROSSO_BLU_RISPOSTA_SI_NO(_MESSAGGIO) = "SI"
ELSE
   XDESCRI = "INFORMAZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Operazione annullata"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   RETURN .F.
ENDIF

SELECT SEL_BANCALI_DA_INCOM 
GO TOP
SCAN
   IF DELETED()
      LOOP
   ENDIF
   IF ALLTRIM(SELEZIONE) == "==>"
      _IDBANC = IDBANC
      _SEEK = _IDBANC 
      IF USED("CUR_BANCALI")
	      SELECT CUR_BANCALI
	      SET FILTER TO
	      SET ORDER TO I_IDBANC
	      GO TOP
	      SEEK _SEEK
	      IF FOUND()
	         DELETE
	      ENDIF
	  ENDIF
      
      IF USED("SEL_PROD_CARICHI")
	      UPDATE SEL_PROD_CARICHI SET NUMBAN = 0, IDBANC = "" WHERE ALLTRIM(IDBANC) == ALLTRIM(_IDBANC)
	  ENDIF
      
      x_idbn = "idbanc = '" + _IDBANC + "'"
      x_cond = x_idbn
      Csql   = "UPDATE PROD_CARICHI SET STABAN = '03' WHERE " + x_cond
      IF !ExecCommand(Csql,"UPD_PROD_CARICHI")
     	 return(.f.)
      ENDIF
      
      SELECT SEL_BANCALI_DA_INCOM
      XDESCRI = "INFORMAZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Bancale N° " + ALLTRIM(STR(NUMBAN,3,0)) + " del cliente " + ALLTRIM(CODCLI) + CHR(13) + ;
                "impostato come incompleto"
      MESSAGGIO_GROSSO_BLU(XDESCRI)
      
      DO PFP_STAMPA_ETICHETTA_BANCALE WITH _IDBANC
      
      EXIT
   ENDIF
ENDSCAN

IF USED("CUR_BANCALI")
	*** ELIMINO DAL CURSORE DEI BANCALI QUELLI CHE NON FIGURANO NEL CURSORE DEI DETTAGLI ROTOLI
	SELECT CUR_BANCALI
	GO TOP
	SCAN
		_IDBANC = IDBANC
		IF EMPTY(ALLTRIM(_IDBANC))
			SELECT CUR_BANCALI
			DELETE
			LOOP
		ENDIF
		
		SELECT * FROM SEL_PROD_CARICHI WHERE ALLTRIM(IDBANC) = ALLTRIM(_IDBANC) INTO CURSOR TMP_ROTOLI_CHECK
		SELECT TMP_ROTOLI_CHECK
		GO TOP
		IF EOF()
			SELECT CUR_BANCALI
			DELETE
			LOOP
		ENDIF
	ENDSCAN

	_W_NUMBAN = ""
	SELECT CUR_BANCALI
	SET FILTER TO
	SET ORDER TO
	GO TOP
	SCAN
	   IF DELETED()
	      LOOP
	   ENDIF
	   IF NUMBAN > 0
