CREATE CURSOR APPOGGIO (PALLET N(10,0), RIFERI C(250), ORDCLI C(250))

SELECT APPOGGIO
INDEX ON PALLET TAG NR_PAL


SELECT DISTINCT NUMBAN,NUMORD,DATORD FROM BANCALI_STA INTO CURSOR PCK_RIFERI
SELECT PCK_RIFERI
GO TOP
DO WHILE !EOF()

	IF DELETED()
		SKIP + 1
		LOOP
	ENDIF
	
	SELECT PCK_RIFERI	
	
	___num = numord
	___dat = datord
	___ban = numban	

	_xswsw_ = SELECT()
	
	*** RICERCA NUMERO PROGRESSIVO PACKING LIST
	x_num  = "ord_numord = '" + ___num + "'"
	x_dat  = "ord_datord = '" + ___dat + "'"
	x_cond = x_num + " and " + x_dat  
	cSql	= "select ord_riferi from u_ord_tt where " + x_cond	
	IF !ExecCommand(cSql,"cu_ord_rif")
		return(.f.)
	ENDIF
	SELECT cu_ord_rif
	
	___rifordcli = ALLTRIM(ord_riferi)
	___ordcli = ALLTRIM(___num)+" del "+ribalta2(___dat)


	SELECT APPOGGIO
	SET ORDER TO NR_PAL
	SEEK ___ban 
	IF FOUND()
		SELECT APPOGGIO
		REPLACE RIFERI WITH ALLTRIM(RIFERI) + IIF(EMPTY(RIFERI),"","; ") + ___rifordcli 
		REPLACE ORDCLI WITH ALLTRIM(ORDCLI) + IIF(EMPTY(ORDCLI),"","; ") + ___ordcli 
	ELSE
		SELECT APPOGGIO	
		APPEND BLANK
		REPLACE RIFERI WITH ALLTRIM(___rifordcli)
		REPLACE ORDCLI WITH ALLTRIM(___ordcli)
		REPLACE PALLET WITH ___ban 		
	ENDIF

	SELECT(_xswsw_)
	SKIP + 1
	
ENDDO

SELECT APPOGGIO
SET ORDER TO NR_PAL
GO TOP
DO WHILE !EOF()

	SELECT APPOGGIO
	_ban = PALLET  
	_RIF = ALLTRIM(RIFERI)
	_OCL = ALLTRIM(ORDCLI)
	
	_X_ = SELECT()

	SELECT BANCALI_STA 	
	REPLACE rif_ordcli WITH _RIF FOR numban = _ban ALL 
	REPLACE ordcli WITH _OCL FOR numban = _ban ALL 

	SELECT(_X_)
	SKIP + 1

ENDDO

