		REPLACE LOTPRD WITH LOTPRD  && ROTOLI AGGIUNTI FUORI PRODUZIONE, CON LOTTO DI PRODUZIONE ASSEGNATO IN MANUALE
	ENDIF
ENDSCAN
GO TOP

TABLEUPDATE(.T.,.T.,"STA_PROD_CARICHI")

