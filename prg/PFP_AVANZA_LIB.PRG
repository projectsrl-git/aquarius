***********************************************************************
PROCEDURE PFP_STAMPA_ETICHETTA_BANCALE
***********************************************************************

LPARAMETERS _XX_IDBANC

IF USED("BANCALI_STA")
	SELECT BANCALI_STA
	USE
ENDIF
x_nban = "PROD_CARICHI.NUMBAN > 0"
x_idbn = "PROD_CARICHI.IDBANC = '" + ALLTRIM(_XX_IDBANC) + "'"
x_cond = x_nban + " and " + x_idbn
Csql   = "SELECT SPACE(250) AS RIF_ORDCLI, SPACE(250) AS ORDCLI, SPACE(40) AS DESSTA, 'ROTOLI IN PRODUZIONE' AS TIPO_ROTOLI, " + CHR(13) + ;
         "PROD_ORDINI.CODCLI, PROD_ORDINI.RAGSOC, PROD_ORDINI.NUMORD, PROD_ORDINI.DATORD, COALESCE(ORD.ORD_CDAPRD,PROD_CARICHI.CODART) AS CDAPRD, " + CHR(13) + ;
         "COALESCE(ORD.ORD_DSAPRD,PROD_CARICHI.DESART) AS DSAPRD, CAST('' AS TEXT) AS INDDDT, PROD_CARICHI.* FROM PROD_CARICHI " + CHR(13) + ;
	     "LEFT OUTER JOIN PROD_ORDINI ON PROD_ORDINI.IDPRG = PROD_CARICHI.IDPRG AND PROD_ORDINI.CODSYS = PROD_CARICHI.SYSORD " + CHR(13) + ;
	     "LEFT OUTER JOIN U_ORD_DD AS ORD ON ORD.ORD_CODSYS = PROD_CARICHI.SYSORD AND ORD.ORD_DESART <> '*** COMMENTO ***' " + CHR(13) + ;
	     "WHERE " + x_cond	        
IF !ExecCommand(Csql,"BANCALI_STA")
   return(.f.)
ENDIF
SELECT BANCALI_STA
GO TOP
IF EOF()
   XDESCRI = "ATTENZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Bancale non trovato"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   RETURN .F.
ENDIF

_INDDDT = ""
IF FLGDDT AND !EMPTY(NUMDDT) AND !EMPTY(DATDDT)
	IF !EMPTY(AGGDDT)
		x_agga = "TAGGANCIO = '" + ALLTRIM(AGGDDT) + "'"
		x_cond = x_agga 
	ELSE
		x_nddt = "ORD_NUMORD = '" + ALLTRIM(NUMDDT) + "'"
		x_dddt = "ORD_DATORD = '" + ALLTRIM(DATDDT) + "'"
		x_cond = x_nddt + " and " + x_dddt 
	ENDIF
	cSql = "SELECT * FROM U_BOL_TT WHERE " + x_cond
	IF !ExecCommand(cSql,"TMP_BOL_TT")
		return(.f.)
	ENDIF
	SELECT TMP_BOL_TT
	GO TOP
	IF !EOF()
		*** CONTRAGGIORNO NR. E DT. DDT IN QUANTO POTREBBE ESSERE STATA VARIATA
		_ORD_NUMORD = ORD_NUMORD
		_ORD_DATORD = ORD_DATORD
		SELECT BANCALI_STA
		REPLACE NUMDDT WITH _ORD_NUMORD ALL
		REPLACE DATDDT WITH _ORD_DATORD ALL
		
		SELECT TMP_BOL_TT
		IF !EMPTY(ORD_RAGC)
			_INDDDT = _INDDDT + ALLTRIM(ORD_RAGC)
			IF !EMPTY(ORD_ATTENZIONE)
				_INDDDT = _INDDDT + CHR(13) + "All'attenzione di " + ALLTRIM(ORD_ATTENZIONE)
			ENDIF
			IF !EMPTY(ORD_INDC)
				_INDDDT = _INDDDT + CHR(13) + ALLTRIM(ORD_INDC)
			ENDIF
			IF !EMPTY(ORD_CAPC) OR !EMPTY(ORD_LOCC) OR !EMPTY(ORD_PROC)
				_cIndirizzo = ""
				_cIndirizzo = ALLTRIM(_cIndirizzo) + IIF(!EMPTY(ORD_CAPC), ALLTRIM(ORD_CAPC), "")
				_cIndirizzo = ALLTRIM(_cIndirizzo) + IIF(!EMPTY(ORD_LOCC), IIF(!EMPTY(_cIndirizzo), "  ", "") + ALLTRIM(ORD_LOCC), "")
				_cIndirizzo = ALLTRIM(_cIndirizzo) + IIF(!EMPTY(ORD_PROC), IIF(!EMPTY(_cIndirizzo), "  ", "") + "(" + ALLTRIM(ORD_PROC) + ")", "")
				_INDDDT = _INDDDT + CHR(13) + _cIndirizzo
			ENDIF
			
			**=> ERASMO - INIZIO 23/11/2017
			_ORD_DSNAZC = ALLTRIM(ORD_DSNAZC)
			IF EMPTY(_ORD_DSNAZC)
				cSql = "SELECT DESCRI FROM PARA WHERE CODICE = 'STA'+(SELECT CLI_NAZION FROM U_CLI_AN WHERE CLI_CODCLI = '" + ALLTRIM(ORD_CODCLI) + "')"
				IF !ExecCommand(cSql,"TMP_NAZION")
					return(.f.)
				ENDIF
				SELECT TMP_NAZION
				GO TOP
				IF !EOF()
					_ORD_DSNAZC = ALLTRIM(DESCRI)
				ENDIF
				SELECT TMP_BOL_TT
			ENDIF
			IF ALLTRIM(UPPER(_ORD_DSNAZC)) <> 'ITALIA' AND !EMPTY(_ORD_DSNAZC)
				IF OCCURS(UPPER(_ORD_DSNAZC),UPPER(_INDDDT)) = 0 OR !PUB_NOSTPNAZ
					_INDDDT = _INDDDT + " - " + _ORD_DSNAZC
				ENDIF
			ENDIF
			**=> ERASMO - FINE 23/11/2017
		ELSE
			_INDDDT = _INDDDT + ALLTRIM(ORD_RAGSOC)
			IF !EMPTY(ORD_RAGDUE)
				_INDDDT = _INDDDT + CHR(13) + ALLTRIM(ORD_RAGDUE)
			ENDIF
			IF !EMPTY(ORD_INDIRI)
				_INDDDT = _INDDDT + CHR(13) + ALLTRIM(ORD_INDIRI)
			ENDIF
			IF !EMPTY(ORD_CAP) OR !EMPTY(ORD_LOCALI) OR !EMPTY(ORD_PROVIN)
				_cIndirizzo = ""
				_cIndirizzo = ALLTRIM(_cIndirizzo) + IIF(!EMPTY(ORD_CAP), ALLTRIM(ORD_CAP), "")
				_cIndirizzo = ALLTRIM(_cIndirizzo) + IIF(!EMPTY(ORD_LOCALI), IIF(!EMPTY(_cIndirizzo), "  ", "") + ALLTRIM(ORD_LOCALI), "")
				_cIndirizzo = ALLTRIM(_cIndirizzo) + IIF(!EMPTY(ORD_PROVIN), IIF(!EMPTY(_cIndirizzo), "  ", "") + "(" + ALLTRIM(ORD_PROVIN) + ")", "")
				_INDDDT = _INDDDT + CHR(13) + _cIndirizzo
			ENDIF
			
			**=> ERASMO - INIZIO 23/11/2017
			_ORD_DESNAZ = ""
			cSql = "SELECT DESCRI FROM PARA WHERE CODICE = 'STA'+(SELECT CLI_NAZION FROM U_CLI_AN WHERE CLI_CODCLI = '" + ALLTRIM(ORD_CODCLI) + "')"
			IF !ExecCommand(cSql,"TMP_NAZION")
				return(.f.)
			ENDIF
			SELECT TMP_NAZION
			GO TOP
			IF !EOF()
				_ORD_DESNAZ = ALLTRIM(DESCRI)
			ENDIF
			SELECT TMP_BOL_TT
			IF ALLTRIM(UPPER(_ORD_DESNAZ)) <> 'ITALIA' AND !EMPTY(_ORD_DESNAZ)
				IF OCCURS(UPPER(_ORD_DESNAZ),UPPER(_INDDDT)) = 0 OR !PUB_NOSTPNAZ
					_INDDDT = _INDDDT + " - " + _ORD_DESNAZ 
				ENDIF
			ENDIF
			**=> ERASMO - FINE 23/11/2017
		ENDIF
	ENDIF
ENDIF

_lSoloBobine = .T.  && ERASMO - 04/10/2016
SELECT BANCALI_STA
GO TOP
SCAN
	
	SELECT BANCALI_STA
	_DESSTA = ""
