Csql   = "SELECT SELEZIONE, CODCLI, RAGSOC, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB, SUM(NUMROT) AS TOTROT, RTRIM(RAGSOC)+' ('+RTRIM(CODCLI)+')' AS CLIENTE FROM ( " + CHR(13) + ;
         "SELECT SPACE(10) AS SELEZIONE, PROD_ORDINI.CODCLI AS CODCLI, PROD_ORDINI.RAGSOC AS RAGSOC, IDBANC, NUMBAN, STABAN, DESCRI AS DESSTA, ALTBAN, LARBAN, CODIMB, DESIMB, " + CHR(13) + ;
