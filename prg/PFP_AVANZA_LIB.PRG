***********************************************************************
PROCEDURE PFP_RISTAMPA_ETICHETTE_BANCALE
***********************************************************************
LPARAMETERS _par_idbanc

IF USED("STA_PROD_CARICHI")
	SELECT STA_PROD_CARICHI
	USE
ENDIF
*IF !ExecCommand("select CAST(0 AS BIT) AS SELEZI, CAST(0 AS BIT) AS EVIDENZIA, SPACE(6) AS NUMPRG, SPACE(10) AS DATPRG, SPACE(10) AS NUMORD, SPACE(10) AS DATORD, " + CHR(13) + 
IF !ExecCommand("select CAST(0 AS BIT) AS SELEZI, CAST(0 AS BIT) AS EVIDENZIA, SPACE(6) AS NUMPRG, SPACE(10) AS DATPRG, SPACE(10) AS NUMORD, SPACE(10) AS DATORD, CAST(0 AS BIT) AS NOSTPLOGO, CAST(0 AS BIT) AS NOSTPCLIE, " + CHR(13) + ;
	"SPACE(10) AS CODCLI, SPACE(80) AS RAGSOC, SPACE(200) AS ORDINE, SPACE(100) AS DES2, " + CHR(13) + ;
    "SPACE(6) AS MAG_CODMAG, SPACE(5) AS MAG_FILA_X, SPACE(5) AS MAG_PIAN_X, SPACE(5) AS MAG_UBIC_X, " + CHR(13) + ;
	"CAST(0 AS NUMERIC(5,0)) AS MAG_FILA_N, CAST(0 AS NUMERIC(5,0)) AS MAG_PIAN_N, CAST(0 AS NUMERIC(5,0)) AS MAG_UBIC_N, CODART AS CDAPRD, DESART AS DSAPRD, SPACE(10) AS MAG_FORNSUPP, " + CHR(13) + ;
	"* from PROD_CARICHI where 1=0","STA_PROD_CARICHI")
	return(.f.)
ENDIF

*** RICERCA DETTAGLI CARICHI AVANZAMENTI
IF USED("TMP_PROD_CARICHI")
	SELECT TMP_PROD_CARICHI
	USE
ENDIF
x_codi = "PC.NUMBAN > 0"
x_idbn = "PC.IDBANC = '" + _par_idbanc + "'"
x_cond = x_codi + " and " + x_idbn
cSql = 	"SELECT PC.*, PO.NUMORD, PO.DATORD, PO.CODCLI, PO.RAGSOC, COALESCE(GG.MAG_CODMAG,'') AS MAG_CODMAG, COALESCE(GG.MAG_FILA_X,'') AS MAG_FILA_X, " + CHR(13) + ;
		"COALESCE(GG.MAG_PIAN_X,'') AS MAG_PIAN_X, COALESCE(PR.NUMPRG,'') AS NUMPRG, COALESCE(PR.DATPRG,'') AS DATPRG, COALESCE(PR.NOSTPLOGO,'') AS NOSTPLOGO, COALESCE(PR.NOSTPCLIE,'') AS NOSTPCLIE, " + CHR(13) + ;
        "COALESCE(GG.MAG_UBIC_X,'') AS MAG_UBIC_X, COALESCE(ORD.ORD_CDAPRD,PC.CODART) AS CDAPRD, COALESCE(ORD.ORD_DSAPRD,PC.DESART) AS DSAPRD, COALESCE(ORD.ORD_DES2,'') AS DES2, GG.MAG_FORNSUPP from PROD_CARICHI AS PC " + CHR(13) + ;
        "LEFT OUTER JOIN PROD_ORDINI AS PO ON PO.IDPRG = PC.IDPRG AND PO.CODSYS = PC.SYSORD " + CHR(13) + ;
        "LEFT OUTER JOIN PRODUZIONE AS PR ON PR.IDPRG = PC.IDPRG AND PR.PARENT = '' " + CHR(13) + ;
        "LEFT OUTER JOIN U_MAG_GG AS GG ON GG.MAG_UNIQUE = PC.MAG_UNIQUE " + CHR(13) + ;
        "LEFT OUTER JOIN U_ORD_DD AS ORD ON ORD.ORD_CODSYS = PC.SYSORD AND ORD.ORD_DESART <> '*** COMMENTO ***' " + CHR(13) + ;
        "WHERE " + x_cond + " order by PROGRE"
IF !ExecCommand(cSql,"TMP_PROD_CARICHI")
  return(.f.)
ENDIF
SELECT TMP_PROD_CARICHI
GO TOP
SCAN
	SCATTER MEMVAR MEMO
	SELECT STA_PROD_CARICHI
	APPEND BLANK
	GATHER MEMVAR MEMO
	REPLACE EVIDENZIA WITH .F.
	REPLACE ORDINE WITH IIF(CODCLI = PUB_CLISOC, "Stock di magazzino", ALLTRIM(RAGSOC) + IIF(!EMPTY(NUMORD)," - N° " + ALLTRIM(NUMORD) + " del " + RIBALTA2(DATORD), ""))
