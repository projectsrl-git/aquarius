*************************************************************************************
FUNCTION PFP_FORMATO_SINTETICO
*************************************************************************************
*** FUNZIONE CHE RESTITUISCE IL FORMATO PER PRODUZIONE FILM PROTETTIVO IN MODO SINTETICO

LPARAMETERS _par_formato

IF PCOUNT() >= 1
ELSE
	RETURN ""
ENDIF

IF EMPTY(_par_formato)
	RETURN ""
ENDIF

LOCAL _OLD_SELECT
_OLD_SELECT = SELECT()

_cFormatoSintetico = ""
_cFormatoEsteso = ALLTRIM(_par_formato)

*** SCOMPOSIZIONE FORMATO NELLE VARIE MISURE IN UN CURSORE
_XS_FORMATO = ALLTRIM(_par_formato)
_NS_FORMATI = OCCURS(" + ",_XS_FORMATO) + 1
CREATE CURSOR TMP_MISURE (MISURA N(6,0), NUMBOB N(10,0))
INDEX ON MISURA TAG I_MISURA ADDITIVE
INDEX ON MISURA TAG D_MISURA DESCENDING ADDITIVE
INDEX ON STR(NUMBOB,10,0)+STR(MISURA,6,0) TAG D_NUMBOB DESCENDING ADDITIVE
*_OLD_MISURA = 0

FOR _I = 1 TO _NS_FORMATI
	_X_MISURA = ""
	IF OCCURS(" + ",_XS_FORMATO) > 0
		_X_MISURA = ALLTRIM(SUBSTR(_XS_FORMATO,1,AT(" + ",_XS_FORMATO)-1))
		_XS_FORMATO = SUBSTR(_XS_FORMATO,AT(" + ",_XS_FORMATO)+3)
	ELSE
		_X_MISURA = ALLTRIM(_XS_FORMATO)
		_XS_FORMATO = ""
	ENDIF
	
	_N_MISURA = VAL(_X_MISURA)
	
	SELECT TMP_MISURE
	SET ORDER TO I_MISURA
	GO TOP
	SEEK _N_MISURA
	IF FOUND()
		REPLACE NUMBOB WITH NUMBOB + 1
	ELSE
		APPEND BLANK
		REPLACE MISURA WITH _N_MISURA 
		REPLACE NUMBOB WITH 1
	ENDIF
	*_OLD_MISURA = VAL(_X_MISURA)
NEXT

SELECT TMP_MISURE
*SET ORDER TO D_MISURA
SET ORDER TO D_NUMBOB  && ORDINAMENTO E COMPOSIZIONE DELLA STRINGA A PARTIRE DAL MAGGIOR NUMERO BOBINE PRODOTTE
GO TOP
SCAN
	IF EMPTY(_cFormatoSintetico)
		_cFormatoSintetico = ALLTRIM(STR(MISURA)) + " x " + ALLTRIM(STR(NUMBOB)) + " rt."
	ELSE
		_cFormatoSintetico = _cFormatoSintetico + "|" + ALLTRIM(STR(MISURA)) + " x " + ALLTRIM(STR(NUMBOB)) + " rt."
	ENDIF
ENDSCAN

SELECT TMP_MISURE
USE

SELECT(_OLD_SELECT)

RETURN _cFormatoSintetico


*************************************************************************************
FUNCTION PFP_FORMATO_ESTESO
*************************************************************************************
*** FUNZIONE CHE RESTITUISCE IL FORMATO PER PRODUZIONE FILM PROTETTIVO IN MODO ESTESO

LPARAMETERS _par_formato_sintetico

IF PCOUNT() >= 1
ELSE
	RETURN ""
ENDIF

IF EMPTY(_par_formato_sintetico)
	RETURN ""
ENDIF

LOCAL _OLD_SELECT
_OLD_SELECT = SELECT()

_cFormatoSintetico = ALLTRIM(_par_formato_sintetico)
_cFormatoEsteso = ""

*** SCOMPOSIZIONE FORMATO NELLE VARIE MISURE IN UN CURSORE
_XS_FORMSNT = ALLTRIM(_par_formato_sintetico)
_NS_FORMATI = OCCURS("|",_XS_FORMSNT) + 1
CREATE CURSOR TMP_MISURE (MISURA N(6,0), NUMBOB N(10,0))
INDEX ON MISURA TAG I_MISURA ADDITIVE
INDEX ON MISURA TAG D_MISURA DESCENDING ADDITIVE
INDEX ON STR(NUMBOB,10,0)+STR(MISURA,6,0) TAG D_NUMBOB DESCENDING ADDITIVE
FOR _I = 1 TO _NS_FORMATI
	_X_MISURA = ALLTRIM(SUBSTR(_XS_FORMSNT,1,AT("x",_XS_FORMSNT)-1))
	_X_NUMBOB = ALLTRIM(SUBSTR(_XS_FORMSNT,AT("x",_XS_FORMSNT)+1,AT("rt.",_XS_FORMSNT)-1))
	IF OCCURS("|",_XS_FORMSNT) > 0
		_XS_FORMSNT = SUBSTR(_XS_FORMSNT,AT("|",_XS_FORMSNT)+1)
	ELSE
		_XS_FORMSNT = ""
	ENDIF
	
	_N_MISURA = VAL(_X_MISURA)
	_N_NUMBOB = VAL(_X_NUMBOB)
	
	SELECT TMP_MISURE
	SET ORDER TO I_MISURA
	GO TOP
	SEEK _N_MISURA
	IF FOUND()
		REPLACE NUMBOB WITH NUMBOB + _X_NUMBOB
	ELSE
		APPEND BLANK
		REPLACE MISURA WITH _N_MISURA 
		REPLACE NUMBOB WITH _N_NUMBOB
	ENDIF
NEXT

SELECT TMP_MISURE
*SET ORDER TO D_MISURA
SET ORDER TO D_NUMBOB  && ORDINAMENTO E COMPOSIZIONE DELLA STRINGA A PARTIRE DAL MAGGIOR NUMERO BOBINE PRODOTTE
GO TOP
SCAN
	FOR _I = 1 TO NUMBOB
		IF EMPTY(_cFormatoEsteso)
			_cFormatoEsteso = ALLTRIM(STR(MISURA))
		ELSE
			_cFormatoEsteso = _cFormatoEsteso + " + " + ALLTRIM(STR(MISURA))
		ENDIF
	NEXT
ENDSCAN

SELECT TMP_MISURE
USE

SELECT(_OLD_SELECT)

RETURN _cFormatoEsteso


***********************************************************************
PROCEDURE PFP_RIPRENDI_BANCALE_DA_CURSORE
***********************************************************************
LPARAMETERS _PAR_SEL,_PAR_NOMECUR

_RITORNO = .F.

_W_NUMBAN = ""
SELECT CUR_BANCALI
SET FILTER TO
SET ORDER TO
ZAP

*!*	SELECT DISTINCT CODCLI, RAGSOC, IDBANC, NUMBAN, STABAN, ALTBAN, LARBAN, CODIMB, DESIMB FROM &_PAR_NOMECUR WHERE NUMBAN > 0 AND IDBANC <> '' AND FLGDDT = .F. GROUP BY CODCLI, RAGSOC, IDBANC, NUMBAN, STABAN, ALTBAN, LARBAN, CODIMB, DESIMB INTO CURSOR TMP_BANCALI
*!*	SELECT TMP_BANCALI
*!*	GO TOP
*!*	IF EOF()
*!*	   RETURN .F.
*!*	ENDIF

*!*	SCAN
*!*	   _IDBANC = IDBANC
*!*	   _CODCLI = CODCLI
*!*	   _RAGSOC = RAGSOC
*!*	   _NUMBAN = NUMBAN
*!*	   _STABAN = STABAN
*!*	   _MISURE = LTRIM(STR(ALTBAN)) + ' X ' + LTRIM(STR(LARBAN))
*!*	   _ALTBAN = ALTBAN
*!*	   _LARBAN = LARBAN
*!*	   _CODIMB = CODIMB 
*!*	   _DESIMB = DESIMB 
*!*	   SELECT CUR_BANCALI
*!*	   APPEND BLANK
*!*	   REPLACE IDBANC WITH _IDBANC
*!*	   REPLACE CODCLI WITH _CODCLI
*!*	   REPLACE RAGSOC WITH _RAGSOC
*!*	   REPLACE NUMBAN WITH _NUMBAN 
*!*	   REPLACE MISURE WITH _MISURE 
*!*	   REPLACE ALTBAN WITH _ALTBAN 
*!*	   REPLACE LARBAN WITH _LARBAN 
*!*	   REPLACE LOCKED WITH .F.
*!*	   REPLACE PREESISTENTE WITH .T.
*!*	   REPLACE CODIMB WITH _CODIMB 
*!*	   REPLACE DESIMB WITH _DESIMB    
*!*	ENDSCAN

CREATE CURSOR SEL_BANCALI (SELEZIONE C(10), CODCLI C(10), IDBANC C(10), NUMBAN N(10,0), STABAN C(2), DESSTA C(100), ALTBAN N(10,0), LARBAN N(10,0), ;
	MISURE C(30), CODIMB C(3), DESIMB C(100), TOTROT N(10,0), TIPO_ROTOLI C(50))
INDEX ON IDBANC TAG I_IDBANC

SELECT &_PAR_NOMECUR
GO TOP
SCAN
	
	IF STABAN = '01' AND !FLGDDT  && SOLO BANCALI IN LAVORAZIONE
	ELSE
		LOOP
	ENDIF
	
	_xs_CODCLI = CODCLI 
	_xs_IDBANC = IDBANC 
	_xs_NUMBAN = NUMBAN 
	_xs_STABAN = STABAN 
	_xs_ALTBAN = ALTBAN 
	_xs_LARBAN = LARBAN 
	_xs_MISURE = ALLTRIM(STR(ALTBAN)) + ' X ' + ALLTRIM(STR(LARBAN))
	_xs_CODIMB = CODIMB 
	_xs_DESIMB = DESIMB 
	_xs_QTANRPROD = QTANRPROD 
	
	_xs_DESSTA = ""
		
	x_codi = "CODICE = 'STB" + _xs_STABAN + "'"
	x_cond = x_codi
	Csql   = "SELECT CODICE, DESCRI FROM PARA WHERE " + x_cond
	IF !ExecCommand(Csql,"TMP_PARA")
		return(.f.)
	ENDIF
	SELECT TMP_PARA
	GO TOP
	IF !EOF()
		_xs_DESSTA = ALLTRIM(DESCRI)
	ENDIF
	
	SELECT SEL_BANCALI
	SET ORDER TO I_IDBANC
	GO TOP
	SEEK _xs_IDBANC
	IF !FOUND()
		APPEND BLANK
		REPLACE CODCLI WITH _xs_CODCLI 
		REPLACE IDBANC WITH _xs_IDBANC 
		REPLACE NUMBAN WITH _xs_NUMBAN 
		REPLACE STABAN WITH _xs_STABAN 
		REPLACE DESSTA WITH _xs_DESSTA 
		REPLACE ALTBAN WITH _xs_ALTBAN 
		REPLACE LARBAN WITH _xs_LARBAN 
		REPLACE MISURE WITH _xs_MISURE 
		REPLACE CODIMB WITH _xs_CODIMB 
		REPLACE DESIMB WITH _xs_DESIMB 
		REPLACE TOTROT WITH _xs_QTANRPROD
		REPLACE TIPO_ROTOLI WITH 'ROTOLI IN PRODUZIONE'
	ELSE
		REPLACE TOTROT WITH TOTROT + _xs_QTANRPROD
	ENDIF
ENDSCAN
SELECT &_PAR_NOMECUR
GO TOP

SELECT SEL_BANCALI
GO TOP
IF EOF()
   RETURN .F.
ENDIF

DO prg\aq_browseview WITH "SEL_BANCALI","Selezionare il bancale",;
                          "CODCLI:Cliente,W:20;NUMBAN:N.Bancale,W:5;DESSTA:Stato,W:55;MISURE:Dimensioni,W:20;TOTROT:TOT Rotoli,W:8;",600,900,.F.,.T.
IF NumeroRecordLetti = 0
   XDESCRI = "INFORMAZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun bancale selezionato"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   RETURN .F.
ENDIF

SELECT SEL_BANCALI
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   IF ALLTRIM(SELEZIONE) = '==>'
      _IDBANC = IDBANC
      _NUMBAN = NUMBAN
      _MISURE = MISURE
      _ALTBAN = ALTBAN
      _LARBAN = LARBAN
      _CODIMB = CODIMB 
      _DESIMB = DESIMB 
      _RITORNO = .T.
      EXIT
   ENDIF
   SKIP +1
ENDDO
SELECT CUR_BANCALI
APPEND BLANK
REPLACE IDBANC WITH _IDBANC
REPLACE NUMBAN WITH _NUMBAN
REPLACE MISURE WITH _MISURE
REPLACE ALTBAN WITH _ALTBAN
REPLACE LARBAN WITH _LARBAN
REPLACE LOCKED WITH .F.
REPLACE PREESISTENTE WITH .T.
REPLACE CODIMB WITH _CODIMB
REPLACE DESIMB WITH _DESIMB
      
SELECT CUR_BANCALI
SET FILTER TO !LOCKED
GO TOP
IF EOF()
   RETURN .F.
ENDIF

RETURN _RITORNO


***********************************************************************
PROCEDURE PFP_INIZIO_BANCALE_DA_CURSORE
***********************************************************************
LPARAMETERS _PAR_NOMECUR,_PAR_CODCLI,_PAR_RAGSOC

_W_NUMBAN = ""

SELECT CUR_BANCALI
DELETE FOR !LOCKED

_CODCLI = _PAR_CODCLI
_RAGSOC = ALLTRIM(_PAR_RAGSOC)
_NUMBAN = 1
   
*** CERCO IL PRIMO NUMERO BANCALI LIBERO PER QUEL CLIENTE (TRA TUTTI I BANCALI IN LAVORAZIONE / PRONTI PER IMBALLO / INCOMPLETI)
SELECT NUMBAN FROM &_PAR_NOMECUR WHERE NUMBAN > 0 AND IDBANC <> '' AND STABAN IN ('01','02','03') AND FLGDDT = .F. AND NUMPCK = '' ORDER BY NUMBAN DESC INTO CURSOR CHK_BANCALI
SELECT CHK_BANCALI
GO TOP
IF !EOF()
	_NUMBAN = NUMBAN + 1
ENDIF

*** VERIFICA ESISTENZA TRA I BANCALI GIA' PRESENTI SUL DB
DO WHILE .T.
	_ALRDY_ESIST = .F.
	x_clie = "PROD_ORDINI.CODCLI = '" + _CODCLI + "'"
	x_nban = "PROD_CARICHI.NUMBAN = " + ALLTRIM(STR(_NUMBAN,3,0))
	x_idbn = "PROD_CARICHI.IDBANC <> ''"
	x_stat = "PROD_CARICHI.STABAN IN ('01','02','03')"
	x_fddt = "PROD_CARICHI.FLGDDT = 0"
	x_npck = "PROD_CARICHI.NUMPCK = ''"
	x_cond = x_clie + " and " + x_nban + " and " + x_idbn + " and " + x_stat + " and " + x_fddt + " and " + x_npck            
	Csql   = "SELECT SELEZIONE, CODCLI, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB, SUM(NUMROT) AS TOTROT FROM ( " + CHR(13) + ;
	         "SELECT SPACE(10) AS SELEZIONE, PROD_ORDINI.CODCLI AS CODCLI, IDBANC, NUMBAN, STABAN, DESCRI AS DESSTA, ALTBAN, LARBAN, CODIMB, DESIMB, " + CHR(13) + ;
	         "LTRIM(STR(ALTBAN)) + ' X ' + LTRIM(STR(LARBAN)) AS MISURE, COUNT(*) AS NUMROT, 'ROTOLI IN PRODUZIONE' AS TIPO_ROTOLI FROM PROD_CARICHI " + CHR(13) + ;
	         "LEFT OUTER JOIN PARA ON PARA.CODICE = ('STB' + PROD_CARICHI.STABAN) " + CHR(13) + ;
	         "LEFT OUTER JOIN PROD_ORDINI ON PROD_ORDINI.IDPRG = PROD_CARICHI.IDPRG AND PROD_ORDINI.CODSYS = PROD_CARICHI.SYSORD " + CHR(13) + ;
	         "WHERE " + x_cond + CHR(13) + ;
	         "GROUP BY CODCLI, IDBANC, NUMBAN, STABAN, ALTBAN, LARBAN, DESCRI, CODIMB, DESIMB " + CHR(13) + ;
	         ") AS T1 GROUP BY SELEZIONE, CODCLI, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB "
	IF !ExecCommand(Csql,"CHK_BANCALI")
		return(.f.)
	ENDIF
	SELECT CHK_BANCALI
	GO TOP
	IF EOF()
	ELSE
		_ALRDY_ESIST = .T.
		*_STATO_ESIST = ALLTRIM(DESSTA)
		*_CLIEN_ESIST = ALLTRIM(CODCLI)
	ENDIF
	
	IF _ALRDY_ESIST
		_NUMBAN = NUMBAN + 1
		LOOP
	ENDIF
	
	EXIT
ENDDO

SELECT CUR_BANCALI
APPEND BLANK
REPLACE IDBANC WITH SUBSTR(SYS(2015),2)
REPLACE CODCLI WITH _CODCLI
REPLACE RAGSOC WITH _RAGSOC
REPLACE NUMBAN WITH _NUMBAN
REPLACE MISURE WITH ""
REPLACE ALTBAN WITH 0
REPLACE LARBAN WITH 0
REPLACE LOCKED WITH .F.
REPLACE PREESISTENTE WITH .F.
REPLACE CODIMB WITH ""
REPLACE DESIMB WITH ""

SELECT CUR_BANCALI
SET FILTER TO !LOCKED
GO TOP
IF EOF()
   XDESCRI = "ATTENZIONE:"+CHR(10)+CHR(10)+CHR(10)+"Nessun bancale da gestire"
   MESSAGGIO_GROSSO_BLU(XDESCRI)
   SELECT CUR_BANCALI
   SET FILTER TO
   RETURN .F.
ENDIF

_OK_NEWBAN = .F.

DO FORM FORM\PFP_TAGLIO_NEWBAN LINKED

IF _OK_NEWBAN
ELSE
   SELECT CUR_BANCALI
   ZAP
ENDIF

SELECT CUR_BANCALI
GO TOP
SCAN
	IF !EMPTY(ALLTRIM(MISURE))
		_ALTBAN = VAL(ALLTRIM(SUBSTR(UPPER(MISURE),1,AT('X',UPPER(MISURE))-1)))
		_LARBAN = VAL(ALLTRIM(SUBSTR(UPPER(MISURE),AT('X',UPPER(MISURE))+1)))
	 	REPLACE ALTBAN WITH _ALTBAN 
	 	REPLACE LARBAN WITH _LARBAN 
	ENDIF
ENDSCAN
GO TOP

ENDPROC
