x_idbn = "PROD_CARICHI.IDBANC <> ''"
x_stat = "PROD_CARICHI.STABAN = '01'"
x_fddt = "PROD_CARICHI.FLGDDT = 0"
x_npck = "PROD_CARICHI.NUMPCK = ''"
x_cond = x_clie + " and " + x_nban + " and " + x_idbn + " and " + x_stat + " and " + x_fddt + " and " + x_npck            
Csql   = "SELECT SELEZIONE, CODCLI, RAGSOC, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB, SUM(NUMROT) AS TOTROT, RTRIM(RAGSOC)+' ('+RTRIM(CODCLI)+')' AS CLIENTE FROM ( " + CHR(13) + ;
         "SELECT SPACE(10) AS SELEZIONE, PROD_ORDINI.CODCLI AS CODCLI, PROD_ORDINI.RAGSOC AS RAGSOC, IDBANC, NUMBAN, STABAN, DESCRI AS DESSTA, ALTBAN, LARBAN, CODIMB, DESIMB, " + CHR(13) + ;
         "LTRIM(STR(ALTBAN)) + ' X ' + LTRIM(STR(LARBAN)) AS MISURE, COUNT(*) AS NUMROT, 'ROTOLI IN PRODUZIONE' AS TIPO_ROTOLI FROM PROD_CARICHI " + CHR(13) + ;
         "LEFT OUTER JOIN PARA ON PARA.CODICE = ('STB' + PROD_CARICHI.STABAN) " + CHR(13) + ;
         "LEFT OUTER JOIN PROD_ORDINI ON PROD_ORDINI.IDPRG = PROD_CARICHI.IDPRG AND PROD_ORDINI.CODSYS = PROD_CARICHI.SYSORD " + CHR(13) + ;
         "WHERE " + x_cond + CHR(13) + ;
         "GROUP BY CODCLI, RAGSOC, IDBANC, NUMBAN, STABAN, ALTBAN, LARBAN, DESCRI, CODIMB, DESIMB" + CHR(13) + ;
         ") AS T1 GROUP BY SELEZIONE, CODCLI, RAGSOC, IDBANC, NUMBAN, DESSTA, ALTBAN, LARBAN, MISURE, CODIMB, DESIMB"
IF !ExecCommand(Csql,"SEL_BANCALI_DA_ELIM")
