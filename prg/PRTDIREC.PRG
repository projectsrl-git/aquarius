

IF PUB_NOSPOO
ELSE
   RETURN
ENDIF

PUB_LPT='LPT1'

SELECT PJ_SPOOL
GO BOTTOM
SCATTER MEMVAR

OK_FILE=PUB_DIR+'\'+M.PJ_NOME

IF !FILE(OK_FILE)
  =MESSAGEBOX("FILE SELEZIONATO INESISTENTE",62,"ATTENZIONE")
  RETURN
ENDIF	

RIT = MESSAGEBOX("DESIDERI VEDERE ANTEPRIMA"+CHR(13)+"STAMPA DEL DOCUMENTO ?",292,"ATTENZIONE")
IF RIT = 6
    DO CASE
		CASE PUB_DOCUM = "OFF"
			=ESPL_DETT("CU_OFF_DD")
		CASE PUB_DOCUM = "ORD"
			=ESPL_DETT("CU_ORD_DD")
		CASE PUB_DOCUM = "BOL"
			=ESPL_DETT("CU_BOL_DD")
		CASE PUB_DOCUM = "ORF"
			=ESPL_DETT("CU_ORF_DD")
		CASE PUB_DOCUM = "FAP"
			=ESPL_DETT("CU_FAP_DD")
		CASE PUB_DOCUM = "FAT"
			=ESPL_DETT("CU_FAT_DD")
		CASE PUB_DOCUM = "CTL"
			=ESPL_DETT("CU_CTL_DD")
		CASE PUB_DOCUM = "CMS"
			=ESPL_DETT("CU_COM_DD")

	ENDCASE

ENDIF


IF FILE("C:\WINDOWS\PJSPOOL.SPL") 
   SET HEADINGS OFF
   SET CONSOLE OFF
   SET DEVICE TO PRINTER
   SET PRINT ON
   COMM="TYPE "+M.PJ_NOME+" TO "+PUB_LPT
   &COMM
ELSE
   COMM="COPY FILE "+M.PJ_NOME+" TO "+PUB_LPT
  * COMM="COPY "+M.PJ_NOME+" TO "+PUB_LPT
   &COMM
ENDIF
  
SELECT PJ_SPOOL
M.PJ_COPIE=M.PJ_COPIE+1

GATHER MEMVAR

SET CONSOLE ON
SET DEVICE TO SCREEN

THISFORM.REFRESH