PARAMETERS P_CREA_TABELLE

SET PROCEDURE TO PRG\CBI_LIB.PRG ADDITIVE

LOCAL _CREA_TABELLE

CLOSE DATA ALL

_CREA_TABELLE=.T.

IF PCOUNT()=0
	_CREA_TABELLE=.T.
ELSE
	_CREA_TABELLE=P_CREA_TABELLE
ENDIF


IF _CREA_TABELLE

	DO CREA_DATABASE

	SCRIPSQL('CBI_ORDINE.DBF')
	SCRIPSQL('CBI_LOG.DBF')	
	SCRIPSQL('CBI_STRU.DBF')

	SCRIPSQL("CBIEP10.DBF")
	SCRIPSQL("CBIEP20.DBF")
	SCRIPSQL("CBIEP30.DBF")
	SCRIPSQL("CBIEP70.DBF")
	SCRIPSQL("CBIEPEF.DBF")
	SCRIPSQL("CBIEP.DBF")
	SCRIPSQL("CBIPC10.DBF")
	SCRIPSQL("CBIPC20.DBF")
	SCRIPSQL("CBIPC30.DBF")
	SCRIPSQL("CBIPC40.DBF")
	SCRIPSQL("CBIPC50.DBF")
	SCRIPSQL("CBIPC60.DBF")
	SCRIPSQL("CBIPC70.DBF")
	SCRIPSQL("CBIPCEF.DBF")
	SCRIPSQL("CBIPC.DBF")
	SCRIPSQL("CBIRH61.DBF")
	SCRIPSQL("CBIRH62.DBF")
	SCRIPSQL("CBIRH63.DBF")
	SCRIPSQL("CBIRH64.DBF")
	SCRIPSQL("CBIRH65.DBF")
	SCRIPSQL("CBIRHEF.DBF")
	SCRIPSQL("CBIRH.DBF")

ELSE

*** POPOLA TABELLA SQL CBI_STRU DA TABELLA DBF	

	CREA_TABELLE()

	USE CBI_STRU IN 0 AGAIN
	
	CSQL="SELECT * FROM CBI_STRU "
	IF !ExecRW(cSql,"_SUPP","R")
	   return(.f.)
	ENDIF

	SELECT CBI_STRU
	GO TOP
	DO WHILE !EOF()
		
		IF DELETED()
			SKIP
			LOOP
		ENDIF
					
		SCATTER MEMVAR MEMO 
		
		SELECT 	_SUPP
		APPEND BLANK
		GATHER MEMVAR MEMO

		SELECT CBI_STRU
		SKIP
		LOOP
	ENDDO

	SELECT CBI_STRU
	USE
	
	IF !EXECRW(CSQL,"CBI_STRU","I","","_SUPP")
	   RETURN(.F.)
	ENDIF

*** POPOLA TABELLA SQL CBI_ORDINE DA TABELLA DBF	
	USE CBI_ORDINE IN 0 AGAIN
	
	CSQL="SELECT * FROM CBI_ORDINE "
	IF !ExecRW(cSql,"_SUPP1","R")
	   return(.f.)
	ENDIF

	SELECT CBI_ORDINE
	GO TOP
	DO WHILE !EOF()
		
		IF DELETED()
			SKIP
			LOOP
		ENDIF
					
		SCATTER MEMVAR MEMO 
		
		SELECT 	_SUPP1
		APPEND BLANK
		GATHER MEMVAR MEMO

		SELECT CBI_ORDINE
		SKIP
		LOOP
	ENDDO

	SELECT CBI_ORDINE
	USE
	
	IF !EXECRW(CSQL,"CBI_ORDINE","I","","_SUPP1")
	   RETURN(.F.)
	ENDIF
	
ENDIF
