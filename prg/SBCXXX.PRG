*************************************************************************
 PROCEDURE SBCCHIU  && STAMPA BILANCIO NORMALE
*************************************************************************
PARA V_POSBIL,V_CONINI,V_CONFIN,V_DAL,V_AL,PUB_ANNO,V_DBASE,__STAMPA_SOLO_I_CLIENTI_FORNITORI,__STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI,___ANNOP,__NON_STAMPA_I_CLIENTI_FORNITORI

IF PCOUNT() = 6
   V_DBASE = "CONTICA"
   __STAMPA_SOLO_I_CLIENTI_FORNITORI  = .F. 
   __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI = .F.  
   ___ANNOP = ""
   __NON_STAMPA_I_CLIENTI_FORNITORI   = .F.
ENDIF

IF PCOUNT() = 7
   __STAMPA_SOLO_I_CLIENTI_FORNITORI  = .F.
   __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI = .F.
   ___ANNOP = ""
   __NON_STAMPA_I_CLIENTI_FORNITORI   = .F.
ENDIF

V_SALDOI = 0

RELEASE ___CTOPERC
PUBLIC ___CTOPERC
___CTOPERC = ''


CREATE CURSOR TEMPO_DB;
  (CONTO C(13),DESCRI C(40),DARE N(20,8),AVERE N(20,8), SALDO N(20,8), MOVIM C(02))
 
CREATE CURSOR WOPE_SB3 (DA_TIPO C(02),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),;
                        AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZD_TOTALE N(20,8),ZD_PERC N(10,2),ZA_TOTALE N(20,8),ZA_PERC N(10,2),ZT_PERC N(10,2),ZA_SALDOI N(20,8),DA_TIPOCO C(1))

CREATE CURSOR WOPE_SBC (DA_TIPO C(02),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),;
                        AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZD_TOTALE N(20,8),ZD_PERC N(10,2),ZA_TOTALE N(20,8),ZA_PERC N(10,2),ZT_PERC N(10,2),ZA_SALDOI N(20,8),DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CODCON) + DA_TIPO TAG WOPE_SBC ADDITIVE 


CREATE CURSOR WOPE_TOT (DA_TIPO C(02),DA_CODCON C(13),DA_DESCR C(40),DA_TOTALE N(20,8),;
                        AV_CODCON C(13),AV_DESCR C(40),AV_TOTALE N(20,8),ZD_TOTALE N(20,8),ZD_PERC N(10,2),ZA_TOTALE N(20,8),ZA_PERC N(10,2),ZT_PERC N(10,2),ZA_SALDOI N(20,8),DA_TIPOCO C(1))
INDEX ON ALLTRIM(DA_CODCON) + DA_TIPO TAG WOPE_TOT ADDITIVE 

SET NEAR ON
SELECT &V_DBASE
SET ORDER TO CONTO
IF !EMPTY(___ANNOP)								&& CONFRONTO ANNO PRECEDENTE
	SEEK PUB_CODSOC+___ANNOP
ELSE
	SEEK PUB_CODSOC+PUB_ANNO
ENDIF

DETTAGLI = .T.
PRIMOD   = .T.
PRIMOA   = .T.
V_GRSG   = ""
V_OLDD   = ""
V_OLDA   = ""

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF !EMPTY(___ANNOP)								&& CONFRONTO ANNO PRECEDENTE
	   IF DELETED() .OR. CON_ANNO != ___ANNOP
	      SKIP +1
	      LOOP
	   ENDIF
   ELSE
	   IF DELETED() .OR. CON_ANNO != PUB_ANNO
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF
   	
   IF !DETTAGLI .AND. SUBSTR(CON_CONTO,1,PUB_SOTTOG-1)==V_GRSG
      SKIP +1
      LOOP
   ENDIF

   IF LEN(ALLTRIM(CON_CONTO)) < PUB_SOTTOG
      SKIP +1
      LOOP
   ENDIF

   IF CON_TIPOCO = "O"    && SCARTA CONTICA D'ORDINE
      =CREA_SALDI_PIANO_CONTI(V_DBASE)
      SKIP +1
      LOOP
   ENDIF

   IF CON_POSBIL  <> V_POSBIL
      SKIP +1
      LOOP
   ENDIF

   IF __STAMPA_SOLO_I_CLIENTI_FORNITORI 
	   IF CON_TIPOCO  =  "C" OR CON_TIPOCO  =  "F" 
       ELSE
	      SKIP +1
	      LOOP
	   ENDIF
   ENDIF 




   V_CONTO  = CON_CONTO
   V_TIPOCO = CON_TIPOCO
   V_DESCR  = CON_DESCR
   V_GRSG   = SUBSTR(V_CONTO,1,PUB_SOTTOG-1)
   V_SALDOI = CON_SALDOI

   v_seek 	 = "BIL"+V_GRSG
   v_chiave  = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      IF SUBSTR(LIBERA,1,1)=="S"
         DETTAGLI=.T.
      ELSE
         DETTAGLI=.F.
      ENDIF
   ELSE
      DETTAGLI=.F.
   ENDIF

   SELECT &V_DBASE

   V_TOTD = 0
   V_TOTA = 0
   FOR H=V_DAL TO V_AL
       VD="CON_DA"+STRTRAN(STR(H,2)," ","0")
       VA="CON_AV"+STRTRAN(STR(H,2)," ","0")
       V_TOTD=V_TOTD+&VD
       V_TOTA=V_TOTA+&VA
   NEXT

   IF OK_SALDI
      IF V_TOTD = 0 .AND. V_TOTA = 0
         SELECT &V_DBASE
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   DO SBCAGWF1
   
   SELECT &V_DBASE
   SKIP +1
    
ENDDO


SELECT WOPE_SBC

select  * from WOPE_SBC into cursor wope_sbc_save

SELECT WOPE_SBC
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF ZA_SALDOI < 0
      SA_DIFFE=AV_TOTALE-ABS(ZA_SALDOI)
      IF SA_DIFFE < 0
         REPLACE AV_TOTALE WITH 0
         REPLACE DA_TOTALE WITH DA_TOTALE + ABS(SA_DIFFE)
      ELSE
         REPLACE AV_TOTALE WITH ABS(SA_DIFFE)
     ENDIF
  ELSE
     SA_DIFFE=DA_TOTALE-ABS(ZA_SALDOI)
     IF SA_DIFFE < 0
        REPLACE DA_TOTALE WITH 0
        REPLACE AV_TOTALE WITH AV_TOTALE + ABS(SA_DIFFE)
     ELSE
        REPLACE DA_TOTALE WITH ABS(SA_DIFFE)
     ENDIF
  ENDIF
  SKIP+1
ENDDO

** SALVA I DETTAGLI

VA_TOTALE = 0
VD_TOTALE = 0
VA_SALDOI = 0

select wope_sbc_save
DO WHILE .not. EOF()

	VA_TOTALE = VA_TOTALE + ROUND(da_totale,2)
	VD_TOTALE = VD_TOTALE + ROUND(av_totale,2)

	SKIP +1
ENDDO

*!*	sum da_totale to VA_TOTALE
*!*	sum av_totale to VD_TOTALE



SELECT WOPE_SBC
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   V_CONTO=DA_CODCON
   TT_TIPO=DA_TIPO
   IF LEN(ALLTRIM(V_CONTO)) < PUB_SOTTOG
      SELECT WOPE_SBC
      SKIP +1
      LOOP
   ENDIF
   SCATTER MEMVAR
   M.AV_SALDOI = M.ZA_SALDOI
   ** CALCOLO DEI TOTALI GENERALI
   *  VA_TOTALE = VA_TOTALE + M.DA_totale
   *  VD_TOTALE = VD_TOTALE + M.AV_totale
   SELECT WOPE_SB3
   APPEND BLANK
   GATHER MEMVAR
   SELECT WOPE_SBC
   SKIP +1
ENDDO

** RICALCOLO TOTALI GENERALI SU TOTALI ZD_ / ZA_   (TOTALI INTERMEDI DI GRUPPO)

SELECT WOPE_SB3
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   V_CONTO  = SUBSTR(DA_CODCON,1,PUB_SOTTOG-1)
   TT_TIPO  = "ZZ"
   A_TOTALE = AV_TOTALE
   D_TOTALE = DA_TOTALE
   Z_SALDOI = ZA_SALDOI

   SELECT WOPE_SBC
   SET ORDER TO WOPE_SBC
   _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
   SEEK _SKK
   IF FOUND()
      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
   ELSE
      ** CASO ANOMALO DEVO COMUNQUE RICREARE IL GRUPPO TOTALE DI TESTATA CHE TOTALE TOTALE
      APPEND BLANK
      REPLACE DA_TIPO   WITH TT_TIPO
      REPLACE DA_CODCON WITH V_CONTO
*!*	      REPLACE DA_DESCR  WITH "___________TOTALE CONTO"
      REPLACE DA_DESCR  WITH "__TOTALE : " + ALLTRIM(GETDCON(V_CONTO))

      
      REPLACE ZD_TOTALE WITH ZD_TOTALE + D_TOTALE
      REPLACE ZA_TOTALE WITH ZA_TOTALE + A_TOTALE
      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
      _SKK =  ALLTRIM(V_CONTO)+ "  "
      SEEK _SKK
      IF !FOUND()
         APPEND BLANK
         REPLACE DA_TIPO   WITH "  "
         REPLACE DA_CODCON WITH V_CONTO
         REPLACE DA_DESCR  WITH GETDCON(V_CONTO)
      ENDIF
   ENDIF
   SELECT WOPE_SB3
   SKIP +1
ENDDO

** SALVA I RECORD DI TOTALE GENERALI SU TOTALI ZD_ / ZA_   (TOTALI INTERMEDI DI GRUPPO)

SELECT WOPE_SBC
GO TOP

DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF

   IF DA_TIPO <> "ZZ"
      SELECT WOPE_SBC
      SKIP +1
      LOOP
   ENDIF
   
   SELECT WOPE_TOT
   SET ORDER TO WOPE_TOT
   APPEND BLANK
   
   REPLACE DA_TIPO   WITH WOPE_SBC.DA_TIPO   
   REPLACE DA_CODCON WITH WOPE_SBC.DA_CODCON 
   REPLACE DA_DESCR  WITH WOPE_SBC.DA_DESCR  
   REPLACE ZD_TOTALE WITH WOPE_SBC.ZD_TOTALE 
   REPLACE ZA_TOTALE WITH WOPE_SBC.ZA_TOTALE 
   REPLACE ZA_SALDOI WITH WOPE_SBC.ZA_SALDOI 
   
   SELECT WOPE_SBC
   SKIP +1

ENDDO


** CALCOLA LA PERCENTUALE DEI SINGOLO SOTTOGRUPPO RISPETTO AL TOTALE SOPRA SALVATO SU TOTALI ZD_ / ZA_   (TOTALI INTERMEDI DI GRUPPO)
   
SELECT WOPE_SBC
GO TOP


DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF

   IF DA_TIPO = "ZZ"
      SELECT WOPE_SBC
      SKIP +1
      LOOP
   ENDIF

   TT_TIPO  = "ZZ"
   V_CONTO  = SUBSTR(DA_CODCON,1,PUB_SOTTOG-1)
   
   SELECT WOPE_TOT
   SET ORDER TO WOPE_TOT
   _SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
   SEEK _SKK
   IF FOUND()
      _D_TOTALE = ZD_TOTALE 
      _A_TOTALE = ZA_TOTALE 
      *!*	      REPLACE ZA_SALDOI WITH ZA_SALDOI + Z_SALDOI
   ELSE
      _D_TOTALE = 0 
      _A_TOTALE = 0 
   ENDIF   

   SELECT WOPE_SBC
   
*!*	   IF DA_TOTALE <> 0
   IF _D_TOTALE <> 0
   	  REPLACE ZD_PERC WITH  ROUND((DA_TOTALE / _D_TOTALE ) * 100,2)  
   ELSE
   	  REPLACE ZD_PERC WITH  0  
   ENDIF
   
*!*	   IF AV_TOTALE <> 0   
   IF _A_TOTALE <> 0   
   	  REPLACE ZA_PERC WITH  ROUND((AV_TOTALE / _A_TOTALE ) * 100,2)  
   ELSE
   	  REPLACE ZA_PERC WITH  0  
   ENDIF
  

   SKIP +1

ENDDO


IF __STAMPA_SOLO_I_GRUPPI_SOTTOGRUPPI
	
	SELECT WOPE_SBC
	GO TOP
	
	DO WHILE .T.
	   
	   IF EOF()
	      EXIT
	   ENDIF
	
	   IF ALLTRIM(DA_TIPO) <> "ZZ"

        DELETE
        
	   ENDIF
	
	
		
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
        IF !EMPTY(___ANNOP)
			x_anno = "con_anno = '" + ___ANNOP + "'"
		ELSE
			x_anno = "con_anno = '" + PUB_ANNO + "'"
		ENDIF
		x_cont = "con_conto = '" + ALLTRIM(WOPE_SBC.DA_CODCON) + "'"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont
		Csql   = "select * from CONTICA where " + x_cond + " order by con_soc,con_anno,con_conto"
		IF !ExecCommand(cSql,"xCONTICAx")
		   return(.f.)
		ENDIF
		SELECT xCONTICAx
		GO TOP
		IF EOF()
			_DA_DESCR  = "*** CONTO INESISTENTE SUL PIANO DEI CONTICA ***"
		ELSE
			_DA_DESCR  = ALLTRIM(CON_DESCR)
		ENDIF
	
	
	   SELECT WOPE_SBC	   
       REPLACE DA_DESCR  WITH _DA_DESCR  
       REPLACE AV_DESCR  WITH _DA_DESCR  
*!*	       REPLACE DA_TIPO   WITH SPACE(13) 

	   SKIP +1	
	
	ENDDO WHILE .T.
	
	
ENDIF

*!*	2006-07-21 SERGIO INIZIO SBC400
IF OK_SALDI				&& non tratta i movimenti di dettaglio con saldo a 0

	SELECT WOPE_SBC
	GO TOP

	
	DO WHILE .NOT.EOF()

	   IF DA_TIPO = "DD"
	      IF DA_TOTALE - AV_TOTALE = 0
	         DELETE
	      ENDIF
	   ENDIF DA_TIPO = "DD"

	   SELECT WOPE_SBC
	   SKIP +1


	ENDDO WHILE .NOT.EOF()

ENDIF
*!*	2006-07-21 SERGIO FINE


*!*	2007-10-19 SERGIO INIZIO
IF __NON_STAMPA_I_CLIENTI_FORNITORI   
	
	SELECT WOPE_SBC
	GO TOP
	
	DO WHILE .T.
	   
	   IF EOF()
	      EXIT
	   ENDIF
	
	   _DA_TIPO = DA_TIPO 
		
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
        IF !EMPTY(___ANNOP)
			x_anno = "con_anno = '" + ___ANNOP + "'"
		ELSE
			x_anno = "con_anno = '" + PUB_ANNO + "'"
		ENDIF
		x_cont = "con_conto = '" + ALLTRIM(WOPE_SBC.DA_CODCON) + "'"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont
		Csql   = "select * from CONTICA where " + x_cond + " order by con_soc,con_anno,con_conto"
		IF !ExecCommand(cSql,"xCONTICAx")
		   return(.f.)
		ENDIF
		SELECT xCONTICAx
		GO TOP
		IF EOF()
			_DA_DESCR  = "*** CONTO INESISTENTE SUL PIANO DEI CONTICA ***"
		ELSE

			
			_DA_DESCR  = ALLTRIM(CON_DESCR)

			IF _DA_TIPO = "ZZ"
				_DA_DESCR  = "__TOTALE : " + ALLTRIM(CON_DESCR)
			ENDIF
			

		ENDIF
	

	    IF CON_TIPOCO  =  "C" OR CON_TIPOCO  =  "F" 

	      SELECT WOPE_SBC
	                
          DELETE
	      
	      SKIP +1
	      LOOP
	    
	    ENDIF

	
	   SELECT WOPE_SBC	   
       REPLACE DA_DESCR  WITH _DA_DESCR  
       REPLACE AV_DESCR  WITH _DA_DESCR  
*!*	       REPLACE DA_TIPO   WITH SPACE(13) 

	   SKIP +1	
	
	ENDDO WHILE .T.

	
ENDIF 
*!*	2007-10-19 SERGIO FINE


** CALCOLA LA PERCENTUALE TOTALE SUI CONTICA DI TIPO ZZ RISPETTO AL CONTO RICAVI

*!*	RICERCA IL CODICE DEL CONTO RICAVO IN TABELLA

v_SEEK = "PRI"+pub_codsoc
IF seek_std('PARA',v_seek,'CODICE','CUR_PARA')
   SELECT CUR_PARA
   ___CTOPERC=ALLTRIM(LIBERA)
ELSE
   ___CTOPERC=""
ENDIF


IF !EMPTY(ALLTRIM(___CTOPERC))

	TT_TIPO  = "ZZ"
	V_CONTO  = SUBSTR(___CTOPERC,1,PUB_SOTTOG-1)
	   
	SELECT WOPE_TOT
	SET ORDER TO WOPE_TOT
    _T_TOTALE   = 0
	_SKK =  ALLTRIM(V_CONTO)+ TT_TIPO
	SEEK _SKK
	IF FOUND()
	  IF ZD_TOTALE <> 0
	  		_T_TOTALE = ZD_TOTALE 
	  ENDIF
	  IF ZA_TOTALE <> 0
	  		_T_TOTALE = ZA_TOTALE 
	  ENDIF
	ELSE
	   _T_TOTALE = 0 
	ENDIF   


	SELECT WOPE_SBC
	GO TOP


	DO WHILE .T.
	   
	   IF EOF()
	      EXIT
	   ENDIF

	   IF DA_TIPO <> "ZZ"
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF

	   IF ALLTRIM(___CTOPERC) = ALLTRIM(DA_CODCON)
	      SELECT WOPE_SBC
	      SKIP +1
	      LOOP
	   ENDIF

	   SELECT WOPE_SBC
	   
	   REPLACE ZD_PERC WITH  0  
	   REPLACE ZA_PERC WITH  0  	   
	   REPLACE ZT_PERC WITH  0  	
	      
	   IF ZD_TOTALE <> 0
	      IF _T_TOTALE <> 0
	   	  	REPLACE ZT_PERC WITH  ROUND((ZD_TOTALE / _T_TOTALE ) * 100,2)  
	   	  ENDIF 
	   ENDIF
	   
	   IF ZA_TOTALE <> 0   
	      IF _T_TOTALE <> 0
	   	  	REPLACE ZT_PERC WITH  ROUND((ZA_TOTALE / _T_TOTALE ) * 100,2)  
	   	  ENDIF 
	   ENDIF
	  

	   SKIP +1

	ENDDO

ENDIF


SELECT WOPE_SBC
GO TOP



SET NEAR OFF
RETURN
