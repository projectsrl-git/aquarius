********************************************
FUNCTION ELABORA_ACQUISTI_VENDITE_0000000100
********************************************
 
_ACQ_VEN_0000000100_ = SELECT()

*!*	############################################################## (vendite e acquisti contabilizzati) ##############################################################
IF USED(cNomeCursorSql)
	SELECT &cNomeCursorSql
	USE
ENDIF

TEXT TO cSql NOSHOW


	SELECT 'VENDITE' AS TIPO, YTOD.*,OGGI.* FROM (SELECT 
		COALESCE(SUM(PAR_TOTIM*(CASE WHEN FLAG_NOTACRED='S' THEN -1 ELSE 1 END)),0) AS IMPO_DA_INIZIO_ANNO,
		COALESCE(SUM(PAR_TIMPOS*(CASE WHEN FLAG_NOTACRED='S' THEN -1 ELSE 1 END)),0) AS IMPOS_DA_INIZIO_ANNO
	FROM ( SELECT 
		PA.PAR_TIPFAT,
		PA.PAR_TOTIM AS PAR_TOTIM,
		PA.PAR_TIMPOS AS PAR_TIMPOS,
		COALESCE(SUBSTRING(PARTOP.LIBERA,2,1),'')  AS FLAG_NATURA, 
		COALESCE(SUBSTRING(PARTOP.LIBERA,11,1),'')  AS FLAG_NOTACRED 
	FROM PART_CLI AS PA
	LEFT OUTER JOIN PARA AS PARTOP
	ON PARTOP.CODICE='TOP'+PA.PAR_TIPFAT  
	WHERE PA.PAR_NPROG = '100'
		AND PA.PAR_DTREG BETWEEN '<<RIBALTA2(_Vty_DATADAL)>>'  AND  '<<RIBALTA2(_Vty_DATAAL)>>' ) AS T1
	WHERE FLAG_NATURA = 'S' ) AS YTOD
	LEFT OUTER JOIN (SELECT 
		COALESCE(SUM(PAR_TOTIM*(CASE WHEN FLAG_NOTACRED='S' THEN -1 ELSE 1 END)),0) AS IMPO_OGGI,
		COALESCE(SUM(PAR_TIMPOS*(CASE WHEN FLAG_NOTACRED='S' THEN -1 ELSE 1 END)),0) AS IMPOS_OGGI
	FROM ( SELECT 
		PA.PAR_TIPFAT,
		PA.PAR_TOTIM AS PAR_TOTIM,
		PA.PAR_TIMPOS AS PAR_TIMPOS,
		COALESCE(SUBSTRING(PARTOP.LIBERA,2,1),'')  AS FLAG_NATURA, 
		COALESCE(SUBSTRING(PARTOP.LIBERA,11,1),'')  AS FLAG_NOTACRED 
	FROM PART_CLI AS PA
	LEFT OUTER JOIN PARA AS PARTOP
	ON PARTOP.CODICE='TOP'+PA.PAR_TIPFAT  
	WHERE PA.PAR_NPROG = '100'
		AND PA.PAR_DTREG ='<<RIBALTA2(_Vty_DATAOGGI)>>' ) AS T2
	WHERE FLAG_NATURA = 'S' ) AS OGGI
	ON 1=1
	UNION
	SELECT 'ACQUISTI' AS TIPO, YTOD.*,OGGI.* FROM (SELECT 
		COALESCE(SUM(PAR_TOTIM*(CASE WHEN FLAG_NOTACRED='S' THEN -1 ELSE 1 END)),0) AS IMPO_DA_INIZIO_ANNO,
		COALESCE(SUM(PAR_TIMPOS*(CASE WHEN FLAG_NOTACRED='S' THEN -1 ELSE 1 END)),0) AS IMPOS_DA_INIZIO_ANNO
	FROM ( SELECT 
		PA.PAR_TIPFAT,
		PA.PAR_TOTIM AS PAR_TOTIM,
		PA.PAR_TIMPOS AS PAR_TIMPOS,
		COALESCE(SUBSTRING(PARTOP.LIBERA,2,1),'')  AS FLAG_NATURA, 
		COALESCE(SUBSTRING(PARTOP.LIBERA,11,1),'')  AS FLAG_NOTACRED 
	FROM PART_FOR AS PA
	LEFT OUTER JOIN PARA AS PARTOP
	ON PARTOP.CODICE='TOP'+PA.PAR_TIPFAT  
	WHERE PA.PAR_NPROG = '100'
		AND PA.PAR_DTREG BETWEEN '<<RIBALTA2(_Vty_DATADAL)>>'  AND  '<<RIBALTA2(_Vty_DATAAL)>>' ) AS T1
	WHERE FLAG_NATURA = 'S' ) AS YTOD
	LEFT OUTER JOIN (SELECT 
		COALESCE(SUM(PAR_TOTIM*(CASE WHEN FLAG_NOTACRED='S' THEN -1 ELSE 1 END)),0) AS IMPO_OGGI,
		COALESCE(SUM(PAR_TIMPOS*(CASE WHEN FLAG_NOTACRED='S' THEN -1 ELSE 1 END)),0) AS IMPOS_OGGI
	FROM ( SELECT 
		PA.PAR_TIPFAT,
		PA.PAR_TOTIM AS PAR_TOTIM,
		PA.PAR_TIMPOS AS PAR_TIMPOS,
		COALESCE(SUBSTRING(PARTOP.LIBERA,2,1),'')  AS FLAG_NATURA, 
		COALESCE(SUBSTRING(PARTOP.LIBERA,11,1),'')  AS FLAG_NOTACRED 
	FROM PART_FOR AS PA
	LEFT OUTER JOIN PARA AS PARTOP
	ON PARTOP.CODICE='TOP'+PA.PAR_TIPFAT  
	WHERE PA.PAR_NPROG = '100'
		AND PA.PAR_DTREG ='<<RIBALTA2(_Vty_DATAOGGI)>>' ) AS T2
	WHERE FLAG_NATURA = 'S' ) AS OGGI
	ON 1=1


ENDTEXT


IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


SELECT &cNomeCursorSql
GO TOP  
IF !EOF()

	DO WHILE .NOT. EOF()
	
	
	    SELECT &cNomeCursorSql
	    SCATTER MEMVAR memo
	    
		DO CASE 
			CASE m.tipo ='VENDITE'

				SELECT &cNomeCursorSqlCompleto				&& ########################## (aggiorna vendite contabilizzati) #################################
				GO TOP

				REPLACE   FC_TIPO  					WITH  	M.TIPO  
				REPLACE   FC_IMPO_DA_INIZIO_ANNO 	WITH	M.IMPO_DA_INIZIO_ANNO	
				REPLACE   FC_IMPOS_DA_INIZIO_ANNO 	WITH	M.IMPOS_DA_INIZIO_ANNO
				REPLACE   FC_IMPO_OGGI 				WITH	M.IMPO_OGGI
				REPLACE   FC_IMPOS_OGGI 			WITH	M.IMPOS_OGGI
			
			CASE m.tipo ='ACQUISTI'

				SELECT &cNomeCursorSqlCompleto				&& ########################## (aggiorna acquisti contabilizzati) #################################
				GO TOP


				REPLACE   FF_TIPO 					WITH	M.TIPO 
				REPLACE   FF_IMPO_DA_INIZIO_ANNO	WITH	M.IMPO_DA_INIZIO_ANNO
				REPLACE   FF_IMPOS_DA_INIZIO_ANNO 	WITH	M.IMPOS_DA_INIZIO_ANNO
				REPLACE   FF_IMPO_OGGI  	 		WITH	M.IMPO_OGGI
				REPLACE   FF_IMPOS_OGGI  			WITH	M.IMPOS_OGGI

		
		ENDCASE
		
	
	
		SELECT &cNomeCursorSql
		SKIP +1
	ENDDO
	

ENDIF


SELECT(_ACQ_VEN_0000000100_)
	

RETURN(.T.)

