	SELECT(_ACT_SEL)
	RETURN
ENDIF


RELEASE PUB_VALRIF,PUB_CODSOC
PUBLIC PUB_VALRIF,PUB_CODSOC
PUB_VALRIF =  "EUR"
PUB_CODSOC = "01"
PUBLIC PUB_CAUSOS,PUB_RICONF,PUB_DECQTA,PUB_DECPRZ,PUB_DECVAL
PUB_CAUSOS = SPACE(04)
PUB_RICONF = .F.
PUB_DECQTA = 0
PUB_DECPRZ = 0
PUB_DECVAL = 0

