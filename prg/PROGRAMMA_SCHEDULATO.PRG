    SCATTER MEMVAR MEMO
    
    **=> ERASMO - INIZIO 10/04/2015
    IF M.ORD_CAMBIO = 0
    	M.ORD_CAMBIO = 1
    ENDIF
    **=> ERASMO - FINE 10/04/2015
    
    M.ORD_FLGCON = ORD_FLGCON
	M.FORNIT = ALLTRIM(M.ORS_RAGSOC)  + ' (' + ALLTRIM(M.ORS_CODCLI) + ')'
	M.ARTICOLO = ALLTRIM(M.ORD_CODART) + " - " + ALLTRIM(M.ORD_DESART)
	M.ORS_DESCPA = ALLTRIM(M.DESCPA) + " (" + ALLTRIM(M.ORD_CPA) + ")"
	M.ORD_QTARES = IIF(M.ORD_QTAORD > M.ORD_QTAEV, M.ORD_QTAORD - M.ORD_QTAEV, 0)
	M.ORD_ULTDCE = M.ULTDCE
	IF ALLTRIM(M.ORD_VALUTA) <> ALLTRIM(PUB_VALRIF)
		M.ORD_PRZNET = M.ORD_PRZNET / M.ORD_CAMBIO
	ENDIF
	M.ORD_VALNET = ROUND(M.ORD_QTARES * M.ORD_PRZNET,PUB_DECVAL)
	M.ORD_DATPAG = ""
	IF EMPTY(M.ORD_DATCON)
		M.ORD_DATCON = M.ORS_DATORD
	ENDIF
	_FLAG_PAGANT = SUBSTR(M.LIBCPA,252,1)  && FLAG "Pagamento anticipato S/N": SOVRASCRIVO LA PRIMA DATA DI SCADENZA CON LA DATA ORDINE
	
	**=> ERASMO - INIZIO 23/09/2024
	IF !EMPTY(M.PRMDCE) AND !M.ORD_PIANIF
		M.GG_LDTM_EFF = CTOD(RIBALTA2(M.PRMDCE)) - CTOD(RIBALTA2(M.ORS_DATORD))
	ELSE
		M.GG_LDTM_EFF = 0
	ENDIF
	**=> ERASMO - FINE 23/09/2024
    
    SELECT CK_ORF_DD
    APPEND BLANK
    GATHER MEMVAR MEMO
    REPLACE  ORD_FLGCON WITH M.ORD_FLGCON
    
    *** RICALCOLO DATE DI SCADENZA RIGA PER RIGA A SECONDA DELLA DATA CONSEGNA ARTICOLO (EFFETTIVA O PREVISTA)
    PUBLIC VET_DAL[2],VET_AL[2],VET_DAY[2]
	VET_DAL[1]= "0000"
	VET_DAL[2]= "0000"
	VET_AL[1] = "0000"
	VET_AL[2] = "0000"
	VET_DAY[1]= "0000"
	VET_DAY[2]= "0000"
	
	IF USED("PERIODI")
		SELECT PERIODI
		USE
	ENDIF
	CREATE CURSOR PERIODI (DSCAD C(10),IMP_SCAD N(15,PUB_DECVAL),NUM_TRAN N(5))
	
	x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
	x_codi = "for_codcli = '" + ALLTRIM(M.ORS_CODCLI) + "'"
	x_cond = x_soci + " and " + x_codi
	Csql   = "select FOR_BDAL, FOR_B2DAL, FOR_BAL, FOR_B2AL, FOR_GG1, FOR_GG2 from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
	IF !ExecCommand(cSql,"cur_fornitore")
	   return(.f.)
	ENDIF
	SELECT cur_fornitore
	GO TOP
	IF !EOF()
	   VET_DAL[1]= FOR_BDAL
	   VET_DAL[2]= FOR_B2DAL
	   VET_AL[1] = FOR_BAL
	   VET_AL[2] = FOR_B2AL
	   VET_DAY[1]= FOR_GG1
	   VET_DAY[2]= FOR_GG2
	ENDIF
    
	V_DATASCAD  = M.ORD_DATCON
	V_PAG		= M.ORD_CPA

	IF !EMPTY(V_PAG) AND !EMPTY(M.ORS_DATORD)
		TOT_ORDT = M.ORD_VALNET
		TOT_IMPOS = 0
