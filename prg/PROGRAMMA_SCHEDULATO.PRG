	QTA_EVASA N(17,PUB_DECQTA), ;
	QTA_RESIDUA N(17,PUB_DECQTA), ;
	PREZZO_NETTO N(19,PUB_DECPRZ), ;
	GG_LDTM_STD N(10,0), ;
	GG_LDTM_EFF N(10,0), ;
	DAGGANCIO C(10), ;
	ORD_CHIUSO L, ;
	N_ORDINE N(10,0), ; 
	DATCONMOD L)
	
SELECT CK_ORF_DD
GO TOP
DO WHILE .T.
	IF EOF()
		EXIT
	ENDIF
	IF DELETED()
		SKIP +1
		LOOP
	ENDIF
	
	SCATTER MEMVAR MEMO
	
	SELECT XLS_ORF_DD
	APPEND BLANK
	
	REPLACE DAGGANCIO WITH M.DAGGANCIO
	REPLACE CONF WITH IIF(M.ORD_FLGCON,"SI","NO")
