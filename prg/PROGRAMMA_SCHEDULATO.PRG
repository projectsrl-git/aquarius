	REPLACE DATA_PREV_CONSEGNA WITH RIBALTA2(M.ORD_DATCON)
	REPLACE VALORE_NETTO WITH M.ORD_VALNET
	REPLACE DATE_PREV_PAGAMENTO WITH M.ORD_DATPAG
	REPLACE COD_ARTICOLO WITH M.ORD_CODART
	REPLACE DESCRIZIONE_ARTICOLO WITH M.ORD_DESART
	REPLACE UM WITH M.ORD_UM
	REPLACE QTA_ORDINATA WITH M.ORD_QTAORD
	REPLACE QTA_EVASA WITH M.ORD_QTAEV
	REPLACE QTA_RESIDUA WITH M.ORD_QTARES
	REPLACE PREZZO_NETTO WITH M.ORD_PRZNET
	REPLACE ORD_CHIUSO WITH M.ORD_CHIUSO
	REPLACE N_ORDINE WITH M.N_ORDINE
	REPLACE DATCONMOD WITH !EMPTY(M.LOGDATCON)
	REPLACE GG_LDTM_STD WITH M.GG_LDTM_STD
	REPLACE GG_LDTM_EFF WITH M.GG_LDTM_EFF
	
	SELECT CK_ORF_DD
	SKIP +1
ENDDO

