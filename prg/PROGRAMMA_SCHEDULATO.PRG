	CONF C(2), ;
	COD_FORNITORE C(10), ;
	RAG_SOCIALE C(80), ;
	CAUSALE C(10), ;
	NUM_ORDINE C(6), ;
	DATA_ORDINE C(10), ;
	CONDIZ_PAGAMENTO C(100), ;
	ULTIMA_DATA_CONS_EFFETT C(10), ;
	DATA_PREV_CONSEGNA C(10), ;
	VALORE_NETTO N(17,PUB_DECVAL), ;
	DATE_PREV_PAGAMENTO C(100), ;
	COD_ARTICOLO C(30), ;
	DESCRIZIONE_ARTICOLO C(100), ;
	UM C(3), ;
