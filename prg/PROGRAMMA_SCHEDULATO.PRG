x_dcal = IIF(EMPTY(_CK_DTCNAL),"1=1","DD.ORD_DATCON <= '" + RIBALTA2(_CK_DTCNAL) + "'") && Elabora le scadenze dei prossimi 6 giorni limitate ad un periodo di 8 giorni partendo dalla data odierna 
