			ENDIF
		ENDSCAN

		SELECT CK_ORF_DD
		REPLACE ORD_DATPAG WITH M.ORD_DATPAG
	ENDIF
    
	**=> ERASMO - INIZIO 19/04/2017
	*** POPOLAMENTO CAMPO "Log Date consegna"
	_cLogDatCon = ""
	_cGRUPPO_EVENTO_1 = "ORDINE FORNITORE "+ALLTRIM(M.ORS_NUMORD)+" DEL "+M.ORS_DATORD+" MODIFICATO"
	_cGRUPPO_EVENTO_2 = "ORDINE FORNITORE "+ALLTRIM(M.ORS_NUMORD)+" DEL "+RIBALTA2(M.ORS_DATORD)+" MODIFICATO"
	x_tipo = "TIPO_EVENTO = 'ORDFOR'"
	x_grup = "(GRUPPO_EVENTO = '" + _cGRUPPO_EVENTO_1 + "' OR GRUPPO_EVENTO = '" + _cGRUPPO_EVENTO_2 + "')"
	x_arti = "SUBSTRING(DESCRIZIONE,1," + ALLTRIM(STR(LEN(ALLTRIM(M.ORD_CODART))+9,30,0)) + ") = 'ARTICOLO " + ALLTRIM(M.ORD_CODART) + "'"
	x_dtcn = "DESCRIZIONE LIKE '%DATA CONSEGNA MODIFICATA%'"
	x_cond = x_tipo + " and " + x_grup + " and " + x_arti + " and " + x_dtcn
	cSql = "SELECT * FROM LOG_EVENTI WHERE " + x_cond + " ORDER BY DATA_EVENTO+ORA_EVENTO DESC"
	IF !ExecCommand(cSql,"TMP_LOG_EVENTI")
		RETURN .F.
	ENDIF
	SELECT TMP_LOG_EVENTI
	GO TOP
	SCAN
		_cNewLogDatCon = "UTENTE: " + ALLTRIM(COD_USER) + " - " + ALLTRIM(DESCRIZIONE) + " - Valore modificato: " + ALLTRIM(VALORE_SUCC) + " - Valore precedente: " + ALLTRIM(VALORE_PREC)
		IF _cNewLogDatCon $ _cLogDatCon
		ELSE
			_cLogDatCon = ALLTRIM(_cLogDatCon) + IIF(EMPTY(_cLogDatCon),"",CHR(13)) + _cNewLogDatCon
		ENDIF
	ENDSCAN
	SELECT CK_ORF_DD
	REPLACE LOGDATCON WITH _cLogDatCon
	**=> ERASMO - FINE 19/04/2017
    
ENDSCAN



SELECT CK_ORF_DD
GO TOP
IF EOF()
	RETURN .T.
ENDIF

*_V_ORDINA = 2	&& ORDINA PER ARTICOLO / FORNITORE / DATA SCADENZA
