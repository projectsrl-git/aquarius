_ID_PARAMETRI_BATCH  	= _Id_email_
_PATH_EMAIL_			= ""


*!*	Seleziona programma batch da eseguire 
DO CASE

	CASE _cNome_programma = '0000000100'	&& Check Up Azienda (COMPLETO)             
	
			*DO SCRIVI_FILE_TESTO WITH _par_oggetto_timer,"FASE 2.3: ENTRATO NELLA CONDIZIONE DEL RICHIAMO ALLA FUNZIONE 'ESEGUE_PROGRAMMA_0000000100' NELLA PROCEDURA 'ELABORA_PROGRAMMA_SCHEDULATO'"
			
			=ESEGUE_PROGRAMMA_0000000100(_par_oggetto_timer)
	
	CASE _cNome_programma = '0000000200'	&& Check Up Azienda (CUSTOMER SERVICE)
			
			=ESEGUE_PROGRAMMA_0000000200()
	
	CASE _cNome_programma = '0000000300'	&& Check Up Azienda (ACQUISTI)
			
			=ESEGUE_PROGRAMMA_0000000300()

	OTHERWISE 
	
		*_PRG_DA_ESEGUIRE = PATH_PROGRAMMA_DA_ESEGUIRE(_cNome_programma)
		*_PARAMETRI = PARAMETRI_PROGRAMMA_DA_ESEGUIRE(_ID_PARAMETRI_BATCH)
		**=> ERASMO - INIZIO 07/06/2023
		_PRG_DA_ESEGUIRE = ALLTRIM(PATH_PROGRAMMA_DA_ESEGUIRE(_cNome_programma))
		_PARAMETRI = ALLTRIM(PARAMETRI_PROGRAMMA_DA_ESEGUIRE(_ID_PARAMETRI_BATCH))
		**=> ERASMO - FINE 07/06/2023
		
		IF !EMPTY(_PRG_DA_ESEGUIRE)
		
			IF EMPTY(_PARAMETRI )
				_COMANDO="DO "+_PRG_DA_ESEGUIRE 
			ELSE
				_COMANDO="DO "+_PRG_DA_ESEGUIRE + " WITH "+_PARAMETRI
			ENDIF	
			&_COMANDO

		ELSE
			WAIT WINDOWS "NESSUN PROGRAMMA BATCH ESEGUITO !!!!!" NOWAIT 
		ENDIF

ENDCASE


