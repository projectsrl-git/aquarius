		V_TUTTO = TRANCHE("PARA",V_PAG,V_DATASCAD,TOT_ORDT,VET_DAL,VET_AL,VET_DAY)
		=CREA_SCADENZE()
		
		IF _FLAG_PAGANT = 'S'  && FLAG "Pagamento anticipato S/N": SOVRASCRIVO LA PRIMA DATA DI SCADENZA CON LA DATA ORDINE
			SELECT PERIODI
			GO TOP
			IF !EOF()
				REPLACE DSCAD WITH RIBALTA2(M.ORS_DATORD)
			ENDIF
		ENDIF
		
		SELECT PERIODI
		GO TOP
		SCAN
			IF EMPTY(M.ORD_DATPAG)
