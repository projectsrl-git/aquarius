cSql   = "SELECT DD.*, TT.ORD_FLGCON, TT.ORD_CPA, TT.ORD_CAUS, TT.ORD_VALUTA, TT.ORD_CAMBIO, COALESCE(PARA_CPA.DESCRI,'') AS DESCPA, " + CHR(13) + ;
         "COALESCE(PARA_CPA.LIBERA,'') AS LIBCPA, AN.ART_LDTMST AS GG_LDTM_STD, TT.ORD_PIANIF, " + CHR(13) + ;
         "COALESCE((SELECT TOP 1 ORS_DATORD FROM U_BFO_DD WHERE ORD_LEGAME = DD.DAGGANCIO AND ORD_LEGASY = DD.ORD_CODSYS ORDER BY ORS_DATORD DESC),'') AS ULTDCE, " + CHR(13) + ;
         "COALESCE((SELECT TOP 1 ORS_DATORD FROM U_BFO_DD WHERE ORD_LEGAME = DD.DAGGANCIO AND ORD_LEGASY = DD.ORD_CODSYS ORDER BY ORS_DATORD),'') AS PRMDCE " + CHR(13) + ;
         "FROM U_ORF_DD AS DD " + CHR(13) + ;
         "LEFT OUTER JOIN U_ORF_TT AS TT ON TT.TAGGANCIO = DD.DAGGANCIO " + CHR(13) + ;
         "LEFT OUTER JOIN PARA AS PARA_CPA ON PARA_CPA.CODICE = 'CPA'+TT.ORD_CPA " + CHR(13) + ;
