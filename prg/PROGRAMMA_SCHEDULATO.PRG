x_cond = x_comm + " and " + x_evas + " and " + x_conf + " and " + x_clie + " and " + x_arti + " and " + x_dtda + " and " + x_dtal + " and " + x_nord + " and " + x_dcda + " and " + x_dcal
x_cond = STRTRAN(x_cond," and 1=1","")
*!*	cSql   = "SELECT DD.*, TT.ORD_FLGCON, TT.ORD_CPA, TT.ORD_CAUS, TT.ORD_VALUTA, TT.ORD_CAMBIO, COALESCE(PARA_CPA.DESCRI,'') AS DESCPA, " + CHR(13) + ;
*!*	         "COALESCE(PARA_CPA.LIBERA,'') AS LIBCPA, COALESCE(BFO_DD.ORS_DATORD,'') AS ULTDCE FROM U_ORF_DD AS DD " + CHR(13) + ;
*!*	         "LEFT OUTER JOIN U_ORF_TT AS TT ON TT.TAGGANCIO = DD.DAGGANCIO " + CHR(13) + ;
*!*	         "LEFT OUTER JOIN PARA AS PARA_CPA ON PARA_CPA.CODICE = 'CPA'+TT.ORD_CPA " + CHR(13) + ;
*!*	         "LEFT OUTER JOIN (SELECT TOP 1 ORS_DATORD, ORD_LEGAME, ORD_LEGASY FROM U_BFO_DD ORDER BY ORS_DATORD DESC) AS BFO_DD ON BFO_DD.ORD_LEGAME = DD.DAGGANCIO AND BFO_DD.ORD_LEGASY = DD.ORD_CODSYS " + ;
*!*	         "WHERE " + x_cond
