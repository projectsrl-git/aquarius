**************************************
PROCEDURE SCHEDULER_ATTENDI_N_SECONDI
**************************************

LPARAMETERS _par_seconds

*_BEFORE_SECONDS = SECONDS()
_BEFORE_SECONDS = INT(SECONDS())  && ERASMO - INIZIO 26/11/2012
IF _BEFORE_SECONDS >= 86399
	_BEFORE_SECONDS = 0
	DO WHILE !(SECONDS() > 0  .AND. SECONDS() < 1)  && A CAVALLO TRA 2 GIORNI, ATTENDO LA MEZZANOTTE
		LOOP
	ENDDO
ENDIF
_AFTER_SECONDS = CEILING(_BEFORE_SECONDS + _par_seconds)

DO WHILE !(SECONDS() >= _AFTER_SECONDS)
	LOOP
ENDDO

ENDPROC

**************************************
PROCEDURE ELABORA_PER_PERDER_TEMPO
**************************************
** ELABORAZIONE FITTIZIA ARCHIVI PER VERIFICARE SE ESEGUE IL SECONDO TASK MENTRE STA OPERANDO IL PRIMO CON UNA NORMALE FASE ESECUTIVA


cSql=""     
cNomeCursorSql="CU_PROGRAMMA__000TEST200"

IF USED(cNomeCursorSql)
	SELECT &cNomeCursorSql
	USE
ENDIF

x_cond  = "id_PARAMETRI = '" + _ID_PARAMETRI_BATCH + "'"					
cSql   = "select * from PARAMETRI_SCHEDULER where " + x_cond  
IF !ExecCommand(cSql,"CU_PARAMETRI_SCHEDULER")
   return(.f.)
ENDIF

SELECT CU_PARAMETRI_SCHEDULER
GO TOP
IF EOF()
	WAIT WINDOWS "Nessun parametro configurato per il programma '" + _ID_PARAMETRI_BATCH + "'" NOWAIT
	RETURN .F.
ENDIF

_Vtyk_DATADAL ="01/01/2000" 		  
_Vtyk_DATAAL  ="31/12/2999" 			 

WAIT WINDOWS "((((((((((((((((( ELABORAZIONE FITTIZIA )))))))))))))))))" NOWAIT

TEXT TO cSql NOSHOW

	SELECT	
		ORD_DATORD,
		COUNT(*) AS QUANTI_ORDINI, 
		SUM(ORD_VALORE) AS AQ_OC_VALOR ,
		SUM(ORD_QTANR) AS AQ_OC_QTANR,
		SUM(ORD_QTAKG) AS AQ_OC_QTAKG,
		SUM(ORD_QTAMC) AS AQ_OC_QTAMC,
		SUM(ORD_QTAMQ) AS AQ_OC_QTAMQ,
		SUM(ORD_QTAML) AS AQ_OC_QTAML 
	FROM(
		SELECT
			TT.ORD_NUMORD,
			TT.ORD_DATORD,
			TT.TAGGANCIO,
			SUM(DD.ORD_VALORE) AS ORD_VALORE,
			SUM(DD.ORD_NUMBOB) AS ORD_QTANR,
			SUM(DD.ORD_QTAKG) AS ORD_QTAKG,
			SUM(DD.ORD_QTAMC) AS ORD_QTAMC,
			SUM(DD.ORD_QTAMQ) AS ORD_QTAMQ,
			SUM(DD.ORD_QTAML) AS ORD_QTAML 
		FROM U_ORD_TT AS TT
		LEFT OUTER JOIN U_ORD_DD AS DD
		ON TT.TAGGANCIO=DD.DAGGANCIO AND DD.ORD_CODART <>'' AND DD.ORD_DESART<>'*** COMMENTO ***'
		GROUP BY TT.ORD_NUMORD, TT.ORD_DATORD, TT.TAGGANCIO) AS T1
	WHERE ORD_DATORD >= '<<RIBALTA2(_Vtyk_DATADAL)>>' AND  ORD_DATORD <= '<<RIBALTA2(_Vtyk_DATAAL)>>'
	GROUP BY ORD_DATORD
	ORDER BY ORD_DATORD 


ENDTEXT


IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF		



ENDPROC





