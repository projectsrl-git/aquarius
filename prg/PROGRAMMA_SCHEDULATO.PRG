_cKey = ""

DO CASE
	CASE _V_ORDINA = 1
		SET ORDER TO D_DAT_NUM 
		_cKey = "DAGGANCIO"
	CASE _V_ORDINA = 2
		SET ORDER TO I_ART_CLI
		_cKey = "ORD_CODART+ORS_CODCLI+ORD_DATCON"
	CASE _V_ORDINA = 3
		SET ORDER TO I_ART_CON
		_cKey = "ORD_CODART+ORD_DATCON"
	CASE _V_ORDINA = 4  && ERASMO - 10/04/2015
		SET ORDER TO I_CLI_CON
		_cKey = "ORS_CODCLI+ORD_DATCON+ORS_DATORD+ORS_NUMORD+ORD_CODART"
	OTHERWISE
		SET ORDER TO D_DAT_NUM
		_cKey = "DAGGANCIO"
ENDCASE

*** SCRITTURA NUMERO RIGA ORDINE PER LETTURA FACILITATA
_OLD_KEY = ""
GO TOP
NEW_N_ORDINE = 0
SCAN
	IF _OLD_KEY == &_cKey
	ELSE
		_OLD_KEY = &_cKey
		NEW_N_ORDINE = NEW_N_ORDINE + 1
	ENDIF
	REPLACE N_ORDINE WITH NEW_N_ORDINE
ENDSCAN
GO TOP

