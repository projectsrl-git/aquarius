
PUBLIC TOTPAG
TOTPAG  = 0
NUMPRO  = TAGGANCIO

SELECT CU_CEA_DD

DO STAMPAMOD

RIGAFAT  = 0
RIGANC   = 0
ANCORA   = 1
V_REPORT = "CEA000.FRX"
V_REPOR1 = "CEA001.FRX"
V_REPOR2 = "CEA002.FRX"

SELECT CU_CEA_DD
=AFIELDS(CAMPI_CEA)
CREATE CURSOR CSR_FAT FROM ARRAY CAMPI_CEA
CREATE CURSOR CSR_NCR FROM ARRAY CAMPI_CEA

RIGAFAT = 0
RIGANC  = 0

SELECT CU_CEA_DD
GO TOP
  
DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
  
*!*	   IF ORD_VALORE>=0
   **=> ERASMO - INIZIO 27/07/2005
   IF ORD_IMPVAL>=0
   **=> ERASMO - FINE 27/07/2005
      RIGAFAT=RIGAFAT+1
      SCATTER MEMVAR
      SELECT CSR_FAT
      APPEND BLANK
      GATHER MEMVAR
      REPLACE ORD_RIGA WITH RIGAFAT
   ELSE
      RIGANC=RIGANC+1
      SCATTER MEMVAR
      SELECT CSR_NCR
      APPEND BLANK
      GATHER MEMVAR
      REPLACE ORD_RIGA WITH RIGANC
      REPLACE ORD_VALORE WITH ABS(ORD_VALORE)
      **=> ERASMO - INIZIO 27/07/2005
      REPLACE ORD_IMPVAL WITH ABS(ORD_IMPVAL)
      **=> ERASMO - FINE 27/07/2005      
   ENDIF
    
   SELECT CU_CEA_DD
   SKIP +1
  
ENDDO

SELECT CSR_FAT
GO TOP
DO PRG\MENUSTA WITH "CSR_FAT",.F.,.T.,"XXX","CEA000","CEA000.FRX"

SELECT CSR_FAT
GO TOP
DO PRG\MENUSTA WITH "CSR_FAT",.F.,.T.,"XXX","CEA001","CEA001.FRX"

SELECT CSR_NCR
GO TOP
DO PRG\MENUSTA WITH "CSR_NCR",.F.,.T.,"XXX","CEA002","CEA002.FRX"
  
SELECT CU_CEA_DD
GO BOTTOM

RETURN


*****************************
PROCEDURE STAMPAMOD
*****************************
PUBLIC VORD_CODSOC,VTNUMERO,VORD_VALUTA,VORD_CAMBIO,VORD_DATORD,VORD_NUMORD,VORD_VALORE,VORD_CODCLI
PUBLIC VORD_RAGSOC,VORD_INDIRI,VORD_CAP,VORD_LOCALI,VORD_PARIVA,VORD_CAUS,VORD_RIFERI,VORD_CONST
PUBLIC VORD_CHIUSO,VORD_TRASME,VORD_CGE,VORD_TELEFO

SELECT CU_CEA_DD
DAGGA = DAGGANCIO

v_seek	 = CEA_RECNO
v_chiave = "taggancio"
IF seek_std('u_CEA_tt',v_seek,v_chiave,'CUR_TESTATA')
   SELECT CUR_TESTATA
   VORD_VALUTA = ORD_VALUTA
   VORD_CAMBIO = ORD_CAMBIO
   VORD_DATORD = RIBALTA2(ORD_DATORD)
   VORD_NUMORD = ORD_NUMORD
   VORD_VALORE = ORD_VALORE
   VORD_CODCLI = ORD_CODCLI
   VORD_RAGSOC = ORD_RAGSOC
   VORD_INDIRI = ORD_INDIRI
   VORD_CAP    = ORD_CAP
   VORD_LOCALI = ORD_LOCALI
   VORD_PARIVA = ORD_PARIVA
   VORD_CAUS   = ORD_CAUS
   VORD_RIFERI = ORD_RIFERI
   VORD_CONST  = ORD_CONST
   VORD_CHIUSO = ORD_CHIUSO
   VORD_TRASME = ORD_TRASME
   VORD_CGE    = ORD_CGE
   VORD_TELEFO = ORD_TELEFO
ELSE 
   VORD_VALUTA = M.ORD_VALUTA
   VORD_CAMBIO = M.ORD_CAMBIO
   VORD_DATORD = RIBALTA2(M.ORD_DATORD)
   VORD_NUMORD = M.ORD_NUMORD
   VORD_VALORE = M.ORD_VALORE
   VORD_CODCLI = M.ORD_CODCLI
   VORD_RAGSOC = M.ORD_RAGSOC
   VORD_INDIRI = M.ORD_INDIRI
   VORD_CAP    = M.ORD_CAP
   VORD_LOCALI = M.ORD_LOCALI
   VORD_PARIVA = M.ORD_PARIVA
   VORD_CAUS   = M.ORD_CAUS 
   VORD_RIFERI = M.ORD_RIFERI
   VORD_CONST  = M.ORD_CONST
   VORD_CHIUSO = M.ORD_CHIUSO
   VORD_TRASME = M.ORD_TRASME
   VORD_CGE    = M.ORD_CGE
   VORD_TELEFO = M.ORD_TELEFO
ENDIF

RETURN
