
_RISP = MESSAGEBOX("Utility per sistemazione anomalia ricarichi di magazzino da produzione manuale bobine" + REPLICATE(CHR(13),2) + ;
	"Continuare?",4+32,"Attenzione")
IF _RISP = 6
ELSE
	RETURN .F.
ENDIF

WAIT WINDOWS "Ricerca programmi con anomalie in corso..." NOWAIT

cSql=""     
cNomeCursorSql="SEL_PROGRAMMI"
TEXT TO cSql NOSHOW
	SELECT SPACE(10) AS SELEZIONE, NUMPRG, DATPRG, IDPRG, CODART FROM (
		SELECT PR.NUMPRG,PR.DATPRG,PC.IDPRG,PC.CODART FROM PROD_CARICHI AS PC
		LEFT OUTER JOIN PROD_IMPEGNI AS PI ON PI.CODART = PC.CODART
		OUTER APPLY (SELECT TOP 1 MOV_PREACQ FROM U_MAG_MO WHERE MOV_CODART = PC.CODINT ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MC
		OUTER APPLY (SELECT TOP 1 MOV_PREACQ FROM U_MAG_MO WHERE MOV_CODART = PI.CODINT ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MI
		LEFT OUTER JOIN PRODUZIONE AS PR ON PC.IDPRG = PR.IDPRG AND PARENT = ''
		WHERE PC.SYSORD = '' AND SUBSTRING(PC.IDPRG,1,1) = 'M'
		AND MC.MOV_PREACQ NOT IN (SELECT MOV_PREACQ FROM U_MAG_MO WHERE MOV_CODART IN (SELECT CODINT FROM PROD_IMPEGNI WHERE IDPRG = PC.IDPRG AND CODART = PI.CODART))
		) AS MAIN
	GROUP BY NUMPRG,DATPRG,IDPRG,CODART
	ORDER BY DATPRG,NUMPRG,CODART
ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT SEL_PROGRAMMI
GO TOP
SCAN
	*** SOLO BOBINE
	IF ALLTRIM(CERCATIPO(CODART)) <> '1'
		DELETE
	ENDIF
ENDSCAN
GO TOP

WAIT CLEAR

IF EOF()
	MESSAGEBOX("Nessun programma con anomalie riscontrate",64,"Informazione")
	RETURN .F.
ENDIF

DO prg\browseview WITH "SEL_PROGRAMMI","Selezione Programmi da sistemare","NUMPRG:Num.programma,W:10;DATPRG:Data,W:10;IDPRG:Id. Programma,W:10;CODART:Articolo,W:15;",500,600,.T.,.F.

IF NumeroRecordLetti = 0
	MESSAGEBOX("Operazione abbandonata",48,"Attenzione")
	RETURN .F.
ENDIF

_CONTA_TOTART_AGGIORNATI = 0
_CONTA_PRG_AGGIORNATI = 0

SELECT SEL_PROGRAMMI
GO TOP
SCAN
	IF ALLTRIM(SELEZIONE) <> "==>"
		LOOP
	ENDIF

	WAIT WINDOWS "Elaborazione programma " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + " (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 
      
	SCATTER MEMVAR
		
	x_idpr = "PC.IDPRG = '" + M.IDPRG + "'"
	x_syso = "PC.SYSORD = ''"
	x_arti = "PC.CODART = '" + M.CODART + "'"
	x_cond = x_idpr + " and " + x_syso + " and " + x_arti 
	cSql = "SELECT COALESCE(MC.MOV_PREACQ,0) AS MOV_PREACQ,* FROM PROD_CARICHI AS PC " + CHR(13) + ;
	       "OUTER APPLY (SELECT TOP 1 MOV_PREACQ FROM U_MAG_MO WHERE MOV_CODART = PC.CODINT) AS MC " + CHR(13) + ;
	       "WHERE " + x_cond + " ORDER BY CODINT"
	IF !ExecCommand(cSql,"TMP_PROD_CARICHI")
	  return(.f.)
	ENDIF
	SELECT TMP_PROD_CARICHI
	GO TOP
	IF EOF()
		SELECT SEL_PROGRAMMI
		LOOP
	ENDIF	
	
	x_idpr = "PI.IDPRG = '" + M.IDPRG + "'"
	x_arti = "PI.CODART = '" + M.CODART + "'"
	x_cond = x_idpr + " and " + x_arti 
	cSql = "SELECT COALESCE(MC.MOV_PREACQ,0) AS MOV_PREACQ,* FROM PROD_IMPEGNI AS PI " + CHR(13) + ;
	       "OUTER APPLY (SELECT TOP 1 MOV_PREACQ FROM U_MAG_MO WHERE MOV_CODART = PI.CODINT) AS MC " + CHR(13) + ;
	       "WHERE " + x_cond + " ORDER BY CODINT"
	IF !ExecCommand(cSql,"TMP_PROD_IMPEGNI")
	  return(.f.)
	ENDIF
	SELECT TMP_PROD_IMPEGNI
	GO TOP
	IF EOF()
		SELECT SEL_PROGRAMMI
		LOOP
	ENDIF
	
	SELECT TMP_PROD_CARICHI
	GO TOP
	SCAN
		_CODART = ALLTRIM(CODART)
		_CODINT = ALLTRIM(CODINT)
		_PREZZO_ASSEGNATO = MOV_PREACQ
		
		IF UPPER(ALLTRIM(_CODART)) == UPPER(ALLTRIM(_CODINT))  && SE UTILIZZO COME CHIAVE IL CODICE INTERNO, ESSO DEVE ESSERE NECESSARIAMENTE DIVERSO DAL CODICE ANAGRAFICO
			LOOP
		ENDIF
		
		_ALMENO_1_PREZZO_CORRISPONDENTE = .F.
		SELECT TMP_PROD_IMPEGNI
		GO TOP
		SCAN	
			IF _PREZZO_ASSEGNATO = MOV_PREACQ	
				_ALMENO_1_PREZZO_CORRISPONDENTE = .T.
				EXIT
			ENDIF
		ENDSCAN
		
		IF _ALMENO_1_PREZZO_CORRISPONDENTE
			SELECT TMP_PROD_CARICHI
			LOOP
		ENDIF
		
		SELECT TMP_PROD_IMPEGNI
		GO TOP
		_PREZZO_NUOVO_DA_ASSEGNARE = MOV_PREACQ
		
		*** AGGIORNAMENTO PREZZI
		x_cint = "MAG_CODART = '" + _CODINT + "'"
		x_cond = x_cint 
		cSql = "SELECT * FROM U_MAG_GG WHERE " + x_cond 
		IF !ExecRW(cSql,"U_MAG_GG","R")
		  return(.f.)
		ENDIF
		SELECT U_MAG_GG
		GO TOP
		SCAN
			REPLACE MAG_PRZCON WITH _PREZZO_NUOVO_DA_ASSEGNARE
		ENDSCAN
		IF !ExecRW(cSql,"U_MAG_GG","W")
		  return(.f.)
		ENDIF
		
		x_cint = "MOV_CODART = '" + _CODINT + "'"
		x_cond = x_cint
		cSql = "SELECT * FROM U_MAG_MO WHERE " + x_cond 
		IF !ExecRW(cSql,"U_MAG_MO","R")
		  return(.f.)
		ENDIF
		SELECT U_MAG_GG
		GO TOP
		SCAN
			REPLACE MOV_PREACQ WITH _PREZZO_NUOVO_DA_ASSEGNARE
		ENDSCAN
		IF !ExecRW(cSql,"U_MAG_MO","W")
		  return(.f.)
		ENDIF
		
		DO AQM_DATI_ULTIMA_MOVIMENTAZIONE_ARTICOLO WITH '+',_CODART,.T.
		
		_CONTA_TOTART_AGGIORNATI = _CONTA_TOTART_AGGIORNATI + 1
		
	ENDSCAN
	
	_CONTA_PRG_AGGIORNATI = _CONTA_PRG_AGGIORNATI + 1
	
ENDSCAN

MESSAGEBOX("Totale programmi aggiornati: " + ALLTRIM(STR(_CONTA_PRG_AGGIORNATI)) + CHR(13) + ;
	"Totale articoli aggiornati: " + ALLTRIM(STR(_CONTA_TOTART_AGGIORNATI)),64,"Informazione")

RETURN
