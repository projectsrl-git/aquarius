****************************************
* PRELEVA_CAMBI_GIORNALIERI
****************************************

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI
*SET STEP ON
_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO
PUBLIC V_TITOLO

V_TITOLO	= "Aggiornamento cambi giornalieri dal sito Banca d'Italia"

WAIT WINDOWS "ESEGUE PROGRAMMA PRELEVA_CAMBI_GIORNALIERI" TIMEOUT 3


LOCAL _CONTA_DATE_SCARICATE

DATADAL = DTOC(DATE())
*!*	IF DOW(DATE()) = 1  && SE DOMENICA
*!*		DATADAL = DTOC(DATE()-2)
*!*	ENDIF
*!*	IF DOW(DATE()) = 2  && SE LUNEDI'
*!*		DATADAL = DTOC(DATE()-3)
*!*	ENDIF
DATAAL = DTOC(DATE())

SET PROCEDURE TO PRG\CAMBIO_LIB	ADDITIVE
SET PROCEDURE TO PRG\REPLIB	ADDITIVE
SET PROCEDURE TO PRG\APPLILIB ADDITIVE  && ERASMO - 21/10/2025
PUB_ULTCAM = .T.
_CONTA_DATE_SCARICATE = SCARICA_CAMBI_GIORNALIERI_DAL_AL(DATADAL,DATAAL)

*!*	RELEASE PROCEDURE PRG\CAMBIO_LIB
*!*	RELEASE PROCEDURE PRG\REPLIB

WAIT CLEAR

IF _CONTA_DATE_SCARICATE = 0
	*MESSAGEBOX("Nessun aggiornamento disponibile per le date indicate",48,"Colloquio con archivio Banca Italia") 
	RETURN
ENDIF

*** DEFINIZIONE CURSORE DI STAMPA
cSql = "Select * from U_VVA_CH where VVA_DATA BETWEEN '"+RIBALTA2(DATADAL)+"' AND '"+RIBALTA2(DATAAL)+"' ORDER BY VVA_DATA,VVA_CODVAL "
IF !ExecCommand(cSql,"STAMPA_VALUTE")
   return(.f.)
ENDIF
SELECT STAMPA_VALUTE
GO TOP
IF EOF()
	RETURN
ENDIF

SELECT STAMPA_VALUTE

_PDF_REPORT_ 		= ALLTRIM(CERCAREPO("XXX","VALLIST","VALLIST.FRX"))
_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "STAMPA_VALUTE"

IF !EMPTY(_PDF_SUBDIR_ )
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
