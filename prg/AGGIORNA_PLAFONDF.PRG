
LPARAMETERS _par_aaaa,_par_mm_al,_par_rigenera

IF PCOUNT() < 2
	RETURN .F.
ENDIF

IF PCOUNT() >= 3
ELSE
	_par_rigenera = .F.
ENDIF


*** SE PARAMETRO DI INGRESSO ATTIVATO, RIGENERA COMPLETAMENTE LA TABELLA U_IVA_FE PER L'ANNO INDICATO
IF _par_rigenera
	cSql=""     
	cNomeCursorSql="TEMP"
	TEXT TO cSql NOSHOW
		DELETE FROM U_IVA_FE WHERE IVA_ANNO = '<<_par_aaaa>>'
	ENDTEXT
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
	
	cSql=""     
	cNomeCursorSql="TEMP"
	TEXT TO cSql NOSHOW
		INSERT INTO U_IVA_FE
		(IVA_CODSOC,IVA_ANNO,IVA_CODFOR,IVA_DESFOR,IVA_PLAFOND) 
		SELECT FOR_CODSOC,'<<_par_aaaa>>',FOR_CODCLI,FOR_RAGSOC,FOR_IMPINT 
		FROM U_FOR_AN 
		WHERE  for_IMPINT<>0
		AND FOR_INTDUE = 'XX' AND FOR_ANNOPE = '<<_par_aaaa>>'
	ENDTEXT
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
ENDIF


*** PATCH ELIMINAZIONE RIGHE DI U_IVA_FE SENZA COD FORNITORE
cSql=""     
cNomeCursorSql="TEMP"
TEXT TO cSql NOSHOW
	DELETE FROM U_IVA_FE WHERE IVA_CODFOR = ''
ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

**=> ERASMO - INIZIO 05/12/2019
*** PATCH RIPOPOLAMENTO FORZATO CAMPO "U_IVA_FE.IVA_PLAFOND" IN CASO DI PERDITA INFORMAZIONE
IF !_par_rigenera
	cSql=""     
	cNomeCursorSql="TEMP"
	TEXT TO cSql NOSHOW
		UPDATE FE SET FE.IVA_PLAFOND = COALESCE((SELECT FOR_IMPINT FROM U_FOR_AN WHERE FOR_CODCLI = FE.IVA_CODFOR AND FOR_INTDUE = 'XX' AND FOR_ANNOPE = '<<_par_aaaa>>'),0) FROM U_IVA_FE AS FE WHERE IVA_ANNO = '<<_par_aaaa>>' AND IVA_PLAFOND = 0
	ENDTEXT
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
ENDIF
**=> ERASMO - FINE 05/12/2019

**=> ERASMO - INIZIO 29/04/2019
_NOME_TABELLA_BOLLATO_IVA_FORNITORI = "U_IVF_CL"
IF PUB_LIQDTDOC
	_NOME_TABELLA_BOLLATO_IVA_FORNITORI = "U_IVF_CL_DTDOC"
ENDIF
**=> ERASMO - FINE 29/04/2019

LOCAL I,N_MESE_AL
I=0
N_MESE_AL = VAL(_par_mm_al)

*** AGGIORNAMENTO PLAFOND FORNITORI DELL'ANNO SPECIFICATO NEL PARAMETRO DI INGRESSO DA GENNAIO AL MESE SPECIFICATO NEL PARAMETRO DI INGRESSO
FOR I=1 TO N_MESE_AL
	
	_C_MESE = PADL(ALLTRIM(STR(I,2,0)),2,'0')
	
	_C_NOMECAMPO = ""
	DO CASE
		CASE _C_MESE = '01'
			_C_NOMECAMPO = "IVA_GENNAI"
		CASE _C_MESE = '02'
			_C_NOMECAMPO = "IVA_FEBBRA"
		CASE _C_MESE = '03'
			_C_NOMECAMPO = "IVA_MARZO"
		CASE _C_MESE = '04'
			_C_NOMECAMPO = "IVA_APRILE"
		CASE _C_MESE = '05'
			_C_NOMECAMPO = "IVA_MAGGIO"
		CASE _C_MESE = '06'
			_C_NOMECAMPO = "IVA_GIUGNO"
		CASE _C_MESE = '07'
			_C_NOMECAMPO = "IVA_LUGLIO"
		CASE _C_MESE = '08'
			_C_NOMECAMPO = "IVA_AGOSTO"
		CASE _C_MESE = '09'
			_C_NOMECAMPO = "IVA_SETTEM"
		CASE _C_MESE = '10'
			_C_NOMECAMPO = "IVA_OTTOBR"
		CASE _C_MESE = '11'
			_C_NOMECAMPO = "IVA_NOVEMB"
		CASE _C_MESE = '12'
			_C_NOMECAMPO = "IVA_DICEMB"
	ENDCASE
	
	cSql=""     
	cNomeCursorSql="TEMP"
*!*		TEXT TO cSql NOSHOW
*!*		
*!*			UPDATE U_IVA_FE 
*!*			SET <<_C_NOMECAMPO>> = COALESCE((SELECT SUM(IVF_IMPONI * (CASE WHEN  IVF_FATNOT='N' THEN -1 ELSE 1 END))
*!*			FROM U_IVF_CL 
*!*			WHERE IVF_CODIVA IN (SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND CALCPLAFACQ = 1) AND IVF_MESE='<<_C_MESE>>' AND IVF_ANNO='<<_par_aaaa>>' AND IVF_CODCLI=IVA_CODFOR
*!*			AND (((SELECT AZI_PRDISP FROM U_AZI_PA) = 1 AND (IVF_CODCLI <> '410109030' OR IVF_DTFATT >= '2017/07/27')) OR ((SELECT AZI_PRDISP FROM U_AZI_PA) = 0))
*!*			GROUP BY IVF_CODCLI,IVF_RAGSOC,IVF_CODIVA,IVF_MESE,IVF_ANNO),0)
*!*			WHERE IVA_ANNO='<<_par_aaaa>>'
*!*		
*!*		ENDTEXT

	**=> ERASMO/SERGIO - INIZIO 23/10/2017
	*** SE PARAMETRO ATTIVO, RICALCOLO IL PLAFOND FORNITORI IN BASE ALLA DATA FATTURA, NON ALLA DATA REGISTRAZIONE
	IF PUB_PLADFA		
		TEXT TO cSql NOSHOW
		
			UPDATE U_IVA_FE 
			SET <<_C_NOMECAMPO>> = COALESCE((SELECT SUM(IVF_IMPONI * (CASE WHEN  IVF_FATNOT='N' THEN -1 ELSE 1 END))
			--FROM U_IVF_CL 
			FROM <<_NOME_TABELLA_BOLLATO_IVA_FORNITORI>>  -- ERASMO - 29/04/2019
			WHERE IVF_CODIVA IN (SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND CALCPLAFACQ = 1) AND SUBSTRING(IVF_DTFATT,6,2)='<<_C_MESE>>' AND SUBSTRING(IVF_DTFATT,1,4)='<<_par_aaaa>>' AND IVF_CODCLI=IVA_CODFOR
			GROUP BY IVF_CODCLI,IVF_RAGSOC,IVF_CODIVA,SUBSTRING(IVF_DTFATT,6,2),SUBSTRING(IVF_DTFATT,1,4)),0)
			WHERE IVA_ANNO='<<_par_aaaa>>'
		
		ENDTEXT
	ELSE
		TEXT TO cSql NOSHOW
		
			UPDATE U_IVA_FE 
			SET <<_C_NOMECAMPO>> = COALESCE((SELECT SUM(IVF_IMPONI * (CASE WHEN  IVF_FATNOT='N' THEN -1 ELSE 1 END))
			--FROM U_IVF_CL 
			FROM <<_NOME_TABELLA_BOLLATO_IVA_FORNITORI>>  -- ERASMO - 29/04/2019
			WHERE IVF_CODIVA IN (SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND CALCPLAFACQ = 1) AND IVF_MESE='<<_C_MESE>>' AND IVF_ANNO='<<_par_aaaa>>' AND IVF_CODCLI=IVA_CODFOR
			GROUP BY IVF_CODCLI,IVF_RAGSOC,IVF_CODIVA,IVF_MESE,IVF_ANNO),0)
			WHERE IVA_ANNO='<<_par_aaaa>>'
		
		ENDTEXT
	ENDIF
	**=> ERASMO/SERGIO - FINE 23/10/2017
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
	
	**=> ERASMO/SERGIO - INIZIO 23/10/2017
	*** ECCEZIONE GESTITA SOLO PER PRODUZIONE DISP. MEDICALI - IN QUESTO CASO IN GENNAIO 2017 SOMMO LE FATTURE CON DATA REGISTRAZIONE GENNAIO (SOLO QUELLE NON CONSIDERATE PRECEDENTEMENTE)
	IF PUB_PLADFA AND PUB_PRDISP AND _par_aaaa = '2017' AND _C_MESE = '01'
		cSql=""     
		cNomeCursorSql="TEMP"
		TEXT TO cSql NOSHOW
		
			UPDATE U_IVA_FE 
			SET <<_C_NOMECAMPO>> = <<_C_NOMECAMPO>> + COALESCE((SELECT SUM(IVF_IMPONI * (CASE WHEN  IVF_FATNOT='N' THEN -1 ELSE 1 END))
			FROM U_IVF_CL 
			WHERE IVF_CODIVA IN (SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND CALCPLAFACQ = 1) AND IVF_MESE='<<_C_MESE>>' AND IVF_ANNO='<<_par_aaaa>>' AND IVF_CODCLI=IVA_CODFOR
			AND ID_UNIQUE NOT IN (SELECT ID_UNIQUE FROM U_IVF_CL 
									WHERE IVF_CODIVA IN (SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND CALCPLAFACQ = 1) AND SUBSTRING(IVF_DTFATT,6,2)='<<_C_MESE>>' AND SUBSTRING(IVF_DTFATT,1,4)='<<_par_aaaa>>' AND IVF_CODCLI=IVA_CODFOR
								)
			GROUP BY IVF_CODCLI,IVF_RAGSOC,IVF_CODIVA,IVF_MESE,IVF_ANNO),0)
			WHERE IVA_ANNO='<<_par_aaaa>>'
		
		ENDTEXT
		IF !ExecPreparedCommand(cSql,cNomeCursorSql)
			return(.F.)
		ENDIF
		
		cSql=""     
		cNomeCursorSql="TEMP"
		TEXT TO cSql NOSHOW
		
			UPDATE U_IVA_FE 
			SET <<_C_NOMECAMPO>> = <<_C_NOMECAMPO>> + COALESCE((SELECT SUM(IVF_IMPONI * (CASE WHEN  IVF_FATNOT='N' THEN -1 ELSE 1 END))
			FROM U_IVF_CL 
			WHERE IVF_CODIVA IN (SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'IVA%' AND CALCPLAFACQ = 1) AND 
				IVF_NUMFAT='1600693' AND IVF_DTFATT='2016/10/28' AND IVF_CODCLI='410126441' AND IVF_CODCLI=IVA_CODFOR
			GROUP BY IVF_CODCLI,IVF_RAGSOC,IVF_CODIVA,IVF_MESE,IVF_ANNO),0)
			WHERE IVA_ANNO='<<_par_aaaa>>' AND IVA_CODFOR='410126441'
		
		ENDTEXT
		IF !ExecPreparedCommand(cSql,cNomeCursorSql)
			return(.F.)
		ENDIF
	ENDIF
	**=> ERASMO/SERGIO - FINE 23/10/2017
	
NEXT


*** AGGIORNAMENTO PLAFOND RESIDUO PER TUTTO L'ANNO SPECIFICATO NEL PARAMETRO DI INGRESSO
cSql=""     
cNomeCursorSql="TEMP"
TEXT TO cSql NOSHOW
		
	UPDATE U_IVA_FE SET 
	IVA_01RESI=IVA_PLAFOND-IVA_GENNAI
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_02RESI=IVA_01RESI-IVA_FEBBRA
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_03RESI=IVA_02RESI-IVA_MARZO
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_04RESI=IVA_03RESI-IVA_APRILE
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_05RESI=IVA_04RESI-IVA_MAGGIO
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_06RESI=IVA_05RESI-IVA_GIUGNO
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_07RESI=IVA_06RESI-IVA_LUGLIO
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_08RESI=IVA_07RESI-IVA_AGOSTO
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_09RESI=IVA_08RESI-IVA_SETTEM
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_10RESI=IVA_09RESI-IVA_OTTOBR
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_11RESI=IVA_10RESI-IVA_NOVEMB
	WHERE IVA_ANNO='<<_par_aaaa>>'

	UPDATE U_IVA_FE SET 
	IVA_12RESI=IVA_11RESI-IVA_DICEMB
	WHERE IVA_ANNO='<<_par_aaaa>>'

ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


*** AGGIORNAMENTO PLAFOND GENERALE DI TUTTI I FORNITORI (SE PARAMETRO AZIENDALE ATTIVO)
IF PUB_PLAFACQ
	cSql=""     
	cNomeCursorSql="TEMP"
	TEXT TO cSql NOSHOW

		UPDATE U_IVA_ES SET
			--IVA_PLAFOND = COALESCE((SELECT SUM(IVA_PLAFOND) AS TOT_IVA_PLAFOND FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_GENNAI = COALESCE((SELECT SUM(IVA_GENNAI) AS TOT_IVA_GENNAI FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_FEBBRA = COALESCE((SELECT SUM(IVA_FEBBRA) AS TOT_IVA_FEBBRA FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_MARZO  = COALESCE((SELECT SUM(IVA_MARZO) AS TOT_IVA_MARZO FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_APRILE = COALESCE((SELECT SUM(IVA_APRILE) AS TOT_IVA_APRILE FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_MAGGIO = COALESCE((SELECT SUM(IVA_MAGGIO) AS TOT_IVA_MAGGIO FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_GIUGNO = COALESCE((SELECT SUM(IVA_GIUGNO) AS TOT_IVA_GIUGNO FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_LUGLIO = COALESCE((SELECT SUM(IVA_LUGLIO) AS TOT_IVA_LUGLIO FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_AGOSTO = COALESCE((SELECT SUM(IVA_AGOSTO) AS TOT_IVA_AGOSTO FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_SETTEM = COALESCE((SELECT SUM(IVA_SETTEM) AS TOT_IVA_SETTEM FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_OTTOBR = COALESCE((SELECT SUM(IVA_OTTOBR) AS TOT_IVA_OTTOBR FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_NOVEMB = COALESCE((SELECT SUM(IVA_NOVEMB) AS TOT_IVA_NOVEMB FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0),
			IVA_DICEMB = COALESCE((SELECT SUM(IVA_DICEMB) AS TOT_IVA_DICEMB FROM U_IVA_FE WHERE IVA_ANNO='<<_par_aaaa>>'), 0)
		WHERE IVA_ANNO = '<<_par_aaaa>>'
		
		UPDATE U_IVA_ES SET 
		IVA_01RESI=IVA_PLAFOND-IVA_GENNAI
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_02RESI=IVA_01RESI-IVA_FEBBRA
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_03RESI=IVA_02RESI-IVA_MARZO
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_04RESI=IVA_03RESI-IVA_APRILE
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_05RESI=IVA_04RESI-IVA_MAGGIO
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_06RESI=IVA_05RESI-IVA_GIUGNO
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_07RESI=IVA_06RESI-IVA_LUGLIO
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_08RESI=IVA_07RESI-IVA_AGOSTO
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_09RESI=IVA_08RESI-IVA_SETTEM
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_10RESI=IVA_09RESI-IVA_OTTOBR
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_11RESI=IVA_10RESI-IVA_NOVEMB
		WHERE IVA_ANNO='<<_par_aaaa>>'

		UPDATE U_IVA_ES SET 
		IVA_12RESI=IVA_11RESI-IVA_DICEMB
		WHERE IVA_ANNO='<<_par_aaaa>>'
	
	ENDTEXT
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF

ENDIF

RETURN .T.
