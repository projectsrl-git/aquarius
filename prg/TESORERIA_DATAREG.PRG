**************************************************************************
* TESORERIA_DATAREG.PRG
*
* Modifica la data di registrazione per banca e tipo di pagamento
**************************************************************************

DO IMPOSTA_COMAREA

DO CREA_I_CURSORI

*** ESEGUE IL FORM PER L'ASSEGNAZIONE DELLE DATE DI REGISTRAZIONE 
*** AI VARI MOVIMENTI IMPOSTATI DALLA TESORERIA
DO FORM FORM\TESORERIA_DATAREG LINKED

*** MODIFICA I MPVIMENTI IN BASE ALLE ASSEGNAZIINI FATTE NELLA MASCHERA
*** PRIMA DI TORNARE A TESORERIA
DO MODIFICA_MOVIMENTI

*** ORA I MOVIMENTI PRESENTANO LA DATA REGISTRAZIOEN DESIDERATA 
*** E SONO PRONTI PER LA CONTABILIZZAZIONE

DO RILASCIA_COMAREA

RETURN
* FINE TESORERIA_CONTAB_AGG.PRG
******************************************************


****************************************
PROCEDURE IMPOSTA_COMAREA
*
* IMPOSTA LE VARIABILI PUBBLICHE DA UTILIZZARE PER 
* SCAMBIARE I DATI TRA I COMPONENTI DI QUESTO PROGRAMMA
****************************************
DO RILASCIA_COMAREA

PUBLIC 	PUB_DTREG_DA_ASSEGNARE

PUB_DTREG_DA_ASSEGNARE	=	SPACE(0)

RETURN
* FINE PROCEDURE IMPOSTA_COMAREA
****************************************


****************************************
PROCEDURE RILASCIA_COMAREA
*
* RILASCIA LE VARIABILI PUBBLICHE UTILIZZATE PER 
* SCAMBIARE I DATI TRA I COMPONENTI DI QUESTO PROGRAMMA
****************************************
RELEASE	PUB_DTREG_DA_ASSEGNARE

RETURN
* FINE PROCEDURE RILASCIA_COMAREA
****************************************


******************************************************
PROCEDURE CREA_I_CURSORI
******************************************************

*** CREO IL CURSOR RIEPILOGATIVO PER BANCA / TIPOLOGIA

SELECT ;
		BANCA,;
		DES_DA, ;
		TIPOLOGIA,;
		SUM(IMPORTO) AS IMPORTO ;
	FROM MOVIMENTI ;
	WHERE TIPOLOGIA!="TRAS-FONDI" ;
	GROUP BY BANCA, DES_DA, TIPOLOGIA ;
	INTO CURSOR CDATAREG1 ;
	READWRITE
	
SELECT 	CDATAREG1
INDEX ON BANCA+TIPOLOGIA 	TAG BANCATIPO

SET ORDER TO BANCATIPO


*** CREO IL CURSOR DEI DETTAGLI DEI PAGAMENTI PER BANCA / TIPOLOGIA
SELECT MOVIMENTI
gnFieldcount = AFIELDS(gaMyArray)  && Create array

CREATE CURSOR CDATAREG2 FROM ARRAY gaMyArray
SELECT CDATAREG2
INDEX ON ID_MOVIMEN			TAG ID_MOVIMEN
INDEX ON BANCA+TIPOLOGIA 	TAG BANCATIPO
SET ORDER TO BANCATIPO

SELECT MOVIMENTI
GO TOP
DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF
	
	SELECT MOVIMENTI
	SCATTER MEMVAR
	
	SELECT CDATAREG2
	APPEND BLANK
	GATHER MEMVAR

	SELECT MOVIMENTI
	SKIP
	
ENDDO

*** ALL'APERTURA DELLA FORM NON DEVO VISUALIZZARE NULLA
*** NELLA GRIGLIA DEL DETTAGLIO FINCHE' NON CI SARA'
*** LA PRIMA SELEZIONE DI UNA BANCA
SELECT CDATAREG2
SET FILTER TO .F.

RETURN
* FINE PROCEDURE CREA_I_CURSORI
******************************************************


******************************************************
PROCEDURE MODIFICA_MOVIMENTI
******************************************************

SELECT	CDATAREG2
GO TOP
DO WHILE !EOF()

	IF DELETED()
		SKIP
		LOOP
	ENDIF

	_ID_MOVIMEN	= ID_MOVIMEN
	_DTREG		= DTREG
	
	MODIFICA_MOVIMENTO(_ID_MOVIMEN,_DTREG)	
	
	SELECT CDATAREG2
	SKIP
	
ENDDO

SELECT	CDATAREG2
GO TOP

RETURN
* FINE PROCEDURE MODIFICA_MOVIMENTI
******************************************************


*************************************************************************
PROCEDURE MODIFICA_MOVIMENTO
*
* Sostituisce nel movimento con ID_MOVIMEN = P_ID_PARTITA passato in input
* la data di registrazione DTREG con P_DATA_REG passata in input
*
* LE DATE SONO RIBALTATE (AAAA/MM/GG)
*
*************************************************************************
PARAMETERS	P_ID_PARTITA,;
			P_DATA_REG
			
LOCAL	_SALVA_SEL

_SALVA_SEL=STR(SELECT())


SELECT MOVIMENTI
GO TOP
SET ORDER TO ID_MOVIMEN

SEEK P_ID_PARTITA

IF !FOUND()
	SELECT &_SALVA_SEL
	RETURN(.F.)
ENDIF

REPLACE	DTREG	WITH	P_DATA_REG

SELECT &_SALVA_SEL
RETURN(.T.)

* FINE PROCEDURE MODIFICA_MOVIMENTO
******************************************************
