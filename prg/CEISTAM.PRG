
PUBLIC TOTPAG
TOTPAG  = 0
NUMPRO  = TAGGANCIO

SELECT CU_CEI_DD

DO STAMPAMOD

RIGAFAT  = 0
RIGANC   = 0
ANCORA   = 1
V_REPORT = "CEI000.FRX"
V_REPOR1 = "CEI001.FRX"
V_REPOR2 = "CEI002.FRX"

SELECT CU_CEI_DD
=AFIELDS(CAMPI_CEI)
CREATE CURSOR CSR_FAT FROM ARRAY CAMPI_CEI
=MODTBL(ALIAS(SELECT()),"PROGPAG","N(17,3)")
=MODTBL(ALIAS(SELECT()),"PGRIGA","C(5)")
=MODTBL(ALIAS(SELECT()),"PROGTOT","N(17,3)")
CREATE CURSOR CSR_NCR FROM ARRAY CAMPI_CEI


SELECT CSR_FAT 
*INDEX ON ORD_IVACEE 	TAG I_IVACEE ADDITIVE
INDEX ON ORD_IVACEE+ORD_CLDOG TAG I_IVACEE ADDITIVE  && ERASMO/FBIANO - 18/04/2016

SELECT CSR_NCR 
*INDEX ON ORD_IVACEE 	TAG I_IVACEE ADDITIVE
INDEX ON ORD_IVACEE+ORD_CLDOG TAG I_IVACEE ADDITIVE  && ERASMO/FBIANO - 18/04/2016




SELECT CU_CEI_DD
GO TOP
  
DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
  
   IF ORD_VALORE>=0
      RIGAFAT=RIGAFAT+1
      SCATTER MEMVAR
      SELECT CSR_FAT
      APPEND BLANK
      GATHER MEMVAR
      REPLACE ORD_RIGA WITH RIGAFAT
   ELSE
      RIGANC=RIGANC+1
      SCATTER MEMVAR
      SELECT CSR_NCR
      APPEND BLANK
      GATHER MEMVAR
      REPLACE ORD_RIGA WITH RIGANC
      REPLACE ORD_VALORE WITH ABS(ORD_VALORE)
   ENDIF
    
   SELECT CU_CEI_DD
   SKIP +1
  
ENDDO

DIECI    = 0
TOTCEI   = 0
TOTPAG   = 0
TOTALONE = 0


_CONTARIGHE=0

SELECT CSR_FAT
GO TOP
  
DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
  
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   
   _CONTARIGHE=_CONTARIGHE+1
   REPLACE ORD_RIGA WITH _CONTARIGHE
   
   TOTCEI   = TOTCEI + ORD_VALORE
   TOTALONE = TOTALONE+ ORD_VALORE
   DIECI    = DIECI+1
   
   IF DIECI = 10
      TOTPAG = TOTPAG + 1 
      REPLACE PROGPAG WITH TOTCEI
      REPLACE PROGTOT WITH TOTALONE		&& ...FABIANO
      REPLACE PGRIGA  WITH ALLTRIM(STR(TOTPAG,5,0))
      DIECI  = 0
      TOTCEI = 0
   ENDIF 
  
   SELECT CSR_FAT
   SKIP +1

ENDDO  

IF DIECI !=0  			&& SE HO PASSATO TUTTO IL CURSORE SENZA CONCLUDERE LE 10 RIGHE
						&& DELL'ULTIMA PAGINA AGGIORNO COMUNQUE IL NUMERO DI PAGINA E
						&& I TOTALI... FABIANO
   SKIP -1
   TOTPAG = TOTPAG + 1 
   REPLACE PROGPAG WITH TOTCEI
   REPLACE PROGTOT WITH TOTALONE		&& ...FABIANO
   REPLACE PGRIGA  WITH ALLTRIM(STR(TOTPAG,5,0))
ENDIF 

SELECT CSR_FAT
GO TOP
DO PRG\MENUSTA WITH "CSR_FAT",.F.,.T.,"XXX","CEI000","CEI000.FRX"

SELECT CSR_FAT
SET ORDER TO I_IVACEE 
GO TOP
DO PRG\MENUSTA WITH "CSR_FAT",.F.,.T.,"XXX","CEI001","CEI001.FRX"

SELECT CSR_NCR
SET ORDER TO I_IVACEE 
GO TOP
DO PRG\MENUSTA WITH "CSR_NCR",.F.,.T.,"XXX","CEI002","CEI002.FRX"
  
SELECT CU_CEI_DD
GO BOTTOM

RETURN


*****************************
PROCEDURE STAMPAMOD
*****************************
PUBLIC VORD_CODSOC,VTNUMERO,VORD_VALUTA,VORD_CAMBIO,VORD_DATORD,VORD_NUMORD,VORD_VALORE,VORD_CODCLI
PUBLIC VORD_RAGSOC,VORD_INDIRI,VORD_CAP,VORD_LOCALI,VORD_PARIVA,VORD_CAUS,VORD_RIFERI,VORD_CONST
PUBLIC VORD_CHIUSO,VORD_TRASME,VORD_CGE,VORD_TELEFO

SELECT CU_CEI_DD
DAGGA = DAGGANCIO

v_seek	 = CEI_RECNO
v_chiave = "taggancio"
IF seek_std('u_cei_tt',v_seek,v_chiave,'CUR_TESTATA')
   SELECT CUR_TESTATA
   VORD_VALUTA = ORD_VALUTA
   VORD_CAMBIO = ORD_CAMBIO
   VORD_DATORD = RIBALTA2(ORD_DATORD)
   VORD_NUMORD = ORD_NUMORD
   VORD_VALORE = ORD_VALORE
   VORD_CODCLI = ORD_CODCLI
   VORD_RAGSOC = ORD_RAGSOC
   VORD_INDIRI = ORD_INDIRI
   VORD_CAP    = ORD_CAP
   VORD_LOCALI = ORD_LOCALI
   VORD_PARIVA = ORD_PARIVA
   VORD_CAUS   = ORD_CAUS
   VORD_RIFERI = ORD_RIFERI
   VORD_CONST  = ORD_CONST
   VORD_CHIUSO = ORD_CHIUSO
   VORD_TRASME = ORD_TRASME
   VORD_CGE    = ORD_CGE
   VORD_TELEFO = ORD_TELEFO
ELSE 
   VORD_VALUTA = M.ORD_VALUTA
   VORD_CAMBIO = M.ORD_CAMBIO
   VORD_DATORD = M.ORD_DATORD
   VORD_DATORD = RIBALTA2(M.ORD_DATORD)
   VORD_VALORE = M.ORD_VALORE
   VORD_CODCLI = M.ORD_CODCLI
   VORD_RAGSOC = M.ORD_RAGSOC
   VORD_INDIRI = M.ORD_INDIRI
   VORD_CAP    = M.ORD_CAP
   VORD_LOCALI = M.ORD_LOCALI
   VORD_PARIVA = M.ORD_PARIVA
   VORD_CAUS   = M.ORD_CAUS 
   VORD_RIFERI = M.ORD_RIFERI
   VORD_CONST  = M.ORD_CONST
   VORD_CHIUSO = M.ORD_CHIUSO
   VORD_TRASME = M.ORD_TRASME
   VORD_CGE    = M.ORD_CGE
   VORD_TELEFO = M.ORD_TELEFO
ENDIF

RETURN
