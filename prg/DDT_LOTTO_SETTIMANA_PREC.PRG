*******************************
* DDT_LOTTO_SETTIMANA_PREC
*******************************
LPARAMETERS _N_SETTIMANE_PREC

IF PCOUNT()<1
	RETURN .F.
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

*!*	RELEASE V_TITOLO,V_GIORNI_PRECEDENTI
*!*	PUBLIC V_TITOLO,V_GIORNI_PRECEDENTI

*!*	V_GIORNI_PRECEDENTI = _GIORNI_PRECEDENTI

*!*	V_TITOLO = "Giacenze alla data"

WAIT WINDOWS "ESEGUE PROGRAMMA DDT_LOTTO_SETTIMANA_PREC" TIMEOUT 3

RELEASE _V_DATE
PUBLIC _V_DATE
_V_DATE = "TT.ORD_DATORD BETWEEN convert(varchar, DATEADD(ww, DATEDIFF(ww,0,DATEADD(week,-" + ALLTRIM(STR(_N_SETTIMANE_PREC,10,0)) + ",GETDATE())), 0), 111) AND " + ;
	"convert(varchar, DATEADD(ww, DATEDIFF(ww,0,DATEADD(week,-" + ALLTRIM(STR(_N_SETTIMANE_PREC,10,0)) + ",GETDATE())), 6), 111)"

cNomeCursorSql="CX_DDT_MOVIMENTI"

LOCAL cSql
cSql = ""
TEXT TO cSql NOSHOW 

	SELECT
		TT.ORD_NUMORD AS NUM_DDT,
		TT.ORD_DATORD AS DATA_DDT,
		TT.ORD_CODCLI COD_CLI,
		TT.ORD_RAGSOC RAG_SOC,
		TT.ORD_CAUS AS CAUS,
		COALESCE(P_TOP.DESCRI,'') AS DESCR_CAUS,
		DD.ORD_CODART AS COD_ART,
		DD.ORD_DESART AS DESCR_ART,
		DD.ORD_UM AS UM,
		MO.MOV_QTAMOV AS QTA,
		MO.MOV_SERIAL AS LOTTO
	FROM U_BOL_DD AS DD
	LEFT OUTER JOIN U_BOL_TT AS TT ON TT.TAGGANCIO = DD.DAGGANCIO
	LEFT OUTER JOIN U_ART_PR AS PR ON PR.ART_CODPRI = DD.ORD_CODART
	LEFT OUTER JOIN U_ART_AN AS AN ON PR.ART_CODPRI = AN.ART_CODPRI
	LEFT OUTER JOIN PARA AS P_TOP ON P_TOP.CODICE = 'TOP'+TT.ORD_CAUS
	LEFT OUTER JOIN U_MAG_MO AS MO ON MO.MOV_ANAART = DD.ORD_CODART AND MO.MOV_LEGSYS = DD.ORD_SYSMAG AND MO.MOV_NUMDOC = TT.ORD_NUMORD AND MO.MOV_TOP = TT.ORD_CAUS
	WHERE TT.ORD_FORNI = 0 AND DD.ORD_CODART <> '' AND <<_V_DATE>> AND AN.ART_CODTSN = 'LOT'
	ORDER BY TT.TAGGANCIO,DD.ORD_SEQUEN,MO.MOV_SERIAL

ENDTEXT

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
   return(.f.)
ENDIF

LOCAL _DIRECTORY_PDF,_NOME_REPORT

_DIRECTORY_PDF=LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")  && RICERCA PERCORSO
IF !DIRECTORY(_DIRECTORY_PDF)
	*MESSAGEBOX("Directory '" + JUSTDRIVE(_DIRECTORY_PDF) + "' inesistente" + CHR(13) + CHR(13) + ;
		"Non sarŕ possibile creare correttamente i files PDF",48,"Attenzione")
	RETURN .F.
ENDIF

_NOME_REPORT = _DIRECTORY_PDF + "\" + "DDT_LOTTO_SETTIMANA_PREC" + SYS(2015) + ".XLSX"

SET PROCEDURE TO PRG\APPLILIB ADDITIVE
SET PROCEDURE TO PRG\XLSLIB	ADDITIVE

WAIT WINDOW "ATTENDERE PREGO: creazione report excel in corso..." NOWAIT

_TITOLO_EXCEL1 = "ARTICOLI DDT A LOTTO SETTIMANA PRECEDENTE"
_TITOLO_EXCEL2 = ""
_TITOLO_EXCEL3 = ""
_TOTALI_GENERALI = .T.
DO ESTRXLS WITH "CX_DDT_MOVIMENTI",_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,_TOTALI_GENERALI,.F.,.F.,_NOME_REPORT

*!*	RELEASE PROCEDURE PRG\APPLILIB 
*!*	RELEASE PROCEDURE PRG\XLSLIB

_ALLEGATI = ""
_FILE_DA_ALLEGARE = JUSTFNAME(_NOME_REPORT)
_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 

_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )