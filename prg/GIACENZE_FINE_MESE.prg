*!*		"	MOV_CODMAG AS MAG_CODMAG," + CHR(13) + ;
*!*		"	DESCRI," + CHR(13) + ;
*!*		"	MOV_ANAART AS MAG_ANAART," + CHR(13) + ;
*!*		"	ART_DESCR," + CHR(13) + ;
