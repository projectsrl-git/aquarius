*!*	LOCAL cSql
*!*	cSql = ""
*!*	TEXT TO cSql NOSHOW 
*!*		Declare @DATAAL as varchar(10)
*!*		Set @DATAAL = '<<RIBALTA2(_V_DATAAL)>>'

*!*		SELECT
*!*			MOV_LEGAME AS MAG_LEGAME,
*!*			SUBSTRING(MIN(MOV_DTREGI+MOV_ORAMOV),1,10) AS MAG_DATAGG,
*!*			SUBSTRING(MIN(MOV_DTREGI+MOV_ORAMOV),11,8) AS MAG_ORACAR,
*!*			MOV_CODMAG AS MAG_CODMAG,
*!*			DESCRI,
*!*			MOV_ANAART AS MAG_ANAART,
*!*			ART_DESCR,
*!*			ART_UMMAGA,
*!*			ART_PRZCOS,
*!*			ART_LINEA,
*!*			DESLIN,
*!*			SUM(CASE WHEN MOV_SEGNO = '+' THEN MOV_QTAMOV ELSE -1*MOV_QTAMOV END) AS MAG_GIACEN,
*!*			0 AS MAG_QTAIMP,
*!*			MOV_SERIAL AS MAG_SERIAL,
*!*			MOV_PREACQ AS MAG_PRZCON,
*!*			MOV_CODFOR AS MAG_FORNIT,
*!*			ULT_DTSCAD AS MAG_DTSCAD,
*!*			ART_CODGMI,
*!*			DESGMI,
*!*			DESGMI_1_3,
*!*			DESGMI_1_6,
*!*			ULT_PREACQ,
*!*			ULT_FORNIT,
*!*			MEP_PREACQ,
*!*			MAG_VALUTA,
*!*			MAG_CHANGE FROM (

*!*			SELECT
*!*				MO.MOV_SEGNO,
*!*				MO.MOV_LEGAME,
*!*				MO.MOV_DTREGI,
*!*				MO.MOV_ORAMOV,
*!*				MO.MOV_CODMAG,
*!*				MG.DESCRI,
*!*				MO.MOV_ANAART,
*!*				PR.ART_DESCR,
*!*				PR.ART_UMMAGA,
*!*				PR.ART_PRZCOS,
*!*				PR.ART_LINEA,
*!*				COALESCE(LN.DESCRI,'') AS DESLIN,
*!*				MO.MOV_QTAMOV,
*!*				MO.MOV_SERIAL,
*!*				--MO.MOV_PREACQ,
*!*				--COALESCE(MV.MOV_PREACQ,MV.MOV_PREACQ,PR.ART_ULPCAR,0) AS MOV_PREACQ,
*!*				COALESCE(MV.MOV_PREACQ,MVU.MOV_PREACQ,0) AS MOV_PREACQ,  -- ERASMO - 28/05/2019
*!*				MO.MOV_CODFOR,
*!*				AN.ART_CODGMI,
*!*				COALESCE(GM.DESCRI,'') AS DESGMI,
*!*				COALESCE(GM_1_3.DESCRI,'') AS DESGMI_1_3,
*!*				COALESCE(GM_1_6.DESCRI,'') AS DESGMI_1_6,
*!*				COALESCE((SELECT TOP 1 MOV_DTSCAD FROM U_MAG_MO WHERE MOV_LEGAME = MO.MOV_LEGAME AND MOV_ANAART = MO.MOV_ANAART AND MOV_DOCMOD = 0 AND MOV_DTREGI <= @DATAAL ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),'') AS ULT_DTSCAD,
*!*				--COALESCE((SELECT TOP 1 MOV_PREACQ FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_DOCMOD = 0 AND MOV_SEGNO = '+' AND MOV_PREACQ > 0 AND MOV_DTREGI <= @DATAAL ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),0) AS ULT_PREACQ,
*!*				--COALESCE((SELECT TOP 1 MOV_FORNIT FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_DOCMOD = 0 AND MOV_SEGNO = '+' AND MOV_PREACQ > 0 AND MOV_DTREGI <= @DATAAL ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),'') AS ULT_FORNIT,
*!*				COALESCE(PR.ART_ULPCAR,0) AS ULT_PREACQ,
*!*				COALESCE((SELECT TOP 1 MOV_FORNIT FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_DOCMOD = 0 AND MOV_SEGNO = '+' AND MOV_PREACQ > 0 ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),'') AS ULT_FORNIT,
*!*				COALESCE(
*!*					(SELECT
*!*						CASE WHEN SOMMA_QTA > 0 THEN SOMMA_QTA_PER_PREZZO / SOMMA_QTA ELSE 0 END AS PREZZO_MEDIO_PONDERATO_GIACENZE
*!*					 FROM (
*!*						SELECT 
*!*							COALESCE(SUM(CASE WHEN (MOV_QTAMOV > 0 AND MOV_PREACQ > 0) THEN MOV_QTAMOV * MOV_PREACQ ELSE 0 END),0) AS SOMMA_QTA_PER_PREZZO, 
*!*							COALESCE(SUM(CASE WHEN (MOV_QTAMOV > 0 AND MOV_PREACQ > 0) THEN MOV_QTAMOV ELSE 0 END),0) AS SOMMA_QTA FROM (
*!*								SELECT MOV_QTAMOV,MOV_PREACQ FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_PREACQ > 0 AND MOV_SEGNO = '+' AND MOV_DTREGI <= @DATAAL
*!*							) AS MAIN
*!*						) AS T1),0) AS MEP_PREACQ,
*!*				--COALESCE(MV.MOV_VALUTA,'') AS MAG_VALUTA, 
*!*				COALESCE(MV.MOV_VALUTA,MVU.MOV_VALUTA,'') AS MAG_VALUTA, 
*!*				--COALESCE(VV.VVA_CHANGE,1) AS MAG_CHANGE
*!*				COALESCE(VV.VVA_CHANGE,VVU.VVA_CHANGE,1) AS MAG_CHANGE
*!*			FROM U_MAG_MO AS MO
*!*			LEFT OUTER JOIN U_ART_PR AS PR ON PR.ART_CODPRI = MO.MOV_ANAART
*!*			LEFT OUTER JOIN U_ART_AN AS AN ON AN.ART_CODPRI = PR.ART_CODPRI
*!*			LEFT OUTER JOIN PARA AS GM ON GM.CODICE = 'GMI'+AN.ART_CODGMI
*!*			LEFT OUTER JOIN PARA AS GM_1_3 ON GM_1_3.CODICE = 'GMI'+SUBSTRING(AN.ART_CODGMI,1,3)
*!*			LEFT OUTER JOIN PARA AS GM_1_6 ON GM_1_6.CODICE = 'GMI'+SUBSTRING(AN.ART_CODGMI,1,6)
*!*			LEFT OUTER JOIN PARA AS MG ON MG.CODICE = 'MAG'+MO.MOV_CODMAG
*!*			LEFT OUTER JOIN PARA AS LN ON LN.CODICE = 'REP'+PR.ART_LINEA
*!*			OUTER APPLY (SELECT TOP 1 MOV_LEGAME, MOV_DTREGI, MOV_VALUTA, MOV_PREACQ, MOV_DTDOCU FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_LEGAME = MO.MOV_LEGAME ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MV 
*!*			--OUTER APPLY (SELECT TOP 1 MOV_LEGAME, MOV_DTREGI, MOV_VALUTA, MOV_PREACQ, MOV_DTDOCU FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_DTREGI <= MO.MOV_DTREGI ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MVU   -- ERASMO - 19/04/2019			
*!*			OUTER APPLY (SELECT TOP 1 MOV_LEGAME, MOV_DTREGI, MOV_VALUTA, MOV_PREACQ, MOV_DTDOCU FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_LEGAME = 
*!*				(SELECT TOP 1 MOV_LEGAME FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_SEGNO = '+' AND MOV_DTREGI <= MO.MOV_DTREGI ORDER BY MOV_DTREGI DESC,MOV_ORAMOV DESC) ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MVU   -- ERASMO - 28/05/2019 
*!*			--OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MV.MOV_VALUTA AND VVA_DATA <= MV.MOV_DTDOCU ORDER BY VVA_DATA DESC) AS VV 
*!*			--OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MVU.MOV_VALUTA AND VVA_DATA <= MVU.MOV_DTDOCU ORDER BY VVA_DATA DESC) AS VVU 
*!*			OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MV.MOV_VALUTA AND VVA_DATA <= (CASE WHEN MV.MOV_DTDOCU = '' THEN MV.MOV_DTREGI ELSE MV.MOV_DTDOCU END) ORDER BY VVA_DATA DESC) AS VV   -- ERASMO - 19/04/2019
*!*			OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MVU.MOV_VALUTA AND VVA_DATA <= (CASE WHEN MVU.MOV_DTDOCU = '' THEN MVU.MOV_DTREGI ELSE MVU.MOV_DTDOCU END) ORDER BY VVA_DATA DESC) AS VVU   -- ERASMO - 19/04/2019
*!*			WHERE <<x_cond>>  AND MO.MOV_SEGNO <> '' AND MO.MOV_DTREGI <= @DATAAL  --AND MO.MOV_CODMAG = 'RCH'
*!*			) AS MAIN
*!*			GROUP BY MOV_LEGAME,MOV_CODMAG,DESCRI,MOV_ANAART,ART_DESCR,ART_UMMAGA,ART_PRZCOS,ART_LINEA,DESLIN,MOV_SERIAL,MOV_PREACQ,MOV_CODFOR,ULT_DTSCAD,ART_CODGMI,DESGMI,DESGMI_1_3,DESGMI_1_6,ULT_PREACQ,ULT_FORNIT,MEP_PREACQ,MAG_VALUTA,MAG_CHANGE
*!*	ENDTEXT

**=> ERASMO - INIZIO 10/03/2023
LOCAL cSql
cSql = ""
TEXT TO cSql NOSHOW
	Declare @DATAAL as varchar(10)
	Set @DATAAL = '<<RIBALTA2(_V_DATAAL)>>'

	SELECT
		MAG_LEGAME,
		MAG_UNIQUE,  -- ERASMO - 18/05/2023
		MAG_DATAGG,
		MAG_ORACAR,
		MAG_CODMAG,
		MG.DESCRI,
		MAG_ANAART,
		PR.ART_DESCR,
		PR.ART_DESCR,
		PR.ART_UMMAGA,
		PR.ART_PRZCOS,
		PR.ART_LINEA,
		PR.ART_CODCTL,
		COALESCE(LN.DESCRI,'') AS DESLIN,
		MAG_GIACEN,
		MAG_QTAIMP,
		MAG_SERIAL,
		COALESCE(MV.MOV_PREACQ,MVU.MOV_PREACQ,0) AS MAG_PRZCON,
		MAG_FORNIT,
		COALESCE((SELECT TOP 1 MOV_DTSCAD FROM U_MAG_MO WHERE MOV_LEGAME = T1.MAG_LEGAME AND MOV_ANAART = T1.MAG_ANAART AND MOV_DOCMOD = 0 AND MOV_DTREGI <= @DATAAL ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),'') AS MAG_DTSCAD,
		AN.ART_CODGMI,
		COALESCE(GM.DESCRI,'') AS DESGMI,
		COALESCE(GM_1_3.DESCRI,'') AS DESGMI_1_3,
		COALESCE(GM_1_6.DESCRI,'') AS DESGMI_1_6,
		COALESCE(PR.ART_ULPCAR,0) AS ULT_PREACQ,
		COALESCE((SELECT TOP 1 MOV_FORNIT FROM U_MAG_MO WHERE MOV_ANAART = T1.MAG_ANAART AND MOV_DOCMOD = 0 AND MOV_SEGNO = '+' AND MOV_PREACQ > 0 ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),'') AS ULT_FORNIT,
		COALESCE(
			(SELECT
				CASE WHEN SOMMA_QTA > 0 THEN SOMMA_QTA_PER_PREZZO / SOMMA_QTA ELSE 0 END AS PREZZO_MEDIO_PONDERATO_GIACENZE
				FROM (
				SELECT 
					COALESCE(SUM(CASE WHEN (MOV_QTAMOV > 0 AND MOV_PREACQ > 0) THEN MOV_QTAMOV * MOV_PREACQ ELSE 0 END),0) AS SOMMA_QTA_PER_PREZZO, 
					COALESCE(SUM(CASE WHEN (MOV_QTAMOV > 0 AND MOV_PREACQ > 0) THEN MOV_QTAMOV ELSE 0 END),0) AS SOMMA_QTA FROM (
						SELECT MOV_QTAMOV,MOV_PREACQ FROM U_MAG_MO WHERE MOV_ANAART = T1.MAG_ANAART AND MOV_PREACQ > 0 AND MOV_SEGNO = '+' AND MOV_DTREGI <= @DATAAL
					) AS MAIN
				) AS T1),0) AS MEP_PREACQ,
		COALESCE(MV.MOV_VALUTA,MVU.MOV_VALUTA,'') AS MAG_VALUTA,
		COALESCE(VV.VVA_CHANGE,VVU.VVA_CHANGE,1) AS MAG_CHANGE
	FROM (
		SELECT * FROM (
			SELECT
				MOV_LEGAME AS MAG_LEGAME,
				MOV_MAGUNQ AS MAG_UNIQUE,  -- ERASMO - 18/05/2023
				SUBSTRING(MIN(MOV_DTREGI+MOV_ORAMOV),1,10) AS MAG_DATAGG,
				SUBSTRING(MIN(MOV_DTREGI+MOV_ORAMOV),11,8) AS MAG_ORACAR,
				MOV_CODMAG AS MAG_CODMAG,
				MOV_ANAART AS MAG_ANAART,
				SUM(CASE WHEN MOV_SEGNO = '+' THEN MOV_QTAMOV ELSE -1*MOV_QTAMOV END) AS MAG_GIACEN,
				0 AS MAG_QTAIMP,
				MOV_SERIAL AS MAG_SERIAL,
				MOV_CODFOR AS MAG_FORNIT
				FROM (
					SELECT
						MO.MOV_SEGNO,
						MO.MOV_LEGAME,
						MO.MOV_MAGUNQ,  -- ERASMO - 18/05/2023
						MO.MOV_DTREGI,
						MO.MOV_ORAMOV,
						MO.MOV_CODMAG,
						MO.MOV_ANAART,
						MO.MOV_QTAMOV,
						MO.MOV_SERIAL,
						MO.MOV_CODFOR
					FROM U_MAG_MO AS MO
					WHERE <<x_cond>> AND MO.MOV_SEGNO <> '' AND MO.MOV_DTREGI <= @DATAAL
				) AS MAIN
				GROUP BY 
				MOV_LEGAME,
				MOV_MAGUNQ,  -- ERASMO - 18/05/2023
				MOV_CODMAG,
				MOV_ANAART,
				MOV_SERIAL,
				MOV_CODFOR
		) AS T2
		WHERE MAG_GIACEN <> 0
	) AS T1
	LEFT OUTER JOIN PARA AS MG ON MG.CODICE = 'MAG'+T1.MAG_CODMAG
	LEFT OUTER JOIN U_ART_PR AS PR ON PR.ART_CODPRI = T1.MAG_ANAART
	LEFT OUTER JOIN PARA AS LN ON LN.CODICE = 'REP'+PR.ART_LINEA
	LEFT OUTER JOIN U_ART_AN AS AN ON AN.ART_CODPRI = PR.ART_CODPRI
	LEFT OUTER JOIN PARA AS GM ON GM.CODICE = 'GMI'+AN.ART_CODGMI
	LEFT OUTER JOIN PARA AS GM_1_3 ON GM_1_3.CODICE = 'GMI'+SUBSTRING(AN.ART_CODGMI,1,3)
	LEFT OUTER JOIN PARA AS GM_1_6 ON GM_1_6.CODICE = 'GMI'+SUBSTRING(AN.ART_CODGMI,1,6)
	OUTER APPLY (SELECT TOP 1 MOV_LEGAME, MOV_DTREGI, MOV_VALUTA, MOV_PREACQ, MOV_DTDOCU FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_LEGAME = T1.MAG_LEGAME ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MV 
	OUTER APPLY (SELECT TOP 1 MOV_LEGAME, MOV_DTREGI, MOV_VALUTA, MOV_PREACQ, MOV_DTDOCU FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_LEGAME = 
		(SELECT TOP 1 MOV_LEGAME FROM U_MAG_MO WHERE MOV_ANAART = T1.MAG_ANAART AND MOV_SEGNO = '+' AND MOV_DTREGI <= T1.MAG_DATAGG ORDER BY MOV_DTREGI DESC,MOV_ORAMOV DESC) ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MVU
	OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MV.MOV_VALUTA AND VVA_DATA <= (CASE WHEN MV.MOV_DTDOCU = '' THEN MV.MOV_DTREGI ELSE MV.MOV_DTDOCU END) ORDER BY VVA_DATA DESC) AS VV
	OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MVU.MOV_VALUTA AND VVA_DATA <= (CASE WHEN MVU.MOV_DTDOCU = '' THEN MVU.MOV_DTREGI ELSE MVU.MOV_DTDOCU END) ORDER BY VVA_DATA DESC) AS VVU

ENDTEXT
**=> ERASMO - FINE 10/03/2023

