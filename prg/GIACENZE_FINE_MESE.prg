*!*		"	MOV_CODFOR AS MAG_FORNIT," + CHR(13) + ;
*!*		"	ULT_DTSCAD AS MAG_DTSCAD," + CHR(13) + ;
*!*		"	ART_CODGMI," + CHR(13) + ;
*!*		"	DESGMI," + CHR(13) + ;
*!*		"	DESGMI_1_3," + CHR(13) + ;
*!*		"	DESGMI_1_6," + CHR(13) + ;
*!*		"	ULT_PREACQ," + CHR(13) + ;
*!*		"	ULT_FORNIT," + CHR(13) + ;
*!*		"	MEP_PREACQ," + CHR(13) + ;
*!*		"	MAG_VALUTA," + CHR(13) + ;
*!*		"	MAG_CHANGE FROM (" + CHR(13) + ;
*!*		"	SELECT" + CHR(13) + ;
*!*		"		MO.MOV_SEGNO," + CHR(13) + ;
*!*		"		MO.MOV_LEGAME," + CHR(13) + ;
*!*		"		MO.MOV_DTREGI," + CHR(13) + ;
*!*		"		MO.MOV_ORAMOV," + CHR(13) + ;
*!*		"		MO.MOV_CODMAG," + CHR(13) + ;
*!*		"		MG.DESCRI," + CHR(13) + ;
*!*		"		MO.MOV_ANAART," + CHR(13) + ;
*!*		"		PR.ART_DESCR," + CHR(13) + ;
*!*		"		PR.ART_UMMAGA," + CHR(13) + ;
*!*		"		PR.ART_PRZCOS," + CHR(13) + ;
*!*		"		PR.ART_LINEA," + CHR(13) + ;
*!*		"		COALESCE(LN.DESCRI,'') AS DESLIN," + CHR(13) + ;
*!*		"		MO.MOV_QTAMOV," + CHR(13) + ;
*!*		"		MO.MOV_SERIAL," + CHR(13) + ;
*!*		"		--MO.MOV_PREACQ," + CHR(13) + ;
*!*		"		--COALESCE(MV.MOV_PREACQ,MV.MOV_PREACQ,PR.ART_ULPCAR,0) AS MOV_PREACQ," + CHR(13) + ;
*!*		"		COALESCE(MV.MOV_PREACQ,MVU.MOV_PREACQ,0) AS MOV_PREACQ,  -- ERASMO - 28/05/2019" + CHR(13) + ;
*!*		"		MO.MOV_CODFOR," + CHR(13) + ;
*!*		"		AN.ART_CODGMI," + CHR(13) + ;
*!*		"		COALESCE(GM.DESCRI,'') AS DESGMI," + CHR(13) + ;
*!*		"		COALESCE(GM_1_3.DESCRI,'') AS DESGMI_1_3," + CHR(13) + ;
*!*		"		COALESCE(GM_1_6.DESCRI,'') AS DESGMI_1_6," + CHR(13) + ;
*!*		"		COALESCE((SELECT TOP 1 MOV_DTSCAD FROM U_MAG_MO WHERE MOV_LEGAME = MO.MOV_LEGAME AND MOV_ANAART = MO.MOV_ANAART AND MOV_DOCMOD = 0 AND MOV_DTREGI <= @DATAAL ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),'') AS ULT_DTSCAD," + CHR(13) + ;
*!*		"		--COALESCE((SELECT TOP 1 MOV_PREACQ FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_DOCMOD = 0 AND MOV_SEGNO = '+' AND MOV_PREACQ > 0 AND MOV_DTREGI <= @DATAAL ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),0) AS ULT_PREACQ," + CHR(13) + ;
*!*		"		--COALESCE((SELECT TOP 1 MOV_FORNIT FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_DOCMOD = 0 AND MOV_SEGNO = '+' AND MOV_PREACQ > 0 AND MOV_DTREGI <= @DATAAL ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),'') AS ULT_FORNIT," + CHR(13) + ;
*!*		"		COALESCE(PR.ART_ULPCAR,0) AS ULT_PREACQ," + CHR(13) + ;
*!*		"		COALESCE((SELECT TOP 1 MOV_FORNIT FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_DOCMOD = 0 AND MOV_SEGNO = '+' AND MOV_PREACQ > 0 ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC),'') AS ULT_FORNIT," + CHR(13) + ;
*!*		"		COALESCE(" + CHR(13) + ;
*!*		"			(SELECT" + CHR(13) + ;
*!*		"				CASE WHEN SOMMA_QTA > 0 THEN SOMMA_QTA_PER_PREZZO / SOMMA_QTA ELSE 0 END AS PREZZO_MEDIO_PONDERATO_GIACENZE" + CHR(13) + ;
*!*		"			 FROM (" + CHR(13) + ;
*!*		"				SELECT " + CHR(13) + ;
*!*		"					COALESCE(SUM(CASE WHEN (MOV_QTAMOV > 0 AND MOV_PREACQ > 0) THEN MOV_QTAMOV * MOV_PREACQ ELSE 0 END),0) AS SOMMA_QTA_PER_PREZZO, " + CHR(13) + ;
*!*		"					COALESCE(SUM(CASE WHEN (MOV_QTAMOV > 0 AND MOV_PREACQ > 0) THEN MOV_QTAMOV ELSE 0 END),0) AS SOMMA_QTA FROM (" + CHR(13) + ;
*!*		"						SELECT MOV_QTAMOV,MOV_PREACQ FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_PREACQ > 0 AND MOV_SEGNO = '+' AND MOV_DTREGI <= @DATAAL" + CHR(13) + ;
*!*		"					) AS MAIN" + CHR(13) + ;
*!*		"				) AS T1),0) AS MEP_PREACQ," + CHR(13) + ;
*!*		"		--COALESCE(MV.MOV_VALUTA,'') AS MAG_VALUTA, " + CHR(13) + ;
*!*		"		COALESCE(MV.MOV_VALUTA,MVU.MOV_VALUTA,'') AS MAG_VALUTA, " + CHR(13) + ;
*!*		"		--COALESCE(VV.VVA_CHANGE,1) AS MAG_CHANGE" + CHR(13) + ;
*!*		"		COALESCE(VV.VVA_CHANGE,VVU.VVA_CHANGE,1) AS MAG_CHANGE" + CHR(13) + ;
*!*		"	FROM U_MAG_MO AS MO" + CHR(13) + ;
*!*		"	LEFT OUTER JOIN U_ART_PR AS PR ON PR.ART_CODPRI = MO.MOV_ANAART" + CHR(13) + ;
*!*		"	LEFT OUTER JOIN U_ART_AN AS AN ON AN.ART_CODPRI = PR.ART_CODPRI" + CHR(13) + ;
*!*		"	LEFT OUTER JOIN PARA AS GM ON GM.CODICE = 'GMI'+AN.ART_CODGMI" + CHR(13) + ;
*!*		"	LEFT OUTER JOIN PARA AS GM_1_3 ON GM_1_3.CODICE = 'GMI'+SUBSTRING(AN.ART_CODGMI,1,3)" + CHR(13) + ;
*!*		"	LEFT OUTER JOIN PARA AS GM_1_6 ON GM_1_6.CODICE = 'GMI'+SUBSTRING(AN.ART_CODGMI,1,6)" + CHR(13) + ;
*!*		"	LEFT OUTER JOIN PARA AS MG ON MG.CODICE = 'MAG'+MO.MOV_CODMAG" + CHR(13) + ;
*!*		"	LEFT OUTER JOIN PARA AS LN ON LN.CODICE = 'REP'+PR.ART_LINEA" + CHR(13) + ;
*!*		"	OUTER APPLY (SELECT TOP 1 MOV_LEGAME, MOV_DTREGI, MOV_VALUTA, MOV_PREACQ, MOV_DTDOCU FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_LEGAME = MO.MOV_LEGAME ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MV " + CHR(13) + ;
*!*		"	--OUTER APPLY (SELECT TOP 1 MOV_LEGAME, MOV_DTREGI, MOV_VALUTA, MOV_PREACQ, MOV_DTDOCU FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_DTREGI <= MO.MOV_DTREGI ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MVU   -- ERASMO - 19/04/2019			" + CHR(13) + ;
*!*		"	OUTER APPLY (SELECT TOP 1 MOV_LEGAME, MOV_DTREGI, MOV_VALUTA, MOV_PREACQ, MOV_DTDOCU FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_LEGAME = " + CHR(13) + ;
*!*		"		(SELECT TOP 1 MOV_LEGAME FROM U_MAG_MO WHERE MOV_ANAART = MO.MOV_ANAART AND MOV_SEGNO = '+' AND MOV_DTREGI <= MO.MOV_DTREGI ORDER BY MOV_DTREGI DESC,MOV_ORAMOV DESC) ORDER BY MOV_DTREGI,MOV_ORAMOV) AS MVU   -- ERASMO - 28/05/2019 " + CHR(13) + ;
*!*		"	--OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MV.MOV_VALUTA AND VVA_DATA <= MV.MOV_DTDOCU ORDER BY VVA_DATA DESC) AS VV " + CHR(13) + ;
*!*		"	--OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MVU.MOV_VALUTA AND VVA_DATA <= MVU.MOV_DTDOCU ORDER BY VVA_DATA DESC) AS VVU " + CHR(13) + ;
*!*		"	OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MV.MOV_VALUTA AND VVA_DATA <= (CASE WHEN MV.MOV_DTDOCU = '' THEN MV.MOV_DTREGI ELSE MV.MOV_DTDOCU END) ORDER BY VVA_DATA DESC) AS VV   -- ERASMO - 19/04/2019" + CHR(13) + ;
*!*		"	OUTER APPLY (SELECT TOP 1 * FROM U_VVA_CH WHERE VVA_CODVAL = MVU.MOV_VALUTA AND VVA_DATA <= (CASE WHEN MVU.MOV_DTDOCU = '' THEN MVU.MOV_DTREGI ELSE MVU.MOV_DTDOCU END) ORDER BY VVA_DATA DESC) AS VVU   -- ERASMO - 19/04/2019" + CHR(13) + ;
*!*		"	WHERE " + x_cond + " AND MO.MOV_CODMAG = 'ZFF'  AND MO.MOV_SEGNO <> '' AND MO.MOV_DTREGI <= @DATAAL" + CHR(13) + ;
*!*		"	) AS MAIN" + CHR(13) + ;
*!*		"	GROUP BY MOV_LEGAME,MOV_CODMAG,DESCRI,MOV_ANAART,ART_DESCR,ART_UMMAGA,ART_PRZCOS,ART_LINEA,DESLIN,MOV_SERIAL,MOV_PREACQ,MOV_CODFOR,ULT_DTSCAD,ART_CODGMI,DESGMI,DESGMI_1_3,DESGMI_1_6,ULT_PREACQ,ULT_FORNIT,MEP_PREACQ,MAG_VALUTA,MAG_CHANGE"
*!*	IF !ExecCommand(cSql,cNomeCursorSql)
*!*	   return(.f.)
*!*	ENDIF

