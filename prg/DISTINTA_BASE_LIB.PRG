	WHERE WCOD = _x_DIS_CODART AND WCODSUP = _x_DIS_GRUPPO AND WDAGGANCIO = _x_DAGGANCIO AND WCHIAVE = _x_CHIAVE
	
	IF __DIS_TIPO = 'A'
	
		__DIS_ORELAV = "00000:00:00"
		__DIS_OREATT = "00000:00:00"
		__DIS_OREIMP = "00000:00:00"
		__DIS_SECIMP = 0
