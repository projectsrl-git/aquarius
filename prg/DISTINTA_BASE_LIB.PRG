**************************************************
PROCEDURE VERIFICA_E_CREA_DISTINTA_BASE
**************************************************

LPARAMETERS _CODPRI,_NO_MESSAGE,_COD_CARTA1,_COD_CARTA2

LOCAL _COD_PRODOTTO_FINITO ,_DESCRI_PRODOTTO_FINITO ,_SPESSORE ,;
	_SPESSORE_STR_CODICE ,_SPESSORE_STR_DESCRI,_TIPOGREZZO ,_TIPONOBILITATO  ,;
	_FLAG_NO_MESSAGE,_COD_GRUPPO ,_DES_GRUPPO ,_FLAG_NO_GRUPPO, _NOB_COD_CARTA1, _NOB_COD_CARTA2

_FLAG_NO_MESSAGE =.F.
IF PCOUNT() >= 2
	_FLAG_NO_MESSAGE = _NO_MESSAGE	              
ENDIF

_NOB_COD_CARTA1 = ""
_NOB_COD_CARTA2 = ""
IF PCOUNT() >= 3
	_NOB_COD_CARTA1 = _COD_CARTA1
ENDIF
IF PCOUNT() >= 4
	_NOB_COD_CARTA2 = _COD_CARTA2
ENDIF

IF CERCATIPO(_CODPRI) == '6'
ELSE
	RETURN .F.
ENDIF

_FLAG_NO_GRUPPO=.F.

Csql   = "SELECT AN.ART_TIPON, AN.ART_TIPOG,PR.ART_DESCR,PR.ART_SPESSO,PR.ART_CODPRI FROM U_ART_PR AS PR LEFT OUTER JOIN U_ART_AN AS AN ON PR.ART_CODPRI=AN.ART_CODPRI WHERE PR.ART_CODPRI='"+ALLTRIM(_CODPRI)+"'"
IF !ExecCommand(cSql,"_TEMP_ARTICOLI")
   return(.f.)
ENDIF

SELECT _TEMP_ARTICOLI
IF RECCOUNT()=0
	MESSAGEBOX("Non esiste l'articolo "+_CODPRI+CHR(13)+;
		"Non č possibile creare la distinta base in automatico",48,"Attezione")
	RETURN .F.
ENDIF

_COD_PRODOTTO_FINITO 	= ALLTRIM(ART_CODPRI)
_DESCRI_PRODOTTO_FINITO = ALLTRIM(ART_DESCR)
_SPESSORE   			= ART_SPESSO
_SPESSORE_STR_CODICE    = "-"+PADL(ALLTRIM(STR(ART_SPESSO)),2,"0")
*_SPESSORE_STR_DESCRI    = PADL(ALLTRIM(STR(ART_SPESSO)),2,"0")+"MM"
_SPESSORE_STR_DESCRI    = ALLTRIM(STR(ART_SPESSO))+" MM"
_TIPOGREZZO             = ART_TIPOG
_TIPONOBILITATO         = ART_TIPON

IF  !EMPTY(_TIPOGREZZO)

	Csql   = "SELECT TOP 1 * FROM PARA WHERE CODICE LIKE 'PRD%' AND LIBERA ='"+_TIPOGREZZO+"'"
	IF !ExecCommand(cSql,"_TEMP")
	   return(.f.)
	ENDIF
	SELECT _TEMP
	IF RECCOUNT()=0

*!*			MESSAGEBOX("Non esiste nessun gruppo produttivo abbinato al Tipo Grezzo "+_TIPOGREZZO+CHR(13)+;
*!*				"Non č possibile creare la distinta base in automatico",48,"Attezione")
*!*			RETURN .F.
		_FLAG_NO_GRUPPO=.T.
		_COD_GRUPPO 			= ALLTRIM(_TIPOGREZZO)
		_DES_GRUPPO 			= "*** ARTICOLO PRODOTTO DA TERZI: GR.PROD. NON PRESENTE ***"
	ELSE
		_SPESSORE_ORIGINALE_CODICE = "-"+PADL(DESIVA,2,"0")
		*_SPESSORE_ORIGINALE_DESCRI = PADL(DESIVA,2,"0")+"MM"
		_SPESSORE_ORIGINALE_DESCRI = ALLTRIM(DESIVA)+" MM"
		_COD_GRUPPO 			= ALLTRIM(SUBSTR(CODICE,4))
		_DES_GRUPPO 			= ALLTRIM(DESCRI)	
		_COD_GRUPPO 			= STRTRAN(_COD_GRUPPO , _SPESSORE_ORIGINALE_CODICE , _SPESSORE_STR_CODICE    )
		_DES_GRUPPO 			= STRTRAN(_DES_GRUPPO , _SPESSORE_ORIGINALE_DESCRI , _SPESSORE_STR_DESCRI    )				
	ENDIF
	
	IF _FLAG_NO_GRUPPO
	
		MESSAGEBOX("Non esiste il Gruppo Produttivo abbinato all'articolo grezzo "+_COD_PRODOTTO_FINITO +"."+CHR(13)+;
							"E' possibile solo se l'articolo in forma grezza viene prodotto da terzi."+CHR(13)+CHR(13)+;
							"La distinta base di questo articolo grezzo NON E' STATA CREATA.",48,"Creazione Di.Ba.")
		RETURN 
	ENDIF 	
		
	IF CREA_DISTINTA_BASE_GREZZO_LEVIGATO(_COD_GRUPPO, _DES_GRUPPO, _COD_PRODOTTO_FINITO,_DESCRI_PRODOTTO_FINITO)

		_COD_GRUPPO = IIF(_FLAG_NO_GRUPPO,"",ALLTRIM(_COD_GRUPPO))
			
		cSql=""     
		cNomeCursorSql="UPDATE_ARTICOLI"
		TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

			UPDATE U_ART_PR
				SET ART_CDDIBA = '<<ALLTRIM(_COD_PRODOTTO_FINITO)>>',
				ART_GRUPRD = '<<_COD_GRUPPO>>'
			WHERE ART_CODPRI = '<<ALLTRIM(_COD_PRODOTTO_FINITO)>>'

		ENDTEXT					&& FINE SCRITTURA QUERY

		IF !ExecPreparedCommand(cSql,cNomeCursorSql)
			return(.F.)
		ENDIF	
	
		IF _FLAG_NO_MESSAGE 
			WAIT WINDOW "Aggiornamento distinta base per l'articolo "+_CODPRI+" terminato correttamente" NOWAIT
		ELSE
			WAIT CLEAR
			MESSAGEBOX("Aggiornamento distinta base per l'articolo "+_CODPRI+" terminato correttamente",64,"Attezione")
		ENDIF
	ENDIF	
	
ELSE

	IF  !EMPTY(_TIPONOBILITATO)

		Csql   = "SELECT TOP 1 * FROM PARA WHERE CODICE LIKE 'PRD%' AND LIBERA ='"+_TIPONOBILITATO+"'"
		IF !ExecCommand(cSql,"_TEMP")
		   return(.f.)
		ENDIF
		SELECT _TEMP		
		IF RECCOUNT()=0
*!*				MESSAGEBOX("Non esiste nessun gruppo produttivo abbinato al Tipo Nobilitato "+_TIPONOBILITATO +CHR(13)+;
*!*					"Non č possibile creare la distinta base in automatico",48,"Attezione")
*!*				RETURN .F.
			_FLAG_NO_GRUPPO=.T.
			_COD_GRUPPO 			= ALLTRIM(_TIPONOBILITATO)
			_DES_GRUPPO 			= "*** ARTICOLO PRODOTTO DA TERZI: GR.PROD. NON PRESENTE ***"
		ELSE
			_SPESSORE_ORIGINALE_CODICE = "-"+PADL(DESIVA,2,"0")
			_SPESSORE_ORIGINALE_DESCRI = PADL(DESIVA,2,"0")+"MM"
			_COD_GRUPPO 			= ALLTRIM(SUBSTR(CODICE,4))
			_DES_GRUPPO 			= ALLTRIM(DESCRI)	
			_COD_GRUPPO 			= STRTRAN(_COD_GRUPPO , _SPESSORE_ORIGINALE_CODICE , _SPESSORE_STR_CODICE    )
			_DES_GRUPPO 			= STRTRAN(_DES_GRUPPO , _SPESSORE_ORIGINALE_DESCRI , _SPESSORE_STR_DESCRI    )							
		ENDIF
	
		IF _FLAG_NO_GRUPPO
		
			RIT = MESSAGEBOX("Non esiste il Gruppo Produttivo abbinato all'articolo nobilitato "+_COD_PRODOTTO_FINITO +"."+CHR(13)+;
								"E' possibile solo se l'articolo in forma grezza viene prodotto da terzi."+CHR(13)+CHR(13)+;
								"Proseguire nella creazione della distinta base?",292,"Creazione Di.Ba.")
			IF RIT <> 6
				RETURN 
			ENDIF 
		ENDIF 

		IF CREA_DISTINTA_BASE_NOBILITATO(_COD_GRUPPO, _DES_GRUPPO, _COD_PRODOTTO_FINITO, _DESCRI_PRODOTTO_FINITO, _NOB_COD_CARTA1, _NOB_COD_CARTA2)
	
			
			_COD_GRUPPO = IIF(_FLAG_NO_GRUPPO,"",ALLTRIM(_COD_GRUPPO))
			
			cSql=""     
			cNomeCursorSql="UPDATE_ARTICOLI"
			TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

				UPDATE U_ART_PR
					SET ART_CDDIBA = '<<ALLTRIM(_COD_PRODOTTO_FINITO)>>',
					ART_GRUPRD = '<<_COD_GRUPPO>>'
				WHERE ART_CODPRI = '<<ALLTRIM(_COD_PRODOTTO_FINITO)>>'

			ENDTEXT					&& FINE SCRITTURA QUERY

			IF !ExecPreparedCommand(cSql,cNomeCursorSql)
				return(.F.)
			ENDIF	

			IF _FLAG_NO_MESSAGE 
				WAIT WINDOW "Aggiornamento distinta base per l'articolo "+_CODPRI+" terminato correttamente" NOWAIT
			ELSE
				WAIT CLEAR
				MESSAGEBOX("Aggiornamento distinta base per l'articolo "+_CODPRI+" terminato correttamente",64,"Attezione")
			ENDIF
		ENDIF	
		
	ENDIF
ENDIF




**************************************************
PROCEDURE CREA_ARTICOLO_GRUPPO_PRODUTTIVO
**************************************************

LPARAMETERS _CODICE_GRUPPO_PRODUTTIVO,_DES_GRUPPO,_SPESSORE

LOCAL SWWS,_COD_GRUPPO , _STR_SPESSORE

SWWS=SELECT()


_STR_SPESSORE = ALLTRIM(STR(_SPESSORE))
_CODICE_GRUPPO_PRODUTTIVO=ALLTRIM(_CODICE_GRUPPO_PRODUTTIVO)

IF SUBSTR(_CODICE_GRUPPO_PRODUTTIVO,LEN(_CODICE_GRUPPO_PRODUTTIVO)-LEN(_STR_SPESSORE))="-"+_STR_SPESSORE 
	_COD_GRUPPO = _CODICE_GRUPPO_PRODUTTIVO
ELSE
	_COD_GRUPPO = _CODICE_GRUPPO_PRODUTTIVO+"-"+_STR_SPESSORE 
ENDIF

*!*	IF _COD_GRUPPO ="BEST_FSC-18"
*!*		SET STEP ON 
*!*	ENDIF

*** RICERCA TIPO GREZZO
_COD_TIPO_GREZZO = ""
Csql   = "SELECT * FROM PARA WHERE CODICE = 'PRD"+_CODICE_GRUPPO_PRODUTTIVO+"'"
IF !ExecCommand(cSql,"_TEMP")
   return(.f.)
ENDIF
SELECT _TEMP
IF !EOF()
	_COD_TIPO_GREZZO = ALLTRIM(LIBERA)
ENDIF

*** VERIFICA SE EISTE ARTICOLO GRUPPO PRODUTTIVO
cSql      = "SELECT * FROM U_ART_PR WHERE ART_CODPRI='"+_COD_GRUPPO+"'"
IF !ExecRW(cSql,"U_ART_PR","R")
	RETURN(.F.)
ENDIF

SELECT U_ART_PR

M.ART_CODSOC = PUB_CODSOC 
M.ART_CODPRI = _COD_GRUPPO
M.ART_DESCR  = _DES_GRUPPO 
M.ART_UNIMIS = "MC"
M.ART_UMMAGA = "MC"
M.ART_LINEA  = "05"
M.ART_CODIVA = "21"
M.ART_CODMAT = "008"
M.ART_MAGA   = DETERMINA_MAGAZZINO("008",_SPESSORE,"")

IF RECCOUNT()> 0
	
	REPLACE ART_CODSOC WITH  M.ART_CODSOC
	REPLACE ART_CODPRI WITH  M.ART_CODPRI 
	REPLACE ART_DESCR  WITH  M.ART_DESCR  
	REPLACE ART_UNIMIS WITH  M.ART_UNIMIS 
	REPLACE ART_UMMAGA WITH  M.ART_UMMAGA 
	REPLACE ART_LINEA  WITH  M.ART_LINEA  
	REPLACE ART_CODIVA WITH  M.ART_CODIVA 
	REPLACE ART_CODMAT WITH  M.ART_CODMAT 
	REPLACE ART_MAGA   WITH  M.ART_MAGA   
	REPLACE ART_SPESSO WITH  _SPESSORE
	REPLACE ART_GRUPRD WITH  _COD_GRUPPO
	REPLACE ART_DATVAR WITH RIBALTA2(DTOC(DATE()))
	
	IF !ExecRW(cSql,"U_ART_PR","W")
		RETURN(.F.)
	ENDIF	
	
	RETURN(.T.)
ENDIF


SELECT U_ART_PR
APPEND BLANK

	
REPLACE ART_CODSOC WITH  M.ART_CODSOC
REPLACE ART_CODPRI WITH  M.ART_CODPRI 
REPLACE ART_DESCR  WITH  M.ART_DESCR  
REPLACE ART_UNIMIS WITH  M.ART_UNIMIS 
REPLACE ART_UMMAGA WITH  M.ART_UMMAGA 
REPLACE ART_LINEA  WITH  M.ART_LINEA  
REPLACE ART_CODIVA WITH  M.ART_CODIVA 
REPLACE ART_CODMAT WITH  M.ART_CODMAT 
REPLACE ART_MAGA   WITH  M.ART_MAGA   
REPLACE ART_SPESSO WITH  _SPESSORE
REPLACE ART_GRUPRD WITH  _COD_GRUPPO
REPLACE ART_DATVAR WITH RIBALTA2(DTOC(DATE()))
REPLACE ART_DATINS WITH RIBALTA2(DTOC(DATE()))

IF !ExecRW(cSql,"U_ART_PR","W")
	RETURN(.F.)
ENDIF
	
*** CREO U_ART_AN
cSql      = "SELECT * FROM U_ART_AN  WHERE 1=0"
IF !ExecRW(cSql,"U_ART_AN","R")
	RETURN(.F.)
ENDIF

SELECT U_ART_AN
APPEND BLANK

REPLACE ART_CODSOC WITH  M.ART_CODSOC
REPLACE ART_CODPRI WITH  M.ART_CODPRI 
REPLACE ART_TIPOG  WITH  _COD_TIPO_GREZZO 

IF !ExecRW(cSql,"U_ART_AN","W")
	RETURN(.F.)
ENDIF	


SELECT(SWWS)

RETURN(.T.) 



**************************************************
PROCEDURE CREA_DISTINTA_BASE_GREZZO_DA_LEVIGARE
**************************************************
*
*	PARAMETRI:
*
*	CODICE GRUPPO PRODUTTIVO	
*	DESCRIZIONE GRUPPO PRODUTTIVO	
*	PREFISSO_PRODOTTO_FINITO: CODICE TIPO GREZZO/NOBILITATO + SPESSORE A 2 CIFRE
*
*  	ES:
*
*  	DO CREA_DISTINTA_BASE_GREZZO_DA_LEVIGARE WITH "BEST-37","TRUCIOLARE GREZZO BEST 37MM DA LEVIGARE","I18"
*
**************************************************


LPARAMETERS _COD_GRUPPO,_DES_GRUPPO,_PREFISSO_PRODOTTO_FINITO

LOCAL FLAG_DIBA_DA_FILE_EXCEL

*!*	SET STEP ON 

*** CERCO I PRODOTTI FINITI ESSTENTI PER IL GRUPPO PRODUTTIVO + SPESSORE SELEZIONATO

cSql=""     
cNomeCursorSql="PRODOTTI_FINITI"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT AN.*,PR.ART_DESCR 
	FROM U_ART_AN AS AN 
	LEFT OUTER JOIN U_ART_PR AS PR 
	ON AN.ART_CODPRI = PR.ART_CODPRI  
	WHERE AN.ART_CODPRI LIKE '<<_PREFISSO_PRODOTTO_FINITO>>%' AND LEN(RTRIM(AN.ART_CODPRI))=15 
	ORDER BY AN.ART_CODPRI

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


SELECT PRODOTTI_FINITI
GO TOP
IF RECCOUNT() = 0
	RETURN(.F.)
ENDIF
	

*** UNITA' MISURA ARTICOLO
cSql      = "SELECT * FROM U_ART_PR WHERE ART_CODPRI='"+_COD_GRUPPO+"'"
IF !ExecCommand(cSql,"_TEMP")
	RETURN(.F.)
ENDIF
SELECT _TEMP

_UMMAGA = "MC"
_MAGA   = "SEDE"
IF RECCOUNT()>0
	_UMMAGA = ART_UMMAGA 
	_MAGA   = ART_MAGA
ENDIF


*** TESTATA DISTINTA BASE
cSql      = "SELECT * FROM U_DIS_TT WHERE DIT_GRUPPO='"+_COD_GRUPPO+"'"
IF !ExecRW(cSql,"U_DIS_TT","R")
	RETURN(.F.)
ENDIF

SELECT U_DIS_TT

IF RECCOUNT() = 0
	APPEND BLANK
	REPLACE TAGGANCIO WITH SYS(2015)
	REPLACE DIT_CODSOC WITH PUB_CODSOC 
	REPLACE DIT_GRUPPO WITH _COD_GRUPPO
	REPLACE DIT_DESCRI WITH _DES_GRUPPO 
	REPLACE DIT_UM WITH _UMMAGA 
	REPLACE DIT_MAGA WITH _MAGA
	REPLACE DIT_LINEA WITH "05"
	REPLACE DIT_CODIVA WITH "21"
ENDIF

_TAGGANCIO=TAGGANCIO


IF !ExecRW(cSql,"U_DIS_TT","W")
	RETURN(.F.)
ENDIF


*** DETTAGLI DISTINTA BASE 
cSql      = "DELETE FROM U_DIS_DD WHERE DAGGANCIO='"+_TAGGANCIO+"'"
IF !ExecCommand(cSql,"_TEMP")
	RETURN(.F.)
ENDIF


*** DUPLICO UNA DISTINTA ESISTENTE CON SPESSORE DIFFERENTE

*** CERCO I PRODOTTI FINITI ESSTENTI PER IL GRUPPO PRODUTTIVO + SPESSORE SELEZIONATO

cSql=""     
cNomeCursorSql="DIBA_GRUPPO_PROD"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT 
		TT.DIT_GRUPPO AS COD_GRUPPO,
		TT.DIT_DESCRI AS DES_GRUPPO,
		DD.DIS_CODART AS CODICE,
		DD.DIS_DESCRI AS DESCRI,
		DD.DIS_MAGA   AS MAGA,
		DD.DIS_UM     AS UMMAGA,
		DD.DIS_QTA    AS QTA,
		DD.DIS_PERC   AS QTAPERC
	FROM U_DIS_DD AS DD
	LEFT OUTER JOIN U_DIS_TT AS TT
	ON DD.DAGGANCIO = TT.TAGGANCIO
	WHERE TT.DIT_GRUPPO LIKE '<<SUBSTR(_COD_GRUPPO,1,LEN(_COD_GRUPPO)-2)>>%'

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

FLAG_DIBA_DA_FILE_EXCEL=.F.

SELECT DIBA_GRUPPO_PROD
IF RECCOUNT()=0
	IF USED("GRUPPO")
		SELECT GRUPPO
		FLAG_DIBA_DA_FILE_EXCEL = .T.
	ELSE
		MESSAGEBOX("Non esistono distinte base per il gruppo produttivo "+SUBSTR(_COD_GRUPPO,1,LEN(_COD_GRUPPO)-3),48,"Attenzione")
		RETURN .F.
	ENDIF
ELSE 
*!*		SET STEP ON 
ENDIF


cSql      = "SELECT * FROM U_DIS_DD WHERE 1=0"
IF !ExecRW(cSql,"U_DIS_DD","R")
	RETURN(.F.)
ENDIF


IF FLAG_DIBA_DA_FILE_EXCEL 
	SELECT GRUPPO
ELSE
	SELECT DIBA_GRUPPO_PROD
ENDIF

GO TOP

_SEQUEN=0

_GRUPPO_DA_COPIARE=COD_GRUPPO

DO WHILE !EOF()

	IF _GRUPPO_DA_COPIARE <> COD_GRUPPO
		EXIT
	ENDIF

	_CODICE     = ALLTRIM(CODICE)
	_DESCRI 	= ALLTRIM(DESCRI)
	
	_QTA 		= QTA 
	_QTAPERC 	= QTAPERC 
	_UMMAGA 	= UMMAGA 
	_MAGA   	= MAGA	

	_SEQUEN=_SEQUEN+10
	
	SELECT U_DIS_DD
	APPEND BLANK 
	REPLACE DAGGANCIO WITH _TAGGANCIO
	REPLACE DIS_GRUPPO WITH _COD_GRUPPO
	REPLACE DIS_TIPO WITH "A"
	REPLACE DIS_CODART WITH _CODICE     
	REPLACE DIS_DESCRI WITH _DESCRI  
	
	_DISQTA =0
	
	IF FLAG_DIBA_DA_FILE_EXCEL 
	    IF _QTAPERC <>0
			_DISQTA = _QTAPERC * _KG_LEGNA 
	    ELSE
			_DISQTA =  _QTA 
	    ENDIF
		REPLACE DIS_PERC WITH _QTAPERC * 100	    
	ELSE
		_DISQTA =  _QTA 
		REPLACE DIS_PERC WITH _QTAPERC 		
	ENDIF
	

	*** CONVERSIONE UNITA' DI MISURA
	DO CASE
		CASE _UMMAGA ="T"
			_DISQTA 	= _DISQTA /1000		
		CASE _UMMAGA ="KG"
			*** NESSUNA CONVERSIONE
			_DISQTA 	= _DISQTA 
		OTHERWISE 
			*** UNITA' DI MISURA NON PREVISTA
			*** WAIT WINDOW "ATTENZIONE: UNITA' DI MISURA NON PREVISTA: "+_UMMAGA +" - ARTICOLO: "+ALLTRIM(_CODICE)
			*** NESSUNA CONVERSIONE
			_DISQTA 	= _DISQTA 			
	ENDCASE		
	
	REPLACE DIS_QTA 	WITH _DISQTA 	
   	REPLACE DIS_MAGA 	WITH _MAGA
	REPLACE DIS_UM 		WITH _UMMAGA 
	REPLACE DIS_FASELA 	WITH ""
	REPLACE DIS_SEQUEN 	WITH _SEQUEN
	
	IF FLAG_DIBA_DA_FILE_EXCEL 
		SELECT GRUPPO
	ELSE
		SELECT DIBA_GRUPPO_PROD
	ENDIF
	SKIP
ENDDO

IF FLAG_DIBA_DA_FILE_EXCEL 
	*** COMPONENTE PRESSATURA
	_SEQUEN=_SEQUEN+10

	SELECT U_DIS_DD
	APPEND BLANK 
	REPLACE DAGGANCIO WITH _TAGGANCIO
	REPLACE DIS_GRUPPO WITH _COD_GRUPPO
	REPLACE DIS_TIPO WITH "A"
	REPLACE DIS_CODART WITH "PRESSATURA"     
	REPLACE DIS_DESCRI WITH "PRESSATURA"   
	REPLACE DIS_QTA WITH 0 
	REPLACE DIS_PERC WITH 0 
	REPLACE DIS_MAGA WITH "SEDE"	
	REPLACE DIS_UM WITH "NR" 
	REPLACE DIS_FASELA WITH "PRESSA"
	REPLACE DIS_SEQUEN WITH _SEQUEN
	REPLACE DIS_ESPLOD WITH "X"
ENDIF

IF !ExecRW(cSql,"U_DIS_DD","W")
	RETURN(.F.)
ENDIF


RETURN .T.


	

**************************************************
PROCEDURE CREA_DISTINTE_BASE_GREZZI_LEVIGATI
**************************************************
*
*	PARAMETRI:
*
*	PREFISSO_PRODOTTO_FINITO: CODICE TIPO GREZZO/NOBILITATO + SPESSORE A 2 CIFRE
*
*  	ES:
*
*  	DO CREA_DISTINTE_BASE_GREZZI_LEVIGATI WITH "I18"
*
**************************************************


LPARAMETERS _PREFISSO_PRODOTTO_FINITO

LOCAL _COD_PRODOTTO_FINITO,_FINITURA ,_SCELTA 

*** CERCO I PRODOTTI FINITI ESSTENTI PER IL GRUPPO PRODUTTIVO + SPESSORE SELEZIONATO

cSql=""     
cNomeCursorSql="PRODOTTI_FINITI"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT AN.*,PR.ART_DESCR 
	FROM U_ART_AN AS AN 
	LEFT OUTER JOIN U_ART_PR AS PR 
	ON AN.ART_CODPRI = PR.ART_CODPRI  
	WHERE AN.ART_CODPRI LIKE '<<_PREFISSO_PRODOTTO_FINITO>>%' AND LEN(RTRIM(AN.ART_CODPRI))=15 
	AND AN.ART_TIPON<>'' 
	ORDER BY AN.ART_CODPRI

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


*** ELABORO I NOBILITATI
SELECT PRODOTTI_FINITI
GO TOP

DO WHILE !EOF()

*!*		IF ART_CODPRI="118A2B1X71X65A1"
*!*			SET STEP ON 
*!*		ENDIF


	***  AGGIORNA ART_GRUPRD SU PRODOTTI FINITI
	SELECT PRODOTTI_FINITI

	_COD_PRODOTTO_FINITO		=ALLTRIM(ART_CODPRI)
	_DESCRI_PRODOTTO_FINITO		=ALLTRIM(ART_DESCR)
	
	CREA_DISTINTA_BASE_NOBILITATO(_COD_GRUPPO,_DES_GRUPPO,_COD_PRODOTTO_FINITO,_DESCRI_PRODOTTO_FINITO)

	SELECT PRODOTTI_FINITI
	
	_CODPRI = ALLTRIM(ART_CODPRI)
	
	cSql=""     
	cNomeCursorSql="UPDATE_GRUPRD"
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
		UPDATE U_ART_PR SET ART_GRUPRD='<<_COD_GRUPPO>>' WHERE ART_CODPRI = '<<_CODPRI>>'
	ENDTEXT					&& FINE SCRITTURA QUERY

	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
