			__DIS_CODFOR = WCODFOR
			__DIS_DESFOR = WDESFOR
		ENDIF
		
		*** SE TIPO PRODUZIONE GRUPPO DI TESTATA E' INTERNA, RICALCOLO IL COSTO DI LAVORAZIONE INTERNA
		*** IN BASE AL PARAMETRO "Costo medio al secondo per determinaz. costi lavorazione interna"
		IF __DIT_TIPOPR = 'I' AND PUB_CSTSEC > 0
			__DIS_COSLAI = __DIS_SECIMP * PUB_CSTSEC
			__DIS_COSATT = __DIS_SECATT * PUB_CSTSEC
		ENDIF
		
		**=> ERASMO - INIZIO 01/02/2024
		*** SE FASE LAVORAZIONE DI UN GRUPPO DI TIPO LAVORAZIONE INTERNA, VERIFICO SE ESISTE IL COSTO SPECIFICO DEFINITO NEL PARAMETRO 'FASE LAVORAZIONE', CAMPO PARA.CODPGO
		IF !EMPTY(_x_DIS_FASELA) AND __DIT_TIPOPR = 'I'
			_CSTSEC_FAL = 0
			x_codi = "codice = 'FAL" + ALLTRIM(_x_DIS_FASELA) + "'"
			cSql   = "SELECT CODPGO FROM PARA WHERE " + x_codi
			IF !ExecCommand(cSql,"TMP_PARA")
