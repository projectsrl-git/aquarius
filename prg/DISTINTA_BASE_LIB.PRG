		*		__DIS_COSLAI = ART_COSLAI
		*		__DIS_COSLAE = ART_COSLAE
		*		__DIS_COSATR = ART_COSATR
		*		
		*	CASE PUB_OPZDBCOST = 2 AND ART_ULPCAR > 0	&& Rivaluta i costi rispetto al prezzo di ultimo carico in anagr. articoli (scheda MOVIMENTAZIONI)
		*		__DIS_COSMAT = ART_ULPCAR
		*		__DIS_COSLAI = 0
		*		__DIS_COSLAE = 0
		*		__DIS_COSATR = 0
		*		
		*	OTHERWISE  					&& Rivaluta i costi rispetto al prezzo standard in anagr. articoli (scheda DATI VARI / COSTI-RICAVI PRODUZIONE)
		*		__DIS_COSMAT = ART_COSMAT
		*		__DIS_COSLAI = ART_COSLAI
		*		__DIS_COSLAE = ART_COSLAE
		*		__DIS_COSATR = ART_COSATR
		*ENDCASE
	
		**=> ERASMO - INIZIO 01/10/2014
		*** SE FASE LAVORAZIONE DI UN GRUPPO DI TIPO LAVORAZIONE ESTERNA, CONSIDERO SEMPRE LA SCHEDA ARTICOLI/FORNITORE DEL CODICE PADRE (MAI IL PREZZO DI ULTIMO CARICO CHE COMPRENDEREBBE ANCHE IL COSTO MATERIALE)
		IF !EMPTY(_x_DIS_FASELA) AND __DIT_TIPOPR = 'E'
			SELECT &_nomecur_art_gruppo_testata
			__DIS_COSMAT = 0
			__DIS_COSLAI = 0
			__DIS_COSLAE = IIF(!EMPTY(ART_CODF1), ART_PRZCO1, IIF(!EMPTY(ART_CODF2), ART_PRZCO2, IIF(!EMPTY(ART_CODF3), ART_PRZCO3, IIF(!EMPTY(ART_CODF4), ART_PRZCO4, IIF(!EMPTY(ART_CODF5), ART_PRZCO5, 0)))))
			__DIS_COSATR = 0
		ELSE
			SELECT &_nomecur_articoli
			DO CASE
				CASE PUB_OPZDBCOST = 1  	&& Rivaluta i costi rispetto al prezzo standard in anagr. articoli (scheda DATI VARI / COSTI-RICAVI PRODUZIONE)				
					__DIS_COSMAT = ART_COSMAT
					__DIS_COSLAI = ART_COSLAI
					__DIS_COSLAE = ART_COSLAE
					__DIS_COSATR = ART_COSATR
					
				CASE PUB_OPZDBCOST = 2 AND ART_ULPCAR > 0	&& Rivaluta i costi rispetto al prezzo di ultimo carico in anagr. articoli (scheda MOVIMENTAZIONI)
					__DIS_COSMAT = ART_ULPCAR
					__DIS_COSLAI = 0
					__DIS_COSLAE = 0
					__DIS_COSATR = 0
					
				OTHERWISE  					&& Rivaluta i costi rispetto al prezzo standard in anagr. articoli (scheda DATI VARI / COSTI-RICAVI PRODUZIONE)
					__DIS_COSMAT = ART_COSMAT
					__DIS_COSLAI = ART_COSLAI
					__DIS_COSLAE = ART_COSLAE
					__DIS_COSATR = ART_COSATR
			ENDCASE
		ENDIF
		**=> ERASMO - FINE 01/10/2014
		
		__DIS_ORELAV = ART_ORELAV
		__DIS_OREATT = ART_OREATT
		__DIS_OREIMP = ART_OREIMP
		__DIS_SECIMP = ART_SECIMP
		__DIS_SECLAV = ART_SECLAV
		__DIS_SECATT = ART_SECATT
		
		__DIS_CODFOR = IIF(!EMPTY(ART_CODF1), ART_CODF1, IIF(!EMPTY(ART_CODF2), ART_CODF2, IIF(!EMPTY(ART_CODF3), ART_CODF3, IIF(!EMPTY(ART_CODF4), ART_CODF4, IIF(!EMPTY(ART_CODF5), ART_CODF5, "")))))
		__DIS_DESFOR = ""
		
	ELSE  && DETERMINAZIONE COSTI DA DETTAGLIO DISTINTA BASE
		SELECT &_par_nomecur
		__DIS_COSMAT = DIS_COSMAT
		__DIS_COSLAI = DIS_COSLAI
		__DIS_COSLAE = DIS_COSLAE
		__DIS_COSATR = DIS_COSATR
		
		__DIS_ORELAV = DIS_ORELAV
		__DIS_OREATT = DIS_OREATT
		__DIS_OREIMP = DIS_OREIMP
		__DIS_SECIMP = DIS_SECIMP
		__DIS_SECLAV = DIS_SECLAV
		__DIS_SECATT = DIS_SECATT
		
		__DIS_CODFOR = DIS_CODFOR
		__DIS_DESFOR = DIS_DESFOR
	ENDIF
	**=> ERASMO - FINE 08/05/2014
	
	**=> ERASMO - INIZIO 20/05/2014
	*** SE TIPO PRODUZIONE GRUPPO DI TESTATA E' INTERNA, RICALCOLO IL COSTO DI LAVORAZIONE INTERNA
	*** IN BASE AL PARAMETRO "Costo medio al secondo per determinaz. costi lavorazione interna"
	IF __DIT_TIPOPR = 'I' AND PUB_CSTSEC > 0
		__DIS_COSLAI = __DIS_SECIMP * PUB_CSTSEC
		__DIS_COSATT = __DIS_SECATT * PUB_CSTSEC  && ERASMO - 29/05/2014
	ENDIF
	**=> ERASMO - INIZIO 20/05/2014
	
	**=> ERASMO - INIZIO 27/05/2014
	*** SE ARTICOLO CON FLAG "NON VALORIZZARE" IN ANAGRAFICA, METTO A ZERO TUTTI I COSTI
	SELECT &_nomecur_articoli
	IF ART_NONVAL
		__DIS_COSMAT = 0
		__DIS_COSLAI = 0
		__DIS_COSLAE = 0
		__DIS_COSATR = 0
	ENDIF
	**=> ERASMO - FINE 27/05/2014
	
ELSE
	__DIS_TIPO = "G"
	SCAN
		DO RIVALUTA_CAMPI_U_DIS_DD WITH _nomecur_dettagli
		
		SELECT &_nomecur_dettagli

		__DIS_COSMAT = __DIS_COSMAT + (DIS_COSMAT * DIS_QTA)
		__DIS_COSLAI = __DIS_COSLAI + (DIS_COSLAI * DIS_QTA)
		__DIS_COSLAE = __DIS_COSLAE + (DIS_COSLAE * DIS_QTA)
		__DIS_COSATR = __DIS_COSATR + (DIS_COSATR * DIS_QTA)
		
		*__DIS_RICMAT = __DIS_RICMAT + (DIS_RICMAT * DIS_QTA)
		*__DIS_RICLAI = __DIS_RICLAI + (DIS_RICLAI * DIS_QTA)
		*__DIS_RICLAE = __DIS_RICLAE + (DIS_RICLAE * DIS_QTA)
		*__DIS_RICATR = __DIS_RICATR + (DIS_RICATR * DIS_QTA)
		
		*__DIS_SECLAV = __DIS_SECLAV + DIS_SECLAV
		*__DIS_SECATT = __DIS_SECATT + DIS_SECATT
		
		**=> ERASMO - INIZIO 29/05/2014
		__DIS_SECLAV = __DIS_SECLAV + (DIS_SECLAV * DIS_QTA)
		__DIS_SECATT = __DIS_SECATT + (DIS_SECATT * DIS_QTA)
		**=> ERASMO - FINE 29/05/2014
		
		**=> ERASMO - INIZIO 10/10/2013
		IF DIS_UM = 'S'
			__DIS_SECLAV = __DIS_SECLAV + DIS_QTA
		ENDIF
		**=> ERASMO - FINE 10/10/2013
	ENDSCAN
ENDIF

__DIS_COSTO  = __DIS_COSMAT + __DIS_COSLAI + __DIS_COSLAE + __DIS_COSATR 
__DIS_PREZZO = __DIS_RICMAT + __DIS_RICLAI + __DIS_RICLAE + __DIS_RICATR

__DIS_ORELAV = da_secondi_a_ore_minuti_secondi(__DIS_SECLAV)
__DIS_OREATT = da_secondi_a_ore_minuti_secondi(__DIS_SECATT)
*!*	SEC1      	 = da_ore_minuti_secondi_a_secondi(__DIS_ORELAV)
*!*	SEC2      	 = da_ore_minuti_secondi_a_secondi(__DIS_OREATT)
*!*	__DIS_SECIMP = SEC1 + SEC2
__DIS_SECIMP = __DIS_SECLAV + __DIS_SECATT 
__DIS_OREIMP = da_secondi_a_ore_minuti_secondi(__DIS_SECIMP)


**=> ERASMO - INIZIO 08/05/2014
IF !EMPTY(__DIS_CODFOR)
	x_soci = "FOR_CODSOC = '" + PUB_CODSOC + "'"
	x_codi = "FOR_CODCLI = '" + __DIS_CODFOR + "'"
	x_cond = x_soci + " and " + x_codi
	*cSql = "select FOR_RAGSOC from U_FOR_AN where " + x_cond 
	cSql = "select FOR_RAGSOC,FOR_VALUTA from U_FOR_AN where " + x_cond  && ERASMO - 01/10/2014
	IF !ExecCommand(cSql,"TMP_FOR_AN")
	   RETURN .F.
	ENDIF
	SELECT TMP_FOR_AN
	GO TOP
	IF !EOF()
		__DIS_DESFOR = FOR_RAGSOC
		**=> ERASMO - INIZIO 01/10/2014
		*** SE IL FORNITORE E' GESTITO CON UNA VALUTA DIVERSA DA QUELLA DI RIFERIMENTO, APPLICO AL PREZZO DI COSTO IL CAMBIO PIU' RECENTE
		IF UPPER(ALLTRIM(FOR_VALUTA)) <> UPPER(ALLTRIM(PUB_VALRIF))
			LOCAL cNomeCursorSql,__VALUTA__,__PREZZO_EUR
			__VALUTA__ = UPPER(ALLTRIM(FOR_VALUTA))
			__PREZZO_EUR = __DIS_COSTO
			cNomeCursorSql="U_VVA_CH_CURS"+SYS(2015)
			TEXT TO cSql NOSHOW
				SELECT 
					TOP 1 * 
				FROM 
					U_VVA_CH 
				WHERE VVA_CODVAL = '<<FOR_VALUTA>>' 
				ORDER BY VVA_DATA DESC
			ENDTEXT
			IF !ExecPreparedCommand(cSql,cNomeCursorSql)
				return(.F.)
			ENDIF
			SELECT &cNomeCursorSql
			GO TOP
			IF !EOF()
				__CAMBIO_RECENTE = VVA_CHANGE
				__PREZZO_EUR = CAMBIO(__VALUTA__,__DIS_COSTO,__CAMBIO_RECENTE,"",.F.,6)
			ELSE
				__PREZZO_EUR = 0
			ENDIF
			__DIS_COSTO = __PREZZO_EUR
		ENDIF
		**=> ERASMO - FINE 01/10/2014
	ENDIF
ELSE
	__DIS_DESFOR = ""
ENDIF
**=> ERASMO - FINE 08/05/2014

SELECT &_par_nomecur
REPLACE DIS_TIPO WITH __DIS_TIPO 
REPLACE DIS_COSMAT WITH __DIS_COSMAT 
REPLACE DIS_COSLAI WITH __DIS_COSLAI 
REPLACE DIS_COSLAE WITH __DIS_COSLAE 
REPLACE DIS_COSATR WITH __DIS_COSATR 
REPLACE DIS_COSTO WITH __DIS_COSTO 
REPLACE DIS_RICMAT WITH __DIS_RICMAT 
REPLACE DIS_RICLAI WITH __DIS_RICLAI 
REPLACE DIS_RICLAE WITH __DIS_RICLAE 
REPLACE DIS_RICATR WITH __DIS_RICATR 
REPLACE DIS_PREZZO WITH __DIS_PREZZO 

REPLACE DIS_ORELAV WITH __DIS_ORELAV 
REPLACE DIS_OREATT WITH __DIS_OREATT 
REPLACE DIS_OREIMP WITH __DIS_OREIMP 
REPLACE DIS_SECIMP WITH __DIS_SECIMP 
REPLACE DIS_SECLAV WITH __DIS_SECLAV 
REPLACE DIS_SECATT WITH __DIS_SECATT 

**=> ERASMO - INIZIO 08/05/2014
REPLACE DIS_CODFOR WITH __DIS_CODFOR
REPLACE DIS_DESFOR WITH __DIS_DESFOR
**=> ERASMO - FINE 08/05/2014

SELECT &_nomecur_dettagli
USE

SELECT &_nomecur_articoli
USE

