*!*			WORELAV = da_secondi_a_ore_minuti_secondi(WSECLAV + __DIT_SECLAV), ;
*!*			WOREATT = da_secondi_a_ore_minuti_secondi(WSECATT + __DIT_SECATT), ;
*!*			WOREIMP = da_secondi_a_ore_minuti_secondi(WSECIMP + __DIT_SECIMP) ;
*!*		WHERE WCOD = _x_DIS_GRUPPO AND WCHIAVE = _x_PARENT
	
	**=> ERASMO - INIZIO 28/11/2014
