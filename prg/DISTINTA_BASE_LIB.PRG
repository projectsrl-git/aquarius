		WCOSLAI = WCOSLAI + __DIT_COSLAI, ;
		WCOSLAE = WCOSLAE + __DIT_COSLAE, ;
		WCOSATR = WCOSATR + __DIT_COSATR, ;
		WCOS  = WCOS + __DIT_COSTO, ;
		WCOST = ROUND((WCOS * WQTA),6), ;
		WSECLAV = WSECLAV + __DIT_SECLAV, ;
		WSECATT = WSECATT + __DIT_SECATT, ;
		WSECIMP = WSECIMP + __DIT_SECIMP ;
	WHERE WCOD = _x_DIS_GRUPPO AND WCHIAVE = _x_PARENT
	
	*** CONTRAGGIORNAMENTO TEMPI IN ORE IN FORMATO STRINGA HHHHH:MM:SS SUL GRUPPO SUPERIORE SUL CURSORE PRINCIPALE DI ESPLOSIONE
	UPDATE &_par_nomecur_wexplode SET ;
		WORELAV = da_secondi_a_ore_minuti_secondi(WSECLAV), ;
		WOREATT = da_secondi_a_ore_minuti_secondi(WSECATT), ;
		WOREIMP = da_secondi_a_ore_minuti_secondi(WSECIMP) ;
	WHERE WCOD = _x_DIS_GRUPPO AND WCHIAVE = _x_PARENT
