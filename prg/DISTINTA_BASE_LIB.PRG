*****************************************
PROCEDURE CREA_CARTA_IMPREGNATA
*****************************************

LPARAMETERS _COLORE,_CODICE_PRODOTTO_FINITO

LOCAL SWWS

SWWS=SELECT()

M.ART_CODSOC = PUB_CODSOC
M.ART_SPESSO = 0
M.ART_CODMAT = "011"
M.ART_CODCAT = 'CI'
M.ART_DESCAT = 'CARTA IMPREGNATA'
M.ART_TIPON	 = ""

M.ART_UNIMIS = "MQ"
M.ART_UMMAGA = "NR"

M.ART_LINEA  = "05"
M.ART_CODIVA = PUB_IVA
M.ART_TIPART = "A" 
M.ART_DISBAS = "S" 

M.ART_CODCOL = _COLORE 
M.ART_DESCOL = ""


M.ART_DATVAR= ""
M.ART_DATINS= RIBALTA2(DTOC(DATE()))


*** DESCRIZIONE COLORE
cSql=""     
cNomeCursorSql="_TEMP"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	SELECT * FROM PARA WHERE CODICE ='COL<<_COLORE>>'
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	SELECT(SWWS)
	return(.F.)
ENDIF

SELECT _TEMP
IF RECCOUNT()>0
	M.ART_DESCOL = ALLTRIM(DESCRI)
ENDIF

M.ART_ALTEZZ= ALTEZZA_CARTA(_CODICE_PRODOTTO_FINITO)

*** MODIFICA PER ECCEZIONE PANNELLI DA 2800 IN LUNGHEZZA (LATO 1) CHE UTILIZZANO LE CARTE DA 5620 TAGLIATE A META'
IF SUBSTR(_CODICE_PRODOTTO_FINITO,5,2) == 'A4'  && LATO 1 = 2800
	M.ART_ALTEZZ = M.ART_ALTEZZ * 2
ENDIF

**=> ERASMO - INIZIO 24/02/2014
*** MODIFICA QUERY PER ECCEZIONE PANNELLI DA 2620 IN LUNGHEZZA (LATO 1) CHE UTILIZZANO LE CARTE DA 5260 TAGLIATE A META'
IF SUBSTR(_CODICE_PRODOTTO_FINITO,5,2) == 'C4'  && LATO 1 = 2620
	M.ART_ALTEZZ = M.ART_ALTEZZ * 2
ENDIF
**=> ERASMO - FINE 24/02/2014

M.ART_LUNGHE= LUNGHEZZA_CARTA(_CODICE_PRODOTTO_FINITO)

M.ART_CODCAT = "CI"
M.ART_DESCAT = "CARTA IMPREGNATA"

M.ART_MAGA  = DETERMINA_MAGAZZINO(M.ART_CODMAT,M.ART_SPESSO,M.ART_TIPON)

_X_CODICE = ""
_X_FAMIGLIA = "01"
_X_TIPO = "003"
_X_PROGRESSIVO = PROGRESSIVO_PER_FAMIGLIA_TIPO(_X_FAMIGLIA,_X_TIPO)

_X_CODICE = _X_FAMIGLIA + '.' + _X_TIPO + '.' + _X_PROGRESSIVO 

M.ART_CODPRI = _X_CODICE 

M.ART_DESCR  = M.ART_DESCOL + ALLTRIM(STR(M.ART_ALTEZZ))+"X"+ALLTRIM(STR(M.ART_LUNGHE))


*** CREO U_ART_PR
cSql      = "SELECT * FROM U_ART_PR WHERE 1=0"
IF !ExecRW(cSql,"U_ART_PR","R")
	RETURN(.F.)
ENDIF

SELECT U_ART_PR
APPEND BLANK


REPLACE ART_CODSOC WITH M.ART_CODSOC
REPLACE ART_SPESSO WITH M.ART_SPESSO 
REPLACE ART_CODMAT WITH M.ART_CODMAT 
REPLACE ART_CODCAT WITH M.ART_CODCAT 
REPLACE ART_DESCAT WITH M.ART_DESCAT 
REPLACE ART_UNIMIS WITH M.ART_UNIMIS 
REPLACE ART_UMMAGA WITH M.ART_UMMAGA 
REPLACE ART_LINEA  WITH M.ART_LINEA  
REPLACE ART_CODIVA WITH M.ART_CODIVA 
REPLACE ART_TIPART WITH M.ART_TIPART 
REPLACE ART_DISBAS WITH M.ART_DISBAS 
REPLACE ART_CODCOL WITH M.ART_CODCOL 
REPLACE ART_DESCOL WITH M.ART_DESCOL 
REPLACE ART_DATVAR WITH M.ART_DATVAR
REPLACE ART_DATINS WITH M.ART_DATINS
REPLACE ART_ALTEZZ WITH M.ART_ALTEZZ
REPLACE ART_LUNGHE WITH M.ART_LUNGHE
REPLACE ART_MAGA  WITH M.ART_MAGA  
REPLACE ART_CODPRI WITH M.ART_CODPRI 
REPLACE ART_DESCR  WITH M.ART_DESCR  


IF !ExecRW(cSql,"U_ART_PR","W")
	RETURN(.F.)
ENDIF		

*** CREO U_ART_AN
cSql      = "SELECT * FROM U_ART_AN  WHERE 1=0"
IF !ExecRW(cSql,"U_ART_AN","R")
	RETURN(.F.)
ENDIF

SELECT U_ART_AN
APPEND BLANK

REPLACE ART_CODSOC WITH M.ART_CODSOC
REPLACE ART_CODPRI WITH M.ART_CODPRI 
REPLACE ART_TIPON  WITH M.ART_TIPON

IF !ExecRW(cSql,"U_ART_AN","W")
	RETURN(.F.)
ENDIF	


SELECT(SWWS)

RETURN(.T.)




