**************************************************
PROCEDURE VERIFICA_E_CREA_DISTINTA_BASE_BG
**************************************************

LPARAMETERS _CODPRI,_NO_MESSAGE,_QTA_GAS

LOCAL _COD_PRODOTTO_FINITO,_DESCRI_PRODOTTO_FINITO

_FLAG_NO_MESSAGE = .F.
IF PCOUNT() >= 2
	_FLAG_NO_MESSAGE = _NO_MESSAGE	              
ENDIF

_DIS_QTA_GAS = 1
IF PCOUNT() >= 3
	_DIS_QTA_GAS = _QTA_GAS	              
ENDIF

IF CERCATIPO(_CODPRI) == 'B'
ELSE
	RETURN .F.
ENDIF

_FLAG_NO_GRUPPO=.F.

Csql   = "SELECT AN.ART_UMVEND,PR.ART_CODPRI,PR.ART_DESCR,PR.ART_UMMAGA,PR.ART_MAGA,PR.ART_CODIVA FROM U_ART_PR AS PR LEFT OUTER JOIN U_ART_AN AS AN ON PR.ART_CODPRI=AN.ART_CODPRI WHERE PR.ART_CODPRI='"+ALLTRIM(_CODPRI)+"'"
IF !ExecCommand(cSql,"_TEMP_ARTICOLI")
   return(.f.)
ENDIF

SELECT _TEMP_ARTICOLI
GO TOP
IF RECCOUNT()=0
	MESSAGEBOX("Non esiste l'articolo "+_CODPRI+CHR(13)+;
		"Non č possibile creare la distinta base in automatico",48,"Attezione")
	RETURN .F.
ENDIF

_COD_PRODOTTO_FINITO 	= ALLTRIM(ART_CODPRI)
_DESCRI_PRODOTTO_FINITO = ALLTRIM(ART_DESCR)
_MAGA					= ALLTRIM(ART_MAGA)
_UMMAGA 				= ALLTRIM(ART_UMMAGA)
_CODIVA					= ALLTRIM(ART_CODIVA)
_LINEA					= ALLTRIM(ART_LINEA)


*** TESTATA DISTINTA BASE
cSql = "SELECT * FROM U_DIS_TT WHERE DIT_GRUPPO='"+_COD_PRODOTTO_FINITO+"'"
IF !ExecRW(cSql,"U_DIS_TT","R")
	RETURN(.F.)
ENDIF

SELECT U_DIS_TT

*** SE ESISTE GIA' NON LA CREO
IF RECCOUNT() > 0
	RETURN .F.
ENDIF

*** SE SI TRATTA DI UN CODICE BOMBOLA VUOTA, NON CREO LA DI.BA.
_COD_BOMBOLA_PIENA = _COD_PRODOTTO_FINITO
_COD_BOMBOLA_VUOTA = SUBSTR(_COD_BOMBOLA_PIENA,1,11) + '000'

IF _COD_BOMBOLA_PIENA = _COD_BOMBOLA_VUOTA
	RETURN .F.
ENDIF

APPEND BLANK
REPLACE TAGGANCIO WITH SYS(2015)
REPLACE DIT_CODSOC WITH PUB_CODSOC 
REPLACE DIT_GRUPPO WITH _COD_PRODOTTO_FINITO
REPLACE DIT_DESCRI WITH _DESCRI_PRODOTTO_FINITO
REPLACE DIT_UM WITH _UMMAGA 
REPLACE DIT_MAGA WITH _MAGA
REPLACE DIT_LINEA WITH _LINEA
REPLACE DIT_CODIVA WITH _CODIVA

_TAGGANCIO=TAGGANCIO

IF !ExecRW(cSql,"U_DIS_TT","W")
	RETURN(.F.)
ENDIF

*** CANCELLA DETTAGLI DISTINTA BASE 
cSql = "DELETE FROM U_DIS_DD WHERE DAGGANCIO='"+_TAGGANCIO+"'"
IF !ExecCommand(cSql,"_TEMP")
	RETURN(.F.)
ENDIF



*** COMPONENTE BOMBOLA VUOTA
Csql   = "SELECT AN.ART_UMVEND,PR.ART_CODPRI,PR.ART_DESCR,PR.ART_UMMAGA,PR.ART_MAGA,PR.ART_CODIVA FROM U_ART_PR AS PR LEFT OUTER JOIN U_ART_AN AS AN ON PR.ART_CODPRI=AN.ART_CODPRI WHERE PR.ART_CODPRI='"+ALLTRIM(_COD_BOMBOLA_VUOTA)+"'"
IF !ExecCommand(cSql,"_TEMP_ART_BOMBOLA_VUOTA")
   return(.f.)
ENDIF

SELECT _TEMP_ART_BOMBOLA_VUOTA
GO TOP
IF RECCOUNT()=0
	MESSAGEBOX("Non esiste l'articolo bombola vuota "+_COD_BOMBOLA_VUOTA+CHR(13)+;
		"Non č possibile creare la distinta base in automatico",48,"Attezione")
	cSql = "DELETE FROM U_DIS_TT WHERE TAGGANCIO='"+_TAGGANCIO+"'"
	IF !ExecCommand(cSql,"_TEMP")
		RETURN(.F.)
	ENDIF
	RETURN .F.
ENDIF

_DESCRI_BOMBOLA_VUOTA	= ALLTRIM(ART_DESCR)
_UMMAGA					= ART_UMMAGA
_MAGA					= ART_MAGA

cSql = "SELECT * FROM U_DIS_DD WHERE 1=0"
IF !ExecRW(cSql,"U_DIS_DD","R")
	RETURN(.F.)
ENDIF

_SEQUEN=0

*** DETTAGLI DISTINTA BASE 
_SEQUEN=_SEQUEN+10

SELECT U_DIS_DD
APPEND BLANK 
REPLACE DAGGANCIO 	WITH _TAGGANCIO
REPLACE DIS_GRUPPO 	WITH _COD_PRODOTTO_FINITO
REPLACE DIS_TIPO 	WITH "A"
REPLACE DIS_CODART	WITH _COD_BOMBOLA_VUOTA
REPLACE DIS_DESCRI 	WITH _DESCRI_BOMBOLA_VUOTA
REPLACE DIS_QTA 	WITH 1
REPLACE DIS_PERC 	WITH 100
REPLACE DIS_MAGA 	WITH _MAGA  
REPLACE DIS_UM 		WITH _UMMAGA  
REPLACE DIS_FASELA 	WITH ""
REPLACE DIS_SEQUEN 	WITH _SEQUEN

*** COMPONENTE GAS 
_COD_GAS = SUBSTR(_COD_BOMBOLA_PIENA,2,4)

Csql   = "SELECT AN.ART_UMVEND,PR.ART_CODPRI,PR.ART_DESCR,PR.ART_UMMAGA,PR.ART_MAGA,PR.ART_CODIVA FROM U_ART_PR AS PR LEFT OUTER JOIN U_ART_AN AS AN ON PR.ART_CODPRI=AN.ART_CODPRI WHERE PR.ART_CODPRI='"+ALLTRIM(_COD_GAS)+"'"
IF !ExecCommand(cSql,"_TEMP_ART_GAS")
   return(.f.)
ENDIF

SELECT _TEMP_ART_GAS
GO TOP
IF RECCOUNT()=0
	MESSAGEBOX("Non esiste l'articolo gas "+_COD_GAS +CHR(13)+;
		"Non č possibile creare la distinta base in automatico",48,"Attezione")
	cSql = "DELETE FROM U_DIS_TT WHERE TAGGANCIO='"+_TAGGANCIO+"'"
	IF !ExecCommand(cSql,"_TEMP")
		RETURN(.F.)
	ENDIF
	RETURN .F.
ENDIF

_DESCRI_GAS	= ALLTRIM(ART_DESCR)
_UMMAGA		= ART_UMMAGA
_MAGA		= ART_MAGA

_SEQUEN=_SEQUEN+10

SELECT U_DIS_DD
APPEND BLANK 
REPLACE DAGGANCIO 	WITH _TAGGANCIO
REPLACE DIS_GRUPPO 	WITH _COD_PRODOTTO_FINITO
REPLACE DIS_TIPO 	WITH "A"
REPLACE DIS_CODART	WITH _COD_GAS
REPLACE DIS_DESCRI 	WITH _DESCRI_GAS
REPLACE DIS_QTA 	WITH _DIS_QTA_GAS
REPLACE DIS_PERC 	WITH 100
REPLACE DIS_MAGA 	WITH _MAGA  
REPLACE DIS_UM 		WITH _UMMAGA  
REPLACE DIS_FASELA 	WITH ""
REPLACE DIS_SEQUEN 	WITH _SEQUEN


*** COMPONENTE LAVORAZIONE
_SEQUEN=_SEQUEN+10
	
SELECT U_DIS_DD
APPEND BLANK 
REPLACE DAGGANCIO 	WITH _TAGGANCIO
REPLACE DIS_GRUPPO 	WITH _COD_PRODOTTO_FINITO
REPLACE DIS_TIPO 	WITH "A"
REPLACE DIS_CODART 	WITH "001"     
REPLACE DIS_DESCRI 	WITH "LAVORAZIONE"   
REPLACE DIS_QTA 	WITH 0 
REPLACE DIS_PERC 	WITH 0 
REPLACE DIS_MAGA 	WITH "SEDE"	
REPLACE DIS_UM 		WITH "NR" 
REPLACE DIS_FASELA 	WITH "001"
REPLACE DIS_SEQUEN 	WITH _SEQUEN
REPLACE DIS_ESPLOD 	WITH "X"


IF !ExecRW(cSql,"U_DIS_DD","W")
	RETURN(.F.)
ENDIF

IF _FLAG_NO_MESSAGE 
	WAIT WINDOW "Creazione distinta base per l'articolo "+_COD_PRODOTTO_FINITO+" terminato correttamente" NOWAIT
ELSE
	WAIT CLEAR
	MESSAGEBOX("Creazione distinta base per l'articolo "+_COD_PRODOTTO_FINITO+" terminato correttamente",64,"Attezione")
ENDIF

RETURN .T.
**=> ERASMO - FINE 16/05/2017
