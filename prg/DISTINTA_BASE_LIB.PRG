__DIT_RICLAI = WRICLAI 
__DIT_RICLAE = WRICLAE 
__DIT_RICATR = WRICATR 
__DIT_PREZZO = WPRZT

__DIT_ORELAV = WORELAV 
__DIT_OREATT = WOREATT 
__DIT_OREIMP = WOREIMP 
__DIT_SECIMP = WSECIMP 
__DIT_SECLAV = WSECLAV 
__DIT_SECATT = WSECATT 


SELECT &_par_nomecur
REPLACE DIT_DESCRI WITH __DIT_DESCRI
REPLACE DIT_UM WITH __DIT_UM
REPLACE DIT_MAGA WITH __DIT_MAGA
*REPLACE DIT_CODIVA WITH __DIT_CODIVA
REPLACE DIT_LINEA WITH __DIT_LINEA
REPLACE DIT_TIPOPR WITH __DIT_TIPOPR
**=> ERASMO - INIZIO 17/03/2020
IF ASCAN(A_STRU_CUR_DIS,"DIT_CODCTL",1,ALEN(A_STRU_CUR_DIS,1),1,8) > 0
	REPLACE DIT_CODCTL WITH __DIT_CODCTL
ENDIF
IF TYPE("M.DIT_CODCTL") == 'C'
	M.DIT_CODCTL = __DIT_CODCTL
ENDIF
**=> ERASMO - FINE 17/03/2020

REPLACE DIT_COSMAT WITH __DIT_COSMAT 
REPLACE DIT_COSLAI WITH __DIT_COSLAI 
REPLACE DIT_COSLAE WITH __DIT_COSLAE 
REPLACE DIT_COSATR WITH __DIT_COSATR 
REPLACE DIT_COSTO WITH __DIT_COSTO 

REPLACE DIT_RICMAT WITH __DIT_RICMAT 
REPLACE DIT_RICLAI WITH __DIT_RICLAI 
REPLACE DIT_RICLAE WITH __DIT_RICLAE 
REPLACE DIT_RICATR WITH __DIT_RICATR 
REPLACE DIT_PREZZO WITH __DIT_PREZZO 

REPLACE DIT_ORELAV WITH __DIT_ORELAV 
REPLACE DIT_OREATT WITH __DIT_OREATT 
REPLACE DIT_OREIMP WITH __DIT_OREIMP 
REPLACE DIT_SECIMP WITH __DIT_SECIMP 
REPLACE DIT_SECLAV WITH __DIT_SECLAV 
REPLACE DIT_SECATT WITH __DIT_SECATT 

TABLEUPDATE(.T.,.T.,_par_nomecur)

SELECT(_n_ACT_SEL)

ENDPROC


*************************************************************************
PROCEDURE RIVALUTA_CAMPI_U_DIS_DD
*************************************************************************
*** PROCEDURA PER RIVALUTARE TUTTI I CAMPI DI DETTAGLIO DELLE DISTINTE BASE
*** CHE DIPENDONO DA EVENTUALI DETTAGLI (COMPONENTI), ANAGRAFICA ARTICOLI
*** O DA ALTRE DI.BA. ESISTENTI
*** [VERSIONE BASATA SULLA RIVALUTAZIONE WEXPLODE DI TIPO "BOTTOM -> UP"]

LPARAMETERS _par_nomecur

IF !USED(_par_nomecur)
	RETURN
ELSE
	IF EOF()
		RETURN	
	ENDIF
ENDIF

LOCAL _n_ACT_SEL,_x_DAGGANCIO,_x_DIS_CODART,_x_DIS_GRUPPO,_x_DIS_FASELA

_n_ACT_SEL = SELECT()

SELECT &_par_nomecur

LOCAL ARRAY A_STRU_CUR_DIS_DD(1,18)
AFIELDS(A_STRU_CUR_DIS_DD)

*** CONTROLLO CHE ESISTANO ALMENO I CAMPI CHIAVE
IF ASCAN(A_STRU_CUR_DIS_DD,"DAGGANCIO",1,ALEN(A_STRU_CUR_DIS_DD,1),1,8) > 0
ELSE
	RETURN
ENDIF
IF ASCAN(A_STRU_CUR_DIS_DD,"DIS_CODART",1,ALEN(A_STRU_CUR_DIS_DD,1),1,8) > 0
ELSE
	RETURN
ENDIF
IF ASCAN(A_STRU_CUR_DIS_DD,"DIS_GRUPPO",1,ALEN(A_STRU_CUR_DIS_DD,1),1,8) > 0
ELSE
	RETURN
ENDIF

_x_DAGGANCIO = DAGGANCIO
_x_DIS_CODART = DIS_CODART
_x_DIS_GRUPPO = DIS_GRUPPO
_x_DIS_OPZCST = 1
IF ASCAN(A_STRU_CUR_DIS_DD,"DIS_OPZCST",1,ALEN(A_STRU_CUR_DIS_DD,1),1,8) > 0
	_x_DIS_OPZCST = DIS_OPZCST
ENDIF
_x_DIS_FASELA = ""
IF ASCAN(A_STRU_CUR_DIS_DD,"DIS_FASELA",1,ALEN(A_STRU_CUR_DIS_DD,1),1,8) > 0
	_x_DIS_FASELA = DIS_FASELA
ENDIF

LOCAL __DIS_DESCRI,__DIS_UM,__DIS_MAGA,__DIS_TIPOPR
__DIS_DESCRI = ""
__DIS_UM = ""
__DIS_MAGA = ""
__DIS_TIPOPR = ""

LOCAL __DIS_TIPO,__DIS_COSMAT,__DIS_COSLAI,__DIS_COSLAE,__DIS_COSATR,__DIS_COSTO,__DIS_RICMAT,__DIS_RICLAI,__DIS_RICLAE,__DIS_RICATR,__DIS_PREZZO, ;
	__DIS_ORELAV,__DIS_OREATT,__DIS_OREIMP,__DIS_SECIMP,__DIS_SECLAV,__DIS_SECATT,__DIS_CODFOR,__DIS_DESFOR,__DIT_TIPOPR,__DIS_CODCTL,__ORD_SINTE
__DIS_TIPO = ""
__DIS_COSMAT = 0
__DIS_COSLAI = 0
__DIS_COSLAE = 0
__DIS_COSATR = 0
__DIS_COSTO  = 0
__DIS_RICMAT = 0
__DIS_RICLAI = 0
__DIS_RICLAE = 0
__DIS_RICATR = 0
__DIS_PREZZO = 0
__DIS_ORELAV = "00000:00:00"
__DIS_OREATT = "00000:00:00"
__DIS_OREIMP = "00000:00:00"
__DIS_SECIMP = 0
__DIS_SECLAV = 0
__DIS_SECATT = 0
__DIS_CODFOR = ""
__DIS_DESFOR = ""
__DIT_TIPOPR = ""
__DIS_CODCTL = ""  && ERASMO - 17/03/2020
__ORD_SINTE = .F.  && ERASMO - 21/02/2022

LOCAL _lPrelevaDatiDaWexplode
_lPrelevaDatiDaWexplode = .F.

*** SE HO DEI RISULTATI NEL CURSORE WEXPLODE, ALLORA IL COMPONENTE E' ANCHE UN GRUPPO
DO ALBERO_DIBA WITH .F.,_x_DIS_CODART,128,.F.,.T.

SELECT WEXPLODE
GO TOP
SCAN
	IF WTIP = 'T'
		EXIT
	ENDIF
ENDSCAN
IF !EOF()
	__DIS_TIPO = 'G'
	_lPrelevaDatiDaWexplode = .T.
ELSE
	__DIS_TIPO = 'A'
	*** ANALIZZO IL COMPONENTE NEL SUO GRUPPO DI.BA.
	DO ALBERO_DIBA WITH .F.,_x_DIS_GRUPPO,128,.F.,.T.

	SELECT WEXPLODE
	GO TOP
	SCAN
		IF WCODSUP = _x_DIS_GRUPPO AND WCOD = _x_DIS_CODART
			EXIT
		ENDIF
	ENDSCAN
	IF !EOF()
		_lPrelevaDatiDaWexplode = .T.
	ELSE
		*** NON ESISTE ANCORA NESSUNA DI.BA. IN CUI E' PRESENTE IL COMPONENTE, QUINDI PRENDO SOLO I DATI ANAGRAFICI DIRETTAMENTE DALL'ANAGRAFICA ARTICOLI
		LOCAL _nomecur_articoli
		_nomecur_articoli = "TMP_ART_" + SYS(2015)
		x_soci = "U_ART_PR.ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "U_ART_PR.ART_CODPRI = '" + _x_DIS_CODART + "'"
		x_cond = x_soci + " and " + x_codi
		cSql = "SELECT U_ART_PR.ART_CODPRI,ART_DESCR,ART_UMMAGA,ART_MAGA,ART_CODIVA,ART_LINEA,ART_COSMAT,ART_COSLAI,ART_COSLAE,ART_COSATR," + ;
		       "ART_RICMAT,ART_RICLAI,ART_RICLAE,ART_RICATR,ART_ORELAV,ART_OREATT,ART_OREIMP,ART_SECIMP,ART_SECLAV,ART_SECATT,ART_TIPOPR," + ;
		       "ART_CODF1,ART_CODF2,ART_CODF3,ART_CODF4,ART_CODF5,ART_ULPCAR,ART_NONVAL,ART_CODCTL FROM U_ART_PR " + ;
		       "LEFT OUTER JOIN (SELECT ART_CODPRI,ART_NONVAL FROM U_ART_AN) AS U_ART_AN ON U_ART_AN.ART_CODPRI = U_ART_PR.ART_CODPRI " + ;
		       "WHERE " + x_cond
		IF !ExecCommand(cSql,_nomecur_articoli)
			RETURN .F.
		ENDIF
		SELECT &_nomecur_articoli
		GO TOP
		IF EOF()
			RETURN
		ENDIF
		__DIS_DESCRI = ART_DESCR
		__DIS_UM = ART_UMMAGA
		__DIS_MAGA = ART_MAGA
		__DIS_TIPOPR = ART_TIPOPR
		__DIS_CODCTL = ART_CODCTL  && ERASMO - 17/03/2020
		
		**=> ERASMO - INIZIO 30/01/2019
		__DIS_RICMAT = ART_RICMAT
		__DIS_RICLAI = ART_RICLAI
		__DIS_RICLAE = ART_RICLAE
		__DIS_RICATR = ART_RICATR
		__DIS_PREZZO = 0
		*** DEVE MANTENERE LA LOGICA DI COSTIFICAZIONE SULLA BASE DEI PARAMETRI AZIENDALI
		IF _x_DIS_OPZCST = 1
			SELECT &_nomecur_articoli
			DO CASE
				CASE PUB_OPZDBCOST = 1  	&& Riprendo i costi rispetto al prezzo standard in anagr. articoli (scheda DATI VARI / COSTI-RICAVI PRODUZIONE)				
					__DIS_COSMAT = ART_COSMAT
					__DIS_COSLAI = ART_COSLAI
					__DIS_COSLAE = ART_COSLAE
					__DIS_COSATR = ART_COSATR
					
				CASE PUB_OPZDBCOST = 2 AND ART_ULPCAR > 0	&& Riprendo i costi rispetto al prezzo di ultimo carico in anagr. articoli (scheda MOVIMENTAZIONI)
					__DIS_COSMAT = ART_ULPCAR
					__DIS_COSLAI = 0
					__DIS_COSLAE = 0
					__DIS_COSATR = 0
					
				OTHERWISE  					&& Riprendo i costi rispetto al prezzo standard in anagr. articoli (scheda DATI VARI / COSTI-RICAVI PRODUZIONE)
					__DIS_COSMAT = ART_COSMAT
					__DIS_COSLAI = ART_COSLAI
					__DIS_COSLAE = ART_COSLAE
					__DIS_COSATR = ART_COSATR
			ENDCASE
			__DIS_COSTO = __DIS_COSMAT + __DIS_COSLAI + __DIS_COSLAE + __DIS_COSATR 
			
			__DIS_ORELAV = ART_ORELAV
			__DIS_OREATT = ART_OREATT
			__DIS_OREIMP = ART_OREIMP
			__DIS_SECIMP = ART_SECIMP
			__DIS_SECLAV = ART_SECLAV
			__DIS_SECATT = ART_SECATT
			
			__DIS_CODFOR = IIF(!EMPTY(ART_CODF1), ART_CODF1, IIF(!EMPTY(ART_CODF2), ART_CODF2, IIF(!EMPTY(ART_CODF3), ART_CODF3, IIF(!EMPTY(ART_CODF4), ART_CODF4, IIF(!EMPTY(ART_CODF5), ART_CODF5, "")))))
			__DIS_DESFOR = ""
			IF !EMPTY(__DIS_CODFOR)
				x_soci = "FOR_CODSOC = '" + PUB_CODSOC + "'"
				x_codi = "FOR_CODCLI = '" + __DIS_CODFOR + "'"
				x_cond = x_soci + " and " + x_codi
				cSql = "select FOR_RAGSOC,FOR_VALUTA from U_FOR_AN where " + x_cond
				IF !ExecCommand(cSql,"TMP_FOR_AN")
				   RETURN .F.
				ENDIF
				SELECT TMP_FOR_AN
				GO TOP
				IF !EOF()
					__DIS_DESFOR = FOR_RAGSOC
					*** SE IL FORNITORE E' GESTITO CON UNA VALUTA DIVERSA DA QUELLA DI RIFERIMENTO, APPLICO AL PREZZO DI COSTO IL CAMBIO PIU' RECENTE
					IF UPPER(ALLTRIM(FOR_VALUTA)) <> UPPER(ALLTRIM(PUB_VALRIF))
						LOCAL cNomeCursorSql,__VALUTA__,__PREZZO_EUR
						__VALUTA__ = UPPER(ALLTRIM(FOR_VALUTA))
						__PREZZO_EUR = __DIS_COSTO
						cNomeCursorSql="U_VVA_CH_CURS"+SYS(2015)
						TEXT TO cSql NOSHOW
							SELECT 
								TOP 1 * 
							FROM 
								U_VVA_CH 
							WHERE VVA_CODVAL = '<<FOR_VALUTA>>' 
							ORDER BY VVA_DATA DESC
						ENDTEXT
						IF !ExecPreparedCommand(cSql,cNomeCursorSql)
							return(.F.)
						ENDIF
						SELECT &cNomeCursorSql
						GO TOP
						IF !EOF()
							__CAMBIO_RECENTE = VVA_CHANGE
							__PREZZO_EUR = CAMBIO(__VALUTA__,__DIS_COSTO,__CAMBIO_RECENTE,"",.F.,6)
						ELSE
							__PREZZO_EUR = 0
						ENDIF
						__DIS_COSTO = __PREZZO_EUR
					ENDIF
				ENDIF
			ELSE
				__DIS_DESFOR = ""
			ENDIF

		ENDIF
		**=> ERASMO - FINE 30/01/2019
		
		_lPrelevaDatiDaWexplode = .F.
	ENDIF
ENDIF

IF _lPrelevaDatiDaWexplode
	*** RIVALUTAZIONE CAMPI PRESENTE IN CURSORE WEXPLODE
	SELECT WEXPLODE
	__DIS_DESCRI = WDES
	__DIS_UM = WUM
	__DIS_MAGA = WMAGA
	__DIS_TIPOPR = WTIPART
	__DIS_COSMAT = WCOSMAT
	__DIS_COSLAI = WCOSLAI
	__DIS_COSLAE = WCOSLAE
	__DIS_COSATR = WCOSATR
	__DIS_COSTO  = WCOS
	__DIS_RICMAT = WRICMAT
	__DIS_RICLAI = WRICLAI
	__DIS_RICLAE = WRICLAE
	__DIS_RICATR = WRICATR
	__DIS_PREZZO = WPRZ
	__DIS_ORELAV = WORELAV
	__DIS_OREATT = WOREATT
	__DIS_OREIMP = WOREIMP
	__DIS_SECIMP = WSECIMP
	__DIS_SECLAV = WSECLAV
	__DIS_SECATT = WSECATT
	__DIS_CODFOR = WCODFOR
	__DIS_DESFOR = WDESFOR
	__DIS_CODCTL = WCODCTL  && ERASMO - 17/03/2020
	__ORD_SINTE  = WSINTE  && ERASMO - 21/02/2022
ENDIF


SELECT &_par_nomecur

REPLACE DIS_DESCRI WITH __DIS_DESCRI 
REPLACE DIS_UM WITH __DIS_UM 
REPLACE DIS_MAGA WITH __DIS_MAGA 
REPLACE DIS_TIPOPR WITH __DIS_TIPOPR 

REPLACE DIS_TIPO WITH __DIS_TIPO 
REPLACE DIS_COSMAT WITH __DIS_COSMAT 
REPLACE DIS_COSLAI WITH __DIS_COSLAI 
