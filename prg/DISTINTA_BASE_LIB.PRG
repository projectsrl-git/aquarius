						__DIS_COSMAT = ART_COSMAT
						__DIS_COSLAI = ART_COSLAI
						__DIS_COSLAE = ART_COSLAE
						__DIS_COSATR = ART_COSATR
						
					CASE PUB_OPZDBCOST = 2 AND ART_ULPCAR > 0	&& Rivaluta i costi rispetto al prezzo di ultimo carico in anagr. articoli (scheda MOVIMENTAZIONI)
						__DIS_COSMAT = ART_ULPCAR
						__DIS_COSLAI = 0
						__DIS_COSLAE = 0
						__DIS_COSATR = 0
						
					OTHERWISE  					&& Rivaluta i costi rispetto al prezzo standard in anagr. articoli (scheda DATI VARI / COSTI-RICAVI PRODUZIONE)
						__DIS_COSMAT = ART_COSMAT
						__DIS_COSLAI = ART_COSLAI
