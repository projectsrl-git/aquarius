			IF !EOF()
				__DIS_DESFOR = FOR_RAGSOC
*!*					*** SE IL FORNITORE E' GESTITO CON UNA VALUTA DIVERSA DA QUELLA DI RIFERIMENTO, APPLICO AL PREZZO DI COSTO IL CAMBIO PIU' RECENTE
*!*					IF UPPER(ALLTRIM(FOR_VALUTA)) <> UPPER(ALLTRIM(PUB_VALRIF))
*!*						LOCAL cNomeCursorSql,__VALUTA__,__PREZZO_EUR
