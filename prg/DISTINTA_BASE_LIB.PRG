		__DIS_SECATT = 0

		__DIS_CODFOR = ""
		__DIS_DESFOR = ""

		*** ACCESSO ANAGRAFICA ARTICOLI PER DETERMINAZIONE TIPO DI PRODUZIONE GRUPPO PADRE DI TESTATA E PER EVENTUALE RIVALUTAZIONE SU CODICE PADRE PER CONTO LAV. ESTERNO
		__DIT_TIPOPR = ""
		LOCAL _nomecur_art_gruppo_testata
