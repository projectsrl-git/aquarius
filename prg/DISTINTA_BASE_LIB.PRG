IF !ExecCommand(cSql,_nomecur_articoli)
	RETURN .F.
ENDIF
SELECT &_nomecur_articoli
GO TOP
IF EOF()
	RETURN
ENDIF

*** RIVALUTAZIONE CAMPO "DIT_DESCRI" DA ANAGRAFICA ARTICOLI
SELECT &_par_nomecur
IF ASCAN(A_STRU_CUR_DIS,"DIT_DESCRI",1,ALEN(A_STRU_CUR_DIS,1),1,8) > 0
	LOCAL __DIT_DESCRI 
	__DIT_DESCRI = ""
	SELECT &_nomecur_articoli
	__DIT_DESCRI = ART_DESCR
	SELECT &_par_nomecur
	REPLACE DIT_DESCRI WITH __DIT_DESCRI
ENDIF

*** RIVALUTAZIONE CAMPO "DIT_UM" DA ANAGRAFICA ARTICOLI
SELECT &_par_nomecur
IF ASCAN(A_STRU_CUR_DIS,"DIT_UM",1,ALEN(A_STRU_CUR_DIS,1),1,8) > 0
	LOCAL __DIT_UM 
	__DIT_UM = ""
	SELECT &_nomecur_articoli
	__DIT_UM = ART_UMMAGA
	SELECT &_par_nomecur
	REPLACE DIT_UM WITH __DIT_UM
ENDIF

