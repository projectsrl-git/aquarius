			__DIT_RICLAE = ART_RICLAE
			__DIT_RICATR = ART_RICATR
			__DIT_PREZZO = ART_RICMAT + ART_RICLAI + ART_RICLAE + ART_RICATR
			IF __DIT_PREZZO > 0
			ELSE
				__DIT_PREZZO = ART_PRZVEN
			ENDIF

			*** RICERCA PREZZO DI VENDITA DA EVENTUALE LISTINO
			_OLD_IVA_ESE = ""
			IF TYPE("IVA_ESE") = "C"
				_OLD_IVA_ESE = IVA_ESE
			ENDIF
			_OLD_ORD_CODCLI = ""
			IF TYPE("M.ORD_CODCLI") = "C"
				_OLD_ORD_CODCLI = M.ORD_CODCLI
			ENDIF
			_OLD_ORD_DATORD = ""
			IF TYPE("M.ORD_DATORD") = "C"
				_OLD_ORD_DATORD = M.ORD_DATORD
			ENDIF
			_OLD_ORD_CODART = ""
			IF TYPE("M.ORD_CODART") = "C"
				_OLD_ORD_CODART = M.ORD_CODART
			ENDIF
			_OLD_ORD_SC1 = 0
			IF TYPE("M.ORD_SC1") = "N"
				_OLD_ORD_SC1 = M.ORD_SC1
			ENDIF
			_OLD_ORD_SC2 = 0
			IF TYPE("M.ORD_SC2") = "N"
				_OLD_ORD_SC2 = M.ORD_SC2
			ENDIF
			_OLD_ORD_SC3 = 0
			IF TYPE("M.ORD_SC3") = "N"
				_OLD_ORD_SC3 = M.ORD_SC3
			ENDIF
			_OLD_ORD_SC4 = 0
			IF TYPE("M.ORD_SC4") = "N"
				_OLD_ORD_SC4 = M.ORD_SC4
			ENDIF
			_OLD_ORD_SC5 = 0
			IF TYPE("M.ORD_SC5") = "N"
				_OLD_ORD_SC5 = M.ORD_SC5
			ENDIF
			_OLD_ORD_PRORIG = 0
			IF TYPE("M.ORD_PRORIG") = "N"
				_OLD_ORD_PRORIG = M.ORD_PRORIG
			ENDIF
			_OLD_ORD_PREZZO = 0
			IF TYPE("M.ORD_PREZZO") = "N"
				_OLD_ORD_PREZZO = M.ORD_PREZZO
			ENDIF
			_OLD_ORD_PRZNET = 0
			IF TYPE("M.ORD_PRZNET") = "N"
				_OLD_ORD_PRZNET = M.ORD_PRZNET
			ENDIF
			_OLD_ORD_UMCLI = ""
			IF TYPE("M.ORD_UMCLI") = "C"
				_OLD_ORD_UMCLI = M.ORD_UMCLI
			ENDIF
			_OLD_ORD_ALTEZZ = 0
			IF TYPE("M.ORD_ALTEZZ") = "N"
				_OLD_ORD_ALTEZZ = M.ORD_ALTEZZ
			ENDIF
			_OLD_ORD_LUNGHE = 0
			IF TYPE("M.ORD_LUNGHE") = "N"
				_OLD_ORD_LUNGHE = M.ORD_LUNGHE
			ENDIF
			**=> ERASMO - INIZIO 12/02/2020
			_OLD_ORD_CPA = ""
			IF TYPE("M.ORD_CPA") = "C"
				_OLD_ORD_CPA = M.ORD_CPA
			ENDIF
			**=> ERASMO - FINE 12/02/2020

			IVA_ESE = ""
			M.ORD_CODCLI = ""
			M.ORD_DATORD = DTOC(DATE())
			M.ORD_CODART = _x_DIT_GRUPPO
			M.ORD_SC1 = 0
			M.ORD_SC2 = 0
			M.ORD_SC3 = 0
			M.ORD_SC4 = 0
			M.ORD_SC5 = 0
			M.ORD_PRORIG = 0
			M.ORD_PREZZO = 0
			M.ORD_UMCLI = ""
			M.ORD_ALTEZZ = 1000
			M.ORD_LUNGHE = 1
			M.ORD_CPA = ""  && ERASMO - 12/02/2020
			RELEASE TLISTIN
			PUBLIC TLISTIN
			TLISTIN = ""
			DO OK_LIST
			IF M.ORD_PREZZO > 0
				M.ORD_PRZNET = 0
				VPRE         = M.ORD_PREZZO
				VPRE         = VPRE-ROUND((VPRE*M.ORD_SC1/100),6)
				VPRE         = VPRE-ROUND((VPRE*M.ORD_SC2/100),6)
				VPRE         = VPRE-ROUND((VPRE*M.ORD_SC3/100),6)
				VPRE         = VPRE-ROUND((VPRE*M.ORD_SC4/100),6)  
				VPRE         = VPRE-ROUND((VPRE*M.ORD_SC5/100),6)  
				M.ORD_PRZNET = VPRE
				M.ORD_PRZNET = ROUND(M.ORD_PRZNET,6)
				
				__DIT_RICMAT = M.ORD_PRZNET
				__DIT_RICLAI = 0
				__DIT_RICLAE = 0
				__DIT_RICATR = 0
				__DIT_PREZZO = 0
			ENDIF
			__DIT_PREZZO = __DIT_RICMAT + __DIT_RICLAI + __DIT_RICLAE + __DIT_RICATR
			
			IVA_ESE      = _OLD_IVA_ESE   
			M.ORD_CODCLI = _OLD_ORD_CODCLI
			M.ORD_DATORD = _OLD_ORD_DATORD
			M.ORD_CODART = _OLD_ORD_CODART
			M.ORD_SC1    = _OLD_ORD_SC1   
			M.ORD_SC2    = _OLD_ORD_SC2   
			M.ORD_SC3    = _OLD_ORD_SC3   
			M.ORD_SC4    = _OLD_ORD_SC4   
			M.ORD_SC5    = _OLD_ORD_SC5   
			M.ORD_PRORIG = _OLD_ORD_PRORIG
			M.ORD_PREZZO = _OLD_ORD_PREZZO
			M.ORD_PRZNET = _OLD_ORD_PRZNET
			M.ORD_UMCLI  = _OLD_ORD_UMCLI 
			M.ORD_ALTEZZ = _OLD_ORD_ALTEZZ
			M.ORD_LUNGHE = _OLD_ORD_LUNGHE
			M.ORD_CPA    = _OLD_ORD_CPA  && ERASMO - 12/02/2020

			*** CONTRAGGIORNAMENTO RICAVI DETTAGLIO SUL CURSORE PRINCIPALE DI ESPLOSIONE
			UPDATE &_par_nomecur_wexplode SET ;
				WRICMAT = __DIT_RICMAT, ;
				WRICLAI = __DIT_RICLAI, ;
				WRICLAE = __DIT_RICLAE, ;
				WRICATR = __DIT_RICATR, ;
				WPRZ = __DIT_PREZZO, ;
				WPRZT = __DIT_PREZZO ;
			WHERE WCOD = _x_DIT_GRUPPO AND WCODSUP = "" AND WPARENT = ""
		ENDIF
	ENDIF
ENDIF
**=> ERASMO - FINE 15/11/2017

ENDPROC


*************************************************************************
PROCEDURE RIVALUTA_CAMPI_U_DIS_TT
*************************************************************************
*** PROCEDURA PER RIVALUTARE TUTTI I CAMPI DI TESTATA DELLE DISTINTE BASE
*** CHE DIPENDONO DAI DETTAGLI (COMPONENTI) O DA ALTRE DI.BA. ESISTENTI
*** [VERSIONE BASATA SULLA RIVALUTAZIONE WEXPLODE DI TIPO "BOTTOM -> UP"]

LPARAMETERS _par_nomecur

IF !USED(_par_nomecur)
	RETURN
ELSE
	IF EOF()
		RETURN	
	ENDIF
ENDIF

LOCAL _n_ACT_SEL,_x_TAGGANCIO,_x_DIT_GRUPPO

_n_ACT_SEL = SELECT()

SELECT &_par_nomecur
AFIELDS(A_STRU_CUR_DIS)

*** CONTROLLO CHE ESISTANO ALMENO I CAMPI CHIAVE
IF ASCAN(A_STRU_CUR_DIS,"TAGGANCIO",1,ALEN(A_STRU_CUR_DIS,1),1,8) > 0
ELSE
	RETURN
ENDIF
