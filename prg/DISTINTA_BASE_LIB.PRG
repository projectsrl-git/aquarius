	_par_solo_prod_interna = .F.
ENDIF
**=> ERASMO - FINE 16/10/2013

**=> ERASMO - INIZIO 18/11/2013
IF PCOUNT() >= 6
ELSE
	_par_rivaluta_campi = .T.
ENDIF
**=> ERASMO - FINE 18/11/2013

**=> ERASMO - INIZIO 25/11/2013
IF PCOUNT() >= 7
ELSE
	_par_leadtmaxt = 0
ENDIF
**=> ERASMO - FINE 25/11/2013

**=> ERASMO - INIZIO 03/06/2014
IF PCOUNT() >= 8
ELSE
	_par_sivideo = .F.
ENDIF
**=> ERASMO - FINE 03/06/2014

_crlf = CHR(13) + CHR(10)

LOCAL _nomecur,_oldPath
_nomecur = "CX_DIS_DD" + SYS(2015)
_oldPath = _pPath
_pPath = _pPath + IIF(EMPTY(_pPath),"","/") + ALLTRIM(_par_gruppo)

x_grup = "DIS_GRUPPO = '" + ALLTRIM(_par_gruppo) + "'"
x_cond = x_grup
cSql   = "SELECT U_DIS_DD.*, COALESCE(AN_GRU.ART_DESCR,'') AS ART_DESGRU, COALESCE(PA_FAL.DESCRI,'') AS DESFASELA, " + _crlf + ;
         "COALESCE(AN_COMP.ART_TIPOPR,'') AS ART_TIPOPR, COALESCE(AN_COMP.ART_MAGA,'') AS ART_MAGA, COALESCE(AN_COMP.ART_LINEA,'') AS ART_LINEA, COALESCE(AN_COMP.ART_CODCTL,'') AS ART_CODCTL, " + _crlf + ;
         "COALESCE(AN_COMP.ART_DESCR,'') AS ART_DESCR, COALESCE(AN_COMP.ART_UMMAGA,'') AS ART_UMMAGA, CAST(COALESCE(A2_COMP.ART_CHDIBA,0) AS BIT) AS ART_CHDIBA, " + _crlf + ;
         "COALESCE(AN_COMP.ART_COSMAT,0) AS ART_COSMAT, COALESCE(AN_COMP.ART_COSLAI,0) AS ART_COSLAI, COALESCE(AN_COMP.ART_COSLAE,0) AS ART_COSLAE, COALESCE(AN_COMP.ART_COSATR,0) AS ART_COSATR, COALESCE(AN_COMP.ART_ULPCAR,0) AS ART_ULPCAR, " + _crlf + ;  && ERASMO - 23/03/2015
         "COALESCE(A2_COMP.ART_LDTMST,0) AS ART_LDTMST, COALESCE(A2_COMP.ART_LDTM1,0) AS ART_LDTM1, COALESCE(A2_COMP.ART_LDTM2,0) AS ART_LDTM2, " + _crlf + ;
         "COALESCE(A2_COMP.ART_LDTM3,0) AS ART_LDTM3, COALESCE(A2_COMP.ART_LDTM4,0) AS ART_LDTM4, COALESCE(A2_COMP.ART_LDTM5,0) AS ART_LDTM5, " + _crlf + ;
         "COALESCE(PA_REP.DESCRI,'') AS ART_DESLIN, COALESCE(CHILDREN.CONTA_FIGLI,0) AS CONTA_FIGLI " + _crlf + ;  && ERASMO - 02/10/2014
         "FROM U_DIS_DD " + _crlf + ;
         "LEFT OUTER JOIN U_ART_PR AS AN_GRU ON U_DIS_DD.DIS_GRUPPO = AN_GRU.ART_CODPRI " + _crlf + ;
         "LEFT OUTER JOIN U_ART_PR AS AN_COMP ON U_DIS_DD.DIS_CODART = AN_COMP.ART_CODPRI " + _crlf + ;
         "LEFT OUTER JOIN U_ART_AN AS A2_COMP ON U_DIS_DD.DIS_CODART = A2_COMP.ART_CODPRI " + _crlf + ;
         "LEFT OUTER JOIN PARA AS PA_FAL ON 'FAL'+U_DIS_DD.DIS_FASELA = PA_FAL.CODICE " + _crlf + ;         
         "LEFT OUTER JOIN PARA AS PA_REP ON 'REP'+AN_COMP.ART_LINEA = PA_REP.CODICE " + _crlf + ;  && ERASMO - 02/10/2014
         "OUTER APPLY (SELECT COUNT(*) AS CONTA_FIGLI FROM U_DIS_DD AS CF_DIS_DD WHERE CF_DIS_DD.DIS_GRUPPO = U_DIS_DD.DIS_CODART) AS CHILDREN " + _crlf + ;  && ERASMO - 02/10/2014
         "WHERE " + x_cond + _crlf + ;
         "ORDER BY DIS_SEQUEN"
IF !ExecCommand(cSql,_nomecur)
	_pLivello = _pLivello - 1
	_pPath = _oldPath
	return(.f.)
ENDIF
SELECT &_nomecur
GO TOP
SCAN
	IF ALLTRIM(DIS_ESPLOD) == 'X'
		LOOP
	ENDIF
	
	_pProgre = _pProgre + 1
	
*!*		IF _par_rivaluta_campi  							&& ERASMO - 18/11/2013
*!*		
*!*			**=> ERASMO - INIZIO 03/06/2014
*!*			IF _par_sivideo 
*!*				WAIT WINDOWS "Rivalutazione Costi / Ricavi / Tempi articolo " + ALLTRIM(DIS_CODART) + " ..." NOWAIT
*!*			ENDIF
*!*			**=> ERASMO - FINE 03/06/2014
*!*			
*!*			DO RIVALUTA_CAMPI_U_DIS_DD WITH _nomecur
*!*		ENDIF  												&& ERASMO - 18/11/2013
	
	**=> ERASMO - INIZIO 02/10/2014
	IF _par_sivideo 
		WAIT WINDOWS "Esplosione articolo " + ALLTRIM(DIS_CODART) + " ..." NOWAIT
	ENDIF
	**=> ERASMO - INIZIO 02/10/2014
		
	LOCAL _V_CHIAVE,_V_PARENT,_V_GRUPPO,_V_DESGRU,_V_CODSUP,_V_DESSUP,_V_CODART,_V_TIPO	,_V_DESCRI,_V_COSTO,_V_PREZZO,_V_QTA,_V_EXP,_V_PERC,_V_QTACO2,_V_DES2,_V_COSLAI,_V_COSLAE, ;
		_V_COSMAT,_V_COSATR,_V_RICLAI,_V_RICLAE,_V_RICMAT,_V_RICATR,_V_ORELAV,_V_OREATT,_V_OREIMP,_V_SECIMP,_V_SECLAV,_V_SECATT,_V_EXP,_V_COMSOS,_V_FASELA,_V_SYSDD, ;
		_V_MAGA,_V_TIPART,_V_UMMAGA,_V_QTAT,_V_FITTIZ,_V_CHDIBA,_V_LINEA,_V_DLINEA,_V_CMPIMB,_V_OPZCST,_V_DAGGANCIO,_V_CODFOR,_V_DESFOR,_V_NOTE,_V_CODCTL,_V_SINTE
	
	_V_CHIAVE = SYS(2015)
	_V_PARENT = _par_parent
	
	SELECT &_nomecur
	_V_CODSUP = DIS_GRUPPO
	_V_DESSUP = ART_DESGRU
	_V_CODART = DIS_CODART
	*_V_TIPO	  = DIS_TIPO
	_V_TIPO	  = IIF(CONTA_FIGLI > 0, 'G', 'A')  && ERASMO - 02/10/2014
	_V_DESCRI = ART_DESCR
	_V_COSTO  = DIS_COSTO
	_V_PREZZO = DIS_PREZZO
	_V_QTA	  = DIS_QTA
	_V_EXP	  = DIS_ESPLOD
	_V_PERC	  = DIS_PERC
	_V_QTACO2 = DIS_QTACO2
	_V_DES2	  = DIS_DSNOCQ

	_V_COSLAI = DIS_COSLAI 
	_V_COSLAE = DIS_COSLAE 
	_V_COSMAT = DIS_COSMAT 
	_V_COSATR = DIS_COSATR 

	_V_RICLAI = DIS_RICLAI 
	_V_RICLAE = DIS_RICLAE  
	_V_RICMAT = DIS_RICMAT 
	_V_RICATR = DIS_RICATR 

	_V_ORELAV = DIS_ORELAV 
	_V_OREATT = DIS_OREATT  
	_V_OREIMP = DIS_OREIMP 

	_V_SECIMP = DIS_SECIMP 
	_V_SECLAV = DIS_SECLAV 
	_V_SECATT = DIS_SECATT 

	_V_EXP	  = DIS_ESPLOD
	_V_COMSOS = DIS_COMSOS
	_V_FASELA = DIS_FASELA
	_V_DESFAS = DESFASELA  && ERASMO - 10/10/2013

	_V_SYSDD  = DIS_SYSDD
 
	_V_MAGA	  = ART_MAGA  && ERASMO - 18/11/2013
	
	_V_TIPART = ART_TIPOPR  && ERASMO - 18/11/2013
	*_V_UMMAGA = ART_UMMAGA  && ERASMO - 18/11/2013
	_V_UMMAGA = DIS_UM  && ERASMO - 23/03/2017 - POSSIBILITA' DI ESPRIMERE IL COEFFICIENTE DI IMPIEGO IN UM DIVERSA DA QUELLA DI MAGAZZINO (AD ES. UM ACQUISTO)
	_V_QTAT   = _V_QTA * _par_qta_gruppo  && ERASMO - 16/10/2013
	_V_FITTIZ = DIS_FITTIZ  && ERASMO - 16/10/2013
	
	_V_LEADTMAX	= MAX(ART_LDTMST,ART_LDTM1,ART_LDTM2,ART_LDTM3,ART_LDTM4,ART_LDTM5)	&& ERASMO - 25/11/2013
	_V_LEADTMAXT = _V_LEADTMAX + _par_leadtmaxt 									&& ERASMO - 25/11/2013
	
	_V_CHDIBA = ART_CHDIBA  && ERASMO - 04/02/2014
	_V_LINEA = ART_LINEA    && ERASMO - 04/02/2014
	_V_DLINEA = ART_DESLIN  && ERASMO - 02/10/2014
	_V_CMPIMB = DIS_CMPIMB  && ERASMO - 04/02/2014
	
	_V_OPZCST = DIS_OPZCST		&& ERASMO - 02/10/2014
	_V_DAGGANCIO = DAGGANCIO	&& ERASMO - 02/10/2014
	_V_CODFOR = DIS_CODFOR		&& ERASMO - 02/10/2014
	_V_DESFOR = DIS_DESFOR		&& ERASMO - 02/10/2014
	
	_V_NOTE = DIS_NOTE			&& ERASMO - 01/02/2017
	
	_V_CODCTL = ALLTRIM(ART_CODCTL)  && ERASMO - 17/03/2020
	
	_V_SINTE = ORD_SINTE  && ERASMO - 21/02/2022
	
	**=> ERASMO - INIZIO 23/03/2015
	*** DEVE MANTENERE LA LOGICA DI COSTIFICAZIONE SULLA BASE DEI PARAMETRI AZIENDALI
	IF _V_OPZCST = 1
		SELECT &_nomecur
		DO CASE
			CASE PUB_OPZDBCOST = 1  	&& Riprendo i costi rispetto al prezzo standard in anagr. articoli (scheda DATI VARI / COSTI-RICAVI PRODUZIONE)				
				_V_COSMAT = ART_COSMAT
				_V_COSLAI = ART_COSLAI
				_V_COSLAE = ART_COSLAE
				_V_COSATR = ART_COSATR
				
			CASE PUB_OPZDBCOST = 2 AND ART_ULPCAR > 0	&& Riprendo i costi rispetto al prezzo di ultimo carico in anagr. articoli (scheda MOVIMENTAZIONI)
				_V_COSMAT = ART_ULPCAR
				_V_COSLAI = 0
				_V_COSLAE = 0
				_V_COSATR = 0
				
			OTHERWISE  					&& Riprendo i costi rispetto al prezzo standard in anagr. articoli (scheda DATI VARI / COSTI-RICAVI PRODUZIONE)
				_V_COSMAT = ART_COSMAT
				_V_COSLAI = ART_COSLAI
				_V_COSLAE = ART_COSLAE
				_V_COSATR = ART_COSATR
		ENDCASE
		_V_COSTO = _V_COSMAT + _V_COSLAI + _V_COSLAE + _V_COSATR 
	ENDIF
	**=> ERASMO - FINE 23/03/2015
	
	SELECT WEXPLODE
	APPEND BLANK
		
	REPLACE WCHIAVE WITH _V_CHIAVE
	REPLACE WPARENT WITH _V_PARENT

	REPLACE WGRUPPO WITH _G_GRUPPO 
	REPLACE WDESGRU WITH _G_DESCRI 

	REPLACE WCODSUP WITH _V_CODSUP
	REPLACE WDESSUP WITH _V_DESSUP
	
	REPLACE WPATH	WITH _pPath
	
	REPLACE WPROGRE	WITH _pProgre 
		
	REPLACE WCOD  WITH _V_CODART
	REPLACE WDES  WITH _V_DESCRI
	REPLACE WDES2 WITH _V_DES2
	REPLACE WCOS  WITH _V_COSTO
	REPLACE WPRZ  WITH _V_PREZZO
	REPLACE WTIP  WITH _V_TIPO
	REPLACE WLIV  WITH _pLivello
	REPLACE WQTA  WITH _V_QTA
	
	*REPLACE TREE  WITH REPLICATE('-',_pLivello) + SPACE(1) + ALLTRIM(_V_CODART)
	REPLACE TREE  WITH REPLICATE(SPACE(2),_pLivello) + "•—— " + ALLTRIM(_V_CODART)
	
	*REPLACE WQTAT WITH _V_QTA
	REPLACE WQTAT WITH _V_QTAT  && ERASMO - 16/10/2013
	
	REPLACE WCOST WITH ROUND((_V_COSTO * _V_QTA),6)
	REPLACE WPRZT WITH ROUND((_V_PREZZO * _V_QTA),6)
	REPLACE WPERC WITH _V_PERC
	REPLACE WQTACO2 WITH _V_QTACO2

	REPLACE WEXP WITH _V_EXP	 
	REPLACE WCOMSOS WITH _V_COMSOS 
	REPLACE WFASELA	WITH _V_FASELA 
	REPLACE WDESFAS	WITH _V_DESFAS  && ERASMO - 10/10/2013

	REPLACE WCOSLAI WITH _V_COSLAI 			&& COSTI DI PRODUZIONE
	REPLACE WCOSLAE WITH _V_COSLAE 
	REPLACE WCOSMAT WITH _V_COSMAT 
	REPLACE WCOSATR WITH _V_COSATR 

	REPLACE WRICLAI WITH _V_RICLAI 			&& RICAVI DI PRODUZIONE 
	REPLACE WRICLAE WITH _V_RICLAE  
	REPLACE WRICMAT WITH _V_RICMAT 
	REPLACE WRICATR WITH _V_RICATR 
	
	REPLACE WORELAV WITH _V_ORELAV 			&& TEMPI DI PRODUZIONE 
	REPLACE WOREATT WITH _V_OREATT  
	REPLACE WOREIMP WITH _V_OREIMP 

	REPLACE WSECIMP WITH _V_SECIMP 			&& TEMPI IN SECONDI DI PRODUZIONE 
	REPLACE WSECLAV WITH _V_SECLAV 
	REPLACE WSECATT WITH _V_SECATT 

	REPLACE WSYSDD  WITH _V_SYSDD

	REPLACE WMAGA	WITH _V_MAGA
	
	**=> ERASMO - INIZIO 16/10/2013
	REPLACE WTIPART  WITH _V_TIPART
	REPLACE WDESTIPA WITH IIF(WTIPART = 'I',"INTERNO",IIF(WTIPART = 'E',"ESTERNO",""))
	REPLACE WUM      WITH _V_UMMAGA
	REPLACE WFITTIZ  WITH _V_FITTIZ
	
	REPLACE WLEADTMAX WITH _V_LEADTMAX		&& ERASMO - 25/11/2013
	REPLACE WLEADTMAXT WITH _V_LEADTMAXT  	&& ERASMO - 25/11/2013
	
	REPLACE WCHDIBA WITH _V_CHDIBA		&& ERASMO - 04/02/2014
	REPLACE WLINEA WITH _V_LINEA 		&& ERASMO - 04/02/2014
	REPLACE WDLINEA WITH _V_DLINEA		&& ERASMO - 02/10/2014
	REPLACE WCMPIMB WITH _V_CMPIMB 		&& ERASMO - 04/02/2014
	
	REPLACE WOPZCST WITH _V_OPZCST			&& ERASMO - 02/10/2014
	REPLACE WDAGGANCIO WITH _V_DAGGANCIO	&& ERASMO - 02/10/2014
	REPLACE WCODFOR WITH _V_CODFOR			&& ERASMO - 02/10/2014
	REPLACE WDESFOR WITH _V_DESFOR			&& ERASMO - 02/10/2014
	
	REPLACE WNOTE WITH _V_NOTE 				&& ERASMO - 01/02/2017
	
	REPLACE WCODCTL WITH _V_CODCTL  && ERASMO - 17/03/2020
	
	REPLACE WSINTE WITH _V_SINTE  && ERASMO - 21/02/2022
	
	IF _par_solo_prod_interna
		IF _V_TIPO = 'G' AND _V_TIPART = 'E'
			SELECT &_nomecur
			LOOP
		ENDIF
	ENDIF
		
	*DO livello_successivo_diba WITH _V_CODART,_V_QTAT,_V_CHIAVE,_par_nlivmax,_par_solo_prod_interna
	DO livello_successivo_diba WITH _V_CODART,_V_QTAT,_V_CHIAVE,_par_nlivmax,_par_solo_prod_interna,_par_rivaluta_campi,_V_LEADTMAXT  && ERASMO - 25/11/2013
	**=> ERASMO - FINE 16/10/2013
	
	*DO livello_successivo_diba WITH _V_CODART,_V_CHIAVE,_par_nlivmax	
	SELECT &_nomecur
	
ENDSCAN

SELECT &_nomecur
USE

_pLivello = _pLivello - 1

_pPath = _oldPath

ENDPROC


********************************************************************************
PROCEDURE WHERE_USED_DIBA
********************************************************************************
LPARAMETERS _par_sivideo,_par_gruppo,_par_opzliv,_par_opzcsttmp,_par_groupfilter

IF PCOUNT() >= 1
ELSE
	RETURN .F.
ENDIF

IF PCOUNT() >= 2
ELSE
	RETURN .F.
ENDIF

IF PCOUNT() >= 3
ELSE
	_par_opzliv = .F.
ENDIF

IF PCOUNT() >= 4
ELSE
	_par_opzcsttmp = .F.
ENDIF

IF PCOUNT() >= 4
ELSE
	_par_groupfilter = ""
ENDIF

___VERIFICA_ESISTENZA_COMPONENTI = .F.

*WAIT WINDOWS "Ricerca in corso..." NOWAIT

_nLivello = 1
x_cond = "U_DIS_DD.DIS_CODART = '" + ALLTRIM(_par_gruppo) + "'"
*!*	CSQL   = "SELECT SPACE(16) AS ROOT, SPACE(254) AS PATH, SPACE(110) AS PATH_B64, CAST('' AS TEXT) AS ALLPATHS, CAST(" + ALLTRIM(STR(_nLivello,10,0)) + " AS INT) AS LIVELLO, U_DIS_DD.*, U_DIS_TT.DIT_DESCRI AS DIS_DESGRU FROM U_DIS_DD " + ;
*!*	         "INNER JOIN U_DIS_TT ON U_DIS_TT.TAGGANCIO = U_DIS_DD.DAGGANCIO " + ;
*!*	         "WHERE " + x_cond + " ORDER BY DIS_GRUPPO, DIS_SEQUEN"
**=> ERASMO - INIZIO 11/11/2015         
CSQL   = "SELECT SPACE(30) AS ROOT, SPACE(254) AS PATH, SPACE(110) AS PATH_B64, CAST('' AS TEXT) AS ALLPATHS, CAST(" + ALLTRIM(STR(_nLivello,10,0)) + " AS INT) AS LIVELLO, U_DIS_DD.*, ART_DD.ART_DESCR, ART_TT.ART_DESCR AS DIS_DESGRU FROM U_DIS_DD " + ;
         "INNER JOIN U_DIS_TT ON U_DIS_TT.TAGGANCIO = U_DIS_DD.DAGGANCIO " + ;
         "LEFT OUTER JOIN U_ART_PR AS ART_TT ON U_DIS_TT.DIT_GRUPPO = ART_TT.ART_CODPRI " + ;
         "LEFT OUTER JOIN U_ART_PR AS ART_DD ON U_DIS_DD.DIS_CODART = ART_DD.ART_CODPRI " + ;
         "WHERE " + x_cond + " ORDER BY DIS_GRUPPO, DIS_SEQUEN"
**=> ERASMO - FINE 11/11/2015
IF !ExecCommand(cSql,"__CU_DIS_DD__")
   RETURN .F.
ENDIF
SELECT __CU_DIS_DD__
GO TOP
IF !EOF()
	___VERIFICA_ESISTENZA_COMPONENTI = .T.
ENDIF

IF !___VERIFICA_ESISTENZA_COMPONENTI 
   RIT = MESSAGEBOX("Articolo " + ALLTRIM(_par_gruppo) + " non presente nelle distinte base",62,"ATTENZIONE")
   RETURN    
ENDIF

SELECT __CU_DIS_DD__
GO TOP
SCAN
	REPLACE DIS_DESCRI WITH ART_DESCR  && ERASMO - 11/11/2015
	REPLACE ROOT WITH DIS_GRUPPO
	REPLACE PATH WITH '*'+ALLTRIM(_par_gruppo)+'*' + " >> " + '*'+ALLTRIM(DIS_GRUPPO)+'*'
	REPLACE PATH_B64 WITH STRCONV(PATH,14)  && ERASMO - 13/03/2015
ENDSCAN
GO TOP

IF _par_opzliv
	WAIT WINDOWS "Ricerca ricorsiva su piů livelli in corso..." NOWAIT
	SELECT * FROM __CU_DIS_DD__ INTO CURSOR __CU_DIS_DD__TMP
	SELECT __CU_DIS_DD__TMP
	GO TOP
	SCAN
		_AllPaths = ""
		_Root = ROOT
		DO WHERE_USED_DIBA_LIVELLO_SUPERIORE WITH ALLTRIM(DIS_GRUPPO),ROOT,PATH
		UPDATE __CU_DIS_DD__ SET ALLPATHS = _AllPaths WHERE ALLTRIM(ROOT) = ALLTRIM(_Root)
	ENDSCAN
	SELECT __CU_DIS_DD__TMP
	USE
ENDIF

*** OPZIONE "Filtra per derivazione da un solo gruppo di.ba."
IF !EMPTY(_par_groupfilter)
	SELECT __CU_DIS_DD__
	GO TOP
	SCAN
		IF '*'+ALLTRIM(_par_groupfilter)+'*' $ ALLTRIM(ALLPATHS)
		ELSE
			DELETE
		ENDIF
	ENDSCAN
ENDIF

SELECT __CU_DIS_DD__

IF  _par_opzcsttmp
	GO TOP
	SCAN
		WAIT WINDOWS "Rivalutazione costi e tempi in corso (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT
		DO RIVALUTA_CAMPI_U_DIS_DD WITH "__CU_DIS_DD__"
	ENDSCAN
	GO TOP
ENDIF
WAIT CLEAR

SELECT __CU_DIS_DD__
INDEX ON ROOT+STR(LIVELLO,10,0) TAG D_ROOTLIV DESCENDING ADDITIVE
INDEX ON STR(LIVELLO,10,0) TAG D_LIV ADDITIVE
INDEX ON PATH_B64 TAG I_PATH_B64 ADDITIVE  && ERASMO - 13/03/2015
*SET ORDER TO D_ROOTLIV 
SET ORDER TO I_PATH_B64  && ERASMO - 13/03/2015
GO TOP
IF EOF()
	MESSAGEBOX("Nessun gruppo da visualizzare per i filtri digitati",64,"Informazione")
	RETURN .F.
ENDIF

IF _par_sivideo
	GRUPPO_DISTINTA					= _par_gruppo
	SELEZIONA_ESPOSIZIONE_COLONNE	= 1
	CURSORE_DA_VISUALIZZARE 		= "__CU_DIS_DD__"
	IF _par_opzcsttmp
		DO FORM FORM\DISDOVE_CSTTMP WITH GRUPPO_DISTINTA,SELEZIONA_ESPOSIZIONE_COLONNE,CURSORE_DA_VISUALIZZARE LINKED
	ELSE
    	*SELECT __CU_DIS_DD__
	    *SET ORDER TO D_LIV
	    *GO TOP
		DO FORM FORM\DISDOVE WITH GRUPPO_DISTINTA,SELEZIONA_ESPOSIZIONE_COLONNE,CURSORE_DA_VISUALIZZARE LINKED
	ENDIF
ENDIF

ENDPROC


*******************************************
PROCEDURE WHERE_USED_DIBA_LIVELLO_SUPERIORE
*******************************************
LPARAMETERS _par_gruppo,_par_root,_par_path

LOCAL _cNomeCurs
_cNomeCurs = "CX_DIS_DD" + SYS(2015)

_nLivello = _nLivello + 1
x_cond = "U_DIS_DD.DIS_CODART = '" + ALLTRIM(_par_gruppo) + "'"
*!*	CSQL   = "SELECT CAST(" + ALLTRIM(STR(_nLivello,10,0)) + " AS INT) AS LIVELLO, U_DIS_DD.*, U_DIS_TT.DIT_DESCRI AS DIS_DESGRU FROM U_DIS_DD " + ;
*!*	         "INNER JOIN U_DIS_TT ON U_DIS_TT.TAGGANCIO = U_DIS_DD.DAGGANCIO " + ;
*!*	         "WHERE " + x_cond + " ORDER BY DIS_GRUPPO, DIS_SEQUEN"
**=> ERASMO - INIZIO 11/11/2015
*CSQL   = "SELECT CAST(" + ALLTRIM(STR(_nLivello,10,0)) + " AS INT) AS LIVELLO, U_DIS_DD.*, ART_DD.ART_DESCR, ART_TT.ART_DESCR AS DIS_DESGRU FROM U_DIS_DD " + 
CSQL   = "SELECT CAST(" + ALLTRIM(STR(_nLivello,10,0)) + " AS INT) AS LIVELLO, U_DIS_DD.*, ART_DD.ART_DESCR AS DIS_DESART, ART_TT.ART_DESCR AS DIS_DESGRU FROM U_DIS_DD " + ;  && ERASMO - 02/11/2017
         "INNER JOIN U_DIS_TT ON U_DIS_TT.TAGGANCIO = U_DIS_DD.DAGGANCIO " + ;
         "LEFT OUTER JOIN U_ART_PR AS ART_TT ON U_DIS_TT.DIT_GRUPPO = ART_TT.ART_CODPRI " + ;
         "LEFT OUTER JOIN U_ART_PR AS ART_DD ON U_DIS_DD.DIS_CODART = ART_DD.ART_CODPRI " + ;
         "WHERE " + x_cond + " ORDER BY DIS_GRUPPO, DIS_SEQUEN"
**=> ERASMO - FINE 11/11/2015
IF !ExecCommand(cSql,_cNomeCurs)
   RETURN .F.
ENDIF
SELECT &_cNomeCurs
GO TOP
SCAN
	SCATTER MEMVAR MEMO
	
	*M.DIS_DESCRI = M.ART_DESCR  && ERASMO - 11/11/2015
	M.DIS_DESCRI = M.DIS_DESART  && ERASMO - 02/11/2017
	
	SELECT __CU_DIS_DD__
	APPEND BLANK
	GATHER MEMVAR MEMO
	
	REPLACE ROOT WITH _par_root

	LOCAL _path
	_path = ALLTRIM(_par_path) + " >> " + '*'+ALLTRIM(DIS_GRUPPO)+'*'
	REPLACE PATH WITH _path
	REPLACE PATH_B64 WITH STRCONV(PATH,14)  && ERASMO - 13/03/2015
	
	DO WHERE_USED_DIBA_LIVELLO_SUPERIORE WITH ALLTRIM(M.DIS_GRUPPO),_par_root,PATH
	
	IF ALLTRIM(_path) $ _AllPaths
	ELSE
		_AllPaths = _AllPaths + CHR(13) + ALLTRIM(_path)
	ENDIF
ENDSCAN

SELECT &_cNomeCurs
USE

_nLivello = _nLivello - 1

ENDPROC

***********************************************************
FUNCTION ELIMINA_DISTINTA_BASE_CON_TUTTI_I_GRUPPI_INTERNI
***********************************************************
LPARAMETERS __CODICE_DISTINTA_BASE 


AABBSS_db    = SELECT()

LOCAL _Tagga_diba
_Tagga_diba = ""


WAIT WINDOWS "Eliminazione distinta base gruppo " + ALLTRIM(__CODICE_DISTINTA_BASE) + " in corso, attendere prego ....." nowait

*** LANCIO LA CREAZIONE DELL'ALBERO DI.BA. SPECIFICANDO DI NON RIVALUTARE I CAMPI (DESCRIZIONI / COSTI / RICAVI / TEMPI ETC..)
DO ALBERO_DIBA WITH .F.,__CODICE_DISTINTA_BASE,128,.F.,.F.


**-- cancella tutti i gruppi della contenuti nella distinta

SELECT WEXPLODE
SET FILTER TO WTIP = 'T' OR WTIP = 'G'
*!*	INDEX ON WLIV TAG D_WLIV DESCENDING ADDITIVE
*!*	SET ORDER TO D_WLIV 
*!*	BROWSE FIELDS WCOD,WTIP,WLIV,WDES
GO TOP

DO WHILE .not.eof()

	SCATTER MEMVAR MEMO

	x_soci = "dit_codsoc = '" + PUB_CODSOC + "'"
	x_grup = "dit_gruppo = '" + M.WCOD + "'"
	x_cond = x_soci + " and " + x_grup
	cSql = "select * from u_dis_tt where " + x_cond + " order by dit_codsoc,dit_gruppo"
	IF !ExecRW(cSql,"U_DIS_TT","R")
	   RETURN .F.
	ENDIF
	SELECT U_DIS_TT
	GO TOP
	IF !EOF()
	   =SCRIVI_LOG_DELETED("U_DIS_TT",TAGGANCIO,DIT_GRUPPO)  && ERASMO - 19/07/2024
	   DELETE
	ENDIF
	IF !ExecRW(cSql,"U_DIS_TT","W")
	   RETURN .F.
	ENDIF

	** CANCELLO I DETTAGLI

	x_cond = "dis_gruppo = '" + M.WCOD + "'"
	cSql = "select * from u_dis_dd where " + x_cond + " order by dis_gruppo"
	IF !ExecRW(cSql,"U_DIS_DD","R")
	   RETURN .F.
	ENDIF
	SELECT U_DIS_DD
	GO TOP
	IF !EOF()
	   DO WHILE .T.
	      IF EOF()
	         EXIT
	      ENDIF
		  IF DELETED()
	  		 SKIP +1
			 LOOP
		  ENDIF
		  DELETE
		  SKIP +1
	   ENDDO    
	ELSE
	   *WAIT WINDOW "Dettagli distinta base non cancellati"      
	ENDIF
	IF !ExecRW(cSql,"U_DIS_DD","W")
	   RETURN .F.
	ENDIF
	

	SELECT WEXPLODE
	SKIP +1
	
ENDDO 

**-- cancella gli articoli rimanenti del primo livello e la testata della distinta
_Tagga_diba = ""
x_soci = "dit_codsoc = '" + PUB_CODSOC + "'"
x_grup = "dit_gruppo = '" + __CODICE_DISTINTA_BASE + "'"
x_cond = x_soci + " and " + x_grup
cSql = "select * from u_dis_tt where " + x_cond + " order by dit_codsoc,dit_gruppo"
IF !ExecRW(cSql,"U_DIS_TT","R")
   RETURN .F.
ENDIF
SELECT U_DIS_TT
GO TOP
IF !EOF()
   _Tagga_diba = TAGGANCIO
   DELETE
ELSE
   *WAIT WINDOW "Testata distinta base non cancellata"
ENDIF
IF !ExecRW(cSql,"U_DIS_TT","W")
   RETURN .F.
ENDIF

** CANCELLO I DETTAGLI

x_cond = "daggancio = '" + _Tagga_diba + "'"
cSql = "select * from u_dis_dd where " + x_cond + " order by daggancio"
IF !ExecRW(cSql,"U_DIS_DD","R")
   RETURN .F.
ENDIF
SELECT U_DIS_DD
GO TOP
IF !EOF()
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
	  IF DELETED()
  		 SKIP +1
		 LOOP
	  ENDIF
	  DELETE
	  SKIP +1
   ENDDO    
ELSE
   *WAIT WINDOW "Dettagli distinta base non cancellati"      
ENDIF
IF !ExecRW(cSql,"U_DIS_DD","W")
   RETURN .F.
ENDIF

SELECT(AABBSS_db)

WAIT CLEAR

RETURN .T.



**=> ERASMO - INIZIO 02/10/2014
************************************************************************************************************
PROCEDURE ALBERO_DIBA
************************************************************************************************************
LPARAMETERS _par_sivideo,_par_gruppo,_par_nlivmax,_par_solo_prod_interna,_par_rivaluta_campi,_par_opzliv_riv

IF PCOUNT() >= 2
ELSE
	RETURN .F.
ENDIF

IF PCOUNT() >= 3
ELSE
	_par_nlivmax = 128  && NUMERO MASSIMO DI RICHIAMI RICORSIVI NIDIFICATI SUPPORTATI IN VFP9
ENDIF

IF _par_nlivmax < 1
	_par_nlivmax = 1
ENDIF

IF _par_nlivmax > 128
	_par_nlivmax = 128
ENDIF

IF PCOUNT() >= 4
ELSE
	_par_solo_prod_interna = .F.
ENDIF

IF PCOUNT() >= 5
ELSE
	_par_rivaluta_campi = .T.
ENDIF

**=> ERASMO - INIZIO 23/03/2015
IF PCOUNT() >= 6
ELSE
	_par_opzliv_riv = .F.
ENDIF
**=> ERASMO - FINE 23/03/2015

IF _par_sivideo
	WAIT WINDOWS "Esplosione distinta base in corso..." NOWAIT
ENDIF

LOCAL _SEC_INI,_SEC_FIN
_SEC_INI = SECONDS()

DO DEFINISCE_WEXPLODE  && DEFINISCE IL CURSORE PER L'ESPLOSIONE DELLA DISTINTA BASE

LOCAL _cNomeCur_U_DIS_TT,_crlf
_cNomeCur_U_DIS_TT = "TMP_DIS_TT" + SYS(2015)
_crlf = CHR(13) + CHR(10)
x_grup = "U_DIS_TT.DIT_GRUPPO = '" + ALLTRIM(_par_gruppo) + "'"
x_cond = x_grup
cSql   = "SELECT U_DIS_TT.*, " + _crlf + ;
         "COALESCE(AN_GRU.ART_TIPOPR,'') AS ART_TIPOPR, COALESCE(AN_GRU.ART_MAGA,'') AS ART_MAGA," + _crlf + ;
         "COALESCE(AN_GRU.ART_DESCR,'') AS ART_DESCR, COALESCE(AN_GRU.ART_UMMAGA,'') AS ART_UMMAGA, COALESCE(P_REP.DESCRI,'') AS ART_DESLIN, COALESCE(AN_GRU.ART_CODCTL,'') AS ART_CODCTL" + _crlf + ;
         "FROM U_DIS_TT " + _crlf + ;
         "LEFT OUTER JOIN U_ART_PR AS AN_GRU ON U_DIS_TT.DIT_GRUPPO = AN_GRU.ART_CODPRI" + _crlf + ;         
         "LEFT OUTER JOIN PARA AS P_REP ON P_REP.CODICE = 'REP'+AN_GRU.ART_LINEA " + _crlf + ;
         "WHERE " + x_cond
IF !ExecCommand(cSql,_cNomeCur_U_DIS_TT)
	return(.f.)
ENDIF
SELECT &_cNomeCur_U_DIS_TT
GO TOP
IF EOF()
	IF _par_sivideo
		MESSAGEBOX("Nessuna Di.ba. per il gruppo " + ALLTRIM(_par_gruppo),48,"Attenzione")
	ENDIF
	RETURN .F.
ENDIF

*!*	IF _par_rivaluta_campi
*!*		DO RIVALUTA_CAMPI_U_DIS_TT WITH "TMP_DIS_TT"
*!*	ENDIF

*!*	RELEASE _pLivello,_pPath,_pProgre
*!*	PUBLIC _pLivello,_pPath,_pProgre
PRIVATE _pLivello,_pPath,_pProgre  && ERASMO - 22/10/2014
_pLivello = 0
_pPath = ""
_pProgre = 1

SELECT &_cNomeCur_U_DIS_TT
GO TOP

LOCAL _V_CHIAVE,_V_PARENT,_V_CODART,_V_DESCRI,_V_CODSUP,_V_DESSUP,_V_COSTO,_V_PREZZO,_V_COSLAI,_V_COSLAE,_V_COSMAT,_V_COSATR,_V_RICLAI,_V_RICLAE,_V_RICMAT,_V_RICATR, ;
	_V_ORELAV,_V_OREATT,_V_OREIMP,_V_SECIMP,_V_SECLAV,_V_SECATT,_V_SYSTT,_V_MAGA,_V_NOTE,_V_TIPART,_V_UMMAGA,_V_FITTIZ,_V_LINEA,_V_DLINEA,_V_CMPIMB,_V_OPZCST,_V_DAGGANCIO,_V_CODFOR,_V_DESFOR,_V_CODCTL,_V_SINTE
_V_CHIAVE = SYS(2015)
_V_PARENT = ""
_V_CODART = DIT_GRUPPO
_V_DESCRI = ART_DESCR
_V_CODSUP = ""
_V_DESSUP = ""
_V_COSTO  = DIT_COSTO
_V_PREZZO = DIT_PREZZO
_V_COSLAI = DIT_COSLAI 
_V_COSLAE = DIT_COSLAE 
_V_COSMAT = DIT_COSMAT 
_V_COSATR = DIT_COSATR 
_V_RICLAI = DIT_RICLAI 
_V_RICLAE = DIT_RICLAE  
_V_RICMAT = DIT_RICMAT 
_V_RICATR = DIT_RICATR 
_V_ORELAV = DIT_ORELAV 
_V_OREATT = DIT_OREATT  
_V_OREIMP = DIT_OREIMP 
_V_SECIMP = DIT_SECIMP 
_V_SECLAV = DIT_SECLAV 
_V_SECATT = DIT_SECATT 
_V_SYSTT  = DIT_SYSTT
_V_MAGA	  = ART_MAGA
_V_NOTE   = DIT_NOTE
_V_TIPART = ART_TIPOPR
_V_UMMAGA = ART_UMMAGA
_V_FITTIZ = .F.
_V_LINEA  = DIT_LINEA
_V_DLINEA = ART_DESLIN
_V_CMPIMB = .F.
_V_OPZCST = 1
_V_DAGGANCIO = ""
_V_CODFOR = ""
_V_DESFOR = ""
_V_CODCTL = ALLTRIM(ART_CODCTL)  && ERASMO - 17/03/2020
_V_SINTE = .F.  && ERASMO - 21/02/2022

_G_GRUPPO = DIT_GRUPPO
_G_DESCRI = DIT_DESCRI

SELECT WEXPLODE
APPEND BLANK

REPLACE WCHIAVE WITH _V_CHIAVE
REPLACE WPARENT WITH _V_PARENT

REPLACE WGRUPPO WITH _G_GRUPPO 
REPLACE WDESGRU WITH _G_DESCRI 

REPLACE WCODSUP WITH _V_CODSUP
REPLACE WDESSUP WITH _V_DESSUP

REPLACE WPATH	WITH _pPath

REPLACE WPROGRE	WITH _pProgre 

REPLACE WCOD    WITH _V_CODART
REPLACE WDES    WITH _V_DESCRI
REPLACE WDES2	WITH _V_DESCRI 
REPLACE WCOS    WITH _V_COSTO
REPLACE WPRZ    WITH _V_PREZZO
REPLACE WTIP    WITH "T"
REPLACE WLIV    WITH _pLivello
REPLACE WQTA    WITH 1
REPLACE TREE    WITH _V_CODART
REPLACE WQTAT   WITH 1
REPLACE WCOST   WITH _V_COSTO
REPLACE WPRZT   WITH _V_PREZZO

REPLACE WCOSLAI WITH _V_COSLAI 			&& COSTI DI PRODUZIONE
REPLACE WCOSLAE WITH _V_COSLAE 
REPLACE WCOSMAT WITH _V_COSMAT 
REPLACE WCOSATR WITH _V_COSATR 

REPLACE WRICLAI WITH _V_RICLAI 			&& RICAVI DI PRODUZIONE 
REPLACE WRICLAE WITH _V_RICLAE  
REPLACE WRICMAT WITH _V_RICMAT 
REPLACE WRICATR WITH _V_RICATR 

REPLACE WORELAV WITH _V_ORELAV 			&& TEMPI DI PRODUZIONE 
REPLACE WOREATT WITH _V_OREATT  
REPLACE WOREIMP WITH _V_OREIMP 

REPLACE WSECIMP WITH _V_SECIMP 			&& TEMPI IN SECONDI DI PRODUZIONE 
REPLACE WSECLAV WITH _V_SECLAV 
REPLACE WSECATT WITH _V_SECATT 

REPLACE WSYSDD  WITH _V_SYSTT 			&& SYS DELLA TESTATA DISTINTA

REPLACE WMAGA   WITH _V_MAGA

REPLACE WTNOTE  WITH _V_NOTE  

REPLACE WTIPART  WITH _V_TIPART
REPLACE WDESTIPA WITH IIF(WTIPART = 'I',"INTERNO",IIF(WTIPART = 'E',"ESTERNO",""))
REPLACE WUM      WITH _V_UMMAGA
REPLACE WFITTIZ  WITH _V_FITTIZ

REPLACE WLEADTMAX WITH 0
REPLACE WLEADTMAXT WITH 0

REPLACE WCHDIBA WITH .F.
REPLACE WLINEA WITH _V_LINEA
REPLACE WDLINEA WITH _V_DLINEA
REPLACE WCMPIMB WITH _V_CMPIMB

REPLACE WOPZCST WITH _V_OPZCST
REPLACE WDAGGANCIO WITH _V_DAGGANCIO
REPLACE WCODFOR WITH _V_CODFOR 
REPLACE WDESFOR WITH _V_DESFOR 

REPLACE WCODCTL WITH _V_CODCTL  && ERASMO - 17/03/2020

REPLACE WSINTE WITH _V_SINTE  && ERASMO - 21/02/2022

SELECT &_cNomeCur_U_DIS_TT
USE

*** INNESCO LA PROCEDURA RICORSIVA DI POPOLAMENTO NODI FIGLI
IF _par_solo_prod_interna AND _V_TIPART = 'E'
ELSE
	*** LA RIVALUTAZIONE DEI CAMPI (6° PARAMETRO) E' SETTATA A .F. IN QUANTO TALE RIVALUTAZIONE VIENE EFFETTUATA CON TECNICA BOTTOM-UP DIRETTAMENTE SUL CURSORE WEXPLODE
	*DO livello_successivo_diba WITH _V_CODART,1,_V_CHIAVE,_par_nlivmax,_par_solo_prod_interna,.F.,0,_par_sivideo
	DO livello_successivo_diba WITH _V_CODART,1,_V_CHIAVE,IIF(_par_opzliv_riv,128,_par_nlivmax),_par_solo_prod_interna,.F.,0,_par_sivideo  && ERASMO - 23/03/2015
ENDIF

IF _par_rivaluta_campi
	DO RIVALUTA_CAMPI_WEXPLODE WITH "WEXPLODE",999,_par_sivideo
ENDIF

**=> ERASMO - INIZIO 23/03/2015
IF _par_opzliv_riv
	SELECT WEXPLODE
	DELETE FOR WLIV > _par_nlivmax
ENDIF
**=> ERASMO - FINE 23/03/2015

IF _par_sivideo
	WAIT CLEAR
ENDIF

_SEC_FIN = SECONDS()
*WAIT WINDOWS ALLTRIM(STR(_SEC_FIN - _SEC_INI)) + " SECONDI IMPIEGATI"

IF _par_sivideo
	LOCAL _oActiveForm
	_oActiveForm = _SCREEN.ActiveForm
	_oActiveForm.Visible = .F.
	DO FORM FORM\ALBERO_DIBA WITH _G_GRUPPO,_G_DESCRI
	_oActiveForm.Visible = .T.
ENDIF

ENDPROC


*************************************************************************
PROCEDURE RIVALUTA_CAMPI_WEXPLODE
*************************************************************************
*** PROCEDURA PER RIVALUTARE TUTTI I CAMPI DI DETTAGLIO DELLE DISTINTE BASE NEL CURSORE WEXPLODE
*** CHE DIPENDONO DA EVENTUALI DETTAGLI (COMPONENTI), ANAGRAFICA ARTICOLI
*** O DA ALTRE DI.BA. ESISTENTI

LPARAMETERS _par_nomecur_wexplode,_par_level,_par_sivideo

IF !USED(_par_nomecur_wexplode) 
	RETURN
ELSE
	**=> ERASMO - INIZIO 02/12/2014
	SELECT &_par_nomecur_wexplode
	GO TOP
	**=> ERASMO - FINE 02/12/2014
	IF EOF()
		RETURN	
	ENDIF
ENDIF

LOCAL _n_ACT_SEL
_n_ACT_SEL = SELECT()

IF _par_level = 999

*!*		UPDATE &_par_nomecur_wexplode SET ;
*!*			WCOSMAT = 0, ;
*!*			WCOSLAI = 0, ;
*!*			WCOSLAE = 0, ;
*!*			WCOSATR = 0, ;
*!*			WCOS  = 0, ;
*!*			WCOST = 0, ;
*!*			WSECIMP = 0, ;
*!*			WSECLAV = 0, ;
*!*			WSECATT = 0 ;
*!*		WHERE WOPZCST <> 2
	
	SELECT MAX(WLIV) AS MAX_LIV FROM &_par_nomecur_wexplode INTO CURSOR TMP_MAX_LIV
	SELECT TMP_MAX_LIV
	GO TOP
	IF EOF() OR MAX_LIV <= 0
		SELECT(_n_ACT_SEL)
		RETURN
	ELSE
		_par_level = MAX_LIV
	ENDIF
	
	**=> ERASMO - INIZIO 23/03/2015
	*** SBIANCO SOLO I LIVELLI MINORI DI QUELLO MASSIMO PRESENTE, IN QUANTO NEL CASO DI FILTRI SU LIVELLI LIMITATI
	*** DEVE MANTENERE I DATI DI COSTIFICAZIONE DEI GRUPPI SENZA FIGLI, CHE ALTRIMENTI NON VERREBBERO VALORIZZATI
	UPDATE &_par_nomecur_wexplode SET ;
		WCOSMAT = 0, ;
		WCOSLAI = 0, ;
		WCOSLAE = 0, ;
		WCOSATR = 0, ;
		WCOS  = 0, ;
		WCOST = 0, ;
		WSECIMP = 0, ;
		WSECLAV = 0, ;
		WSECATT = 0 ;
	WHERE WOPZCST <> 2 AND WLIV < _par_level
	**=> ERASMO - FINE 23/03/2015
		
ENDIF

LOCAL _x_PARENT,_x_DAGGANCIO,_x_DIS_CODART,_x_DIS_GRUPPO,_x_DIS_FASELA

LOCAL _nomecur_wexplode_level
_nomecur_wexplode_level = "TMP_WEXPLODE" + SYS(2015)

SELECT * FROM &_par_nomecur_wexplode WHERE WLIV = _par_level ORDER BY WPROGRE INTO CURSOR &_nomecur_wexplode_level READWRITE
SELECT &_nomecur_wexplode_level
GO TOP
SCAN
	_x_PARENT = WPARENT
	_x_DAGGANCIO = WDAGGANCIO
	_x_DIS_CODART = WCOD
	_x_DIS_GRUPPO = WCODSUP
	_x_DIS_OPZCST = WOPZCST
	_x_DIS_FASELA = WFASELA
	_x_CHIAVE = WCHIAVE  && ERASMO - 28/11/2014

	IF _par_sivideo 
		WAIT WINDOWS "Rivalutazione Costi / Ricavi / Tempi articolo " + ALLTRIM(_x_DIS_CODART) + " ..." NOWAIT
	ENDIF
	
	*IF _x_DIS_CODART = '80409512'
	*	SET STEP ON
	*ENDIF
	
	*** ACCESSO ANAGRAFICA ARTICOLI PER RIVALUTAZIONE CAMPI
	LOCAL _nomecur_articoli,__DIS_DESCRI,__DIS_UM,__DIS_MAGA,__DIS_TIPOPR
	_nomecur_articoli = "TMP_ART_" + SYS(2015)
	__DIS_DESCRI = ""
	__DIS_UM = ""
	__DIS_MAGA = ""
	__DIS_TIPOPR = ""
	x_soci = "U_ART_PR.ART_CODSOC = '" + PUB_CODSOC + "'"
	x_codi = "U_ART_PR.ART_CODPRI = '" + _x_DIS_CODART + "'"
	x_cond = x_soci + " and " + x_codi
	cSql = "SELECT U_ART_PR.ART_CODPRI,ART_DESCR,ART_UMMAGA,ART_MAGA,ART_CODIVA,ART_LINEA,ART_COSMAT,ART_COSLAI,ART_COSLAE,ART_COSATR," + ;
	       "ART_RICMAT,ART_RICLAI,ART_RICLAE,ART_RICATR,ART_ORELAV,ART_OREATT,ART_OREIMP,ART_SECIMP,ART_SECLAV,ART_SECATT,ART_TIPOPR," + ;
	       "ART_CODF1,ART_CODF2,ART_CODF3,ART_CODF4,ART_CODF5,ART_ULPCAR,ART_NONVAL FROM U_ART_PR " + ;
	       "LEFT OUTER JOIN (SELECT ART_CODPRI,ART_NONVAL FROM U_ART_AN) AS U_ART_AN ON U_ART_AN.ART_CODPRI = U_ART_PR.ART_CODPRI " + ;
	       "WHERE " + x_cond
	IF !ExecCommand(cSql,_nomecur_articoli)
		RETURN .F.
	ENDIF
	SELECT &_nomecur_articoli
	GO TOP
	IF EOF()
		SELECT &_nomecur_wexplode_level
		LOOP
	ENDIF
	
	*** RIVALUTAZIONE CAMPI DA ANAGRAFICA ARTICOLI
	SELECT &_nomecur_articoli
	__DIS_DESCRI = ART_DESCR
	__DIS_UM = ART_UMMAGA
	__DIS_MAGA = ART_MAGA
	
	XLINEA = ART_LINEA  && ERASMO - 25/10/2020
	
	SELECT &_nomecur_wexplode_level
	REPLACE WDES WITH __DIS_DESCRI
	REPLACE WUM WITH __DIS_UM
	REPLACE WMAGA WITH __DIS_MAGA
	REPLACE WTIPART  WITH __DIS_TIPOPR
	REPLACE WDESTIPA WITH IIF(WTIPART = 'I',"INTERNO",IIF(WTIPART = 'E',"ESTERNO",""))
	
	LOCAL __DIS_TIPO,__DIS_COSMAT,__DIS_COSLAI,__DIS_COSLAE,__DIS_COSATR,__DIS_COSTO,__DIS_RICMAT,__DIS_RICLAI,__DIS_RICLAE,__DIS_RICATR,__DIS_PREZZO, ;
		__DIS_ORELAV,__DIS_OREATT,__DIS_OREIMP,__DIS_SECIMP,__DIS_SECLAV,__DIS_SECATT,__DIS_CODFOR,__DIS_DESFOR,__DIT_TIPOPR,__DIS_COSTOT
	
	SELECT &_nomecur_wexplode_level
	__DIS_TIPO = WTIP
	
	__DIS_COSMAT = 0
	__DIS_COSLAI = 0
	__DIS_COSLAE = 0
	__DIS_COSATR = 0
	__DIS_COSTO  = 0
	__DIS_COSTOT = 0

	SELECT &_nomecur_articoli
	__DIS_RICMAT = ART_RICMAT
	__DIS_RICLAI = ART_RICLAI
	__DIS_RICLAE = ART_RICLAE
	__DIS_RICATR = ART_RICATR
	__DIS_PREZZO = 0

	*** RICERCA PREZZO DI VENDITA DA EVENTUALE LISTINO
	
	**=> ERASMO - INIZIO 10/11/2017
	_OLD_IVA_ESE = ""
	IF TYPE("IVA_ESE") = "C"
		_OLD_IVA_ESE = IVA_ESE
	ENDIF
	_OLD_ORD_CODCLI = ""
	IF TYPE("M.ORD_CODCLI") = "C"
		_OLD_ORD_CODCLI = M.ORD_CODCLI
	ENDIF
	_OLD_ORD_CODLOC = ""
	IF TYPE("M.ORD_CODLOC") = "C"
		_OLD_ORD_CODLOC = M.ORD_CODLOC
	ENDIF
	_OLD_ORD_DATORD = ""
	IF TYPE("M.ORD_DATORD") = "C"
		_OLD_ORD_DATORD = M.ORD_DATORD
	ENDIF
	_OLD_ORD_CODART = ""
	IF TYPE("M.ORD_CODART") = "C"
		_OLD_ORD_CODART = M.ORD_CODART
	ENDIF
	_OLD_ORD_SC1 = 0
	IF TYPE("M.ORD_SC1") = "N"
		_OLD_ORD_SC1 = M.ORD_SC1
	ENDIF
	_OLD_ORD_SC2 = 0
	IF TYPE("M.ORD_SC2") = "N"
		_OLD_ORD_SC2 = M.ORD_SC2
	ENDIF
	_OLD_ORD_SC3 = 0
	IF TYPE("M.ORD_SC3") = "N"
		_OLD_ORD_SC3 = M.ORD_SC3
	ENDIF
	_OLD_ORD_SC4 = 0
	IF TYPE("M.ORD_SC4") = "N"
		_OLD_ORD_SC4 = M.ORD_SC4
	ENDIF
	_OLD_ORD_SC5 = 0
	IF TYPE("M.ORD_SC5") = "N"
		_OLD_ORD_SC5 = M.ORD_SC5
	ENDIF
	_OLD_ORD_PRORIG = 0
	IF TYPE("M.ORD_PRORIG") = "N"
		_OLD_ORD_PRORIG = M.ORD_PRORIG
	ENDIF
	_OLD_ORD_PREZZO = 0
	IF TYPE("M.ORD_PREZZO") = "N"
		_OLD_ORD_PREZZO = M.ORD_PREZZO
	ENDIF
	_OLD_ORD_PRZNET = 0
	IF TYPE("M.ORD_PRZNET") = "N"
