PROCEDURE RIVALUTA_CAMPI_U_DIS_TT_OLD
*************************************************************************
*** PROCEDURA PER RIVALUTARE TUTTI I CAMPI DI TESTATA DELLE DISTINTE BASE
*** CHE DIPENDONO DAI DETTAGLI (COMPONENTI) O DA ALTRE DI.BA. ESISTENTI

LPARAMETERS _par_nomecur

IF !USED(_par_nomecur)
	RETURN
ELSE
	IF EOF()
		RETURN	
	ENDIF
ENDIF

LOCAL _n_ACT_SEL,_x_TAGGANCIO,_x_DIT_GRUPPO

_n_ACT_SEL = SELECT()

SELECT &_par_nomecur
AFIELDS(A_STRU_CUR_DIS)

*** CONTROLLO CHE ESISTANO ALMENO I CAMPI CHIAVE
IF ASCAN(A_STRU_CUR_DIS,"TAGGANCIO",1,ALEN(A_STRU_CUR_DIS,1),1,8) > 0
ELSE
	RETURN
ENDIF
IF ASCAN(A_STRU_CUR_DIS,"DIT_GRUPPO",1,ALEN(A_STRU_CUR_DIS,1),1,8) > 0
ELSE
	RETURN
ENDIF
_x_TAGGANCIO = TAGGANCIO
_x_DIT_GRUPPO = DIT_GRUPPO


*** ACCESSO ANAGRAFICA ARTICOLI PER RIVALUTAZIONE CAMPI
LOCAL _nomecur_articoli
_nomecur_articoli = "TMP_ART_" + SYS(2015)
x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
x_codi = "ART_CODPRI = '" + _x_DIT_GRUPPO + "'"
