		x_soci = "U_ART_PR.ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "U_ART_PR.ART_CODPRI = '" + _x_DIS_GRUPPO + "'"
		x_cond = x_soci + " and " + x_codi
		cSql = "SELECT ART_TIPOPR,ART_CODF1,ART_PRZCO1,ART_CODF2,ART_PRZCO2,ART_CODF3,ART_PRZCO3,ART_CODF4,ART_PRZCO5,ART_CODF5,ART_NONVAL, " + ;
		       "ART_ORELAV,ART_OREATT,ART_OREIMP,ART_SECIMP,ART_SECLAV,ART_SECATT FROM U_ART_PR " + ;
		       "LEFT OUTER JOIN (SELECT ART_CODPRI,ART_NONVAL FROM U_ART_AN) AS U_ART_AN ON U_ART_AN.ART_CODPRI = U_ART_PR.ART_CODPRI " + ;
		       "WHERE " + x_cond
		IF !ExecCommand(cSql,_nomecur_art_gruppo_testata)
