ELSE
	RETURN
ENDIF
_x_TAGGANCIO = TAGGANCIO
_x_DIT_GRUPPO = DIT_GRUPPO

DO ALBERO_DIBA WITH .F.,_x_DIT_GRUPPO,128,.F.,.T.

SELECT WEXPLODE
GO TOP
SCAN
	IF WTIP = 'T'
		EXIT
	ENDIF
ENDSCAN
IF EOF()
	RETURN .F.
ENDIF

LOCAL __DIT_DESCRI,__DIT_UM,__DIT_MAGA,__DIT_CODIVA,__DIT_LINEA,__DIT_TIPOPR, ;
	__DIT_COSMAT,__DIT_COSLAI,__DIT_COSLAE,__DIT_COSATR,__DIT_COSTO,__DIT_RICMAT,__DIT_RICLAI,__DIT_RICLAE,__DIT_RICATR,__DIT_PREZZO, ;
	__DIT_ORELAV,__DIT_OREATT,__DIT_OREIMP,__DIT_SECIMP,__DIT_SECLAV,__DIT_SECATT,__DIT_CODCTL

SELECT WEXPLODE
__DIT_DESCRI = WDES
__DIT_UM = WUM 
__DIT_MAGA = WMAGA 
*__DIT_CODIVA = ""
__DIT_LINEA = WLINEA 
__DIT_TIPOPR = WTIPART
__DIT_CODCTL = WCODCTL  && ERASMO - 17/03/2020

__DIT_COSMAT = WCOSMAT 
__DIT_COSLAI = WCOSLAI 
__DIT_COSLAE = WCOSLAE 
__DIT_COSATR = WCOSATR 
__DIT_COSTO  = WCOST

