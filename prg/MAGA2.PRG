
x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"  
x_maga = "mag_codmag = '" + ALLTRIM(_MAG) + "'"
x_codi = "mag_codart = '" + ALLTRIM(_CODART) + "'"
x_cond = x_soci + " and " + x_maga + " and " + x_codi
Csql   = "select * from u_mag_an where " + x_cond + " order by mag_codsoc,mag_codmag,mag_codart"
IF !ExecRW(cSql,"U_MAG_AN","R")
   return(.f.)
ENDIF
SELECT U_MAG_AN
IF RECCOUNT() <> 0
   IF _SEGNO = '+'
      REPLACE MAG_QTAIMP WITH MAG_QTAIMP + _QTAIMP
   ELSE
      REPLACE MAG_QTAIMP WITH MAG_QTAIMP - _QTAIMP
   ENDIF
ELSE

   APPEND BLANK

   REPLACE MAG_CODSOC WITH PUB_CODSOC
   REPLACE MAG_CODMAG WITH M.ORD_MAGA
   REPLACE MAG_CODART WITH M.ORD_CODART
   REPLACE MAG_DESART WITH M.ORD_DESART

   IF _SEGNO = '+'
      REPLACE MAG_QTAIMP WITH MAG_QTAIMP + _QTAIMP
   ELSE
      REPLACE MAG_QTAIMP WITH MAG_QTAIMP - _QTAIMP
   ENDIF

   REPLACE MAG_CODFOR WITH M.ORD_FORNIT
   REPLACE MAG_CODCOL WITH M.ORD_CODCOL
   REPLACE MAG_DESCOL WITH M.ORD_DESCOL
   REPLACE MAG_UNIMIS WITH M.ORD_UM
   REPLACE MAG_DTCREA WITH RIBALTA2(DTOC(DATE()))
   REPLACE MAG_CODPDV WITH m.ord_codbun
   REPLACE MAG_CODTAG WITH M.ORD_CODCOL
   REPLACE MAG_DESTAG WITH M.ORD_DESTAG
   REPLACE MAG_COSTO  WITH _ART_PRZCOS   
   REPLACE MAG_UNIQUE WITH SYS(2015)   
ENDIF


REPLACE MAG_FLGTRA WITH .F.

SCATTER MEMVAR MEMO
IF !ExecRW(cSql,"U_MAG_AN","W")
   return(.f.)
ENDIF




RETURN
