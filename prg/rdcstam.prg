*******************************************************************************
*	STAMPA DOCUMENTI DI TRASPORTO IN FORMATO DOS TRAMITE SPOOLER
*******************************************************************************
PARA _XXX_OPT

RELEASE V_NUMPAG,V_NUMRIG,V_NUMDET,START_TE,START_DE,START_TO,ROT_PAG,_TOT_RIGHE

PUBLIC V_NUMPAG,V_NUMRIG,V_NUMDET,START_TE,START_DE,START_TO,ROT_PAG,_TOT_RIGHE

V_NUMPAG = 0
V_NUMRIG = 90
V_NUMDET = 90
START_TE = 0		&& RIGA DI PARTENZA TESTATA
START_DE = 23       && RIGA DI PARTENZA DETTAGLIO
START_TO = 56       && RIGA DI PARTENZA TOTALI
ROT_PAG  = 52       && NUMERO RIGA PER SALTO PAGINA
_TOT_RIGHE=30 		&& NUMERO RIGHE DI DETTAGLIO
V_TOTRIG = 66       && LUNGHEZZA MODULO IN RIGHE

SELECT u_bfo_tt
NUMPRO=TAGGANCIO
SELECT CU_BFO_DD

ANCORA = 1

** CREAZIONE CURSORE PER PAGINA/RIGA

CREATE CURSOR FILE_STA (STA_PAGINA N(4), STA_RIGA N(4), STA_RECORD C(132))
INDEX ON STR(STA_PAGINA,4,0) + STR(STA_RIGA,3,0) TAG FILE_IND ADDITIVE
SELECT FILE_STA
SET ORDER TO FILE_IND
GO TOP

*IF V_VALUTA="ITL" .OR. V_VALUTA="LIT"
*ELSE
*ENDIF  

IF V_NUMDET > ROT_PAG
   DO STAMPA_TESTATA
   V_NUMRIG = START_DE
   V_NUMDET = 0
ENDIF

DO STAMPA_DETTAGLI

DO STAMPA_TOTALI

SELECT FILE_STA

DO PJCOMPLETA WITH V_TOTRIG 
   
SELECT FILE_STA
GO TOP

CREATE CURSOR FILE_PRT (PRT_RIGA C(132))
SELECT FILE_PRT
GO TOP

SELECT FILE_STA
SET ORDER TO FILE_IND
GO TOP

GO BOTTOM
DELETE			&& CANCELLA ULTIMA RIGA PER LA STAMPA SUCCESSIVA
GO TOP

DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DELETED()
     SKIP
     LOOP
   ENDIF
   V_RECORD = STA_RECORD
   SELECT FILE_PRT
   APPEND BLANK
   REPLACE PRT_RIGA WITH V_RECORD      
   SELECT FILE_STA
   SKIP +1
ENDDO          


IF PCOUNT()=0
  DO CREA_SPOOL WITH "FILE_PRT","D.D.T. N. "+ALLTRIM(M.ORD_NUMORD)+" - "+M.ORD_DATORD
  RELEASE WINDOW DISPLAY
  IF PUB_NOSPOO
     DO PRTDIREC      && STAMPA DIRETTA DELLO SPOOL
  ELSE 
     =MESSAGEBOX("FINE ELABORAZIONE. PROCEDI CON LA STAMPA TRAMITE LO SPOOLER",62,"ATTENZIONE")
  ENDIF 
ENDIF

RELEASE V_NUMPAG,V_NUMRIG,V_NUMDET,START_TE,START_DE,START_TO,ROT_PAG,_TOT_RIGHE

RETURN


************************
PROCEDURE STAMPA_TESTATA        && STAMPA TESTATA  
************************

**--> IMPOSTAZIONE PRIMA RIGA

   V_NUMPAG = V_NUMPAG + 1
   V_NUMRIG = START_TE +1

   * Ragione sociale  

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 41
   V_CAMPO    = "Spett.le"
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

**--> IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG = V_NUMRIG + 1

   * Ragione sociale  

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 41
   V_CAMPO    = M.ORD_RAGSOC
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 
   
**--> IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG = V_NUMRIG + 1

   * Indirizzo  

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 41
   V_CAMPO    = M.ORD_INDIRI
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

**--> IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG = V_NUMRIG + 1

   * Cap + Localitŕ

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 41
   V_CAMPO    = ALLTRIM(M.ORD_CAP)+" "+ALLTRIM(M.ORD_LOCALI)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

**--> IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG = V_NUMRIG + 3

   * Luogo di destinazione - ragione sociale

   IF !EMPTY(M.ORD_RAGC)
     V_PAGINA   = V_NUMPAG
     V_RIGA     = V_NUMRIG
     V_COLONNA  = 41
     V_CAMPO    = ALLTRIM(M.ORD_RAGC) 
     V_LENCAMPO = LEN(V_CAMPO)
     DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 
   ENDIF

**--> IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG = V_NUMRIG + 1

   * Luogo di destinazione - indirizzo

   IF !EMPTY(M.ORD_RAGC)
     V_PAGINA   = V_NUMPAG
     V_RIGA     = V_NUMRIG
     V_COLONNA  = 41
     V_CAMPO    = ALLTRIM(M.ORD_INDC) 
     V_LENCAMPO = LEN(V_CAMPO)
     DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 
   ENDIF

**--> IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG = V_NUMRIG + 1

   * Luogo di destinazione - Cap + Localitŕ

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 41
   V_CAMPO    = ALLTRIM(M.ORD_CAPC)+" "+ALLTRIM(M.ORD_LOCC)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

**--> IMPOSTAZIONE PRIMA RIGA

   V_NUMRIG = V_NUMRIG + 2

   * Numero D.D.T
      
   SELECT CU_BFO_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 71
   V_CAMPO    = ALLTRIM(M.ORD_NUMORD)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

**-->  IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG =  V_NUMRIG+1
 
   * Codice cliente

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 09
   V_CAMPO    = ALLTRIM(M.ORD_CODCLI)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

   * Ns. n. riferimento

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 21
   V_CAMPO    = ALLTRIM(M.ORD_RIFERI)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

   * Data D.D.T.
      
   SELECT CU_BFO_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 67
   V_CAMPO    = M.ORD_DATORD
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

**-->  IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG =  V_NUMRIG + 1

   * Descrizione n. pagina 

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 67
   V_CAMPO    = "Pagina"
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

   * Numero della pagina 

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 74
   V_CAMPO    = STR(V_NUMPAG,3,0)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

**-->  IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG =  V_NUMRIG+1
 
   * Spedizione a mezzo

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 03
   V_CAMPO    = ALLTRIM(SAY_ACURA)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

   * Condizione di pagamento
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 38
   V_CAMPO    = ALLTRIM(SAY_CPA)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

**--> IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG = V_NUMRIG + 2
 
   * Codice agente

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 12
   V_CAMPO    = ALLTRIM(M.ORD_AGE)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

**--> IMPOSTAZIONE NUOVA RIGA

   V_NUMRIG = V_NUMRIG + 2
 
   * Causale del trasporto

   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 03
   V_CAMPO    = ALLTRIM(SAY_CAUS)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

RETURN


*************************
PROCEDURE STAMPA_DETTAGLI		&& STAMPA DETTAGLI
*************************


SELECT CU_BFO_DD
GO TOP

DO WHILE .T.

   **--> PREPARAZIONE DELLA RIGA 23

   IF EOF()
     EXIT
   ENDIF

   IF ALLTRIM(DAGGANCIO) = "EOF"
     SELECT CU_BFO_DD
     SKIP   
     LOOP
   ENDIF
 

   V_CA       = ALLTRIM(ORD_CODART)

   DO CASE

      CASE   SUBSTR(V_CA,1,3) = ".A " 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP

      CASE   SUBSTR(V_CA,1,3) = ".B " 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".I " 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".IE" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".II" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,4) = ".INC" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".MB" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".PS" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".SA" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".SI" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".SP" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".ST" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP
      CASE   SUBSTR(V_CA,1,3) = ".SC" 
		     SELECT CU_BFO_DD
		     SKIP   
		     LOOP


   ENDCASE
   
   
 
   * Note
   
   IF ALLTRIM(ORD_DESART)="*** COMMENTO ***"    
     DO ESPL_COMM WITH 60	&& il parametro corrisponde al numero di caratteri che si vogliono
     						&& assegnare al commento
     SELECT CU_BFO_DD
     SKIP   
     LOOP
   ENDIF
   
   * Codice Articolo
      
   SELECT CU_BFO_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 03
   V_CAMPO    = ALLTRIM(ORD_CODART)

   DO CASE

      CASE   SUBSTR(V_CA,1,3) = "/M " 
		     V_CAMPO = " "

      CASE   SUBSTR(V_CA,1,4) = "/NAM" 
		     V_CAMPO = " "

      CASE   SUBSTR(V_CA,1,4) = "/NAR" 
		     V_CAMPO = " "

      CASE   SUBSTR(V_CA,1,3) = "/PS" 
		     V_CAMPO = " "

      CASE   SUBSTR(V_CA,1,3) = "/SC" 
		     V_CAMPO = " "

      CASE   SUBSTR(V_CA,1,3) = "/SG" 
		     V_CAMPO = " "

      CASE   SUBSTR(V_CA,1,3) = "/V " 
		     V_CAMPO = " "

 
   ENDCASE
   
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

   * Descrizione

   SELECT CU_BFO_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 20
   V_CAMPO    = ALLTRIM(SUBSTR(ORD_DESART,1,44))
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

   * UM
        
   SELECT CU_BFO_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 61
   V_CAMPO    = ALLTRIM(ORD_UM)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

   * Quantitŕ
      
   SELECT CU_BFO_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 66
   *V_CAMPO    = ALLTRIM(STR(ORD_QTAORD))
   V_CAMPO    = STR(ORD_QTAORD,9,2)
   V_CAMPO    = PADL(V_CAMPO,11, ' ')
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 



  IF V_NUMRIG >= _TOT_RIGHE+START_DE
   
     V_NUMRIG = V_NUMRIG + 1
     
     SELECT CU_BFO_DD
     V_PAGINA   = V_NUMPAG
     V_RIGA     = V_NUMRIG
     V_COLONNA  = 1
    * V_CAMPO    = "" + ""
     V_CAMPO    = "" 
     V_LENCAMPO = LEN(V_CAMPO)
     DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

     DO STAMPA_TESTATA
     V_NUMDET=0
     V_NUMRIG=START_DE - 1
      
   ENDIF
   
   V_NUMDET = V_NUMDET + 1
   V_NUMRIG = V_NUMRIG + 1
      
   SELECT CU_BFO_DD
   
   SKIP +1
   LOOP
  
ENDDO

***********************
