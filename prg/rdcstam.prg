   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

   * Numero colli
        
   SELECT CU_BFO_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 40
   V_CAMPO    = ALLTRIM(M.ORD_COLLI)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

V_NUMRIG = V_NUMRIG + 2

   * Porto
        
   SELECT CU_BFO_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 03
   V_CAMPO    = ALLTRIM(SAY_PORTO)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

   * Peso lordo kg
        
   SELECT CU_BFO_DD
   V_PAGINA   = V_NUMPAG
   V_RIGA     = V_NUMRIG
   V_COLONNA  = 49
   V_CAMPO    = STR(M.ORD_PESO,10,2)
   V_LENCAMPO = LEN(V_CAMPO)
   DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 



RETURN


   
   
*************************  
FUNCTION ESPL_COMM
*************************
PARA _NUM_CAR

_SSXX=SELECT()
_RECORDXXX=RECNO()

POSIZIONE=0
PARZIALE =0
RIGA	   =""
V_NOTE=ORD_NOTE
  
LUNGH_MEMO=LEN(ALLTRIM(V_NOTE))

DO WHILE .T.

  POSIZIONE=POSIZIONE+1
  PARZIALE =PARZIALE+1

  CARATTERE=SUBSTR(V_NOTE,POSIZIONE,1)

  IF POSIZIONE>=LUNGH_MEMO
    RIGA=RIGA+CARATTERE


    V_PAGINA   = V_NUMPAG
    V_RIGA     = V_NUMRIG
    V_COLONNA  = 15
    V_CAMPO    = RIGA
    V_LENCAMPO = LEN(V_CAMPO)
    DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

    IF V_NUMRIG = _TOT_RIGHE+START_DE
      V_NUMRIG = V_NUMRIG + 1
      SELECT CU_BFO_DD
      V_PAGINA   = V_NUMPAG
      V_RIGA     = V_NUMRIG
      V_COLONNA  = 1
      *V_CAMPO    = "" + ""
      V_CAMPO    = ""
      V_LENCAMPO = LEN(V_CAMPO)
      DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

      DO STAMPA_TESTATA
      V_NUMDET=0
      V_NUMRIG=START_DE - 1
    ENDIF
    
    V_NUMDET = V_NUMDET + 1
    V_NUMRIG = V_NUMRIG + 1
     
    EXIT
  ENDIF

  IF PARZIALE=_NUM_CAR
    RIGA=RIGA+CARATTERE

    V_PAGINA   = V_NUMPAG
    V_RIGA     = V_NUMRIG
    V_COLONNA  = 15
    V_CAMPO    = RIGA
    V_LENCAMPO = LEN(V_CAMPO)
    DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

    RIGA	  =""
    RIGA_SPEZZ=""
    PARZIALE=0
    ULTIMOSPAZIO=.F.    
    NUM_SPAZI=OCCURS(" ",SUBSTR(V_NOTE,POSIZIONE+1,40))
    
    IF V_NUMRIG = _TOT_RIGHE+START_DE
      V_NUMRIG = V_NUMRIG + 1
      SELECT CU_BFO_DD
      V_PAGINA   = V_NUMPAG
      V_RIGA     = V_NUMRIG
      V_COLONNA  = 1
      *V_CAMPO    = "" + ""
      V_CAMPO    = ""
      V_LENCAMPO = LEN(V_CAMPO)
      DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 
      DO STAMPA_TESTATA
      V_NUMDET=0
      V_NUMRIG=START_DE - 1
    ENDIF
    
    V_NUMDET = V_NUMDET + 1
    V_NUMRIG = V_NUMRIG + 1

    LOOP
  ENDIF

  IF CARATTERE=CHR(13)
    POSIZIONE=POSIZIONE+1

    V_PAGINA   = V_NUMPAG
    V_RIGA     = V_NUMRIG
    V_COLONNA  = 15
    V_CAMPO    = RIGA
    V_LENCAMPO = LEN(V_CAMPO)
    DO PJPREPARA WITH V_PAGINA,V_RIGA,V_COLONNA,V_CAMPO,V_LENCAMPO 

    RIGA	  =""
    RIGA_SPEZZ=""
    PARZIALE=0
    ULTIMOSPAZIO=.F.    
    NUM_SPAZI=OCCURS(" ",SUBSTR(V_NOTE,POSIZIONE+1,40))

    IF V_NUMRIG = _TOT_RIGHE+START_DE
      V_NUMRIG = V_NUMRIG + 1
      SELECT CU_BFO_DD
      V_PAGINA   = V_NUMPAG
      V_RIGA     = V_NUMRIG
      V_COLONNA  = 1
      *V_CAMPO    = "" + ""
      V_CAMPO    = ""
