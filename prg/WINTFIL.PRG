*       *********************************************************
*       *                                                         
*       * _R490MWNTT           B10 VALID                          
*       *                                                         
*       * Function Origin:                                        
*       *                                                         
*       * From Platform:       Windows                            
*       * From Screen:         WINTFIL,     Record Number:    4   
*       * Variable:            B10                                
*       * Called By:           VALID Clause                       
*       * Object Type:         Push Button                        
*       * Snippet Number:      1                                  
*       *                                                         
*       *********************************************************
*
FUNCTION _r490mwntt     &&  B10 VALID
#REGION 1
DO CASE
   CASE B10=1
      DO CASE
         CASE TIPOFILE=1
             V_EXT="TXT"
         CASE TIPOFILE=2
             V_EXT="DIF"
         CASE TIPOFILE=3
             V_EXT="MOD"
         CASE TIPOFILE=4
             V_EXT=""
         CASE TIPOFILE=5
             V_EXT="WK1"
         CASE TIPOFILE=6
             V_EXT="WKS"
         CASE TIPOFILE=7
             V_EXT="WR1"
         CASE TIPOFILE=8
             V_EXT="WRK"
         CASE TIPOFILE=9
             V_EXT="XLS"
         ENDCASE
      V_TEMP=GETFILE(V_EXT,"File di Output","OK")
      IF LEN(V_TEMP)>0
         V_NOMEFILE=V_TEMP
      ENDIF
      SHOW GETS
   CASE B10=2
      IF LEN(ALLTRIM(V_NOMEFILE))=0
         WAIT WINDOW "Inserire il nome del file !"
         RETURN
      ENDIF
      DO CASE
         CASE TIPOFILE=1
             COPY TO (V_NOMEFILE) TYPE SDF
         CASE TIPOFILE=2
             COPY TO (V_NOMEFILE) TYPE DIF
         CASE TIPOFILE=3
             COPY TO (V_NOMEFILE) TYPE MOD
         CASE TIPOFILE=4
             COPY TO (V_NOMEFILE) TYPE SYLK
         CASE TIPOFILE=5
             COPY TO (V_NOMEFILE) TYPE WK1
         CASE TIPOFILE=6
             COPY TO (V_NOMEFILE) TYPE WKS
         CASE TIPOFILE=7
             COPY TO (V_NOMEFILE) TYPE WR1
         CASE TIPOFILE=8
             COPY TO (V_NOMEFILE) TYPE WRK
         CASE TIPOFILE=9
             COPY TO (V_NOMEFILE) TYPE XLS
      ENDCASE
      CLEAR READ
ENDCASE