***************************	
* Procedure CalcolaCompensazione
***************************
***PROCEDURE CalcolaCompensazione

PARAMETERS FLAG_CONTABILIZZA

PRIVATE _IMORTO_COMPENSAZIONE,;
		_COMPENSAZIONE_DARE,;
		_COMPENSAZIONE_AVERE,;
		_SALDO_SINGOLA_PARTITA,;
		_NDARE,;
		_NAVERE,;
		_NSALDO,;
        _RAGSOC,;
		_COD_CLIFOR,;
		_COD_FORNITORE,;
		_COD_CLIENTE,;
		_MASTRO_CLIENTI,;
		_MASTRO_FORNITORI,;
		_CODICE_CONTO_BANCA,;
		_DESCRIZIONE_CONTO_BANCA,;
		_CONTAMOVIMENTI,;
		_PAR_NUMPRO ,;  
        _PAR_INDICE ,;  
        _PAR_NREG   ,;
        _PAR_NDOC   

		
		
*** IMPOSTO VARIABILI PUBBLICHE PER CODICE MASTRO CLIENTI/FORNITORI
_ER = SOTTOGEN("ITA")
IF !_ER
   	_MASTRO_FORNITORI = PUB_FF
   	_MASTRO_CLIENTI	  = PUB_CC	
ELSE
	RETURN
ENDIF 

_IMORTO_COMPENSAZIONE	=0
_NDARE					=0
_NAVERE					=0
_NSALDO					=0
_SALDO_SINGOLA_PARTITA	=0
_TOTALE_PRIMA_NOTA		=0   && QUANDO ESEGUE AQUAREP SOMMA DARE PER OTTENERE IL TOTALE ALLA FINE 
							 && IL TOTALE OTTENUTO VA SU INDICE
_COD_CLIFOR				=SPACE(0)
_COD_FORNITORE			=SPACE(0)
_COD_CLIENTE			=SPACE(0)
_RAGSOC					=SPACE(0)
_RAGSOC_FORNITORE		=SPACE(0)
_RAGSOC_CLIENTE			=SPACE(0)

_PAR_NUMPRO = SPACE(0)
_PAR_INDICE = SPACE(0)
_PAR_NREG   = SPACE(0)
_PAR_NDOC   = SPACE(0)


*** ___codban   && CODICE CONTO BANCA: SE PAGO FORNITORE SERVE PER LA CONTROPARTITA DI AVERE
*** ___desban   && DESCRIZIONE CONTO BANCA: SE PAGO FORNITORE SERVE PER LA CONTROPARTITA DI AVERE

*** ___codfor   && CODICE CONTO FORNITORE: SE PAGO FORNITORE SERVE PER LA PARTITA DI DARE
*** ___desfor   && DESCRIZIONE CONTO FORNITORE: SE PAGO FORNITORE SERVE PER LA PARTITA DI DARE


*** CALCOLO QUANTO HO A DISPOSIZIONE IN DARE E AVERE PER COMPENSARE
*** LE OPPOSTE PARTITE

_COMPENSAZIONE_DARE=0
_COMPENSAZIONE_AVERE=0


***SELECT * FROM CSPLITCOMP ORDER BY NSALDO DESC INTO CURSOR ORDINE_DI_IMPORTO

SELECT CSPLITCOMP
GO TOP
DO WHILE !EOF()

	IF EMPTY(SELEZIONE)
		SKIP
		LOOP
	ENDIF
	
	IF CSPLITCOMP.NSALDO<0
		_COMPENSAZIONE_AVERE=_COMPENSAZIONE_AVERE+ABS(CSPLITCOMP.NSALDO)
	ELSE		
		_COMPENSAZIONE_DARE=_COMPENSAZIONE_DARE+CSPLITCOMP.NSALDO
	ENDIF		
	
	SKIP
ENDDO

_IMORTO_COMPENSAZIONE=_COMPENSAZIONE_DARE-_COMPENSAZIONE_AVERE


*** ADESSO EFFETTUO IL CALCOLO VERO E PROPRIO DELLE CONPENSAZIONI 
*** ED IL RELATIVO PAGAMENTO SE SI STA CONSOLIDANDO IL PIANO DI PAGAMENTO
	
_CONTAMOVIMENTI=0
_NUMPART_ESUBERO=0

SELECT CSPLITCOMP 
GO TOP

DO WHILE !EOF()

	IF EMPTY(SELEZIONE)
		SKIP
		LOOP
	ENDIF


	IF SUBSTR(codfor,1,LEN(_MASTRO_FORNITORI))=_MASTRO_FORNITORI
	&& E' IL FORNITORE DELLA COPPIA CLI/FOR PER COMPENSAZIONE

		IF EMPTY(_COD_FORNITORE)
			_COD_FORNITORE		=CSPLITCOMP.codfor
			_RAGSOC_FORNITORE	=CSPLITCOMP.RAGSOC
		ENDIF
		

	ELSE 
		IF SUBSTR(codfor,1,LEN(_MASTRO_CLIENTI))=_MASTRO_CLIENTI
		&& E' IL CLIENTE DELLA COPPIA CLI/FOR PER COMPENSAZIONE
		
			IF EMPTY(_COD_CLIENTE)
				_COD_CLIENTE	=CSPLITCOMP.codfor
				_RAGSOC_CLIENTE	=CSPLITCOMP.RAGSOC
			ENDIF
		

		ENDIF
	ENDIF

	
	SELECT CSPLITCOMP 		
	_CONTAMOVIMENTI=_CONTAMOVIMENTI+1
	
	SKIP
ENDDO


IF _IMORTO_COMPENSAZIONE>0 	&& DARE QUINDI CREDITO VERSO CLIENTE
	_NDARE=_IMORTO_COMPENSAZIONE
	_NAVERE=0
	_NSALDO=_IMORTO_COMPENSAZIONE
	_RAGSOC=_RAGSOC_CLIENTE
	_COD_CLIFOR=_COD_CLIENTE
				
ELSE				&& AVERE QUINDI DEBITO VERSO FORNITORE
	_NDARE=0
	_NAVERE=ABS(_IMORTO_COMPENSAZIONE)
	_NSALDO=_IMORTO_COMPENSAZIONE
	_RAGSOC=_RAGSOC_FORNITORE
	_COD_CLIFOR=_COD_FORNITORE
ENDIF


SELECT CSALDI_PARTITE
REPLACE NDARE  WITH _NDARE	
REPLACE NAVERE WITH _NAVERE	
REPLACE NSALDO WITH _NSALDO
REPLACE RAGSOC WITH _RAGSOC
REPLACE CODFOR WITH _COD_CLIFOR




RETURN _CONTAMOVIMENTI
* FINE PROCEDURE CalcolaCompensazione
***************************

