*********************************
FUNCTION CARICA_TABELLA
*********************************
PARAMETERS _V_NOMDBF,_V_NOMSQL 

CLOSE DATABASES ALL

V_SONOQUI  = SYS(5)+SYS(2003)
V_DIR_COPY = V_SONOQUI + "\UTILARC"

SET DEFAULT TO &V_DIR_COPY
CLOSE DATABASES ALL

V_NOMDBF = ALLTRIM(_V_NOMDBF) + ".DBF"
IF FILE(V_NOMDBF)
ELSE
   =MESSAGEBOX("Tabella " + V_NOMDBF + " da caricare non presente",64,"*** INFORMAZIONE ***")
   SET DEFAULT TO &V_SONOQUI
   RETURN
ENDIF

Csql = "delete from " + _V_NOMSQL
IF !ExecCommand(Csql,_V_NOMSQL)
   SET DEFAULT TO &V_SONOQUI
   =MESSAGEBOX("Tabella sql " + _V_NOMSQL + " di destinazione non presente",64,"*** INFORMAZIONE ***")
   return(.f.)
ENDIF



_V_NOMDBF = ALLTRIM(_V_NOMDBF)
_V_NOMSQL = ALLTRIM(_V_NOMSQL)


SELECT 1 						&& DATABASE INPUT _V_NOMDBF 
USE &_V_NOMDBF IN 0 AGAIN
SET FILTER TO
SET ORDER TO
GO TOP


DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   SCATTER MEMVAR MEMO
   cSql = "select * from " + _V_NOMSQL + " where 1=0"
   IF !ExecRW(cSql,_V_NOMSQL,"R")
      SET DEFAULT TO &V_SONOQUI
      return(.f.)
   ENDIF
   SELECT &_V_NOMSQL
   APPEND BLANK
   IF _V_NOMSQL = 'U_FOR_AN'
      DO X_FOR_AN
   ELSE
      IF _V_NOMSQL = 'U_AZI_AN'
         DO X_AZI_AN
      ELSE
         DO &_V_NOMSQL
      ENDIF
   ENDIF
   IF !ExecRW(cSql,_V_NOMSQL,"W")
      SET DEFAULT TO &V_SONOQUI
      return
   ENDIF
   SELECT 1 && DATABASE INPUT _V_NOMDBF 
   SKIP +1
ENDDO

SET DEFAULT TO &V_SONOQUI



RETURN(.T.)


