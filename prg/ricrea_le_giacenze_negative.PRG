*********************************************************************************
*      			PROCEDURA PER RICREARE LE GIACENZE NEGATIVE	    				*
*********************************************************************************
*!*	RICREATUTTE LE GIAGENZE NEGATIVE GENERATE DOPO L'INVENTARIO DEL 24/08/2012


RIT = MESSAGEBOX("Procedo con la ricreazione  "+CHR(13)+"delle GIACENZE NEGATIVE ?",292,"ATTENZIONE")
IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF


*!*	**##################################################################################################################### U_MAG_GG ##########################
 
 
WAIT WINDOWS "Giacenze di magazzino in elaborazione "  nowait


Csql = "select * from u_mag_gg where 1=0"
IF !ExecRW(Csql,"u_mag_gg","R")
	return(.f.)
ENDIF


x_cond = "MAG_GIACEN < 0"  
cSql   = "DELETE FROM U_MAG_GG where " + x_cond
IF !ExecCommand(cSql,"jU_MAG_GG")
   RETURN .F.
ENDIF





*!*	*!*	SOLO LE GIAGENZE NEGATIVE GENERATE DOPO L'INVENTARIO DEL 24/08/2012 PER ARTICOLO XXXXX

*!*	cSql=""     
*!*	cNomeCursorSql="Gn_U_MAG_MO"
*!*	*!*	_ANAART____ = '438A2S100000001'			
*!*	_ANAART____ = '135A2B300000001'		

*!*	TEXT TO cSql NOSHOW
*!*		SELECT * FROM U_MAG_MO
*!*		WHERE 
*!*		MOV_TOP = 'M++' AND 
*!*		MOV_DOCMOD = 0 AND 
*!*		MOV_DTREGI >= '2012/08/24' AND
*!*		MOV_ANAART = '<<_ANAART____>>' AND
*!*		MOV_LEGAME IN (SELECT MOV_LEGAME FROM U_MAG_MO WHERE MOV_TOP = '001') 
*!*		ORDER BY MOV_DTREGI,MOV_ORAMOV
*!*	ENDTEXT




*!*	TUTTE LE GIAGENZE NEGATIVE GENERATE DOPO L'INVENTARIO DEL 24/08/2012

cSql=""     
cNomeCursorSql="Gn_U_MAG_MO"

TEXT TO cSql NOSHOW
	SELECT * FROM U_MAG_MO
	WHERE 
	MOV_TOP = 'M++' AND 
	MOV_DOCMOD = 0 AND 
	MOV_DTREGI >= '2012/08/24' AND
	MOV_LEGAME IN (SELECT MOV_LEGAME FROM U_MAG_MO WHERE MOV_TOP = '001') 
	ORDER BY MOV_DTREGI,MOV_ORAMOV
ENDTEXT




IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF		





PUBLIC V_CONTA
V_CONTA = 0

SELECT Gn_U_MAG_MO
GO TOP

DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF
   

    SCATTER MEMVAR MEMO

    __ID_UNIQUE___ = ID_UNIQUE
    
	=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
	

	  ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODMAT = ''
	  ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESMAT = ''
	  ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_TIPART = ''
	  _X_UMMAGA = ''
	  _X_ALTEZZ = 0
	  _X_LUNGHE = 0
	  _X_IVA    = ''
	  _X_CODM   = ''
	  _X_SPESSO = 0
	  
	  x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
	  x_codi = "ART_CODPRI = '" + M.MOV_ANAART + "'"
	  x_cond = x_soci + " and " + x_codi
	  cSql = "SELECT ART_CODPRI,ART_DESCR,ART_UNIMIS,ART_UMMAGA,ART_SPESSO,ART_MAGA,ART_TIPART,ART_CODCOL,ART_ALTEZZ,ART_LUNGHE,ART_CODIVA,ART_PRZCOS,ART_PRZVEN,ART_UNIMIS,ART_UMMAGA,ART_COORD,ART_CODMAT,ART_DESMAT,ART_CODIMB,ART_DESIMB,ART_CODF1  FROM U_ART_PR WHERE " + x_cond
	  IF !ExecCommand(cSql,"CjX_ART_PR")
		 return(.f.)
	  ENDIF
	  SELECT CjX_ART_PR
	  GO TOP
	  IF !EOF()
			_X_DESART  = ALLTRIM(ART_DESCR)
			_X_UNIMIS  = ART_UNIMIS
			_X_UMMAGA  = ART_UMMAGA
			_X_CODCOL  = ART_CODCOL
			_X_ALTEZZ  = ART_ALTEZZ
			_X_LUNGHE  = ART_LUNGHE
			_X_SPESSO  = ART_SPESSO
	        _X_IVA	   = ART_CODIVA
	        _X_CODM    = ART_MAGA
	        AQM_DESART = ART_DESCR
	        ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_TIPART = ART_TIPART
		   	ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_PREACQ = ART_PRZCOS 
		   	ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_PREVEN = ART_PRZVEN
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_UNIMIS = ART_UNIMIS
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_UNMAGA = ART_UMMAGA 
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_COORD  = ART_COORD 
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODMAT = ART_CODMAT
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESMAT = ART_DESMAT
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODIMB = ART_CODIMB
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESIMB = ART_DESIMB
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODFOR = ART_CODF1
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESFOR = ""
	  ENDIF


	
	AQM_GIANEG 	= .T.
	AQM_DATAGG 	= RIBALTA2(DTOC(DATE()))
	AQM_ORACAR 	= TIME()							&& ORA 1° CARICO DELLA GIACENZA CHE STO MOVIMENTANDO


	**AQM_NUMERO_LOTTO_INTERNO(M.MOV_ANAART)
	AQM_ANAART 	= M.MOV_ANAART
	AQM_CODART 	= M.MOV_ANAART
	AQM_DESART	= M.MOV_DESART
	AQM_CODMAG	= _X_CODM    
	AQM_GIACEN	= M.MOV_QTAMOV * -1
	AQM_SPESSO	= _X_SPESSO  
	AQM_ALTEZZ	= _X_ALTEZZ  
	AQM_LUNGHE	= _X_LUNGHE
	AQM_QTAKG	= 0
	AQM_QTAMQ	= 0
	AQM_QTAML	= 0
	AQM_QTAMC  	= 0
	AQM_QTANR  	= 0
	
	X_TIPO = CERCATIPO(M.MOV_ANAART)
	
	
	AQM_LEGSYS	= SYS(2015)
	AQM_LEGAME	= SYS(2015)
	AQM_NUMIDE  = AQM_NEW_NUMIDE()
	AQM_UNIQUE  = SYS(2015)
	=AQM_NUMERO_LOTTO_INTERNO(AQM_ANAART) 
	

	SELECT U_MAG_GG

	APPEND BLANK


	REPLACE MAG_GIANEG WITH AQM_GIANEG  
	 	
	REPLACE MAG_CODSOC WITH PUB_CODSOC
	REPLACE MAG_DATAGG WITH AQM_DATAGG  && ERASMO - 11/05/2011 - LA VARIABILE AQM_DATAGG E' GIA' NEL FORMATO 'AAAA/MM/GG'
	REPLACE MAG_ORACAR WITH AQM_ORACAR	&& ORA 1° CARICO DELLA GIACENZA CHE STO CREANDO
	REPLACE MAG_ANAART WITH AQM_ANAART  && ERASMO - 11/05/2011 - MANCAVA IL CODICE ARTICOLO ANAGRAFICO
	REPLACE MAG_CODART WITH AQM_CODART 
	REPLACE MAG_DESART WITH AQM_DESART
	REPLACE MAG_CODMAG WITH AQM_CODMAG
	REPLACE MAG_CODPDV WITH AQM_CODPDV 
	REPLACE MAG_FORNIT WITH AQM_CODFOR
	REPLACE MAG_DESFOR WITH AQM_DESFOR 

	REPLACE MAG_GIACEN WITH AQM_GIACEN

	REPLACE MAG_SPESSO WITH AQM_SPESSO
	REPLACE MAG_ALTEZZ WITH AQM_ALTEZZ
	REPLACE MAG_LUNGHE WITH AQM_LUNGHE

	REPLACE MAG_QTAKG  WITH AQM_QTAKG	
	REPLACE MAG_QTAMQ  WITH AQM_QTAMQ	
	REPLACE MAG_QTAML  WITH AQM_QTAML
	REPLACE MAG_QTAMC  WITH AQM_QTAMC  && ERASMO - 13/06/2012
	REPLACE MAG_QTANR  WITH AQM_QTANR  && SERGIO - 05/09/2012


	REPLACE MAG_QTAIMP WITH AQM_QTAIMP	 
	REPLACE MAG_GMLIMP WITH AQM_GMLIMP 	
	REPLACE MAG_GKGIMP WITH AQM_GKGIMP 	



	REPLACE MAG_PRZCON WITH AQM_PRZCON
	REPLACE MAG_LEGSYS WITH AQM_LEGSYS
	REPLACE MAG_LEGAME WITH AQM_LEGAME
	REPLACE MAG_PRZUFF WITH AQM_PRZCON
	REPLACE MAG_NUMIDE WITH AQM_NUMIDE	
	REPLACE MAG_SC1    WITH AQM_SC1
	REPLACE MAG_SC2    WITH AQM_SC2
	REPLACE MAG_SC3    WITH AQM_SC3
	REPLACE MAG_UNIQUE WITH AQM_UNIQUE  && ?????
	REPLACE MAG_ANNO   WITH PUB_ANNO


	REPLACE MAG_CODMAT WITH AQM_CODMAT
	REPLACE MAG_DESMAT WITH AQM_DESMAT
	REPLACE MAG_CODCOL WITH AQM_CODCOL
	REPLACE MAG_DESCOL WITH AQM_DESCOL
	REPLACE MAG_TIPART WITH ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_TIPART
	REPLACE MAG_NRLINT WITH AQM_NRLINT  && ERASMO - 11/05/2011
	REPLACE MAG_NRDBOB WITH AQM_NRDBOB


	REPLACE MAG_AAPROD WITH AQM_AAPROD  
	REPLACE MAG_SERBOL WITH AQM_SERBOL 
	REPLACE MAG_SERNUM WITH AQM_SERNUM 
	REPLACE MAG_NUMEDA WITH AQM_NUMEDA 
	REPLACE MAG_NUMEAL WITH AQM_NUMEAL 
	REPLACE MAG_CBFISC WITH AQM_CBFISC 

	REPLACE MAG_SERIE  WITH AQM_SERIE
	REPLACE MAG_FILA_X WITH AQM_FILA_X
	REPLACE MAG_PIAN_X WITH AQM_PIAN_X
	REPLACE MAG_UBIC_X WITH AQM_UBIC_X
	REPLACE MAG_FILA_N WITH AQM_FILA_N
	REPLACE MAG_PIAN_N WITH AQM_PIAN_N
	REPLACE MAG_UBIC_N WITH AQM_UBIC_N

	REPLACE MAG_CDAFOR WITH AQM_CDAFOR
	REPLACE MAG_OINFOR WITH AQM_OINFOR
	REPLACE MAG_PINFOR WITH AQM_PINFOR
	=CAMBIADT(AQM_DTPFOR,"MAG_DTPFOR")
	REPLACE MAG_TRAFOR WITH AQM_TRAFOR
	REPLACE MAG_NBAFOR WITH AQM_NBAFOR
	REPLACE MAG_BDAFOR WITH AQM_BDAFOR
	REPLACE MAG_BALFOR WITH AQM_BALFOR
	REPLACE MAG_PNKFOR WITH AQM_PNKFOR

	REPLACE MAG_QUAPRO WITH AQM_QUAPRO 				&& SERGIO 06/08/2012
	REPLACE MAG_CLIENT WITH AQM_CLIINV 				&& SERGIO 06/08/2012	&& PRODUZIONE PER CLIENTE RILEVATA DA INVENTARIO

	IF X_TIPO = '1'  && BOBINE

		REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL(AQM_ALTEZZ,AQM_LUNGHE,1)
		REPLACE MAG_QTAML WITH TROVA_ML_DA_LU(AQM_LUNGHE,1)
		REPLACE MAG_QTAKG WITH TROVA_KG_DA_MQ(M.MOV_ANAART,AQM_SPESSO,AQM_GIACEN,1)

	ENDIF
	
	IF X_TIPO = '3'  && MANICOTTI
		IF ALLTRIM(_X_UMMAGA) == "NR"
			REPLACE MAG_QTAML WITH AQM_GIACEN * AQM_ALTEZZ / 1000
		ENDIF
	ENDIF
	
	IF X_TIPO = '6'  && PANNELLI TRUCIOLARI
		X_QTANR = 0
		DO CASE
			CASE ALLTRIM(_X_UMMAGA) == "MQ"
				X_QTANR = TROVA_NR_DA_MQ_LEGNO(AQM_ALTEZZ,AQM_LUNGHE,AQM_GIACEN)
			CASE ALLTRIM(_X_UMMAGA) == "MC"
				X_QTANR = TROVA_NR_DA_MC_LEGNO(AQM_ALTEZZ,AQM_LUNGHE,AQM_GIACEN,AQM_SPESSO)
		ENDCASE
		REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL_LEGNO(AQM_ALTEZZ,AQM_LUNGHE,X_QTANR)
		REPLACE MAG_QTAML WITH TROVA_ML_DA_LU(AQM_LUNGHE,X_QTANR)
		REPLACE MAG_QTAKG WITH 0
		REPLACE MAG_QTAMC WITH TROVA_MC_DA_AL_LEGNO(AQM_ALTEZZ,AQM_LUNGHE,X_QTANR,AQM_SPESSO) 
	ENDIF


	IF X_TIPO = '8'  
		IF ALLTRIM(_X_UMMAGA) == "NR"
			REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL(AQM_ALTEZZ,AQM_LUNGHE,AQM_GIACEN)
		ENDIF
	ENDIF

	*!*	CANCELLA IL MOVIMENTO M++ CHE HA GENERATO LA GIACENZA NEGATIVA
	x_cond = "ID_UNIQUE = '" + ALLTRIM(__ID_UNIQUE___) + "'"
	cSql   = "DELETE FROM U_MAG_MO where " + x_cond
	IF !ExecCommand(cSql,"DEL_U_MAG_MO")
	   RETURN .F.
	ENDIF

 
    V_CONTA = V_CONTA + 1
    WAIT WINDOWS "RECORDS AGGIORNATI : "+STR(V_CONTA,10,0) NOWAIT
   
    SELECT Gn_U_MAG_MO
    SKIP +1
   
ENDDO

IF !ExecRW(cSql,"U_MAG_GG","W")							
   return(.f.)
ENDIF


=MESSAGEBOX("Operazione terminata correttamente ",62,"ATTENZIONE")

RETURN


