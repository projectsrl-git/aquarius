
LOCAL _V_DATAAL

*** PROPONGO DI DEFAULT 2 MESI PRECEDENTI
_nAnno = VAL(SUBSTR(DTOC(DATE()),7,4))
_nMese = VAL(SUBSTR(DTOC(DATE()),4,2))
_nMese = _nMese - 2
IF _nMese = 0
	_nMese = 12
	_nAnno = _nAnno - 1
ELSE
	IF _nMese = -1
		_nMese = 11
		_nAnno = _nAnno - 1
	ENDIF
ENDIF
_Anno = TRC(4,ALLTRIM(STR(_nAnno,4,0)))
_Mese = TRC(2,ALLTRIM(STR(_nMese,2,0)))
_V_DATAAL = DATA_FINE_MESE(_Mese + "/" + _Anno)

_V_DATAAL = PJ_INPUTBOX("Inserire la data fino alla quale eliminare i programmi","Selezione data sfoltimento Al",_V_DATAAL)
IF EMPTY(_V_DATAAL)
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF
IF VALID_DATA(_V_DATAAL)
   _V_DATAAL=OK_DATA(_V_DATAAL)       
ELSE
	MESSAGEBOX('Data non valida',64,'*** ATTENZIONE ***') 
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF


_N_PROGRAMMI_DA_SFOLTIRE = 0

*cSql = "SELECT COUNT(*) AS CONTA_PRG FROM PRODUZIONE WHERE PARENT = '' AND FLGCLOSED = 1 AND DATPRG <= '" + RIBALTA2(_V_DATAAL) + "'"
*!*	cSql = "SELECT COUNT(*) AS CONTA_PRG FROM PRODUZIONE WHERE PARENT = '' AND DATPRG <= '" + RIBALTA2(_V_DATAAL) + "' AND " + ;
*!*	       "(FLGCLOSED = 1 OR IDPRG NOT IN (SELECT IDPRG FROM PROD_AVANZA WHERE QTAPROD < QTA))"  && ERASMO - 17/04/2020 - PROGRAMMI CHIUSI O TERMINATI
**=> ERASMO - INIZIO 28/01/2021
*** PROGRAMMI CHIUSI O TERMINATI COMPLETAMENTE EVASI
_WHERECONDITION = "PARENT = '' AND DATPRG <= '" + RIBALTA2(_V_DATAAL) + "' AND (FLGCLOSED = 1 OR IDPRG NOT IN (SELECT IDPRG FROM PROD_AVANZA WHERE QTAPROD < QTA)) AND " + ;
	"IDPRG NOT IN (SELECT IDPRG FROM PROD_CARICHI WHERE MAG_UNIQUE IN (SELECT MAG_UNIQUE FROM U_MAG_GG))"
cSql = "SELECT COUNT(*) AS CONTA_PRG FROM PRODUZIONE WHERE " + _WHERECONDITION
**=> ERASMO - FINE 28/01/2021
IF !ExecCommand(cSql,"TMP_CONTA_PRG")
   return(.f.)
ENDIF
SELECT TMP_CONTA_PRG
GO TOP

_N_PROGRAMMI_DA_SFOLTIRE = CONTA_PRG

IF _N_PROGRAMMI_DA_SFOLTIRE > 0
ELSE
	MESSAGEBOX("Nessun programma chiuso da sfoltire per la data selezionata",48,"Attenzione")
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF

*_RISP = MESSAGEBOX("Continuare con lo sfoltimento di " + ALLTRIM(STR(_N_PROGRAMMI_DA_SFOLTIRE,10,0)) + " programmi di produzione chiusi?",4+32+256,"Attenzione")
_RISP = MESSAGEBOX("Continuare con lo sfoltimento di " + ALLTRIM(STR(_N_PROGRAMMI_DA_SFOLTIRE,10,0)) + " programmi di produzione chiusi o terminati?",4+32+256,"Attenzione")  && ERASMO - 17/04/2020 - PROGRAMMI CHIUSI O TERMINATI
IF _RISP = 6
ELSE
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF

WAIT WINDOWS "Sfoltimento tabelle di produzione in corso..." NOWAIT

*cSql = "DELETE FROM PRODUZIONE WHERE IDPRG IN (SELECT IDPRG FROM PRODUZIONE WHERE PARENT = '' AND FLGCLOSED = 1 AND DATPRG <= '" + RIBALTA2(_V_DATAAL) + "')"
*!*	cSql = "DELETE FROM PRODUZIONE WHERE IDPRG IN (SELECT IDPRG FROM PRODUZIONE WHERE PARENT = '' AND DATPRG <= '" + RIBALTA2(_V_DATAAL) + "' AND " + ;
*!*	       "(FLGCLOSED = 1 OR IDPRG NOT IN (SELECT IDPRG FROM PROD_AVANZA WHERE QTAPROD < QTA)))"  && ERASMO - 17/04/2020 - PROGRAMMI CHIUSI O TERMINATI
**=> ERASMO - INIZIO 28/01/2021
*** ELIMINAZIONE PROGRAMMI CHIUSI O TERMINATI COMPLETAMENTE EVASI
cSql = "DELETE FROM PRODUZIONE WHERE IDPRG IN (SELECT IDPRG FROM PRODUZIONE WHERE " + _WHERECONDITION + ")"
**=> ERASMO - FINE 28/01/2021
IF !ExecCommand(cSql,"DEL_PRODUZIONE")
   return(.f.)
ENDIF

cSql = "DELETE FROM PROD_AVANZA WHERE IDPRG NOT IN (SELECT IDPRG FROM PRODUZIONE)"
IF !ExecCommand(cSql,"DEL_PROD_AVANZA")
   return(.f.)
ENDIF

cSql = "DELETE FROM PROD_CARICHI WHERE IDPRG NOT IN (SELECT IDPRG FROM PRODUZIONE)"
IF !ExecCommand(cSql,"DEL_PROD_CARICHI")
   return(.f.)
ENDIF

cSql = "DELETE FROM PROD_ORDINI WHERE IDPRG NOT IN (SELECT IDPRG FROM PRODUZIONE)"
IF !ExecCommand(cSql,"DEL_PROD_ORDINI")
   return(.f.)
ENDIF

cSql = "DELETE FROM PROD_PACKING WHERE IDPRG NOT IN (SELECT IDPRG FROM PRODUZIONE)"
IF !ExecCommand(cSql,"DEL_PROD_PACKIN")
   return(.f.)
ENDIF


WAIT CLEAR 


MESSAGEBOX("Operazione terminata: " + ALLTRIM(STR(_N_PROGRAMMI_DA_SFOLTIRE,10,0)) + " programmi di produzione eliminati",64,"Informazione")

RETURN .T.


 