
LPARAMETERS _COMANDO_PRECEDENTE

_old_sele=select()

if !file("LOG_OBJOPEN.DBF")
  create dbf LOG_OBJOPEN free (DATA C(10), ORA C(08), OPERATORE C(10), CMD_PREC C(254), LISTA_OBJ M)
  select LOG_OBJOPEN 
  use
ENDIF

IF !USED("LOG_OBJOPEN")
   USE LOG_OBJOPEN IN 0 AGAIN
ENDIF

_LISTA_OBJ = ""

FOR _FrmIndex = 1 TO _SCREEN.FORMCOUNT
   _Form_Name = _SCREEN.FORMS(_FrmIndex).Name
   _Form_Caption = _SCREEN.FORMS(_FrmIndex).Caption
   
   IF EMPTY(ALLTRIM(_LISTA_OBJ))
   ELSE
      _LISTA_OBJ = _LISTA_OBJ + CHR(13)
   ENDIF
   _LISTA_OBJ = _LISTA_OBJ + "Nome form: " + _Form_Name + " ### Caption: " + _Form_Caption
NEXT

SELECT LOG_OBJOPEN
SET FILTER TO
SET ORDER TO
GO TOP

APPEND BLANK
REPLACE DATA WITH DTOC(DATE())
REPLACE ORA WITH TIME()
REPLACE OPERATORE WITH PUB_CODOPE
REPLACE CMD_PREC WITH _COMANDO_PRECEDENTE
REPLACE LISTA_OBJ WITH _LISTA_OBJ

SELECT LOG_OBJOPEN
USE

select(_old_sele)
