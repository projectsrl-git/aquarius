************************************
* CHECK_LIST_IMPEGNI_SPEDIZIONE
************************************

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO,V_GIORNI_PRECEDENTI
PUBLIC V_TITOLO,V_GIORNI_PRECEDENTI

V_TITOLO = "Check list di controllo articoli con impegni di magazzino per spedizione"

WAIT WINDOWS "ESEGUE PROGRAMMA CHECK_LIST_IMPEGNI_SPEDIZIONE" TIMEOUT 3
 
cSql=""     
cNomeCursorSql="CU_IMPEGNI"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

	SELECT
		PR.ART_CODPRI AS CODART,
		PR.ART_DESCR AS DESART,
		PR.ART_UMMAGA AS UM,
		COALESCE(GG.MAG_CODMAG,'') AS CODMAG,
		COALESCE(GG.MAG_SERIAL,'') AS LOTTO,
		COALESCE(GG.MAG_DATAGG,'') AS DATA,
		COALESCE(GG.MAG_GIACEN,0) AS GIACEN,
		COALESCE(GG.MAG_QTAIMP,0) AS QTAIMP,
		CAST(coalesce(stuff((SELECT DISTINCT CHAR(10) + '- ' + ORD_NUMORD + ' del ' + dbo.ribalta2(ORD_DATORD) + ' di ' + RTRIM(ORD_RAGSOC)
	        FROM U_ORD_IM
			LEFT OUTER JOIN U_ORD_TT ON U_ORD_TT.TAGGANCIO = U_ORD_IM.DAGGANCIO
			WHERE U_ORD_IM.MAG_UNIQUE = GG.MAG_UNIQUE AND U_ORD_IM.FLGEV = 0
	        for xml path('')
	    ),1,1,''),'') AS nvarchar(254)) AS ORDIMP
	FROM U_ART_PR AS PR
	LEFT OUTER JOIN U_ART_AN AS AN ON AN.ART_CODPRI = PR.ART_CODPRI
	LEFT OUTER JOIN U_MAG_GG AS GG ON GG.MAG_ANAART = PR.ART_CODPRI
	WHERE AN.ART_IMPSPE = 1 AND AN.ART_CODTSN = 'LOT'
	ORDER BY PR.ART_CODPRI,COALESCE(GG.MAG_DATAGG,'')
	
ENDTEXT					&& FINE SCRITTURA QUERY           


IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT CU_IMPEGNI
GO TOP

FILE_PDF_APPENA_GENERATO = ""

_PDF_REPORT_		= ALLTRIM(CERCAREPO("XXX","CHECK_LIST_IMPEGNI_SPEDIZIONE","CHECK_LIST_IMPEGNI_SPEDIZIONE.FRX"))
_PDF_DESCRIZIONE_	= STRTRAN(V_TITOLO,'/','-')+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "CU_IMPEGNI"

IF !EMPTY(_PDF_SUBDIR_)
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 



_ERRORE =.F.
*DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
