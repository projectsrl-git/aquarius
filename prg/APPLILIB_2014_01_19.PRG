	PROCEDURE MouseEnter
	
		LPARAMETERS nButton, nShift, nXCoord, nYCoord

		*this.BorderStyle = 1
		THISFORM.container1.shape2.BorderWidth = 2
		
		THIS.Parent.label1.FontBold = .T.
		
		*THIS.Parent.label1.ForeColor = RGB(255,0,0)
		
	ENDPROC


	PROCEDURE Click
	
		RELEASE THISFORM
		
	ENDPROC

ENDDEFINE
