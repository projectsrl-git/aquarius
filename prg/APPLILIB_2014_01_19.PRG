      REPLACE NUD_DESFOR WITH SPACE(50)
      REPLACE NUD_LUNGHE WITH 0
      REPLACE NUD_UNITAM WITH SPACE(03)
      REPLACE NUD_QTAMQ  WITH 0
      REPLACE NUD_QTAKG  WITH 0
      REPLACE NUD_CODINT WITH SPACE(16)
