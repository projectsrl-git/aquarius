      REPLACE ORF_QTADSP WITH M.ORD_QTAORD
      REPLACE ORF_CODMIT WITH PUB_CLISOC
      REPLACE ORF_RAGMIT WITH PUB_RAGSOC
      REPLACE ORF_CDFORN WITH XYZ_FORNIT
      REPLACE ORF_DSFORN WITH XYZ_RAGFOR
      IF !ExecRW(Csql,"U_BOL_RE","W")
