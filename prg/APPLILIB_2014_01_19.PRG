PROCEDURE PRORICA4
***************************************************************************

M.G099  = TMATU2				&&  12/06/2003
M.G100  = TMATU
M.G101  = 0.0
M.G103  = 0.0
M.G106  = 0.0
M.G107  = 0.0
M.G108  = 0.0
M.G110  = 0.0
M.E112  = 0.0
M.E114  = 0.0
M.E115  = 0.0
M.E117  = 0.0
M.E119  = 0.0
M.E121  = 0.0
M.E122  = 0.0
M.E123  = 0.0
M.E125  = 0.0
M.E126  = 0.0
M.E129  = M.MDC_PERIVC
M.E131  = 0.0
M.E121B = 0.0
M.G70   = M.MDC_QTFIHH
M.G71   = M.MDC_PERCEN
M.G72   = M.MDC_RAPCST
