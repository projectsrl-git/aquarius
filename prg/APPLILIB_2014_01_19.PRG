REPLACE SEL_CDDIBA WITH SPACE(16)
REPLACE SEL_PROGRE WITH RIB1_PROGRE
REPLACE SEL_SCARTO WITH .F.
REPLACE SEL_ALTCOM WITH 99999 - SEL_ALTMAG
REPLACE SEL_CODSYS WITH SPACE(10)
REPLACE SEL_LUNPRG WITH RIB1_LUNMAG
REPLACE SEL_MISTAG WITH ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
REPLACE SEL_FLGELA WITH .F.
REPLACE SEL_PROSUC WITH 999999
REPLACE SEL_NUMLOT WITH RIB1_NRLINT

*REPLACE SEL_LUNPRG WITH SEL_LUNMAG FOR SEL_PROGRE = RIB1_PROGRE
REPLACE SEL_LUNPRG WITH SEL_LUNMAG FOR SEL_NUMLOT = RIB1_NRLINT

RETURN



***************************************************************************
PROCEDURE ribobinatura_trovato
***************************************************************************

SELECT RIN_RIBOBINATURA
ZAP

SELECT CUR_RIBOBINATURA

V_LUNRESTANTE  = RIB1_LUNMAG - RIB1_LUNPRG
RIB2_PROGRE    = SEL_PROGRE
RIB2_PROSUC    = RIB1_PROSUC + 1

IF V_LUNRESTANTE < SEL_LUNPRG
   V_NUMBOBINE = INT((V_LUNRESTANTE / SEL_LUNGHE))

   IF V_NUMBOBINE > 0
   ELSE
      REPLACE SEL_FLGELA WITH .T.
      RETURN
   ENDIF

   RIB2_LUNPRG = 0

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF SEL_PROGRE = RIB2_PROGRE
      ELSE
         EXIT
      ENDIF

      REPLACE SEL_BOBPRG WITH SEL_BOBPRG - V_NUMBOBINE
      REPLACE SEL_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTMAG,SEL_LUNGHE,SEL_BOBPRG)
      REPLACE SEL_MISTAG WITH ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      SELECT CUR_RIBOBINATURA
      REPLACE SEL_LUNPRG WITH SEL_LUNGHE * SEL_BOBPRG
      SCATTER MEMVAR MEMO

      SELECT RIN_RIBOBINATURA
      APPEND BLANK
      GATHER MEMVAR MEMO

      REPLACE SEL_PROGRE WITH RIB1_PROGRE
      REPLACE SEL_BOBPRG WITH V_NUMBOBINE
      REPLACE SEL_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTMAG,SEL_LUNGHE,SEL_BOBPRG)
      REPLACE SEL_MISTAG WITH ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      SELECT RIN_RIBOBINATURA
      REPLACE SEL_LUNPRG WITH SEL_LUNGHE * SEL_BOBPRG
      REPLACE SEL_PROSUC WITH RIB2_PROGRE

      RIB2_LUNPRG = SEL_LUNPRG

      SELECT CUR_RIBOBINATURA
      SKIP +1

   ENDDO

   SELECT RIN_RIBOBINATURA
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      SCATTER MEMVAR MEMO
      SELECT CUR_RIBOBINATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      SELECT RIN_RIBOBINATURA
      SKIP +1
   ENDDO

   V_LUNBOBINE = RIB1_LUNPRG + RIB2_LUNPRG

ELSE

   V_LUNBOBINE = RIB1_LUNPRG + SEL_LUNPRG
   REPLACE SEL_PROSUC WITH RIB2_PROGRE FOR SEL_PROGRE = RIB2_PROGRE ALL
   REPLACE SEL_PROGRE WITH RIB1_PROGRE FOR SEL_PROGRE = RIB2_PROGRE ALL

ENDIF

REPLACE SEL_LUNPRG WITH V_LUNBOBINE FOR SEL_PROGRE = RIB1_PROGRE ALL

RIB1_PROSUC = RIB2_PROSUC

RETURN


***************************************************************************
PROCEDURE spalmatura_salamescole
***************************************************************************

*=> Determinazione delle quantitŕ in MQ da spalmare (tutta la bobina in altezza)
V_QTAMQS = TROVA_MQ_DA_AL(V_ALT,V_LUXPRG,1)

*=> Esplosione del Distinta base
SI_VIDEO = .F.
DO ALBERELLO  WITH SI_VIDEO,V_CDDIBA   && ESPLODE LA DISTINTA BASE A VIDEO

SELECT WEXPLODE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Dal primo livello (codice Di.Ba. salvo il codice e la descrizione del Distinta Base)
   IF WLIV = 1
      V_CPADRE = WCOD
      V_DPADRE = WDES
   ENDIF

   *=> Accesso alla anagrafica articoli dei singoli componenti per prelevare i seguenti campi :
   *=> - Unitŕ di misura
   *=> - Scorta minima
   *=> - Codice Imballo
   *=> - Descrizione Imballo
   *=> - Lotto minimo da ordinare
   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.WCOD) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articolo")
      return(.f.)
   ENDIF
   SELECT cur_articolo
   GO TOP
   IF EOF()
      V_UNITAM = 'NN'
      V_SCORMI = 0
      V_CODIMB = SPACE(03)
      V_DESIMB = SPACE(50)
      V_LOTMIN = 0
   ELSE
      V_UNITAM = ART_UNIMIS
      V_SCORMI = ART_SCORMI
      V_CODIMB = ART_CODIMB
      V_DESIMB = ART_DESIMB
      V_LOTMIN = ART_LOTMIN
   ENDIF

   *=> Scrittura del record nel cursore delle sala mescole
   SELECT CUR_SALAMESCOLE
   APPEND BLANK
   REPLACE SEL_CODART WITH M.WCOD
   REPLACE SEL_DESART WITH M.WDES
   REPLACE SEL_CDDIBA WITH V_CPADRE
   REPLACE SEL_DSDIBA WITH V_DPADRE
   REPLACE SEL_SCORMI WITH V_SCORMI
   REPLACE SEL_CODIMB WITH V_CODIMB
   REPLACE SEL_DESIMB WITH V_DESIMB
   REPLACE SEL_LOTMIN WITH V_LOTMIN
   REPLACE SEL_QTAGIA WITH 0
   REPLACE SEL_LIVELL WITH M.WLIV
   REPLACE SEL_QTADIB WITH V_QTAMQS
   REPLACE SEL_QTADOR WITH 0
   REPLACE SEL_UNITAM WITH V_UNITAM
   REPLACE SEL_PROGRE WITH V_PROGRE
   REPLACE SEL_QTANEC WITH M.WQTAT * V_QTAMQS				&& Qtŕ necessaria alla produzione

   SELECT WEXPLODE
   SKIP +1

ENDDO

RETURN


***************************************************************************
PROCEDURE taglio_rilevagglavorativi
***************************************************************************

RELEASE PUB_NUMSET,PUB_SETINI,PUB_SETFIN,PUB_DATINI,PUB_DATFIN
PUBLIC  PUB_NUMSET,PUB_SETINI,PUB_SETFIN,PUB_DATINI,PUB_DATFIN
PUB_NUMSET = V_SETIMP
PUB_SETINI = SPACE(07)
PUB_SETFIN = SPACE(07)
PUB_DATINI = DTOC(DATE())
PUB_DATFIN = SPACE(10)
V_PRIMA    = .T.
V_SETT     = SPACE(07)
IND_NUMSET = 0
V_ORELAV   = 0
V_ORAINI   = SPACE(08)

CREATE CURSOR SETTPROD (SET_CODICE C(03), SET_DESCRI C(50), SET_ORDINE N(2), SET_TIPO N(01),   ;
                        SET_DATA C(10),   SET_SETT C(07),   SET_ORELAV N(2), SET_ORAINI C(08), ;
                        SET_FATTO L(01))
INDEX ON SET_CODICE 										 TAG I_CODICE ADDITIVE
INDEX ON SET_DATA + STR(SET_TIPO,1,0) + STR(SET_ORDINE,2,0)	 TAG I_ORDINE ADDITIVE
INDEX ON SET_DATA + SET_CODICE								 TAG I_DATA   ADDITIVE

SELECT CU_CAL_LA
SET ORDER TO I_DATAMG
SET FILTER TO
SEEK RIBALTA2(PUB_DATINI)

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF IND_NUMSET > PUB_NUMSET
      EXIT
   ENDIF

   IF CAL_SETT = V_SETT
   ELSE
      V_SETT = CAL_SETT
      IND_NUMSET = IND_NUMSET + 1
      LOOP
   ENDIF

   IF CAL_LAVO
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF CAL_ORELAV > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF V_PRIMA
      V_PRIMA = .F.
      PUB_SETINI = CAL_SETT
      PUB_DATINI = CAL_DATA
   ENDIF

   PUB_SETFIN = CAL_SETT
   PUB_DATFIN = CAL_DATA
   V_ORELAV   = CAL_ORELAV
   V_ORAINI   = CAL_ORAINI

   SELECT CU_MAC_AN
   SET ORDER TO I_ORDINE
   GO TOP
   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF MAC_TIPO = 3	  					&& 2=TAGLIO  -  SOLO MACCHINE DI TAGLIO
      ELSE
         SKIP +1
         LOOP
      ENDIF

      IF ALLTRIM(SELEZIONE) = "=>"			&& MACCHINA SELEZIONATA
      ELSE
         SKIP +1
         LOOP
      ENDIF

      SCATTER MEMVAR MEMO

      V_TROVATO = .T.

      SELECT CU_PRO_IM
      SET FILTER TO
      SET ORDER TO I_IMPEGNI
      SEEK 'TAG' + M.MAC_CODICE + RIBALTA2(PUB_DATFIN)
      IF FOUND()
         IF IMP_ORELAV > IMP_OREIMP
         ELSE
            V_TROVATO = .F.
         ENDIF
      ENDIF

      SELECT SETTPROD
      APPEND BLANK
      REPLACE SET_CODICE WITH M.MAC_CODICE
      REPLACE SET_DESCRI WITH M.MAC_DESCRI
      REPLACE SET_ORDINE WITH M.MAC_ORDINE
      REPLACE SET_TIPO   WITH M.MAC_TIPO
      REPLACE SET_DATA   WITH RIBALTA2(PUB_DATFIN)
      REPLACE SET_SETT   WITH PUB_SETFIN
      REPLACE SET_ORELAV WITH V_ORELAV
      REPLACE SET_ORAINI WITH V_ORAINI
      IF V_TROVATO
         REPLACE SET_FATTO WITH .F.
      ELSE
         REPLACE SET_FATTO WITH .T.
      ENDIF

      SELECT CU_MAC_AN
      SKIP +1

   ENDDO

   SELECT CU_CAL_LA
   SKIP +1

ENDDO

RETURN


