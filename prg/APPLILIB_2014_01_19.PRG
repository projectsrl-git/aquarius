*************************************
PROCEDURE MANAGE_EMBEDDED_EMAIL_FILES
*************************************
PARAMETERS _name_var_HTML,_name_var_ATTACHMENTS

IF PCOUNT() >= 2
ELSE
	RETURN .F.
ENDIF

*** GESTISCO EVENTUALI IMMAGINI PRESENTI ALL'INTERNO DEL MESSAGGIO E-MAIL HTML COME ALLEGATI
*** ASSEGNANDO LORO UN RIFERIMENTO "CONTENT-ID" E TRACCIANDOLE NEL CURSORE "ATTCH_SIGN_FILES"
IF "<IMG " $ UPPER(&_name_var_HTML)
	CREATE CURSOR ATTCH_SIGN_FILES (NAME C(240), FULLNAME C(240), ID_FILE C(10))
	INDEX ON FULLNAME TAG I_FULLNAME
	_ESCI = .F.
	_NFILE = 1
	DO WHILE !_ESCI
		_NEW_ID_FILE = SYS(2015)
		_rgth_str = SUBSTR(&_name_var_HTML,AT('src="',&_name_var_HTML,_NFILE))
		_sign_file_strn = SUBSTR(_rgth_str,1,AT('"',_rgth_str,2))
		_signature_file = STRTRAN(STRTRAN(SUBSTR(_rgth_str,6,AT('"',_rgth_str,2)-6),'/','\'),'file:\\\','')
		IF FILE(_signature_file)
			&_name_var_HTML = STRTRAN(&_name_var_HTML,_sign_file_strn,'src="cid:'+_NEW_ID_FILE+'"',1,1)
			SELECT ATTCH_SIGN_FILES
			APPEND BLANK
			REPLACE NAME WITH JUSTFNAME(_signature_file)
			REPLACE FULLNAME WITH _signature_file
			REPLACE ID_FILE WITH _NEW_ID_FILE
			&_name_var_ATTACHMENTS = IIF(EMPTY(&_name_var_ATTACHMENTS),_signature_file,&_name_var_ATTACHMENTS + " ; " + _signature_file)
		ENDIF
		IF OCCURS('src="',_rgth_str) > 1
			_NFILE = _NFILE + 1
		ELSE
			_ESCI = .T.
		ENDIF
	ENDDO
ENDIF


RETURN


