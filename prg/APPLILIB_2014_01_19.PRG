      ENDIF
      SELECT &_testata
      IF reccount() <> 0
         REPLACE ORD_VALORE WITH M.ORD_VALORE
      ENDIF
      IF !ExecRW("",_testata,"W")
         return
      ENDIF
   ENDIF
*!*	ENDIF

