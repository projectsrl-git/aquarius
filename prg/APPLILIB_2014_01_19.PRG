   *SET ORDER TO I_INDICE1
   *SEEK O_CODMAT + O_CODCOL + STR(O_SPESSO,5,0) + STR(O_ALTEZZ,5,0) + STR(O_LUNGHE,6,0)
   SET ORDER TO I_INDICE4
   SEEK O_CODMAT + O_CODCOL + STR(O_SPESSO,5,0) + STR(O_ALTEZZ,5,0)
   IF FOUND()
      REPLACE MAG_GIACEN WITH MAG_GIACEN - XXX_QTAMQ
      REPLACE MAG_QTAKG  WITH MAG_QTAKG  - XXX_QTAKG
      REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  - XXX_QTAMQ
      REPLACE MAG_QTAML  WITH MAG_QTAML  - XXX_QTAML
      REPLACE MAG_LUNGHE WITH MAG_QTAML
   ENDIF

