*****************************************************************************************
* Procedura - trova_quantita_bfo_consegnate_da_orf     Data: 07/03/2008   Autore: Project
*****************************************************************************************
*
*  CREA IL CURSORE 'CUR_CONSEGNE' CHE CONTIENE IL DETTAGLIO DELLE QTA' CONSEGNATE
*
*  RESTITUISCE INOLTRE I TOTALE DELLE QTA' CONSEGNATE NELLE VARIE UNITA' DI MISURA
*
*****************************************************************************************
PROCEDURE trova_quantita_bfo_consegnate_da_orf
*****************************************************************************************

PARAMETERS _LEGSYS

RELEASE _CON_QTAORD,_CON_NUMBOB,_CON_QTAKG,_CON_QTAMQ,_CON_QTAML
PUBLIC  _CON_QTAORD,_CON_NUMBOB,_CON_QTAKG,_CON_QTAMQ,_CON_QTAML

_CON_QTAORD = 0
_CON_NUMBOB = 0
_CON_QTAKG  = 0
_CON_QTAMQ  = 0
_CON_QTAML  = 0

x_cond = "ord_legsys = '" + ALLTRIM(_LEGSYS) + "'"
*!*	Csql   = "select * from U_BFO_DD where " + x_cond + " order by ors_datord,ors_numord"
**=> ERASMO - INIZIO 14/11/2008
Csql   = "select * from U_BFO_DD " + ;
         "LEFT OUTER JOIN (SELECT TAGGANCIO,ORD_RIFERI AS ORS_RIFBFO FROM U_BFO_TT) AS TT ON U_BFO_DD.DAGGANCIO = TT.TAGGANCIO " + ;
         "where " + x_cond + " order by ors_datord,ors_numord"
**=> ERASMO - FINE 14/11/2008
IF !ExecCommand(cSql,"CUR_CONSEGNE")
   return(.f.)
ENDIF
SELECT CUR_CONSEGNE
GO TOP
SCAN
   x_agga = "daggancio = '" + DAGGANCIO + "'"
   x_lega = "dlegame = '" + ORD_CODSYS + "'"
   x_cond = x_agga + " and " + x_lega
   Csql   = "select COUNT(*) AS NUMBOB, SUM(ORD_QTAKG) AS QTAKG, SUM(ORD_QTAMQ) AS QTAMQ, SUM(ORD_QTAML) AS QTAML from U_BFO_DL where " + x_cond
   IF !ExecCommand(cSql,"TOT_PARZ_CONSEGNE")
      return(.f.)
   ENDIF
   SELECT TOT_PARZ_CONSEGNE
   GO TOP
   _X_NUMBOB = IIF(ISNULL(NUMBOB),0,NUMBOB)
   _X_QTAKG  = IIF(ISNULL(QTAKG),0,QTAKG)
   _X_QTAMQ  = IIF(ISNULL(QTAMQ),0,QTAMQ)
   _X_QTAML  = IIF(ISNULL(QTAML),0,QTAML)

   SELECT CUR_CONSEGNE
   REPLACE ORD_NUMBOB WITH _X_NUMBOB
   REPLACE ORD_QTAKG WITH _X_QTAKG
   REPLACE ORD_QTAMQ WITH _X_QTAMQ
   REPLACE ORD_QTAML WITH _X_QTAML
   _CON_QTAORD = _CON_QTAORD + ORD_QTAORD
   _CON_NUMBOB = _CON_NUMBOB + ORD_NUMBOB
   _CON_QTAKG  = _CON_QTAKG + ORD_QTAKG
   _CON_QTAMQ  = _CON_QTAMQ + ORD_QTAMQ
   _CON_QTAML  = _CON_QTAML + ORD_QTAML

   **=> ERASMO - INIZIO 14/11/2008
   IF EMPTY(ALLTRIM(ORS_RIFBFO))
      REPLACE ORS_RIFBFO WITH ORS_NUMORD
   ENDIF
   **=> ERASMO - FINE 14/11/2008

ENDSCAN

RETURN


*********************************************************************************************************
* Procedura - verifica_esistenza_programmi_confermati_interferenti     Data: 07/03/2008   Autore: Project
*********************************************************************************************************
*
*  CERCA L'ESISTENZA DI PROGRAMMI DI PRODUZIONE CONFERMATI CHE ABBIANO RANGE DATA INIZIO/FINE PRODUZIONE
*  INTERFERENTI CON QUELLE PASSATE NEI PARAMETRI
*
*  RESTITUISCE .T. OPPURE .F.
*
*****************************************************************************************
FUNCTION verifica_esistenza_programmi_confermati_interferenti
*****************************************************************************************

PARAMETERS _W_DTINI,_W_DTFIN,_W_PJ_BUT

IF PARAMETERS() < 2
   RETURN .F.
ENDIF

IF PARAMETERS() < 3
   _W_PJ_BUT = ""
ENDIF

IF SUBSTR(_W_DTINI,3,1) = "/"
   _W_DTINI = RIBALTA2(_W_DTINI)
ENDIF

IF SUBSTR(_W_DTFIN,3,1) = "/"
   _W_DTFIN = RIBALTA2(_W_DTFIN)
ENDIF

_RITORNO = .F.

x_cond = "pr1_staprg <> '001'"
IF EMPTY(ALLTRIM(_W_PJ_BUT))
ELSE
   x_cond = x_cond + " and pj_prgprd1 <> '" + ALLTRIM(_W_PJ_BUT) + "'"
ENDIF
Csql = "SELECT * FROM U_PRD_D1 where " + x_cond + " order by pj_prgprd1"
IF !ExecCommand(cSql,'CHECK_PRD_D1')
   return(.f.)
ENDIF
SELECT CHECK_PRD_D1
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   DT_INIZ = IIF(EMPTY(ALLTRIM(PR1_DTINEF)),PR1_DTINPR,PR1_DTINEF)
   DT_FINE = IIF(EMPTY(ALLTRIM(PR1_DTFIEF)),PR1_DTFIPR,PR1_DTFIEF)

   IF SUBSTR(DT_INIZ,3,1) = "/"
      DT_INIZ = RIBALTA2(DT_INIZ)
   ENDIF
   IF SUBSTR(DT_FINE,3,1) = "/"
      DT_FINE = RIBALTA2(DT_FINE)
   ENDIF

   IF (_W_DTINI >= DT_INIZ .AND. _W_DTINI <= DT_FINE) .OR. (_W_DTFIN >= DT_INIZ .AND. _W_DTFIN <= DT_FINE)
   ELSE
      DELETE
      SKIP +1
      LOOP
   ENDIF

   SELECT CHECK_PRD_D1
   SKIP +1
ENDDO

SELECT CHECK_PRD_D1
GO TOP
IF EOF()
ELSE
   _RITORNO = .T.
ENDIF

RETURN _RITORNO


**********************************************************************************************************************
* Procedura - stampa_congruenza_fatture_ddt											Data: 29/07/2008   Autore: Project
**********************************************************************************************************************
*
*  VERIFICA E STAMPA LE FATTURE GENERATE DA DDT INCONGRUENTI CON QUEST'ULTIME
*
*  ES.: DO stampa_congruenza_fatture_ddt WITH _V_CODCLN,_V_NORDDA,_V_NORDAL,_V_DORDDA,_V_DORDAL,_V_OPZCGR,_V_OPZGEN
*
*  DOVE: - _V_CODCLN = Codice cliente (SE = SPACE(10) OPPURE = "" CONSIDERA TUTTI I CLIENTI)
*        - _V_NORDDA = Numero Fattura Dal (OBBLIGATORIO)
*        - _V_NORDAL = Numero Fattura Al (OBBLIGATORIO)
*        - _V_DORDDA = Data Fattura Dal (FORMATO GG/MM/AAAA; OBBLIGATORIO)
*        - _V_DORDAL = Data Fattura Al (FORMATO GG/MM/AAAA; OBBLIGATORIO)
*        - _V_OPZCGR = Stampa anche le fatture congruenti (.T. oppure .F.; OBBLIGATORIO)
*        - _V_OPZGEN = Considera solo fatture generate da DDT (.T. oppure .F.; OBBLIGATORIO)
*
**********************************************************************************************************************
PROCEDURE stampa_congruenza_fatture_ddt
**********************************************************************************************************************

LPARAMETERS _ZX_CODCLN,_ZX_NORDDA,_ZX_NORDAL,_ZX_DORDDA,_ZX_DORDAL,_ZX_OPZCGR,_ZX_OPZGEN

IF PARAMETERS() < 7
   MESSAGEBOX("Parametri insufficienti per la funzione di verifica congruenza fatture/DDT!",16,"Attenzione")
   RETURN .F.
ENDIF

WAIT WINDOWS "Ricerca congruenza fatture/DDT in corso..." NOWAIT

RELEASE _X_FILTRI
PUBLIC  _X_FILTRI
_X_FILTRI = ""

IF EMPTY(ALLTRIM(_ZX_NORDDA))
ELSE
   _X_FILTRI = _X_FILTRI + " » N° fattura Dal: " + ALLTRIM(_ZX_NORDDA)
ENDIF
IF EMPTY(ALLTRIM(_ZX_NORDAL))
ELSE
   _X_FILTRI = _X_FILTRI + " » N° fattura Al: " + ALLTRIM(_ZX_NORDAL)
ENDIF
IF EMPTY(ALLTRIM(_ZX_DORDDA)) .OR. _ZX_DORDDA = "  /  /    "
ELSE
   _X_FILTRI = _X_FILTRI + " » Data fattura Dal: " + ALLTRIM(_ZX_DORDDA)
ENDIF
IF EMPTY(ALLTRIM(_ZX_DORDAL)) .OR. _ZX_DORDAL= "  /  /    "
ELSE
   _X_FILTRI = _X_FILTRI + " » Data fattura Al: " + ALLTRIM(_ZX_DORDAL)
ENDIF
IF EMPTY(ALLTRIM(_ZX_CODCLN))
ELSE
   _X_FILTRI = _X_FILTRI + " » Cliente: " + ALLTRIM(_ZX_CODCLN)
ENDIF
IF _ZX_OPZCGR
   _X_FILTRI = _X_FILTRI + " » Stampa anche le fatture congruenti"
ENDIF
IF EMPTY(ALLTRIM(_X_FILTRI))
ELSE
   _X_FILTRI = "FILTRI DI ELABORAZIONE " + _X_FILTRI
ENDIF

CREATE CURSOR CU_CONGRUENZA (NUMFAT C(06),  DATFAT C(10),  CODCLI C(10),  RAGSOC C(80),  CODART C(16),  DESART C(80),  UM C(03),  ;
                             ALTEZZ N(5,0), LUNGHE N(6,0), QTAFAT N(17,3), QTADDT N(17,3), NUMDDT C(06),  DATDDT C(10), NUMBOB N(10,0),  ;
                             SYSDDT C(10),  SEQUEN N(10),  NBBDDT N(10,0), UNIQUE_DDT C(36))
SELECT CU_CONGRUENZA
INDEX ON DATFAT+NUMFAT+STR(SEQUEN,10,0) TAG I_ORDER
INDEX ON NUMDDT+DATDDT+UNIQUE_DDT TAG I_CHKDDT

x_clie = IIF(EMPTY(ALLTRIM(_ZX_CODCLN)),"ord_codcli = ord_codcli","ord_codcli = '" + ALLTRIM(_ZX_CODCLN) + "'")
x_ordd = IIF(EMPTY(ALLTRIM(_ZX_NORDDA)),"ord_numord = ord_numord","ord_numord >= '" + ALLTRIM(_ZX_NORDDA) + "'")
x_orda = IIF(EMPTY(ALLTRIM(_ZX_NORDAL)),"ord_numord = ord_numord","ord_numord <= '" + ALLTRIM(_ZX_NORDAL) + "'")
x_dtda = IIF(EMPTY(ALLTRIM(_ZX_DORDDA)),"ord_datord = ord_datord","ord_datord >= '" + RIBALTA2(_ZX_DORDDA) + "'")
x_dtal = IIF(EMPTY(ALLTRIM(_ZX_DORDAL)),"ord_datord = ord_datord","ord_datord <= '" + RIBALTA2(_ZX_DORDAL) + "'")
x_cond = x_clie + " and " + x_ordd + " and " + x_orda + " and " + x_dtda + " and " + x_dtal
Csql = "select * from u_fat_tt where " + x_cond + " order by taggancio"
IF !ExecCommand(cSql,'CU_FAT_TT')
   return(.f.)
ENDIF
SELECT CU_FAT_TT
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   CREATE CURSOR ELENCO_DDT (NUMDDT C(06),  DATDDT C(10),  CODART C(16),  DESART C(80),  UM C(03),  ;
                             ALTEZZ N(5,0), LUNGHE N(6,0), QTADDT N(17,3),  NBBDDT N(10,0), ID_UNIQUE C(36))
   INDEX ON ID_UNIQUE TAG I_UNIQUE

   SELECT CU_FAT_TT
   SCATTER MEMVAR MEMO

   WAIT WINDOWS "Ricerca congruenza fatture/DDT in corso... - Elaborazione fattura N° " + ALLTRIM(M.ORD_NUMORD) + " del " + RIBALTA2(M.ORD_DATORD) NOWAIT

   x_agga = "daggancio = '" + M.TAGGANCIO + "'"
   x_comm = "ord_desart <> '*** COMMENTO ***'"
   x_cart = "ord_codart <> ''"
   x_poli = "substring(ord_codart,1,7) <> 'POLIECO'"
   x_qtao = "ord_qtaord > = 0"
   x_cond = x_agga + " and " + x_comm + " and " + x_cart + " and " + x_poli + " and " + x_qtao
   Csql = "select * from u_fat_dd where " + x_cond + " order by ord_sequen"
   IF !ExecCommand(cSql,'CU_FAT_DD')
      return(.f.)
   ENDIF
   SELECT CU_FAT_DD
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF DELETED()
         SKIP +1
         LOOP
      ENDIF

      IF _ZX_OPZGEN
         IF EMPTY(ALLTRIM(ORS_NUMDDT)) .OR. EMPTY(ALLTRIM(ORS_DATDDT))
            SELECT CU_FAT_DD
            SKIP +1
            LOOP
         ENDIF
      ENDIF

      SCATTER MEMVAR MEMO

      _NUMFAT = M.ORD_NUMORD
      _DATFAT = M.ORD_DATORD
      _CODCLI = M.ORD_CODCLI
      _RAGSOC = M.ORD_RAGSOC
      _CODART = M.ORD_CODART
      _DESART = M.ORD_DESART
      _UM     = M.ORD_UM
      _ALTEZZ = M.ORD_ALTEZZ
      _LUNGHE = M.ORD_LUNGHE
      _QTAFAT = ROUND(M.ORD_QTAORD,2)
      _QTADDT = 0
      _NUMDDT = M.ORS_NUMDDT
      _DATDDT = M.ORS_DATDDT
      _NUMBOB = M.ORD_NUMBOB
      _SYSDDT = M.ORS_SYSDDT
      _SEQUEN = M.ORD_SEQUEN
      _NBBDDT = 0
      _UNIQUE_DDT = ""

*!*	      *** RICERCA QTA' EVASA CON DDT
*!*	      x_nddt = IIF(EMPTY(ALLTRIM(_NUMDDT)) .OR. VAL(_NUMDDT) = 0,"ors_numord = ors_numord","ors_numord = " + _NUMDDT)
*!*	      x_dddt = "ors_datord = '" + _DATDDT + "'"
*!*	      x_cart = "ord_codart = '" + _CODART + "'"
*!*	      x_unim = "ord_um = '" + _UM + "'"
*!*	      x_alte = "ord_altezz = " + STR(_ALTEZZ,5,0)
*!*	      x_lung = "ord_lunghe = " + STR(_LUNGHE,6,0)
*!*	      x_comm = "ord_desart <> '*** COMMENTO ***'"
*!*	      x_lega = "ord_legsys = '" + _LEGSYS + "'"
*!*	      x_nrot = "ord_numbob = " + STR(_NUMBOB,10,0)
*!*	      x_cond = x_nddt + " and " + x_dddt + " and " + x_cart + " and " + x_unim + " and " + x_alte + " and " + x_lung + " and " + ;
*!*	               x_comm + " and " + x_lega + " and " + x_nrot

      *** RICERCA QTA' EVASA CON DDT
**** SIMONE - 30/04/2009 - INIZIO
*!*	      x_nddt = IIF(EMPTY(ALLTRIM(_NUMDDT)) .OR. VAL(_NUMDDT) = 0,"ors_numord = ors_numord","ors_numord = " + _NUMDDT)
*!*	      x_dddt = "ors_datord = '" + _DATDDT + "'"
*!*	      x_cart = "ord_codart = '" + _CODART + "'"
*!*	      x_unim = "ord_um = '" + _UM + "'"
*!*	      x_comm = "ord_desart <> '*** COMMENTO ***'"
*!*	      x_lega = "ors_sysfat = '" + _SYSDDT + "'"
*!*	      x_cond = x_nddt + " and " + x_dddt + " and " + x_cart + " and " + x_unim + " and " + x_comm + " and " + x_lega
      x_cart = "ord_codart = '" + _CODART + "'"
      x_unim = "ord_um = '" + _UM + "'"
      x_comm = "ord_desart <> '*** COMMENTO ***'"
      x_lega = "ors_sysfat = '" + _SYSDDT + "'"
      x_cond = x_cart + " and " + x_unim + " and " + x_comm + " and " + x_lega
**** SIMONE - 30/04/2009 - FINE
      Csql = "select * from u_bol_dd where " + x_cond
      IF !ExecCommand(cSql,'CU_BOL_DD')
         return(.f.)
      ENDIF
      SELECT CU_BOL_DD
      GO TOP
      SCAN
         _XX_UNIQUE_DDT = ID_UNIQUE
         SELECT CU_CONGRUENZA
         SET ORDER TO I_CHKDDT
         GO TOP
         _SEEK = _NUMDDT+_DATDDT+_XX_UNIQUE_DDT
         SEEK _SEEK
         IF FOUND()
            SELECT CU_BOL_DD
            LOOP
         ENDIF
         SELECT CU_CONGRUENZA
         SET ORDER TO

         SELECT CU_BOL_DD
         _QTADDT = ROUND(ORD_QTAORD,2)
         _NBBDDT = ROUND(ORD_NUMBOB,0)
         _UNIQUE_DDT = ID_UNIQUE
         EXIT
      ENDSCAN

      SELECT CU_CONGRUENZA
      APPEND BLANK

      REPLACE NUMFAT WITH _NUMFAT
      REPLACE DATFAT WITH _DATFAT
      REPLACE CODCLI WITH _CODCLI
      REPLACE RAGSOC WITH _RAGSOC
      REPLACE CODART WITH _CODART
      REPLACE DESART WITH _DESART
      REPLACE UM WITH _UM
      REPLACE ALTEZZ WITH _ALTEZZ
      REPLACE LUNGHE WITH _LUNGHE
      REPLACE QTAFAT WITH _QTAFAT
      REPLACE QTADDT WITH _QTADDT
      REPLACE NUMDDT WITH _NUMDDT
      REPLACE DATDDT WITH _DATDDT
      REPLACE SYSDDT WITH _SYSDDT
      REPLACE NUMBOB WITH _NUMBOB
      REPLACE SEQUEN WITH _SEQUEN
      REPLACE NBBDDT WITH _NBBDDT
      REPLACE UNIQUE_DDT WITH _UNIQUE_DDT


      *** RIEMPIO IL CURSORE TEMPORANEO PER LA CONTROVERIFICA DELLE RIGHE IN DDT
      x_nddt = IIF(EMPTY(ALLTRIM(_NUMDDT)) .OR. VAL(_NUMDDT) = 0,"ors_numord = ors_numord","ors_numord = " + _NUMDDT)
      x_dddt = "ors_datord = '" + _DATDDT + "'"
      x_comm = "ord_desart <> '*** COMMENTO ***'"
      x_lega = "ors_sysfat = '" + _SYSDDT + "'"
      x_cond = x_nddt + " and " + x_dddt + " and " + x_comm + " AND " + x_lega
      Csql = "select * from u_bol_dd where " + x_cond
      IF !ExecCommand(cSql,'CUR_BOL_DD')
         return(.f.)
      ENDIF
      SELECT CUR_BOL_DD
      GO TOP
      DO WHILE .T.
         IF EOF()
            EXIT
         ENDIF
         SCATTER MEMVAR MEMO
         SELECT ELENCO_DDT
         SET ORDER TO I_UNIQUE
         GO TOP
         _SEEK = M.ID_UNIQUE
         SEEK _SEEK
         IF FOUND()
         ELSE
            APPEND BLANK
            REPLACE ID_UNIQUE WITH M.ID_UNIQUE
            REPLACE NUMDDT WITH TRC(6,M.ORS_NUMORD)
            REPLACE DATDDT WITH M.ORS_DATORD
            REPLACE CODART WITH M.ORD_CODART
            REPLACE DESART WITH M.ORD_DESART
            REPLACE UM WITH M.ORD_UM
            REPLACE ALTEZZ WITH M.ORD_ALTEZZ
            REPLACE LUNGHE WITH M.ORD_LUNGHE
            REPLACE QTADDT WITH M.ORD_QTAORD
            REPLACE NBBDDT WITH M.ORD_NUMBOB
         ENDIF
         SELECT CUR_BOL_DD
         SKIP +1
      ENDDO

      SELECT CU_FAT_DD
      SKIP +1
   ENDDO

   *** AGGIUNGO AL CURSORE DI STAMPA LE RIGHE DDT NON COMPRESE NELLE RIGHE FATTURA GIA' ANALIZZATE
   SELECT ELENCO_DDT
   GO TOP
   SCAN
      SCATTER MEMVAR
      SELECT CU_CONGRUENZA
      SET ORDER TO I_CHKDDT
      GO TOP
      _SEEK = M.NUMDDT+M.DATDDT+M.ID_UNIQUE
      SEEK _SEEK
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE NUMFAT WITH M.ORD_NUMORD
         REPLACE DATFAT WITH M.ORD_DATORD
         REPLACE CODCLI WITH M.ORD_CODCLI
         REPLACE RAGSOC WITH M.ORD_RAGSOC
         REPLACE CODART WITH M.CODART
         REPLACE DESART WITH M.DESART
         REPLACE UM WITH M.UM
         REPLACE ALTEZZ WITH M.ALTEZZ
         REPLACE LUNGHE WITH M.LUNGHE
         REPLACE QTAFAT WITH 0
         REPLACE QTADDT WITH M.QTADDT
         REPLACE NUMDDT WITH M.NUMDDT
         REPLACE DATDDT WITH M.DATDDT
         REPLACE SYSDDT WITH ""
         REPLACE NUMBOB WITH 0
         REPLACE SEQUEN WITH 99999
         REPLACE NBBDDT WITH M.NBBDDT
         REPLACE UNIQUE_DDT WITH M.ID_UNIQUE
      ENDIF
      SET ORDER TO
   ENDSCAN


   SELECT CU_FAT_TT
   SKIP +1
ENDDO

IF _ZX_OPZCGR
ELSE
   *** ELIMINO I RECORD CONGRUENTI PER EVIDENZIARE SOLO QUELLI INCONGRUENTI
   SELECT CU_CONGRUENZA
   GO TOP
   DELETE FOR QTAFAT == QTADDT
ENDIF

SELECT CU_CONGRUENZA
SET ORDER TO I_ORDER
GO TOP
IF EOF()
   WAIT WINDOWS "Nessun risultato" NOWAIT
ELSE
   V_REPORT = "congruenza_fatture_ddt.FRX"
   DO PRG\MENUSTA WITH "CU_CONGRUENZA",.T.,.T.,"XXX","&V_REPORT","&V_REPORT",.F.,"Congruenza fatture/DDT"
ENDIF


RETURN

