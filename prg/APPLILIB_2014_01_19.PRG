            cSql   = "SELECT * FROM U_ALT_DA WHERE " + x_cond
            IF !ExecRW(cSql,"U_ALT_DA","R")
               return(.f.)
            ENDIF
            SELECT U_ALT_DA
            GO TOP
            IF EOF()
               APPEND BLANK
               REPLACE ALT_UNIQUE WITH SYS(2015)
            ENDIF
            REPLACE ALT_DADOVE WITH 'BFOCAMAG'
            REPLACE ALT_CODMAG WITH M.ORD_MAGA
            REPLACE ALT_LEGAME WITH ZZZ_LEGAME
            REPLACE ALT_NUMORF WITH M.ORS_NUMORC
            IF M.ORS_DATORC = SPACE(10) .OR. M.ORS_DATORC = '  /  /    ' .OR. EMPTY(M.ORS_DATORC)
               REPLACE ALT_DATORF WITH SPACE(10)
            ELSE
               IF SUBSTR(M.ORS_DATORC,3,1) = '/'
                  REPLACE ALT_DATORF WITH RIBALTA2(M.ORS_DATORC)
               ELSE
                  REPLACE ALT_DATORF WITH M.ORS_DATORC
               ENDIF
            ENDIF
            REPLACE ALT_PAGAME WITH M.ORS_CODCPA
            REPLACE ALT_CODACQ WITH M.ORS_CODACQ
            REPLACE ALT_DESACQ WITH X_DESACQ
            REPLACE ALT_SC1    WITH M.ORD_SC1
            REPLACE ALT_SC2    WITH M.ORD_SC2
            REPLACE ALT_SC3    WITH M.ORD_SC3
            REPLACE ALT_NUMIDE WITH M.ORS_NUMIDE
            REPLACE ALT_CODBUN WITH M.ORS_CODBUN
            REPLACE ALT_ANNO   WITH M.ORS_ANNO
            REPLACE ALT_CODCLI WITH M.ORS_CODCLI
            REPLACE ALT_DTASCA WITH M.ORD_DTASCA
            REPLACE ALT_FLGTRA WITH .F.

            REPLACE ALT_UMMAGA WITH V_UMMAGA
            REPLACE ALT_DAGGAN WITH M.DAGGANCIO
            REPLACE ALT_DLEGAM WITH M.DLEGAME
            REPLACE ALT_CODART WITH M.ORD_CODART
            REPLACE ALT_DESART WITH M.ORD_DESART
            REPLACE ALT_CODMAT WITH M.ORD_CODMAT
            REPLACE ALT_DESMAT WITH M.ORD_DESMAT
            REPLACE ALT_CODCOL WITH M.ORD_CODCOL
            REPLACE ALT_DESCOL WITH M.ORD_DESCOL
            REPLACE ALT_SPESSO WITH M.ORD_SPESSO
            REPLACE ALT_ALTEZZ WITH M.ORD_ALTEZZ
            REPLACE ALT_LUNGHE WITH M.ORD_LUNGHE
		    REPLACE ALT_NUMBOB WITH M.ORD_NUMBOB
		    REPLACE ALT_QTAKG  WITH M.ORD_QTAKG
		    REPLACE ALT_QTAMQ  WITH M.ORD_QTAMQ
		    REPLACE ALT_QTAML  WITH M.ORD_QTAML
		    REPLACE ALT_SALCON WITH M.ORD_SALCON
		    REPLACE ALT_CHIUSO WITH M.ORD_CHIUSO
		    REPLACE ALT_SEQUEN WITH M.ORD_SEQUEN
		    REPLACE ALT_CODSYS WITH M.ORD_CODSYS
   		    REPLACE ALT_ERRQTA WITH M.ORD_ERRQTA
		    REPLACE ALT_ARTORF WITH M.ORD_ARTORF
		    REPLACE ALT_AGGORF WITH M.ORD_AGGORF
		    REPLACE ALT_SYSORF WITH M.ORD_SYSORF
		    REPLACE ALT_CODORF WITH M.ORD_CODORF
		    REPLACE ALT_NRLINT WITH M.ORD_NRLINT
		    REPLACE ALT_NRDBOB WITH M.ORD_NRDBOB
		    REPLACE ALT_CDAFOR WITH M.ORD_CDAFOR
		    REPLACE ALT_OINFOR WITH M.ORD_OINFOR
		    REPLACE ALT_PINFOR WITH M.ORD_PINFOR
		    REPLACE ALT_DTPFOR WITH M.ORD_DTPFOR
		    REPLACE ALT_TRAFOR WITH M.ORD_TRAFOR
		    REPLACE ALT_NBAFOR WITH M.ORD_NBAFOR
		    REPLACE ALT_BDAFOR WITH M.ORD_BDAFOR
		    REPLACE ALT_BALFOR WITH M.ORD_BALFOR
		    REPLACE ALT_PNKFOR WITH M.ORD_PNKFOR
		    REPLACE ALT_ALTRIL WITH M.ORD_ALTRIL
		    REPLACE ALT_LUNRIL WITH M.ORD_LUNRIL
		    REPLACE ALT_PESRIL WITH M.ORD_PESRIL
		    REPLACE ALT_COLRIL WITH M.ORD_COLRIL
            REPLACE ALT_FLGRIB WITH M.ORD_FLGRIB
            REPLACE ALT_FLGIMB WITH M.ORD_FLGIMB
	        IF !ExecRW(cSql,"U_ALT_DA","W")
               return(.f.)
            ENDIF
            H_DADOVE = 'BFOCAMAG'
            H_GENMOV = 'SI'
            H_TIPO   = 'GIA'
            H_IMPE   = ""
            H_MAGSCA = M.ORD_MAGA
            H_MAGCAR = ""
            H_CODART = M.ORD_ARTORF
            H_TOPSCA = M.ORD_CAUS
            H_TOPCAR = ""
            IF M.ORD_UM = 'KG'
               V_QTACTRL = M.ORD_QTAKG
            ELSE
               V_QTACTRL = M.ORD_QTAMQ
            ENDIF
            H_QUANTI = V_QTACTRL
            H_NUMDOC = M.ORD_NUMORD
            H_DATDOC = M.ORD_DATORD
		    IF EMPTY(PUB_DATREG)
		       H_DATREG = RIBALTA2(DTOC(DATE()))
		    ELSE
		       IF SUBSTR(PUB_DATREG,3,1) = '/'
		          H_DATREG = RIBALTA2(PUB_DATREG)
		       ELSE
		          H_DATREG = PUB_DATREG
		       ENDIF
		    ENDIF
            H_ORAMOV = TIME()
		    IF PUB_DAINVE
               H_NUMDOC = '000001'
               H_DATDOC = DTOC(DATE())
               H_DATREG = _V_DATINV
               H_ORAMOV = _V_ORAINV
