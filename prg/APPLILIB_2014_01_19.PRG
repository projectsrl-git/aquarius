      V_DTINI  = SPACE(10)
      V_DTFIN  = SPACE(10)
      V_VELIN  = 0
      V_HHLAV  = 0
      V_TEMCG  = 0
      V_TEMCR  = 0
      V_NUMRIG = 1
      V_SCARTO = SEL_SCARTO
      IF YYY_PRIMA
         YYY_PRIMA = .F.
         XXX_ALTE = SEL_ALTMAG
         XXX_DIBA = SEL_CDDIBA
      ENDIF
      DO SPALMATURA_REPORTS
      SELECT RIE_SPALMATURA
      SKIP +1
   ENDDO
ENDIF


RELEASE W_SETINI,W_SETFIN,W_DATINI,W_DATFIN,W_PRIMA
PUBLIC  W_SETINI,W_SETFIN,W_DATINI,W_DATFIN,W_PRIMA
W_SETINI = SPACE(07)
W_SETFIN = SPACE(07)
W_DATINI = SPACE(10)
W_DATFIN = SPACE(10)
