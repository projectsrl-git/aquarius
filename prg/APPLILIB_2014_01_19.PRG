****************************************
FUNCTION OK_LISAV
****************************************
**
**  DETERMINA IL PREZZO DI VENDITA PER TIPOLOGIA LISTINO DI VENDITA/ARTICOLO IN BASE A PUB_LISAV
**
**
**  	- PER TIPOLOGIA AZIENDALE/ARTICOLO/DATA VALIDITA' DAL
**
**  RITORNA :
**
**		-  PUB_LISOK = .T. PER ABILITARE L'INSERIMENTO O MENO NELL'ARCHIVIO DEI LISTINI AGENTE/ARTICOLO
**		-  PUB_PREZZO/M.ORD_PREZZO : CONTENENTE L'ULTIMO PREZZO DI LISTINO VALIDO
**								 	 PER DETERMINARE SE IL PREZZO E' VALIDO CONSIDERA :
**
**									 IL FLAG DI VALIDITA' = SI
**									 		- SE L'UTENTE STA CODIFICANDO I LISTINI FUTURI FINO
**											  A CHE NON HA ABILITATO IL LISTINO TRAMITE APPOSITA	
**											  PROCEDURA IL PREZZO NON E' CONSIDERATO
**
**									 PARTE DALL'ULTIMO PREZZO QUINDI IN VIGORE   	
**					
**

PARA _SOC,_CLI,_ART,_DTDO

IF SUBSTR(_DTDO,3,1) = '/'
ELSE
   _DTDO = RIBALTA2(_DTDO)
ENDIF

IF !PUB_LISAV 	
  RETURN		&& ####################################### EXIT FUNCTION ########################################
ENDIF			

S_S=STR(SELECT())

_CLI =ALLTRIM(_CLI)
TLISTINO=""
x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
x_codi = "cli_codcli = '" + _CLI + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"cu_cli_an_XX")
   return(.f.)
ENDIF
SELECT cu_cli_an_XX
GO TOP
IF reccount() <> 0
  TLISTINO=ALLTRIM(CLI_LISCLI)
ENDIF



x_soci = "lis_codsoc = '" + PUB_CODSOC + "'"
x_tlis = "lis_tipoazi = '" + TLISTINO + "'"
x_arti = "lis_codart = '" + ALLTRIM(_ART) + "'"
x_data = " '"+RIBALTA2(_DTDO)+"' between lis_datlis and lis_allist"
x_cond = x_soci + " and " + x_tlis + " and " + x_arti + " and " + x_data

Csql   = "select * from u_lis_av where " + x_cond + " order by lis_codsoc,lis_tipoazi,lis_codart"
IF !ExecCommand(cSql,"cur_u_lis_av")
	return(.f.)
ENDIF
SELECT CUR_U_LIS_AV
GO top
IF EOF()
	SELECT &S_S
	RETURN
ENDIF


M.ORD_PREZZO   = LIS_PREZZO		&&LISTINO RELATIVO AL PERIODO IN GESTIONE
M.ORD_SC1	   = LIS_SC1
M.ORD_SC2	   = LIS_SC2
M.ORD_SC3	   = LIS_SC3
M.ORD_PRORIG   = LIS_PROVVI			  			
M.ORD_PUBBLI   = LIS_PUBBLI
	


SELECT &S_S

RETURN

