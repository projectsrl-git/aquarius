***************************************************************************
PROCEDURE spalmatura_programmaordinifornitorism_nop
***************************************************************************

CREATE CURSOR CUR_SELEZIONE (SEL_CDDIBA C(16), SEL_CODCOL C(03), SEL_DESCOL C(30), SEL_CODMAT C(03), SEL_DESMAT C(30),     ;
                             SEL_SPESSO N(05), SEL_ALTEZZ N(05), SEL_LUNGHE N(10))

*=> Elaborazione del file di spalmatura non programmato per calcolarne le relative qtŕ di adesivo da applicare per la
*=> sala mescole

SELECT STA_SPALMATURA
INDEX ON STA_CODCOL + STA_CODMAT + STR(STA_SPEMAG,3,0) + STR(STA_ALTMAG,5,0) + ;
         STR(STA_LUNPRG,6,0) + STA_CDDIBA TAG I_DIBA ADDITIVE
SET ORDER TO I_DIBA
GO TOP
IF EOF()
   RETURN
ENDIF

V_CDCOL = STA_CODCOL
V_DSCOL = STA_DESCOL
V_CDMAT = STA_CODMAT
V_DSMAT = STA_DESMAT
V_SPESS = STA_SPEMAG
V_ALTEZ = STA_ALTMAG
V_LUNGH = STA_LUNPRG
V_CDDIB = STA_CDDIBA

V_PRIMO = .T.

DO WHILE .T.

   IF EOF()
      IF V_PRIMO
      ELSE
         *=> Scrivi il record nel cursore delle selezioni
         SELECT CUR_SELEZIONE
         APPEND BLANK
         REPLACE SEL_CDDIBA WITH V_CDDIB
         REPLACE SEL_CODCOL WITH V_CDCOL
         REPLACE SEL_DESCOL WITH V_DSCOL
         REPLACE SEL_CODMAT WITH V_CDMAT
         REPLACE SEL_DESMAT WITH V_DSMAT
         REPLACE SEL_SPESSO WITH V_SPESS
         REPLACE SEL_ALTEZZ WITH V_ALTEZ	
         REPLACE SEL_LUNGHE WITH V_LUNGH
      ENDIF
      EXIT
   ENDIF

   IF STA_CODMAC = 'SPS'
      SKIP +1
      LOOP
   ENDIF

   V_PRIMO = .F.

   *=> Verifica rottura sequenza (cambia bobina da spalmare)
   IF STA_CODCOL = V_CDCOL .AND. ;
      STA_CODMAT = V_CDMAT .AND. ;
      STA_SPEMAG = V_SPESS .AND. ;
      STA_ALTMAG = V_ALTEZ .AND. ;
      STA_LUNPRG = V_LUNGH
   ELSE
      *=> Scrivi il record nel cursore delle selezioni
      SELECT CUR_SELEZIONE
      APPEND BLANK
      REPLACE SEL_CDDIBA WITH V_CDDIB
      REPLACE SEL_CODCOL WITH V_CDCOL
      REPLACE SEL_DESCOL WITH V_DSCOL
      REPLACE SEL_CODMAT WITH V_CDMAT
      REPLACE SEL_DESMAT WITH V_DSMAT
      REPLACE SEL_SPESSO WITH V_SPESS
      REPLACE SEL_ALTEZZ WITH V_ALTEZ
      REPLACE SEL_LUNGHE WITH V_LUNGH
      *=> Legge il record di spalmatura successivo
      SELECT STA_SPALMATURA
      V_CDCOL = STA_CODCOL
	  V_DSCOL = STA_DESCOL
	  V_CDMAT = STA_CODMAT
	  V_DSMAT = STA_DESMAT
	  V_SPESS = STA_SPEMAG
	  V_ALTEZ = STA_ALTMAG
	  V_LUNGH = STA_LUNPRG
	  V_CDDIB = STA_CDDIBA
      LOOP
   ENDIF

   SELECT STA_SPALMATURA
   SKIP +1

ENDDO


SELECT CUR_SALAMESCOLEOF
INDEX ON SEL_CODART TAG I_CODICE ADDITIVE

SELECT CUR_SALAMESCOLE
INDEX ON SEL_CODART TAG I_CODICE ADDITIVE

RELEASE V_QTAMQS,V_UNITAM,V_SCORMI,V_CODIMB,V_DESIMB,V_LOTMIN
PUBLIC  V_QTAMQS,V_UNITAM,V_SCORMI,V_CODIMB,V_DESIMB,V_LOTMIN
V_QTAMQS = 0
V_UNITAM = SPACE(03)
V_SCORMI = 0
V_CODIMB = SPACE(03)
V_DESIMB = SPACE(50)
V_LOTMIN = 0

*=> ELABORAZIONE CURSORE SELEZIONE PER DETERMINARE LE QTA' NECESSARIE AL PROGRAMMA DI SALA MESCOLE
SELECT CUR_SELEZIONE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Determinazione delle quantitŕ in MQ da spalmare (tutta la bobina in altezza)
   V_QTAMQS = TROVA_MQ_DA_AL((M.SEL_ALTEZZ-V_CIMOSA),M.SEL_LUNGHE,1)    && PROJECT 12/01/2005

   *=> Esplosione del Distinta base
   SI_VIDEO = .F.
   DO ALBERELLO  WITH SI_VIDEO,M.SEL_CDDIBA   && ESPLODE LA DISTINTA BASE A VIDEO
   SELECT WEXPLODE
   GO TOP

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      SCATTER MEMVAR MEMO

      *=> Dal primo livello (codice Di.Ba. salvo il codice e la descrizione del Distinta Base)
      IF WLIV = 1
         V_CPADRE = WCOD
         V_DPADRE = WDES
      ENDIF

      *=> Accesso alla anagrafica articoli dei singoli componenti per prelevare i seguenti campi :
      *=> - Unitŕ di misura
      *=> - Scorta minima
      *=> - Codice Imballo
      *=> - Descrizione Imballo
      *=> - Lotto minimo da ordinare
      x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
      x_codi = "art_codpri = '" + ALLTRIM(M.WCOD) + "'"
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
      IF !ExecCommand(cSql,"cur_articolo")
         return(.f.)
      ENDIF
      SELECT cur_articolo
      GO TOP
      IF EOF()
         V_UNITAM = 'NN'
         V_SCORMI = 0
         V_CODIMB = SPACE(03)
         V_DESIMB = SPACE(50)
         V_LOTMIN = 0
      ELSE
         V_UNITAM = ART_UNIMIS
         V_SCORMI = ART_SCORMI
         V_CODIMB = ART_CODIMB
         V_DESIMB = ART_DESIMB
         V_LOTMIN = ART_LOTMIN
      ENDIF

      *=> Aggiornamento sul cursore della sala mescole delle quantita' necessarie alla produzione
      SELECT CUR_SALAMESCOLEOF
      SET ORDER TO I_CODICE
      SEEK M.WCOD
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE SEL_CODART WITH M.WCOD
         REPLACE SEL_DESART WITH M.WDES
         REPLACE SEL_CDDIBA WITH V_CPADRE
         REPLACE SEL_DSDIBA WITH V_DPADRE
         REPLACE SEL_SCORMI WITH V_SCORMI
         REPLACE SEL_CODIMB WITH V_CODIMB
         REPLACE SEL_DESIMB WITH V_DESIMB
         REPLACE SEL_LOTMIN WITH V_LOTMIN
         REPLACE SEL_QTAGIA WITH 0
         REPLACE SEL_LIVELL WITH M.WLIV
         REPLACE SEL_QTADIB WITH V_QTAMQS
         REPLACE SEL_QTADOR WITH 0
         REPLACE SEL_UNITAM WITH V_UNITAM
      ENDIF
      REPLACE SEL_QTANEC WITH SEL_QTANEC + (M.WQTAT * V_QTAMQS)				&& Qtŕ necessaria alla produzione

      SELECT WEXPLODE
      SKIP +1

   ENDDO

   SELECT CUR_SELEZIONE
   SKIP +1

ENDDO

*=> ELABORAZIONE CURSORE SELEZIONE PER DETERMINARE LE QTA' NECESSARIE AL PROGRAMMA DI SALA MESCOLE
SELECT CUR_SALAMESCOLEOF
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Prelievo delle giacenze al netto dell'impegnato
   V_GIACEN = 0
   SELECT NOP_MAG_GG
   SET ORDER TO I_INDICE2
   SEEK M.SEL_CODART
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF MAG_ANAART = M.SEL_CODART
      ELSE
         EXIT
      ENDIF
      V_GIACEN = V_GIACEN + (MAG_GIACEN - MAG_QTAIMP)
      SKIP +1
   ENDDO

   *=> Rilevamento di quanto giŕ impegnato per la programmazione in corso
   V_QTAIMP = 0
   SELECT CUR_SALAMESCOLE
   SET ORDER TO I_CODICE
   SEEK M.SEL_CODART
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF SEL_CODART = M.SEL_CODART
      ELSE
         EXIT
      ENDIF
      V_QTAIMP = V_QTAIMP + SEL_QTANEC
      SKIP +1
   ENDDO

   V_GIACEN = V_GIACEN - V_QTAIMP

   *=> Riepilogo dell'ordinato a fornitori di film nudo in essere
   *V_QTAORF = 0
   *x_arti = "ord_codart = '" + M.SEL_CODART + "'"
   *x_sald = "ord_salcon <> 'S'"
   *x_cond = x_arti + " and " + x_sald
   *Csql   = "select * from u_orf_dd where " + x_cond
   *IF !ExecCommand(Csql,"u_orf_dd")
   *   return(.f.)
   *ENDIF
   *SELECT U_ORF_DD
   *GO TOP
   *DO WHILE .T.
   *   IF EOF()
   *      EXIT
   *   ENDIF
   *   V_QTAORF = V_QTAORF + (ord_qtaord - ord_qtaev)
   *   SKIP +1
   *ENDDO

   *V_GIACEN = V_GIACEN + V_QTAORF

   IF V_GIACEN < 1
      V_GIACEN = 0
   ENDIF

   *=> Accesso alla angrafica articoli per intercettare se trattasi di articolo da movimentare in magazzino
   *=> in caso di articolo da non movimentare, viene forzata una giacenza altissima in modo da non scaturire
   *=> l'emissione automatica dell'ordine a fornitore (č il caso dell'acqua)  PROJECT 4/01/2005
   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.SEL_CODART) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
      OUT = .f.
   ELSE
      OUT = art_NONMOV
   ENDIF
   IF OUT
      V_GIACEN = 999999999
   ENDIF

   *=> Aggiornamento sul cursore della sala mescole delle quantita' necessarie alla produzione
   SELECT CUR_SALAMESCOLEOF
   REPLACE SEL_QTAGIA WITH V_GIACEN
   IF SEL_QTAGIA < SEL_QTANEC
      REPLACE SEL_QTADOR WITH SEL_QTANEC - SEL_QTAGIA		&& Qtŕ da ordinare (manca giacenza)
   ELSE
      REPLACE SEL_QTADOR WITH 0
   ENDIF

   V_QTADOR = SEL_QTADOR

   *=> Aggiornamento impegni sul non programmato
   SELECT NOP_MAG_GG
   SET ORDER TO I_INDICE2
   SEEK M.SEL_CODART
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF MAG_ANAART = M.SEL_CODART
      ELSE
         EXIT
      ENDIF
      V_DIFF = MAG_GIACEN - MAG_QTAIMP
      IF V_DIFF > 0
      ELSE
         SKIP +1
         LOOP
      ENDIF
      IF V_DIFF > V_QTADOR
         REPLACE MAG_QTAIMP WITH MAG_QTAIMP + V_QTADOR
         V_QTADOR = 0
      ELSE
         REPLACE MAG_QTAIMP WITH MAG_QTAIMP + V_DIFF
         V_QTADOR = V_QTADOR - V_DIFF
      ENDIF
      IF V_QTADOR < 1
         EXIT
      ENDIF
      SKIP +1
   ENDDO

   SELECT CUR_SALAMESCOLEOF
   SKIP +1

ENDDO

*!*	SELECT CUR_SALAMESCOLE
*!*	SET ORDER TO I_CODICE
*!*	GO TOP
*!*	DO WHILE .T.
*!*	   IF EOF()
*!*	      EXIT
*!*	   ENDIF
*!*	   IF SEL_QTADOR > 0
*!*	   ELSE
*!*	      SKIP +1
*!*	      LOOP
*!*	   ENDIF
*!*	   SCATTER MEMVAR
*!*	   *=> Aggiornamento sul cursore della sala mescole delle quantita' necessarie alla produzione
*!*	   SELECT CUR_SALAMESCOLEOF
*!*	   SET ORDER TO I_CODICE
*!*	   SEEK M.SEL_CODART
*!*	   IF FOUND()
*!*	      REPLACE SEL_QTADOR WITH SEL_QTADOR + M.SEL_QTADOR
*!*	   ELSE
*!*	      APPEND BLANK
*!*	      GATHER MEMVAR MEMO
*!*	   ENDIF
*!*	   SELECT CUR_SALAMESCOLE
*!*	   SKIP +1
*!*	ENDDO

RETURN


***************************************************************************
PROCEDURE generagiacenze_x_ordcli						
***************************************************************************

CREATE CURSOR CUR_GIACMAGFN (MAG_CODMAG C(06),   MAG_CODART C(16),   MAG_DESART C(50),   MAG_ANAART C(16),  MAG_CODMAT C(03),   ;
                             MAG_DESMAT C(50),   MAG_CODCOL C(03),   MAG_DESCOL C(50),   MAG_SPESSO N(05),  MAG_ALTEZZ N(05),   ;
                             MAG_LUNGHE N(06),   MAG_QTAMQ N(10,2),  MAG_QTAML N(10),    MAG_QTAKG N(10,2), MAG_QTAMQI N(10,2), ;
                             MAG_QTAMLI N(10),   MAG_QTAKGI N(10,2), MAG_QTAMQD N(10,2), MAG_QTAMLD N(10),  MAG_QTAKGD N(10,2), ;
                             MAG_QTAMQN N(10,2), MAG_QTAMLN N(10),   MAG_QTAKGN N(10,2), MAG_FORNIT C(10),  MAG_DESFOR C(50),   ;
                             MAG_PRZCON N(16,6), MAG_DATAGG C(10))

CREATE CURSOR CUR_GIACMAGAD (MAG_CODMAG C(06),   MAG_CODART C(16),   MAG_DESART C(50),   MAG_ANAART C(16),   MAG_CODMAT C(03),   ;
                             MAG_DESMAT C(50),   MAG_CODIMB C(03),   MAG_DESIMB C(50),   MAG_QTAKG N(16,6),  MAG_QTAKGI N(16,6), ;
                             MAG_QTAKGD N(16,6), MAG_QTAKGN N(16,6), MAG_FORNIT C(10),  MAG_DESFOR C(50),    MAG_PRZCON N(16,6), ;
                             MAG_DATAGG C(10))

*=> Acquisizione dello spessore compatibile
*=> - accedo con key = spessore del film ordinato
*=> - acquisisco dalla tabella lo spessore del film nudo compatibile.
x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
x_tmat = "mic_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
x_cond = x_spes + " and " + x_tmat
Csql   = "select * from u_pro_my where " + x_cond
IF !ExecCommand(Csql,"u_pro_my")
   return(.f.)
ENDIF
SELECT U_PRO_MY
GO TOP
IF EOF()
   x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
   x_tmat = "mic_codmat = SPACE(03)"
   x_cond = x_spes + " and " + x_tmat
   Csql   = "select * from u_pro_my where " + x_cond
   IF !ExecCommand(Csql,"u_pro_my")
      return(.f.)
   ENDIF
   SELECT U_PRO_MY
   GO TOP
   IF EOF()
      RETURN
   ENDIF
   SCATTER MEMVAR
ELSE
   SCATTER MEMVAR
ENDIF

V_CAR = SPACE(16)
V_DAR = SPACE(50)

x_soci  = "art_codsoc = '" + PUB_CODSOC + "'"
x_tmat  = "art_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
x_imba  = "art_codimb = art_codimb"
x_colo  = "art_codcol = '" + ALLTRIM(M.ORD_CODCOL) + "'"
x_spes  = "art_spesso = " + ALLTRIM(STR(M.MIC_SPEORD,5,0))
x_alte  = "art_altezz = art_altezz"
x_lung  = "art_lunghe = art_lunghe"
x_arti  = "art_codpri = art_codpri"
x_cond  = x_soci + " and " + x_arti
x_cond1 = " and " + x_tmat + " and " + x_imba + " and " + x_colo
x_cond2 = " and " + x_spes + " and " + x_alte + " and " + x_lung
x_cond3 = " and 1=1 "
x_cond  = x_cond + x_cond1 + x_cond2 + x_cond3
Csql    = "select * from u_art_pr where " + x_cond
IF !ExecCommand(cSql,"CU_ART_PR")
   return(.f.)
ENDIF
SELECT CU_ART_PR
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF ART_TIPART = 'A'
      V_CAR = ART_CODPRI
      V_DAR = ART_DESCR
      EXIT
   ENDIF
   SKIP +1
ENDDO

IF EMPTY(ALLTRIM(V_CAR))
   V_CAR = M.ORD_CODART
   V_DAR = M.ORD_DESART
ENDIF

X_MQ = TROVA_MQ_DA_AL(V_ALMAFN,V_NRBOB3,1)
X_KG = TROVA_KG_DA_MQ(V_CAR,M.MIC_SPEORD,X_MQ,1)

x_data = "mag_datagg <> SPACE(10)"
x_giac = "mag_giacen > 0"
x_maga = "mag_codmag = mag_codmag"
x_impe = "mag_qtaimp < mag_giacen"
x_tmat = "mag_codmat = '" + M.ORD_CODMAT + "'"
x_colo = "mag_codcol = '" + M.ORD_CODCOL + "'"
x_spes = "mag_spesso >= " + ALLTRIM(STR(M.MIC_SPESDA,5,0))
x_alte = "mag_altezz >= " + ALLTRIM(STR(M.ORD_ALTEZZ,5,0))
x_cond = x_data + " and " + x_giac + " and " + x_maga + " and " + x_impe + " and " + x_tmat + " and " + x_colo + ;
         " and " + x_spes + " and " + x_alte
Csql   = "select * from u_mag_gg where " + x_cond + " order by mag_codmat,mag_codcol,mag_spesso,mag_altezz desc,mag_nrlint,MAG_QTAML desc"
IF !ExecCommand(Csql,"G_mag_gg")
   return(.f.)
ENDIF
SELECT G_MAG_GG
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF MAG_SPESSO > M.MIC_SPESAL
      SKIP +1
      LOOP
   ENDIF
   IF MAG_QTAML > MAG_GMLIMP
   ELSE
      SKIP +1
      LOOP
   ENDIF
   SCATTER MEMVAR MEMO
   SELECT CUR_GIACMAGFN
   APPEND BLANK
   GATHER MEMVAR MEMO
   REPLACE MAG_QTAMQI WITH M.MAG_QTAIMP
   REPLACE MAG_QTAMLI WITH M.MAG_GMLIMP
   REPLACE MAG_QTAKGI WITH M.MAG_GKGIMP
   REPLACE MAG_QTAMQD WITH MAG_QTAMQ - MAG_QTAMQI
   REPLACE MAG_QTAMLD WITH MAG_QTAML - MAG_GMLIMP
   REPLACE MAG_QTAKGD WITH MAG_QTAKG - MAG_GKGIMP
   REPLACE MAG_QTAMQN WITH X_MQ
   REPLACE MAG_QTAMLN WITH V_NRBOB3
   REPLACE MAG_QTAKGN WITH X_KG
   SELECT G_MAG_GG
   SKIP +1
ENDDO

SELECT CUR_GIACMAGFN
GO TOP
IF EOF()
   V_OKORF = .T.
   SELECT CUR_GIACMAGFN
   APPEND BLANK
   REPLACE MAG_CODMAG WITH 'DA ORD'
   REPLACE MAG_CODART WITH V_CAR
   REPLACE MAG_DESART WITH V_DAR
   REPLACE MAG_ANAART WITH V_CAR
   REPLACE MAG_CODMAT WITH M.ORD_CODMAT
   REPLACE MAG_DESMAT WITH M.ORD_DESMAT
   REPLACE MAG_CODCOL WITH M.ORD_CODCOL
   REPLACE MAG_DESCOL WITH M.ORD_DESCOL
   REPLACE MAG_SPESSO WITH M.MIC_SPEORD
   REPLACE MAG_ALTEZZ WITH V_ALMAFN
   REPLACE MAG_LUNGHE WITH V_NRBOB3
   REPLACE MAG_QTAMQ  WITH 0
   REPLACE MAG_QTAML  WITH 0
   REPLACE MAG_QTAKG  WITH 0
   REPLACE MAG_QTAMQI WITH 0
   REPLACE MAG_QTAMLI WITH 0
   REPLACE MAG_QTAKGI WITH 0
   REPLACE MAG_QTAMQD WITH 0
   REPLACE MAG_QTAMLD WITH 0
   REPLACE MAG_QTAKGD WITH 0
   REPLACE MAG_QTAMQN WITH X_MQ
   REPLACE MAG_QTAMLN WITH V_NRBOB3
   REPLACE MAG_QTAKGN WITH X_KG
   REPLACE MAG_FORNIT WITH SPACE(10)
   REPLACE MAG_DESFOR WITH SPACE(50)
   REPLACE MAG_PRZCON WITH 0
   REPLACE MAG_DATAGG WITH SPACE(10)
ENDIF

*=> Riepilogo delle giacenze di colla adesiva (di.ba.) per il prodotto ordinato
x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
x_codi = "art_codpri = '" + ALLTRIM(M.ORD_CODART) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
IF !ExecCommand(cSql,"cur_articolo")
   return(.f.)
ENDIF
SELECT cur_articolo
GO TOP
IF EOF()
   V_DIBA = M.ORD_CODART
ELSE
   V_DIBA = ART_CDDIBA
ENDIF
SI_VIDEO = .F.
DO ALBERELLO  WITH SI_VIDEO,V_DIBA   && ESPLODE LA DISTINTA BASE A VIDEO
SELECT WEXPLODE
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF WLIV = 1
      SKIP +1
      LOOP
   ENDIF
   Q_CODART = WCOD
   Q_DESART = WDES
   Q_QUANTI = WQTA
   x_data = "mag_datagg <> SPACE(10)"
   x_giac = "mag_giacen > 0"
   x_maga = "mag_codmag = mag_codmag"
   x_impe = "mag_qtaimp < mag_giacen"
   x_arti = "mag_anaart = '" + Q_CODART + "'"
   x_cond = x_data + " and " + x_giac + " and " + x_maga + " and " + x_impe + " and " + x_arti
   Csql   = "select * from u_mag_gg where " + x_cond + " order by mag_codart"
   IF !ExecCommand(Csql,"G_mag_gg")
      return(.f.)
   ENDIF
   V_TROV = .F.
   SELECT G_MAG_GG
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      SCATTER MEMVAR MEMO
      SELECT CUR_GIACMAGAD
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE MAG_QTAKG  WITH M.MAG_GIACEN
      REPLACE MAG_QTAKGI WITH M.MAG_QTAIMP
      REPLACE MAG_QTAKGD WITH MAG_QTAKG - MAG_QTAKGI
      REPLACE MAG_QTAKGN WITH Q_QUANTI * X_MQ
      V_TROV = .T.
      SELECT G_MAG_GG
      SKIP +1
   ENDDO
   IF V_TROV
   ELSE
      x_soci  = "art_codsoc = '" + PUB_CODSOC + "'"
      x_tmat  = "art_codmat = '004'"
      x_imba  = "art_codimb = art_codimb"
      x_colo  = "art_codcol = art_codcol"
      x_spes  = "art_spesso = art_spesso"
      x_alte  = "art_altezz = art_altezz"
      x_lung  = "art_lunghe = art_lunghe"
      x_arti  = "art_codpri = '" + ALLTRIM(Q_CODART) + "'"
      x_cond  = x_soci + " and " + x_arti
      x_cond1 = " and " + x_tmat + " and " + x_imba + " and " + x_colo
      x_cond2 = " and " + x_spes + " and " + x_alte + " and " + x_lung
      x_cond3 = " and 1=1 "
      x_cond  = x_cond + x_cond1 + x_cond2 + x_cond3
      Csql    = "select * from u_art_pr where " + x_cond
      IF !ExecCommand(cSql,"CU_ART_PR")
         return(.f.)
      ENDIF
      SELECT CU_ART_PR
      GO TOP
      IF EOF()
         Q_CODIMB = SPACE(03)
         Q_DESIMB = SPACE(50)
         Q_LOTMIN = 0
         Q_CODMAT = SPACE(03)
         Q_DESMAT = SPACE(50)
      ELSE
         Q_CODIMB = ART_CODIMB
         Q_DESIMB = ART_DESIMB
         Q_LOTMIN = ART_LOTMIN
         Q_CODMAT = ART_CODMAT
         Q_DESMAT = ART_DESMAT
      ENDIF
      SELECT CUR_GIACMAGAD
      APPEND BLANK
      REPLACE MAG_CODMAG WITH 'DA ORD'
      REPLACE MAG_CODART WITH Q_CODART
      REPLACE MAG_DESART WITH Q_DESART
      REPLACE MAG_ANAART WITH Q_CODART
      REPLACE MAG_CODMAT WITH Q_CODMAT
      REPLACE MAG_DESMAT WITH Q_DESMAT
      REPLACE MAG_CODIMB WITH Q_CODIMB
      REPLACE MAG_DESIMB WITH Q_DESIMB
      REPLACE MAG_QTAKG  WITH 0
      REPLACE MAG_QTAKGI WITH 0
      REPLACE MAG_QTAKGD WITH 0
      REPLACE MAG_QTAKGN WITH Q_QUANTI * X_MQ
      REPLACE MAG_FORNIT WITH SPACE(10)
      REPLACE MAG_DESFOR WITH SPACE(50)
      REPLACE MAG_PRZCON WITH 0
      REPLACE MAG_DATAGG WITH SPACE(10)
      V_OKORF = .T.
   ENDIF
   SELECT WEXPLODE
   SKIP +1
ENDDO

SELECT CUR_GIACMAGAD
GO TOP
IF EOF()
   V_OKORF = .T.
ENDIF

RETURN


*************************
PROCEDURE CERCA_PROGRAMMA
*************************

PARAMETERS _ARCH,_CHIAVE

RELEASE V_ARCH_PRG,V_ARCH_AVA,V_CHIAVE,V_MAGAZ
PUBLIC  V_ARCH_PRG,V_ARCH_AVA,V_CHIAVE,V_MAGAZ

IF _ARCH = 'SPA'
   V_ARCH_PRG = 'U_PRG_SP'
   V_ARCH_AVA = 'U_AVA_SP'
   V_MAGAZ    = PUB_SPACQS
ENDIF
IF _ARCH = 'RIB'
   V_ARCH_PRG = 'U_PRG_RI'
   V_ARCH_AVA = 'U_AVA_RI'
   V_MAGAZ    = PUB_RIBSLO	
ENDIF
IF _ARCH = 'TAG'
   V_ARCH_PRG = 'U_PRG_TG'
   V_ARCH_AVA = 'U_AVA_TG'
   V_MAGAZ    = PUB_TAGPFO
ENDIF
V_CHIAVE = _CHIAVE

* Accesso alla tabella delle programmazioni per cliente (tutte le programmazioni legate alla riga d'ordine cliente)
* mettendo in chiave il codice sys che lega la riga d'ordine del cliente
x_tipo = "prg_tipo = '" + _ARCH + "'"
x_csys = "prg_unique = '" + V_CHIAVE + "'"
x_cond = x_tipo + " and " + x_csys
Csql   = "select * from u_prg_cl where " + x_cond
IF !ExecCommand(cSql,"U_PRG_CL")
   return(.f.)
ENDIF
SELECT U_PRG_CL
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   * Accesso alla tabella delle programmazioni (spalmatura/ribobinatura/taglio) per sapere se il programma č
   * teminato oppure no
   x_csys = "sta_syscli = '" + ALLTRIM(PRG_CODSYS) + "'"
   x_data = "sta_datini <> 'GG/MM/AAAA'"
   x_cond = x_csys + " and " + x_data
   Csql   = "select * from " + V_ARCH_PRG + " where " + x_cond
   IF !ExecCommand(cSql,"&V_ARCH_PRG")
      return(.f.)
   ENDIF
   SELECT &V_ARCH_PRG
   GO TOP
   IF EOF()
      *=> Se NON esiste (cancellato/annullato), NON devo incrementare le bobine di giŕ programmato.
      SELECT U_PRG_CL
      SKIP +1
      LOOP
   ENDIF

   *=> Flag di fine avanzamento
   IF STA_FLGEND
   ELSE
      *=> Se il programma NON č terminato (ancora in produzione), DEVO incrementare le bobine di giŕ programmato.
      SELECT U_PRG_CL
      X_NRBPRG = X_NRBPRG + PRG_BOBPRG
      X_QTAPRG = X_QTAPRG + PRG_QTAPRG
      SKIP +1
      LOOP
   ENDIF

   V_NBOBAVA = 0		&& CONTATORE DELLE BOBINE AVANZATE
   V_NBOBGIA = 0		&& CONTATORE DELLE BOBINE IN GIACENZA IN REPARTO

   *=> Se il programma E' terminato (fine produzione), ma le bobine sono ancora in giacenza nel reparto di produzione
   *=> (non ancora spostate sul magazzino di materiale disponibile per altre produzioni), DEVO incrementare le bobine
   *=> di giŕ programmato perchč se no rischio di riprogrammarlo (č il caso delle bobine di spalmato).

   IF _ARCH = 'SPA'
      x_nprg = "sta_numprg = '" + STA_NUMPRG + "'"
      x_dprg = "sta_datprg = '" + STA_DATPRG + "'"
      x_prog = "sta_progre = " + ALLTRIM(STR(STA_PROGRE,10,0))
      x_tipo = "ava_tipava = 'BS'"
      x_cond = x_nprg + " and " + x_dprg + " and " + x_prog + " and " + x_tipo
      Csql   = "select * from " + V_ARCH_AVA + " where " + x_cond
      IF !ExecCommand(cSql,"&V_ARCH_AVA")
         return(.f.)
      ENDIF
      SELECT &V_ARCH_AVA
      GO TOP
      DO WHILE .T.
         IF EOF()
            EXIT
         ENDIF
         V_NBOBAVA = V_NBOBAVA + 1
         x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
         x_tmat = "mag_codmat = mag_codmat"
         x_colo = "mag_codcol = mag_codcol"
         x_spes = "mag_spesso = mag_spesso"
         x_alte = "mag_altezz = mag_altezz"
         x_lung = "mag_lunghe = mag_lunghe"
         x_arti = "mag_codart = '" + ALLTRIM(NUD_CODINT) + "'"
         x_nrli = "mag_nrlint = " + ALLTRIM(STR(NUD_NUMLOT,8,0))
         x_maga = "mag_codmag = '" + ALLTRIM(V_MAGAZ) + "'"
         x_forn = "mag_fornit = mag_fornit"
         x_nide = "mag_numide = mag_numide"
         x_anno = "mag_anno = mag_anno"
         x_data = "mag_datagg <> SPACE(10)"
         x_giac = "mag_giacen > 0"
         x_impe = "mag_qtaimp = mag_qtaimp"
         x_cond = x_soci + " and " + x_tmat + " and " + x_colo + " and " + x_spes + " and " + x_alte
         x_cond = x_cond + " and " + x_lung + " and " + x_arti + " and " + x_nrli + " and " + x_maga
         x_cond = x_cond + " and " + x_forn + " and " + x_nide + " and " + x_anno + " and " + x_data
         x_cond = x_cond + " and " + x_giac + " and " + x_impe
         cSql   = "select * from u_mag_gg where " + x_cond + " order by mag_datagg,mag_codart"
         IF !ExecCommand(cSql,'CU_MAGAZZINO')
            return(.f.)
         ENDIF
         SELECT CU_MAGAZZINO
         GO TOP
         IF EOF()
         ELSE
            V_NBOBGIA = V_NBOBGIA + 1
         ENDIF
         SELECT &V_ARCH_AVA
         SKIP +1
      ENDDO
      IF V_NBOBAVA = V_NBOBGIA
         SELECT U_PRG_CL
         X_NRBPRG = X_NRBPRG + PRG_BOBPRG
         X_QTAPRG = X_QTAPRG + PRG_QTAPRG
      ENDIF
   ENDIF

   SELECT U_PRG_CL
   SKIP +1

ENDDO

RETURN


