         M.MAG_QTAMQ  = M.MAG_QTAMQ - M.MAG_QTAIMP
         M.MAG_QTAML  = M.MAG_QTAML - M.MAG_GMLIMP
         M.MAG_LUNGHE = M.MAG_QTAML
         M.MAG_NLPROV = 99999 - M.MAG_ALTEZZ					 && ALTEZZA COMPLEMENTATA
         GATHER MEMVAR MEMO
      ENDIF

      *=> Accedo alle giacenze per aggiornarne le quantitŕ programmate

      SELECT NOP_MAG_GG
      SET ORDER TO I_INDICE4
