         IF FOUND()
            REPLACE MAG_GIACEN WITH MAG_GIACEN + (M.MAG_GIACEN - M.MAG_QTAIMP)
            REPLACE MAG_QTAKG  WITH MAG_QTAKG  + (M.MAG_QTAKG - M.MAG_GKGIMP)
            REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  + (M.MAG_QTAMQ - M.MAG_QTAIMP)
            REPLACE MAG_QTAML  WITH MAG_QTAML  + (M.MAG_QTAML - M.MAG_GMLIMP)
            REPLACE MAG_NRDBOB WITH MAG_NRDBOB + 1
            REPLACE MAG_BDAFOR WITH MAG_BDAFOR + (M.MAG_QTAMQ - M.MAG_QTAIMP)
            REPLACE MAG_BALFOR WITH MAG_BALFOR + (M.MAG_QTAML - M.MAG_GMLIMP)
            REPLACE MAG_PNKFOR WITH MAG_PNKFOR + (M.MAG_QTAKG - M.MAG_GKGIMP)
            REPLACE MAG_NUMPED WITH MAG_NUMPED + 1
         ELSE
            APPEND BLANK
            M.MAG_DATAGG = SPACE(10)
            M.MAG_CODART = SPACE(16)
            M.MAG_FORNIT = SPACE(10)
            M.MAG_DESFOR = SPACE(50)
            M.MAG_PRZCON = 0
            M.MAG_NRDBOB = 1
            M.MAG_ALTRES = M.MAG_ALTEZZ
            M.MAG_GIACEN = M.MAG_GIACEN - M.MAG_QTAIMP
            M.MAG_QTAKG  = M.MAG_QTAKG - M.MAG_GKGIMP
            M.MAG_QTAMQ  = M.MAG_QTAMQ - M.MAG_QTAIMP
            M.MAG_QTAML  = M.MAG_QTAML - M.MAG_GMLIMP
            M.MAG_BDAFOR = M.MAG_QTAMQ - M.MAG_QTAIMP
            M.MAG_BALFOR = M.MAG_QTAML - M.MAG_GMLIMP
            M.MAG_PNKFOR = M.MAG_QTAKG - M.MAG_GKGIMP
            M.MAG_NUMPED = 1
            M.MAG_NLPROV = 99999 - M.MAG_ALTEZZ					&& ALTEZZA COMPLEMENTATA
            GATHER MEMVAR MEMO
         ENDIF

         SELECT CQ_MAG_GG
         REPLACE MAG_COMODO WITH MAG_GIACEN
         REPLACE MAG_GIACEN WITH 0

         SKIP +1

      ENDDO

      SELECT WEXPLODE
      SKIP +1

   ENDDO

   SELECT CU_ORD_DL
   SKIP +1

ENDDO

RETURN


***************************************************************************
PROCEDURE spalmatura_programmazione						
***************************************************************************

RELEASE V_DIBA,V_TROV,V_ALTEZZA,V_LUNGHEZ,V_ACCBOBI,V_PERCNOUSATA,V_ACCOPPIA,V_ALTUSATA, ;
        V_MAX_BOB_SPALM,V_LUNGORD,V_PROGRE,V_SCAR,V_SCAABU,V_ALMAFN,V_ALMIFN,V_LUMIFN,V_LUMAIN
PUBLIC  V_DIBA,V_TROV,V_ALTEZZA,V_LUNGHEZ,V_ACCBOBI,V_PERCNOUSATA,V_ACCOPPIA,V_ALTUSATA, ;
        V_MAX_BOB_SPALM,V_LUNGORD,V_PROGRE,V_SCAR,V_SCAABU,V_ALMAFN,V_ALMIFN,V_LUMIFN,V_LUMAIN
V_DIBA          = SPACE(16)
V_TROV          = .F.
V_ALTEZZA       = 0
V_LUNGHEZ       = 0
V_ACCBOBI       = 0
V_PERCNOUSATA   = 0
V_ACCOPPIA      = 0
V_ALTUSATA      = 0
V_MAX_BOB_SPALM = 0
V_LUNGORD       = 0
V_PROGRE        = 0
V_SCAR          = .F.
V_SCAABU        = 0
V_ALMAFN        = 0
V_ALMIFN        = 0
V_LUMIFN        = 0
V_LUMAIN        = 0

CREATE CURSOR CUR_SELEZIONE (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50), SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                             SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03), SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                             SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05), SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                             SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05), SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                             SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16), SEL_SCARTO L(1),  ;
                             SEL_CODSYS C(10),   SEL_CILRET N(03))

CREATE CURSOR CUR_SPALMATURA (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50),   SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                              SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03),   SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                              SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05),   SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                              SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05),   SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                              SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16),   SEL_PROGRE N(06), ;
                              SEL_CODMAC C(03),   SEL_DESMAC C(50), SEL_SCARTO L(01),   SEL_ALTCOM N(05),   SEL_CODSYS C(10), ;
                              SEL_FLGELI C(2),    SEL_CILRET N(03), SEL_MISTAG M(04),   SEL_CLIELA M(04),   SEL_LUNPRG N(16), ;
                              SEL_NOTE M(04))

CREATE CURSOR RIE_SPALMATURA (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50),   SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                              SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03),   SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                              SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05),   SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                              SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05),   SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                              SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16),   SEL_PROGRE N(06), ;
                              SEL_CODMAC C(03),   SEL_DESMAC C(50), SEL_SCARTO L(01),   SEL_ALTCOM N(05),   SEL_CODSYS C(10), ;
                              SEL_FLGELI C(2),    SEL_CILRET N(03), SEL_MISTAG M(04),   SEL_CLIELA M(04),   SEL_LUNPRG N(16), ;
                              SEL_NOTE M(04),     SEL_ALTPRG N(05))

CREATE CURSOR NOP_SPALMATURA (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50),   SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                              SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03),   SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                              SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05),   SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                              SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05),   SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                              SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16),   SEL_PROGRE N(06), ;
                              SEL_CODMAC C(03),   SEL_DESMAC C(50), SEL_SCARTO L(01),   SEL_ALTCOM N(05),   SEL_CODSYS C(10), ;
                              SEL_FLGELI C(2),    SEL_CILRET N(03), SEL_MISTAG M(04),   SEL_CLIELA M(04),   SEL_LUNPRG N(16), ;
                              SELEZIONE C(10),    SEL_NOTE M(04))

SELECT NOP_SPALMATURA
INDEX ON SEL_UNIQUE TAG I_UNIQUE ADDITIVE
INDEX ON SEL_CODSYS TAG I_CODSYS ADDITIVE	&& PROJECT 13/11/04


*=> ******************************************************************** <=*
*=>                                                                      <=*
*=>    P R O G R A M M A Z I O N E   D E L L A   S P A L M A T U R A     <=*
*=>                                                                      <=*
*=> ******************************************************************** <=*

RELEASE __STEPSP,__TOLL,__OLDNEW
PUBLIC  __STEPSP,__TOLL,__OLDNEW

x_codi = "codice = 'PDP04'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __STEPSP = 'NO'
ELSE
   __STEPSP = SUBSTR(LIBERA,1,2)
ENDIF

IF __STEPSP = 'SI'
   SET STEP ON
ENDIF

x_codi = "codice = 'GTP01'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __TOLL   = 'SI'
   __OLDNEW = 'NEW'
ELSE
   __TOLL   = SUBSTR(LIBERA,1,2)
   __OLDNEW = SUBSTR(DESIVA,1,3)
ENDIF
IF EMPTY(__OLDNEW)
   __OLDNEW = 'NEW'
ENDIF

*=> Decurtazione delle quantitŕ giŕ programmate per la spalmatura
RELEASE X_NRBPRG,X_QTAPRG
PUBLIC  X_NRBPRG,X_QTAPRG

SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL NUMERO DI BOBINE DA SPALMARE = 0
   IF ORD_NRBSPD > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF EMPTY(ALLTRIM(ORD_CODSYS))
      SKIP +1
      LOOP
   ENDIF

   X_NRBPRG = 0
   X_QTAPRG = 0

   XQ_UNIQUE = ORD_CODSYS

   *=> DETERMINO IL NUMERO DELLE BOBINE GIA' PROGRAMMATE
   DO CERCA_PROGRAMMA WITH 'SPA',XQ_UNIQUE

   *=> AGGIORNO IL NUMERO DELLE BOBINE DA PROGRAMMARE
   SELECT CU_ORD_DL
   REPLACE ORD_NRBSPD WITH ORD_NRBSPD - X_NRBPRG
   REPLACE ORD_QTASPD WITH TROVA_MQ_DA_AL(ORD_ALTEZZ,ORD_LUNGHE,ORD_NRBSPD)

   SKIP +1

ENDDO

*=> ELABORO TUTTE LE RIGHE D'ORDINE FORNITORE SELEZIONATE PER LA PRODUZIONE IN SPALMATURA

SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL NUMERO DI BOBINE DA SPALMARE = 0
   IF ORD_NRBSPD > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   *=> BY-PASSO QUELLE RIGHE CHE HO GIA' ELABORATO
   IF ORD_CODMAC = 'SPS'
      SKIP +1
      LOOP
   ENDIF

   *=> BY-PASSO QUELLE RIGHE CHE NON DEVONO ESSERE SPALMATE (ORDINI DI FILM NUDO O SENZA DI.BA.)
   IF ORD_UM = 'KG' .OR. EMPTY(ALLTRIM(ORD_CDDIBA))
      SKIP +1
      LOOP
   ENDIF

   WAIT WINDOWS "PROGRAMMAZIONE DELLA SPALMATURA : % in alt. tollerata = " + ALLTRIM(STR(V__SCARTO,6,2)) + CHR(13) + ;
	            "Stň elaborando l'articolo " + ORD_CODART + " " + ALLTRIM(ord_codcol) + " mm. " + ALLTRIM(STR(ORD_ALTEZZ,5,0)) + " x mtl. " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + CHR(13) + ;
	            "Nr.bob. : " + ALLTRIM(STR(ORD_NRBRID,7,0)) + " Nr.Ordine : " + ORS_NUMORD + " del " + ORS_DATORD + " Cliente : " + ORS_RAGSOC NOWAIT

   SCATTER MEMVAR MEMO

   SELECT NOP_SPALMATURA
   SET ORDER TO I_CODSYS
   SEEK M.ORD_CODSYS
   IF FOUND()
   ELSE
      APPEND BLANK
      REPLACE SEL_UNIQUE WITH M.ID_UNIQUE
      REPLACE SEL_CODART WITH M.ORD_CODART
      REPLACE SEL_DESART WITH M.ORD_DESART
      REPLACE SEL_CODCLI WITH M.ORS_CODCLI
      REPLACE SEL_RAGSOC WITH M.ORS_RAGSOC
      REPLACE SEL_NUMORD WITH M.ORS_NUMORD
      REPLACE SEL_DATORD WITH M.ORS_DATORD
      REPLACE SEL_CODCOL WITH M.ORD_CODCOL
      REPLACE SEL_DESCOL WITH M.ORD_DESCOL
      REPLACE SEL_CODMAT WITH M.ORD_CODMAT
      REPLACE SEL_DESMAT WITH M.ORD_DESMAT
      REPLACE SEL_SPESSO WITH M.ORD_SPESSO
      REPLACE SEL_ALTEZZ WITH M.ORD_ALTEZZ
      REPLACE SEL_LUNGHE WITH M.ORD_LUNGHE
      REPLACE SEL_BOBORD WITH M.ORD_NRBSPD
      REPLACE SEL_QTAORD WITH M.ORD_QTASPD
      REPLACE SEL_CODSYS WITH M.ORD_CODSYS
      REPLACE SEL_BOBPRG WITH 0
      REPLACE SEL_QTAPRG WITH 0
      *§°§ REPLACE SEL_BOBPRG WITH M.ORD_NRBSPD DISATTIVATO TEMPORANEAMENTE (LANDI - 03/02/2005 - PROJECT)
      *§°§ REPLACE SEL_QTAPRG WITH M.ORD_QTASPD DISATTIVATO TEMPORANEAMENTE (LANDI - 03/02/2005 - PROJECT)
   ENDIF

   V_DIBA = M.ORD_CDDIBA

   *=> ACQUISISCO I PARAMETRI STANDARD PER LE CAPACITA PRODUTTIVE DELLE MACCHINE IN SPALMATURA

   V_ALMAFN = V_ALTMAX		&& ALTEZZA MASSIMA FILM NUDO IN INPUT
   V_ALMIFN = V_ALTMIN		&& ALTEZZA MINIMA FILM NUDO IN INPUT
   *V_SCAABU = V_SCARTO		&& PERCENTUALE DI SCARTO TOLLERATO SU ALTEZZA BOBINA IN INPUT
   V_SCAABU = V_SCAMAX		&& PERCENTUALE DI SCARTO TOLLERATO SU ALTEZZA BOBINA IN INPUT
   V_LUMIFN = V_LUNMIN		&& LUNGHEZZA MINIMA FILM NUDO IN INPUT
   V_LUMAIN = V_LUNMAR		&& LUNGHEZZA MASSIMA FILM SPALMATO IN INPUT

   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL LEGAME CON LA MACCHINA DI PRODUZIONE SENZA ALTEZZA MAX FILM NUDO IN INPUT
   IF V_ALMAFN = 0
      SELECT CU_ORD_DL
      REPLACE ORD_CODMAC WITH 'SPS'
      SKIP +1
      LOOP
   ENDIF

   *=> Acquisizione dello spessore compatibile
   *=> - accedo con key = spessore del film ordinato
   *=> - acquisisco dalla tabella lo spessore del film nudo compatibile.
   x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
   x_tmat = "mic_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
   x_cond = x_spes + " and " + x_tmat
   Csql   = "select * from u_pro_my where " + x_cond
   IF !ExecCommand(Csql,"u_pro_my")
      return(.f.)
   ENDIF
   SELECT U_PRO_MY
   GO TOP
   IF EOF()
      x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
      x_tmat = "mic_codmat = SPACE(03)"
      x_cond = x_spes + " and " + x_tmat
      Csql   = "select * from u_pro_my where " + x_cond
      IF !ExecCommand(Csql,"u_pro_my")
         return(.f.)
      ENDIF
      SELECT U_PRO_MY
      GO TOP
      IF EOF()
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF
   ENDIF
   SCATTER MEMVAR

   *=> Forzatura degli spessori compatibili per una casistica di ordini particolari
   *=> utilizzo della famiglia G nei colori bianco o bianco/nero con spessore 80 o 100
   IF SUBSTR(V_DIBA,4,1) = 'G'
      IF M.ORD_CODCOL = 'BIA' .OR. M.ORD_CODCOL = 'B/N'
         IF M.ORD_SPESSO = 80
            M.MIC_SPESDA = 75
            M.MIC_SPESAL = 75
         ENDIF
         IF M.ORD_SPESSO = 100
            M.MIC_SPESDA = 90
            M.MIC_SPESAL = 90
         ENDIF
      ENDIF
   ENDIF

   *=> Ricerca giacenze riepilogate in ordine di altezza e lunghezza DISCENDENTE

   V_SEEK = M.ORD_CODMAT + M.ORD_CODCOL

   SET NEAR ON

   SELECT CURS_MAG_GG
   SET ORDER TO I_INDICE3
   SEEK V_SEEK

   V_TROV = .F.
   V_SCAR = .F.

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      *=> Controllo rottura chiave per termine elaborazione
      IF MAG_CODMAT = M.ORD_CODMAT .AND. MAG_CODCOL = M.ORD_CODCOL
      ELSE
         EXIT
      ENDIF

      IF DELETED()
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le bobine gia' esaminate ma non idonee per il troppo sfrido calcolato
      IF MAG_BYPASS
         V_SCAR = .T.
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo gli spessori che non rientrano nel range di tolleranza    INTERVENTO PROJECT 03/11/2004
      IF MAG_SPESSO > M.MIC_SPESAL
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo gli spessori che non rientrano nel range di tolleranza
      IF MAG_SPESSO < M.MIC_SPESDA
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le altezze inferiori a quelle dell'ordine
      IF MAG_ALTEZZ < (M.ORD_ALTEZZ+V_CIMOSA)
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le giacenze a 0
      IF MAG_GIACEN > 0
      ELSE
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le altezze superiori a quelle previste in input per la spalmatura
      IF MAG_ALTEZZ > V_ALMAFN
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le altezze inferiori a quelle previste in input per la spalmatura
      IF MAG_ALTRES < V_ALMIFN
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le lunghezze inferiori a quelle previste in input per la spalmatura
      IF MAG_QTAML < V_LUMIFN
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le lunghezze inferiori a quelle dell'ordine
      IF MAG_QTAML < M.ORD_LUNGHE
         SKIP +1
         LOOP
      ENDIF

      V_TROV = .T.

      SCATTER MEMVAR MEMO
      EXIT

   ENDDO

   SET NEAR OFF

   V_BYPASS = .F.

   *=> Test se č stata trovata giacenza compatibile con quanto ordinato
   IF V_TROV
      V_SCAR = .F.
   ELSE
      *=> Se non č stata trovata la giacenza ma sono state by-passate delle bobine per troppo scarto,
      *=> la programmazione sulla bobina con minor scarto (altezza piů bassa) č possibile farla in base ad
      *=> un parametro gestito dall'utente (se NO non programma)
      IF __TOLL = 'NO'
         IF V_SCAR
            SELECT CURS_MAG_GG
            REPLACE MAG_BYPASS WITH .F. ALL
         ENDIF
         SELECT CU_ORD_DL
         REPLACE ORD_CODMAC WITH 'SPS'
         SKIP +1
         LOOP
      ENDIF
      IF V_SCAR
         SELECT CURS_MAG_GG
         IF MAG_BYPASS
            V_BYPASS = .T.
            V_TROV   = .T.
            REPLACE MAG_BYPASS WITH .F.
            SCATTER MEMVAR MEMO
         ELSE
            SKIP -1
            DO WHILE .T.
               IF BOF()
                  EXIT
               ENDIF
               IF MAG_BYPASS
                  *=> PROJECT 19/01/2005 - INIZIO
                  IF MAG_ALTEZZ = MAG_ALTRES
                     Q_ALTEZZA = MAG_ALTEZZ - V_CIMOSA
                     Q_ALTEZZA = Q_ALTEZZA - (V_TAGLIO * 2)
                  ELSE
                     Q_ALTEZZA = MAG_ALTRES
                  ENDIF
                  IF Q_ALTEZZA < M.ORD_ALTEZZ
                     SKIP -1
                     LOOP
                  ENDIF
                  *=> PROJECT 19/01/2005 - FINE
                  V_BYPASS = .T.
                  V_TROV   = .T.
                  REPLACE MAG_BYPASS WITH .F.
                  SCATTER MEMVAR MEMO
                  EXIT
               ENDIF
               SKIP -1
            ENDDO
         ENDIF
      ENDIF
      IF V_TROV
      ELSE
         IF V_SCAR
            SELECT CURS_MAG_GG
            REPLACE MAG_BYPASS WITH .F. ALL
         ENDIF
         SELECT CU_ORD_DL
         REPLACE ORD_CODMAC WITH 'SPS'
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   *=> Imposto l'altezza iniziale della bobina in giacenza togliendogli la cimosa (40 mm)
   *=> questo perchč le bobine di film nudo vengono caricate con l'altezza che prevede la cimosa,
   *=> mentre le bobine ordinate dai clienti sono al netto delle cimose
   IF M.MAG_ALTEZZ = M.MAG_ALTRES
      V_ALTEZZA = M.MAG_ALTEZZ - V_CIMOSA
      V_ALTEZZA = V_ALTEZZA - (V_TAGLIO * 2)
   ELSE
      V_ALTEZZA = M.MAG_ALTRES
   ENDIF
   V_LUNGHEZ = M.MAG_QTAML
   V_ACCBOBI = 0

   *=> Inizio loop di accoppiamento righe d'ordine con stessa lunghezza
   SELECT CU_ORD_DL
   V_LUNGORD = ORD_LUNGHE
   V_CODMATE = ORD_CODMAT
   V_CODCOLO = ORD_CODCOL
   V_CODSPES = ORD_SPESSO
   V_CODARTI = ORD_CODART
   V_CODDIBA = ORD_CDDIBA
   V_CILRETI = ORD_CILRET

   IF V_ALTEZZA < ORD_ALTEZZ			&& PROJECT 19/01/2005
      SELECT CURS_MAG_GG
      REPLACE MAG_BYPASS WITH .T.
      SELECT CUR_SELEZIONE
      ZAP
      SELECT CU_ORD_DL
      SET ORDER TO I_PROGRA
      GO TOP
      LOOP
   ENDIF

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF ORD_NRBSPD > 0
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Determino la percentuale di tolleranza sul reso in altezza
      V_PERCNOUSATA = (V_ALTEZZA * 100) / (M.MAG_ALTEZZ - V_CIMOSA)
      IF V_PERCNOUSATA > V_SCAABU
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso tipo prodotto
      IF ORD_CODMAT = V_CODMATE
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia della stessa di.ba.
      IF ORD_CDDIBA = V_CODDIBA
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia con lo stesso cilindro retinato
      IF ORD_CILRET = V_CILRETI
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso prodotto
      IF ORD_CODART = V_CODARTI
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso colore
      IF ORD_CODCOL = V_CODCOLO
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso spessore
      IF ORD_SPESSO = V_CODSPES
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia della stessa lunghezza
      IF ORD_LUNGHE = V_LUNGORD
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Determino quanti accoppiamenti riesco a fare con l'altezza della bobina in giacenza
      V_ACCOPPIA = INT((V_ALTEZZA / ORD_ALTEZZ))
      IF V_ACCOPPIA > ORD_NRBSPD
         V_ACCOPPIA = ORD_NRBSPD
      ENDIF

      *=> Determino l'altezza usata per l'accoppiamento  PROJECT 4/01/2005
      V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
      IF V_ACCOPPIA = 1
         V_ALTUSATA = V_ALTUSATA
      ELSE
         V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
      ENDIF

      IF V_ALTUSATA > V_ALTEZZA
         V_ACCOPPIA = V_ACCOPPIA - 1
         V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
         V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
      ENDIF

      *=> by-passo le righe che non riescono ad essere evasi con l'altezza della bobina in giacenza
      IF V_ALTUSATA = 0
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      SELECT CU_ORD_DL
      SCATTER MEMVAR MEMO

      *=> Scrivo in un cursore di appoggio le righe d'ordine che riesco a programmare
      SELECT CUR_SELEZIONE
      APPEND BLANK
      REPLACE SEL_UNIQUE WITH M.ID_UNIQUE
      REPLACE SEL_CODART WITH M.ORD_CODART
      REPLACE SEL_DESART WITH M.ORD_DESART
      REPLACE SEL_CODCLI WITH M.ORS_CODCLI
      REPLACE SEL_RAGSOC WITH M.ORS_RAGSOC
      REPLACE SEL_NUMORD WITH M.ORS_NUMORD
      REPLACE SEL_DATORD WITH M.ORS_DATORD
      REPLACE SEL_CODCOL WITH M.ORD_CODCOL
      REPLACE SEL_DESCOL WITH M.ORD_DESCOL
      REPLACE SEL_CODMAT WITH M.ORD_CODMAT
      REPLACE SEL_DESMAT WITH M.ORD_DESMAT
      REPLACE SEL_SPESSO WITH M.ORD_SPESSO
      REPLACE SEL_ALTEZZ WITH M.ORD_ALTEZZ
      REPLACE SEL_LUNGHE WITH M.ORD_LUNGHE
      REPLACE SEL_BOBORD WITH M.ORD_NRBSPD
      REPLACE SEL_QTAORD WITH M.ORD_QTASPD
      REPLACE SEL_SPEMAG WITH M.MAG_SPESSO
      REPLACE SEL_ALTMAG WITH M.MAG_ALTEZZ
      REPLACE SEL_LUNMAG WITH M.MAG_QTAML
      REPLACE SEL_ACCOPP WITH V_ACCOPPIA
      REPLACE SEL_BOBACC WITH INT((SEL_BOBORD / SEL_ACCOPP))
      REPLACE SEL_BOBPRG WITH 0
      REPLACE SEL_QTAPRG WITH 0
      REPLACE SEL_CDDIBA WITH V_DIBA
      REPLACE SEL_SCARTO WITH V_SCAR
      REPLACE SEL_CODSYS WITH M.ORD_CODSYS
      REPLACE SEL_CILRET WITH M.ORD_CILRET

      *=> Rilevo il numero di bobine piů basso (l'accoppiamento deve avvenire per stessa altezza e stesso
      *=> numero di bobine da programmare

      IF V_ACCBOBI = 0
         V_ACCBOBI = SEL_BOBACC
      ENDIF

      IF SEL_BOBACC < V_ACCBOBI
         V_ACCBOBI = SEL_BOBACC
      ENDIF

      *=> Determino la nuova altezza con cui si devono confrontare gli altri ordini diminuendola di quella usata

      V_ALTEZZA = V_ALTEZZA - V_ALTUSATA

      SELECT CU_ORD_DL
      SKIP +1

   ENDDO

   SELECT CUR_SELEZIONE
   GO TOP
   IF EOF()
   ELSE
      IF V_BYPASS
      ELSE
         *=> Determino la percentuale di tolleranza sul reso in altezza
         V_PERCNOUSATA = (V_ALTEZZA * 100) / (M.MAG_ALTEZZ - V_CIMOSA)
         IF V_PERCNOUSATA > V_SCAABU
            SELECT CURS_MAG_GG
            REPLACE MAG_BYPASS WITH .T.
            SELECT CUR_SELEZIONE
            ZAP
            SELECT CU_ORD_DL
            SET ORDER TO I_PROGRA
            GO TOP
            LOOP
         ENDIF
      ENDIF
   ENDIF

   *=> Riprendo in esame il cursore provvisorio con le righe d'ordine che sono riuscito ad accoppiare
   *=> per determinerne le esatte quantitŕ

   V_PROGRE = V_PROGRE + 1

   SELECT CUR_SELEZIONE
   GO TOP

   *=> calcolo il numero massimo di bobine che riuscirei a spalmare con la lunghezza della bobina in giacenza
   IF EOF()
   ELSE
      V_MAX_BOB_SPALM = INT((V_LUNGHEZ / V_LUNGORD))
      IF V_ACCBOBI > V_MAX_BOB_SPALM
         V_ACCBOBI = V_MAX_BOB_SPALM
      ENDIF
   ENDIF

   RELEASE T_QTAMQ,T_QTAKG,T_QTAML
   PUBLIC  T_QTAMQ,T_QTAKG,T_QTAML
   T_QTAMQ = 0
   T_QTAKG = 0
   T_QTAML = 0

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      *=> Determino il numero di bobine e la quantitŕ in MQ da programmare per la singola riga d'ordine
      REPLACE SEL_BOBPRG WITH V_ACCBOBI * SEL_ACCOPP
      REPLACE SEL_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTEZZ,SEL_LUNGHE,SEL_BOBPRG)
      SELECT CUR_SELEZIONE
      SCATTER MEMVAR MEMO

      *=> Accedo alle righe d'ordine selezionate dall'utente per aggiornarne le quantitŕ programmate
      SELECT CU_ORD_DL
      SET ORDER TO I_CODSYS	&& PROJECT 13/11/04
      SEEK M.SEL_CODSYS		&& PROJECT 13/11/04
      IF FOUND()
         REPLACE ORD_NRBSPD WITH ORD_NRBSPD - M.SEL_BOBPRG
         REPLACE ORD_QTASPD WITH ORD_QTASPD - M.SEL_QTAPRG
         REPLACE ORD_NRBOBX WITH ORD_NRBOBX + M.SEL_BOBPRG
         REPLACE ORD_QUANTX WITH ORD_QUANTX + M.SEL_QTAPRG
         REPLACE ORD_NRBOBO WITH 0
         REPLACE ORD_QUANTO WITH 0
      ENDIF

      W_QTAKG = TROVA_KG_DA_MQ(M.SEL_CODART,M.SEL_SPESSO,M.SEL_QTAPRG,1)

      *=> Accedo alle giacenze per aggiornarne le quantitŕ programmate
      SELECT CURS_MAG_GG
      REPLACE MAG_GIACEN WITH MAG_GIACEN - M.SEL_QTAPRG
      REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  - M.SEL_QTAPRG
      REPLACE MAG_QTAKG  WITH MAG_QTAKG  - W_QTAKG

      T_QTAMQ = T_QTAMQ + M.SEL_QTAPRG
      T_QTAKG = T_QTAKG + W_QTAKG

      *=> Aggiorno la nuova altezza della bobina residua
      SELECT CURS_MAG_GG
      REPLACE MAG_ALTRES WITH V_ALTEZZA
      REPLACE MAG_COMODO WITH 1

      *=> Scrivo su un nuovo cursore le righe d'ordine che sono riuscito ad accoppiare con le quantitŕ programmate
      SELECT CUR_SPALMATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_PROGRE WITH V_PROGRE
      REPLACE SEL_CODMAC WITH 'SPS'
      REPLACE SEL_DESMAC WITH 'SPS'
      REPLACE SEL_SCARTO WITH V_SCAR
      REPLACE SEL_ALTCOM WITH 99999 - SEL_ALTMAG		&& ALTEZZA COMPLEMENTATA A 99999 PER SORT ALTEZZA DISCENDENTE

      SELECT CUR_SELEZIONE
      SKIP +1

   ENDDO

   *=> Accedo alle giacenze per aggiornarne i metri lineari utilizzati e la lunghezza della bobina
   SELECT CURS_MAG_GG
   REPLACE MAG_QTAML  WITH MAG_QTAML - (V_ACCBOBI * V_LUNGORD)
   REPLACE MAG_ALTRES WITH MAG_ALTEZZ

   *=> Aggiorno le giacenze dettagliate x verificare se rimane della lunghezza in giacenza da spalmare fuori ordine

   T_QTAML = (V_ACCBOBI * V_LUNGORD)

   SCATTER MEMVAR

   V_SEEK = M.MAG_CODMAT + M.MAG_CODCOL + STR(M.MAG_SPESSO,5,0) + STR((M.MAG_ALTEZZ),5,0)

   SELECT DETTA_MAG_GG
   SET ORDER TO I_DETTA
   SEEK V_SEEK

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF DELETED()
         SKIP +1
         LOOP
      ENDIF

      IF T_QTAML > 0
      ELSE
         EXIT
      ENDIF

      IF MAG_CODMAT = M.MAG_CODMAT .AND. MAG_CODCOL = M.MAG_CODCOL .AND. MAG_SPESSO = MAG_SPESSO .AND. MAG_ALTEZZ = MAG_ALTEZZ
      ELSE
         EXIT
      ENDIF

      IF MAG_QTAML > MAG_GMLIMP
      ELSE
         SKIP +1
         LOOP
      ENDIF

      IF MAG_LUNGHE > MAG_GMLIMP
      ELSE
         SKIP +1
         LOOP
      ENDIF

      IF MAG_LUNGHE < T_QTAML
      ELSE
         REPLACE MAG_QTAIMP WITH MAG_QTAIMP + T_QTAMQ
         REPLACE MAG_GKGIMP WITH MAG_GKGIMP + T_QTAKG
         REPLACE MAG_GMLIMP WITH MAG_GMLIMP + T_QTAML
         T_QTAML = 0
         T_QTAMQ = 0
         T_QTAKG = 0
         EXIT
      ENDIF

      REPLACE MAG_QTAIMP WITH MAG_GIACEN
      REPLACE MAG_GKGIMP WITH MAG_QTAKG
      REPLACE MAG_GMLIMP WITH MAG_QTAML
      T_QTAML = T_QTAML - MAG_QTAML
      T_QTAMQ = T_QTAMQ - MAG_GIACEN
      T_QTAKG = T_QTAKG - MAG_QTAKG

      SKIP +1

   ENDDO

   *=> Gestione del fuori ordine per completare la bobina in linea
   SELECT DETTA_MAG_GG
   IF EOF()
   ELSE
      T_DIFLUN = MAG_QTAML - MAG_GMLIMP
      IF T_DIFLUN > M.MIC_LMAXFO
      ELSE
         IF T_DIFLUN > 0
            V_PROGRE = V_PROGRE + 1
            SELECT CUR_SPALMATURA
            SCATTER MEMVAR MEMO
            APPEND BLANK
            GATHER MEMVAR MEMO
            REPLACE SEL_PROGRE WITH V_PROGRE
            REPLACE SEL_UNIQUE WITH SPACE(32)
            *REPLACE SEL_CODART WITH M.ORD_CODART
            *REPLACE SEL_DESART WITH M.ORD_DESART
            REPLACE SEL_CODCLI WITH '9999999999'
            REPLACE SEL_RAGSOC WITH 'FUORI ORDINE'
            REPLACE SEL_NUMORD WITH '99999'
            *REPLACE SEL_DATORD WITH M.ORS_DATORD
            *REPLACE SEL_CODCOL WITH M.ORD_CODCOL
            *REPLACE SEL_DESCOL WITH M.ORD_DESCOL
            *REPLACE SEL_CODMAT WITH M.ORD_CODMAT
            *REPLACE SEL_DESMAT WITH M.ORD_DESMAT
            *REPLACE SEL_SPESSO WITH M.ORD_SPESSO
            REPLACE SEL_ALTEZZ WITH M.MAG_ALTEZZ
            REPLACE SEL_LUNGHE WITH T_DIFLUN
            REPLACE SEL_BOBORD WITH 1
            REPLACE SEL_QTAORD WITH TROVA_MQ_DA_AL(SEL_ALTEZZ,SEL_LUNGHE,SEL_BOBORD)
            REPLACE SEL_SPEMAG WITH M.MAG_SPESSO
            REPLACE SEL_ALTMAG WITH M.MAG_ALTEZZ
            REPLACE SEL_LUNMAG WITH M.MAG_QTAML
            REPLACE SEL_ACCOPP WITH 1
            REPLACE SEL_BOBACC WITH 1
            REPLACE SEL_BOBPRG WITH 1
            REPLACE SEL_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTEZZ,SEL_LUNGHE,SEL_BOBPRG)
            *REPLACE SEL_CDDIBA WITH V_DIBA
            *REPLACE SEL_SCARTO WITH V_SCAR
            REPLACE SEL_CODSYS WITH SYS(2015)
            *REPLACE SEL_CILRET WITH M.ORD_CILRET
            W_QTAMQ = TROVA_MQ_DA_AL(M.MAG_ALTEZZ,T_DIFLUN,1)
            W_QTAKG = TROVA_KG_DA_MQ(M.SEL_CODART,M.MAG_SPESSO,W_QTAMQ,1)
            SELECT CURS_MAG_GG
            REPLACE MAG_GIACEN WITH MAG_GIACEN - W_QTAMQ
            REPLACE MAG_QTAMQ  WITH MAG_QTAMQ - W_QTAMQ
            REPLACE MAG_QTAKG  WITH MAG_QTAKG - W_QTAKG
            REPLACE MAG_QTAML  WITH MAG_QTAML - T_DIFLUN
         ENDIF
      ENDIF
   ENDIF

   SELECT CURS_MAG_GG
   REPLACE MAG_BYPASS WITH .F. ALL

   SELECT CUR_SELEZIONE
   ZAP

   SELECT CU_ORD_DL
   SET ORDER TO I_PROGRA
   GO TOP

ENDDO

SELECT CUR_SPALMATURA
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF SEL_CODMAC = 'SPS'
   ELSE
      SKIP +1
      LOOP
   ENDIF
   SCATTER MEMVAR MEMO
   SELECT CU_ORD_DL
   SET ORDER TO I_CODSYS		&& PROJECT 13/11/04
   SEEK M.SEL_CODSYS			&& PROJECT 13/11/04
   IF FOUND()
      REPLACE ORD_CODMAC WITH 'SP1'
   ENDIF
   SELECT CUR_SPALMATURA
   REPLACE SEL_CODMAC WITH 'SP1'
   REPLACE SEL_DESMAC WITH 'SPALMATRICE 1'
   SKIP +1
ENDDO

SELECT CUR_SPALMATURA
INDEX ON STR(SEL_CILRET,3,0) + SEL_CDDIBA + STR(SEL_ALTCOM,5,0) + SEL_CODART + STR(SEL_PROGRE,6,0) TAG I_ORDRIN ADDITIVE
SET ORDER TO I_ORDRIN
GO TOP

=DEFPUB(SELECT())
SCATTER MEMVAR MEMO BLANK
HH=AFIELDS(TRANSITO)
CREATE CURSOR RIN_SPALMATURA FROM ARRAY TRANSITO

SELECT CUR_SPALMATURA
V_PROGRE = 1
V_PR     = SEL_PROGRE
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   SCATTER MEMVAR MEMO
   IF SEL_PROGRE = V_PR
      SELECT RIN_SPALMATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_PROGRE WITH V_PROGRE
   ELSE
      V_PROGRE = V_PROGRE + 1
      V_PR     = SEL_PROGRE
      LOOP
   ENDIF
   SELECT CUR_SPALMATURA
   SKIP +1
ENDDO
SELECT CUR_SPALMATURA
ZAP
SELECT RIN_SPALMATURA
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   SCATTER MEMVAR MEMO
   SELECT CUR_SPALMATURA
   APPEND BLANK
   GATHER MEMVAR MEMO
   SELECT NOP_SPALMATURA
   SET ORDER TO I_CODSYS			&& PROJECT 13/11/04
   SEEK M.SEL_CODSYS				&& PROJECT 13/11/04
   IF FOUND()
   ELSE
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_BOBPRG WITH 0
      REPLACE SEL_QTAPRG WITH 0
   ENDIF
   REPLACE SELEZIONE WITH SPACE(10)
   SELECT RIN_SPALMATURA
   SKIP +1
ENDDO

SELECT CUR_SPALMATURA
GO TOP

RETURN


***************************************************************************
PROCEDURE spalmatura_programmaordinifornitori						
***************************************************************************

CREATE CURSOR CUR_SELEZIONE (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50), SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                             SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03), SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                             SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05), SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                             SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05), SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                             SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16), SEL_SCARTO L(1),  ;
                             SEL_CODSYS C(10),   SEL_CILRET N(03))


*=> ********************************************************************  <=*
*=>                                                                       <=*
*=>    P R O G R A M M A Z I O N E   O R D I N I   A   F O R N I T O R I  <=*
*=>                                                                       <=*
*=> ********************************************************************  <=*


SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP
REPLACE ORD_CODMAC WITH SPACE(03) ALL

*=> ELABORO SOLO LE MACCHINE DI PRODUZIONE IN SPALMATURA

SELECT CU_MAC_AN
SET ORDER TO I_ORDINE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF MAC_TIPO = 1						&& 1=SPALMATURA  -  SOLO MACCHINE DI SPALMATURA
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF ALLTRIM(SELEZIONE) = "=>"			&& MACCHINA SELEZIONATA
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR

   *=> ELABORO TUTTE LE RIGHE D'ORDINE FORNITORE SELEZIONATE PER LA PRODUZIONE IN SPALMATURA

   SELECT CU_ORD_DL
   SET ORDER TO I_PROGRA
   GO TOP

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      *=> ELABORO SOLO LE RIGHE CHE NON HANNO PROGRAMMATO TUTTO QUANTO RICHIESTO DALL'UTENTE
      IF ORD_NRBSPD > 0
      ELSE
         SKIP +1
         LOOP
      ENDIF

      *=> BY-PASSO QUELLE RIGHE CHE HO GIA' ELABORATO PER LA MACCHINA IN QUESTIONE
      IF ORD_CODMAC = M.MAC_CODICE
         SKIP +1
         LOOP
      ENDIF

      *=> BY-PASSO QUELLE RIGHE CHE NON DEVONO ESSERE SPALMATE (ORDINI DI FILM NUDO O SENZA DI.BA.)
      IF ORD_UM = 'KG' .OR. EMPTY(ALLTRIM(ORD_CDDIBA))
         SKIP +1
         LOOP
      ENDIF

      WAIT WINDOWS "PROGRAMMAZIONE DELLE BOBINE DI FILM NUDO DA ORDINARE (2) : " + CHR(13) + ;
                   "Stň elaborando l'articolo " + ORD_CODART + "Colore : " + ALLTRIM(ord_descol) + " Altezza : " + ALLTRIM(STR(ORD_ALTEZZ,5,0)) + " Lunghezza : " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + CHR(13) + ;
                   "Nr.bob. : " + ALLTRIM(STR(ORD_NRBSPD,7,0)) + " Nr.Ordine : " + ORS_NUMORD + " del " + ORS_DATORD + " Cliente : " + ORS_RAGSOC NOWAIT


      SCATTER MEMVAR MEMO

      V_DIBA = M.ORD_CDDIBA

      *=> ACCESSO ALLA TABELLA DELLE CAPACITA PRODUTTIVE DELLE MACCHINE PER PRELEVARNE I PARAMETRI DI ELABORAZIONE

      V_ALMAFN = 0		&& ALTEZZA MASSIMA FILM NUDO IN INPUT
      V_ALMIFN = 0		&& ALTEZZA MINIMA FILM NUDO IN INPUT
      V_SCAABU = 0		&& PERCENTUALE DI SCARTO TOLLERATO SU ALTEZZA BOBINA IN INPUT
      V_LUMIFN = 0		&& LUNGHEZZA MINIMA FILM NUDO IN INPUT
      V_LUMAIN = 0		&& LUNGHEZZA MASSIMA FILM IN INPUT

      x_clav = "cap_codlav = 'SPA'"
      x_cmac = "cap_codmac = '" + ALLTRIM(M.MAC_CODICE) + "'"
      x_cmat = "cap_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
      x_diba = "cap_cddiba = '" + ALLTRIM(V_DIBA) + "'"
      x_cond = x_clav + " and " + x_cmac + " and " + x_cmat + " and " + x_diba
      cSql   = "select * from u_pro_ca where " + x_cond
      IF !ExecCommand(cSql,"U_PRO_CA")
         return(.f.)
      ENDIF
      SELECT U_PRO_CA
      GO TOP
      IF EOF()
         x_cond = x_clav + " and " + x_cmac + " and " + x_cmat
         cSql   = "select * from u_pro_ca where " + x_cond
         IF !ExecCommand(cSql,"U_PRO_CA")
            return(.f.)
         ENDIF
         SELECT U_PRO_CA
         GO TOP
         IF EOF()
            x_cond = x_clav + " and " + x_cmac
            cSql   = "select * from u_pro_ca where " + x_cond
            IF !ExecCommand(cSql,"U_PRO_CA")
               return(.f.)
            ENDIF
            SELECT U_PRO_CA
            GO TOP
            IF EOF()
            ELSE
               V_ALMAFN = CAP_ALMAFN
               V_ALMIFN = CAP_ALMIFN
               V_SCAABU = CAP_SCAABU
               V_LUMIFN = CAP_LUMIFN
               V_LUMAIN = CAP_LUMAIN
            ENDIF
         ELSE
            V_ALMAFN = CAP_ALMAFN
            V_ALMIFN = CAP_ALMIFN
            V_SCAABU = CAP_SCAABU
            V_LUMIFN = CAP_LUMIFN
            V_LUMAIN = CAP_LUMAIN
         ENDIF
      ELSE
         V_ALMAFN = CAP_ALMAFN
         V_ALMIFN = CAP_ALMIFN
         V_SCAABU = CAP_SCAABU
         V_LUMIFN = CAP_LUMIFN
         V_LUMAIN = CAP_LUMAIN
      ENDIF

      *=> BY-PASSO QUELLE RIGHE CHE HANNO IL LEGAME CON LA MACCHINA DI PRODUZIONE SENZA ALTEZZA MAX FILM NUDO IN INPUT
      IF V_ALMAFN = 0
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Acquisizione dello spessore compatibile
      *=> - accedo con key = spessore del film ordinato
      *=> - acquisisco dalla tabella lo spessore del film nudo compatibile.
      x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
      x_tmat = "mic_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
      x_cond = x_spes + " and " + x_tmat
      Csql   = "select * from u_pro_my where " + x_cond
      IF !ExecCommand(Csql,"u_pro_my")
         return(.f.)
      ENDIF
      SELECT U_PRO_MY
      GO TOP
      IF EOF()
         x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
         x_tmat = "mic_codmat = SPACE(03)"
         x_cond = x_spes + " and " + x_tmat
         Csql   = "select * from u_pro_my where " + x_cond
         IF !ExecCommand(Csql,"u_pro_my")
            return(.f.)
         ENDIF
         SELECT U_PRO_MY
         GO TOP
         IF EOF()
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF
      ENDIF
      SCATTER MEMVAR

      *=> Forzatura degli spessori compatibili per una casistica di ordini particolari
      *=> utilizzo della famiglia G nei colori bianco o bianco/nero con spessore 80 o 100
      IF SUBSTR(V_DIBA,4,1) = 'G'
         IF M.ORD_CODCOL = 'BIA' .OR. M.ORD_CODCOL = 'B/N'
            IF M.ORD_SPESSO = 80
               M.MIC_SPESDA = 75
               M.MIC_SPESAL = 75
            ENDIF
            IF M.ORD_SPESSO = 100
               M.MIC_SPESDA = 90
               M.MIC_SPESAL = 90
            ENDIF
         ENDIF
      ENDIF

      *=> Ricerca giacenze ordinate a fornitori riepilogate in ordine di altezza e lunghezza DISCENDENTE

      V_SEEK = M.ORD_CODMAT + M.ORD_CODCOL

      SET NEAR ON

      SELECT CURS_MAG_OR
      SET ORDER TO I_INDICE3
      SEEK V_SEEK

      V_TROV = .F.

      DO WHILE .T.

         IF EOF()
            EXIT
         ENDIF

         *=> Controllo rottura chiave per termine elaborazione
         IF MAG_CODMAT = M.ORD_CODMAT .AND. MAG_CODCOL = M.ORD_CODCOL
         ELSE
            EXIT
         ENDIF

         IF DELETED()
            SKIP +1
            LOOP
         ENDIF

         *=> By-passo le giacenze a 0
         IF MAG_GIACEN > 0
         ELSE
            SKIP +1
            LOOP
         ENDIF

         *=> By-passo gli spessori che non rientrano nel range
         IF MAG_SPESSO > M.MIC_SPESAL
            SKIP +1
            LOOP
         ENDIF

         *=> By-passo gli spessori che non rientrano nel range
         IF MAG_SPESSO < M.MIC_SPESDA
            SKIP +1
            LOOP
         ENDIF

         *=> By-passo le altezze inferiori a quelle dell'ordine
         IF MAG_ALTEZZ < (M.ORD_ALTEZZ+V_CIMOSA)
            SKIP +1
            LOOP
         ENDIF

         *=> By-passo le altezze superiori a quelle previste in input per la spalmatura
         IF MAG_ALTEZZ > V_ALMAFN
            SKIP +1
            LOOP
         ENDIF

         *=> By-passo le altezze inferiori a quelle previste in input per la spalmatura
         IF MAG_ALTRES < V_ALMIFN
            SKIP +1
            LOOP
         ENDIF

         *=> By-passo le lunghezze inferiori a quelle previste in input per la spalmatura
         IF MAG_QTAML < V_LUMIFN
            SKIP +1
            LOOP
         ENDIF

         V_TROV = .T.

         SCATTER MEMVAR MEMO
         EXIT

      ENDDO

      SET NEAR OFF

      *=> Test se č stata trovata giacenza ordinata compatibile con quanto ordinato
      IF V_TROV
      ELSE
         SELECT CU_ORD_DL
         REPLACE ORD_CODMAC WITH M.MAC_CODICE
         SKIP +1
         LOOP
      ENDIF

      *=> Imposto l'altezza iniziale della bobina in giacenza togliendogli la cimosa (40 mm)
      *=> questo perchč le bobine di film nudo vengono caricate con l'altezza che prevede la cimosa,
      *=> mentre le bobine ordinate dai clienti sono al netto delle cimose
      IF M.MAG_ALTEZZ = M.MAG_ALTRES
         V_ALTEZZA = M.MAG_ALTEZZ - V_CIMOSA
         V_ALTEZZA = V_ALTEZZA - (V_TAGLIO * 2)
      ELSE
         V_ALTEZZA = M.MAG_ALTRES
      ENDIF
      V_LUNGHEZ = M.MAG_QTAML
      V_ACCBOBI = 0

      *=> Inizio loop di accoppiamento righe d'ordine con stessa lunghezza
      SELECT CU_ORD_DL
      V_LUNGORD = ORD_LUNGHE
      V_CODMATE = ORD_CODMAT
      V_CODCOLO = ORD_CODCOL
      V_CODSPES = ORD_SPESSO
      V_CODARTI = ORD_CODART
      V_CODDIBA = ORD_CDDIBA
      V_CILRETI = ORD_CILRET

      IF V_ALTEZZA < ORD_ALTEZZ			&& PROJECT 19/01/2005
         SELECT CU_ORD_DL
         REPLACE ORD_CODMAC WITH M.MAC_CODICE
         SKIP +1
         LOOP
      ENDIF

      DO WHILE .T.

         IF EOF()
            EXIT
         ENDIF

         *=> Determino la percentuale di tolleranza sul reso in altezza
         V_PERCNOUSATA = (V_ALTEZZA * 100) / M.MAG_ALTEZZ
         IF V_PERCNOUSATA > V_SCAABU
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso tipo prodotto
         IF ORD_CODMAT = V_CODMATE
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia della stessa di.ba.
         IF ORD_CDDIBA = V_CODDIBA
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia con lo stesso cilindro retinato
         IF ORD_CILRET = V_CILRETI
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso prodotto
         IF ORD_CODART = V_CODARTI
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso colore
         IF ORD_CODCOL = V_CODCOLO
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso spessore
         IF ORD_SPESSO = V_CODSPES
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia della stessa lunghezza
         IF ORD_LUNGHE = V_LUNGORD
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
        ENDIF

         *=> Determino quanti accoppiamenti riesco a fare con l'altezza della bobina in giacenza
         V_ACCOPPIA = INT((V_ALTEZZA / ORD_ALTEZZ))
         *IF V_ACCOPPIA > ORD_NRBOBD
         *   V_ACCOPPIA = ORD_NRBOBD
         *ENDIF
         IF V_ACCOPPIA > ORD_NRBSPD
            V_ACCOPPIA = ORD_NRBSPD
         ENDIF

         *=> Determino l'altezza usata per l'accoppiamento  PROJECT 4/01/2005
         V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
         IF V_ACCOPPIA = 1
            V_ALTUSATA = V_ALTUSATA
         ELSE
            V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
         ENDIF

         *=> by-passo le righe che non riescono ad essere evasi con l'altezza della bobina in giacenza
         IF V_ALTUSATA = 0
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         SELECT CU_ORD_DL
         SCATTER MEMVAR MEMO

         *=> Scrivo in un cursore di appoggio le righe d'ordine che riesco a programmare
         SELECT CUR_SELEZIONE
         APPEND BLANK
         REPLACE SEL_UNIQUE WITH M.ID_UNIQUE
         REPLACE SEL_CODART WITH M.ORD_CODART
         REPLACE SEL_DESART WITH M.ORD_DESART
         REPLACE SEL_CODCLI WITH M.ORS_CODCLI
         REPLACE SEL_RAGSOC WITH M.ORS_RAGSOC
         REPLACE SEL_NUMORD WITH M.ORS_NUMORD
         REPLACE SEL_DATORD WITH M.ORS_DATORD
         REPLACE SEL_CODCOL WITH M.ORD_CODCOL
         REPLACE SEL_DESCOL WITH M.ORD_DESCOL
         REPLACE SEL_CODMAT WITH M.ORD_CODMAT
         REPLACE SEL_DESMAT WITH M.ORD_DESMAT
         REPLACE SEL_SPESSO WITH M.ORD_SPESSO
         REPLACE SEL_ALTEZZ WITH M.ORD_ALTEZZ
         REPLACE SEL_LUNGHE WITH M.ORD_LUNGHE
         REPLACE SEL_BOBORD WITH M.ORD_NRBSPD
         REPLACE SEL_QTAORD WITH M.ORD_QTASPD
         REPLACE SEL_SPEMAG WITH M.MAG_SPESSO
         REPLACE SEL_ALTMAG WITH M.MAG_ALTEZZ
         REPLACE SEL_LUNMAG WITH M.MAG_QTAML
         REPLACE SEL_ACCOPP WITH V_ACCOPPIA
         REPLACE SEL_BOBACC WITH INT((SEL_BOBORD / SEL_ACCOPP))
         REPLACE SEL_BOBPRG WITH 0
         REPLACE SEL_QTAPRG WITH 0
         REPLACE SEL_CDDIBA WITH V_DIBA
         REPLACE SEL_CILRET WITH M.ORD_CILRET
      *   REPLACE SEL_SCARTO WITH V_SCAR
         REPLACE SEL_CODSYS WITH M.ORD_CODSYS

         *=> Rilevo il numero di bobine piů basso (l'accoppiamento deve avvenire per stessa altezza e stesso
         *=> numero di bobine da programmare

         IF V_ACCBOBI = 0
            V_ACCBOBI = SEL_BOBACC
         ENDIF

         IF SEL_BOBACC < V_ACCBOBI
            V_ACCBOBI = SEL_BOBACC
         ENDIF

         *=> Determino la nuova altezza con cui si devono confrontare gli altri ordini diminuendola di quella usata

         V_ALTEZZA = V_ALTEZZA - V_ALTUSATA

         SELECT CU_ORD_DL
         SKIP +1

      ENDDO

      *=> Riprendo in esame il cursore provvisorio con le righe d'ordine che sono riuscito ad accoppiare
      *=> per determinerne le esatte quentitŕ

      SELECT CUR_SELEZIONE
      GO TOP

      *=> calcolo il numero massimo di bobine che riuscirei a spalmare con la lunghezza della bobina in giacenza
      IF EOF()
      ELSE
         V_MAX_BOB_SPALM = INT((V_LUNGHEZ / V_LUNGORD))
         IF V_ACCBOBI > V_MAX_BOB_SPALM
            V_ACCBOBI = V_MAX_BOB_SPALM
         ENDIF
      ENDIF

      DO WHILE .T.

         IF EOF()
            EXIT
         ENDIF

         *=> Determino il numero di bobine e la quantitŕ in MQ da programmare per la singola riga d'ordine
         REPLACE SEL_BOBPRG WITH V_ACCBOBI * SEL_ACCOPP
         REPLACE SEL_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTEZZ,SEL_LUNGHE,SEL_BOBPRG)
         SELECT CUR_SELEZIONE
         SCATTER MEMVAR MEMO

         *=> Accedo alle righe d'ordine selezionate dall'utente per aggiornarne le quantitŕ programmate
         SELECT CU_ORD_DL
         SET ORDER TO I_CODSYS
         SEEK M.SEL_CODSYS
         IF FOUND()
            REPLACE ORD_NRBSPD WITH ORD_NRBSPD - M.SEL_BOBPRG
            REPLACE ORD_QTASPD WITH ORD_QTASPD - M.SEL_QTAPRG
            REPLACE ORD_NRBOBO WITH ORD_NRBOBO + M.SEL_BOBPRG
            REPLACE ORD_QUANTO WITH ORD_QUANTO + M.SEL_QTAPRG
            REPLACE ORD_NRBOBY WITH ORD_NRBOBY + M.SEL_BOBPRG
            REPLACE ORD_QUANTY WITH 1
         ENDIF

         *=> Accedo alle giacenze per aggiornarne le quantitŕ programmate
         SELECT CURS_MAG_OR
         REPLACE MAG_GIACEN WITH MAG_GIACEN - M.SEL_QTAPRG
         REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  - M.SEL_QTAPRG
         REPLACE MAG_QTAKG  WITH MAG_QTAKG  - TROVA_KG_DA_MQ(M.SEL_CODART,M.SEL_SPESSO,M.SEL_QTAPRG,1)
         *=> Aggiorno la nuova altezza della bobina residua
         SELECT CURS_MAG_OR
         REPLACE MAG_ALTRES WITH V_ALTEZZA

         SELECT CUR_SELEZIONE
         SKIP +1

      ENDDO

      *=> Accedo alle giacenze per aggiornarne i metri lineari utilizzati e quindi la lunghezza della bobina
      SELECT CURS_MAG_OR
      REPLACE MAG_QTAML  WITH MAG_QTAML - (V_ACCBOBI * V_LUNGORD)
      REPLACE MAG_ALTRES WITH MAG_ALTEZZ

      SELECT CUR_SELEZIONE
      ZAP

      SELECT CU_ORD_DL
      SET ORDER TO I_PROGRA
      GO TOP

   ENDDO

   SELECT CU_MAC_AN
   SKIP +1

ENDDO

SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF ORD_NRBSPD > 0
      IF ORD_NRBOBY = 0
         REPLACE ORD_NRBOBO WITH ORD_NRBSPD
         REPLACE ORD_QUANTO WITH ORD_QTASPD
         REPLACE ORD_NRBOBY WITH ORD_NRBSPD
         REPLACE ORD_QUANTY WITH 1
      ENDIF
   ENDIF
   REPLACE ORD_CODMAC WITH SPACE(03)
   SKIP +1
ENDDO

* -->> Creazione cursore giacenze riepilogate magazzino M.P. bobine da ordinare dettagliate
* -----------------------------------------------------------------------------------------
CREATE CURSOR CUR_MAG_DE (MAG_CODART C(16), MAG_DESART C(50),    MAG_ANAART C(16),  MAG_CODMAT C(03),  MAG_DESMAT C(50),  ;
                           MAG_CODCOL C(03), MAG_DESCOL C(50),   MAG_SPESSO N(05),  MAG_ALTEZZ N(05),  MAG_LUNGHE N(06),  ;
                           MAG_ALTRES N(05), MAG_GIACEN N(12,2), MAG_QTAMQ N(18,2), MAG_QTAKG N(18,2), MAG_QTAML N(18,2), ;
                           MAG_CDDIBA C(16), MAG_LUNORD N(15),   MAG_NUMBOB N(09))

SELECT CUR_MAG_DE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + STR(MAG_LUNGHE,6,0) 	TAG I_INDICE1 ADDITIVE
INDEX ON MAG_ANAART 																				TAG I_INDICE2 ADDITIVE
INDEX ON STR(MAG_ALTEZZ,5,0) + STR(MAG_QTAML,6,0)													TAG I_INDICE3 DESCENDING ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + STR(MAG_LUNORD,6,0) 	TAG I_INDICE4 ADDITIVE

V_DIBA          = SPACE(16)
V_ALMAFN        = 0
V_SCAABU        = 0
V_TROV          = .F.
V_ALTEZZA       = 0
V_LUNGHEZ       = 0
V_ACCBOBI       = 0
V_PERCNOUSATA   = 0
V_ACCOPPIA      = 0
V_ALTUSATA      = 0
V_MAX_BOB_SPALM = 0
V_LUNGORD       = 0
V_ALMIFN        = 0
V_PROGRE        = 0
V_LUMIFN        = 0


CREATE CURSOR CUR_SELEZIONE (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50), SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                             SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03), SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                             SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05), SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                             SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05), SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                             SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16), SEL_SCARTO L(1),  ;
                             SEL_CODSYS C(10),   SEL_CILRET N(03))

*=> ******************************************************************** <=*
*=>                                                                      <=*
*=>    P R O G R A M M A Z I O N E   D E L L A   S P A L M A T U R A     <=*
*=>                                                                      <=*
*=> ==================================================================== <=*
*=>                                                                      <=*
*=>        ELABORO SOLO LE MACCHINE DI PRODUZIONE IN SPALMATURA    §°§°§°§      <=*
*=>                                                                      <=*
*=> ******************************************************************** <=*

SELECT CU_MAC_AN
SET ORDER TO I_ORDINE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF MAC_TIPO = 1						&& 1=SPALMATURA  -  SOLO MACCHINE DI SPALMATURA
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF ALLTRIM(SELEZIONE) = "=>"			&& MACCHINA SELEZIONATA
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR

   *=> ELABORO TUTTE LE RIGHE D'ORDINE FORNITORE SELEZIONATE PER LA PRODUZIONE IN SPALMATURA


   SELECT CU_ORD_DL
   SET ORDER TO I_PROGRA
   GO TOP

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      *=> BY-PASSO QUELLE RIGHE CHE HANNO IL NUMERO DI BOBINE DA SPALMARE = 0
      IF ORD_NRBSPD > 0
      ELSE
         SKIP +1
         LOOP
      ENDIF

      *=> BY-PASSO QUELLE RIGHE CHE HO GIA' ELABORATO PER LA MACCHINA IN QUESTIONE
      IF ORD_CODMAC = M.MAC_CODICE
         SKIP +1
         LOOP
      ENDIF

      *=> BY-PASSO QUELLE RIGHE CHE NON DEVONO ESSERE SPALMATE (ORDINI DI FILM NUDO O SENZA DI.BA.)
      IF ORD_UM = 'KG' .OR. EMPTY(ALLTRIM(ORD_CDDIBA))
         SKIP +1
         LOOP
      ENDIF

      WAIT WINDOWS "PROGRAMMAZIONE DELLE BOBINE DI FILM NUDO DA ORDINARE (3) : " + CHR(13) + ;
                   "Stň elaborando l'articolo " + ORD_CODART + "Colore : " + ALLTRIM(ord_descol) + " Altezza : " + ALLTRIM(STR(ORD_ALTEZZ,5,0)) + " Lunghezza : " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + CHR(13) + ;
                   "Nr.bob. : " + ALLTRIM(STR(ORD_NRBSPD,7,0)) + " Nr.Ordine : " + ORS_NUMORD + " del " + ORS_DATORD + " Cliente : " + ORS_RAGSOC NOWAIT

      SCATTER MEMVAR MEMO

      V_DIBA = M.ORD_CDDIBA

      *=> ACCESSO ALLA TABELLA DELLE CAPACITA PRODUTTIVE DELLE MACCHINE PER PRELEVARNE I PARAMETRI DI ELABORAZIONE

      V_ALMAFN = 0		&& ALTEZZA MASSIMA FILM NUDO IN INPUT
      V_ALMIFN = 0		&& ALTEZZA MINIMA FILM NUDO IN INPUT
      V_SCAABU = 0		&& PERCENTUALE DI SCARTO TOLLERATO SU ALTEZZA BOBINA IN INPUT
      V_LUMIFN = 0		&& LUNGHEZZA MINIMA FILM NUDO IN INPUT

      x_clav = "cap_codlav = 'SPA'"
      x_cmac = "cap_codmac = '" + ALLTRIM(M.MAC_CODICE) + "'"
      x_cmat = "cap_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
      x_diba = "cap_cddiba = '" + ALLTRIM(V_DIBA) + "'"
      x_cond = x_clav + " and " + x_cmac + " and " + x_cmat + " and " + x_diba
      cSql   = "select * from u_pro_ca where " + x_cond
      IF !ExecCommand(cSql,"U_PRO_CA")
         return(.f.)
      ENDIF
      SELECT U_PRO_CA
      GO TOP
      IF EOF()
         x_cond = x_clav + " and " + x_cmac + " and " + x_cmat
         cSql   = "select * from u_pro_ca where " + x_cond
         IF !ExecCommand(cSql,"U_PRO_CA")
            return(.f.)
         ENDIF
         SELECT U_PRO_CA
         GO TOP
         IF EOF()
            x_cond = x_clav + " and " + x_cmac
            cSql   = "select * from u_pro_ca where " + x_cond
            IF !ExecCommand(cSql,"U_PRO_CA")
               return(.f.)
            ENDIF
            SELECT U_PRO_CA
            GO TOP
            IF EOF()
            ELSE
               V_ALMAFN = CAP_ALMAFN
               V_ALMIFN = CAP_ALMIFN
               V_SCAABU = CAP_SCAABU
               V_LUMIFN = CAP_LUMIFN
               V_LUMAIN = CAP_LUMAIN
            ENDIF
         ELSE
            V_ALMAFN = CAP_ALMAFN
            V_ALMIFN = CAP_ALMIFN
            V_SCAABU = CAP_SCAABU
            V_LUMIFN = CAP_LUMIFN
            V_LUMAIN = CAP_LUMAIN
         ENDIF
      ELSE
         V_ALMAFN = CAP_ALMAFN
         V_ALMIFN = CAP_ALMIFN
         V_SCAABU = CAP_SCAABU
         V_LUMIFN = CAP_LUMIFN
         V_LUMAIN = CAP_LUMAIN
      ENDIF

      *=> BY-PASSO QUELLE RIGHE CHE HANNO IL LEGAME CON LA MACCHINA DI PRODUZIONE SENZA ALTEZZA MAX FILM NUDO IN INPUT
      IF V_ALMAFN = 0
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Acquisizione dello spessore compatibile
      *=> - accedo con key = spessore del film ordinato
      *=> - acquisisco dalla tabella lo spessore del film nudo compatibile.
      x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
      x_tmat = "mic_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
      x_cond = x_spes + " and " + x_tmat
      Csql   = "select * from u_pro_my where " + x_cond
      IF !ExecCommand(Csql,"u_pro_my")
         return(.f.)
      ENDIF
      SELECT U_PRO_MY
      GO TOP
      IF EOF()
         x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
         x_tmat = "mic_codmat = SPACE(03)"
         x_cond = x_spes + " and " + x_tmat
         Csql   = "select * from u_pro_my where " + x_cond
         IF !ExecCommand(Csql,"u_pro_my")
            return(.f.)
         ENDIF
         SELECT U_PRO_MY
         GO TOP
         IF EOF()
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF
      ENDIF
      SCATTER MEMVAR

      *=> Forzatura degli spessori compatibili per una casistica di ordini particolari
      *=> utilizzo della famiglia G nei colori bianco o bianco/nero con spessore 80 o 100
      IF SUBSTR(V_DIBA,4,1) = 'G'
         IF M.ORD_CODCOL = 'BIA' .OR. M.ORD_CODCOL = 'B/N'
            IF M.ORD_SPESSO = 80
               M.MIC_SPESDA = 75
               M.MIC_SPESAL = 75
            ENDIF
            IF M.ORD_SPESSO = 100
               M.MIC_SPESDA = 90
               M.MIC_SPESAL = 90
            ENDIF
         ENDIF
      ENDIF

		V_CAR = SPACE(16)
		V_DAR = SPACE(50)

		x_soci  = "art_codsoc = '" + PUB_CODSOC + "'"
		x_tmat  = "art_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
		x_imba  = "art_codimb = art_codimb"
		x_colo  = "art_codcol = '" + ALLTRIM(M.ORD_CODCOL) + "'"
		x_spes  = "art_spesso = " + ALLTRIM(STR(M.MIC_SPEORD,5,0))
		x_alte  = "art_altezz = " + ALLTRIM(STR(V_ALMAFN,5,0))
		x_lung  = "art_lunghe = " + ALLTRIM(STR(M.MIC_LUNORD,6,0))
		x_arti  = "art_codpri = art_codpri"
		x_cond  = x_soci + " and " + x_arti
		x_cond1 = " and " + x_tmat + " and " + x_imba + " and " + x_colo
		x_cond2 = " and " + x_spes + " and " + x_alte + " and " + x_lung
		x_cond3 = " and 1=1 "
		x_cond  = x_cond + x_cond1 + x_cond2 + x_cond3
		Csql    = "select * from u_art_pr where " + x_cond
		IF !ExecCommand(cSql,"CU_ART_PR")
		   return(.f.)
		ENDIF
		SELECT CU_ART_PR
		GO TOP
		IF EOF()
		   x_lung  = "art_lunghe = art_lunghe"
		   x_cond  = x_soci + " and " + x_arti
		   x_cond1 = " and " + x_tmat + " and " + x_imba + " and " + x_colo
		   x_cond2 = " and " + x_spes + " and " + x_alte + " and " + x_lung
		   x_cond3 = " and 1=1 "
		   x_cond  = x_cond + x_cond1 + x_cond2 + x_cond3
		   Csql    = "select * from u_art_pr where " + x_cond
		   IF !ExecCommand(cSql,"CU_ART_PR")
		      return(.f.)
		   ENDIF
		   SELECT CU_ART_PR
		   GO TOP
		   IF EOF()
		      x_alte  = "art_altezz = art_altezz"
		      x_cond  = x_soci + " and " + x_arti
		      x_cond1 = " and " + x_tmat + " and " + x_imba + " and " + x_colo
		      x_cond2 = " and " + x_spes + " and " + x_alte + " and " + x_lung
		      x_cond3 = " and 1=1 "
		      x_cond  = x_cond + x_cond1 + x_cond2 + x_cond3
		      Csql    = "select * from u_art_pr where " + x_cond
		      IF !ExecCommand(cSql,"CU_ART_PR")
		         return(.f.)
		      ENDIF
		      SELECT CU_ART_PR
		      GO TOP
		      IF EOF()
		      ELSE
		         DO WHILE .T.
		            IF EOF()
		               EXIT
		            ENDIF
		            IF ART_TIPART = 'A'
		               V_CAR = ART_CODPRI
		               V_DAR = ART_DESCR
		               EXIT
		            ENDIF
		            SKIP +1
		         ENDDO
		      ENDIF
		   ELSE
		      DO WHILE .T.
		         IF EOF()
		            EXIT
		         ENDIF
		         IF ART_TIPART = 'A'
		            V_CAR = ART_CODPRI
		            V_DAR = ART_DESCR
		            EXIT
		         ENDIF
		         SKIP +1
		      ENDDO
		      IF EMPTY(ALLTRIM(V_CAR))
		         x_lung  = "art_altezz = art_altezz"
		         x_cond  = x_soci + " and " + x_arti
		         x_cond1 = " and " + x_tmat + " and " + x_imba + " and " + x_colo
		         x_cond2 = " and " + x_spes + " and " + x_alte + " and " + x_lung
		         x_cond3 = " and 1=1 "
		         x_cond  = x_cond + x_cond1 + x_cond2 + x_cond3
		         Csql    = "select * from u_art_pr where " + x_cond
		         IF !ExecCommand(cSql,"CU_ART_PR")
		            return(.f.)
		         ENDIF
		         SELECT CU_ART_PR
		         GO TOP
		         IF EOF()
		         ELSE
		            DO WHILE .T.
		               IF EOF()
		                  EXIT
		               ENDIF
		               IF ART_TIPART = 'A'
		                  V_CAR = ART_CODPRI
		                  V_DAR = ART_DESCR
		                  EXIT
		               ENDIF
		               SKIP +1
		            ENDDO
		         ENDIF
		      ENDIF
		   ENDIF
		ELSE
		   DO WHILE .T.
		      IF EOF()
		         EXIT
		      ENDIF
		      IF ART_TIPART = 'A'
		         V_CAR = ART_CODPRI
		         V_DAR = ART_DESCR
		         EXIT
		      ENDIF
		      SKIP +1
		   ENDDO
		   IF EMPTY(ALLTRIM(V_CAR))
		      x_alte  = "art_altezz = art_altezz"
		      x_lung  = "art_lunghe = art_lunghe"
		      x_cond  = x_soci + " and " + x_arti
		      x_cond1 = " and " + x_tmat + " and " + x_imba + " and " + x_colo
		      x_cond2 = " and " + x_spes + " and " + x_alte + " and " + x_lung
		      x_cond3 = " and 1=1 "
		      x_cond  = x_cond + x_cond1 + x_cond2 + x_cond3
		      Csql    = "select * from u_art_pr where " + x_cond
		      IF !ExecCommand(cSql,"CU_ART_PR")
		         return(.f.)
		      ENDIF
		      SELECT CU_ART_PR
		      GO TOP
		      IF EOF()
		      ELSE
		         DO WHILE .T.
		            IF EOF()
		               EXIT
		            ENDIF
		            IF ART_TIPART = 'A'
		               V_CAR = ART_CODPRI
		               V_DAR = ART_DESCR
		               EXIT
		            ENDIF
		            SKIP +1
		         ENDDO
		      ENDIF
		   ENDIF
		ENDIF

      *=> PROJECT 19/01/2005 - INIZIO
      Q_ALTEZZA = V_ALMAFN - V_CIMOSA
      Q_ALTEZZA = Q_ALTEZZA - (V_TAGLIO * 2)
      IF M.ORD_ALTEZZ > Q_ALTEZZA
         W_ALMAFN = M.ORD_ALTEZZ + V_CIMOSA + (V_TAGLIO * 2)
      ELSE
         W_ALMAFN = V_ALMAFN
      ENDIF
      *=> PROJECT 19/01/2005 - FINE

      V_TROV = .F.

      V_SEEK = M.ORD_CODMAT + M.ORD_CODCOL + STR(M.MIC_SPEORD,3,0) + STR(W_ALMAFN,5,0) + STR(M.MIC_LUNORD,6,0)
      SELECT CUR_MAG_DE
      SET ORDER TO I_INDICE4
      SEEK V_SEEK
      IF FOUND()
         V_TROV = .T.
      ELSE
         SELECT CUR_MAG_DE
         APPEND BLANK
         REPLACE MAG_CODART WITH V_CAR
         REPLACE MAG_DESART WITH V_DAR
         REPLACE MAG_ANAART WITH V_CAR
         REPLACE MAG_CODMAT WITH M.ORD_CODMAT
         REPLACE MAG_DESMAT WITH M.ORD_DESMAT
         REPLACE MAG_CODCOL WITH M.ORD_CODCOL
         REPLACE MAG_DESCOL WITH M.ORD_DESCOL
         REPLACE MAG_SPESSO WITH M.MIC_SPEORD
         REPLACE MAG_ALTEZZ WITH W_ALMAFN
         REPLACE MAG_LUNGHE WITH M.ORD_LUNGHE
         REPLACE MAG_ALTRES WITH MAG_ALTEZZ
         REPLACE MAG_GIACEN WITH 0
         REPLACE MAG_QTAMQ  WITH 0
         REPLACE MAG_QTAML  WITH 0
         REPLACE MAG_QTAKG  WITH 0
         REPLACE MAG_CDDIBA WITH V_DIBA
         REPLACE MAG_LUNORD WITH M.MIC_LUNORD
         REPLACE MAG_NUMBOB WITH 0
      ENDIF

      SCATTER MEMVAR

      *=> Imposto l'altezza iniziale della bobina in giacenza togliendogli la cimosa (40 mm)
      *=> questo perchč le bobine di film nudo vengono caricate con l'altezza che prevede la cimosa,
      *=> mentre le bobine ordinate dai clienti sono al netto delle cimose
      IF M.MAG_ALTEZZ = M.MAG_ALTRES
         V_ALTEZZA = M.MAG_ALTEZZ - V_CIMOSA
         V_ALTEZZA = V_ALTEZZA - (V_TAGLIO * 2)
      ELSE
         V_ALTEZZA = M.MAG_ALTRES
      ENDIF
      V_LUNGHEZ = M.MAG_QTAML
      V_ACCBOBI = 0

      *=> Inizio loop di accoppiamento righe d'ordine con stessa lunghezza
      SELECT CU_ORD_DL
      V_LUNGORD = ORD_LUNGHE
      V_CODMATE = ORD_CODMAT
      V_CODCOLO = ORD_CODCOL
      V_CODSPES = ORD_SPESSO
      V_CODARTI = ORD_CODART
      V_CODDIBA = ORD_CDDIBA
      V_CILRETI = ORD_CILRET

      DO WHILE .T.

         IF EOF()
            EXIT
         ENDIF

         IF ORD_NRBSPD > 0
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Determino la percentuale di tolleranza sul reso in altezza
         V_PERCNOUSATA = (V_ALTEZZA * 100) / M.MAG_ALTEZZ
         IF V_PERCNOUSATA > V_SCAABU
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso tipo prodotto
         IF ORD_CODMAT = V_CODMATE
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia della stessa di.ba.
         IF ORD_CDDIBA = V_CODDIBA
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia con lo stesso cilindro retinato
         IF ORD_CILRET = V_CILRETI
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso prodotto
         IF ORD_CODART = V_CODARTI
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso colore
         IF ORD_CODCOL = V_CODCOLO
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso spessore
         IF ORD_SPESSO = V_CODSPES
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Verifico che la riga d'ordine che stň elaborando sia della stessa lunghezza
         IF ORD_LUNGHE = V_LUNGORD
         ELSE
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         *=> Determino quanti accoppiamenti riesco a fare con l'altezza della bobina in giacenza
         V_ACCOPPIA = INT((V_ALTEZZA / ORD_ALTEZZ))
         IF V_ACCOPPIA > ORD_NRBSPD
            V_ACCOPPIA = ORD_NRBSPD
         ENDIF

         *=> Determino l'altezza usata per l'accoppiamento  PROJECT 4/01/2005
         V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
         IF V_ACCOPPIA = 1
            V_ALTUSATA = V_ALTUSATA
         ELSE
            V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
         ENDIF

         *=> by-passo le righe che non riescono ad essere evasi con l'altezza della bobina in giacenza
         IF V_ALTUSATA = 0
            SELECT CU_ORD_DL
            SKIP +1
            LOOP
         ENDIF

         SELECT CU_ORD_DL
         SCATTER MEMVAR MEMO

         *=> Scrivo in un cursore di appoggio le righe d'ordine che riesco a programmare
         SELECT CUR_SELEZIONE
         APPEND BLANK
         REPLACE SEL_UNIQUE WITH M.ID_UNIQUE
         REPLACE SEL_CODART WITH M.ORD_CODART
         REPLACE SEL_DESART WITH M.ORD_DESART
         REPLACE SEL_CODCLI WITH M.ORS_CODCLI
         REPLACE SEL_RAGSOC WITH M.ORS_RAGSOC
         REPLACE SEL_NUMORD WITH M.ORS_NUMORD
         REPLACE SEL_DATORD WITH M.ORS_DATORD
         REPLACE SEL_CODCOL WITH M.ORD_CODCOL
         REPLACE SEL_DESCOL WITH M.ORD_DESCOL
         REPLACE SEL_CODMAT WITH M.ORD_CODMAT
         REPLACE SEL_DESMAT WITH M.ORD_DESMAT
         REPLACE SEL_SPESSO WITH M.ORD_SPESSO
         REPLACE SEL_ALTEZZ WITH M.ORD_ALTEZZ
         REPLACE SEL_LUNGHE WITH M.ORD_LUNGHE
         REPLACE SEL_BOBORD WITH M.ORD_NRBSPD
         REPLACE SEL_QTAORD WITH M.ORD_QTASPD
         REPLACE SEL_SPEMAG WITH M.MAG_SPESSO
         REPLACE SEL_ALTMAG WITH M.MAG_ALTEZZ
         REPLACE SEL_LUNMAG WITH M.MAG_QTAML
         REPLACE SEL_ACCOPP WITH V_ACCOPPIA
         REPLACE SEL_BOBACC WITH INT((SEL_BOBORD / SEL_ACCOPP))
         REPLACE SEL_BOBPRG WITH 0
         REPLACE SEL_QTAPRG WITH 0
         REPLACE SEL_CDDIBA WITH V_DIBA
         REPLACE SEL_CILRET WITH M.ORD_CILRET
      *   REPLACE SEL_SCARTO WITH V_SCAR
         REPLACE SEL_CODSYS WITH M.ORD_CODSYS

         *=> Rilevo il numero di bobine piů basso (l'accoppiamento deve avvenire per stessa altezza e stesso
         *=> numero di bobine da programmare

         IF V_ACCBOBI = 0
            V_ACCBOBI = SEL_BOBACC
         ENDIF

         IF SEL_BOBACC < V_ACCBOBI
            V_ACCBOBI = SEL_BOBACC
         ENDIF

         *=> Determino la nuova altezza con cui si devono confrontare gli altri ordini diminuendola di quella usata

         V_ALTEZZA = V_ALTEZZA - V_ALTUSATA

         SELECT CU_ORD_DL
         SKIP +1

      ENDDO

      *=> Riprendo in esame il cursore provvisorio con le righe d'ordine che sono riuscito ad accoppiare
      *=> per determinerne le esatte quentitŕ

      V_PROGRE = V_PROGRE + 1
      V_PRIMA  = .T.

      SELECT CUR_SELEZIONE
      GO TOP

      DO WHILE .T.

         IF EOF()
            EXIT
         ENDIF

         *=> Determino il numero di bobine e la quantitŕ in MQ da programmare per la singola riga d'ordine
         REPLACE SEL_BOBPRG WITH V_ACCBOBI * SEL_ACCOPP
         REPLACE SEL_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTEZZ,SEL_LUNGHE,SEL_BOBPRG)
         SELECT CUR_SELEZIONE
         SCATTER MEMVAR MEMO

         *=> Aggiorno il numero di bobine sulla bobina da ordinare
         SELECT CUR_MAG_DE
         IF V_PRIMA
            V_PRIMA = .F.
            REPLACE MAG_NUMBOB WITH MAG_NUMBOB + M.SEL_BOBPRG
            REPLACE MAG_QTAML  WITH MAG_QTAML + (MAG_LUNGHE * (M.SEL_BOBPRG/SEL_ACCOPP))
         ENDIF

         *=> Accedo alle righe d'ordine selezionate dall'utente per aggiornarne le quantitŕ programmate
         SELECT CU_ORD_DL
         SET ORDER TO I_CODSYS
         SEEK M.SEL_CODSYS
         IF FOUND()
            REPLACE ORD_NRBSPD WITH ORD_NRBSPD - M.SEL_BOBPRG
            REPLACE ORD_QTASPD WITH ORD_QTASPD - M.SEL_QTAPRG
            REPLACE ORD_NRBOBX WITH ORD_NRBOBX + M.SEL_BOBPRG
            REPLACE ORD_QUANTX WITH ORD_QUANTX + M.SEL_QTAPRG
         ENDIF

         SELECT CUR_SELEZIONE
         SKIP +1

      ENDDO

      SELECT CUR_SELEZIONE
      ZAP

      SELECT CU_ORD_DL
      SET ORDER TO I_PROGRA
      GO TOP

   ENDDO

   SELECT CU_MAC_AN
   SKIP +1

ENDDO


* -->> Creazione cursore giacenze riepilogate magazzino M.P. bobine da ordinare dettagliate
* -----------------------------------------------------------------------------------------
CREATE CURSOR CUR_MAG_DO (MAG_CODART C(16), MAG_DESART C(50),    MAG_ANAART C(16),  MAG_CODMAT C(03),  MAG_DESMAT C(50),  ;
                          MAG_CODCOL C(03), MAG_DESCOL C(50),   MAG_SPESSO N(05),  MAG_ALTEZZ N(05),  MAG_LUNGHE N(06),  ;
                          MAG_ALTRES N(05), MAG_GIACEN N(12,2), MAG_QTAMQ N(18,2), MAG_QTAKG N(18,2), MAG_QTAML N(18,2), ;
                          MAG_CDDIBA C(16), MAG_LUNORD N(15),   MAG_NUMBOB N(09))

SELECT CUR_MAG_DO
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + STR(MAG_LUNGHE,6,0) 	TAG I_INDICE1 ADDITIVE
INDEX ON MAG_ANAART 																				TAG I_INDICE2 ADDITIVE
INDEX ON STR(MAG_ALTEZZ,5,0) + STR(MAG_QTAML,6,0)													TAG I_INDICE3 DESCENDING ADDITIVE

SELECT CUR_MAG_DE
SET ORDER TO I_INDICE4
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR

   V_QTAML  = MAG_QTAML

   SET NEAR ON
   SELECT NOP_MAG_GG
   SET ORDER TO I_INDICE1
   SEEK M.MAG_CODMAT + M.MAG_CODCOL + STR(M.MAG_SPESSO,5,0) + STR(M.MAG_ALTEZZ,5,0)
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF V_QTAML > 0
      ELSE
         EXIT
      ENDIF
      IF MAG_CODMAT = M.MAG_CODMAT .AND. MAG_CODCOL = M.MAG_CODCOL .AND. MAG_SPESSO = M.MAG_SPESSO .AND. ;
         MAG_ALTEZZ = M.MAG_ALTEZZ
      ELSE
         SKIP +1
         LOOP
      ENDIF
      IF MAG_BALFOR > MAG_GMLIMP
      ELSE
         SKIP +1
         LOOP
      ENDIF
      V_DIFF = MAG_BALFOR - MAG_GMLIMP
      IF V_DIFF > V_QTAML
         REPLACE MAG_GMLIMP WITH MAG_GMLIMP + V_QTAML
         V_QTAML = 0
      ELSE
         REPLACE MAG_GMLIMP WITH MAG_GMLIMP + V_DIFF
         V_QTAML = V_QTAML - V_DIFF
      ENDIF
      SKIP +1
   ENDDO
   SET NEAR OFF

   IF V_QTAML > 0
   ELSE
      SELECT CUR_MAG_DE
      SKIP +1
      LOOP
   ENDIF

   SELECT CUR_MAG_DE
   REPLACE MAG_QTAML  WITH V_QTAML

   V_LUNGHE_DEC = MAG_QTAML / MAG_LUNORD
   V_LUNGHE_INT = INT(MAG_QTAML / MAG_LUNORD)
   V_LUNGHE_DIF = V_LUNGHE_DEC - V_LUNGHE_INT
   IF V_LUNGHE_DIF > 0
      V_LUNGHE = V_LUNGHE_INT + 1
   ELSE
      V_LUNGHE = V_LUNGHE_INT
   ENDIF

   REPLACE MAG_NUMBOB WITH V_LUNGHE

   SELECT CUR_MAG_DO
   APPEND BLANK
   GATHER MEMVAR

   REPLACE MAG_LUNGHE WITH MAG_LUNORD
   REPLACE MAG_QTAML  WITH MAG_LUNGHE * V_LUNGHE
   REPLACE MAG_QTAMQ  WITH TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_QTAML,1)
   REPLACE MAG_GIACEN WITH MAG_QTAMQ
   REPLACE MAG_QTAKG  WITH TROVA_KG_DA_MQ(MAG_CODART,MAG_SPESSO,MAG_QTAMQ,1)

   *=> Prelievo delle giacenze al netto dell'impegnato

   SELECT CUR_MAG_DE
   SKIP +1

ENDDO

RETURN


***************************************************************************
PROCEDURE spalmatura_programmasalamescole						
***************************************************************************

*=> ******************************************************************** <=*
*=>                                                                      <=*
*=>   P R O G R A M M A Z I O N E   D E L L A   S A L A   M E S C O L E  <=*
*=>                                                                      <=*
*=> ******************************************************************** <=*

CREATE CURSOR CUR_SELEZIONE (SEL_CDDIBA C(16), SEL_CODCOL C(03), SEL_DESCOL C(30), SEL_CODMAT C(03), SEL_DESMAT C(30),     ;
                             SEL_SPESSO N(05), SEL_ALTEZZ N(05), SEL_LUNGHE N(06))

CREATE CURSOR CUR_SALAMESCOLE (SEL_CODART C(16),   SEL_DESART C(50),   SEL_CDDIBA C(16),   SEL_DSDIBA C(50),   ;
                               SEL_UNITAM C(03),   SEL_QTAGIA N(16,6), SEL_QTANEC N(16,6), SEL_QTADOR N(16,6), ;
                               SEL_SCORMI N(16,6), SEL_CODIMB C(03),   SEL_DESIMB C(50),   SEL_LOTMIN N(12,2), ;
                               SEL_LIVELL N(10,0), SEL_QTADIB N(16,6), SEL_PROGRE N(06))

RELEASE V_QTAMQS,V_UNITAM,V_SCORMI,V_CODIMB,V_DESIMB,V_LOTMIN,V_PROGRE,V_CDDIBA,V_CPADRE,V_DPADRE,V_ALT,V_REC,V_LUXPRG
PUBLIC  V_QTAMQS,V_UNITAM,V_SCORMI,V_CODIMB,V_DESIMB,V_LOTMIN,V_PROGRE,V_CDDIBA,V_CPADRE,V_DPADRE,V_ALT,V_REC,V_LUXPRG
V_QTAMQS = 0
V_UNITAM = SPACE(03)
V_SCORMI = 0
V_CODIMB = SPACE(03)
V_DESIMB = SPACE(50)
V_LOTMIN = 0
V_PROGRE = 0
V_CDDIBA = SPACE(16)
V_CPADRE = SPACE(16)
V_DPADRE = SPACE(50)
V_ALT    = 0
V_REC    = 0
V_LUXPRG = 0

*=> Elaborazione del file di spalmatura programmato per calcolarne le relative qtŕ di adesivo da applicare per la
*=> sala mescole

WAIT WINDOWS "PROGRAMMAZIONE SALA MESCOLE (4) : " + CHR(13) + ;
             "Stň elaborando l'articolo " + ORD_CODART + "Colore : " + ALLTRIM(ord_descol) + " Altezza : " + ALLTRIM(STR(ORD_ALTEZZ,5,0)) + " Lunghezza : " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + CHR(13) + ;
             "Nr.bob. : " + ALLTRIM(STR(ORD_NRBSPD,7,0)) + " Nr.Ordine : " + ORS_NUMORD + " del " + ORS_DATORD + " Cliente : " + ORS_RAGSOC NOWAIT

SELECT RIE_SPALMATURA
INDEX ON SEL_PROGRE TAG I_SPALMA ADDITIVE
SET ORDER TO I_SPALMA
GO TOP
IF EOF()
   RETURN
ENDIF

V_LUXPRG = SEL_LUNPRG
V_PROGRE = SEL_PROGRE
V_ALT    = SEL_ALTMAG
V_CDDIBA = SEL_CDDIBA

*BROWSE NORMAL
*SET STEP ON

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   V_LUXPRG = SEL_LUNPRG
   V_PROGRE = SEL_PROGRE
   V_ALT    = SEL_ALTMAG - V_CIMOSA  && PROJECT 12/01/2005
   V_CDDIBA = SEL_CDDIBA

   DO SPALMATURA_SALAMESCOLE

   SELECT RIE_SPALMATURA
   SKIP +1

ENDDO


*=> ELABORAZIONE CURSORE SELEZIONE PER DETERMINARE LE QTA' NECESSARIE AL PROGRAMMA DI SALA MESCOLE
SELECT CUR_SALAMESCOLE
GO TOP
*BROWSE NORMAL
*SET STEP ON

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   V_REC = RECNO()

   *=> Prelievo delle giacenze al netto dell'impegnato
   x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
   x_tmat = "mag_codmat = mag_codmat"
   x_colo = "mag_codcol = mag_codcol"
   x_spes = "mag_spesso = mag_spesso"
   x_alte = "mag_altezz = mag_altezz"
   x_lung = "mag_lunghe = mag_lunghe"
   x_arti = "mag_anaart = '" + ALLTRIM(M.SEL_CODART) + "'"
   x_nrli = "mag_nrlint = mag_nrlint"
   x_maga = "mag_codmag = '" + ALLTRIM(PUB_CQUMPC) + "'"
   x_forn = "mag_fornit = mag_fornit"
   x_nide = "mag_numide = mag_numide"
   x_anno = "mag_anno = mag_anno"
   x_data = "mag_datagg <> SPACE(10)"
   x_giac = "mag_giacen > 0"
   x_impe = "mag_qtaimp = mag_qtaimp"
   x_cond = x_soci + " and " + x_tmat + " and " + x_colo + " and " + x_spes + " and " + x_alte
   x_cond = x_cond + " and " + x_lung + " and " + x_arti + " and " + x_nrli + " and " + x_maga
   x_cond = x_cond + " and " + x_forn + " and " + x_nide + " and " + x_anno + " and " + x_data
   x_cond = x_cond + " and " + x_giac + " and " + x_impe
   cSql   = "select * from u_mag_gg where " + x_cond + " order by mag_datagg,mag_codart"
   IF !ExecCommand(cSql,'CUT_MAG_GG')
      return(.f.)
   ENDIF
   SELECT CUT_MAG_GG
   GO TOP
   V_GIACEN = 0
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF MAG_GIACEN > MAG_QTAIMP
         V_GIACEN = V_GIACEN + (MAG_GIACEN - MAG_QTAIMP)
      ENDIF
      SKIP +1
   ENDDO

   *=> Rilevamento delle quantitŕ precedentemente impegnate dal programma di spalmatura
   SELECT CUR_SALAMESCOLE
   SET FILTER TO SEL_PROGRE < M.SEL_PROGRE .AND. SEL_CODART = M.SEL_CODART
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      V_GIACEN = V_GIACEN - SEL_QTANEC
      SKIP +1
   ENDDO

   IF V_GIACEN < 1
      V_GIACEN = 0
   ENDIF

   *=> Accesso alla angrafica articoli per intercettare se trattasi di articolo da movimentare in magazzino
   *=> in caso di articolo da non movimentare, viene forzata una giacenza altissima in modo da non scaturire
   *=> l'emissione automatica dell'ordine a fornitore (č il caso dell'acqua)  PROJECT 4/01/2005
   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.SEL_CODART) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
      OUT = .f.
   ELSE
      OUT = art_NONMOV
   ENDIF
   IF OUT
      V_GIACEN = 999999999
   ENDIF

   *=> Riposizionamento sul record salamescole per aggiornamento giacenza e qtŕ da ordinare
   SELECT CUR_SALAMESCOLE
   SET FILTER TO
   GOTO V_REC
   REPLACE SEL_QTAGIA WITH V_GIACEN
   IF SEL_QTAGIA < SEL_QTANEC
      REPLACE SEL_QTADOR WITH SEL_QTANEC - SEL_QTAGIA		&& Qtŕ da ordinare (manca giacenza)
   ELSE
      REPLACE SEL_QTADOR WITH 0
   ENDIF

   SKIP +1

ENDDO

RETURN


***************************************************************************
PROCEDURE spalmatura_programmaordinifornitorism						
***************************************************************************


CREATE CURSOR CUR_SELEZIONE (SEL_CDDIBA C(16), SEL_CODCOL C(03), SEL_DESCOL C(30), SEL_CODMAT C(03), SEL_DESMAT C(30),     ;
                             SEL_SPESSO N(05), SEL_ALTEZZ N(05), SEL_LUNGHE N(10))

*=> Elaborazione del file di spalmatura programmato per calcolarne le relative qtŕ di adesivo da applicare per la
*=> sala mescole

SELECT CUR_MAG_DO
INDEX ON MAG_CODCOL + MAG_CODMAT + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + ;
         STR(MAG_QTAML,6,0) TAG I_SPALMA ADDITIVE
SET ORDER TO I_SPALMA
GO TOP

IF EOF()
   RETURN
ENDIF

WAIT WINDOWS "PROGRAMMAZIONE DEGLI ADESIVI DA ORDINARE (5) : " + CHR(13) + ;
             "Stň elaborando l'articolo " + ORD_CODART + "Colore : " + ALLTRIM(ord_descol) + " Altezza : " + ALLTRIM(STR(ORD_ALTEZZ,5,0)) + " Lunghezza : " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + CHR(13) + ;
             "Nr.bob. : " + ALLTRIM(STR(ORD_NRBSPD,7,0)) + " Nr.Ordine : " + ORS_NUMORD + " del " + ORS_DATORD + " Cliente : " + ORS_RAGSOC NOWAIT

V_CDCOL = MAG_CODCOL
V_DSCOL = MAG_DESCOL
V_CDMAT = MAG_CODMAT
V_DSMAT = MAG_DESMAT
V_SPESS = MAG_SPESSO
V_ALTEZ = MAG_ALTEZZ
V_LUNGH = MAG_QTAML
V_CDDIB = MAG_CDDIBA

DO WHILE .T.

   IF EOF()
      *=> Scrivi il record nel cursore delle selezioni
      SELECT CUR_SELEZIONE
      APPEND BLANK
      REPLACE SEL_CDDIBA WITH V_CDDIB
      REPLACE SEL_CODCOL WITH V_CDCOL
      REPLACE SEL_DESCOL WITH V_DSCOL
      REPLACE SEL_CODMAT WITH V_CDMAT
      REPLACE SEL_DESMAT WITH V_DSMAT
      REPLACE SEL_SPESSO WITH V_SPESS
      REPLACE SEL_ALTEZZ WITH V_ALTEZ	
      REPLACE SEL_LUNGHE WITH V_LUNGH
      EXIT
   ENDIF

   *=> Verifica rottura sequenza (cambia bobina da spalmare)
   IF MAG_CODCOL = V_CDCOL .AND. ;
      MAG_CODMAT = V_CDMAT .AND. ;
      MAG_SPESSO = V_SPESS .AND. ;
      MAG_ALTEZZ = V_ALTEZ .AND. ;
      MAG_QTAML = V_LUNGH
   ELSE
      *=> Scrivi il record nel cursore delle selezioni
      SELECT CUR_SELEZIONE
      APPEND BLANK
      REPLACE SEL_CDDIBA WITH V_CDDIB
      REPLACE SEL_CODCOL WITH V_CDCOL
      REPLACE SEL_DESCOL WITH V_DSCOL
      REPLACE SEL_CODMAT WITH V_CDMAT
      REPLACE SEL_DESMAT WITH V_DSMAT
      REPLACE SEL_SPESSO WITH V_SPESS
      REPLACE SEL_ALTEZZ WITH V_ALTEZ
      REPLACE SEL_LUNGHE WITH V_LUNGH
      *=> Legge il record di spalmatura successivo
      SELECT CUR_MAG_DO
      V_CDCOL = MAG_CODCOL
	  V_DSCOL = MAG_DESCOL
	  V_CDMAT = MAG_CODMAT
	  V_DSMAT = MAG_DESMAT
	  V_SPESS = MAG_SPESSO
	  V_ALTEZ = MAG_ALTEZZ
	  V_LUNGH = MAG_QTAML
	  V_CDDIB = MAG_CDDIBA
      LOOP
   ENDIF

   SELECT CUR_MAG_DO
   SKIP +1

ENDDO

*=> Creazione del cursore per la sala mescola§°§

CREATE CURSOR CUR_SALAMESCOLEOF (SEL_CODART C(16),   SEL_DESART C(50),   SEL_CDDIBA C(16),   SEL_DSDIBA C(50),   ;
                                 SEL_UNITAM C(03),   SEL_QTAGIA N(16,6), SEL_QTANEC N(16,6), SEL_QTADOR N(16,6), ;
                                 SEL_SCORMI N(16,6), SEL_CODIMB C(03),   SEL_DESIMB C(50),   SEL_LOTMIN N(12,2), ;
                                 SEL_LIVELL N(10,0), SEL_QTADIB N(16,6))

SELECT CUR_SALAMESCOLEOF
INDEX ON SEL_CODART TAG I_CODICE ADDITIVE

SELECT CUR_SALAMESCOLE
INDEX ON SEL_CODART TAG I_CODICE ADDITIVE

RELEASE V_QTAMQS,V_UNITAM,V_SCORMI,V_CODIMB,V_DESIMB,V_LOTMIN
PUBLIC  V_QTAMQS,V_UNITAM,V_SCORMI,V_CODIMB,V_DESIMB,V_LOTMIN
V_QTAMQS = 0
V_UNITAM = SPACE(03)
V_SCORMI = 0
V_CODIMB = SPACE(03)
V_DESIMB = SPACE(50)
V_LOTMIN = 0

*=> ELABORAZIONE CURSORE SELEZIONE PER DETERMINARE LE QTA' NECESSARIE AL PROGRAMMA DI SALA MESCOLE
SELECT CUR_SELEZIONE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Determinazione delle quantitŕ in MQ da spalmare (tutta la bobina in altezza)
   V_QTAMQS = TROVA_MQ_DA_AL((M.SEL_ALTEZZ-V_CIMOSA),M.SEL_LUNGHE,1)    && PROJECT 12/01/2005

   *=> Esplosione del Distinta base
   SI_VIDEO = .F.
   DO ALBERELLO  WITH SI_VIDEO,M.SEL_CDDIBA   && ESPLODE LA DISTINTA BASE A VIDEO
   SELECT WEXPLODE
   GO TOP

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      SCATTER MEMVAR MEMO

      *=> Dal primo livello (codice Di.Ba. salvo il codice e la descrizione del Distinta Base)
      IF WLIV = 1
         V_CPADRE = WCOD
         V_DPADRE = WDES
         SKIP +1
         LOOP
      ENDIF

      *=> Accesso alla anagrafica articoli dei singoli componenti per prelevare i seguenti campi :
      *=> - Unitŕ di misura
      *=> - Scorta minima
      *=> - Codice Imballo
      *=> - Descrizione Imballo
      *=> - Lotto minimo da ordinare
      x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
      x_codi = "art_codpri = '" + ALLTRIM(M.WCOD) + "'"
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
      IF !ExecCommand(cSql,"cur_articolo")
         return(.f.)
      ENDIF
      SELECT cur_articolo
      GO TOP
      IF EOF()
         V_UNITAM = 'NN'
         V_SCORMI = 0
         V_CODIMB = SPACE(03)
         V_DESIMB = SPACE(50)
         V_LOTMIN = 0
      ELSE
         V_UNITAM = ART_UNIMIS
         V_SCORMI = ART_SCORMI
         V_CODIMB = ART_CODIMB
         V_DESIMB = ART_DESIMB
         V_LOTMIN = ART_LOTMIN
      ENDIF

      *=> Aggiornamento sul cursore della sala mescole delle quantita' necessarie alla produzione
      SELECT CUR_SALAMESCOLEOF
      SET ORDER TO I_CODICE
      SEEK M.WCOD
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE SEL_CODART WITH M.WCOD
         REPLACE SEL_DESART WITH M.WDES
         REPLACE SEL_CDDIBA WITH V_CPADRE
         REPLACE SEL_DSDIBA WITH V_DPADRE
         REPLACE SEL_SCORMI WITH V_SCORMI
         REPLACE SEL_CODIMB WITH V_CODIMB
         REPLACE SEL_DESIMB WITH V_DESIMB
         REPLACE SEL_LOTMIN WITH V_LOTMIN
         REPLACE SEL_QTAGIA WITH 0
         REPLACE SEL_LIVELL WITH M.WLIV
         REPLACE SEL_QTADIB WITH V_QTAMQS
         REPLACE SEL_QTADOR WITH 0
         REPLACE SEL_UNITAM WITH V_UNITAM
      ENDIF
      REPLACE SEL_QTANEC WITH SEL_QTANEC + (M.WQTAT * V_QTAMQS)				&& Qtŕ necessaria alla produzione

      SELECT WEXPLODE
      SKIP +1

   ENDDO

   SELECT CUR_SELEZIONE
   SKIP +1

ENDDO


*=> ELABORAZIONE CURSORE SELEZIONE PER DETERMINARE LE QTA' NECESSARIE AL PROGRAMMA DI SALA MESCOLE
SELECT CUR_SALAMESCOLEOF
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Prelievo delle giacenze al netto dell'impegnato
   x_soci = "mag_codsoc = '" + ALLTRIM(PUB_CODSOC) + "'"
   x_maga = "mag_codmag = '" + ALLTRIM(PUB_CQUMPC) + "'"
   x_arti = "mag_anaart = '" + ALLTRIM(M.SEL_CODART) + "'"
   x_cond = x_soci + " and " + x_maga + " and " + x_arti
   Csql   = "select * from u_mag_an where " + x_cond
   IF !ExecCommand(Csql,"M_mag_an")
      return(.f.)
   ENDIF
   V_GIACEN = 0
   SELECT M_MAG_AN
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      V_GIACEN = V_GIACEN + (MAG_GIACEN - MAG_QTAIMP)
      SKIP +1
   ENDDO

   *=> Rilevamento di quanto giŕ impegnato per la programmazione in corso
   V_QTAIMP = 0
   SELECT CUR_SALAMESCOLE
   SET ORDER TO I_CODICE
   SEEK M.SEL_CODART
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF SEL_CODART = M.SEL_CODART
      ELSE
         EXIT
      ENDIF
      V_QTAIMP = V_QTAIMP + SEL_QTANEC
      SKIP +1
   ENDDO

   V_GIACEN = V_GIACEN - V_QTAIMP

   *=> Riepilogo dell'ordinato a fornitori di film nudo in essere
   V_QTAORF = 0
   x_arti = "ord_codart = '" + M.SEL_CODART + "'"
   x_sald = "ord_salcon <> 'S'"
   x_cond = x_arti + " and " + x_sald
   Csql   = "select * from u_orf_dd where " + x_cond
   IF !ExecCommand(Csql,"u_orf_dd")
      return(.f.)
   ENDIF
   SELECT U_ORF_DD
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      V_QTAORF = V_QTAORF + (ord_qtaord - ord_qtaev)
      SKIP +1
   ENDDO

   V_GIACEN = V_GIACEN + V_QTAORF

   IF V_GIACEN < 1
      V_GIACEN = 0
   ENDIF

   *=> Accesso alla angrafica articoli per intercettare se trattasi di articolo da movimentare in magazzino
   *=> in caso di articolo da non movimentare, viene forzata una giacenza altissima in modo da non scaturire
   *=> l'emissione automatica dell'ordine a fornitore (č il caso dell'acqua)  PROJECT 4/01/2005
   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.SEL_CODART) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
      OUT = .f.
   ELSE
      OUT = art_NONMOV
   ENDIF
   IF OUT
      V_GIACEN = 999999999
   ENDIF

   *=> Aggiornamento sul cursore della sala mescole delle quantita' necessarie alla produzione
   SELECT CUR_SALAMESCOLEOF
   REPLACE SEL_QTAGIA WITH V_GIACEN
   IF SEL_QTAGIA < SEL_QTANEC
      REPLACE SEL_QTADOR WITH SEL_QTANEC - SEL_QTAGIA		&& Qtŕ da ordinare (manca giacenza)
   ELSE
      REPLACE SEL_QTADOR WITH 0
   ENDIF

   SKIP +1

ENDDO

SELECT CUR_SALAMESCOLE
SET ORDER TO I_CODICE
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF SEL_QTADOR > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF
   SCATTER MEMVAR
   *=> Aggiornamento sul cursore della sala mescole delle quantita' necessarie alla produzione
   SELECT CUR_SALAMESCOLEOF
   SET ORDER TO I_CODICE
   SEEK M.SEL_CODART
   IF FOUND()
      REPLACE SEL_QTADOR WITH SEL_QTADOR + M.SEL_QTADOR
   ELSE
      APPEND BLANK
      GATHER MEMVAR MEMO
   ENDIF
   SELECT CUR_SALAMESCOLE
   SKIP +1
ENDDO

RETURN



