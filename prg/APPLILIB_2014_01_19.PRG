***************************************************************************
PROCEDURE calcolagiornilavoro						
***************************************************************************

RELEASE V_GGLAV,V_HHLAV,V_MMLAV,V_SSLAV
PUBLIC  V_GGLAV,V_HHLAV,V_MMLAV,V_SSLAV
V_GGLAV  = 0
V_HHLAV  = 0
V_MMLAV  = 0
V_SSLAV  = 0

SELECT CU_CAL_LA
SET ORDER TO I_DATAMG
SET FILTER TO

V_FILTER = "SET FILTER TO "

IF EMPTY(ALLTRIM(_V_SPRGDA)) .OR. _V_SPRGDA = '  /    ' .OR. _V_ALLSET
   IF EMPTY(ALLTRIM(_V_SPRGAL)) .OR. _V_SPRGAL = '  /    ' .OR. _V_ALLSET
   ELSE
      V_FILTER = V_FILTER + "CAL_SETT = '" + _V_SPRGAL + "'"
   ENDIF
ELSE
   V_FILTER = V_FILTER + "CAL_SETT = '" + _V_SPRGDA + "'"
   IF EMPTY(ALLTRIM(_V_SPRGAL)) .OR. _V_SPRGAL = '  /    ' .OR. _V_ALLSET
   ELSE
      V_FILTER = V_FILTER + ".OR. CAL_SETT = '" + _V_SPRGAL + "'"
   ENDIF
ENDIF

&V_FILTER
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF CAL_LAVO
      V_HHLAV = V_HHLAV + CAL_ORELAV
      V_GGLAV = V_GGLAV + 1
   ENDIF

   SKIP +1

ENDDO

V_MMLAV = V_HHLAV * 60
V_SSLAV = V_HHLAV * 3600

RETURN


