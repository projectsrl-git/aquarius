IF !ExecCommand(cSql,"CHK_BOL_DD")
   RETURN .F.
ENDIF
SELECT CHK_BOL_DD
GO TOP
IF !EOF()

   _RIT = 0

   SCAN
      _RIT = _RIT + ORD_QTAORD

