****************************************
FUNCTION da_ore_minuti_secondi_a_secondi
****************************************
* TRASFORMA LE ORE MINUTI SECONDI IN FORMATO TIME HH:MM:SS IN SECONDI
*
* INPUT     :   CAMPO _HH_MM_SS DA TRASFORMARE IN MINUTI
*
* OUTPUT    :   CAMPO _SECONDI TRASFORMATI
*

PARAMETERS _HH_MM_SS

SS=STR(SELECT())

  IF _HH_MM_SS = "  :  :  " OR _HH_MM_SS = "00:00:00"
  	_SECONDI = 0
  	SELECT &SS
  	RETURN(_SECONDI)
  ENDIF

  _HH_MM_SS___ 	= ALLTRIM(_HH_MM_SS)

  _SECONDI 		= VAL(SUBSTR(_HH_MM_SS___,7,2)) + (VAL(SUBSTR(_HH_MM_SS___,4,2)) * 60) + (VAL(SUBSTR(_HH_MM_SS___,1,2)) * 60 * 60)


SELECT &SS

RETURN(_SECONDI)


****************************************
FUNCTION da_secondi_a_ore_minuti_secondi
****************************************
* TRASFORMA I SECONDI IN FORMATO TIME HH:MM:SS E IN OUTPUT RITORNA INOLTRA IN FORMA SEPARATA HH , MM , SS
*
* INPUT     :   CAMPO _SECONDI DA TRASFORMARE IN FORMATO TIME HH:MM:SS
*
* OUTPUT    :   CAMPO PUB_HH_MM_SS 	TRASFORMATI
*			:   CAMPO PUB_HH 		ISOLATO
*			:   CAMPO PUB_MM 		ISOLATO
*			:   CAMPO PUB_SS 		ISOLATO
*

PARAMETERS _SECONDI

SS=STR(SELECT())

IF _SECONDI  = 0
	PUB_HH_MM_SS	= "00:00:00"
	SELECT &SS
	RETURN(PUB_HH_MM_SS)
ENDIF

  PUB_HH= INT(_SECONDI / 3600)				&& ORE

  RESTO1= _SECONDI - ( PUB_HH * 3600)

  PUB_MM= INT(RESTO1/60)					&& MINUTI

  PUB_SS= RESTO1 - (PUB_MM  * 60)			&& SECONDI


  STR_HH=ALLTRIM(STR(PUB_HH,2,0))
  STR_MM=ALLTRIM(STR(PUB_MM,2,0))
  STR_SS=ALLTRIM(STR(PUB_SS,2,0))

  IF PUB_HH<10
  	STR_HH="0"+STR_HH
  ENDIF

  IF PUB_MM <10
  	STR_MM="0"+STR_MM
  ENDIF

  IF PUB_SS<10
  	STR_SS="0"+STR_SS
  ENDIF


  PUB_HH_MM_SS = STR_HH+":"+STR_MM+":"+STR_SS


SELECT &SS

RETURN(PUB_HH_MM_SS)



