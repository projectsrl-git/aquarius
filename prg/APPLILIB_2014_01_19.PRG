**********************************************************************************************************
FUNCTION OK_LISTINO_CLIENTE_TIPO_PRODOTTO_SPESSORE
**********************************************************************************************************
**
**  DETERMINA IL PREZZO DI VENDITA PER CLIENTE /TIPO PRODOTTO / SPESSORE
**
**
**  	SE TIPO PRODOTTO NOBILITATO ACCESSO A U_LIS_TS PER:
**		===================================================
**
**
**			1) CLIENTE + TIPO PRODOTTO + SPESSORE + GRUPPO COLORE (A/B/C/D/E/F/G)
**			in questo caso č un listino specifico per il cliente
**
**			2) TIPO PRODOTTO + SPESSORE + GRUPPO COLORE (A/B/C/D/E/F/G)
**			in questo caso č un listino generico per tutti i clienti
**
**
**			SE NON ESISTE UN PREZZO DI LISTINO PER QUESTI DUE ALLORA SI PROVA AD ACCEDERE PER :
**
**			3) CLIENTE + TIPO PRODOTTO + SPESSORE
**			in questo caso č un listino specifico per il cliente
**			
**			4) TIPO PRODOTTO + SPESSORE
**			in questo caso č un listino generico per tutti i clienti
**
**
**  	SE TIPO PRODOTTO GREZZO ACCESSO A U_LIS_TS PER:
**		===============================================
**
**			3) CLIENTE + TIPO PRODOTTO + SPESSORE
**			in questo caso č un listino specifico per il cliente
**			
**			4) TIPO PRODOTTO + SPESSORE
**			in questo caso č un listino generico per tutti i clienti
**
**  RITORNA :
**
**		-  PUB_PREZZO/M.ORD_PREZZO : CONTENENTE L'ULTIMO PREZZO DI LISTINO VALIDO
**					
**

PARA _SOC,_CLI,_ART,_DTDO

IF SUBSTR(_DTDO,3,1) = '/'
ELSE
   _DTDO = RIBALTA2(_DTDO)
ENDIF

S_S=STR(SELECT())

RELEASE _local_trovato                 && flag di prezzo trovato
PUBLIC  _local_trovato                 && flag di prezzo trovato
_local_trovato= .f.                    && flag di prezzo trovato


local_cliente = _CLI
local_data_listino = _DTDO

* ACCESSO ALL'ANAGRAFICA ARTICOLI

x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
x_codi = "art_codpri = '" + ALLTRIM(_ART) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
IF !ExecCommand(cSql,"local_cu_art_pr")
   return(.f.)
ENDIF
SELECT local_cu_art_pr
GO TOP
IF eof()
	local_spesso 	= ""				&& spessore
	local_codcol 	= ""   				&& colore anteriore
ELSE
	local_spesso 	= art_spesso		&& spessore
	local_codcol 	= art_codcol   		&& colore anteriore
ENDIF  		

x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
x_codi = "art_codpri = '" + ALLTRIM(_ART) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_art_an where " + x_cond + " order by art_codsoc,art_codpri"
IF !ExecCommand(cSql,"local_cu_art_an")
   return(.f.)
ENDIF
SELECT local_cu_art_an
GO TOP
IF eof()
	local_tipoG  	= ""				&& flag tipo prodotto grezzo
	local_tipoN  	= ""				&& flag tipo prodotto nobilitato
	local_codcolret	= ""				&& colore retro
ELSE
	local_tipoG  	= art_tipoG 		&& flag tipo prodotto grezzo
	local_tipoN  	= art_tipoN			&& flag tipo prodotto nobilitato
	local_codcolret	= art_codcolret		&& colore retro
ENDIF  	



IF !EMPTY(local_tipoG)  				&& tipo prodotto grezzo

    local_flaggn = "G"					&& identifica il prodotto grezzo
    local_accesso= "ACCESSO-01"			&& cliente + tipo prodotto + spessore
    _local_trovato= .f.                 && flag di prezzo trovato
	=accesso_u_lis_ts_grezzo(local_cliente,local_flaggn,local_tipoG,local_spesso,local_data_listino,local_accesso)
	IF _local_trovato
		select &s_s
		return	
	ENDIF
	
    local_flaggn = "G"					&& identifica il prodotto grezzo
    local_accesso= "ACCESSO-02"			&& tipo prodotto + spessore
    _local_trovato= .f.                 && flag di prezzo trovato
	=accesso_u_lis_ts_grezzo(local_cliente,local_flaggn,local_tipoG,local_spesso,local_data_listino,local_accesso)
	IF _local_trovato
		select &s_s
		return	
	ENDIF
	
	SELECT &S_S
	RETURN
ENDIF


IF !EMPTY(local_tipoN)  				&& tipo prodotto nobilitato

    local_flaggn = "N"					&& identifica il prodotto nobilitato
    local_accesso= "ACCESSO-01"			&& cliente + tipo prodotto + spessore + gruppo colore (a/b/c/d/e/f/g)   : PREZZO NETTO
    _local_trovato= .f.                 && flag di prezzo trovato
	=accesso_u_lis_ts_nobilitato(local_cliente,local_flaggn,local_tipoN,local_spesso,local_codcol,local_codcolret,local_data_listino,local_accesso)
	IF _local_trovato
		_PREZZO_NETTO_SU_CLIENTE_ESISTENTE = .T.
		select &s_s
		return	
	ENDIF

    local_flaggn = "N"					&& identifica il prodotto nobilitato
    local_accesso= "ACCESSO-02"			&& tipo prodotto + spessore + gruppo colore (a/b/c/d/e/f/g)
    _local_trovato= .f.                 && flag di prezzo trovato
	=accesso_u_lis_ts_nobilitato(local_cliente,local_flaggn,local_tipoN,local_spesso,local_codcol,local_codcolret,local_data_listino,local_accesso)
	IF _local_trovato
		select &s_s
		return	
	ENDIF

    local_flaggn = "N"					&& identifica il prodotto nobilitato
    local_accesso= "ACCESSO-03"			&& cliente + tipo prodotto + spessore
    _local_trovato= .f.                 && flag di prezzo trovato
	=accesso_u_lis_ts_nobilitato(local_cliente,local_flaggn,local_tipoN,local_spesso,local_codcol,local_codcolret,local_data_listino,local_accesso)
	IF _local_trovato
		select &s_s
		return	
	ENDIF

    local_flaggn = "N"					&& identifica il prodotto nobilitato
    local_accesso= "ACCESSO-04"			&& tipo prodotto + spessore
    _local_trovato= .f.                 && flag di prezzo trovato
	=accesso_u_lis_ts_nobilitato(local_cliente,local_flaggn,local_tipoN,local_spesso,local_codcol,local_codcolret,local_data_listino,local_accesso)
	IF _local_trovato
		select &s_s
		return	
	ENDIF


	SELECT &S_S
	RETURN

ENDIF


SELECT &S_S

RETURN



****************************************************************************
FUNCTION accesso_u_lis_ts_grezzo
****************************************************************************
PARAMETERS ___l_cliente,___l_flaggn,___l_tipoG,___l_spesso,___l_data_listino,___l_accesso


DO CASE

	CASE ___l_accesso = "ACCESSO-01"
			
			*!*	________________________________________________________________________1) accesso per cliente / tipo prodotto /spessore
	
			x_soci   = "lis_codsoc = '" + PUB_CODSOC + "'"
			x_clie   = "lis_codcli = '" + ALLTRIM(___l_cliente) + "'"
			x_flaggn = "lis_flaggn = '" + ALLTRIM(___l_flaggn) + "'"
			x_tipopr = "lis_tipopr = '" + ALLTRIM(___l_tipoG) + "'"
			x_spesso = "lis_spesso = '" + STR(___l_spesso,2,0) + "'"
			x_data   =  " '"+RIBALTA2(___l_data_listino)+"' between lis_datada and lis_dataal"

			x_cond = x_soci + " and " + x_clie + " and " + x_flaggn + " and " + x_tipopr + " and " + x_spesso + " and " + x_data

			Csql   = "select * from U_LIS_TS where " + x_cond + " order by lis_codsoc,lis_codcli,lis_tipopr"
			IF !ExecCommand(cSql,"TMP1_TS")
			   return(.f.)
			ENDIF
			SELECT TMP1_TS
			GO TOP
			IF !EOF()    						
				PUB_PREZZO		= LIS_PREZZO											&& prezzo tovato !!!!!
				M.ORD_PREZZO	= LIS_PREZZO
				_local_trovato= .T.                 									&& flag di prezzo trovato
				RETURN
			ENDIF


	CASE ___l_accesso = "ACCESSO-02"

			*!*	________________________________________________________________________2) accesso per tipo prodotto /spessore

			x_soci   = "lis_codsoc = '" + PUB_CODSOC + "'"
			___x_cliente = ""
			x_clie   = "lis_codcli = '" + ___x_cliente + "'"
			x_flaggn = "lis_flaggn = '" + ALLTRIM(___l_flaggn) + "'"
			x_tipopr = "lis_tipopr = '" + ALLTRIM(___l_tipoG) + "'"
			x_spesso = "lis_spesso = '" + STR(___l_spesso,2,0) + "'"
			x_data   =  " '"+RIBALTA2(___l_data_listino)+"' between lis_datada and lis_dataal"

			x_cond = x_soci + " and " + x_clie + " and " + x_flaggn + " and " + x_tipopr + " and " + x_spesso + " and " + x_data

			Csql   = "select * from U_LIS_TS where " + x_cond + " order by lis_codsoc,lis_codcli,lis_tipopr"
			IF !ExecCommand(cSql,"TMP1_TS")
			   return(.f.)
			ENDIF
			SELECT TMP1_TS
			GO TOP
			IF !EOF()    						
				PUB_PREZZO		= LIS_PREZZO											&& prezzo tovato !!!!!
				M.ORD_PREZZO	= LIS_PREZZO
				_local_trovato= .T.                 									&& flag di prezzo trovato
				RETURN
			ENDIF

	ENDCASE
	

RETURN


****************************************************************************
FUNCTION accesso_u_lis_ts_nobilitato
****************************************************************************
PARAMETERS ___l_cliente,___l_flaggn,___l_tipoN,___l_spesso,___l_codcol,___l_codcolret,___l_data_listino,___l_accesso

*!*	________________________________________________________________________1) preleva il gruppo colore dai colori fronte/retro


*!*	GRUPPO COLORE FRONTE
V_SEEK	 = 'COL'+ALLTRIM(___l_codcol)
V_CHIAVE = "CODICE"
IF SEEK_STD('PARA',V_SEEK,V_CHIAVE,'CUR_PARA')
   SELECT CUR_PARA
   ___l_gruppo_codcol=SUBSTR(LIBERA,1,1)
ELSE
   ___l_gruppo_codcol=""
ENDIF


*!*	GRUPPO COLORE RETRO
V_SEEK	 = 'COL'+ALLTRIM(___l_codcolret)
V_CHIAVE = "CODICE"
IF SEEK_STD('PARA',V_SEEK,V_CHIAVE,'CUR_PARA')
   SELECT CUR_PARA
   ___l_gruppo_codcolret=SUBSTR(LIBERA,1,1)
ELSE
   ___l_gruppo_codcolret=""
ENDIF


DO CASE


	CASE ___l_accesso = "ACCESSO-01"

			*!*	________________________________________________________________________2) accesso per cliente / tipo prodotto /spessore / gruppo colore (A/B/C/D/E/F/G)

			x_soci   = "lis_codsoc = '" + PUB_CODSOC + "'"
