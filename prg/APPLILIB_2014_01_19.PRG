*!*	**=> ERASMO - INIZIO 09/11/2011
*!*	**************************************************************************
*!*	  PROCEDURE CALCBCL  && CALCOLA IL VALORE DEL DOCUMENTO
*!*	**************************************************************************
*!*	=CALCdocgen("cu_bcl_dd")
*!*	RETURN
*!*	**=> ERASMO - FINE 09/11/2011


** SERGIO 03/01/2005 INIZIO
**************************************************************************
  function CALCdocgen  && CALCOLA IL VALORE DEL DOCUMENTO IVE COMPRESE
**************************************************************************
***  RICHIAMATA NEL SEGUENTE MODO =CALCdocgen("cu_fat_dd")
para _tabella

SWS=SELECT()
M.T_IMPONIB = 0
M.T_IMPOSTA = 0
M.T_VALORE  = 0
MATPUBX     = 0

M.T_ENPACL  = 0
M.T_RA      = 0
M.T_NETTO   = 0


IF _TABELLA = "cu_orf_dd"
   *_ALRID      = ALLTRIM(PUB_IVA)
   _ALRID      = CERCA_IVA_DEFAULT(_tabella,"CODICE")  && ERASMO - 21/09/2011
   _ESENZI     =.F.				&& CLIENTE NON IN ESENZIONE
   _RAPERC     = 0
   _ENPACLPERC = 0
ELSE
   x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "cli_codcli = '" + ALLTRIM(m.ord_codcli) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
   IF !ExecCommand(cSql,"u_cli_an")
      return(.f.)
   ENDIF
   SELECT u_cli_an
   IF reccount() <> 0
      _ALRID    = CLI_ALRID
	  IF !EMPTY(CLI_ALRID)
	     _ESENZI = .T.			&& CLIENTE IN ESENZIONE
	  ELSE
	     *_ALRID  = ALLTRIM(PUB_IVA)
	     _ALRID  = CERCA_IVA_DEFAULT(_tabella,"CODICE")  && ERASMO - 21/09/2011
	     _ESENZI = .F.			&& CLIENTE NON IN ESENZIONE
	  ENDIF

	  IF ___NON_CALCOLA_RA_ENPACL
	   	  _RAPERC     = 0
	      _ENPACLPERC = 0
	  ELSE
	     _RAPERC     = CLI_RA
	     _ENPACLPERC = CLI_ENPACL
      ENDIF

   ELSE
	  *_ALRID      = ALLTRIM(PUB_IVA)
	  _ALRID      = CERCA_IVA_DEFAULT(_tabella,"CODICE")  && ERASMO - 21/09/2011
	  _ESENZI     =.F.				&& CLIENTE NON IN ESENZIONE
      _RAPERC     = 0
      _ENPACLPERC = 0
   ENDIF
ENDIF


SELECT &_tabella
GO TOP

IVA1   = SPACE(3)
IVA2   = SPACE(3)
IVA3   = SPACE(3)
IVA4   = SPACE(3)
IVA5   = SPACE(3)
IMPO1  = 0
IMPO2  = 0
IMPO3  = 0
IMPO4  = 0
IMPO5  = 0
IMPOS1 = 0
IMPOS2 = 0
IMPOS3 = 0
IMPOS4 = 0
IMPOS5 = 0
M.T_OMAGGIO = 0
M.I_OMAGGIO = 0

**=> ERASMO - INIZIO 09/01/2012
RELEASE IMPO_MAGG,IMPOS_MAGG
PUBLIC IMPO_MAGG,IMPOS_MAGG
IMPO_MAGG  = 0
IMPOS_MAGG = 0
**=> ERASMO - FINE 09/01/2012

*** SIMONE - 10/10/2008
RELEASE _CNT_PUBBLI,_CNT_ARTICOLI,PUB_TOTPOLIECO
PUBLIC  _CNT_PUBBLI,_CNT_ARTICOLI,PUB_TOTPOLIECO
_CNT_PUBBLI 	= 0		&& CONTATORE DI ARTICOLI PUBBLICITARI
_CNT_ARTICOLI 	= 0		&& CONTATORE DI ARTICOLI DI VENDITA
PUB_TOTPOLIECO  = 0		&& CALCOLO POLIECO
*** SIMONE - 10/10/2008

*** SERGIO - 08/12/2008
_CNT_OMAGGI 		= 0		&& CONTATORE DI ARTICOLI OMAGGIO CON IVA A CARICO AZIENDA
_IMPONIBILE_POLIECO = 0
_IMPOSTA_POLIECO    = 0   	
*** SERGIO - 08/12/2008


DO WHILE .NOT. EOF()

   IF DELETED()
      SELECT &_tabella
      SKIP +1
      LOOP
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
      SELECT &_tabella
      SKIP +1
      LOOP
   ENDIF

   COD_IVA = ORD_IVA
   IMPONIB = ORD_VALORE
   DES_ART  = SUBSTR(ORD_DESART,1,16)

   *** SIMONE - 10/10/2008
   IF SUBSTR(ORD_CODART,1,7) <> 'POLIECO'
   		_CNT_ARTICOLI = _CNT_ARTICOLI + 1
   ENDIF
   IF SUBSTR(ORD_CODART,1,7) = 'POLIECO'
   		PUB_TOTPOLIECO = PUB_TOTPOLIECO + ORD_VALORE
   ENDIF
   *** SIMONE - 10/10/2008

   IF ORD_PUBBLI = "S"
      MATPUBX = MATPUBX + ORD_VALORE
      *** SIMONE - 10/10/2008
      _CNT_PUBBLI = _CNT_PUBBLI + 1		
      *** SIMONE - 10/10/2008	
   ENDIF

   IF !ExecCommand("select * from para where codice = 'IVA'+?COD_IVA","para")
      return
   ENDIF
   SELECT PARA
   IF reccount() <> 0
      ALIQ = SUBSTR(LIBERA,1,3)
      NUM_ALIQ = VAL(ALIQ)
   ELSE
      NUM_ALIQ = 0
   ENDIF

   SELECT &_tabella

