******************************
FUNCTION TXT_TOTMC
******************************
* CREA TESTO CON TOTALE METRI CUBI

PARA _TIPON,_CURSORE,_TIP_TXT,_TXT,_XVAL

SELECT &_CURSORE
_REC_ = RECNO()

GO TOP
_TVAL = 0
_MATP = 0
TOTALE_METRI_CUBI = 0
__COD_CLIENTE = ''
PUB_COSTOTR  = 0

DO WHILE .NOT.EOF()

   IF DELETED()
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF


*!*	   IF !EMPTY(ALLTRIM(PUB_DAGGANCIO))						&& SOLO PER QUEL DDT MEMORIZZATO NEL CURSORE (NE POSSONO ESISTERE ALTRI)
*!*	       IF ALLTRIM(PUB_DAGGANCIO) <> ALLTRIM(DAGGANCIO)
*!*			  SELECT &_CURSORE
*!*			  SKIP +1
*!*			  LOOP
*!*		   ENDIF
*!*	   ENDIF

   IF !EMPTY(ALLTRIM(ORS_CODCLI))
		__COD_CLIENTE = ORS_CODCLI
   ENDIF

   TOTALE_METRI_CUBI = TOTALE_METRI_CUBI + ORD_QTAMC

   SELECT &_CURSORE
   SKIP +1

ENDDO

SELECT &_CURSORE
GO TOP

* INSERISCE NEL TESTO CON IL TOTALE METRI CUBI CALCOLATO
 _TXT = STRTRAN(_TXT,".TOTMETRICUBI",ALLTRIM(STR(TOTALE_METRI_CUBI,15,PUB_DECQTA)))


* CALCOLA IL COSTO TOTALE DEL TRASPORTO IN BASE AL COSTO AL METRO CUBO PER PROVINCIA DI ARRIVO
=TXT_COSTO_TRASPORTO(__COD_CLIENTE)

RETURN(_TXT)

****************************
FUNCTION TXT_COSTO_TRASPORTO
****************************
PARA _CCLI

X_S=STR(SELECT())


x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
x_codi = "cli_codcli = '" + ALLTRIM(_CCLI) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"jcu_cli_an")
   return(.f.)
ENDIF
SELECT jcu_cli_an
GO TOP
IF reccount() <> 0
   _cli_provin = cli_provin
   x_codi = "sigla = '" + _cli_provin + "'"
   x_cond = x_codi
   cSql = "select * from PROVINCE where " + x_cond + " order by PROVINCIA"
   IF !ExecCommand(cSql,"CX_PROVINCE")
      return(.f.)
   ENDIF
   SELECT CX_PROVINCE
   GO TOP
   IF !EOF()
     _PRV_COSTOT = PRV_COSTOT
   ELSE
     _PRV_COSTOT = 0
   ENDIF

   PUB_COSTOTR = _PRV_COSTOT * TOTALE_METRI_CUBI

ELSE
   _cli_provin = ""	
ENDIF


SELECT &X_S

RETURN


