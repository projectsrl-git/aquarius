**************************
FUNCTION CERCA_IVA_DEFAULT
**************************
**********************************************************************************************************************************
*** PASSANDO IL NOME TABELLA OPPURE LA DATA DI RIFERIMENTO RITORNA IL CODICE IVA DI DEFAULT OPPURE L'ALIQUOTA
**********************************************************************************************************************************
*** ESEMPI:
***   PUB_IVADEF = CERCA_IVA_DEFAULT("CU_FAT_DD","CODICE")
**********************************************************************************************************************************
***   PUB_ALIQ = CERCA_IVA_DEFAULT("CU_FAT_DD","ALIQUOTA")
**********************************************************************************************************************************
***   PUB_IVADEF = CERCA_IVA_DEFAULT("","CODICE",M.ORD_DATORD)
**********************************************************************************************************************************
PARAMETERS _par_tabella,_par_ritorno,_par_datarif

IF PCOUNT() >= 2
ELSE
	MESSAGEBOX("Parametri per Function 'CERCA_IVA_DEFAULT' insufficienti",16,"Attenzione")
	RETURN ""
ENDIF

IF TYPE("_par_tabella") == 'C'
ELSE
	MESSAGEBOX("Parametri per Function 'CERCA_IVA_DEFAULT' non validi o insufficienti",16,"Attenzione")
	RETURN ""
ENDIF

IF TYPE("_par_ritorno") == 'C'
ELSE
	MESSAGEBOX("Parametri per Function 'CERCA_IVA_DEFAULT' non validi o insufficienti",16,"Attenzione")
	RETURN ""
ENDIF
IF _par_ritorno == 'CODICE' .OR. _par_ritorno == 'ALIQUOTA'
ELSE
	MESSAGEBOX("Parametri per Function 'CERCA_IVA_DEFAULT' non validi o insufficienti",16,"Attenzione")
	RETURN ""
ENDIF

IF PCOUNT() >= 3
ELSE
	_par_datarif = ""
ENDIF

IF EMPTY(_par_tabella)
	IF EMPTY(_par_datarif)
		MESSAGEBOX("Parametri per Function 'CERCA_IVA_DEFAULT' non validi o insufficienti",16,"Attenzione")
		RETURN ""
	ENDIF	
ENDIF

_RIT = ""
_data = ""

SWS=SELECT()


IF EMPTY(_par_datarif)
	SELECT &_par_tabella
	GO TOP

	DO CASE
		*CASE 'U_BOL_DD' $ UPPER(ALLTRIM(_par_tabella))
		CASE 'U_BOL_DD' $ UPPER(ALLTRIM(_par_tabella)) OR 'U_BCL_DD' $ UPPER(ALLTRIM(_par_tabella))  && ERASMO - 09/11/2011
			IF TYPE("M.ORD_INTRAS") == 'C'
				_data = M.ORD_INTRAS
			ENDIF
			IF EMPTY(_data)
				IF TYPE("M.ORD_DATORD") == 'C'
					_data = M.ORD_DATORD
				ELSE
					_data = ORS_DATORD
				ENDIF
			ENDIF
			
		OTHERWISE
			IF TYPE("M.ORD_DATORD") == 'C'
				_data = M.ORD_DATORD
			ELSE
				_data = ORS_DATORD
			ENDIF
	ENDCASE
ELSE
	_data = _par_datarif
ENDIF

IF EMPTY(_data)
	_data = RIBALTA2(DTOC(DATE()))
ENDIF

IF SUBSTR(_data,3,1) == '/'
	_data = RIBALTA2(_data)
ENDIF

_CODIVA = ""
x_dtda = "DATADA <= '" + _data + "'"
x_dtal = "DATAAL >= '" + _data + "'"
x_cond = x_dtda + " and " + x_dtal
Csql = "select * from ivadefault where " + x_cond
IF !ExecCommand(Csql,"cx_ivadefault")
   return(.f.)
ENDIF
SELECT cx_ivadefault
GO TOP
IF EOF()
	_CODIVA = ALLTRIM(PUB_IVA)
ELSE
	_CODIVA = ALLTRIM(CODIVA)
ENDIF

IF _par_ritorno == 'CODICE'
	_RIT = _CODIVA
ELSE
	PERC_ALIQ = 0
	IF !ExecCommand("select * from para where codice = 'IVA" + ALLTRIM(_CODIVA) + "'","cx_para")
	   return
	ENDIF
	SELECT cx_para
	IF reccount() <> 0
	   cALIQ = SUBSTR(LIBERA,1,3)
	   PERC_ALIQ = VAL(cALIQ)
	ENDIF
	RELEASE _RIT
	_RIT = PERC_ALIQ
ENDIF

SELECT(SWS)

RETURN _RIT

ENDFUNC


****************************************************************************************************
FUNCTION CERCA_IN_DOCUMENTI
****************************************************************************************************
*** RICERCA I DETTAGLI DEI DOCUMENTI IL CUI CODICE ARTICOLO, DESCRIZIONE O RAGIONE SOCIALE
*** CONTIENE UNA DETERMINATA STRINGA DI CARATTERI, E NE MOSTRA I RISULTATI TRAMITE BROWSEVIEW
***
*** PARAMETRI:
*** 	- _par_cTipSource = Stringa di 3 caratteri indicante il tipo documento in cui ricercare
*** 	- _par_cTabSource = Stringa contenente il nome del cursore contenente la lista dei tipi
*** 	  documenti in cui ricercare (alternativo al primo parametro)
*** 	- _par_cStringa = Stringa da ricercare
*** 	- [_par_nSelezione] = Numero (0/1/2) indicante il tipo di selezione da poter effettuare
*** 	  (0 = nessuna selezione / 1 = selezione singola / 2 = selezione multipla)
***
*** ESEMPIO:
*** 	DO PRG\CERCA_IN_DOCUMENTI WITH "","TMP_SOURCE",_cTestoDaRicercare,2
*** ESEMPIO:
*** 	DO PRG\CERCA_IN_DOCUMENTI WITH "ODA","",_cTestoDaRicercare
***
*** VARIABILI DI RITORNO
*** 	1) Cursore "CUR_DOCS" popolante la griglia di visualizzazione dei risultati di ricerca
*** 	2) Variabile di ritorno di tipo stringa _VAR_RIT contenente l'aggancio al primo documento
*** 	   selezionato (solo se _par_nSelezione >= 1)
****************************************************************************************************
LPARAMETERS _par_cTipSource,_par_cTabSource,_par_cStringa,_par_nSelezione

RELEASE _VAR_RIT
PUBLIC _VAR_RIT
_VAR_RIT = ""

IF PCOUNT() >= 3
ELSE
	MESSAGEBOX("Parametri insufficienti",16,"Attenzione")
	RETURN _VAR_RIT
ENDIF

IF PCOUNT() >= 3
ELSE
	MESSAGEBOX("Parametri insufficienti",16,"Attenzione")
	RETURN _VAR_RIT
ENDIF

IF PCOUNT() >= 4 .and. TYPE("_par_nSelezione") == 'N'
ELSE
	_par_nSelezione = 0
ENDIF

IF !EMPTY(_par_cTipSource)
	CREATE CURSOR TMP_SOURCE (TIPOLOGIA C(3))
	SELECT TMP_SOURCE
	APPEND BLANK
	REPLACE TIPOLOGIA WITH UPPER(ALLTRIM(_par_cTipSource))
	_par_cTabSource = "TMP_SOURCE"
ENDIF

IF !USED(_par_cTabSource)
	MESSAGEBOX("Cursore &_par_cTabSource inesistente",16,"Attenzione")
	RETURN _VAR_RIT
ENDIF

_par_cStringa = ALLTRIM(_par_cStringa)

SELECT &_par_cTabSource
_TotFields=afields(_NameFields)
_NomeCampoTipologia = _NameFields[1,1]

SELECT &_par_cTabSource
GO TOP
SCAN
	DO CASE
		CASE UPPER(ALLTRIM(&_NomeCampoTipologia)) == "RDA"
		
		CASE UPPER(ALLTRIM(&_NomeCampoTipologia)) == "ODA"
		
		OTHERWISE
			MESSAGEBOX("Tipologia " + &_NomeCampoTipologia + " non gestita",16,"Attenzione")
			RETURN _VAR_RIT
	ENDCASE
ENDSCAN

IF TYPE("_par_cStringa") <> 'C'
	MESSAGEBOX("Parametro stringa da cercare non di tipo STRINGA",16,"Attenzione")
	RETURN _VAR_RIT
ENDIF

CREATE CURSOR CUR_DOCS (SELEZIONE L, FLGCHNG L, TIPDOC C(10), AGGANCIO C(10), NUMDOC C(10), DATDOC C(10), CLIFOR C(10), RAGSOC C(100), CODRIC C(10), ;
						DESRIC C(100), CODMAG C(06), CODART C(16), DESART C(100), UM C(3), QUANTI N(17,2), PREZZO N(17,6), SCONTO1 N(9,3), SCONTO2 N(9,3), ;
						SCONTO3 N(9,3), VALORE N(19,3), COMMENTO M)

SELECT CUR_DOCS
INDEX ON TIPDOC + DATDOC + NUMDOC TAG I_DATNUM DESCENDING ADDITIVE
_TotFields_CUR_DOCS = AFIELDS(_Fields_CUR_DOCS)

SELECT &_par_cTabSource
GO TOP
SCAN
	
	SELECT &_par_cTabSource
	IF UPPER(ALLTRIM(&_NomeCampoTipologia)) == "RDA"
		x_anno = "SUBSTRING(TT.DATA,1,4) = '" + PUB_ANNO + "'"
		x_note = "TT.NOTERIC LIKE '%" + _par_cStringa + "%'"
		x_comm = "COMMENTO LIKE '%" + _par_cStringa + "%'"
		x_rsoc = "DESFOR LIKE '%" + _par_cStringa + "%'"
		x_cart = "CODART LIKE '%" + _par_cStringa + "%'"
		x_dart = "DESART LIKE '%" + _par_cStringa + "%'"
		x_strc = "(TT.TAGGANCIO IN (SELECT DAGGANCIO FROM RDA_DD WHERE (" + x_comm + " or " + x_rsoc + " or " + x_cart + " or " + x_dart + ")) or " + x_note + ")"
		x_cond = x_anno + " and " + x_strc
		x_cric = "TT.CODRIC IN ('###'"  && LIMITAZIONE VISIBILITA' RICHIESTE D'ACQUISTO IN BASE ALLE AUTORIZZAZIONI UTENTE
		DO VEDO_UTENTI WITH ALLTRIM(PUB_CODOPE)
		SELECT CVEDO_UTENTI
		GO TOP
		SCAN
			x_cric = x_cric + ",'" + ALLTRIM(USERID) + "'"
		ENDSCAN
		x_cric = x_cric + ")"
		x_cond = x_cond + " and " + x_cric
		cSql = "SELECT CAST(0 AS BIT) AS SELEZIONE, CAST(0 AS BIT) AS FLGCHNG, " + ;
		       "'RDA' AS TIPDOC, " + ;
		       "TT.TAGGANCIO AS AGGANCIO, " + ;
		       "TT.NUMERO AS NUMDOC, " + ;
		       "TT.DATA AS DATDOC, " + ;
		       "TT.CODRIC AS CODRIC, " + ;
		       "TT.DESRIC AS DESRIC, " + ;
		       "DD.CODFOR AS CLIFOR, " + ;
		       "DD.DESFOR AS RAGSOC, " + ;
		       "DD.CODMAG AS CODMAG, " + ;
		       "DD.CODART AS CODART, " + ;
		       "DD.DESART AS DESART, " + ;
		       "DD.UNIMIS AS UM, " + ;
		       "DD.QUANTITA AS QUANTI, " + ;
		       "DD.PREZZO AS PREZZO, " + ;
		       "0 AS SCONTO1, " + ;
		       "0 AS SCONTO2, " + ;
		       "0 AS SCONTO3, " + ;
		       "DD.VALORE AS VALORE, " + ;
		       "DD.COMMENTO AS COMMENTO " + ;
		       "FROM RDA_TT AS TT " + ;
		       "LEFT OUTER JOIN RDA_DD AS DD ON TT.TAGGANCIO = DD.DAGGANCIO " + ;
		       "WHERE " + x_cond + " " + ;
		       "ORDER BY DAGGANCIO,SEQUEN"
		IF !ExecCommand(cSql,"CX_DETT_RDA")
		  return(.f.)
		ENDIF
		SELECT CX_DETT_RDA
		GO TOP
		SCAN
			SELECT CUR_DOCS
			APPEND BLANK
			FOR I=1 TO _TotFields_CUR_DOCS
				SELECT CX_DETT_RDA
				_NomeCampo = _Fields_CUR_DOCS[I,1]
				_NomeVar = "_X_" + ALLTRIM(_NomeCampo)
				*&_NomeVar = &_NomeCampo
				&_NomeVar = IIF(!ISNULL(&_NomeCampo),&_NomeCampo,IIF(TYPE(_NomeCampo)=='N',0,IIF(TYPE(_NomeCampo)=='L',.F.,"")))  && ERASMO - 26/04/2012
				SELECT CUR_DOCS
				REPLACE &_NomeCampo WITH &_NomeVar
			NEXT
		ENDSCAN
	ENDIF
	
	SELECT &_par_cTabSource
	IF UPPER(ALLTRIM(&_NomeCampoTipologia)) == "ODA"
		x_anno = "SUBSTRING(TT.ORD_DATORD,1,4) = '" + PUB_ANNO + "'"
		x_rsoc = "TT.ORD_RAGSOC LIKE '%" + _par_cStringa + "%'"
		x_comm = "ORD_NOTE LIKE '%" + _par_cStringa + "%'"
		x_cart = "ORD_CODART LIKE '%" + _par_cStringa + "%'"
		x_dart = "ORD_DESART LIKE '%" + _par_cStringa + "%'"
		x_dar2 = "ORD_DES2 LIKE '%" + _par_cStringa + "%'"
		x_strc = "(TT.TAGGANCIO IN (SELECT DAGGANCIO FROM U_ORF_DD WHERE (" + x_comm + " or " + x_cart + " or " + x_dart + " or " + x_dar2 + ")) or " + x_rsoc + ")"
		x_cond = x_anno + " and " + x_strc
		cSql = "SELECT CAST(0 AS BIT) AS SELEZIONE, CAST(0 AS BIT) AS FLGCHNG, " + ;
		       "'ODA' AS TIPDOC, " + ;
		       "TT.TAGGANCIO AS AGGANCIO, " + ;
		       "TT.ORD_NUMORD AS NUMDOC, " + ;
		       "TT.ORD_DATORD AS DATDOC, " + ;
		       "'' AS CODRIC, " + ;
		       "'' AS DESRIC, " + ;
		       "TT.ORD_CODCLI AS CLIFOR, " + ;
		       "TT.ORD_RAGSOC AS RAGSOC, " + ;
		       "DD.ORD_MAGA AS CODMAG, " + ;
		       "DD.ORD_CODART AS CODART, " + ;
		       "DD.ORD_DESART AS DESART, " + ;
		       "DD.ORD_UM AS UM, " + ;
		       "DD.ORD_QTAORD AS QUANTI, " + ;
		       "DD.ORD_PRZNET AS PREZZO, " + ;
		       "DD.ORD_SC1 AS SCONTO1, " + ;
		       "DD.ORD_SC2 AS SCONTO2, " + ;
		       "DD.ORD_SC3 AS SCONTO3, " + ;
		       "DD.ORD_VALORE AS VALORE, " + ;
		       "DD.ORD_NOTE AS COMMENTO " + ;
		       "FROM U_ORF_TT AS TT " + ;
		       "LEFT OUTER JOIN U_ORF_DD AS DD ON TT.TAGGANCIO = DD.DAGGANCIO " + ;
		       "WHERE " + x_cond + " " + ;
		       "ORDER BY DAGGANCIO,ORD_SEQUEN"
		IF !ExecCommand(cSql,"CX_DETT_ORF")
		  return(.f.)
		ENDIF

		SELECT CX_DETT_ORF
		GO TOP
		SCAN
			SELECT CUR_DOCS
			APPEND BLANK
			FOR I=1 TO _TotFields_CUR_DOCS
				SELECT CX_DETT_ORF
				_NomeCampo = _Fields_CUR_DOCS[I,1]
				_NomeVar = "_X_" + ALLTRIM(_NomeCampo)
				*&_NomeVar = &_NomeCampo
				&_NomeVar = IIF(!ISNULL(&_NomeCampo),&_NomeCampo,IIF(TYPE(_NomeCampo)=='N',0,IIF(TYPE(_NomeCampo)=='L',.F.,"")))  && ERASMO - 26/04/2012
				SELECT CUR_DOCS
				REPLACE &_NomeCampo WITH &_NomeVar
			NEXT
		ENDSCAN
	ENDIF
	
ENDSCAN

_VAR_RIT = ""

SELECT CUR_DOCS
SET ORDER TO I_DATNUM
GO TOP
IF EOF()
ELSE
*!*		_cCampiBrowse = "TIPDOC:Doc.,W:5;NUMDOC:Numero,W:8;DATDOC:Data,W:10;CLIFOR:Codice,W:10;RAGSOC:Rag.Sociale,W:20;DESRIC:Richiedente,W:20;" + ;
*!*						"CODART:Articolo,W:10;DESART:Descrizione,W:15;UM:UM,W:5;QUANTI:Qtŕ,W:10;PREZZO:Prezzo,W:15;SCONTO1:Sc.1,W:6;SCONTO2:Sc.1,W:6;" + ;
*!*						"SCONTO3:Sc.1,W:6;VALORE:Valore,W:10;"
*!*		DO CASE
*!*			CASE _par_nSelezione = 0
*!*				DO PRG\browseview WITH "CUR_DOCS","Risultati di ricerca",_cCampiBrowse,600,1020
*!*			
*!*			CASE _par_nSelezione = 1
*!*				DO PRG\browseview WITH "CUR_DOCS","Selezionare un risultato di ricerca",_cCampiBrowse,600,1000,.F.,.T.
*!*			
*!*			CASE _par_nSelezione = 2
*!*				DO PRG\browseview WITH "CUR_DOCS","Selezionare i risultati di ricerca",_cCampiBrowse,600,1000,.T.,.F.
*!*		ENDCASE

	*** MARCATURA CUR_DOCS.FLGCHNG PER VISUALIZZAZIONE BIANCO/GRIGETTO A ROTTURA DOCUMENTO
	_OLD_AGGANCIO = ""
	_OLD_FLGCHNG = .T.
	SCAN
		IF _OLD_AGGANCIO = AGGANCIO
			REPLACE FLGCHNG WITH _OLD_FLGCHNG
		ELSE
			_OLD_FLGCHNG = !_OLD_FLGCHNG
			_OLD_AGGANCIO = AGGANCIO
			REPLACE FLGCHNG WITH _OLD_FLGCHNG
		ENDIF
	ENDSCAN
	GO TOP
	
	_V_MOSTRA_PREZZI = UTENTE_MOSTRA_PREZZI(PUB_CODOPE)
	
	DO FORM FORM\CERCA_IN_DOCUMENTI WITH _par_nSelezione LINKED
	
	*** RITORNO L'AGGANCIO DEL PRIMO DOCUMENTO SELEZIONATO
	NumeroRecordSelezionati = 0
	SELECT CUR_DOCS
	GO TOP
	SCAN
		IF SELEZIONE
			NumeroRecordSelezionati = NumeroRecordSelezionati + 1
		ENDIF
	ENDSCAN
	
	GO TOP
	IF NumeroRecordSelezionati > 0
		SCAN
			IF SELEZIONE
				_VAR_RIT = AGGANCIO
				EXIT
			ENDIF
		ENDSCAN
	ENDIF
ENDIF

RETURN _VAR_RIT

ENDFUNC




**********************************************************************************************************************************
FUNCTION UTENTE_MOSTRA_PREZZI
**********************************************************************************************************************************
*** PASSANDO IL CODICE UTENTE PREMETTE DI SAPERE SE L'UTENTE E' AUTORIZZATO OPPURE NO A VISUALIZZARE PREZZI A VALORI
*** ESEMPIO:
***   _V_MOSTRA_PREZZI = UTENTE_MOSTRA_PREZZI("SER")
***
*** VARIABILE DI RITORNO DI TIPO LOGICO (.T./.F.)
**********************************************************************************************************************************
PARAMETERS _par_utente

IF PCOUNT() >= 1
ELSE
	MESSAGEBOX("Parametri per Function 'UTENTE_MOSTRA_PREZZI' insufficienti",16,"Attenzione")
	RETURN .F.
ENDIF

IF TYPE("_par_utente") == 'C'
ELSE
	MESSAGEBOX("Parametri per Function 'UTENTE_MOSTRA_PREZZI' non validi o insufficienti",16,"Attenzione")
	RETURN .F.
ENDIF

_RIT = .F.

SWS=SELECT()

DO VEDO_SINGOLO_UTENTE WITH ALLTRIM(PUB_CODOPE)
SELECT CVEDO_UTENTI
GO TOP
SCAN
	IF MOSTRA_PREZZI
		_RIT = .T.
		EXIT
	ENDIF
ENDSCAN

SELECT(SWS)

RETURN _RIT

ENDFUNC


**********************************************************************************************************************************
FUNCTION CERCA_LOCAZIONE_PREDEFINITA
**********************************************************************************************************************************
*** PASSANDO IL CODICE ARTICOLO PREMETTE DI TROVARE LA LOCAZIONE PREDEFINITA PER QUELL'ARTICOLO
*** ESEMPIO:
*** IF CERCA_LOCAZIONE_PREDEFINITA(M.ORD_CODART)
*** 	SELECT PJ_LOC_RULES
*** 	M.ORD_MAGA = RUL_CODMAG
*** 	M.ORD_FILA_X = RUL_FILA_X
*** 	M.ORD_PIAN_X = RUL_PIAN_X
*** 	M.ORD_UBIC_X = RUL_UBIC_X
*** 	M.ORD_FILA_N = RUL_FILA_N
*** 	M.ORD_PIAN_N = RUL_PIAN_N
*** 	M.ORD_UBIC_N = RUL_UBIC_N
*** ENDIF
***
*** VARIABILE DI RITORNO DI TIPO LOGICO (.T. = TROVATO/.F. = NON TROVATO)
*** CURSORE DI RITORNO PJ_LOC_RULES CON STESSA STRUTTURA DELLA TABELLA LOC_RULES
**********************************************************************************************************************************
PARAMETERS _par_anaart

IF PCOUNT() >= 1
ELSE
	MESSAGEBOX("Parametri per Function 'CERCA_LOCAZIONE_PREDEFINITA' insufficienti",16,"Attenzione")
	RETURN .F.
ENDIF

_RIT = .F.

SWS=SELECT()

x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
x_codi = "art_codpri = '" + _par_anaart + "'"
x_cond = x_soci + " and " + x_codi
cSql = "select * from U_ART_PR where " + x_cond
IF !ExecCommand(cSql,"TMP_ART_PR")
   RETURN .F.
ENDIF
SELECT TMP_ART_PR
GO TOP
IF EOF()
	RETURN .F.
ENDIF

IF !ExecCommand("select * from LOC_RULES where 1=0","PJ_LOC_RULES")
  return(.f.)
ENDIF

IF !ExecCommand("select * from LOC_RULES","CU_LOC_RULES")
  return(.f.)
ENDIF
SELECT CU_LOC_RULES
GO TOP
SCAN
	SCATTER MEMVAR MEMO
	_EXPRESSION = ALLTRIM(M.RUL_EXPRESSION)
	SELECT TMP_ART_PR
	IF &_EXPRESSION
		SELECT PJ_LOC_RULES
		APPEND BLANK
		GATHER MEMVAR MEMO
		_RIT = .T.
	ENDIF
	
ENDSCAN

SELECT(SWS)

RETURN _RIT

ENDFUNC


