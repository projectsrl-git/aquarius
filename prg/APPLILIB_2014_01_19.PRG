************************************************************
PROCEDURE CHIUSURA_ANNO_FISCALE
************************************************************
* PROCEDURA PER LA CHIUSURA/APERTURA ANNO FISCALE,
* PER PERMETTERE O MENO LA MODIFICA DEI MOVIMENTI
* APPARTENENTI A DETERMINATI ANNI
************************************************************

PUB_PJPWD =.F.
PUB_MESS  = CHR(13) + "Chiusura/apertura anno fiscale" + CHR(13) + ;
          "Accesso consentito solo a persone autorizzate munite di password" + CHR(13) + CHR(13) + ;
          "Digitare password di accesso..."

DO FORM FORM\PJPWD WITH 'DTR' LINKED

IF !PUB_PJPWD
   =MESSAGEB("Password non abilitata !!!",16,"*** ATTENZIONE ***")
   RETURN
ENDIF

x_codi = "codice like 'ANN" + PUB_CODSOC + "%'"
x_cond = x_codi
Csql   = "SELECT SPACE(10) AS SELEZIONE, CASE CHIUFISCAL WHEN 1 THEN 'CHIUSO' WHEN 0 THEN 'APERTO' ELSE '' END AS STATO, " + ;
         "SUBSTRING(CODICE,6,4) AS ANNO, * FROM PARA WHERE " + x_cond + " ORDER BY CODICE"
IF !ExecCommand(Csql,"SEL_ANNO_FISCALE")
   return(.f.)
ENDIF
SELECT SEL_ANNO_FISCALE
GO TOP
IF EOF()
   MESSAGEBOX("Nessun anno fiscale da aprire/chiudere",16,"Attenzione")
   RETURN .F.
ENDIF

DO prg\browseview WITH "SEL_ANNO_FISCALE","Selezionare l'anno fiscale da aprire/chiudere",;
                       "ANNO:Anno,W:21;STATO:Stato fiscale,W:40;",500,500,.F.,.T.
IF NumeroRecordLetti = 0
   MESSAGEBOX("Nessun anno fiscale selezionato",16,"Informazione")
   RETURN .F.
ENDIF

_SI_CHIUDI = .F.
_ANNO_SELE = ""
_TIPO_SELE = ""
SELECT SEL_ANNO_FISCALE
GO TOP
SCAN
   IF DELETED()
      LOOP
   ENDIF
   IF ALLTRIM(SELEZIONE) == "==>"
      _ANNO_SELE = ALLTRIM(ANNO)
      IF CHIUFISCAL
         _TIPO_SELE = "DA APRIRE"
      ELSE
         _TIPO_SELE = "DA CHIUDERE"
      ENDIF
   ENDIF
ENDSCAN

IF EMPTY(_ANNO_SELE)
   RETURN .F.
ENDIF

x_valu = "0"
IF _TIPO_SELE = "DA CHIUDERE"
	_MESSAGGIO = CHR(10) + "ATTENZIONE:" + CHR(10) + CHR(10) + "Chiudere l'anno fiscale " + _ANNO_SELE + " ?" + CHR(10) + CHR(10) + ;
	             "N.B.: Effettuando la chiusura non sarŕ piů possibile modificare i movimenti relativi all'anno " + _ANNO_SELE
	x_valu = "1"
ELSE
	_MESSAGGIO = CHR(10) + "ATTENZIONE:"+CHR(10)+CHR(10)+"Aprire l'anno fiscale " + _ANNO_SELE + " ?" + CHR(10) + CHR(10) + ;
	             "N.B.: Effettuando l'apertura sarŕ di nuovo possibile modificare i movimenti relativi all'anno " + _ANNO_SELE
	x_valu = "0"
ENDIF
IF MESSAGGIO_GROSSO_ROSSO_RISPOSTA_SI_NO(_MESSAGGIO) = "SI"
ELSE
	MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	RETURN .F.
ENDIF

x_codi = "codice = 'ANN" + ALLTRIM(PUB_CODSOC) + _ANNO_SELE + "'"
x_cond = x_codi
Csql   = "UPDATE PARA SET CHIUFISCAL = '" + x_valu + "' WHERE " + x_cond
IF !ExecCommand(Csql,"UPD_PARA")
	return(.f.)
ENDIF

IF _TIPO_SELE = "DA CHIUDERE"
	MESSAGEBOX("Anno fiscale " + _ANNO_SELE + " chiuso correttamente",64,"Informazione")
ELSE
	MESSAGEBOX("Anno fiscale " + _ANNO_SELE + " aperto correttamente",64,"Informazione")
ENDIF

RETURN


