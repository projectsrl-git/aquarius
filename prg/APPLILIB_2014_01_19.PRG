*********************************************
FUNCTION INSERISCI_COMMENTI_AUTOMATICI_E_NO
*********************************************

 DO CASE


  	 CASE NOC_TOTDO
  		    _CODICE = NOT_CODICE		
	     	_TESTO  = NOT_TESTO	
   			=DLET_NOTE_AUTOMATICHE(_TIPON,_CURSORE,_CODICE)	  	     				
       		=ISRT_SIAU(_TIPON,_CURSORE,_CODICE,_XVAL,_PESO,_PALLET,_DTCONS)	 	&& TESTI CON CALCOLI

     CASE NOC_SCON
  		    _CODICE = NOT_CODICE		
	     	_TESTO  = NOT_TESTO	
   			=DLET_NOTE_AUTOMATICHE(_TIPON,_CURSORE,_CODICE)	  	     				
       		=ISRT_SIAU(_TIPON,_CURSORE,_CODICE,_XVAL,_PESO,_PALLET,_DTCONS)	 	&& TESTI CON CALCOLI

     CASE NOC_PAGAN


            IF _CURSORE <> "CU_ORF_DD"

				V_SEEK	 = 'CPA'+M.ORD_CPA
				V_CHIAVE = "CODICE"
				IF SEEK_STD('PARA',V_SEEK,V_CHIAVE,'CUR_PARA')
				   SELECT CUR_PARA
                   _SCA	 =  ALLTRIM(SUBSTR(LIBERA,08,01))
				ELSE
                   _SCA	 =  " "
				ENDIF
				
				SELECT NOTE_COM				
				
				IF _SCA = "A"				&& CONDIZIONE DI PAGAMENTO ANTICIPATO : CREA COMMENTO
		  		    _CODICE = NOT_CODICE		
			     	_TESTO  = NOT_TESTO				
   					=DLET_NOTE_AUTOMATICHE(_TIPON,_CURSORE,_CODICE)	
		       		=ISRT_SIAU(_TIPON,_CURSORE,_CODICE,_XVAL,_PESO,_PALLET,_DTCONS)	 	&& TESTI CON CALCOLI
    			ENDIF
    			
			ENDIF



      CASE NOC_TOTMQ
           *** CALCOLA TOTALE METRI QUADRI SUL DOCUMENTO
  		    _CODICE = NOT_CODICE		
	     	_TESTO  = NOT_TESTO				
   			=DLET_NOTE(_TIPON,_CURSORE,_CODICE)
	        SAVE_ORD_FLGMOD = M.ORD_FLGMOD
	        M.ORD_FLGMOD = 'I'
       		=ISRT_SIAU(_TIPON,_CURSORE,_CODICE,_XVAL,_PESO,_PALLET,_DTCONS)	 	&& TESTI CON CALCOLI
	        M.ORD_FLGMOD = SAVE_ORD_FLGMOD


      **=> ERASMO - INIZIO 06/12/2011
      CASE NOC_TOTMC
           *** CALCOLA TOTALE METRI CUBI SUL DOCUMENTO
  		    _CODICE = NOT_CODICE		
	     	_TESTO  = NOT_TESTO				
   			=DLET_NOTE(_TIPON,_CURSORE,_CODICE)
	        SAVE_ORD_FLGMOD = M.ORD_FLGMOD
	        M.ORD_FLGMOD = 'I'
       		=ISRT_SIAU(_TIPON,_CURSORE,_CODICE,_XVAL,_PESO,_PALLET,_DTCONS)	 	&& TESTI CON CALCOLI
	        M.ORD_FLGMOD = SAVE_ORD_FLGMOD
      **=> ERASMO - FINE 06/12/2011


     OTHERWISE
            ** GESTIONE TESTI STANDARD CONAI,...
  		    _CODICE = NOT_CODICE		
	     	_TESTO  = NOT_TESTO		
   			=DLET_NOTE_AUTOMATICHE(_TIPON,_CURSORE,_CODICE)	     			
 	        =ISRT_NOTE(_TESTO,_CURSORE,_CODICE)
 	
 ENDCASE


RETURN(.T.)


******************************
FUNCTION ISRT_SIAU
******************************
* ELABORA I COMMENTI E DETERMINA SE DEVE CREARE IL COMMENTO IN AUTOMATICO CON CALCOLI RICHIESTI
**SERGIOTXT
PARA _TIPON,_CURSORE,_TIP_TXT,_XVAL,_PESO,_PALLET,_DTCONS
SS=STR(SELECT())

_TESTO=""

x_soci  = "not_codsoc = '" + PUB_CODSOC + "'"
x_codi  = "not_codice = '" + ALLTRIM(_TIP_TXT) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from note_com where " + x_cond + " order by not_codsoc,not_codice"

IF !ExecCommand(cSql,"CX_note_com")
   return(.f.)
ENDIF
SELECT CX_note_com
GO TOP



IF reccount() <> 0

   _TESTO = NOT_TESTO

   * -------------------------------------------------------------------------- descrizioni in lingua ---------- 'TESTOCONAI' ---------- *
   DL_TIPODES 		= 'TESTOCONAI'
   DL_CODICE  		= ALLTRIM(_TIP_TXT)
   _DESCR_LINGUA 	= CERCA_DESCRIZIONI_IN_LINGUA(DL_TIPODES,DL_LINGUA,DL_CODICE)
   IF !EMPTY(_DESCR_LINGUA)
  	  _TESTO        = _DESCR_LINGUA
   ENDIF
   * -------------------------------------------------------------------------- descrizioni in lingua ---------- 'TESTOCONAI' ---------- *

   SELECT CX_note_com

   DO CASE

      CASE NOC_TOTDO			&& EFFETTUA CALCOLO TOTALE MERCE E CREA TESTO
           M.ORD_VALCO = 0
	       _TXT = NOT_TESTO	
           M.ORD_NOTE=TXT_TT(_TIPON,_CURSORE,_TIP_TXT,_TXT,_XVAL)
	       =ISRT_NOTE(M.ORD_NOTE,_CURSORE,_TIP_TXT)

      CASE NOC_SPINC


	  CASE NOC_PAGAN			&& SCONTO SU PAGAMENTO ANTICIPATO
           M.ORD_VALCO = 0
	       _TXT = NOT_TESTO	
           M.ORD_NOTE=TXT_SCONTI(_TIPON,_CURSORE,_TIP_TXT,_TXT,_XVAL)
	       =ISRT_NOTE(M.ORD_NOTE,_CURSORE,_TIP_TXT)

      CASE NOC_SCON				&& SCONTO GENERICO
           M.ORD_VALCO = 0
	       _TXT = NOT_TESTO	
           M.ORD_NOTE=TXT_SCONTI(_TIPON,_CURSORE,_TIP_TXT,_TXT,_XVAL)
	       =ISRT_NOTE(M.ORD_NOTE,_CURSORE,_TIP_TXT)

      CASE NOC_GEST3
           _TESTO=CHR(13)+CHR(13)+CHR(13)+CHR(13)+'- - - - - - - - - - - - - - - - - - - - - - -'+CHR(13)
           _TESTO=_TESTO+NOT_TESTO	+": "+ALLTRIM(_PESO)

      CASE NOC_GEST4
           _TESTO=NOT_TESTO	+": "+ALLTRIM(_PALLET)

      CASE NOC_GEST5
           _TESTO=NOT_TESTO	+": "+ALLTRIM(_DTCONS)

      CASE NOC_GEST6
           *** IN QUESTO CASO IL PESO CONTIENE L'INDIRIZZO DELLA DESTINAZIONE
           _TESTO=NOT_TESTO	+": "+ALLTRIM(_PESO)

      CASE NOC_TOTMQ
           *** CALCOLA TOTALE METRI QUADRI SUL DOCUMENTO
	       _TXT = NOT_TESTO	
	       TOTALE_METRI_QUADRI = 0
           M.ORD_NOTE=TXT_TOTMQ(_TIPON,_CURSORE,_TIP_TXT,_TXT,_XVAL)
	       IF TOTALE_METRI_QUADRI <> 0
	          PUB_SEQUEN_TESTO = 99500
	      	  =ISRT_NOTE(M.ORD_NOTE,_CURSORE,_TIP_TXT)
	      	  PUB_SEQUEN_TESTO = 0
	       ENDIF

      **=> ERASMO - INIZIO 06/12/2011
      CASE NOC_TOTMC
           *** CALCOLA TOTALE METRI CUBI SUL DOCUMENTO
	       _TXT = NOT_TESTO	
	       TOTALE_METRI_CUBI = 0
	       PUB_COSTOTR  = 0
           M.ORD_NOTE=TXT_TOTMC(_TIPON,_CURSORE,_TIP_TXT,_TXT,_XVAL)
	       IF TOTALE_METRI_CUBI <> 0
	          PUB_SEQUEN_TESTO = 99510
	      	  =ISRT_NOTE(M.ORD_NOTE,_CURSORE,_TIP_TXT)
	      	  PUB_SEQUEN_TESTO = 0
	       ENDIF
      **=> ERASMO - FINE 06/12/2011



   ENDCASE
ENDIF

SELECT &SS
RETURN


******************************
FUNCTION TXT_TOTMQ
******************************
* CREA TESTO CON TOTALE METRI QUADRI

PARA _TIPON,_CURSORE,_TIP_TXT,_TXT,_XVAL


SELECT &_CURSORE
_REC_ = RECNO()

GO TOP
_TVAL = 0
_MATP = 0
TOTALE_METRI_QUADRI = 0


DO WHILE .NOT.EOF()

   IF DELETED()
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF


   IF !EMPTY(ALLTRIM(PUB_DAGGANCIO))						&& SOLO PER QUEL DDT MEMORIZZATO NEL CURSORE (NE POSSONO ESISTERE ALTRI)
       IF ALLTRIM(PUB_DAGGANCIO) <> ALLTRIM(DAGGANCIO)
		  SELECT &_CURSORE
		  SKIP +1
		  LOOP
	   ENDIF
   ENDIF


   TOTALE_METRI_QUADRI = TOTALE_METRI_QUADRI + ORD_QTAMQ

   SELECT &_CURSORE
   SKIP +1

ENDDO

SELECT &_CURSORE
GO TOP




* INSERISCE NEL TESTO CON IL TOTALE METRI QUADRI CALCOLATO

* _TXT = STRTRAN(_TXT,".TOTMETRIQUADRI",ALLTRIM(STR(TOTALE_METRI_QUADRI ,15,2)))
 _TXT = STRTRAN(_TXT,".TOTMETRIQUADRI",ALLTRIM(STR(TOTALE_METRI_QUADRI ,15,PUB_DECQTA)))  && ERASMO - 06/12/2011



RETURN(_TXT)

******************************
FUNCTION DLET_NOTE
******************************
* CANCELLA TESTO

PARA _TIPON,_CURSORE,_CODICE__


SELECT &_CURSORE
_REC_ = RECNO()

GO TOP


DO WHILE .NOT.EOF()

   IF DELETED()
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF

   IF ALLTRIM(ORD_DESART) <> "*** COMMENTO ***"
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF

   IF !EMPTY(ALLTRIM(PUB_DAGGANCIO))						&& SOLO PER QUEL DDT MEMORIZZATO NEL CURSORE (NE POSSONO ESISTERE ALTRI)
       IF ALLTRIM(PUB_DAGGANCIO) <> ALLTRIM(DAGGANCIO)
		  SELECT &_CURSORE
		  SKIP +1
		  LOOP
	   ENDIF
   ENDIF

   IF ALLTRIM(ORD_CODICE) = ALLTRIM(_CODICE__) AND ALLTRIM(ORD_DESART) = "*** COMMENTO ***"  && TEST DI SICUREZZA
   	  SELECT &_CURSORE
      REPLACE ORD_FLGMOD WITH 'A'
      IF PUB_CANCELLA_TESTO  && FLAG GESTITO IN MENU_OTOB003 - SERGIO CANCELLA FISICAMENTE IL COMMENTO DAL CURSORE DI SUPPORTO USATO DURANTE LA CREAZIONE DELLA DDT DA ORDINE (EVASIONE PARZIALE)
		DELETE
	  ENDIF
   ENDIF


   SELECT &_CURSORE
   SKIP +1

ENDDO

SELECT &_CURSORE
GO TOP


RETURN(.T.)

