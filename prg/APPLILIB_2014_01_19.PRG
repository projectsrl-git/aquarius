***************************************************************************
PROCEDURE spalmatura_verificacolla
***************************************************************************§°§

*=> Determinazione delle quantitŕ in MQ da spalmare (tutta la bobina in altezza)
V_QTAXCOLLA = TROVA_MQ_DA_AL((V_ALTXCOLLA-v_cimosa),V_LUNXCOLLA,1)

*=> Esplosione del Distinta base
SI_VIDEO = .F.
DO ALBERELLO  WITH SI_VIDEO,V_DIBXCOLLA   && ESPLODE LA DISTINTA BASE A VIDEO

SELECT WEXPLODE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Dal primo livello (codice Di.Ba. salvo il codice e la descrizione del Distinta Base)
   IF WLIV = 1
      SKIP +1
      LOOP
   ENDIF

   *=> Accesso alla anagrafica articoli dei singoli componenti
   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.WCOD) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articolo")
      return(.f.)
   ENDIF
   SELECT cur_articolo
   GO TOP
   IF EOF()
      V_NONMOV = .T.
   ELSE
      V_NONMOV = ART_NONMOV
   ENDIF

   *=> Articoli da non movimentare (es. acqua)
   IF V_NONMOV
      SELECT WEXPLODE
      SKIP +1
      LOOP
   ENDIF

   V_QTANEC = M.WQTAT * V_QTAXCOLLA				&& Qtŕ necessaria alla produzione
   V_GIACEN = 0

   *x_giac = "mag_comodo > 0"
   *x_arti = "mag_anaart = '" + M.WCOD + "'"
   *x_cond = x_giac + " .and. " + x_arti
   *SELECT G_MAG_GG
   *SET FILTER TO
   *SET FILTER TO &x_cond
   *GO TOP

   V_SEEK = M.WCOD
   SELECT G_MAG_GG
   SET ORDER TO I_GMAGG3
   SEEK V_SEEK
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF DELETED()
         SKIP +1
         LOOP
      ENDIF
      IF MAG_ANAART = M.WCOD
      ELSE
         EXIT
      ENDIF
      IF MAG_COMODO > 0
      ELSE
         SKIP +1
         LOOP
      ENDIF
      IF MAG_COMODO > MAG_QTAIMP
      ELSE
         SKIP +1
         LOOP
      ENDIF
      V_GIACEN = V_GIACEN + MAG_COMODO
      SKIP +1
   ENDDO

   IF V_GIACEN < V_QTANEC
      V_TROXCOLLA = .F.
      EXIT
   ENDIF

   SELECT WEXPLODE
   SKIP +1

ENDDO

RETURN



