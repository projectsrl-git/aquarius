FUNCTION OK_SCONTI_CLIENTE_CATEGORIA_MERCEOLOGICA
**********************************************************************************************************
**
**  ACCESE ALLA TABELLA U_SCO_CM CON DUE MODALITA' :
**
**
**  	1) SCONTO PER CLIENTE\CATEGORIA MERCEOLOGICA E PRELEVA GLI SCONTI DI PRIMA E/O SECONDA SCELTA
**		=============================================================================================
**
**		SE NON ESISTE
**
**  	2) SCONTO PER CATEGORIA MERCEOLOGICA E PRELEVA GLI SCONTI DI PRIMA E/O SECONDA SCELTA
**		=====================================================================================
**
**
**
**
**
**  RITORNA :
**
**		-  PUB_SC1,PUB_SC2,PUB_SC3,PUB_SC4/M.ORD_SC1,M.ORD_SC2,M.ORD_SC3,M.ORD_SC4 : SCONTI DI PRIMA E/O SECONDA SCELTA
**					
**

PARA _SOC,_CLI,_ART,_DTDO

IF SUBSTR(_DTDO,3,1) = '/'
ELSE
   _DTDO = RIBALTA2(_DTDO)
ENDIF

S_S=STR(SELECT())


IF _PREZZO_NETTO_SU_CLIENTE_ESISTENTE && se esiste un PREZZO NETTO mirato sul cliente : SONO GESTITI SOLO GLI SCONTI INCONDIZIONATI SE ESISTONO PER CUI AZZERO SCONTI PRIMA/SECONDA SCELTA

    PUB_SC1		= 0
    PUB_SC2		= 0
    PUB_SC3		= 0
    PUB_SC4		= 0

    M.ORD_SC1 	= 0
    M.ORD_SC2	= 0
    M.ORD_SC3	= 0
    M.ORD_SC4	= 0

	select &s_s
	return	
	
ENDIF



RELEASE _local_trovato                 && flag di sconto trovato
PUBLIC  _local_trovato                 && flag di sconto trovato
_local_trovato= .f.                    && flag di sconto trovato


local_cliente 		= _CLI
local_data_listino 	= _DTDO



**=> ERASMO - INIZIO 13/12/2011
*** PRELEVO I DATI DALL'ANAGRAFICA ARTICOLI, COMPRESO IL CAMPO 'ART_SCELTA' CHE SI TROVA IN U_ART_AN
local_catmer = ""
local_scelta = ""
x_soci = "u_art_pr.art_codsoc = '" + PUB_CODSOC + "'"
x_codi = "u_art_pr.art_codpri = '" + ALLTRIM(_ART) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select u_art_pr.art_codpri, u_art_pr.art_catmer, coalesce(u_art_an.art_scelta,'') as art_scelta from u_art_pr left outer join u_art_an " + ;
	"on u_art_pr.art_codsoc = u_art_an.art_codsoc and u_art_pr.art_codpri = u_art_an.art_codpri where " + x_cond
IF !ExecCommand(cSql,"local_cu_art_pr")
   return(.f.)
ENDIF
SELECT local_cu_art_pr
GO TOP
IF !EOF()
	local_catmer = art_catmer  && categoria merceologica
	local_scelta = art_scelta  && scelta
ENDIF
**=> ERASMO - FINE 13/12/2011

local_accesso	= "ACCESSO-01"														&& cliente + categoria merceologica
_local_trovato	= .f.               												&& flag di prezzo trovato
=accesso_u_sco_cm(local_cliente,local_catmer,local_data_listino,local_accesso,local_scelta)  && ERASMO - 13/12/2011
IF _local_trovato
	select &s_s
	return	
ENDIF

local_accesso= "ACCESSO-02"															&& categoria merceologica
_local_trovato= .f.                 												&& flag di prezzo trovato
=accesso_u_sco_cm(local_cliente,local_catmer,local_data_listino,local_accesso,local_scelta)  && ERASMO - 13/12/2011
IF _local_trovato
	select &s_s
	return	
ENDIF



SELECT &S_S
RETURN


