      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   __PROVVIGIONI_RIGA__ = M.ORD_PRORIG
   _CODICE_ARTICOLO     = M.ORD_CODART

	x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
	x_codi = "art_codpri = '" + M.ORD_CODART + "'"
