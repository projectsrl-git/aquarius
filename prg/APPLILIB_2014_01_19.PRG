   REPLACE ORD_DESTAG WITH M.ART_DESTAG
   REPLACE ORD_CODCOL WITH M.ART_CODCOL
   REPLACE ORD_DESCOL WITH M.ART_DESCOL
   REPLACE ORD_CODMAT WITH M.ART_CODMAT
   REPLACE ORD_DESMAT WITH M.ART_DESMAT
   REPLACE ORD_CODCOL WITH M.ART_CODCOL
   REPLACE ORD_DESCOL WITH M.ART_DESCOL
   REPLACE ORD_SPESSO WITH M.ART_SPESSO
   REPLACE ORD_ALTEZZ WITH M.ART_ALTEZZ
   REPLACE ORD_LUNGHE WITH M.ART_LUNGHE
   REPLACE ORD_CODIMB WITH M.ART_CODIMB
   REPLACE ORD_DESIMB WITH M.ART_DESIMB
   REPLACE ORD_LOTMIN WITH M.ART_LOTMIN
