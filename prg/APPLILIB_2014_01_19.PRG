   x_colo = "art_codcol = '" + ALLTRIM(M.FAB_CODCOL) + "'"
   x_mate = "art_codmat = '" + ALLTRIM(M.FAB_CODMAT) + "'"
   x_spes = "art_spesso = " + ALLTRIM(STR(M.FAB_SPESSO,5,0))
   x_cond = x_soci + " and " + x_tart + " and " + x_colo + " and " + x_mate + " and " + x_spes
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cUt_ART_PR")
      return(.f.)
   ENDIF
   SELECT cUt_ART_PR
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      VVV_CODART = ART_CODPRI
      SELECT CU_SCO_MI
      SET ORDER TO I_SCORMI
      SEEK VVV_CODART + ALLTRIM(STR((M.FAB_ALTEZZ),5,0))
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE SCO_CODART WITH VVV_CODART
         REPLACE SCO_ALTEZZ WITH M.FAB_ALTEZZ
         REPLACE SCO_LUNGHE WITH 0
         REPLACE SCO_NUMBOB WITH 0
         REPLACE SCO_SCORMI WITH 0
      ENDIF
      REPLACE SCO_LUNGHE WITH SCO_LUNGHE + M.FAB_LUNGHE
      REPLACE SCO_SCORMI WITH TROVA_MQ_DA_AL(SCO_ALTEZZ,SCO_LUNGHE,1)
      REPLACE SCO_NUMBOB WITH 1
      SELECT cUt_ART_PR
      SKIP +1
   ENDDO
   SELECT CUR_FABBISOGNI
   SKIP +1
ENDDO

WAIT WINDOWS "Attendere prego, Aggiornamento scorte minime su anagrafica articoli semilavorati e adesivi" NOWAIT

*=> Aggiornamento fabbisogni semilavorati (bobine spalmate) e adesivi
SELECT CUR_FABBISOGNI
SET ORDER TO I_FABBIS
SET FILTER TO
GO TOP
VVV_CODART = FAB_CODART
VVV_QUANTI = 0
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF FAB_CODART = VVV_CODART
   ELSE
      VVV_CODART = FAB_CODART
      VVV_QUANTI = 0
      LOOP
   ENDIF
   V_TIPO = CERCATIPO(FAB_CODART)
   IF V_TIPO = "1"
   ELSE
      XXX_CODART = FAB_CODART
      XXX_QUANTI = FAB_QTAKG
      VVV_QUANTI = VVV_QUANTI + FAB_QTAKG
      SELECT CUP_SCO_MI
      SET ORDER TO I_SCORMI
      SEEK XXX_CODART
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE SCO_CODART WITH XXX_CODART
         REPLACE SCO_SCORMI WITH 0
      ENDIF
      REPLACE SCO_SCORMI WITH SCO_SCORMI + XXX_QUANTI
      SELECT CUR_FABBISOGNI
      SKIP +1
      LOOP
   ENDIF
   SELECT CUR_FABBISOGNI
   SCATTER MEMVAR MEMO

   x_cond = "alt_finudo = " + ALLTRIM(STR((M.FAB_ALTEZZ),5,0))
   cSql   = "select * from U_PRO_AL where " + x_cond
   IF !ExecCommand(cSql,"CUR_PRO_AL")
      return(.f.)
   ENDIF
   SELECT CUR_PRO_AL
   GO TOP
   IF EOF()
   ELSE
      M.FAB_ALTEZZ = ALT_FISPAL
   ENDIF

   SELECT CU_SCO_MI
   SET ORDER TO I_SCORMI
   SEEK VVV_CODART + ALLTRIM(STR((M.FAB_ALTEZZ),5,0))
   IF FOUND()
   ELSE
      APPEND BLANK
      REPLACE SCO_CODART WITH VVV_CODART
      REPLACE SCO_ALTEZZ WITH M.FAB_ALTEZZ
      REPLACE SCO_LUNGHE WITH 0
      REPLACE SCO_NUMBOB WITH 0
      REPLACE SCO_SCORMI WITH 0
   ENDIF
   REPLACE SCO_LUNGHE WITH SCO_LUNGHE + M.FAB_LUNGHE
   REPLACE SCO_SCORMI WITH TROVA_MQ_DA_AL(SCO_ALTEZZ,SCO_LUNGHE,1)
   REPLACE SCO_NUMBOB WITH 1
   VVV_QUANTI = VVV_QUANTI + SCO_SCORMI
   SELECT CUR_FABBISOGNI
   SKIP +1
ENDDO

*!*	V_FFDATA1 = CTOD(_F_DORDDA)
*!*	V_FFDATA2 = CTOD(_F_DORDAL)
*!*	V_NUMGIOR = V_FFDATA2 - V_FFDATA1 + 1
V_NUMGIOR = _V_GGFATT

WAIT WINDOWS "Attendere prego, Consolidamento dati elaborati sulle tabelle di competenza" NOWAIT

SELECT CU_SCO_MI
SET ORDER TO I_SCORMI
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   SCATTER MEMVAR MEMO
   IF SCO_ALTEZZ = 0 .OR. SCO_LUNGHE = 0
      SKIP +1
      LOOP
   ENDIF
   IF _V_GGCOP = 0
   ELSE
      IF _V_GGCOP >= V_NUMGIOR
      ELSE
         V_LUNCOP1 = ROUND((SCO_LUNGHE / V_NUMGIOR),0)
         V_LUNCOP2 = ROUND((V_LUNCOP1 * _V_GGCOP),0)
         REPLACE SCO_LUNGHE WITH V_LUNCOP2
         REPLACE SCO_SCORMI WITH TROVA_MQ_DA_AL(SCO_ALTEZZ,SCO_LUNGHE,1)
         SCATTER MEMVAR MEMO
      ENDIF
   ENDIF
   cSql = "select * from U_SCO_MI where 1=0"
   IF !ExecRW(cSql,"U_SCO_MI","R")
      return(.f.)
   ENDIF
   SELECT U_SCO_MI
   GO TOP
   APPEND BLANK
   DO U_SCO_MI
   IF !ExecRW(cSql,"U_SCO_MI","W")
      return(.f.)
   ENDIF
   SELECT CUP_SCO_MI
   SET ORDER TO I_SCORMI
   SEEK M.SCO_CODART
   IF FOUND()
   ELSE
      APPEND BLANK
      REPLACE SCO_CODART WITH M.SCO_CODART
      REPLACE SCO_SCORMI WITH 0
   ENDIF
   REPLACE SCO_SCORMI WITH SCO_SCORMI + M.SCO_SCORMI
   SELECT CU_SCO_MI
   SKIP +1
ENDDO

SELECT CUP_SCO_MI
SET ORDER TO I_SCORMI
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   SCATTER MEMVAR
   V_TIPO = CERCATIPO(M.SCO_CODART)
   IF V_TIPO = "1"
   ELSE
      IF _V_GGCOP = 0
      ELSE
         IF _V_GGCOP >= V_NUMGIOR
         ELSE
            V_LUNCOP1 = M.SCO_SCORMI / V_NUMGIOR
            V_LUNCOP2 = V_LUNCOP1 * _V_GGCOP
            M.SCO_SCORMI = V_LUNCOP2
         ENDIF
      ENDIF
   ENDIF
   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.SCO_CODART) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond
   IF !ExecRW(cSql,"U_ART_PR","R")
      return(.f.)
   ENDIF
   SELECT U_ART_PR
   GO TOP
   IF EOF()
   ELSE
      REPLACE ART_SCORMI WITH M.SCO_SCORMI
   ENDIF
   IF !ExecRW(cSql,"U_ART_PR","W")
      return(.f.)
   ENDIF
   SELECT CUP_SCO_MI
   SKIP +1
ENDDO

SELECT CUR_FABBISOGNI
SET ORDER TO I_SCORMI
SET FILTER TO
GO TOP

RETURN


***************************************************************************
PROCEDURE generazione_ordforn_per_fabbisogni
***************************************************************************
WAIT WINDOWS "FABBISOGNI : " + CHR(13) + ;
             "Stň riepilogando i fabbisogni per la generazione dell'ordine a fornitore in automatico" NOWAIT

CREATE CURSOR CUR_FABBXORDIN(FAB_CODART C(16),   FAB_DESART C(50),  FAB_CODCOL C(03),   FAB_DESCOL C(30),   FAB_CODMAT C(03),   ;
                             FAB_DESMAT C(30),   FAB_SPESSO N(05),  FAB_ALTEZZ N(05),   FAB_LUNGHE N(15),   FAB_NUMBOB N(06),   ;
                             FAB_QTAMQ N(17,2),  FAB_QTAKG N(17,2), FAB_QTAML N(15),    FAB_CDDIBA C(16),   FAB_CILRET N(03),   ;
                             FAB_CODIMB C(03),   FAB_DESIMB C(50),  FAB_SCORMI N(17,2), FAB_LOTMIN N(17,2), FAB_UNITAM C(02),   ;
                             FAB_TIPART C(01),   FAB_CDFILM C(16),  FAB_DSFILM C(50),   FAB_LUNSTD N(06),   FAB_CODFOR C(10),   ;
                             FAB_DESFOR C(50),   FAB_PREZZO N(17,6), FAB_UMACQ C(03),   FAB_UMMAGA C(03),   FAB_VALORE N(17,2))
INDEX ON FAB_CDFILM+STR(FAB_ALTEZZ,5,0) 							TAG I_CDFILM ADDITIVE
INDEX ON FAB_TIPART+FAB_CDFILM+FAB_CODCOL+FAB_CODMAT+STR(FAB_SPESSO,5,0)+ ;
         STR(FAB_ALTEZZ,5,0)+FAB_CDDIBA+STR(FAB_CILRET,3,0) 		TAG I_FABBIS ADDITIVE

RELEASE __CALFABLUNSTD
PUBLIC  __CALFABLUNSTD
__CALFABLUNSTD = 'NO'

*=> Acquisizione del parametro che indica se le lunghezze da ordinare a fornitore devono essere ricalcolate in base
*=> alla tabella delle lunghezze std oppure ordinare effettivamente solo quelle necessarie
x_codi = "codice = 'GLF01'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __CALFABLUNSTD = 'NO'
ELSE
   __CALFABLUNSTD = SUBSTR(LIBERA,1,2)
ENDIF

*=> Gestione dei fabbisogni da ordinare a fornitore per il film nudo

SELECT CUR_FABBISOGNI
SET ORDER TO I_FABBIS
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> Elaborazione delle sole bobine
   V_TIPO = CERCATIPO(FAB_CODART)
   IF V_TIPO = "1"
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Ricerca in anagrafica articoli il primo record che corrisponde per :
   *=> - codice materiale
   *=> - spessore
   *=> - colore
   *=> - prodotto di acquisto

   V_TROV_MP = .F.

   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_mate = "art_codmat = '" + ALLTRIM(M.FAB_CODMAT) + "'"
   x_spes = "art_spesso = " + ALLTRIM(STR(M.FAB_SPESSO,5,0))
   x_colo = "art_codcol = '" + ALLTRIM(M.FAB_CODCOL) + "'"
   x_cond = x_soci + " and " + x_mate + " and " + x_spes + " and " + x_colo
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
   ELSE
      _V_CDFILM = ART_CODPRI
      _V_DSFILM = ART_DESCR
      _V_UMACQ  = ART_UNIMIS
      _V_UMMAGA = ART_UMMAGA
      _V_PREZZO = ART_PRZCOS
      IF !EMPTY(ALLTRIM(ART_CODF1))
         _V_CODFOR = ART_CODF1
      ELSE
         IF !EMPTY(ALLTRIM(ART_CODF2))
            _V_CODFOR = ART_CODF2
         ELSE
            IF !EMPTY(ALLTRIM(ART_CODF3))
               _V_CODFOR = ART_CODF3
            ELSE
               _V_CODFOR = SPACE(10)
            ENDIF
         ENDIF
      ENDIF
   ENDIF
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF ART_OBSOL = 'S'
         SKIP +1
         LOOP
      ENDIF
      IF ART_TIPART = 'A'
      ELSE
         SKIP +1
         LOOP
      ENDIF
      _V_CDFILM = ART_CODPRI
      _V_DSFILM = ART_DESCR
      _V_UMACQ  = ART_UNIMIS
      _V_UMMAGA = ART_UMMAGA
      _V_PREZZO = ART_PRZCOS
      IF !EMPTY(ALLTRIM(ART_CODF1))
         _V_CODFOR = ART_CODF1
      ELSE
         IF !EMPTY(ALLTRIM(ART_CODF2))
            _V_CODFOR = ART_CODF2
         ELSE
            IF !EMPTY(ALLTRIM(ART_CODF3))
               _V_CODFOR = ART_CODF3
            ELSE
               _V_CODFOR = SPACE(10)
            ENDIF
         ENDIF
      ENDIF
      V_TROV_MP = .T.
      EXIT
   ENDDO

   IF V_TROV_MP
   ELSE
      _V_CDFILM = M.FAB_CODART
      _V_DSFILM = M.FAB_DESART
      _V_UMACQ  = 'KG'
      _V_UMMAGA = 'MQ'
      _V_PREZZO = 0
      _V_CODFOR = SPACE(10)
   ENDIF

   *=> Ricerca della ragione sociale del fornitore
   x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "for_codcli = '" + ALLTRIM(_V_CODFOR) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
   IF !ExecCommand(cSql,"cur_fornitore")
      return(.f.)
   ENDIF
   SELECT cur_fornitore
   GO TOP
   IF EOF()
      _V_DESFOR = SPACE(50)
   ELSE
      _V_DESFOR = FOR_RAGSOC
   ENDIF

   *=> Ricerca nella tabella degli spessori compatibili le lunghezze std. da ordinare al fornitore per :
   *=> - codice materiale
   *=> - spessore

   IF __CALFABLUNSTD = 'NO'
      _V_LUNSTD = M.FAB_LUNGHE
   ELSE
      x_mate = "mic_codmat = '" + ALLTRIM(M.FAB_CODMAT) + "'"
      x_spes = "mic_speord = " + ALLTRIM(STR(M.FAB_SPESSO,5,0))
      x_cond = x_mate + " and " + x_spes
      Csql   = "select * from u_pro_my where " + x_cond
      IF !ExecCommand(cSql,"cur_lunghezzestd")
         return(.f.)
      ENDIF
      SELECT cur_lunghezzestd
      GO TOP
      IF EOF()
         _V_LUNSTD = 8000
      ELSE
         _V_LUNSTD = MIC_LUNORD
      ENDIF
   ENDIF

   *=> Aggiornamento cursore riepilogato per codice articolo

   SELECT CUR_FABBXORDIN
   SET ORDER TO I_CDFILM
   SEEK _V_CDFILM + STR(M.FAB_ALTEZZ,5,0)
   IF FOUND()
      REPLACE FAB_LUNGHE WITH FAB_LUNGHE + M.FAB_LUNGHE
      REPLACE FAB_QTAMQ  WITH FAB_QTAMQ  + M.FAB_QTAMQ
      REPLACE FAB_QTAKG  WITH FAB_QTAKG  + M.FAB_QTAKG
      REPLACE FAB_QTAML  WITH FAB_QTAML  + M.FAB_QTAML
   ELSE
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE FAB_CDFILM WITH _V_CDFILM
      REPLACE FAB_DSFILM WITH _V_DSFILM
      REPLACE FAB_LUNSTD WITH _V_LUNSTD
      REPLACE FAB_UMACQ  WITH _V_UMACQ
      REPLACE FAB_UMMAGA WITH _V_UMMAGA
      REPLACE FAB_PREZZO WITH _V_PREZZO
      REPLACE FAB_CODFOR WITH _V_CODFOR
      REPLACE FAB_DESFOR WITH _V_DESFOR
      REPLACE FAB_VALORE WITH 0
   ENDIF
   IF __CALFABLUNSTD = 'NO'
      REPLACE FAB_LUNSTD WITH FAB_LUNGHE
   ENDIF

   SELECT CUR_FABBISOGNI
   SKIP +1

ENDDO


*=> Gestione dei fabbisogni da ordinare a fornitore per gli adesivi

SELECT CUR_FABBISOGNI
SET ORDER TO I_FABBIS
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> Elaborazione dei soli adesivi
   IF FAB_CODMAT = '004'
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Ricerca in anagrafica articoli i dati necessari all'ordine a fornitore

   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_arti = "art_codpri = '" + ALLTRIM(M.FAB_CODART) + "'"
   x_cond = x_soci + " and " + x_arti
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
      SELECT CUR_FABBISOGNI
      SKIP +1
      LOOP
   ENDIF

   _V_CDFILM = ART_CODPRI
   _V_DSFILM = ART_DESCR
   _V_UMACQ  = ART_UNIMIS
   _V_UMMAGA = ART_UMMAGA
   _V_PREZZO = ART_PRZCOS
   _V_LOTMIN = ART_LOTMIN

   IF !EMPTY(ALLTRIM(ART_CODF1))
      _V_CODFOR = ART_CODF1
   ELSE
      IF !EMPTY(ALLTRIM(ART_CODF2))
         _V_CODFOR = ART_CODF2
      ELSE
         IF !EMPTY(ALLTRIM(ART_CODF3))
            _V_CODFOR = ART_CODF3
         ELSE
            _V_CODFOR = SPACE(10)
         ENDIF
      ENDIF
   ENDIF

   *=> Ricerca della ragione sociale del fornitore
   x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "for_codcli = '" + ALLTRIM(_V_CODFOR) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
   IF !ExecCommand(cSql,"cur_fornitore")
      return(.f.)
   ENDIF
   SELECT cur_fornitore
   GO TOP
   IF EOF()
      _V_DESFOR = SPACE(50)
   ELSE
      _V_DESFOR = FOR_RAGSOC
   ENDIF

   *=> Aggiornamento cursore riepilogato per codice articolo

   SELECT CUR_FABBXORDIN
   SET ORDER TO I_CDFILM
   SEEK _V_CDFILM + STR(M.FAB_ALTEZZ,5,0)
   IF FOUND()
      REPLACE FAB_QTAKG  WITH FAB_QTAKG  + M.FAB_QTAKG
   ELSE
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE FAB_CDFILM WITH _V_CDFILM
      REPLACE FAB_DSFILM WITH _V_DSFILM
      REPLACE FAB_LOTMIN WITH _V_LOTMIN
      REPLACE FAB_UMACQ  WITH _V_UMACQ
      REPLACE FAB_UMMAGA WITH _V_UMMAGA
      REPLACE FAB_PREZZO WITH _V_PREZZO
      REPLACE FAB_CODFOR WITH _V_CODFOR
      REPLACE FAB_DESFOR WITH _V_DESFOR
      REPLACE FAB_VALORE WITH 0
   ENDIF

   SELECT CUR_FABBISOGNI
   SKIP +1

ENDDO



*=> Determinazione delle quantitŕ minime per l'ordine a fornitore sapendo che il numero minimo delle bobine da
*=> ordinare č due (2)

SELECT CUR_FABBXORDIN
SET ORDER TO I_CDFILM
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> Elaborazione delle sole bobine
   V_TIPO = CERCATIPO(FAB_CODART)
   IF V_TIPO = "1"
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF FAB_LUNGHE > FAB_LUNSTD
      *=> Determinazione dell'ordine in base alle misure standard per il fornitore
      V_INTLUN = INT((FAB_LUNGHE / FAB_LUNSTD))
      V_ALLLUN = V_INTLUN * FAB_LUNSTD
      IF V_ALLLUN = FAB_LUNGHE
         V_NUMBOB = V_INTLUN
      ELSE
         V_NUMBOB = V_INTLUN + 1
      ENDIF
      V_INTBOB = INT((V_NUMBOB / 2))
      V_ALLBOB = V_INTBOB * 2
      IF V_ALLBOB = V_NUMBOB
      ELSE
         V_NUMBOB = V_NUMBOB + 1
      ENDIF
      REPLACE FAB_NUMBOB WITH V_NUMBOB
      REPLACE FAB_LUNGHE WITH FAB_LUNSTD
      REPLACE FAB_QTAML  WITH FAB_LUNSTD * FAB_NUMBOB
      REPLACE FAB_QTAMQ  WITH TROVA_MQ_DA_AL(FAB_ALTEZZ,FAB_LUNGHE,FAB_NUMBOB)
      REPLACE FAB_QTAKG  WITH TROVA_KG_DA_MQ(FAB_CDFILM,FAB_SPESSO,FAB_QTAMQ,1)
   ELSE
      *=> Determinazione dell'ordine minimo
      IF __CALFABLUNSTD = 'NO'
         REPLACE FAB_NUMBOB WITH 1
      ELSE
         REPLACE FAB_NUMBOB WITH 2
      ENDIF
      REPLACE FAB_LUNGHE WITH FAB_LUNSTD
      REPLACE FAB_QTAML  WITH FAB_LUNSTD * FAB_NUMBOB
      REPLACE FAB_QTAMQ  WITH TROVA_MQ_DA_AL(FAB_ALTEZZ,FAB_LUNGHE,FAB_NUMBOB)
      REPLACE FAB_QTAKG  WITH TROVA_KG_DA_MQ(FAB_CDFILM,FAB_SPESSO,FAB_QTAMQ,1)
   ENDIF

   *=> Ricerca dell'ultimo carico da fornitore
   x_arti = "ord_codart = '" + FAB_CDFILM + "'"
   x_cond = x_arti
   Csql   = "select top 1 * from u_bfo_dd where " + x_cond + " order by ors_datord desc"
   IF !ExecCommand(cSql,"cur_ddtfornitore")
      return(.f.)
   ENDIF
   SELECT cur_ddtfornitore
   GO TOP
   IF EOF()
   ELSE
      _V_CODFOR = ORS_CODCLI
      _V_DESFOR = ORS_RAGSOC
      _V_PREZZO = ORD_PRZNET
      SELECT CUR_FABBXORDIN
      REPLACE FAB_CODFOR WITH _V_CODFOR
      REPLACE FAB_DESFOR WITH _V_DESFOR
      REPLACE FAB_PREZZO WITH _V_PREZZO
   ENDIF

   SELECT CUR_FABBXORDIN

   IF FAB_UMACQ = 'KG'
      REPLACE FAB_VALORE WITH ROUND((FAB_QTAKG * FAB_PREZZO),2)
   ELSE
      REPLACE FAB_VALORE WITH ROUND((FAB_QTAMQ * FAB_PREZZO),2)
   ENDIF

   SELECT CUR_FABBXORDIN
   SKIP +1

ENDDO


*=> Determinazione delle quantitŕ minime per l'ordine a fornitore conoscendo il lotto minimo

SELECT CUR_FABBXORDIN
SET ORDER TO I_CDFILM
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> Elaborazione dei soli adesivi
   IF FAB_CODMAT = '004'
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF FAB_QTAKG > FAB_LOTMIN
      *=> Determinazione dell'ordine in base ai lotti minimi
      IF FAB_LOTMIN = 0
         REPLACE FAB_LOTMIN WITH FAB_QTAKG
      ENDIF
      V_INTLUN = INT((FAB_QTAKG / FAB_LOTMIN))
      V_ALLLUN = V_INTLUN * FAB_LOTMIN
      IF V_ALLLUN = FAB_QTAKG
         V_NUMBOB = V_INTLUN
      ELSE
         V_NUMBOB = V_INTLUN + 1
      ENDIF
      REPLACE FAB_NUMBOB WITH V_NUMBOB
      REPLACE FAB_QTAKG  WITH ROUND((FAB_LOTMIN * FAB_NUMBOB),2)
   ELSE
      *=> Determinazione dell'ordine minimo
      REPLACE FAB_NUMBOB WITH 1
      REPLACE FAB_QTAKG  WITH ROUND((FAB_LOTMIN * FAB_NUMBOB),2)
