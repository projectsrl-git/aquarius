******************
PROCEDURE INTEMAG2
******************

**--> GENERAZIONE CURSORE PER ORDINI DA FORNITORI

**--> CREAZIONE STRUTTURA TABELLA ORDINI A FORNITORI
CREATE CURSOR TABORDF (STA_CODMAG C(06),   STA_DESMAG C(40), ;
                       STA_NUMERO C(06),   STA_DATA C(10),   ;
                       STA_QUANTI N(11,2), STA_CODICE C(10), ;
                       STA_RAGSOC C(40),   STA_DATCON C(10), ;
                       STA_SPESSO N(5,0),  STA_ALTEZZ N(5,0),;
                       STA_LUNGHE N(6,0))

SELECT TABORDF
GO TOP

IF _V_CODMAG = SPACE(06)
   x_codi = "ord_codart = '" + ALLTRIM(_V_CODART) + "'"
   x_cond = x_codi
   Csql   = "select * from u_orf_dd where " + x_cond + " order by ord_codart,ord_maga,ors_datord"
ELSE
   x_codi = "ord_codart = '" + ALLTRIM(_V_CODART) + "'"
   x_maga = "ord_maga = '" + ALLTRIM(_V_CODMAG) + "'"
   x_cond = x_codi + " and " + x_maga
   Csql   = "select * from u_orf_dd where " + x_cond + " order by ord_codart,ord_maga,ors_datord"
ENDIF
IF !ExecCommand(cSql,"cur_ordfor_dd")
   return(.f.)
ENDIF

SELECT CUR_ORDFOR_DD
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF ORD_CODART = _V_CODART
   ELSE
      EXIT
   ENDIF

   IF _V_CODMAG = SPACE(06)
   ELSE
      IF ORD_MAGA = _V_CODMAG
      ELSE
         EXIT
      ENDIF
   ENDIF

   IF ORD_CHIUSO = .T.
      SKIP +1
      LOOP
   ENDIF

   IF ORD_SALCON = 'S'
      SKIP +1
      LOOP
   ENDIF

   IF ORD_DATCON => RIBALTA2(_V_DATADA)
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF ORD_DATCON <= RIBALTA2(_V_DATAAL)
   ELSE
      SKIP +1
      LOOP
   ENDIF

   V_CODMAG = ORD_MAGA
   V_QUANTI = ORD_QTAORD - ORD_QTAEV
   V_DATCON = RIBALTA2(ORD_DATCON)
   V_NUMERO = ORS_NUMORD
   V_DATA   = ORS_DATORD
   V_CODICE = ORS_CODCLI
   V_RAGSOC = ORS_RAGSOC
   V_SPESSO = ORD_SPESSO
   V_ALTEZZ = ORD_ALTEZZ
   V_LUNGHE = ORD_LUNGHE

   IF V_QUANTI > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   v_seek	= 'MAG'+V_CODMAG
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      V_DESMAG = DESCRI
   ELSE
      V_DESMAG = SPACE(40)
   ENDIF

   SELECT TABORDF
   APPEND BLANK
   REPLACE STA_CODMAG WITH V_CODMAG
   REPLACE STA_DESMAG WITH V_DESMAG
   REPLACE STA_NUMERO WITH V_NUMERO
   REPLACE STA_DATA   WITH V_DATA
   REPLACE STA_QUANTI WITH V_QUANTI
   REPLACE STA_CODICE WITH V_CODICE
   REPLACE STA_RAGSOC WITH V_RAGSOC
   REPLACE STA_DATCON WITH V_DATCON
   REPLACE STA_SPESSO WITH V_SPESSO
   REPLACE STA_ALTEZZ WITH V_ALTEZZ
   REPLACE STA_LUNGHE WITH V_LUNGHE

   _V_ORDFOR = _V_ORDFOR + V_QUANTI

   SELECT CUR_ORDFOR_DD
   SKIP +1

ENDDO

RETURN



