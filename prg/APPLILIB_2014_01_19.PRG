******************************
FUNCTION TXT_SCONTI
******************************
* CREA TESTO CON SCONTO TOTALE MERCE

PARA _TIPON,_CURSORE,_TIP_TXT,_TXT,_XVAL


SELECT &_CURSORE
_REC_ = RECNO()

GO TOP
_TVAL = 0
_MATP = 0
TOTALE_VALORE_NETTO = 0
TOTALE_VALORE_LORDO = 0


DO WHILE .NOT.EOF()

   IF DELETED()
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF

   IF ORD_PUBBLI = "S"
	  _MATP = _MATP + ORD_VALORE
   ENDIF

   TOTALE_VALORE_NETTO = TOTALE_VALORE_NETTO  + ROUND((ORD_PRZNET*ORD_QTAORD),2)
   TOTALE_VALORE_LORDO = TOTALE_VALORE_LORDO  + ROUND((ORD_PREZZO*ORD_QTAORD),2)


   SELECT &_CURSORE
   SKIP +1

ENDDO

SELECT &_CURSORE
GO TOP



TOTALE_VALORE_NETTO = TOTALE_VALORE_NETTO  - _MATP
TOTALE_VALORE_LORDO = TOTALE_VALORE_LORDO  - _MATP

_TVAL = TOTALE_VALORE_LORDO - TOTALE_VALORE_NETTO

IF _TVAL > 0
ELSE
   _TXT = ""
   RETURN(_TXT)		&& NSSUNA OPERAZIONE SUL TESTO
ENDIF

IF _XVAL  = "ITL" .OR.  _XVAL  = "LIT"			&& ARROTONDAMENTO
   _TVAL	=	ROUND(_TVAL,0)
ELSE
   _TVAL	=	ROUND(_TVAL,2)
ENDIF

* INSERISCE NEL TESTO IL VALORE DELLO SCONTO CALCOLATO


M.ORD_VALCO  = _TVAL

IF _XVAL = "ITL" .OR. _XVAL = "LIT"
   _TXT = STRTRAN(_TXT,".TOTSCONTO",ALLTRIM(STR(M.ORD_VALCO,15,0)))
ELSE
   _TXT = STRTRAN(_TXT,".TOTSCONTO",ALLTRIM(STR(M.ORD_VALCO,15,2)))
ENDIF

RETURN(_TXT)


******************************
FUNCTION TXT_TT
******************************
* CREA TESTO CON TOTALE MERCE

PARA _TIPON,_CURSORE,_TIP_TXT,_TXT,_XVAL



SELECT &_CURSORE
_REC_ = RECNO()

GO TOP
_TVAL = 0
_MATP = 0

DO WHILE .NOT.EOF()

   IF DELETED()
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
	  SELECT &_CURSORE
	  SKIP +1
	  LOOP
   ENDIF

   IF ORD_PUBBLI = "S"
	  _MATP = _MATP + ORD_VALORE
   ENDIF

   _TVAL = _TVAL + ORD_VALORE

   SELECT &_CURSORE
   SKIP +1

ENDDO

SELECT &_CURSORE
*!*	GO _REC_
GO TOP


_TVAL = _TVAL - _MATP							&& TOTALE MERCE

IF _XVAL  = "ITL" .OR.  _XVAL  = "LIT"			&& ARROTONDAMENTO
   _TVAL	=	ROUND(_TVAL,0)
ELSE
   _TVAL	=	ROUND(_TVAL,2)
ENDIF

* INSERISCE NEL TESTO IL VALORE CALCOLATO / IMPORTO CALCOLATO


M.ORD_VALCO  = _TVAL

IF _XVAL = "ITL" .OR. _XVAL = "LIT"
   _TXT = STRTRAN(_TXT,".TOTMERCE",ALLTRIM(STR(M.ORD_VALCO,15,0)))
ELSE
   _TXT = STRTRAN(_TXT,".TOTMERCE",ALLTRIM(STR(M.ORD_VALCO,15,2)))
ENDIF

RETURN(_TXT)



