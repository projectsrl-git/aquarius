   ENDIF

   RELEASE WWW_LEGAME,WWW_CODSYS,WWW_CODART,WWW_CODMAG,WWW_DATCON
   PUBLIC  WWW_LEGAME,WWW_CODSYS,WWW_CODART,WWW_CODMAG,WWW_DATCON
