   **==>> RICHIAMA LA FUNZIONE PER GESTIRE I SALDI DEI MOVIMENTI PER ANNO/MESE, MAGAZZINO ED ARTICOLO
   M.MOV_SEGNO = _SEGNO
   DO GESTIONE_SALDI_MOV

