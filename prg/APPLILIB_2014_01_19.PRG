   VPRE = VPRE-ROUND((VPRE*ORD_SC2/100),6)
   VPRE = VPRE-ROUND((VPRE*ORD_SC3/100),6)
   REPLACE ORD_PRZNET WITH VPRE
   REPLACE ORD_PRZNET WITH ROUND(ORD_PRZNET,6)
   REPLACE ORD_VALORE WITH ROUND((ORD_PRZNET * ORD_QTAORD),2)
  * REPLACE ORD_SEQUEN WITH M.ORD_SEQUEN + 10
   REPLACE ORD_SEQUEN WITH M.ORD_SEQUEN + 800
   REPLACE ORD_CODSYS WITH SYS(2015)
   REPLACE ORD_FLGMOD WITH 'I'
   REPLACE ORS_CODCLI WITH M.ORD_CODCLI
   REPLACE ORS_RAGSOC WITH M.ORD_RAGSOC
   REPLACE ORS_NUMORD WITH M.ORD_NUMORD
   IF SUBSTR(M.ORD_DATORD,3,1) = '/'
      REPLACE ORS_DATORD WITH RIBALTA2(M.ORD_DATORD)
   ELSE
      REPLACE ORS_DATORD WITH M.ORD_DATORD
   ENDIF

   SELECT TAB_POLIECO
   SKIP +1

ENDDO

*=> By-passa i record di polieco appena creati per la fattura in esame
SELECT &_TIPOARC
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DAGGANCIO = V_AGGANCIO
      SKIP +1
      LOOP
   ENDIF
