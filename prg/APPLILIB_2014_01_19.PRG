IF !EMPTY(_par_codfor)
	x_forn = "ORS_CODCLI = '" + _par_codfor + "'"
	x_codi = "ORD_CODART = '" + _par_codart + "'"
	x_cond = x_forn + " and " + x_codi
	Csql   = "select TOP 1 ORS_NUMORD,ORS_DATORD,ORD_PREZZO from U_BFO_DD where " + x_cond + " order by ORS_DATORD DESC"
	IF !ExecCommand(cSql,"TMP_BFO_DD")
	   return(.f.)
	ENDIF
	SELECT TMP_BFO_DD
	GO TOP
	IF !EOF()
		_rit = ORD_PREZZO
	ENDIF
ENDIF

*** CERCO IL PREZZO DI COSTO DI QUESTO ARTICOLO IN ANAGRAFICA
IF _rit = 0
	x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
	x_codi = "ART_CODPRI = '" + _par_codart + "'"
	x_cond = x_soci + " and " + x_codi
	Csql   = "select ART_PRZCOS, ART_CODF1, ART_PRZCO1, ART_CODF2, ART_PRZCO2, ART_CODF3, ART_PRZCO3, ART_CODF4, ART_PRZCO4, ART_CODF5, ART_PRZCO5 " + ;
	         "from U_ART_PR where " + x_cond
	IF !ExecCommand(cSql,"TMP_ART_PR")
	   return(.f.)
	ENDIF
	SELECT TMP_ART_PR
	GO TOP
	IF !EOF()
		_rit = ART_PRZCOS
		IF !EMPTY(_par_codfor)
			IF ALLTRIM(_par_codfor) == ALLTRIM(ART_CODF1)
				_rit = ART_PRZCO1
			ENDIF
			IF ALLTRIM(_par_codfor) == ALLTRIM(ART_CODF2)
				_rit = ART_PRZCO2
			ENDIF
			IF ALLTRIM(_par_codfor) == ALLTRIM(ART_CODF3)
				_rit = ART_PRZCO3
			ENDIF
			IF ALLTRIM(_par_codfor) == ALLTRIM(ART_CODF4)
				_rit = ART_PRZCO4
			ENDIF
			IF ALLTRIM(_par_codfor) == ALLTRIM(ART_CODF5)
				_rit = ART_PRZCO5
			ENDIF
		ENDIF
	ENDIF
ENDIF

SELECT(WW)

RETURN _rit


