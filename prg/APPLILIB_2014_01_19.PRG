      REPLACE AVA_DATAVA WITH SPACE(10)
      REPLACE AVA_AMGAVA WITH SPACE(10)
      REPLACE AVA_ORAAVA WITH SPACE(08)
      REPLACE AVA_CONMTL WITH 0
   ENDIF

   SELECT CUR_SALAMESCOLE
   SKIP +1

ENDDO

*=> INIZIO - GESTIONE DELLA PROGRAMMAZIONE SOLO NELLE SETTIMANE PREVISTE
IF V_PROGRE = 1
   *=> ACCESSO AL CALENDARIO LAVORATIVO GENERALE PER PRELEVARE LA SETTIMANA DI INIZIO LAVORO
   x_data = "cal_data = '" + V_DTINI + "'"
   Csql   = "select * from u_cal_la where " + x_data
   IF !ExecCommand(Csql,"cux_cal_la")
      return(.f.)
   ENDIF
   SELECT CUX_CAL_LA
   GO TOP
   IF EOF()
      VVV_SETINI = _V_SPRGDA
   ELSE
      VVV_SETINI = CAL_SETT
   ENDIF
   VVV_NUMSET = VAL(SUBSTR(VVV_SETINI,1,2)) + V_SETIMP - 1
   VVV_NUMANN = VAL(SUBSTR(VVV_SETINI,4,4))
   IF VVV_NUMSET > 52
      VVV_NUMSET = VVV_NUMSET - 52
      VVV_NUMANN = VVV_NUMANN + 1
   ENDIF
   VVV_NUMSEX = ALLTRIM(STR(VVV_NUMSET,2,0))
   IF VVV_NUMSET > 9
   ELSE
      VVV_NUMSEX = '0' + VVV_NUMSEX
   ENDIF
   VVV_SETTIM = VVV_NUMSEX + '/' + ALLTRIM(STR(VVV_NUMANN,4,0))
ENDIF
*=> ACCESSO AL CALENDARIO LAVORATIVO GENERALE PER PRELEVARE LA SETTIMANA DI FINE LAVORO
x_data = "cal_data = '" + V_DTFIN + "'"
Csql   = "select * from u_cal_la where " + x_data
IF !ExecCommand(Csql,"cux_cal_la")
   return(.f.)
ENDIF
SELECT CUX_CAL_LA
GO TOP
IF EOF()
   VVV_SETFIN = _V_SPRGAL
ELSE
   VVV_SETFIN = CAL_SETT
ENDIF
*=> DETERMINAZIONE DELLE SETTIMANE ELABORATE
IF VAL(SUBSTR(VVV_SETFIN,4,4)) = VAL(SUBSTR(VVV_SETINI,4,4))
   VVV_SETDIF = VAL(SUBSTR(VVV_SETFIN,1,2)) - VAL(SUBSTR(VVV_SETINI,1,2)) + 1
ELSE
   VVV_SETDIF = 53 - VAL(SUBSTR(VVV_SETINI,1,2)) + VAL(SUBSTR(VVV_SETINI,1,2))
ENDIF
IF VVV_SETDIF < V_SETIMP
ELSE
   VVV_VERIFICA = .T.
ENDIF
*=> FINE - GESTIONE DELLA PROGRAMMAZIONE SOLO NELLE SETTIMANE PREVISTE

RETURN


