	MESSAGEBOX("Codice Articolo da ri-macinare '" + ALLTRIM(_par_anaart) + "' inesistente" + REPLICATE(CHR(13),2) + ;
		"Provvedere alla corretta configurazione in anagrafica articoli e riciclare successivamente",48,"Attenzione")
	RETURN .F.
