ENDIF

SWS=SELECT()

**=> ERASMO - INIZIO 28/09/2009
*** INIZIALIZZAZIONE FLAG DI CONTROLLO CHE RESTITUISCE .T.
*** SE ESISTONO RIGHE BOLLE SENZA RIGHE ORDINI LEGATI
RELEASE __CHK_ORDBOL
PUBLIC  __CHK_ORDBOL
__CHK_ORDBOL = .F.
**=> ERASMO - FINE 28/09/2009

_RIT = _OLDQTA
*** CERCO LA QUANTITA' EFFETTIVAMENTE EVASA SULLE RIGHE BOLLE LEGATE
x_lsys = "ord_legsys = '" + _LEGSYS + "'"
