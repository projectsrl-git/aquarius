   IF !EOF()
      X_RIPCOM     = ART_RIPCOM
      M.ORD_DESART = ART_DESCR
      M.ORD_DES2   = ART_DESEST
      M.ORD_IVA    = ART_CODIVA
   ENDIF

   IF X_RIPCOM = 'S'
   ELSE
      SELECT WEXPLODE
      SKIP +1
      LOOP
   ENDIF

   M.ORD_QTAORD = M.WQTALL
   M.ORD_VALORE = M.ORD_PRZNET * M.ORD_QTAORD
   M.DAGGANCIO  = X_UNCINO
   M.ORS_NUMORD = X_NUMORD
   M.ORS_DATORD = RIBALTA2(DTOC(DATE()))
   M.ORD_QTAEV  = 0
   M.ORD_QTADEV = 0
   M.ORD_CHIUSO = .F.
   M.ORD_FLGSCP = .T.

   * AGGIORNA I DETTAGLI
   SELECT CUR_BOL_DD
   APPEND BLANK
   GATHER MEMVAR MEMO

   SELECT CU_BOL_DD
   APPEND BLANK
   GATHER MEMVAR MEMO

   CIVA = X_CODIVA

   v_seek	= 'IVA' + CIVA
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      VIVA = VAL(SUBSTR(LIBERA,1,3))
   ELSE
      VIVA = 0
   ENDIF

   SELECT U_BOL_DD

   IF ORD_PUBBLI = "S"
      MATPUBX = MATPUBX + ORD_VALORE
   ENDIF

   M.T_IMPONIB = M.T_IMPONIB + ORD_VALORE
   M.T_IMPOSTA = M.T_IMPOSTA + (ORD_VALORE * (VIVA/100))

   SELECT WEXPLODE
   SKIP +1

ENDDO

SELECT &SS1

RETURN(OUT)


