******************************************************************************************************
PROCEDURE MAG_AGGIORNA_IMPEGNATO  && AGGIORNAMENTO MAGAZZINO IN FASE DI AGGIORNAMENTO DA PAKING LIST
******************************************************************************************************

PARAMETERS _CURSORE,_TABELLA,_SEGNO,_DADOVE

*==> ACCESSO ALLA TABELLA SQL SUL RECORD LEGATO AL CURSORE



x_agga = "daggancio = '" + M.DAGGANCIO + "'"
x_maga = "ord_maga = ord_maga "
x_lega = "ord_legsys = '" + ALLTRIM(M.ORD_LEGSYS) + "'"
x_cond = x_agga + " and " + x_maga + " and " + x_lega
cSql   = "SELECT * FROM " + ALLTRIM(_TABELLA) + " WHERE " + x_cond
IF !ExecCommand(cSql,"&_TABELLA")
   return(.f.)
ENDIF
SELECT &_TABELLA				&& DETTAGLI ARTICOLI ORIGINALI
GO TOP
IF EOF()
   RETURN
ENDIF


XXX_QTAEVA = ORD_QTAORD

RELEASE U_AGGORF,U_SYSORF,U_CODORF,U_NUMPED,U_DATPED,U_NUMDDT,U_DATDDT,U_CODCLI
PUBLIC  U_AGGORF,U_SYSORF,U_CODORF,U_NUMPED,U_DATPED,U_NUMDDT,U_DATDDT,U_CODCLI
U_AGGORF = ORD_LEGAME
IF _TABELLA = "U_PCK_DD"
   U_SYSORF = SPACE(10)
ELSE
   U_SYSORF = ORD_LEGASY
ENDIF
U_AGGANC = DAGGANCIO
U_CODORF = ""
U_NUMPED = 0
U_DATPED = SPACE(10)
U_NUMDDT = SPACE(06)
U_DATDDT = SPACE(10)
U_CODCLI = SPACE(10)
IF _TABELLA = "U_PCK_DD"
   U_NUMPED = ORD_NUMPED
   U_DATPED = ORD_DATPED
   U_NUMDDT = ORS_NUMORD
   U_DATDDT = ORS_DATORD
   U_CODCLI = ORS_CODCLI
ENDIF

*==> GESTIONE DEL CASO DI MODIFICA FATTA DALL'UTENTE :
*==> - SE E' STATA MODIFICATA LA SEQUENZA (NUMERO DI RIGA), VIENE ALZATO UN FLAG CHE INDICHERA'
*==>   ALLA FUNZIONE DI CANCELLAZIONE DEI RECORD DI TABELLA CHE DEVE CANCELLARLI TUTTI PERCHE'
*==>   POI VERRANNO REINSERITI CON LA NUOVA SEQUENZA.
*==> - VIENE AGGIORNATO IL RECORD DELLA TABELLA SQL (TRANNE LA SEQUENZA)
*==> - SE NON E' STATO MODIFICATO ALCUN CAMPO "CHIAVE", NON FA NIENTE, ALTRIMENTI VA AVANTI
*==>   PER CONTRAGGIORNARE GLI ARCHIVI DI MAGAZZINO

U_QTA    = ORD_QTAORD							&& QUANTITA' ORIGINALE DELLA TABELLA
U_LEGAME = ORD_LEGAME
U_CODSYS = ORD_CODSYS

IF M.ORD_FLGMOD = 'M'
   U_ESCI = .F.
   IF ORD_SEQUEN = M.ORD_SEQUEN
   ELSE
      U_CANCELLA = .T.
   ENDIF
   IF ORD_CODART = M.ORD_CODART .AND. ;			&& CONFRONTA LE VARIABILI DEL DETTAGLIO ORIGINALE CON LE
      ORD_MAGA   = M.ORD_MAGA   .AND. ;			&& VARIABILI M. DEL CURSORE CHE STA' AGGIORNANDO
      ORD_QTAORD = M.ORD_QTAORD .AND. ;
      ORD_PRZNET = M.ORD_PRZNET .AND. ;
      ORD_IVA 	 = M.ORD_IVA
      U_ESCI = .T.
   ENDIF

   IF U_CANCELLA
   ELSE
      IF !ExecRW(cSql,"&_TABELLA","R")
         return(.f.)
      ENDIF
      SELECT &_TABELLA
      M.ORD_SEQUEN = ORD_SEQUEN
      M.ORD_FLGMOD = SPACE(01)
      DO &_TABELLA
      IF !ExecRW(cSql,"&_TABELLA","W")			&& AGGIORNA I DETTAGLI ORIGINALI CON I DATI DI DETTAGLIO DEL CURSORE
         return(.f.)
      ENDIF
   ENDIF

   IF U_ESCI
      x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
      x_codi = "art_codpri = '" + ALLTRIM(M.ORD_CODART) + "'"
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_art_pr where " + x_cond
      IF !ExecCommand(cSql,"cur_articoli")
         return(.f.)
      ENDIF
      SELECT cur_articoli
      GO TOP
      IF EOF()
         _CODMAT = '001'
      ELSE
         _CODMAT = ART_CODMAT
      ENDIF
      x_codi = "codice = 'MAT" + _CODMAT + "'"
      Csql   = "select * from para where " + x_codi
      IF !ExecCommand(cSql,"cur_para")
         return(.f.)
      ENDIF
      SELECT cur_para
      GO TOP
      IF EOF()
         V_TIPO = '0'
      ELSE
         V_TIPO = SUBSTR(LIBERA,1,1)
      ENDIF
      IF V_TIPO = '1' .OR. V_TIPO = '2'
      ELSE
         RETURN
      ENDIF
   ENDIF
ENDIF

*==> GESTIONE DEL CASO DI CANCELLAZIONE FATTA DALL'UTENTE :
*==> - VIENE CANCELLATO IL RECORD SULLA TABELLA SQL

IF M.ORD_FLGMOD = 'A'
   IF !ExecRW(cSql,"&_TABELLA","R")
      return(.f.)
   ENDIF
   SELECT &_TABELLA
   DELETE
   IF !ExecRW(cSql,"&_TABELLA","W")				&& CANCELLA LA RIGA ORIGINALE
      return(.f.)
   ENDIF
ENDIF

* PROJECT VERIFICARE SE IL PUNTO DI AGGIORNAMENTO č CORRETTO :
* considera le variabili del cursore in aggiornamento E LA QUANTITA' ORIGINALE PRIMA DEGLI AGGIORNAMENTI DELL'UTENTE
* OPERAZIONE FATTA PER LE MODIFICHE E GLI INSERIMENTI ???????

IF M.ORD_FLGMOD = 'A'
     =MAG_GESTIONE_IMPEGNATO(_CURSORE,_TABELLA,"-",_DADOVE,U_QTA) 		 && SE ANNULLO SCARICA IMPEGNATO CON LA QTA DELLA TABELLA SQL ORIGINALE
ELSE	
     =MAG_GESTIONE_IMPEGNATO(_CURSORE,_TABELLA,"-",_DADOVE,U_QTA) 		 && SCARICA IMPEGNATO CON LA QTA DELLA TABELLA SQL ORIGINALE
     =MAG_GESTIONE_IMPEGNATO(_CURSORE,_TABELLA,"+",_DADOVE,M.ORD_QTAORD) && CARICA IMPEGNATO CON LA QTA DEL CURSORE IN AGGIORNAMENTO
ENDIF



RETURN


**********************************************************************************
FUNCTION MAG_GESTIONE_IMPEGNATO
**********************************************************************************
*	SE ARTICOLO FISCALE GESTISCE U_MAG_GG
*	PER TUTTI GLI ARTICOLI GESTISCE U_MAG_AN

PARAMETERS _CURSORE,_TABELLA,_SEGNO,_DADOVE,_QTAIMP

    IF ALLTRIM(_ART_SERIE) = "ZI"	
		=GESTIONE_QTA_IMPEGNATA_PER_ARTICOLO_MAGAZZINO_FORNITORE_DI_CARICO(_CURSORE,_TABELLA,_SEGNO,_DADOVE,_QTAIMP) && GESTIONE U_MAG_GG
	ENDIF

	=GESTIONE_QTA_IMPEGNATA_PER_ARTICOLO_MAGAZZINO_SU_U_MAG_AN(_CURSORE,_TABELLA,_SEGNO,_DADOVE,_QTAIMP) && GESTIONE U_MAG_AN
	
RETURN

**********************************************************************************
FUNCTION GESTIONE_QTA_IMPEGNATA_PER_ARTICOLO_MAGAZZINO_FORNITORE_DI_CARICO
**********************************************************************************
PARAMETERS _CURSORE,_TABELLA,_SEGNO,_DADOVE,_QTAIMP

   *=> Vengono gestite le giacenze con data a spazi (record riepilogato) solo se attivo il parametro aziendale
   IF PUB_GGDTSP
	   x_soci   = "mag_codsoc = '" + PUB_CODSOC + "'"
	   x_data   = "mag_datagg = '" + SPACE(10) + "'"
	   x_codi   = "mag_codart = '" + ALLTRIM(M.ORD_CODART) + "'"
	   x_maga   = "mag_codmag = '" + ALLTRIM(M.ORD_MAGA) + "'"
	   x_forn   = "mag_fornit = '" + ALLTRIM(M.ORD_FORNIT) + "'"
	   x_cpdv   = "mag_codpdv = '" + SPACE(10) + "'"

	   x_cond = x_soci + " and " + x_data + " and " + x_codi + " and " + x_maga + " and " + x_forn
	   Csql     = "select * from u_mag_gg where " + x_cond + " order by mag_codsoc,mag_datagg,mag_codart,mag_codmag,mag_fornit"
	   IF !ExecRW(cSql,"U_MAG_GG","R")
	      return(.f.)
	   ENDIF

	   SELECT U_MAG_GG
	   IF RECCOUNT() <> 0
	      IF _SEGNO = '+'
	         REPLACE MAG_QTAIMP WITH MAG_QTAIMP + _QTAIMP
	      ELSE
	         REPLACE MAG_QTAIMP WITH MAG_QTAIMP - _QTAIMP
	      ENDIF
	   ELSE
	      APPEND BLANK
	      REPLACE MAG_CODSOC WITH PUB_CODSOC
	      REPLACE MAG_DATAGG WITH SPACE(10)
	      REPLACE MAG_CODMAG WITH M.ORD_MAGA
	      REPLACE MAG_CODART WITH M.ORD_CODART
	      REPLACE MAG_DESART WITH M.ORD_DESART
	      REPLACE MAG_CODPDV WITH SPACE(10)				&& PROJECT
	      REPLACE MAG_FORNIT WITH M.ORD_FORNIT
	      REPLACE MAG_DESFOR WITH SPACE(30)				&& PROJECT
	      IF _SEGNO = '+'
	         REPLACE MAG_QTAIMP WITH _QTAIMP
	      ELSE
	         REPLACE MAG_QTAIMP WITH _QTAIMP * -1
	      ENDIF
	      REPLACE MAG_PRZCON WITH 0
	      REPLACE MAG_UNIQUE WITH SYS(2015)
	      REPLACE MAG_CODMAT WITH M.ORD_CODMAT
	      REPLACE MAG_DESMAT WITH M.ORD_DESMAT
	      REPLACE MAG_CODCOL WITH M.ORD_CODCOL
	      REPLACE MAG_DESCOL WITH M.ORD_DESCOL
	      REPLACE MAG_SPESSO WITH M.ORD_SPESSO
	      REPLACE MAG_ALTEZZ WITH M.ORD_ALTEZZ
	      REPLACE MAG_LUNGHE WITH M.ORD_LUNGHE
	
	*!*	      REPLACE MAG_NRLINT WITH M.ORD_NRLINT	&& PROJECT
	*!*	      REPLACE MAG_ANAART WITH M.ORD_ANAART	&& PROJECT
	*!*	      REPLACE MAG_TIPART WITH M.ORD_TIPART	&& PROJECT

	   ENDIF

       IF MAG_QTAIMP < 0
          REPLACE MAG_QTAIMP WITH 0
       ENDIF
	
	   REPLACE MAG_FLGTRA WITH .F.
	   REPLACE MAG_FLGVIA WITH .F.

       IF MAG_NRLINT > 50000000
          REPLACE MAG_FLGRIB WITH .T.
       ENDIF

	   IF !ExecRw(cSql,"U_MAG_GG","W")
	      return(.f.)
	   ENDIF
   ENDIF



RETURN

**********************************************************************************
FUNCTION GESTIONE_QTA_IMPEGNATA_PER_ARTICOLO_MAGAZZINO_SU_U_MAG_AN
**********************************************************************************
PARAMETERS _CURSORE,_TABELLA,_SEGNO,_DADOVE,_QTAIMP

x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
x_maga = "mag_codmag = '" + ALLTRIM(M.ORD_MAGA) + "'"
x_codi = "mag_codart = '" + ALLTRIM(M.ORD_CODART) + "'"
x_cond = x_soci + " and " + x_maga + " and " + x_codi
Csql   = "select * from u_mag_an where " + x_cond + " order by mag_codsoc,mag_codmag,mag_codart"
IF !ExecRW(cSql,"U_MAG_AN","R")
   return(.f.)
ENDIF
SELECT U_MAG_AN
IF RECCOUNT() <> 0
   IF _SEGNO = '+'
      REPLACE MAG_QTAIMP WITH MAG_QTAIMP + _QTAIMP
   ELSE
      REPLACE MAG_QTAIMP WITH MAG_QTAIMP - _QTAIMP
   ENDIF
   REPLACE MAG_COSTO  WITH M.ORD_PRZCON
ELSE

   APPEND BLANK

   REPLACE MAG_CODSOC WITH PUB_CODSOC
   REPLACE MAG_CODMAG WITH M.ORD_MAGA
   REPLACE MAG_CODART WITH M.ORD_CODART
   REPLACE MAG_DESART WITH M.ORD_DESART

   IF _SEGNO = '+'
      REPLACE MAG_QTAIMP WITH MAG_QTAIMP + _QTAIMP
   ELSE
      REPLACE MAG_QTAIMP WITH MAG_QTAIMP - _QTAIMP
   ENDIF

   REPLACE MAG_CODFOR WITH M.ORD_FORNIT
   REPLACE MAG_CODCOL WITH M.ORD_CODCOL
   REPLACE MAG_DESCOL WITH M.ORD_DESCOL
   REPLACE MAG_UNIMIS WITH M.ORD_UM
   REPLACE MAG_DTCREA WITH RIBALTA2(DTOC(DATE()))
   REPLACE MAG_CODPDV WITH m.ord_codbun
   REPLACE MAG_CODTAG WITH M.ORD_CODCOL
   REPLACE MAG_DESTAG WITH M.ORD_DESTAG
   REPLACE MAG_COSTO  WITH M.ORD_PRZCON
   REPLACE MAG_UNIQUE WITH SYS(2015)
ENDIF

IF MAG_QTAIMP < 0
   REPLACE MAG_QTAIMP WITH 0
ENDIF

REPLACE MAG_FLGTRA WITH .F.

SCATTER MEMVAR MEMO
IF !ExecRW(cSql,"U_MAG_AN","W")
   return(.f.)
ENDIF

RETURN

