A_UNIMIS = SPACE(02)
A_PRZCOS = 0
A_PRZVEN = 0
A_CODIVA = SPACE(03)
A_CODTAG = SPACE(03)
A_DESTAG = SPACE(30)
A_CODCOL = SPACE(03)
A_DESCOL = SPACE(30)
A_COORD  = SPACE(30)

