			** ACCESSO ALLA TABELLA TIG (GREZZO) PER PRELEVARE IL GRUPPO PRODUTTIVO
			__GRUPPO_PRO = seek_para('TIG',ALLTRIM(__TIPO_PRODOTTO),'CODICE','CODICE',"4,3")
		    SELECT _pj_para
