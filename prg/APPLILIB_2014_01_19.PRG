************************************************************************************************
PROCEDURE PKGRIPIMP  && Funzione di ripristino impegni con vecchi records modificati o annullati	
************************************************************************************************

*=> L'obbiettivo di questa funzione č quello di ripristinare gli archivi (giacenze e ordini)
*=> - stornando nella riga d'ordine dalla quantitŕ in pkg il totale della quantitŕ impegnanta
*=> - disimpegnando dalle giacenze le quantitŕ ancora impegnate (solo le righe non a saldo)

SELECT CU_PKG_TD
SET FILTER TO
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   *=> Prendo in considerazione solo le righe modificate o annullate
   IF PKG_FLGMOD = 'A' .OR. PKG_FLGMOD = 'M'
   ELSE
      SKIP +1
      LOOP
   ENDIF

   __V_FLGMOD = PKG_FLGMOD

   *=> Leggo in aggiornamento la riga di testata da aggiornare
   x_cond = "pkg_codsys = '" + PKG_CODSYS + "'"
   Csql   = "select * from u_pkg_td where " + x_cond
   IF !ExecRW(cSql,"u_pkg_td","R")
      return(.f.)
   ENDIF
   SELECT U_PKG_TD
   GO TOP
   IF EOF()
   ELSE
      SCATTER MEMVAR MEMO
      *=> Loop su tutti i record legati alla testata
      x_cond = "leg_syspkg = '" + M.PKG_CODSYS + "'"
      Csql   = "select * from u_pkg_le where " + x_cond
      IF !ExecCommand(cSql,"wuq_pkg_le")
         return(.f.)
      ENDIF
      SELECT wuq_pkg_le
      GO TOP
      DO WHILE .T.
         IF EOF()
            EXIT
         ENDIF
         SCATTER MEMVAR MEMO	 	
         *=> Aggiorno la riga d'ordine stornando tutta la quantitŕ impegnata originaria dal campo delle quantitŕ pkg
         *=> inoltre aggiorno il flag di saldo/inconto ed il flag del giŕ in pkg come se la riga d'ordine dovesse essere
         *=> ripresa in esame per una successiva generazione di picking
         x_csys = "ord_codsys = '" + M.PKG_SYSORD + "'"
         x_cond = x_csys
         Csql   = "select * from u_ord_dd where " + x_cond
         IF !ExecRW(cSql,"u_ord_dd","R")
            return(.f.)
         ENDIF
         SELECT u_ord_dd
         GO TOP
         IF EOF()
         ELSE
            REPLACE ORD_QTAPCK WITH ORD_QTAPCK - M.LEG_QTAIMP
            IF ORD_QTAPCK < 0
               REPLACE ORD_QTAPCK WITH 0
            ENDIF
            REPLACE ORD_SALCON WITH 'C'
            REPLACE ORD_PKLOK  WITH ' '
         ENDIF
         IF !ExecRW(cSql,"u_ord_dd","W")
            return(.f.)
         ENDIF
         *=> Se il legame con il magazzino č giŕ a saldo, non faccio niente, in quanto gli impegni sono
         *=> giŕ stati stornati a suo tempo
         IF M.LEG_SALCON = 'S'
            IF __V_FLGMOD = 'A'
            ELSE
               SELECT wuq_pkg_le
               SKIP +1
               LOOP
            ENDIF
         ENDIF
         *=> Aggiorno la riga di giacenza legata stornando l'impegno in essere (impegno iniziale - giacenza giŕ evasa)
         _Q_QTA = M.LEG_QTAIMP - M.LEG_QTAGEV
         IF _Q_QTA > 0
         ELSE
            SELECT wuq_pkg_le
            SKIP +1
            LOOP
         ENDIF
         DO PKGGESTIONEIMPEGNATO WITH _Q_QTA,"-"
         SELECT wuq_pkg_le
         SKIP +1
      ENDDO
      *=> Cancello tutte le righe di legame al magazzino
      x_cond = "leg_syspkg = '" + M.PKG_CODSYS + "'"
      Csql   = "delete from u_pkg_le where " + x_cond
      IF !ExecCommand(cSql,"u_pkg_le")
         return(.f.)
      ENDIF
      *=> Cancello la riga di testata
      SELECT U_PKG_TD
      DELETE
   ENDIF
   IF !ExecRW(cSql,"u_pkg_td","W")
      return(.f.)
   ENDIF

   SELECT CU_PKG_TD
   SKIP +1

ENDDO

RETURN



************************************************************************************************
PROCEDURE PKGCARIMP		&& Funzione di carico impegni con nuovi recors modificati o annullati
************************************************************************************************

*=> L'obbiettivo di questa funzione č quello di operare sugli archivi con i valori dei cursori (giacenze e ordini)
*=> - impegnando nella riga d'ordine la quantitŕ in pkg con il totale della quantitŕ impegnanta
*=> - impegnando sulle giacenze le quantitŕ ancora da impegnare (solo le righe non a saldo)

SELECT CU_PKG_TD
SET FILTER TO
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   *=> Prendo in considerazione solo le righe modificate
   IF PKG_FLGMOD = 'M'
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO	 	

   *=> Scrivo il record di testata
   Csql   = "select * from u_pkg_td where 1=0"
   IF !ExecRW(cSql,"u_pkg_td","R")
      return(.f.)
   ENDIF
   SELECT u_pkg_td
   APPEND BLANK
   M.PKG_FLGMOD = ' '
   M.SELEZIONE  = SPACE(10)
   DO U_PKG_TD
   IF !ExecRW(cSql,"u_pkg_td","W")
      return(.f.)
   ENDIF

   *=> Loop su tutti i record legati alla testata per la successiva scrittura e impegno sui magazzini e ordini
   SELECT CU_PKG_LE
   SET ORDER TO I_CODSYS
   SEEK M.PKG_CODSYS

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF LEG_SYSPKG = M.PKG_CODSYS
      ELSE
         EXIT
      ENDIF

      SCATTER MEMVAR MEMO

      *=> Scrivo il record di legame
      Csql   = "select * from u_pkg_le where 1=0"
      IF !ExecRW(cSql,"u_pkg_le","R")
         return(.f.)
      ENDIF
      SELECT u_pkg_le
      APPEND BLANK
      IF M.PKG_SC_PKG = 'S'
         M.LEG_SALCON = 'S'
      ENDIF
      M.LEG_FLGMOD = ' '
      M.SELEZIONE  = SPACE(10)
      DO U_PKG_LE
      IF !ExecRW(cSql,"u_pkg_le","W")
         return(.f.)
      ENDIF

      *=> Aggiorno la riga d'ordine sommando tutta la quantitŕ impegnata originaria nel campo delle quantitŕ pkg
      *=> inoltre aggiorno il flag di saldo/inconto ed il flag del giŕ in pkg in base alla quantitŕ ancora da evadere
      *=> per chiudere l'ordine
      x_csys = "ord_codsys = '" + M.PKG_SYSORD + "'"
      x_cond = x_csys
      Csql   = "select * from u_ord_dd where " + x_cond
      IF !ExecRW(cSql,"u_ord_dd","R")
         return(.f.)
      ENDIF
      SELECT u_ord_dd
      GO TOP
      IF EOF()
      ELSE
         REPLACE ORD_QTAPCK WITH ORD_QTAPCK + M.LEG_QTAIMP
         IF ORD_QTAORD > ORD_QTAEV + ORD_QTAPCK
            REPLACE ORD_SALCON WITH 'C'
            REPLACE ORD_PKLOK  WITH ' '
         ELSE
            REPLACE ORD_SALCON WITH 'S'
            REPLACE ORD_PKLOK  WITH 'S'
         ENDIF
      ENDIF
      IF M.PKG_SC_ORD = 'S'
         REPLACE ORD_SALCON WITH 'S'
         REPLACE ORD_PKLOK  WITH 'S'
      ENDIF
      IF !ExecRW(cSql,"u_ord_dd","W")
         return(.f.)
      ENDIF

      *=> Determino la quantitŕ da impegnare sul magazzino calcolando la differenza tra l'impegnato totale e
      *=> quello che richiede questa picking, quindi se č a saldo, la quantitŕ da impegnare č l'impegno totale
      *=> decurtato dell'impegno di questa picking, altrimenti č sempre l'impegno totale
      *=> Se il legame con il magazzino č a saldo, non faccio niente, in quanto gli impegni sono
      *=> giŕ stati stornati con il disimpegno
      IF M.LEG_SALCON = 'S'
         _Q_QTA = M.LEG_QTADEV
      ELSE
         _Q_QTA = M.LEG_QTAIMP - M.LEG_QTAGEV
      ENDIF

      *=> Aggiorno la riga di giacenza legata stornando l'impegno in essere (impegno iniziale - giacenza giŕ evasa)
      IF _Q_QTA > 0
      ELSE
         SELECT CU_PKG_LE
         SKIP +1
         LOOP
      ENDIF
      DO PKGGESTIONEIMPEGNATO WITH _Q_QTA,"+"

      SELECT CU_PKG_LE
      REPLACE LEG_SYSMAG WITH M.LEG_UNIQUE
      REPLACE LEG_CODMAG WITH M.LEG_CODMAG
      SKIP +1

   ENDDO

   SELECT CU_PKG_TD
   SKIP +1

ENDDO

RETURN


