TLAVU   = ART_CSTLAV
VARIAZ  = ART_DATINS
TUSERIE = 0.0
TORELAV = 0.0
MDCP    = 0.0
MDCQ    = 0.0
SIMACC  = 0
TCU     = ART_PRZCOS
ZLOTTO  = Y_LOTTO * M.WQTA

IF V_FINE
