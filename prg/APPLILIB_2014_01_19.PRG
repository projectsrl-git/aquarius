				IF !EOF()
					__GRUPPO_PRODUTTIVO = ALLTRIM(SUBSTR(LIBERA,1,3))
				ELSE
				    __GRUPPO_PRODUTTIVO = ""
				ENDIF
		    ELSE
		       __ORD_GN         	= " "  						&& FORZO NULLA
		       __ORD_TIPOGN			= " "						&& FORZO NULLA
		       __TIPO_PRODOTTO      = ""
		    ENDIF
	    ENDIF
    ELSE
*!*	       __ORD_GN         = "N"  								&& FORZO GREZZO
*!*	       __ORD_TIPOGN		= "1"								&& FORZO TIPO GREZZO
       __ORD_GN         = " "  									&& FORZO NULLA
       __ORD_TIPOGN		= " "									&& FORZO NULLA
       __TIPO_PRODOTTO  = ""
