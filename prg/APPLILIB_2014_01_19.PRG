         M.MAG_GIACEN = M.MAG_GIACEN - M.MAG_QTAIMP
         M.MAG_QTAKG  = M.MAG_QTAKG - M.MAG_GKGIMP
         M.MAG_QTAMQ  = M.MAG_QTAMQ - M.MAG_QTAIMP
         M.MAG_QTAML  = M.MAG_QTAML - M.MAG_GMLIMP
         M.MAG_LUNGHE = M.MAG_QTAML
         M.MAG_NBAFOR = 0
