************************
FUNCTION CAMBIADT
************************
PARA _DATA,_NOMEDT

IF _DATA = '  /  /    ' .OR. _DATA = SPACE(10) .OR. ;
   _DATA = '    /  /  ' .OR. EMPTY(_DATA)
   REPLACE &_NOMEDT WITH SPACE(10)
ELSE
   IF SUBSTR(_DATA,3,1) = '/'
      REPLACE &_NOMEDT WITH RIBALTA2(_DATA)
   ELSE
      REPLACE &_NOMEDT WITH _DATA
   ENDIF
ENDIF

RETURN(.T.)

************************
FUNCTION GETORFO
************************
**--> RECUPERA L'ORDINATO A FORNITORI PER QUELL'ARTICOLO TENENDO CONTO
**--> DELLA DATA DI SCADENZA DELLA COMMESSA
PARA ARTI,SCAD,FORNI,MAGA
SS1=STR(SELECT())

_N_PAR = PARAMETERS()
IF _N_PAR = 2
    L_FORNI = SPACE(10)
    L_MAGA  = SPACE(06)
ELSE
   IF _N_PAR = 3
       L_FORNI = FORNI
       L_MAGA  = SPACE(06)
   ELSE
       L_FORNI = FORNI
       L_MAGA  = MAGA
   ENDIF
ENDIF

IF SUBSTR(SCAD,3,1) = '/'
   SCAD = RIBALTA2(SCAD)
ENDIF

OUT=0

IF PUB_CTRORF
ELSE
   M.ORD_QTAORF = 0
   SELECT &SS1
   RETURN(OUT)
ENDIF

v_seek   = ARTI
v_chiave = "ord_codart"
IF seek_std('u_orf_dd',v_seek,v_chiave,'CUR_ORDFOR_DD')
   SELECT CUR_ORDFOR_DD
   OUT=0
   DO WHILE !EOF()
      IF ALLTRIM(ORD_CODART)<>ALLTRIM(ARTI)
         EXIT
      ENDIF
      IF ORD_CHIUSO
         SKIP +1
         LOOP
      ENDIF
      IF ORD_SALCON = 'S'
         SKIP +1
         LOOP
      ENDIF
      IF EMPTY(L_FORNI) .OR. L_FORNI = SPACE(10)
      ELSE
         IF ORS_CODCLI = L_FORNI
         ELSE
            SKIP +1
            LOOP
         ENDIF
      ENDIF
      IF EMPTY(L_MAGA) .OR. L_MAGA = SPACE(06)
      ELSE
         IF ORS_MAGD = L_MAGA
         ELSE
            SKIP +1
            LOOP
         ENDIF
      ENDIF
      x_agga = "taggancio = '" + ALLTRIM(DAGGANCIO) + "'"
      x_cond = x_agga
      cSql   = "SELECT * FROM U_ORF_TT WHERE " + x_cond
      IF !ExecCommand(cSql,"CUR_ORDFOR_TT")
         return(.f.)
      ENDIF
      SELECT CUR_ORDFOR_TT
      IF EOF()
         SELECT CUR_ORDFOR_DD
         SKIP +1
         LOOP
      ENDIF
      IF ORD_FLGTIP
         SELECT CUR_ORDFOR_DD
         SKIP +1
         LOOP
      ENDIF
      SELECT CUR_ORDFOR_DD
      V_QODET = ORD_QTAORD
      V_QEDET = ORD_QTAEV
      V_AGGA  = DAGGANCIO
      IF PUB_QTAORF                  && NON TIENE CONTO DELLA DATA DI SCADENZA
         OUT=OUT + (V_QODET - V_QEDET)
      ELSE
         IF SCAD < ORD_DATCON
         ELSE
            OUT=OUT + (V_QODET - V_QEDET)
         ENDIF
      ENDIF
      SELECT CUR_ORDFOR_DD
      SKIP +1
   ENDDO
ELSE
   OUT=0
ENDIF

SELECT &SS1
RETURN(OUT)


