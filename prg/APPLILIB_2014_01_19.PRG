*******************************************************************************
* -->> Funzione per la gestione delle movimentazioni articolo su magazzino
*
* _MAG = MAGAZZINO (DI CARICO/SCARICO)
* _TOP = CAUSALE   (DI CARICO/SCARICO)
*
*******************************************************************************

FUNCTION MAGAMOVIM
PARAMETERS _MAG,_MAG1,_TOP,_TOP1

*!*	  SERGIO INIZIO 07/08/2004
RELEASE _M_CODACQ,_M_DESACQ
PUBLIC  _M_CODACQ,_M_DESACQ
_M_CODACQ  = SPACE(03)
_M_DESACQ  = SPACE(03)
*!*	  SERGIO FINE 07/08/2004

IF EMPTY(ALLTRIM(M_CODCLI)) .OR. ALLTRIM(M_CODCLI) = 'X'
   M_CODCLI = SPACE(10)
   M_DESCLI = SPACE(50)
ELSE
   IF V_LIB = 'C'
      x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
      x_codi = "cli_codcli = '" + ALLTRIM(M_CODCLI) + "'"
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
      IF !ExecCommand(cSql,"SuC_cli_an")
         return(.f.)
      ENDIF
      SELECT SuC_cli_an
      GO TOP
      IF EOF()
         M_CODCLI = SPACE(10)
         M_DESCLI = SPACE(50)
      ELSE
         M_DESCLI = CLI_RAGSOC
      ENDIF
   ELSE
      M_CODCLI = SPACE(10)
      M_DESCLI = SPACE(50)
   ENDIF
ENDIF

IF EMPTY(M_CLIFOR) .OR. M_CLIFOR = SPACE(10)
ELSE
   IF X_SEGNO = '+'
      x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
      x_codi = "for_codcli = '" + ALLTRIM(M_CLIFOR) + "'"
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
      IF !ExecCommand(cSql,"u_for_an")
         return(.f.)
      ENDIF
      SELECT u_for_an
      GO TOP
      IF !EOF()
         M_RAGSOC = FOR_RAGSOC
         _M_CODACQ= FOR_CODACQ
         _M_DESACQ= FOR_DESACQ
      ELSE
         x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
         x_codi = "cli_codcli = '" + ALLTRIM(M_CLIFOR) + "'"
         x_cond = x_soci + " and " + x_codi
         Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
         IF !ExecCommand(cSql,"u_cli_an")
            return(.f.)
         ENDIF
         SELECT u_cli_an
         GO TOP
         IF !EOF()
            M_RAGSOC = CLI_RAGSOC
         ENDIF
      ENDIF
   ELSE
      x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
      x_codi = "cli_codcli = '" + ALLTRIM(M_CLIFOR) + "'"
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
      IF !ExecCommand(cSql,"u_cli_an")
         return(.f.)
      ENDIF
      SELECT u_cli_an
      GO TOP
      IF !EOF()
         M_RAGSOC = CLI_RAGSOC
      ELSE
         x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
         x_codi = "for_codcli = '" + ALLTRIM(M_CLIFOR) + "'"
         x_cond = x_soci + " and " + x_codi
         Csql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
         IF !ExecCommand(cSql,"u_for_an")
            return(.f.)
         ENDIF
         SELECT u_for_an
         GO TOP
         IF !EOF()
            M_RAGSOC = FOR_RAGSOC
           _M_CODACQ= FOR_CODACQ
           _M_DESACQ= FOR_DESACQ
         ENDIF
      ENDIF
   ENDIF
ENDIF

*-->> AGGIORNAMENTO MAGAZZINO --

*=> Inizio - PROJECT 04/10/2004
PUB_FILDES_X   = SPACE(05)
PUB_PIADES_X   = SPACE(05)
PUB_UBIDES_X   = SPACE(05)
PUB_FILDES_N   = 0
PUB_PIADES_N   = 0
PUB_UBIDES_N   = 0
*=> Fine - PROJECT 04/10/2004

IF _GGG = "SI"

   IF _DADOVE = 'VEN' .OR. _DADOVE = 'ECASH' .OR. SUBSTR(_DADOVE,1,3) = 'BOL' .OR. _DADOVE = 'SOS_SCARICA'
      IF PUB_FORPRE
         DO GESTIONE_FORN_PREF
      ELSE
         DO GESTIONE_NOFORN_PREF
      ENDIF
   ELSE
      IF _DADOVE = 'PRODSPOSTA' .OR. SUBSTR(_DADOVE,1,8) = 'PRODAVAN' .OR. _DADOVE = 'PRODSCALTRO' .OR. _DADOVE = 'PRODPEDANA'
         DO GESTIONE_SPOSTA
      ELSE
         IF _DADOVE = 'RESSCMAG'
            DO GESTIONE_RESO
         ELSE
            IF _DADOVE = 'RESOPEDANA'
               DO GESTIONE_RESO_PEDANA
            ELSE
               DO GESTIONE_CARICA_MAGA
               **=> ERASMO - INIZIO 08/04/2008
               IF USED("U_ALT_DA")
                  SELECT U_ALT_DA
                  GO TOP
                  SCATTER MEMVAR
               ENDIF
               **=> ERASMO - FINE 08/04/2008
            ENDIF
         ENDIF
      ENDIF
   ENDIF

   M_GENMOV = "NO"

ENDIF

*-->> SCARICA LA GIACENZA DI MAGAZZINO ----------------------------

DO MAGAZZINO_STANDARD

RETURN


