		      LOOP
		   ENDIF
		   IF ORD_FLBOL = "S" 				&& SCARTA BOLLE GIA' ELABORATE
		      SKIP +1
		      LOOP
		   ENDIF
		   IF ORD_FORNI						&& SCARTA BOLLE A FORNITORI
		      SKIP +1
		      LOOP
		   ENDIF
           IF !_RESDANCR(ORD_CAUS)			&& SCARTA BOLLE NON DA FATTURARE
              SKIP +1
	  	      LOOP
		   ENDIF
 	       SCATTER MEMVAR MEMO
 	       __RC = SYS(2015)
		   REPLACE ORD_CODSYS  WITH __RC     && NUMERO RECORD CORRENTE
           SELECT  CBOL_TT
           APPEND BLANK
           GATHER MEMVAR MEMO
 		   REPLACE ORD_CODSYS  WITH __RC     && NUMERO RECORD CORRENTE
		   REPLACE SELEZIONE   WITH __AGG	&& IMPOSTA CAMPO SELEZIONE
		   SELECT U_BOL_TT
		   SKIP +1
		ENDDO
        IF !ExecRW(cSql,"U_BOL_TT","W")
           return(.f.)
        ENDIF

   CASE __TIPO = "CLIE"
        _cliente = TRC(PUB_LCL,ALLTRIM(__CCLI))
        x_soci = "ord_codsoc = '" + PUB_CODSOC + "'"
        x_anno = "ord_anno = '" + PUB_ANNO + "'"
        x_nord = "ord_numord = ord_numord"
        x_clie = "ord_codcli = '" + _cliente + "'"
        x_caus = "ord_caus = '" + PUB_RESCLI + "'"
        x_cond = x_soci + " and " + x_anno + " and " + x_nord + " and " + x_nord + " and " + x_clie + " and " + x_caus
        Csql = "select * from u_bol_tt where " + x_cond + " order by ord_codsoc,ord_anno,ord_numord,ord_codcli"
        IF !ExecRW(cSql,"U_BOL_TT","R")
           return(.f.)
        ENDIF
        SELECT U_BOL_TT
        GO TOP
		DO WHILE .T.
		   IF EOF()
		      EXIT
		   ENDIF
		   IF DELETED()
		      SKIP +1
		      LOOP
		   ENDIF
		   IF ORD_FLBOL = "S" 				&& SCARTA BOLLE GIA' ELABORATE
		      SKIP +1
		      LOOP
		   ENDIF
		   IF ORD_FORNI						&& SCARTA BOLLE A FORNITORI
		      SKIP +1
		      LOOP
		   ENDIF
           IF !_RESDANCR(ORD_CAUS)			&& SCARTA BOLLE NON DA FATTURARE
              SKIP +1
	  	      LOOP
