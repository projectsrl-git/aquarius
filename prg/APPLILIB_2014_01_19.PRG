            ENDIF
         ENDIF
      ELSE
         XXX_SCARICO = VQTAORD
      ENDIF
      IF XXX_SCARICO = 0
      ELSE
         **==>> RICHIAMA LA FUNZIONE PER GESTIRE IL MAGAZZINO
         H_DADOVE = 'PRODISBA'
