	ENDIF
	
    __ORD_GN         	= " "  									&& NESSUNA FAMIGLIA PRODOTTO
    __TIPO_PRODOTTO     = ""
	__GRUPPO_PRODUTTIVO = ""

    SELECT XX_ART_AN
    IF !EOF()
	    IF !EMPTY(ALLTRIM(art_tipoG))
