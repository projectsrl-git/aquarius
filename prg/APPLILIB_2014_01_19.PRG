SELECT STA_SPALMATURA
SET ORDER TO
SET FILTER TO
GO TOP
IF EOF()
ELSE
   W_DATINI = STA_DATINI
   W_DATFIN = STA_DATFIN
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF STA_DATFIN = 'GG/MM/AAAA'
         SKIP +1
         LOOP
      ENDIF
      IF RIBALTA2(STA_DATFIN) > RIBALTA2(W_DATFIN)
         W_DATFIN = STA_DATFIN
      ENDIF
      SKIP +1
   ENDDO
ENDIF

IF EMPTY(ALLTRIM(W_DATINI))
ELSE
   x_cond = "cal_datamg = '" + RIBALTA2(W_DATINI) + "'"
   cSql   = "select * from u_cal_la where " + x_cond
   IF !ExecCommand(cSql,"U_CAL_LA")
      RETURN
   ENDIF
   SELECT U_CAL_LA
   GO TOP
   IF EOF()
   ELSE
      W_SETINI = CAL_SETT
   ENDIF
   x_cond = "cal_datamg = '" + RIBALTA2(W_DATFIN) + "'"
   cSql   = "select * from u_cal_la where " + x_cond
   IF !ExecCommand(cSql,"U_CAL_LA")
      RETURN
   ENDIF
   SELECT U_CAL_LA
   GO TOP
   IF EOF()
   ELSE
      W_SETFIN = CAL_SETT
   ENDIF
ENDIF

_V_DPRGDA = W_DATINI
_V_SPRGDA = W_SETINI
_V_DPRGAL = W_DATFIN
_V_SPRGAL = W_SETFIN

SELECT STA_SPALMATURA
