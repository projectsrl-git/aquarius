******************************
FUNCTION ALTRI_UTENTI_IN_PROC
******************************

PARAMETERS 	_QUANDO,_PROCEDURA,_DESPROCEDURA,_BLOCCA

XXX_SELECT = SELECT()

IF _QUANDO = 'INIZIO'
   x_proc = "att_proced = '" + ALLTRIM(_PROCEDURA) + "'"
   x_uten = "att_codope = att_codope"
   x_cond = x_proc + " and " + x_uten
   cSql   = "select * from u_att_op where " + x_cond + " order by att_amgini,att_oraini"
   IF !ExecRW(cSql,"U_ATT_OP","R")
      return(.f.)
   ENDIF
   SELECT U_ATT_OP
   GO TOP
   IF EOF()
      APPEND BLANK
      SCATTER MEMVAR MEMO BLANK
      M.ATT_PROCED = ALLTRIM(_PROCEDURA)
      M.ATT_DESPRO = ALLTRIM(_DESPROCEDURA)
      M.ATT_CODOPE = PUB_CODOPE
      M.ATT_NOMOPE = PUB_NOMOPE
      M.ATT_DATINI = DTOC(DATE())
      M.ATT_ORAINI = TIME()
      M.ATT_DATFIN = SPACE(10)
      M.ATT_ORAFIN = SPACE(08)
      M.ATT_FLGBLK = _BLOCCA
      DO U_ATT_OP
      _OK = .T.
   ELSE
      SCATTER MEMVAR MEMO
      IF _BLOCCA
         IF EMPTY(ALLTRIM(ATT_DATFIN))
            IF ATT_CODOPE = PUB_CODOPE
               _OK = .T.
            ELSE
               _OK = .F.
            ENDIF
         ELSE
            M.ATT_CODOPE = PUB_CODOPE
            M.ATT_NOMOPE = PUB_NOMOPE
            M.ATT_DATINI = DTOC(DATE())
            M.ATT_ORAINI = TIME()
            M.ATT_DATFIN = SPACE(10)
            M.ATT_ORAFIN = SPACE(08)
            M.ATT_FLGBLK = _BLOCCA
            DO U_ATT_OP
            _OK = .T.
         ENDIF
      ELSE
         M.ATT_CODOPE = PUB_CODOPE
         M.ATT_NOMOPE = PUB_NOMOPE
         M.ATT_DATINI = DTOC(DATE())
         M.ATT_ORAINI = TIME()
         M.ATT_DATFIN = SPACE(10)
         M.ATT_ORAFIN = SPACE(08)
         M.ATT_FLGBLK = _BLOCCA
         DO U_ATT_OP
         _OK = .T.
      ENDIF
      SCATTER MEMVAR MEMO
   ENDIF
ELSE
   x_proc = "att_proced = '" + ALLTRIM(_PROCEDURA) + "'"
   x_uten = "att_codope = '" + ALLTRIM(PUB_CODOPE) + "'"
   x_cond = x_proc + " and " + x_uten
   cSql   = "select * from u_att_op where " + x_cond + " order by att_amgini,att_oraini"
   IF !ExecRW(cSql,"U_ATT_OP","R")
      return(.f.)
   ENDIF
   SELECT U_ATT_OP
   GO TOP
   IF EOF()
   ELSE
      REPLACE ATT_DATFIN WITH DTOC(DATE())
      REPLACE ATT_AMGFIN WITH RIBALTA2(ATT_DATFIN)
      REPLACE ATT_ORAFIN WITH TIME()
   ENDIF
   _OK = .T.
ENDIF

IF !ExecRW(cSql,"U_ATT_OP","W")
   return(.f.)
ENDIF

SELECT(XXX_SELECT)

RETURN(_OK)


****************************
FUNCTION TROVA_DESCR_MAG_CAU
****************************
**--> RITORNA LA DESCRIZIONE DEL MAGAZZINO O DELLA CAUSALE

PARAMETERS _V_TIPRIC,_V_CODRIC
*_V_TIPRIC = 1  ==> CERCA LA DESCRIZIONE DEL MAGAZZINO CON HELP
*_V_TIPRIC = 2  ==> CERCA LA DESCRIZIONE DELLA CAUSALE CON HELP
*_V_TIPRIC = 3  ==> CERCA LA DESCRIZIONE DEL MAGAZZINO SENZA HELP
*_V_TIPRIC = 4  ==> CERCA LA DESCRIZIONE DELLA CAUSALE SENZA HELP

_X_TIPRIC = _V_TIPRIC
_X_CODRIC = _V_CODRIC
_X_RIT    = SPACE(56)

IF _X_TIPRIC <> 1 .OR. _X_TIPRIC <> 2 .OR. _X_TIPRIC <> 3 .OR. _X_TIPRIC <> 4
ELSE
   RETURN(_X_RIT)
ENDIF

SWS = SELECT()

IF _X_TIPRIC = 1

   _V_DESMAG = ""
   _X_CODRIC = seek_para('MAG',ALLTRIM(_X_CODRIC),'CODICE','CODICE',"4,6")
   IF EMPTY(ALLTRIM(_X_CODRIC))
      =MESSAGEBOX("Il codice magazzino č obbligatorio",16,"Attenzione")
      SELECT(SWS)
      RETURN(_X_RIT)
   ENDIF
   SELECT _pj_para
   _V_DESMAG = DESCRI
   _X_RIT = _X_CODRIC + ALLTRIM(_V_DESMAG)

ELSE

   IF _X_TIPRIC = 2
      _V_DESCAU = ""
      _X_CODRIC = SEEK_PARA('TOP',ALLTRIM(_X_CODRIC),'CODICE','CODICE',"4,10")
      IF EMPTY(ALLTRIM(_X_CODRIC))
         =MESSAGEB("Codice causale obbligatorio",16,"*** ATTENZIONE ***")
         SELECT(SWS)
         RETURN(_X_RIT)
      ENDIF
      SELECT _pj_para
      _V_DESCAU = DESCRI
      _X_RIT = _X_CODRIC + ALLTRIM(_V_DESCAU)
   ENDIF

ENDIF

IF _X_TIPRIC = 3

   _V_DESMAG = ""
   x_codi = "codice = 'MAG" + ALLTRIM(_X_CODRIC) + "'"
   x_cond = x_codi
   cSql   = "select * from para where " + x_cond
   IF !ExecCommand(cSql,"PARA")
      return(.f.)
   ENDIF
   SELECT PARA
   GO TOP
   IF EOF()
      _X_CODRIC = SPACE(06)
      _V_DESMAG = SPACE(50)
   ELSE
      _X_CODRIC = SUBSTR(CODICE,1,6)
      _V_DESMAG = DESCRI
   ENDIF
   _X_RIT = _X_CODRIC + ALLTRIM(_V_DESMAG)

ELSE

   IF _X_TIPRIC = 4
      _V_DESCAU = ""
      x_codi = "codice = 'TOP" + ALLTRIM(_X_CODRIC) + "'"
      x_cond = x_codi
      cSql   = "select * from para where " + x_cond
      IF !ExecCommand(cSql,"PARA")
         return(.f.)
      ENDIF
      SELECT PARA
      GO TOP
      IF EOF()
         _X_CODRIC = SPACE(06)
         _V_DESCAU = SPACE(50)
      ELSE
         _X_CODRIC = SUBSTR(CODICE,1,6)
         _V_DESCAU = DESCRI
      ENDIF
      _X_RIT = _X_CODRIC + ALLTRIM(_V_DESCAU)
   ENDIF

ENDIF

SELECT(SWS)

RETURN(_X_RIT)




