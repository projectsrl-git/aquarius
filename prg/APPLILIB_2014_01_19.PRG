                           NUD_CODFOR C(10),    NUD_DESFOR C(50),   NUD_LUNGHE N(06),   NUD_UNITAM C(03),  NUD_QTAMQ N(12,2),  ;
                           NUD_QTAKG N(12,2),   NUD_CODINT C(16),   NUD_NUMLOT N(08),   NUD_CODMAG C(06),         			   ;
                           ADE_CODICE C(16),    ADE_DESCRI C(50),   ADE_DSDIBA C(50),   ADE_UNITAM C(03),  ADE_QTAGIA N(16,6), ;
                           ADE_QTANEC N(16,6),  ADE_QTADOR N(16,6), ADE_SCORMI N(16,6), ADE_CODIMB C(03),  ADE_DESIMB C(50),   ;
                           ADE_LOTMIN N(12,2),  ADE_LIVELL N(10,0), ADE_QTADIB N(16,6), ADE_CODINT C(16),  ADE_NUMLOT N(08),   ;
                           ADE_CODFOR C(10),    ADE_DESFOR C(50),   ADE_CODMAG C(06),    									   ;
                           MAG_QTAGIA N(16,2),  AVA_CODAVA C(03),   AVA_DESAVA C(50),   AVA_DATAVA C(10),  AVA_AMGAVA C(10),   ;
                           AVA_ORAAVA C(08),    AVA_CONMTL N(10),   ADE_QTASCA N(16,6), STA_FLGELI C(2))

SELECT STA_RAPPROD
INDEX ON STA_NUMPRG + STA_DATPRG + STR(STA_PROGRE,6,0) TAG I_INDICE ADDITIVE


* -->> Inizializzazione cursore sala mescole da ordinare
* ------------------------------------------------------
CREATE CURSOR CUR_SALAMESCOLEOF (SEL_CODART C(16),   SEL_DESART C(50),   SEL_CDDIBA C(16),   SEL_DSDIBA C(50),   ;
                                 SEL_UNITAM C(03),   SEL_QTAGIA N(16,6), SEL_QTANEC N(16,6), SEL_QTADOR N(16,6), ;
                                 SEL_SCORMI N(16,6), SEL_CODIMB C(03),   SEL_DESIMB C(50),   SEL_LOTMIN N(12,2), ;
                                 SEL_LIVELL N(10,0), SEL_QTADIB N(16,6))

SELECT CU_ORD_DD
DELETE FOR ORD_CODART <> 'CIAO' ALL

x_codi = IIF(EMPTY(ALLTRIM(_V_CODCLI)) .OR. _V_ALLCLI,"ors_codcli = ors_codcli","ors_codcli = '" + ALLTRIM(_V_CODCLI) + "'" )
x_dord = IIF(EMPTY(ALLTRIM(_V_DORDDA)) .OR. _V_DORDDA = '  /  /    ' .OR. _V_ALLORD,"ors_datord = ors_datord","ors_datord >= '" + RIBALTA2(_V_DORDDA) + "'" )
x_dric = IIF(EMPTY(ALLTRIM(_V_DRICDA)) .OR. _V_DRICDA = '  /  /    ' .OR. _V_ALLRIC,"ord_datcon = ord_datcon","ord_datcon >= '" + RIBALTA2(_V_DRICDA) + "'" )
x_nprg = IIF(EMPTY(ALLTRIM(_V_NUMPRG)) .OR. _V_ALLPRG,"ord_numprg = ord_numprg","ord_numprg = '" + ALLTRIM(_V_NUMPRG) + "'" )
x_dprg = IIF(EMPTY(ALLTRIM(_V_DATPRG)) .OR. _V_DATPRG = '  /  /    ' .OR. _V_ALLPRG,"ord_datprg = ord_datprg","ord_datprg = '" + RIBALTA2(_V_DATPRG) + "'" )
x_cond = x_codi + " and " + x_dord + " and " + x_dric + " and " + x_nprg + " and " + x_dprg
cSql   = "select * from u_ord_dd where " + x_cond
IF !ExecCommand(cSql,'U_ORD_DD')
   return(.f.)
ENDIF


SELECT U_ORD_DD
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF EMPTY(ALLTRIM(_V_DORDAL)) .OR. _V_DORDAL = '  /  /    ' .OR. _V_ALLORD
   ELSE
      IF ORS_DATORD > RIBALTA2(_V_DORDAL)
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   IF EMPTY(ALLTRIM(_V_DRICAL)) .OR. _V_DRICAL = '  /  /    ' .OR. _V_ALLRIC
   ELSE
      IF ORD_DATCON > RIBALTA2(_V_DRICAL)
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
      SKIP +1
      LOOP
   ENDIF

*!*	   IF _V_OPZPRG = 1  			&& PROGRAMMA DI SPALMATURA
      IF _V_OPZAVA = 1			&& DA PROGRAMMARE
         IF ORD_SALCON = 'S'	&& PROGRAMMATO A SALDO
            SKIP +1
            LOOP
         ENDIF
      ELSE
         IF _V_OPZAVA = 2		&& PROGRAMMATO
            IF ORD_NRBSPP > 0 .OR. ORD_NRBRIP > 0 .OR. ORD_NRBTGP > 0	&& QUANTITA' PROGRAMMATA SIGNIFICATIVA
            ELSE
               SKIP +1
               LOOP
            ENDIF
         ENDIF
      ENDIF
*!*	   ENDIF

   SCATTER MEMVAR MEMO

   SELECT U_ORD_DD

   *GIRO LE DATE NEL FORMATO GMA E LE SETTIMANE NEL FORMATO NN/AAAA

   M.ORS_DATORD = RIBALTA2(M.ORS_DATORD)
   M.ORD_DATCON = RIBALTA2(M.ORD_DATCON)

   IF EMPTY(ALLTRIM(M.ORD_DATPRG))
   ELSE
      M.ORD_DATPRG= RIBALTA2(M.ORD_DATPRG)
   ENDIF

   IF EMPTY(ALLTRIM(M.ORD_SEIPRG))
   ELSE
      M.ORD_SEIPRG = RIBALTASET(M.ORD_SEIPRG)
   ENDIF
   IF EMPTY(ALLTRIM(M.ORD_SEFPRG))
   ELSE
      M.ORD_SEFPRG = RIBALTASET(M.ORD_SEFPRG)
   ENDIF

   SELECT CU_ORD_DD
   APPEND BLANK
   GATHER MEMVAR MEMO
   REPLACE ORD_NRBTGO WITH ORD_NUMBOB
   REPLACE ORD_QTATGO WITH ORD_QTAORD
   REPLACE ORD_NRBTGD WITH ORD_NRBTGO - ORD_NRBTGP
   REPLACE ORD_QTATGD WITH ORD_QTATGO - ORD_QTATGP
   REPLACE ORD_NRBOBD WITH ORD_NRBTGD
   REPLACE ORD_QUANTD WITH ORD_QTATGD

   SELECT U_ORD_DD
   SKIP +1

ENDDO

SELECT SALVA_DETT
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
      SKIP +1
      LOOP
   ENDIF
   IF ORD_SALCON = 'S'	&& PROGRAMMATO A SALDO
      SKIP +1
      LOOP
   ENDIF
   SCATTER MEMVAR MEMO
   *GIRO LE DATE NEL FORMATO GMA E LE SETTIMANE NEL FORMATO NN/AAAA
   IF SUBSTR(M.ORS_DATORD,3,1) = '/'
   ELSE
      M.ORS_DATORD = RIBALTA2(M.ORS_DATORD)
   ENDIF
   IF SUBSTR(M.ORS_DATORD,3,1) = '/'
   ELSE
      M.ORD_DATCON = RIBALTA2(M.ORD_DATCON)
   ENDIF
   IF EMPTY(ALLTRIM(M.ORD_DATPRG))
   ELSE
      M.ORD_DATPRG= RIBALTA2(M.ORD_DATPRG)
   ENDIF
   IF EMPTY(ALLTRIM(M.ORD_SEIPRG))
   ELSE
      M.ORD_SEIPRG = RIBALTASET(M.ORD_SEIPRG)
   ENDIF
   IF EMPTY(ALLTRIM(M.ORD_SEFPRG))
   ELSE
      M.ORD_SEFPRG = RIBALTASET(M.ORD_SEFPRG)
   ENDIF
   SELECT CU_ORD_DD
   APPEND BLANK
   GATHER MEMVAR MEMO
   REPLACE ORD_NRBTGO WITH ORD_NUMBOB
   REPLACE ORD_QTATGO WITH ORD_QTAORD
   REPLACE ORD_NRBTGD WITH ORD_NRBTGO - ORD_NRBTGP
   REPLACE ORD_QTATGD WITH ORD_QTATGO - ORD_QTATGP
   REPLACE ORD_NRBOBD WITH ORD_NRBTGD
   REPLACE ORD_QUANTD WITH ORD_QTATGD
   SELECT SALVA_DETT
   SKIP +1
ENDDO

v_salcon = .F.

SELECT CU_ORD_DD
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   IF ORD_SALCON = 'S'
      v_salcon = .T.
      SKIP +1
      LOOP
   ENDIF
   SCATTER MEMVAR MEMO
   M.ORD_SALCON = 'S'
   M.ORD_CODMAC = SPACE(03)
   SELECT CU_ORD_DL
   APPEND BLANK
   GATHER MEMVAR MEMO
   SELECT CU_ORD_DD
   SKIP +1
ENDDO

SELECT CU_ORD_DD
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   IF ORD_SALCON = 'S'
      v_salcon = .T.
      SKIP +1
      LOOP
   ENDIF
   DELETE
   SELECT CU_ORD_DD
   SKIP +1
ENDDO

RETURN


