FUNCTION CERCA_ARTICOLO
PARAMETERS _CODPRI,_CODMAG


AXABBS_Z    = SELECT()

**==> crea cursore anagrafica articoli per aggiornare il bene in ammortamento
x_cond = "ART_CODPRI = '" + ALLTRIM(_CODPRI) + "'"
Csql   = "select * from u_art_pr where " + x_cond + " order by ART_CODPRI"
IF !ExecCommand(cSql,"cuu_art_pr")
   return(.f.)
ENDIF
SELECT cuu_art_pr
GO TOP
IF !EOF()
	LOC_COORDL = art_coord
	LOC_SCORMI = art_scormi
ELSE
	LOC_COORDL = " "
	LOC_SCORMI = 0
ENDIF

LOC_QTAGIAC= 0

*=> Vengono gestite le giacenze con data a spazi (record riepilogato) solo se attivo il parametro aziendale
IF PUB_GGDTSP
	x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
	x_cdma = "mag_codmag = '" + ALLTRIM(_CODMAG) + "'"
	x_cdar = "mag_anaart = '" + ALLTRIM(_CODPRI) + "'"
	x_data = "mag_datagg = SPACE(10)"
	x_cond = x_soci + " and " + x_cdma + " and " + x_cdar + " and " + x_data
	cSql   = "select * from U_MAG_GG where " + x_cond + " order by mag_anaart"
	IF !ExecCommand(cSql,"U_MAG_GG")
	   return(.f.)
	ENDIF
	SELECT U_MAG_GG
	GO TOP
	V_GIACEN = 0
	DO WHILE .T.
	   IF EOF()
	      EXIT
	   ENDIF
	   IF DELETED()
	      SKIP +1
	      LOOP
	   ENDIF
	   LOC_QTAGIAC = LOC_QTAGIAC + MAG_GIACEN
	   SKIP +1
	ENDDO
ENDIF

SELECT(AXABBS_Z)


RETURN

