   ENDIF												&& PROJECT 20/10/2006

   IF EMPTY(ALLTRIM(ORD_LEGSYS))
      REPLACE ORD_LEGSYS WITH SYS(2015)
   ENDIF

   * SI CREA LE VARIABILI DAL RECORD
   SCATTER MEMVAR MEMO

   **=> ERASMO - INIZIO 06/05/2011
   PUB_FILCAR_X = M.ORD_FILA_X
   PUB_PIACAR_X = M.ORD_PIAN_X
   PUB_UBICAR_X = M.ORD_UBIC_X
   PUB_FILCAR_N = M.ORD_FILA_N
   PUB_PIACAR_N = M.ORD_PIAN_N
   PUB_UBICAR_N = M.ORD_UBIC_N
   **=> ERASMO - FINE 06/05/2011

   RELEASE _CODMAT,_CODIMB,_DESMAT,V_UMMAGA,V_TIPO,VVV_SALCON
   PUBLIC  _CODMAT,_CODIMB,_DESMAT,V_UMMAGA,V_TIPO,VVV_SALCON
