***************************************************************************
PROCEDURE GESTIONE_POLIECO								&& GESTIONE POLIECO
***************************************************************************
PARA _TIPOARC

*!*	CALCOLA IL CONTRIBUTO POLIECO PER I SOLI CLIENTI ITALIA
*!*	E PER LE SOLE CATEGORIE DI MATERIALE LEGATE ALLA PLASTICA MAT libera = 1



XX_SELECT = SELECT()

IF !PUB_POLIEC
   RETURN
ENDIF


*=> Ciclo di "eliminazione" del contributo polieco se giŕ presente
SELECT &_TIPOARC
INDEX ON DAGGANCIO + STR(ORD_SEQUEN,3,0) TAG I_INDICE ADDITIVE
SET ORDER TO I_INDICE
GO TOP

DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF SUBSTR(ORD_CODART,1,7) = 'POLIECO'
      DELETE
   ENDIF
   SKIP +1
ENDDO

*=> Generazione cursore con valori contributo poliego
CREATE CURSOR TAB_POLIECO (POL_CODICE C(02), POL_VALUNI N(9,6), POL_QTATOT N(16,6), POL_CODART C(16), POL_TIPO C(03))
INDEX ON POL_TIPO TAG I_POLIECO ADDITIVE

x_cond = "codice like 'POL%'"
Csql   = "select * from para where " + x_cond + " order by codice"
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF

   W_COD = SUBSTR(CODICE,4,2)
   W_TIP = SUBSTR(LIBERA,69,3)
   W_ART = SUBSTR(LIBERA,1,16)
   *=> Ricerca in anagrafica articoli del relativo codice polieco legato per prelevarne il prezzo di vendita al Kg.
   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(W_ART) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
      	W_VAL = 0
   ELSE
		W_VAL  = ART_PRZVEN
   ENDIF
   SELECT TAB_POLIECO
   APPEND BLANK
   REPLACE POL_CODICE WITH W_COD
   REPLACE POL_VALUNI WITH W_VAL
   REPLACE POL_QTATOT WITH 0
   REPLACE POL_CODART WITH W_ART
   REPLACE POL_TIPO   WITH W_TIP

   SELECT CUR_PARA
   SKIP +1

ENDDO



*=> Ciclo di elaborazione per determinazione del contributo polieco , č possibile che il file in input contenga piů fatture
*!*	(vedi la creazione fatture da ddt form\menu_ddttofat) per cui viene gestita la rottura a livello di documento

SELECT &_TIPOARC
SET ORDER TO I_INDICE
GO TOP

V_AGGANCIO = DAGGANCIO
_CLIENTE_IN_ELABORZIONE = ORS_CODCLI

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DAGGANCIO = V_AGGANCIO
   ELSE
      *=> Gestione della rottura fattura (con scarico tabella polieco)
      DO SCRIVI_POLIECO
      *=> Loop sul record della fattura successiva
      SELECT &_TIPOARC
      IF EOF()
         EXIT
      ENDIF
      V_AGGANCIO = DAGGANCIO
      _CLIENTE_IN_ELABORZIONE = ORS_CODCLI
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
      SELECT &_TIPOARC
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR

   *=> Ricerca in anagrafica articoli del relativo codice polieco legato per prelevarne il prezzo di vendita al Kg.

   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.ORD_CODART) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
   		TIPO_GESTIONE   = ""
   ELSE

        W_MAT 	 = ART_CODMAT
		v_seek	 = 'MAT'+W_MAT
		v_chiave ="codice"
		IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
		    SELECT CUR_PARA
   		    TIPO_GESTIONE   = SUBSTR(LIBERA,1,1)
		ELSE
   			TIPO_GESTIONE   = ""
		ENDIF
   ENDIF

   SELECT &_TIPOARC

   IF TIPO_GESTIONE   <> "1"    && GESTIONE BOBINE/ROTOLI PER DETERINARE IL TIPO PRODOTTO PLASTICA SOGGETTO AL CONTRIBUTO POLIECO
      SELECT &_TIPOARC
      SKIP +1
      LOOP
   ENDIF

   IF M.ORD_QTAKG > 0
      SELECT TAB_POLIECO
      SET ORDER TO I_POLIECO
      SEEK 'ITA'
      DO WHILE .T.
         IF EOF()
            EXIT
         ENDIF
         IF POL_TIPO = 'ITA'
         ELSE
            EXIT
         ENDIF
         REPLACE POL_QTATOT WITH POL_QTATOT + M.ORD_QTAKG
         SKIP +1
      ENDDO
   ENDIF


   SELECT &_TIPOARC
   SKIP +1

ENDDO

*=> Gestione del fine file in fattura (con scarico tabella polieco)
DO SCRIVI_POLIECO

SELECT(XX_SELECT)

RETURN



***************************************************************************
PROCEDURE SCRIVI_POLIECO							&& GESTIONE POLIECO
***************************************************************************


** verifica se il cliente č di nazionalitŕ italiana

x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
x_codi = "cli_codcli = '" + ALLTRIM(_CLIENTE_IN_ELABORZIONE) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"u_cli_an")
   return(.f.)
ENDIF
SELECT u_cli_an
GO TOP
IF EOF()
   _NAZIONE       = 'XXX'
ELSE
   _NAZIONE       = CLI_NAZION
ENDIF


IF _NAZIONE   <> 'ITA'
   DO RICREA_CURSORE_POLIECO
   RETURN
ENDIF



SELECT TAB_POLIECO
GO TOP
IF EOF()
   RETURN
ENDIF

*=> Scrive in fattura tanti record polieco quanti sono stati caricati in tabella

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF POL_QTATOT > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR

   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.POL_CODART) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
      SELECT TAB_POLIECO
      SKIP +1
      LOOP
   ENDIF

   IF ART_PRZVEN = 0
      SELECT TAB_POLIECO
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR

   M.ART_CODIVA = CERCA_IVA_DEFAULT(_TIPOARC,"CODICE")  && ERASMO - 21/09/2011

   SELECT &_TIPOARC
   APPEND BLANK

   REPLACE DAGGANCIO  WITH V_AGGANCIO
   REPLACE ORD_CODART WITH M.ART_CODPRI
   REPLACE ORD_MAGA   WITH PUB_TAGPFO
   REPLACE ORD_DESART WITH M.ART_DESCR
   REPLACE ORD_DES2   WITH M.ART_DESEST
   REPLACE ORD_UM	  WITH M.ART_UNIMIS
   REPLACE ORD_IVA	  WITH M.ART_CODIVA
   REPLACE ORD_PREZZO WITH M.ART_PRZVEN
   REPLACE ORD_PUBBLI WITH M.ART_PUBBLI
   REPLACE ORD_COORD  WITH M.ART_COORD
   REPLACE ORD_QTXCON WITH M.ART_QTACON
