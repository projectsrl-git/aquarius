    GATHER MEMVAR MEMO


    REPLACE ORD_GN 		WITH __ORD_GN           		&& FAMIGLIA PRODOTTO
    REPLACE ORD_TIPOGN	WITH ALLTRIM(__ORD_TIPOGN)		&& TIPO PRODOTTO


 				
   ** VERIFICA SE LE PROVVIGIONI DI RIGA SONO STATE MODIFICATE ALTRIMENTI CONSIDERA LE PROVVIGIONI DI TESTATA FATTURA
   IF __PROVVIGIONI_RIGA__  =  0

        REPLACE ORD_PRORIG WITH _PERCPRO_TESTATA 	&& % PROVVIGIONE RIGA = 0 FORZO LA % DI TESTATA / O AGENTE / O CLIENTE

   ENDIF

   ** VERIFICA SE LE ESISTONO LE PROVVIGIONI PERSONALIZZATE
   IF __PROVVIGIONI_PERSONALIZZATE

        REPLACE ORD_PRORIG WITH _PERCPRO_PERSONALIZZATE 	&& % PROVVIGIONE RIGA IMPOSTATA CON LA PROVVIGIONE PERSONALIZZATA PER CLIENTE/TIPO PRODOTTO
        ESISTE_RIGA_CON_PROVVIGIONE_MODIFICATA = .T.		&& CONSIDERA LA FATTURA COME SE FOSSE STATA MODIFICATA

   ENDIF



   SELECT &_dettagli
   SKIP +1

ENDDO



SELECT &_dettagli
GO TOP




DO WHILE .NOT. EOF()

   IF DELETED()
      SELECT &_dettagli
      SKIP +1
      LOOP
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
      SELECT &_dettagli
      SKIP +1
      LOOP
   ENDIF


   COD_IVA  = ORD_IVA
   IMPONIB  = ORD_VALORE
   DES_ART  = SUBSTR(ORD_DESART,1,16)


   IF !ExecCommand("select * from para where codice = 'IVA'+?COD_IVA","para")
      return
   ENDIF
   SELECT PARA
   IF reccount() <> 0
      ALIQ = SUBSTR(LIBERA,1,3)
      NUM_ALIQ = VAL(ALIQ)
   ELSE
      NUM_ALIQ = 0
   ENDIF

   SELECT &_dettagli

   IMPOSTA = (IMPONIB * NUM_ALIQ) / 100


   IF SUBSTR(ORD_CODART,1,7) <> 'POLIECO'
   		_CNT_ARTICOLI = _CNT_ARTICOLI + 1
   ENDIF


   DO CASE

   	  CASE ALLTRIM(_DETTAGLI) = "U_FAT_DD"
		   IF ORD_PUBBLI = "S"
		      MATPUBX = MATPUBX + ORD_VALORE
		      _CNT_PUBBLI = _CNT_PUBBLI + 1		
		   ENDIF
	       IF SUBSTR(ORD_CODART,1,7) = 'POLIECO'
		      PUB_TOTPOLIECO = PUB_TOTPOLIECO + ORD_VALORE
           ENDIF


		   IF ORD_PUBBLI = "O"						&& CONTA ARTICOLO OMAGGIO
			   _CNT_OMAGGI = _CNT_OMAGGI + 1		
		   ENDIF

		   IF SUBSTR(ORD_CODART,1,7) = 'POLIECO' 	&& CALCOLO IMPONIBILE E IMPOSTA POLIECO
		 		_IMPONIBILE_POLIECO = _IMPONIBILE_POLIECO + IMPONIB
				_IMPOSTA_POLIECO    = _IMPOSTA_POLIECO    + IMPOSTA  	
		   ENDIF


		   IF ORD_PUBBLI = "O"			&& MATERIALEIN OMAGGIO CON IVA A CARICO AZIENDA
		      M.T_OMAGGIO = M.T_OMAGGIO + IMPONIB
		      M.I_OMAGGIO = M.I_OMAGGIO + IMPOSTA
		      SKIP +1
		      LOOP
		   ENDIF
		

   ENDCASE


   IF ((IVA1 = SPACE(3)) .OR. (IVA1 = COD_IVA)) .AND. (DES_ART <> ('*** COMMENTO ***'))
      IVA1   = COD_IVA
      IMPO1  = IMPO1+IMPONIB
      IMPOS1 = IMPOS1 + IMPOSTA
   ELSE
      IF ((IVA2 = SPACE(3)) .OR. (IVA2 = COD_IVA))  .AND. (DES_ART <> ('*** COMMENTO ***'))
         IVA2   = COD_IVA
         IMPO2  = IMPO2+IMPONIB
         IMPOS2 = IMPOS2 + IMPOSTA
      ELSE
         IF ((IVA3 = SPACE(3)) .OR. (IVA3 = COD_IVA)) .AND. (DES_ART <> ('*** COMMENTO ***'))
            IVA3   = COD_IVA
            IMPO3  = IMPO3+IMPONIB
            IMPOS3 = IMPOS3 + IMPOSTA
         ELSE
            IF ((IVA4 = SPACE(3)) .OR. (IVA4 = COD_IVA)) .AND. (DES_ART <> ('*** COMMENTO ***'))
               IVA4   = COD_IVA
               IMPO4  = IMPO4+IMPONIB
               IMPOS4 = IMPOS4 + IMPOSTA
            ELSE
               IF ((IVA5 = SPACE(3)) .OR. (IVA5 = COD_IVA)) .AND. (DES_ART <> ('*** COMMENTO ***'))
                  IVA5   = COD_IVA
                  IMPO5  = IMPO5+IMPONIB
                  IMPOS5 = IMPOS5 + IMPOSTA
               ENDIF
            ENDIF
         ENDIF
      ENDIF
   ENDIF


   SELECT &_dettagli
   SKIP +1

ENDDO



IMPO_MAGG = ROUND(IMPO_MAGG,2)
IMPOS_MAGG = ROUND(IMPOS_MAGG,2)

V_SPESE = M.ORD_SPBOLL + M.ORD_SPTRAS

PUB_ALIQ = CERCA_IVA_DEFAULT(_dettagli,"ALIQUOTA")  && ERASMO - 21/09/2011

IF !_ESENZI      					&& SOLO SE NON IN ESENZIONE
   *V_IMPSP = V_SPESE * (VAL(PUB_IVA)/100)
   V_IMPSP = V_SPESE * (PUB_ALIQ/100)  && ERASMO - 21/09/2011
ELSE
   V_IMPSP = 0		 				&& ESENTE
ENDIF


*** SERGIO - 08/12/2008
*** SE TUTTI GLI ARTICOLI SONO OMAGGIO DEVO TOGLIERE IL POLIECO DAL TOTALE IMPONIBILE E IMPOSTA E LI SOMMA NEL TOTALE IMPONIBILE , IMPOSTA OMAGGIO
*** QUESTA REGOLA E' APPLICATA ALLE SOLE FATTURE IN QUANTO POI IL COSTO E L'IVA SONO A CARICO DELL'AZIENDA
   IF _CNT_OMAGGI = _CNT_ARTICOLI && ARTICOLO OMAGGIO
       IMPO1  = IMPO1  - _IMPONIBILE_POLIECO
       IMPOS1 = IMPOS1 - _IMPOSTA_POLIECO
       M.T_OMAGGIO = M.T_OMAGGIO + _IMPONIBILE_POLIECO
       M.I_OMAGGIO = M.I_OMAGGIO + _IMPOSTA_POLIECO
   ENDIF
*** SERGIO - 08/12/2008


*  inizio
* ----------------------------------------------------------------------------
* -->> inserisco l'iva delle spese(20%) sulle ive al 20
FOR HF=1 TO 5
  _IMPO ="IMPO"+ALLTRIM(STR(HF))
  _IMPOS="IMPOS"+ALLTRIM(STR(HF))
  IF &_IMPO=0
  	LOOP
  ENDIF	
  *IF ROUND((&_IMPOS/&_IMPO)*100,0)=VAL(PUB_IVA)
  IF ROUND((&_IMPOS/&_IMPO)*100,0)=PUB_ALIQ  && ERASMO - 21/09/2011
     &_IMPOS=&_IMPOS+V_IMPSP
     EXIT
  ENDIF
NEXT

IMPOS1		=	ROUND((IMPOS1+.0000),2)
IMPOS2		=	ROUND((IMPOS2+.0000),2)
IMPOS3		=	ROUND((IMPOS3+.0000),2)
IMPOS4		=	ROUND((IMPOS4+.0000),2)		
IMPOS5		=	ROUND((IMPOS5+.0000),2)

M.T_IMPONIB = IMPO1 + IMPO2 + IMPO3 + IMPO4 + IMPO5
M.T_IMPOSTA = IMPOS1 + IMPOS2 + IMPOS3 + IMPOS4 + IMPOS5

*  fine
* ----------------------------------------------------------

**=> ERASMO - INIZIO 09/01/2012
M.T_IMPONIB = M.T_IMPONIB + IMPO_MAGG
M.T_IMPOSTA = M.T_IMPOSTA + IMPOS_MAGG
**=> ERASMO - FINE 09/01/2012

M.T_IMPONIB = M.T_IMPONIB + V_SPESE

M.T_VALORE  = M.T_IMPONIB + M.T_IMPOSTA - MATPUBX
*** SIMONE - 10/10/2008	
*** SE TUTTI GLI ARTICOLI SONO PUBBLICITARI DEVO TOGLIERE IL POLIECO DAL TOTALE
*** QUESTA REGOLA E' APPLICATA ALLE SOLE FATTURE
IF _CNT_PUBBLI = _CNT_ARTICOLI
	M.T_VALORE  = M.T_IMPONIB + M.T_IMPOSTA - MATPUBX - PUB_TOTPOLIECO
ENDIF
*** SIMONE - 10/10/2008	

*!*	CALCOLO ENPACL
IF _ENPACLPERC <> 0
	M.T_ENPACL = ROUND((M.T_IMPONIB * _ENPACLPERC ) / 100,2)
	M.T_IMPONIB = M.T_IMPONIB + M.T_ENPACL  && SOMMO A IMPONIBILE IL CONTRIBUTO DEL 2% ENPACL
	_IVA_ENPACL = (M.T_ENPACL * NUM_ALIQ) / 100
	_IVA_ENPACL	=  ROUND((_IVA_ENPACL+.0000),2)
	M.T_IMPOSTA = M.T_IMPOSTA + _IVA_ENPACL
	M.T_VALORE  = M.T_VALORE  + M.T_ENPACL + _IVA_ENPACL && SOMMO A TOTALE DOCUMENTO IL CONTRIBUTO DEL 2% ENPACL + RELATIVA IVA
ENDIF


*!*	CALCOLO RA
IF _RAPERC   <> 0
	_IMPONIBILE_NO_ENPACL = ( M.T_IMPONIB - M.T_ENPACL )
	M.T_RA = ROUND((_IMPONIBILE_NO_ENPACL * _RAPERC   ) / 100,2)
	M.T_NETTO = M.T_VALORE - M.T_RA
ENDIF


M.ORD_VALORE = M.T_VALORE

IVA1   = ""
IVA2   = ""
IVA3   = ""
IVA4   = ""
IVA5   = ""
IMPO1  = 0
IMPO2  = 0
IMPO3  = 0
IMPO4  = 0
IMPO5  = 0
IMPOS1 = 0
IMPOS2 = 0
IMPOS3 = 0
IMPOS4 = 0
IMPOS5 = 0

*!*	IF M.T_IMPONIB <> 0
   IF _OKAGG
      v_sql = 'select * from ' + _testata + ' where taggancio = ?_chiave'
      IF !ExecRW(v_sql,_testata,"R")
         return
      ENDIF
      SELECT &_testata
      IF reccount() <> 0
         REPLACE ORD_VALORE WITH M.ORD_VALORE
      ENDIF
      IF !ExecRW("",_testata,"W")
         return
      ENDIF
   ENDIF
*!*	ENDIF



**SERPRO?
** CREAZIONE CURSORE RIEPILOGO FATTURE CON PROVVIGIONI RIGA MODIFICATE
IF ESISTE_RIGA_CON_PROVVIGIONE_MODIFICATA

	SELECT CU_DETTAGLI_PROVVIGIONI
	GO TOP


	SELECT ORD_GN,ORD_TIPOGN,ORD_PRORIG, SUM(ORD_VALORE) AS ORD_VALORE, SUM(ORD_COSTOTR) AS ORD_COSTOTR FROM CU_DETTAGLI_PROVVIGIONI GROUP BY ORD_GN,ORD_TIPOGN,ORD_PRORIG ORDER BY ORD_GN,ORD_TIPOGN,ORD_PRORIG INTO CURSOR CU_RIE_PROVVIGIONI

	SELECT CU_RIE_PROVVIGIONI
	GO TOP
	_CONTA_DETTAGLI_PROVVIGIONI  = 0
	_TOTALE_ARTICOLI_VARI        = 0
	DO WHILE .NOT. EOF()
	
	    IF EMPTY(ALLTRIM(ORD_GN))
	     	_TOTALE_ARTICOLI_VARI = _TOTALE_ARTICOLI_VARI + ORD_VALORE
            SELECT CU_RIE_PROVVIGIONI
            SKIP +1
            LOOP
	    ENDIF

	
	    _CONTA_DETTAGLI_PROVVIGIONI = _CONTA_DETTAGLI_PROVVIGIONI + 1
	
		SELECT CU_RIE_PROVVIGIONI
		SKIP +1
		
	ENDDO
	
	
	__TES_COSTTR    = 0
	__COMPENSA      = 0
	IF _CONTA_DETTAGLI_PROVVIGIONI > 0
		__TES_COSTTR2   = TES_COSTTR / _CONTA_DETTAGLI_PROVVIGIONI
		__TES_COSTTR 	= ROUND((__TES_COSTTR2),2)
	ENDIF
	


	SELECT CU_RIE_PROVVIGIONI
	INDEX ON ORD_VALORE TAG I_VALORE DESC ADDITIVE
	GO TOP
		
	
    ** SPALMA IL COSTO DEL TRASPORTO SE ESISTE NEL CURSORE DI RIEPILOGO E SOMMA IL VALORE DEGLI ARTICOLI VARI
	_SOMMA_TRASPORTO_RIPARTITO       = 0
	SOLO_RECORD_CON_IMPORTO_PIU_ALTO = .T.
	SELECT CU_RIE_PROVVIGIONI
	GO TOP
	
    DO WHILE .NOT.EOF()

	   IF EMPTY(ALLTRIM(ORD_GN))
	     	SELECT CU_RIE_PROVVIGIONI
	     	SKIP +1
	     	LOOP
	   ENDIF
	
	
	   IF SOLO_RECORD_CON_IMPORTO_PIU_ALTO
	   		__ORD_VALORE 	= ORD_VALORE + _TOTALE_ARTICOLI_VARI 		&& SOMMA IL TOTALE DEGLI ARTICOLI VARI COME BOLLI,FINITURA C,FINITURA P ALTRI ..... AL VALORE
	   		SOLO_RECORD_CON_IMPORTO_PIU_ALTO = .F.
	   ELSE
	   		__ORD_VALORE 	= ORD_VALORE
	   ENDIF	
	
       __ORD_GN 		= ORD_GN
       __ORD_TIPOGN 	= ORD_TIPOGN
       __ORD_PRORIG     = ORD_PRORIG

       SELECT CU_RIEPILOGO_PROVVIGIONI

       APPEND BLANK
       REPLACE ORD_GN		WITH __ORD_GN
       REPLACE ORD_TIPOGN	WITH __ORD_TIPOGN
       REPLACE ORD_PRORIG   WITH __ORD_PRORIG
       REPLACE ORD_VALORE	WITH __ORD_VALORE
       REPLACE ORD_COSTOTR 	WITH __TES_COSTTR

	   _SOMMA_TRASPORTO_RIPARTITO = _SOMMA_TRASPORTO_RIPARTITO + __TES_COSTTR

       SELECT CU_RIE_PROVVIGIONI
       SKIP +1

    ENDDO

    IF _SOMMA_TRASPORTO_RIPARTITO > TES_COSTTR
      DIFFERENZA_TRASPORTO = _SOMMA_TRASPORTO_RIPARTITO - TES_COSTTR
      SELECT CU_RIEPILOGO_PROVVIGIONI
      GO TOP
      REPLACE ORD_COSTOTR 	WITH ORD_COSTOTR - DIFFERENZA_TRASPORTO  && TOGLIE EVENTUALE CENTESIMO DI COMPENSAZIONE SUL TOTALE DEL TRASPORTO RIPARTITO
    ELSE
      DIFFERENZA_TRASPORTO = TES_COSTTR  - _SOMMA_TRASPORTO_RIPARTITO
      SELECT CU_RIEPILOGO_PROVVIGIONI
      GO TOP
      REPLACE ORD_COSTOTR 	WITH ORD_COSTOTR + DIFFERENZA_TRASPORTO  && AGGIUNGE EVENTUALE CENTESIMO DI COMPENSAZIONE SUL TOTALE DEL TRASPORTO RIPARTITO
    ENDIF



ENDIF

	
	
SELECT(SWS)

RETURN(.T.)


