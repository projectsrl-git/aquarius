******************************
FUNCTION CERCAORIGINE_OLD
******************************
**--> RITORNA I/IL CODICE ARTICOLO (COMPRENSIVO DI LOTTO) DELLA
**--> BOBINA DI FILM NUDO DA CUI DERIVA, E RICHIEDE COME PARAMETRI
**--> IL NUMERO DI LOTTO DA RICERCARE E IL NUMERO DI ARTICOLI MAX

PARAMETERS _NUMLOT,_NUMART


VAR_NUMLOT = STR(_NUMLOT,8,0)
VAR_NUMART = _NUMART
VAR_RITORN = ""
V_TIPO = 1 && TRACCIABILITA' A RITROSO

****CREAZIONE CURSORI RICORSIVI U_LOT*** PER TRACCIABILITA A RITROSO
RELEASE V_LAST_VALID_CUR
PUBLIC V_LAST_VALID_CUR
V_LAST_VALID_CUR = ""

RELEASE V_IND_N,V_LIVELL
PUBLIC  V_IND_N,V_LIVELL

V_LIVELL = 1

V_IND_N  = 1
V_IND_X  = STR(V_IND_N,3,0)
PUB_LNO  = 3
V_IND_X  = TRC(PUB_LNO,ALLTRIM(V_IND_X))
V_NOMCUR = "U_LOT" + V_IND_X

x_soci = "lot_codsoc = '" + PUB_CODSOC + "'"
x_codi = "lot_nlofin = '" + VAR_NUMLOT + "'"
x_cond = x_soci + " and " + x_codi
cSql   = "select * from u_lot_ri where " + x_cond

IF !ExecCommand(cSql,"U_LOT_RI")
   return(.f.)
ENDIF

CREATE CURSOR &V_NOMCUR (LOT_CODSOC C(2),  LOT_NLOINI N(10,0), LOT_DATOPE C(10), ;
                         LOT_ORAOPE C(8),  LOT_MAGSCA C(6),    LOT_MAGCAR C(6),  ;
                         LOT_CODCAU C(4),  LOT_NLOFIN N(10,0), LOT_CODMAT C(5),  ;
                         LOT_DESMAT C(60), LOT_LIVELL N(2,0))
SELECT U_LOT_RI
GO TOP

SCAN
   SCATTER MEMVAR
   SELECT &V_NOMCUR
   APPEND BLANK
   GATHER MEMVAR
   REPLACE LOT_LIVELL WITH V_LIVELL
ENDSCAN

SELECT &V_NOMCUR
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   &&FASE ASCENDENTE PROCEDURA RICORSIVA
   DO PRG\CICLO WITH V_TIPO
   &&FASE DISCENDENTE PROCEDURA RICORSIVA

   SELECT &V_NOMCUR
   V_LIVELL = LOT_LIVELL
   SKIP +1

ENDDO

****CREAZIONE CURSORE GENERALE DI TRACCIABILITA'
CREATE CURSOR CUR_LOT_RI (LOT_CODSOC C(2),  LOT_NLOINI N(10,0), LOT_DATOPE C(10), ;
                          LOT_ORAOPE C(8),  LOT_MAGSCA C(6),    LOT_MAGCAR C(6),  ;
                          LOT_CODCAU C(4),  LOT_NLOFIN N(10,0), LOT_CODMAT C(5),  ;
                          LOT_DESMAT C(60), LOT_LIVELL N(2,0))

INDEX ON STR(LOT_LIVELL,8,0)+STR(LOT_NLOINI,8,0)+STR(LOT_NLOFIN,8,0)+RIBALTA2(LOT_DATOPE)+LOT_ORAOPE TAG D_LIVELL DESCENDING ADDITIVE

SELECT CUR_LOT_RI
ZAP

V_IND_F = 1

DO WHILE .T.

   IF V_IND_F > V_IND_N
      EXIT
   ENDIF

   V_IND_X = STR(V_IND_F,3,0)
   PUB_LNO = 3
   V_IND_X = TRC(PUB_LNO,ALLTRIM(V_IND_X))
   V_NOMCUR = "U_LOT" + V_IND_X

   SELECT &V_NOMCUR
   GO TOP

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      SCATTER MEMVAR MEMO

      SELECT CUR_LOT_RI
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE LOT_DATOPE WITH RIBALTA2(LOT_DATOPE)
      ****ASSEGNAZIONE CODICE MATERIALE E DESCRIZIONE
      SWS = SELECT()
      __V_NRLINT = LOT_NLOFIN
      x_codi = "mag_nrlint = " + STR(__V_NRLINT,8,0)
      x_cond = x_codi
      cSql = "select * from u_mag_gg where " + x_cond + " order by mag_datagg desc"
      IF !ExecCommand(cSql,"U_MAG_GG")
         return(.f.)
      ENDIF
      SELECT U_MAG_GG
      GO TOP
      __V_CODMAT = MAG_CODMAT
      __V_DESMAT = MAG_DESMAT
      SELECT(SWS)
      REPLACE LOT_CODMAT WITH __V_CODMAT
      REPLACE LOT_DESMAT WITH __V_DESMAT
      ****FINE ASSEGNAZIONE CODICE MATERIALE E DESCRIZIONE

      SELECT &V_NOMCUR
      SKIP +1

   ENDDO

   V_IND_F = V_IND_F + 1

ENDDO

****CANCELLAZIONE RECORD DUPLICATI IN CUR_LOT_RI
SELECT CUR_LOT_RI
GO TOP

DO WHILE .T.

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF EOF()
      EXIT
   ENDIF

   V_POSITION = RECNO()
   V_DOPPIONE = 0

   _V_LOT_NLOINI = LOT_NLOINI
   _V_LOT_DATOPE = LOT_DATOPE
   _V_LOT_ORAOPE = LOT_ORAOPE
   _V_LOT_MAGSCA = LOT_MAGSCA
   _V_LOT_MAGCAR = LOT_MAGCAR
   _V_LOT_CODMAT = LOT_CODMAT
   _V_LOT_DESMAT = LOT_DESMAT
   _V_LOT_CODCAU = LOT_CODCAU
   _V_LOT_NLOFIN = LOT_NLOFIN

   SELECT CUR_LOT_RI
   GO TOP

   DO WHILE .T.
	
      IF DELETED()
         SKIP +1
         LOOP
      ENDIF

      IF EOF()
         EXIT
      ENDIF
	
      IF (LOT_NLOINI = _V_LOT_NLOINI .AND. LOT_DATOPE = _V_LOT_DATOPE .AND. LOT_ORAOPE = _V_LOT_ORAOPE .AND.;
          LOT_MAGSCA = _V_LOT_MAGSCA .AND. LOT_MAGCAR = _V_LOT_MAGCAR .AND. LOT_CODMAT = _V_LOT_CODMAT .AND.;
          LOT_DESMAT = _V_LOT_DESMAT .AND. LOT_CODCAU = _V_LOT_CODCAU .AND. LOT_NLOFIN = _V_LOT_NLOFIN)

         V_DOPPIONE = V_DOPPIONE + 1

      ENDIF

	  IF V_DOPPIONE = 2
	     DELETE
	     V_DOPPIONE = V_DOPPIONE - 1
	  ENDIF
	
      SKIP +1
	
   ENDDO
	
   SELECT CUR_LOT_RI
   GO V_POSITION
   SKIP +1
	
ENDDO
****FINE CANCELLAZIONE RECORD DUPLICATI IN CUR_LOT_RI


****CANCELLAZIONE RECORD COMPONENTI COLLA
SELECT CUR_LOT_RI
GO TOP
DELETE FOR SUBSTR(ALLTRIM(STR(LOT_NLOINI,8,0)),1,1) = "2" .OR. SUBSTR(ALLTRIM(STR(LOT_NLOFIN,8,0)),1,1) = "2"
****FINE CANCELLAZIONE RECORD COMPONENTI COLLA

SELECT CUR_LOT_RI
SET ORDER TO D_LIVELL
GO TOP
_V_LIVELLO = LOT_LIVELL && LIVELLO PIU' ALTO
****CANCELLAZIONE RECORD CHE NON SIANO QUELLI CON LIVELLO PIU' ALTO (DEVONO RESTARE SOLO QUELLI DELLE BOBINE ORIGINARIE)
DELETE FOR LOT_LIVELL <> _V_LIVELLO

V_INDICE = 1
SELECT CUR_LOT_RI
GO TOP

DO WHILE .T.

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF EOF()
      EXIT
   ENDIF

   IF V_INDICE > VAR_NUMART
      EXIT
   ENDIF

   __V_NRLINT = LOT_NLOFIN
   x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "mag_nrlint = " + STR(__V_NRLINT,8,0)
   x_cond = x_soci + " and " + x_codi
   cSql = "select * from u_mag_gg where " + x_cond + " order by mag_datagg desc"
   IF !ExecCommand(cSql,"U_MAG_GG")
      return(.f.)
   ENDIF
   SELECT U_MAG_GG
   GO TOP
   __V_CODART = MAG_CODART
   __V_CODMAT = MAG_CODMAT

   IF __V_CODMAT = '004'  && NON CONSIDERO LE COMPONENTI COLLA SL
   ELSE
      VAR_RITORN = VAR_RITORN + __V_CODART
      V_INDICE = V_INDICE + 1
   ENDIF

   SELECT CUR_LOT_RI
   SKIP +1

ENDDO

_RIT = ALLTRIM(VAR_RITORN)

RETURN(_RIT)


