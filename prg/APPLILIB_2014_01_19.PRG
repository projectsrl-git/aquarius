****************************************
FUNCTION OK_LISCALT
****************************************
**
**  DETERMINA IL PREZZO DI VENDITA PER CLIENTE/ARTICOLO/ALTEZZA/LUNGHEZZA O TIPOLOGIA DEL LISTINO IN FUNZIONE DI PUB_LIS0A:
**
**
**  	- PER CLIENTE/ARTICOLO/ALTEZZA/LUNGHEZZA
**		- PER CLIENTE/ARTICOLO/ALTEZZA/LUNGHEZZA/DATA VALIDITA' DAL
**						
**  RITORNA :
**
**		-  PUB_LISOK = .T. PER ABILITARE L'INSERIMENTO O MENO NELL'ARCHIVIO DEI LISTINI
**		-  PUB_PREZZO/M.ORD_PREZZO : CONTENENTE L'ULTIMO PREZZO DI LISTINO VALIDO
**								 	 PER DETERMINARE SE IL PREZZO E' VALIDO CONSIDERA :
**
**									 IL FLAG DI VALIDITA' = SI
**									 		- SE L'UTENTE STA CODIFICANDO I LISTINI FUTURI FINO
**											  A CHE NON HA ABILITATO IL LISTINO TRAMITE APPOSITA	
**											  PROCEDURA IL PREZZO NON E' CONSIDERATO
**
**									 PARTE DALL'ULTIMO PREZZO QUINDI IN VIGORE   	
**					
**

PARA _SOC,_CLI,_ART,_DTDO,_ALTE,_TIPO,_LUNG

_NUM_PARAM = PARAMETERS()
IF _NUM_PARAM = 6
   _LUNG = 0
ENDIF

IF SUBSTR(_DTDO,3,1) = '/'
   _DTDO = RIBALTA2(_DTDO)
ENDIF

S_S = STR(SELECT())

IF !PUB_LIS0A       && GESTIONE LISTINO PER SOLO CLIENTE/ARTICOLO/ALTEZZA/LUNGHEZZA E NO VERSIONE

   _TROV  = .F.
   x_soci = "lis_codsoc = '" + PUB_CODSOC + "'"
   x_clie = "lis_codcli = '" + ALLTRIM(_CLI) + "'"
   x_arti = "lis_codart = '" + ALLTRIM(_ART) + "'"
   x_cond = x_soci + " and " + x_clie + " and " + x_arti
   Csql   = "select * from u_lis_al where " + x_cond + " order by lis_codsoc,lis_codcli,lis_codart,lis_alteda"
   IF !ExecCommand(cSql,"cur_u_lis_al")
      return(.f.)
   ENDIF
   SELECT CUR_U_LIS_AL
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF _ALTE >= LIS_ALTEDA .AND. _ALTE <= LIS_ALTEAL
         IF _LUNG = 0 .AND. LIS_LUNGDA = 0 .AND. LIS_LUNGAL = 0
         ELSE
            IF LIS_LUNGDA = 0 .AND. LIS_LUNGAL = 0 .AND. _LUNG > 0
               M.ORD_PREZZO = LIS_PREZZO
               M.ORD_SC1    = LIS_SC1
               M.ORD_SC2    = LIS_SC2
               M.ORD_SC3    = LIS_SC3
               M.ORD_PRORIG = LIS_PROVVI
               M.ORD_PUBBLI = LIS_PUBBLI
               _TROV = .T.
               SKIP +1  && CONTINUA A CERCARE NEL CASO IN CUI TROVI UN LISTINO CON RANGE LUNGHEZZE VALORIZZATO
               LOOP
            ELSE
               IF LIS_LUNGDA > 0 .AND. LIS_LUNGAL > 0 .AND. _LUNG = 0
                  SKIP +1
                  LOOP
               ELSE
                  IF _LUNG >= LIS_LUNGDA .AND. _LUNG <= LIS_LUNGAL
                  ELSE
                     SKIP +1
                     LOOP
                  ENDIF
               ENDIF
            ENDIF
         ENDIF
         M.ORD_PREZZO = LIS_PREZZO
         M.ORD_SC1    = LIS_SC1
	     M.ORD_SC2    = LIS_SC2
	     M.ORD_SC3    = LIS_SC3
 	     M.ORD_PRORIG = LIS_PROVVI			  			
         M.ORD_PUBBLI = LIS_PUBBLI
         _TROV        = .T.
         EXIT
      ENDIF
      SKIP +1
   ENDDO

   SELECT &S_S
   RETURN

ENDIF

* GESTIONE VERSIONE LISTINO RICERCANDO LA VERSIONE IN VIGORE SU BASE
* DATA DI VALIDITA' DEL LISTINO STESSO
* EFFETTUA UNA SELECT PER CLIENTE/ARTICOLO/ALTEZZA/LUNGHEZZA/DATA DOCUMENTO : SE ESISTE
*													   	                    : PRELEVA IL PREZZO + SCONTI

RELEASE _OLDLIS
PUBLIC  _OLDLIS
_OLDLIS = .F.

_TROV  = .F.
x_soci = "lis_codsoc = '" + PUB_CODSOC + "'"
x_clie = "lis_codcli = '" + ALLTRIM(_CLI) + "'"
x_arti = "lis_codart = '" + ALLTRIM(_ART) + "'"
x_cond = x_soci + " and " + x_clie + " and " + x_arti
Csql   = "select * from u_lis_al where " + x_cond + " order by lis_codsoc,lis_codcli,lis_codart,lis_alteda,lis_datlis"
IF !ExecCommand(cSql,"cur_u_lis_al")
   return(.f.)
ENDIF
SELECT CUR_U_LIS_AL
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF _DTDO >= LIS_DATLIS .AND. _DTDO <= LIS_ALLIST
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF _ALTE >= LIS_ALTEDA .AND. _ALTE <= LIS_ALTEAL
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF _LUNG = 0 .AND. LIS_LUNGDA = 0 .AND. LIS_LUNGAL = 0
   ELSE
      IF LIS_LUNGDA = 0 .AND. LIS_LUNGAL = 0 .AND. _LUNG > 0
         _OLDLIS = .T.
         M.ORD_PREZZO = LIS_PREZZO
         M.ORD_SC1    = LIS_SC1
         M.ORD_SC2    = LIS_SC2
         M.ORD_SC3    = LIS_SC3
         M.ORD_PRORIG = LIS_PROVVI
         M.ORD_PUBBLI = LIS_PUBBLI
         _TROV = .T.
         SKIP +1  && CONTINUA A CERCARE NEL CASO IN CUI TROVI UN LISTINO CON RANGE LUNGHEZZE VALORIZZATO
         LOOP
      ELSE
         IF LIS_LUNGDA > 0 .AND. LIS_LUNGAL > 0 .AND. _LUNG = 0
            SKIP +1
            LOOP
         ELSE
            IF _LUNG >= LIS_LUNGDA .AND. _LUNG <= LIS_LUNGAL
               _OLDLIS = .F.
            ELSE
               SKIP +1
               LOOP
            ENDIF
         ENDIF
      ENDIF
   ENDIF

   M.ORD_PREZZO = LIS_PREZZO
   M.ORD_SC1    = LIS_SC1
   M.ORD_SC2    = LIS_SC2
   M.ORD_SC3    = LIS_SC3
   M.ORD_PRORIG = LIS_PROVVI
   M.ORD_PUBBLI = LIS_PUBBLI
   _TROV = .T.

   IF LIS_LUNGDA = 0 .AND. LIS_LUNGAL = 0
      _OLDLIS = .T.
   ENDIF

   EXIT

ENDDO

IF _TROV
   PUB_LISOK = .F.				&& NON E' POSSIBILE INSERIRE IL LISTINO
ELSE
   PUB_LISOK = .T.				&& E' POSSIBILE INSERIRE IL LISTINO
ENDIF

SELECT &S_S

RETURN


****************************************
FUNCTION CERCA_NUMERO_DATA_PRG
****************************************
PARAMETERS _VV_CODART

_XX_CODART = _VV_CODART
_XX_NUMPRG = SPACE(06)
_XX_DATPRG = SPACE(10)
_XX_AMGPRG = SPACE(10)
_XX_RIT    = SPACE(26)

SWWS = SELECT()

x_cint = "nud_codint = '" + _XX_CODART + "'"
x_cond = x_cint
cSql   = "SELECT TOP 1 * FROM U_PRG_RT WHERE " + x_cond + " order by sta_amgprg desc"
IF !ExecCommand(cSql,"U_PRG_RT")
   return(.f.)
ENDIF
SELECT U_PRG_RT
GO TOP
IF EOF()
   x_cint = "nud_codint = '" + _XX_CODART + "'"
   x_cond = x_cint
   cSql   = "SELECT TOP 1 * FROM U_PRG_RR WHERE " + x_cond + " order by sta_amgprg desc"
   IF !ExecCommand(cSql,"U_PRG_RR")
      return(.f.)
   ENDIF
   SELECT U_PRG_RR
   GO TOP
   IF EOF()
      x_cint = "nud_codint = '" + _XX_CODART + "'"
      x_cond = x_cint
      cSql   = "SELECT TOP 1 * FROM U_PRG_RA WHERE " + x_cond + " order by sta_amgprg desc"
      IF !ExecCommand(cSql,"U_PRG_RA")
         return(.f.)
      ENDIF
      SELECT U_PRG_RA
      GO TOP
      IF EOF()
         x_cint = "nud_codint = '" + _XX_CODART + "'"
         x_cond = x_cint
         cSql   = "SELECT TOP 1 * FROM U_AVA_TG WHERE " + x_cond + " order by ava_datava desc"
         IF !ExecCommand(cSql,"U_AVA_TG")
            return(.f.)
         ENDIF
         SELECT U_AVA_TG
         GO TOP
         IF EOF()
            x_cint = "nud_codint = '" + _XX_CODART + "'"
            x_cond = x_cint
            cSql   = "SELECT TOP 1 * FROM U_AVA_RI WHERE " + x_cond + " order by ava_datava desc"
            IF !ExecCommand(cSql,"U_AVA_RI")
               return(.f.)
            ENDIF
            SELECT U_AVA_RI
            GO TOP
            IF EOF()
               x_cint = "nud_codint = '" + _XX_CODART + "'"
               x_cond = x_cint
               cSql   = "SELECT TOP 1 * FROM U_AVA_SP WHERE " + x_cond + " order by ava_datava desc"
               IF !ExecCommand(cSql,"U_AVA_SP")
                  return(.f.)
               ENDIF
               SELECT U_AVA_SP
               GO TOP
               IF EOF()
               ELSE
                  _XX_NUMPRG = STA_NUMPRG
                  _XX_DATPRG = STA_DATPRG
                  _XX_AMGPRG = STA_AMGPRG
               ENDIF
            ELSE
               _XX_NUMPRG = STA_NUMPRG
               _XX_DATPRG = STA_DATPRG
               _XX_AMGPRG = STA_AMGPRG
            ENDIF
         ELSE
            _XX_NUMPRG = STA_NUMPRG
            _XX_DATPRG = STA_DATPRG
            _XX_AMGPRG = STA_AMGPRG
         ENDIF
      ELSE
         _XX_NUMPRG = STA_NUMPRG
         _XX_DATPRG = STA_DATPRG
         _XX_AMGPRG = STA_AMGPRG
      ENDIF
   ELSE
      _XX_NUMPRG = STA_NUMPRG
      _XX_DATPRG = STA_DATPRG
      _XX_AMGPRG = STA_AMGPRG
   ENDIF
ELSE
   _XX_NUMPRG = STA_NUMPRG
   _XX_DATPRG = STA_DATPRG
   _XX_AMGPRG = STA_AMGPRG
ENDIF

IF EMPTY(ALLTRIM(_XX_NUMPRG))
   _XX_RIT = SPACE(26)
ELSE
   _XX_RIT = STA_NUMPRG + STA_DATPRG + STA_AMGPRG
ENDIF

SELECT (SWWS)

RETURN _XX_RIT


