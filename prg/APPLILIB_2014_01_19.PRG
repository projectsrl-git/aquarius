**************************************************************************
  PROCEDURE CALCRIA  && CALCOLA IL VALORE DEL DOCUMENTO CON R.A.
**************************************************************************

SWS=SELECT()

M.T_IMPONIX 	= 0
M.T_CONTRIB 	= 0
M.T_IMPONIB 	= 0
M.T_IMPOSTA 	= 0
M.T_VALORE  	= 0
M.T_RITACC  	= 0
M.T_IMPSPESE   	= 0
M.T_IVASPESE   	= 0
M.T_IMPCASPR   	= 0
M.T_IVACASPR	= 0

v_seek	 = 'RIA'+M.ORD_CODRAC
v_chiave = "codice"
IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
   SELECT CUR_PARA
   VRA  = VAL(SUBSTR(LIBERA,1,6))
   VRAI = VAL(SUBSTR(LIBERA,9,6))
ELSE
   VRA  = 0
   VRAI = 100
ENDIF

SELECT CU_RIA_DD
GO TOP


DO WHILE .NOT. EOF()

   IF DELETED()
      SELECT CU_RIA_DD
      SKIP +1
      LOOP
   ENDIF


   CIVA = ORD_IVA

   v_seek	= 'IVA'+CIVA
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      VIVA = VAL(SUBSTR(LIBERA,1,3))
   ELSE
      VIVA = 0
   ENDIF

   SELECT CU_RIA_DD

*!*	   IF ORD_SPESE <> "S"
*!*		   M.T_IMPONIX = M.T_IMPONIX + ORD_VALORE
*!*		   M.T_IMPONIB = M.T_IMPONIB + ORD_VALORE + (ORD_VALORE * (M.ORD_PERCCO / 100))
*!*		   M.T_IMPOSTA = M.T_IMPOSTA + ((ORD_VALORE + (ORD_VALORE * (M.ORD_PERCCO / 100))) * (VIVA/100))
*!*		   M.T_CONTRIB = M.T_CONTRIB + (ORD_VALORE * (M.ORD_PERCCO / 100))
*!*	   ELSE
*!*		   M.T_IMPSPESE   	= M.T_IMPSPESE + ORD_VALORE
*!*		   M.T_IVASPESE		= M.T_IVASPESE + (ORD_VALORE  * (VIVA/100))
*!*	   ENDIF


   DO CASE
   		
   		CASE ALLTRIM(ORD_SPESE) = "S"
			   M.T_IMPSPESE   	= M.T_IMPSPESE + ORD_VALORE
			   M.T_IVASPESE		= M.T_IVASPESE + (ORD_VALORE  * (VIVA/100))
   		
   		CASE ALLTRIM(ORD_SPESE) = "C"
			   M.T_IMPCASPR   	= M.T_IMPCASPR + ORD_VALORE
			   M.T_IVACASPR		= M.T_IVACASPR + (ORD_VALORE  * (VIVA/100))
   		
   		OTHERWISE		
   		
   		
   			IF ORD_NOCALC4PE = "N"								&& NON CALCOLA LA % ENPACL/CONPAIO O VERSAMENTO 4%
			   _ORD_PERCCO = 0
			   M.T_IMPONIX = M.T_IMPONIX + ORD_VALORE
			   M.T_IMPONIB = M.T_IMPONIB + ORD_VALORE + (ORD_VALORE * (_ORD_PERCCO / 100))
			   M.T_IMPOSTA = M.T_IMPOSTA + ((ORD_VALORE + (ORD_VALORE * (_ORD_PERCCO / 100))) * (VIVA/100))
			   M.T_CONTRIB = M.T_CONTRIB + (ORD_VALORE * (_ORD_PERCCO / 100))
   			ELSE
			   M.T_IMPONIX = M.T_IMPONIX + ORD_VALORE
			   M.T_IMPONIB = M.T_IMPONIB + ORD_VALORE + (ORD_VALORE * (M.ORD_PERCCO / 100))
			   M.T_IMPOSTA = M.T_IMPOSTA + ((ORD_VALORE + (ORD_VALORE * (M.ORD_PERCCO / 100))) * (VIVA/100))
			   M.T_CONTRIB = M.T_CONTRIB + (ORD_VALORE * (M.ORD_PERCCO / 100))
  			ENDIF
  			
  			
   ENDCASE



   SELECT CU_RIA_DD
   SKIP +1

ENDDO




IF M.ORD_PERENA = 0									&& PROFESSIONISTI NORMALI

    __IMPONIBILE_ENASARCO_RICALCOLATO       = 0

	** CASSA PREVIDENZA
	M.T_IMPCASPR = ROUND(M.T_IMPCASPR,2)
	M.ORD_IMPCASPR = M.T_IMPCASPR

	M.T_IVACASPR = ROUND(M.T_IVACASPR,2)
	M.ORD_IVACASPR = M.T_IVACASPR


	** SPESE
	M.T_IMPSPESE = ROUND(M.T_IMPSPESE,2)
	M.ORD_IMPSPESE = M.T_IMPSPESE

	M.T_IVASPESE = ROUND(M.T_IVASPESE,2)
	M.ORD_IVASPESE = M.T_IVASPESE


	** COMPENSO + C.N.P.A.I.A. - SPESE  = IMPONIBILE
	____IMPONIB		= M.T_IMPONIB                    && SONO GIA' ESCLUSE LE SPESE E LA CASSA PREVIDENZA IN FASE DI SOMMATORIA SOPRA
	M.T_IMPONIB		= ROUND(____IMPONIB,2)
	M.ORD_TOTIMP 	= M.T_IMPONIB


	** IMPONIBILE + C.N.P.A.I.A. - SPESE = IMPOSTA
	M.T_IMPOSTA  	= ROUND(M.T_IMPOSTA,2)
	M.ORD_TOTIVA 	= M.T_IMPOSTA


	** IMPONIBILE - C.N.P.A.I.A. = RITENUTA ACCONTO
	V_IMPNET   		= ROUND((M.T_IMPONIX - (M.T_IMPONIX * (100 - VRAI)) / 100),2)
	M.T_RITACC 		= ROUND(((V_IMPNET * VRA) /100),2)
	M.ORD_TOTRAC 	= M.T_RITACC


	** (IMPONIBILE + C.N.P.A.I.A. + SPESE + CASSA PREVIDENZA + IMPOSTA) - RITENUTA ACCONTO = TOTALE FATTURA DA PAGARE AL FORNITORE
	M.T_CONTRIB		= ROUND(M.T_CONTRIB,2)
	M.T_VALORE 		= (M.T_IMPONIB + M.T_IMPSPESE + M.T_IVASPESE + M.T_IMPCASPR + M.T_IVACASPR + M.T_IMPOSTA) - M.T_RITACC
	M.ORD_TOTFAT 	= M.T_VALORE

	M.ORD_TOTCON = M.T_CONTRIB


ELSE												&& AGENTI DI VENDITA CON ENASARCO



	** SPESE
	M.T_IMPSPESE = ROUND(M.T_IMPSPESE,2)
	M.ORD_IMPSPESE = M.T_IMPSPESE

	M.T_IVASPESE = ROUND(M.T_IVASPESE,2)
	M.ORD_IVASPESE = M.T_IVASPESE

	** IMPONIBILE
	____IMPONIB		= M.T_IMPONIB                    && SONO GIA' ESCLUSE LE SPESE IN FASE DI SOMMATORIA SOPRA
	M.T_IMPONIB		= ROUND(____IMPONIB,2)
	M.ORD_TOTIMP 	= M.T_IMPONIB
    __IMPONIBILE_ENASARCO_RICALCOLATO       = M.ORD_TOTIMP

	** IMPOSTA
	M.T_IMPOSTA  	= ROUND(M.T_IMPOSTA,2)
	M.ORD_TOTIVA 	= M.T_IMPOSTA

	** RITENUTA ACCONTO CALCOLATA SULL' x PERCENTO DELL'IMPONIBILE
	V_IMPNET   		= ROUND((M.T_IMPONIX - (M.T_IMPONIX * (100 - VRAI)) / 100),2)
	M.T_RITACC 		= ROUND(((V_IMPNET * VRA) /100),2)
	M.ORD_TOTRAC 	= M.T_RITACC

    ** VERIFICA SE VIENE SUPERATO IL MASSIMALE
*!*	    IF ___FATTOT > ___MASSIM						

*!*		    ___TOTFAT_NEW   = ___FATTOT + M.T_IMPONIB
*!*		    ___DIFFERENZA   = ___MASSIM - ___TOTFAT_NEW
*!*		
*!*		    IF ___DIFFERENZA < 0			&& HO SUPERATO IL MASSIMALE

*!*				__IMPONIBILE_ENASARCO_RICALCOLATO       =  M.T_IMPONIB - ABS(___DIFFERENZA)

*!*		    ENDIF

	
*!*		ENDIF



	** ENASARCO
	M.T_TOTENA 		= ROUND(((__IMPONIBILE_ENASARCO_RICALCOLATO * M.ORD_PERENA) /100),2)
	M.ORD_TOTENA 	= M.T_TOTENA
	M.ORD_IMPENA 	= __IMPONIBILE_ENASARCO_RICALCOLATO


	** (IMPONIBILE  + SPESE + IMPOSTA) - RITENUTA ACCONTO = TOTALE FATTURA DA PAGARE AL FORNITORE
	M.T_VALORE 		= (M.T_IMPONIB + M.T_IMPSPESE + M.T_IVASPESE + M.T_IMPOSTA) - M.T_RITACC - M.T_TOTENA
	M.ORD_TOTFAT 	= M.T_VALORE

	M.ORD_TOTCON = 0

ENDIF

SELECT(SWS)

RETURN

