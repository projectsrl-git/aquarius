PROCEDURE INTEMAG0
*******************

**--> GENERAZIONE CURSORE PER MOVIMENTI DI MAGAZZINO

CREATE CURSOR TABMOVI (STA_CODMAG C(06),   STA_DESMAG C(40), ;
					   STA_NUMDOC C(15),   STA_DATDOC C(10), ;
					   STA_TOP C(03),      STA_CODICE C(10), ;
					   STA_DESTOP C(40),   STA_DATREG C(10), ;  	
                       STA_QUANTI N(11,2), STA_SEGNO  C(01), ;
                       STA_RAGSOC C(30),   STA_CODFOR C(10), ;
                       STA_DESFOR C(50),   STA_SPESSO N(5,0), ;
                       STA_ALTEZZ N(5,0),  STA_LUNGHE N(6,0), ;
                       STA_NRLINT N(10,0))
SELECT TABMOVI
GO TOP

x_soci = "mov_codsoc = '" + PUB_CODSOC + "'"
x_tmat = "mov_codmat = mov_codmat"
x_colo = "mov_codcol = mov_codcol"
x_spes = "mov_spesso = mov_spesso"
x_alte = "mov_altezz = mov_altezz"
x_lung = "mov_lunghe = mov_lunghe"
x_arti = IIF(EMPTY(ALLTRIM(_V_CODART)),"mov_anaart = mov_anaart","mov_anaart = '" + ALLTRIM(_V_CODART) + "'" )
x_nrli = "mov_nrlint = mov_nrlint"
x_maga = IIF(EMPTY(ALLTRIM(_V_CODMAG)),"mov_codmag = mov_codmag","mov_codmag = '" + ALLTRIM(_V_CODMAG) + "'" )
x_forn = "mov_fornit = mov_fornit"
x_nide = "mov_numide = mov_numide"
x_anno = "mov_anno = mov_anno"
x_ndoc = "mov_numdoc = mov_numdoc"
x_ddoc = "mov_dtdocu = mov_dtdocu"
x_ctop = "mov_top = mov_top"
x_data = "mov_dtregi >= '" + RIBALTA2(_V_DATADA) + "'"
x_cond = x_soci + " and " + x_tmat + " and " + x_colo + " and " + x_spes + " and " + x_alte
x_cond = x_cond + " and " + x_lung + " and " + x_arti + " and " + x_nrli + " and " + x_maga
x_cond = x_cond + " and " + x_forn + " and " + x_nide + " and " + x_anno + " and " + x_ndoc
x_cond = x_cond + " and " + x_ddoc + " and " + x_ctop + " and " + x_data
Csql   = "select * from u_mag_mo where " + x_cond + " order by mov_codsoc,mov_codmag,mov_dtregi"
IF !ExecCommand(cSql,"cur_movimenti")
   return(.f.)
ENDIF
SELECT CUR_MOVIMENTI
DELETE FOR MOV_DTREGI > _V_DATAAL

SELECT CUR_MOVIMENTI
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   V_CODMAG = MOV_CODMAG
   V_NUMDOC = MOV_NUMDOC
   V_DATDOC = RIBALTA2(MOV_DTDOCU)
   V_TOP    = MOV_TOP
   V_DATREG = RIBALTA2(MOV_DTREGI)
   V_QUANTI = MOV_QTAMOV
   V_DESMAG = SPACE(40)
   V_COORD  = MOV_COORD
   V_CODFOR = MOV_FORNIT
   V_DESFOR = MOV_DESFOR
   V_SPESSO = MOV_SPESSO
   V_ALTEZZ = MOV_ALTEZZ
   V_LUNGHE = MOV_LUNGHE
   V_NRLINT = MOV_NRLINT

   v_seek	= 'MAG'+V_CODMAG
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      V_DESMAG = DESCRI
   ELSE
      V_DESMAG = SPACE(40)
   ENDIF

   v_seek	= "TOP"+V_TOP
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      V_DESTOP = DESCRI
      IF SUBSTR(LIBERA,1,1) = "C"
         V_SEGNO = "+"
      ELSE
         V_SEGNO = "-"
      ENDIF
   ELSE
      V_DESTOP = 'TOP SCONOSCIUTO'
      V_SEGNO  = ' '
   ENDIF

   SELECT TABMOVI
   APPEND BLANK
   REPLACE STA_CODMAG WITH V_CODMAG
   REPLACE STA_DESMAG WITH V_DESMAG
   REPLACE STA_NUMDOC WITH V_NUMDOC
   REPLACE STA_DATDOC WITH V_DATDOC
   REPLACE STA_TOP    WITH V_TOP
   REPLACE STA_DESTOP WITH V_DESTOP
*!*	   REPLACE STA_CODICE WITH V_CODICE
*!*	   REPLACE STA_RAGSOC WITH V_RAGSOC
   REPLACE STA_DATREG WITH V_DATREG
   REPLACE STA_QUANTI WITH V_QUANTI
   REPLACE STA_SEGNO  WITH V_SEGNO
   REPLACE STA_CODFOR WITH V_CODFOR
   REPLACE STA_DESFOR WITH V_DESFOR

   REPLACE STA_SPESSO WITH V_SPESSO
   REPLACE STA_ALTEZZ WITH V_ALTEZZ
   REPLACE STA_LUNGHE WITH V_LUNGHE
   REPLACE STA_NRLINT WITH V_NRLINT

   SELECT CUR_MOVIMENTI
   SKIP +1

ENDDO

RETURN


