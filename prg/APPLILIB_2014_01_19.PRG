*********************************
FUNCTION CALCOLA_TOTALE_DOCUMENTO
*********************************
*
* ELABORA I DOCUMENTI PER CALCOLARE IL TOTALE DEL DOCUMENTO IN FUNZIONE DEL SET DI RECORD
*
* __DOCUMENTO      : DDT
* __TIPO_DOCUMENTO : SE "DDT_NON_FATTURATI" LA FUNZIONE OTTIENE IL TOTALE DELLE DDT NON ANCORA FATTURATE PER CLIENTE
*
* __DOCUMENTO      : FAT
* __TIPO_DOCUMENTO : SE "FAT_NON_CONTABILIZZATE" LA FUNZIONE OTTIENE IL TOTALE DELLE FAT NON ANCORA CONTABILIZZATE PER CLIENTE
*                  : ALTRIMENTI CALCOLA IL TOTALE DI TUTTE LE FATTURE PER CLIENTE
*
*



PARA __DOCUMENTO,__TIPO_DOCUMENTO,__CODCLI

DO CASE

   CASE __DOCUMENTO= "DDT"


 		___IMPONIB = 0
		___IMPOSTA = 0
		___VALORE  = 0
			


   		IF __TIPO_DOCUMENTO  = "DDT_NON_FATTURATI"
   			_FLBOL= " "
   		ELSE
   			_FLBOL= "S"   		
   		ENDIF

        x_soci = "ord_codsoc = '" + PUB_CODSOC + "'"
        x_clie = "ord_codcli = '" + ALLTRIM(__CODCLI) + "'"
        x_flbo = "ord_flbol = '" + _FLBOL + "'" 				&& SCARTA BOLLE GIA' FATTURATE
        x_cond = x_soci + " and " + x_flbo
        x_cond = x_cond + " and " + x_clie
        Csql = "select * from u_bol_tt where " + x_cond + " order by ord_codsoc,ord_datord,ord_numord"


		IF !ExecCommand(Csql,"CUBOL_TT")
           return(.f.)
        ENDIF

        SELECT CUBOL_TT
        GO TOP

	    DO WHILE .T.
	
	
		   	IF EOF()
		      EXIT
		   	ENDIF
		
		   	IF DELETED()
		      SELECT CUBOL_TT
		      SKIP +1
		      LOOP
	       	ENDIF
	
		   	IF ORD_FORNI						&& SCARTA BOLLE A FORNITORI
		      SELECT CUBOL_TT
		      SKIP +1
		      LOOP
		   	ENDIF
		
           	_CAUS = ORD_CAUS
           	IF !_BOLDAFAT(_CAUS)				&& SCARTA BOLLE NON DA FATTURARE
              SELECT CUBOL_TT
	 	      SKIP +1
	 	      LOOP
	 	  	ENDIF
	 	
 	       	SCATTER MEMVAR MEMO



 			M.T_IMPONIB = 0
			M.T_IMPOSTA = 0
			M.T_VALORE  = 0
		
			=CALCdocge1(M.TAGGANCIO,"bolhookd","u_bol_dd","u_bol_tt",.F.) && CALCOLA IL VALORE DEL DOCUMENTO SU DBASE EFFETTIVO SENZA CONTROAGGIORNARE
		
 			___IMPONIB = ___IMPONIB + M.T_IMPONIB
			___IMPOSTA = ___IMPOSTA + M.T_IMPOSTA
			___VALORE  = ___VALORE  + M.T_VALORE
			
			
			
			
		   SELECT CUBOL_TT
		   SKIP +1
		
		
		ENDDO

   CASE __DOCUMENTO= "FAT"


 		___IMPONIB = 0
		___IMPOSTA = 0
		___VALORE  = 0
			



        x_soci = "ord_codsoc = '" + PUB_CODSOC + "'"
        x_clie = "ord_codcli = '" + ALLTRIM(__CODCLI) + "'"


   		IF __TIPO_DOCUMENTO  = "FAT_NON_CONTABILIZZATE"
   			x_flcg = "ord_cge = 0"
   		ELSE
   			x_flcg = "ord_cge = 1" 		
   		ENDIF

        				
        x_cond = x_soci + " and " + x_flcg
        x_cond = x_cond + " and " + x_clie


        Csql = "select * from u_fat_tt where " + x_cond + " order by ord_codsoc,ord_datord,ord_numord"


		IF !ExecCommand(Csql,"CUFAT_TT")
           return(.f.)
        ENDIF

        SELECT CUFAT_TT
        GO TOP

	    DO WHILE .T.
	
	
		   	IF EOF()
		      EXIT
		   	ENDIF
		
		   	IF DELETED()
		      SELECT CUFAT_TT
		      SKIP +1
		      LOOP
	       	ENDIF
	
          	_CAUS = ORD_CAUS

 	       	SCATTER MEMVAR MEMO



 			M.T_IMPONIB = 0
			M.T_IMPOSTA = 0
			M.T_VALORE  = 0
		
			=CALCdocge1(M.TAGGANCIO,"fathookd","u_fat_dd","u_fat_tt",.F.) && CALCOLA IL VALORE DEL DOCUMENTO SU DBASE EFFETTIVO SENZA CONTROAGGIORNARE
		

           	IF _VERIFICASENOTACREDITO(_CAUS)				&& TRATTA NOTA CREDITO
	 			___IMPONIB = M.T_IMPONIB * -1
				___IMPOSTA = M.T_IMPOSTA * -1
				___VALORE  = M.T_VALORE  * -1
	 	  	ENDIF


 			___IMPONIB = ___IMPONIB + M.T_IMPONIB
			___IMPOSTA = ___IMPOSTA + M.T_IMPOSTA
			___VALORE  = ___VALORE  + M.T_VALORE
			
	 	
			
			
			
		   SELECT CUFAT_TT
		   SKIP +1
		
		
		ENDDO

        		
ENDCASE

RETURN


********************************
