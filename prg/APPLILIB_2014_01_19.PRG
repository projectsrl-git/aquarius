REPLACE WQTA   WITH 1
REPLACE TREE   WITH V_CODART
REPLACE WQTALL WITH 0
REPLACE WQTALY WITH 0

DO TROVA_QTAX WITH XXGRUPPO

SELECT WEXPLODE
PUN=RECCOUNT()
K=SPACE(0)

SELECT WEXPLODE
GO TOP
DELETE FOR WLIV > LIV_ESPLN ALL
GO TOP

DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF WLIV = 1
      XX_QTA  = WQTA * XXQTA
      XX_QTA1 = XX_QTA
      YY_QTA  = WQTA * YYQTA
      YY_QTA1 = YY_QTA
   ENDIF
   IF WLIV = 2
      XX_QTA  = WQTA * XX_QTA1
      XX_QTA2 = XX_QTA
      YY_QTA  = WQTA * YY_QTA1
      YY_QTA2 = YY_QTA
   ENDIF
   IF WLIV = 3
      XX_QTA  = WQTA * XX_QTA2
      XX_QTA3 = XX_QTA
      YY_QTA  = WQTA * YY_QTA2
      YY_QTA3 = YY_QTA
   ENDIF
   IF WLIV = 4
      XX_QTA  = WQTA * XX_QTA3
      XX_QTA4 = XX_QTA
      YY_QTA  = WQTA * YY_QTA3
      YY_QTA4 = YY_QTA
   ENDIF
   IF WLIV = 5
      XX_QTA  = WQTA * XX_QTA4
      XX_QTA5 = XX_QTA
      YY_QTA  = WQTA * YY_QTA4
      YY_QTA5 = YY_QTA
   ENDIF
   IF WLIV = 6
      XX_QTA  = WQTA * XX_QTA5
      XX_QTA6 = XX_QTA
      YY_QTA  = WQTA * YY_QTA5
      YY_QTA6 = YY_QTA
   ENDIF
   IF WLIV = 7
      XX_QTA  = WQTA * XX_QTA6
      XX_QTA7 = XX_QTA
      YY_QTA  = WQTA * YY_QTA6
      YY_QTA7 = YY_QTA
   ENDIF
   REPLACE WQTALL WITH XX_QTA
   REPLACE WQTALY WITH YY_QTA
   SELECT WEXPLODE
   SKIP +1
ENDDO

SELECT WEXPLODE
GO TOP

IF SI_VIDEO
	V_TIT="ESPLOSIONE GRUPPO - "+XXGRUPPO
	V_TES="ALBERO:TREE:32;Q.TA X 1:WQTA:13;Q.TA X N:WQTALL:13;DESCRIZIONE:WDES:25;PREZZO:WPRZ:10;COSTO:WCOS:10;TIPO:WTIP:1"
	=WSHOWDBF("WEXPLODE",V_TIT,V_TES)
ENDIF

RETURN

