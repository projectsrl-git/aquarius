	SELECT(_ACT_SELECT)  && ERASMO - 31/08/2012
	RETURN _RIT
ENDIF

_nNew_Scelta = VAL(RIGHT(_par_art1sc,1)) + (_par_nscelta - 1)
_cNew_Scelta = ALLTRIM(STR(_nNew_Scelta))
_art_Nscelta = SUBSTR(_par_art1sc,1,LEN(_par_art1sc) - 1) + _cNew_Scelta
**=> ERASMO - FINE 22/06/2012

