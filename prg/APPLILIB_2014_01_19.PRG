						PUB_PREZZO		= LIS_PREZZO
						M.ORD_PREZZO	= LIS_PREZZO
						_local_trovato= .T.
						RETURN
					ENDIF
				ENDIF
			**=> ERASMO - FINE 12/12/2011
			ENDIF


	CASE ___l_accesso = "ACCESSO-02"

			*!*	________________________________________________________________________3) accesso per tipo prodotto /spessore / gruppo colore (A/B/C/D/E/F/G)

			x_soci   = "lis_codsoc = '" + PUB_CODSOC + "'"
