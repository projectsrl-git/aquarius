V_SEEK = V_CDMAT + V_CDCOL + STR(V_MYMAG,3,0) + STR((V_ALMAG),5,0)

SELECT G_MAG_GG
SET ORDER TO I_GMAGG2
SEEK V_SEEK

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

