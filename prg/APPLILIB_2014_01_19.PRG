****************
FUNCTION CTRLQTA
****************
PARAMETERS _CODART,_QTA,_ALTEZZ,_LUNGHE,_SPESSO

IF _QTA = 0
   RETURN(.T.)
ENDIF

RELEASE W_CODART,W_QTA,W_ALTEZZ,W_LUNGHE,W_SPESSO,W_QTAMQ,W_QTAKG,W_DIFFE,W_PERTOL
PUBLIC  W_CODART,W_QTA,W_ALTEZZ,W_LUNGHE,W_SPESSO,W_QTAMQ,W_QTAKG,W_DIFFE,W_PERTOL
W_CODART = _CODART
W_QTA    = _QTA
W_ALTEZZ = _ALTEZZ
W_LUNGHE = _LUNGHE
W_SPESSO = _SPESSO
W_QTAMQ  = 0
W_QTAKG  = 0

W_QTAMQ = TROVA_MQ_DA_AL(W_ALTEZZ,W_LUNGHE,1)
W_QTAKG = TROVA_KG_DA_MQ(W_CODART,W_SPESSO,W_QTAMQ,1)

IF W_QTA > W_QTAKG
   W_DIFFE = W_QTA - W_QTAKG
ELSE
   W_DIFFE = W_QTAKG - W_QTA
ENDIF

x_codi = "codice = 'TPNACQ'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   W_PERTOL = 0
ELSE
   W_PERTOL = VAL(ALLTRIM(SUBSTR(LIBERA,1,6)))
ENDIF

W_VALTOL = W_QTAKG * W_PERTOL / 100

IF W_VALTOL < W_DIFFE
   _OK = .F.
ELSE
   _OK = .T.
ENDIF

RETURN(_OK)


