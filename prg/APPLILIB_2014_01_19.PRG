*=> Genero archivio delle altezze compatibili per gli acquisti
CREATE CURSOR CU_PRO_AL (MAG_BYPASS L(01), MAG_ALTEZZ N(05), MAG_QTAML N(10), MAG_SPESSO N(05))
Csql = "select * from u_pro_al order by alt_finudo desc"
IF !ExecCommand(Csql,"u_pro_al")
   return(.f.)
ENDIF
SELECT U_PRO_AL
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   FFF_FINUDO = ALT_FINUDO
   SELECT CU_PRO_AL
   APPEND BLANK
   REPLACE MAG_BYPASS WITH .F.
   REPLACE MAG_ALTEZZ WITH FFF_FINUDO
   REPLACE MAG_QTAML  WITH 1000000
   REPLACE MAG_SPESSO WITH 0
   SELECT U_PRO_AL
   SKIP +1
ENDDO

*=> ELABORO TUTTE LE RIGHE D'ORDINE SELEZIONATE PER LA PRODUZIONE IN SPALMATURA

SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL NUMERO DI BOBINE DA SPALMARE = 0
   IF ORD_NRBSPD > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   *=> BY-PASSO QUELLE RIGHE CHE HO GIA' ELABORATO
   IF ORD_CODMAC = 'SPS'
      SKIP +1
      LOOP
   ENDIF

   *=> BY-PASSO QUELLE RIGHE CHE NON DEVONO ESSERE SPALMATE (ORDINI DI FILM NUDO O SENZA DI.BA.)
   IF ORD_UM = 'KG' .OR. EMPTY(ALLTRIM(ORD_CDDIBA))
      SKIP +1
      LOOP
   ENDIF

   WAIT WINDOWS "PROGRAMMAZIONE DEI FABBISOGNI PER LA SPALMATURA : " + CHR(13) + ;
                "Stň elaborando l'articolo " + ORD_CODART + "Colore : " + ALLTRIM(ord_descol) + " Altezza : " + ALLTRIM(STR(ORD_ALTEZZ,5,0)) + " Lunghezza : " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + CHR(13) + ;
                "Nr.bob. : " + ALLTRIM(STR(ORD_NRBSPD,7,0)) + " Nr.Ordine : " + ORS_NUMORD + " del " + ORS_DATORD + " Cliente : " + ORS_RAGSOC NOWAIT

   SCATTER MEMVAR MEMO

   V_DIBA = M.ORD_CDDIBA

   *=> ACQUISISCO I PARAMETRI STANDARD PER LE CAPACITA PRODUTTIVE DELLE MACCHINE IN SPALMATURA

   V_ALMAFN = V_ALTMAX		&& ALTEZZA MASSIMA FILM NUDO IN INPUT
   V_ALMIFN = V_ALTMIN		&& ALTEZZA MINIMA FILM NUDO IN INPUT
   V_SCAABU = V_SCAMAX		&& PERCENTUALE DI SCARTO TOLLERATO SU ALTEZZA BOBINA IN INPUT
   V_LUMIFN = V_LUNMIN		&& LUNGHEZZA MINIMA FILM NUDO IN INPUT
   V_LUMAIN = V_LUNMAR		&& LUNGHEZZA MASSIMA FILM SPALMATO IN INPUT

   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL LEGAME CON LA MACCHINA DI PRODUZIONE SENZA ALTEZZA MAX FILM NUDO IN INPUT
   IF V_ALMAFN = 0
      SELECT CU_ORD_DL
      REPLACE ORD_CODMAC WITH 'SPS'
      SKIP +1
      LOOP
   ENDIF

   *=> Acquisizione dello spessore compatibile
   *=> - accedo con key = spessore del film ordinato
   *=> - acquisisco dalla tabella lo spessore del film nudo compatibile.
   x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
   x_tmat = "mic_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
   x_cond = x_spes + " and " + x_tmat
   Csql   = "select * from u_pro_my where " + x_cond
   IF !ExecCommand(Csql,"u_pro_my")
      return(.f.)
   ENDIF
   SELECT U_PRO_MY
   GO TOP
   IF EOF()
      x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
      x_tmat = "mic_codmat = SPACE(03)"
      x_cond = x_spes + " and " + x_tmat
      Csql   = "select * from u_pro_my where " + x_cond
      IF !ExecCommand(Csql,"u_pro_my")
         return(.f.)
      ENDIF
      SELECT U_PRO_MY
      GO TOP
      IF EOF()
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF
   ENDIF
   SCATTER MEMVAR

   *=> Forzatura degli spessori compatibili per una casistica di ordini particolari
   *=> utilizzo della famiglia G nei colori bianco o bianco/nero con spessore 80 o 100
   IF SUBSTR(V_DIBA,4,1) = 'G'
      IF M.ORD_CODCOL = 'BIA' .OR. M.ORD_CODCOL = 'B/N'
         IF M.ORD_SPESSO = 80
            M.MIC_SPESDA = 75
            M.MIC_SPESAL = 75
            M.MIC_SPEORD = 75
         ENDIF
         IF M.ORD_SPESSO = 100
            M.MIC_SPESDA = 90
            M.MIC_SPESAL = 90
            M.MIC_SPEORD = 75
         ENDIF
      ENDIF
   ENDIF

   SELECT CU_PRO_AL
   REPLACE MAG_SPESSO WITH M.MIC_SPEORD ALL

   V_TROV = .F.
   V_SCAR = .F.

   SELECT CU_PRO_AL
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      *=> By-passo le bobine gia' esaminate ma non idonee per il troppo sfrido calcolato
      IF MAG_BYPASS
         V_SCAR = .T.
         SKIP +1
         LOOP
      ENDIF
      V_TROV = .T.
      SCATTER MEMVAR MEMO
      EXIT
   ENDDO

   V_BYPASS = .F.

   *=> Test se č stata trovata giacenza compatibile con quanto ordinato
   IF V_TROV
      V_SCAR       = .F.
   ELSE
      *=> Se non č stata trovata la giacenza ma sono state by-passate delle bobine per troppo scarto,
      *=> la programmazione sulla bobina con minor scarto (altezza piů bassa) č possibile farla in base ad
      *=> un parametro gestito dall'utente (se NO non programma)
      IF __TOLL = 'NO'
         IF V_SCAR
            SELECT CU_PRO_AL
            REPLACE MAG_BYPASS WITH .F. ALL
         ENDIF
         SELECT CU_ORD_DL
         REPLACE ORD_CODMAC WITH 'SPS'
         SKIP +1
         LOOP
      ENDIF
      IF V_SCAR
         SELECT CU_PRO_AL
         IF MAG_BYPASS
            V_BYPASS = .T.
            V_TROV   = .T.
            REPLACE MAG_BYPASS WITH .F.
            SCATTER MEMVAR MEMO
         ELSE
            SKIP -1
            DO WHILE .T.
               IF BOF()
                  EXIT
               ENDIF
               IF MAG_BYPASS
                  Q_ALTEZZA = MAG_ALTEZZ - V_CIMOSA
                  *Q_ALTEZZA = Q_ALTEZZA - (V_TAGLIO * 2)
                  IF Q_ALTEZZA < M.ORD_ALTEZZ
                     SKIP -1
                     LOOP
                  ENDIF
                  V_BYPASS = .T.
                  V_TROV   = .T.
                  REPLACE MAG_BYPASS WITH .F.
                  SCATTER MEMVAR MEMO
                  EXIT
               ENDIF
               SKIP -1
            ENDDO
         ENDIF
      ENDIF
      IF V_TROV
      ELSE
         IF V_SCAR
            SELECT CU_PRO_AL
            REPLACE MAG_BYPASS WITH .F. ALL
         ENDIF
         SELECT CU_ORD_DL
         REPLACE ORD_CODMAC WITH 'SPS'
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   *=> Imposto l'altezza iniziale della bobina in giacenza togliendogli la cimosa (40 mm)
   *=> questo perchč le bobine di film nudo vengono caricate con l'altezza che prevede la cimosa,
   *=> mentre le bobine ordinate dai clienti sono al netto delle cimose
   V_ALTEZZA = M.MAG_ALTEZZ - V_CIMOSA
   *V_ALTEZZA = V_ALTEZZA - (V_TAGLIO * 2)
   V_LUNGHEZ = M.MAG_QTAML
   V_ACCBOBI = 0

   *=> Inizio loop di accoppiamento righe d'ordine con stessa lunghezza
   SELECT CU_ORD_DL
   V_LUNGORD = ORD_LUNGHE
   V_CODMATE = ORD_CODMAT
   V_CODCOLO = ORD_CODCOL
   V_CODSPES = ORD_SPESSO
   V_CODARTI = ORD_CODART
   V_CODDIBA = ORD_CDDIBA
   V_CILRETI = ORD_CILRET

   IF V_ALTEZZA < ORD_ALTEZZ			&& PROJECT 19/01/2005
      SELECT CU_PRO_AL
      REPLACE MAG_BYPASS WITH .T.
      SELECT CUR_SELEZIONE
      ZAP
      SELECT CU_ORD_DL
      SET ORDER TO I_PROGRA
      GO TOP
      LOOP
   ENDIF

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF ORD_NRBSPD > 0
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Determino la percentuale di tolleranza sul reso in altezza
      V_PERCNOUSATA = (V_ALTEZZA * 100) / (M.MAG_ALTEZZ - V_CIMOSA)
      IF V_PERCNOUSATA > V_SCAABU
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso tipo prodotto
      IF ORD_CODMAT = V_CODMATE
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia della stessa di.ba.
      IF ORD_CDDIBA = V_CODDIBA
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia con lo stesso cilindro retinato
      IF ORD_CILRET = V_CILRETI
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso prodotto
      IF ORD_CODART = V_CODARTI
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso colore
      IF ORD_CODCOL = V_CODCOLO
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso spessore
      IF ORD_SPESSO = V_CODSPES
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Verifico che la riga d'ordine che stň elaborando sia della stessa lunghezza
      IF ORD_LUNGHE = V_LUNGORD
      ELSE
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      *=> Determino quanti accoppiamenti riesco a fare con l'altezza della bobina in giacenza
      V_ACCOPPIA = INT((V_ALTEZZA / ORD_ALTEZZ))
      IF V_ACCOPPIA > ORD_NRBSPD
         V_ACCOPPIA = ORD_NRBSPD
      ENDIF

      *=> Determino l'altezza usata per l'accoppiamento  PROJECT 4/01/2005
      V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
      IF V_ACCOPPIA = 1
         V_ALTUSATA = V_ALTUSATA
      ELSE
         V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
      ENDIF

      IF V_ALTUSATA > V_ALTEZZA
         V_ACCOPPIA = V_ACCOPPIA - 1
         V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
         V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
      ENDIF

      *=> by-passo le righe che non riescono ad essere evasi con l'altezza della bobina in giacenza
      IF V_ALTUSATA = 0
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF

      M.MAG_SPESSO = M.MIC_SPEORD

      SELECT CU_ORD_DL
      SCATTER MEMVAR MEMO

      *=> Scrivo in un cursore di appoggio le righe d'ordine che riesco a programmare
      SELECT CUR_SELEZIONE
      APPEND BLANK
      REPLACE SEL_UNIQUE WITH M.ID_UNIQUE
      REPLACE SEL_CODART WITH M.ORD_CODART
      REPLACE SEL_DESART WITH M.ORD_DESART
      REPLACE SEL_CODCLI WITH M.ORS_CODCLI
      REPLACE SEL_RAGSOC WITH M.ORS_RAGSOC
      REPLACE SEL_NUMORD WITH M.ORS_NUMORD
      REPLACE SEL_DATORD WITH M.ORS_DATORD
      REPLACE SEL_CODCOL WITH M.ORD_CODCOL
      REPLACE SEL_DESCOL WITH M.ORD_DESCOL
      REPLACE SEL_CODMAT WITH M.ORD_CODMAT
      REPLACE SEL_DESMAT WITH M.ORD_DESMAT
      REPLACE SEL_SPESSO WITH M.ORD_SPESSO
      REPLACE SEL_ALTEZZ WITH M.ORD_ALTEZZ
      REPLACE SEL_LUNGHE WITH M.ORD_LUNGHE
      REPLACE SEL_BOBORD WITH M.ORD_NRBSPD
      REPLACE SEL_QTAORD WITH M.ORD_QTASPD
      REPLACE SEL_SPEMAG WITH M.MAG_SPESSO
      REPLACE SEL_ALTMAG WITH M.MAG_ALTEZZ
      REPLACE SEL_LUNMAG WITH M.MAG_QTAML
      REPLACE SEL_ACCOPP WITH V_ACCOPPIA
      REPLACE SEL_BOBACC WITH INT((SEL_BOBORD / SEL_ACCOPP))
      REPLACE SEL_BOBPRG WITH 0
      REPLACE SEL_QTAPRG WITH 0
      REPLACE SEL_CDDIBA WITH V_DIBA
      REPLACE SEL_SCARTO WITH V_SCAR
      REPLACE SEL_CODSYS WITH M.ORD_CODSYS
      REPLACE SEL_CILRET WITH M.ORD_CILRET

      *=> Rilevo il numero di bobine piů basso (l'accoppiamento deve avvenire per stessa altezza e stesso
      *=> numero di bobine da programmare

      IF V_ACCBOBI = 0
         V_ACCBOBI = SEL_BOBACC
      ENDIF

      IF SEL_BOBACC < V_ACCBOBI
         V_ACCBOBI = SEL_BOBACC
      ENDIF

      *=> Determino la nuova altezza con cui si devono confrontare gli altri ordini diminuendola di quella usata

      V_ALTEZZA = V_ALTEZZA - V_ALTUSATA

      SELECT CU_ORD_DL
      SKIP +1

   ENDDO

   SELECT CUR_SELEZIONE
   GO TOP
   IF EOF()
   ELSE
      IF V_BYPASS
      ELSE
         *=> Determino la percentuale di tolleranza sul reso in altezza
         V_PERCNOUSATA = (V_ALTEZZA * 100) / (M.MAG_ALTEZZ - V_CIMOSA)
         IF V_PERCNOUSATA > V_SCAABU
            SELECT CU_PRO_AL
            REPLACE MAG_BYPASS WITH .T.
            SELECT CUR_SELEZIONE
            ZAP
            SELECT CU_ORD_DL
            SET ORDER TO I_PROGRA
            GO TOP
            LOOP
         ENDIF
      ENDIF
   ENDIF

   *=> Riprendo in esame il cursore provvisorio con le righe d'ordine che sono riuscito ad accoppiare
   *=> per determinerne le esatte quantitŕ

   V_PROGRE = V_PROGRE + 1

   SELECT CUR_SELEZIONE
   GO TOP

   *=> calcolo il numero massimo di bobine che riuscirei a spalmare con la lunghezza della bobina in giacenza
   IF EOF()
   ELSE
      V_MAX_BOB_SPALM = INT((V_LUNGHEZ / V_LUNGORD))
      IF V_ACCBOBI > V_MAX_BOB_SPALM
         V_ACCBOBI = V_MAX_BOB_SPALM
      ENDIF
   ENDIF

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      *=> Determino il numero di bobine e la quantitŕ in MQ da programmare per la singola riga d'ordine
      REPLACE SEL_BOBPRG WITH V_ACCBOBI * SEL_ACCOPP
      REPLACE SEL_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTEZZ,SEL_LUNGHE,SEL_BOBPRG)
      SELECT CUR_SELEZIONE
      SCATTER MEMVAR MEMO

      *=> Accedo alle righe d'ordine selezionate dall'utente per aggiornarne le quantitŕ programmate
      SELECT CU_ORD_DL
      SET ORDER TO I_CODSYS	&& PROJECT 13/11/04
      SEEK M.SEL_CODSYS		&& PROJECT 13/11/04
      IF FOUND()
         REPLACE ORD_NRBSPD WITH ORD_NRBSPD - M.SEL_BOBPRG
         REPLACE ORD_QTASPD WITH ORD_QTASPD - M.SEL_QTAPRG
         REPLACE ORD_NRBOBX WITH ORD_NRBOBX + M.SEL_BOBPRG
         REPLACE ORD_QUANTX WITH ORD_QUANTX + M.SEL_QTAPRG
         REPLACE ORD_NRBOBO WITH 0
         REPLACE ORD_QUANTO WITH 0
      ENDIF

      W_QTAKG = TROVA_KG_DA_MQ(M.SEL_CODART,M.SEL_SPESSO,M.SEL_QTAPRG,1)

      *=> Scrivo su un nuovo cursore le righe d'ordine che sono riuscito ad accoppiare con le quantitŕ programmate
      SELECT CUR_SPALMATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_PROGRE WITH V_PROGRE
      REPLACE SEL_CODMAC WITH 'SPS'
      REPLACE SEL_DESMAC WITH 'SPS'
      REPLACE SEL_SCARTO WITH V_SCAR
      REPLACE SEL_ALTCOM WITH 99999 - SEL_ALTMAG		&& ALTEZZA COMPLEMENTATA A 99999 PER SORT ALTEZZA DISCENDENTE

      SELECT CUR_SELEZIONE
      SKIP +1

   ENDDO

   SELECT CU_PRO_AL
   REPLACE MAG_BYPASS WITH .F. ALL

   SELECT CUR_SELEZIONE
   ZAP

   SELECT CU_ORD_DL
   SET ORDER TO I_PROGRA
   GO TOP

ENDDO

SELECT CUR_SPALMATURA
INDEX ON STR(SEL_CILRET,3,0) + SEL_CDDIBA + STR(SEL_ALTCOM,5,0) + SEL_CODART + STR(SEL_PROGRE,6,0) TAG I_ORDRIN ADDITIVE
SET ORDER TO I_ORDRIN
GO TOP

=DEFPUB(SELECT())
SCATTER MEMVAR MEMO BLANK
HH=AFIELDS(TRANSITO)
CREATE CURSOR RIN_SPALMATURA FROM ARRAY TRANSITO

SELECT CUR_SPALMATURA
V_PROGRE = 1
V_PR     = SEL_PROGRE
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   SCATTER MEMVAR MEMO
   IF SEL_PROGRE = V_PR
      SELECT RIN_SPALMATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_PROGRE WITH V_PROGRE
   ELSE
      V_PROGRE = V_PROGRE + 1
      V_PR     = SEL_PROGRE
      LOOP
   ENDIF
   SELECT CUR_SPALMATURA
   SKIP +1
ENDDO
SELECT CUR_SPALMATURA
ZAP
SELECT RIN_SPALMATURA
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   SCATTER MEMVAR MEMO
   SELECT CUR_SPALMATURA
   APPEND BLANK
   GATHER MEMVAR MEMO
   SELECT RIN_SPALMATURA
   SKIP +1
ENDDO

V_PRIMA = .T.

SELECT CUR_SPALMATURA
INDEX ON STR(SEL_CILRET,3,0) + SEL_CDDIBA + STR(SEL_ALTCOM,5,0) + SEL_CODART + STR(SEL_PROGRE,6,0) TAG I_ORDRIN ADDITIVE
SET ORDER TO I_ORDRIN
GO TOP
IF EOF()
ELSE

	DO WHILE .T.

	   IF EOF()
	      V_SEEK = '1' + M.SEL_CODART+M.SEL_CODCOL+M.SEL_CODMAT+STR(M.SEL_SPEMAG,3,0)+STR(M.SEL_ALTMAG,5,0)+M.SEL_CDDIBA+STR(M.SEL_CILRET,3,0)
	      SELECT CUR_FABBISOGNI
	      SET ORDER TO I_FABBIS
	      SEEK V_SEEK
	      IF FOUND()
	      ELSE
	         APPEND BLANK
	         REPLACE FAB_TIPART WITH '1'
	         REPLACE FAB_CODART WITH M.SEL_CODART
	         REPLACE FAB_DESART WITH M.SEL_DESART
	         REPLACE FAB_CODCOL WITH M.SEL_CODCOL
	         REPLACE FAB_DESCOL WITH M.SEL_DESCOL
	         REPLACE FAB_CODMAT WITH M.SEL_CODMAT
	         REPLACE FAB_DESMAT WITH M.SEL_DESMAT
	         REPLACE FAB_SPESSO WITH M.SEL_SPEMAG
	         REPLACE FAB_ALTEZZ WITH M.SEL_ALTMAG
	         REPLACE FAB_CDDIBA WITH M.SEL_CDDIBA
	         REPLACE FAB_CILRET WITH M.SEL_CILRET
	         REPLACE FAB_LUNGHE WITH 0
	         REPLACE FAB_NUMBOB WITH 1
	         REPLACE FAB_QTAMQ  WITH 0
	         REPLACE FAB_QTAKG  WITH 0
	         REPLACE FAB_QTAML  WITH 0
             REPLACE FAB_CODIMB WITH SPACE(03)
	         REPLACE FAB_DESIMB WITH SPACE(50)
	         REPLACE FAB_SCORMI WITH 0
	         REPLACE FAB_LOTMIN WITH 0
	         REPLACE FAB_UNITAM WITH 'MQ'
	      ENDIF
	      REPLACE FAB_LUNGHE WITH FAB_LUNGHE + ROUND(((M.SEL_BOBPRG / M.SEL_ACCOPP) * SEL_LUNGHE),0)
	      REPLACE FAB_QTAML  WITH FAB_LUNGHE
	      REPLACE FAB_QTAMQ  WITH FAB_QTAMQ + TROVA_MQ_DA_AL(FAB_ALTEZZ,FAB_LUNGHE,1)
	      REPLACE FAB_QTAKG  WITH FAB_QTAKG + TROVA_KG_DA_MQ(FAB_CODART,FAB_SPESSO,FAB_QTAMQ,1)
	      EXIT
	   ENDIF

	   IF V_PRIMA
	      V_PRIMA = .F.
	      V_CILRET = SEL_CILRET
	      V_CDDIBA = SEL_CDDIBA
	      V_ALTCOM = SEL_ALTCOM
	      V_CODART = SEL_CODART
	      V_PROGRE = SEL_PROGRE
	   ENDIF
	
	   IF SEL_CILRET = V_CILRET .AND. SEL_CDDIBA = V_CDDIBA .AND. SEL_ALTCOM = V_ALTCOM .AND. SEL_CODART = V_CODART .AND. SEL_PROGRE = V_PROGRE
	   ELSE
	      V_SEEK = '1'+M.SEL_CODART+M.SEL_CODCOL+M.SEL_CODMAT+STR(M.SEL_SPEMAG,3,0)+STR(M.SEL_ALTMAG,5,0)+M.SEL_CDDIBA+STR(M.SEL_CILRET,3,0)
	      SELECT CUR_FABBISOGNI
	      SET ORDER TO I_FABBIS
	      SEEK V_SEEK
	      IF FOUND()
	      ELSE
	         APPEND BLANK
	         REPLACE FAB_TIPART WITH '1'
	         REPLACE FAB_CODART WITH M.SEL_CODART
	         REPLACE FAB_DESART WITH M.SEL_DESART
	         REPLACE FAB_CODCOL WITH M.SEL_CODCOL
	         REPLACE FAB_DESCOL WITH M.SEL_DESCOL
	         REPLACE FAB_CODMAT WITH M.SEL_CODMAT
	         REPLACE FAB_DESMAT WITH M.SEL_DESMAT
	         REPLACE FAB_SPESSO WITH M.SEL_SPEMAG
	         REPLACE FAB_ALTEZZ WITH M.SEL_ALTMAG
	         REPLACE FAB_CDDIBA WITH M.SEL_CDDIBA
	         REPLACE FAB_CILRET WITH M.SEL_CILRET
	         REPLACE FAB_LUNGHE WITH 0
	         REPLACE FAB_NUMBOB WITH 1
	         REPLACE FAB_QTAMQ  WITH 0
	         REPLACE FAB_QTAKG  WITH 0
	         REPLACE FAB_QTAML  WITH 0
             REPLACE FAB_CODIMB WITH SPACE(03)
	         REPLACE FAB_DESIMB WITH SPACE(50)
	         REPLACE FAB_SCORMI WITH 0
	         REPLACE FAB_LOTMIN WITH 0
	         REPLACE FAB_UNITAM WITH 'MQ'
	      ENDIF
	      REPLACE FAB_LUNGHE WITH FAB_LUNGHE + ROUND(((M.SEL_BOBPRG / M.SEL_ACCOPP) * SEL_LUNGHE),0)
	      REPLACE FAB_QTAML  WITH FAB_LUNGHE
	      REPLACE FAB_QTAMQ  WITH FAB_QTAMQ + TROVA_MQ_DA_AL(FAB_ALTEZZ,FAB_LUNGHE,1)
	      REPLACE FAB_QTAKG  WITH FAB_QTAKG + TROVA_KG_DA_MQ(FAB_CODART,FAB_SPESSO,FAB_QTAMQ,1)
	      V_PRIMA = .T.
          SELECT CUR_SPALMATURA
	      LOOP
	   ENDIF
	
	   SCATTER MEMVAR MEMO
	
	   SELECT CUR_SPALMATURA
	   SKIP +1
	
	ENDDO
ENDIF


CREATE CURSOR CUR_SELEZIONE (SEL_CDDIBA C(16), SEL_CODCOL C(03), SEL_DESCOL C(30), SEL_CODMAT C(03), SEL_DESMAT C(30),     ;
                             SEL_SPESSO N(05), SEL_ALTEZZ N(05), SEL_LUNGHE N(06))

CREATE CURSOR CUR_SALAMESCOLE (SEL_CODART C(16),   SEL_DESART C(50),   SEL_CDDIBA C(16),   SEL_DSDIBA C(50),   ;
                               SEL_UNITAM C(03),   SEL_QTAGIA N(16,6), SEL_QTANEC N(16,6), SEL_QTADOR N(16,6), ;
                               SEL_SCORMI N(16,6), SEL_CODIMB C(03),   SEL_DESIMB C(50),   SEL_LOTMIN N(12,2), ;
                               SEL_LIVELL N(10,0), SEL_QTADIB N(16,6), SEL_PROGRE N(06))

CREATE CURSOR CURS_SALAMESCOLE (SEL_CODART C(16),   SEL_DESART C(50),   SEL_CDDIBA C(16),   SEL_DSDIBA C(50),   ;
                                SEL_UNITAM C(03),   SEL_QTAGIA N(16,6), SEL_QTANEC N(16,6), SEL_QTADOR N(16,6), ;
                                SEL_SCORMI N(16,6), SEL_CODIMB C(03),   SEL_DESIMB C(50),   SEL_LOTMIN N(12,2), ;
                                SEL_LIVELL N(10,0), SEL_QTADIB N(16,6), SEL_PROGRE N(06))
INDEX ON SEL_CODART TAG I_INDICE1 ADDITIVE

RELEASE V_QTAMQS,V_UNITAM,V_SCORMI,V_CODIMB,V_DESIMB,V_LOTMIN,V_PROGRE,V_CDDIBA,V_CPADRE,V_DPADRE,V_ALT,V_REC,V_LUXPRG
PUBLIC  V_QTAMQS,V_UNITAM,V_SCORMI,V_CODIMB,V_DESIMB,V_LOTMIN,V_PROGRE,V_CDDIBA,V_CPADRE,V_DPADRE,V_ALT,V_REC,V_LUXPRG
V_QTAMQS = 0
V_UNITAM = SPACE(03)
V_SCORMI = 0
V_CODIMB = SPACE(03)
V_DESIMB = SPACE(50)
V_LOTMIN = 0
V_PROGRE = 0
V_CDDIBA = SPACE(16)
V_CPADRE = SPACE(16)
V_DPADRE = SPACE(50)
V_ALT    = 0
V_REC    = 0
V_LUXPRG = 0

*=> Elaborazione del file di spalmatura programmato per calcolarne le relative qtŕ di adesivo da applicare per la
*=> sala mescole

SELECT CUR_FABBISOGNI
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   V_LUXPRG = FAB_LUNGHE
   V_ALT    = FAB_ALTEZZ - V_CIMOSA
   V_CDDIBA = FAB_CDDIBA
   V_PROGRE = 0

   DO SPALMATURA_SALAMESCOLE

   SELECT CUR_FABBISOGNI
   SKIP +1

ENDDO

*=> ELABORAZIONE CURSORE SELEZIONE PER DETERMINARE LE QTA' NECESSARIE AL PROGRAMMA DI SALA MESCOLE

SELECT CUR_SALAMESCOLE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF SEL_LIVELL = 1
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   SELECT CURS_SALAMESCOLE
   SET ORDER TO I_INDICE1
   SEEK M.SEL_CODART
   IF FOUND()
   ELSE
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_QTAGIA WITH 0
      REPLACE SEL_QTANEC WITH 0
      REPLACE SEL_QTADOR WITH 0
   ENDIF

   REPLACE SEL_QTANEC WITH SEL_QTANEC + M.SEL_QTANEC

   SELECT CUR_SALAMESCOLE
   SKIP +1

ENDDO


SELECT G_MAG_GG
GO TOP
REPLACE MAG_GIACEN WITH MAG_COMODO FOR MAG_GIACEN = 0 AND MAG_COMODO > 0 ALL

SELECT CURS_SALAMESCOLE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF SEL_LIVELL = 1
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   V_GIACEN = 0

   *=> Prelievo delle giacenze al netto dell'impegnato
   IF PUB_NOGIAC
   ELSE
      SELECT G_MAG_GG
      SET ORDER TO I_GMAGG3
      SEEK M.SEL_CODART
      IF FOUND()
         DO WHILE .T.
            IF EOF()
               EXIT
            ENDIF
            IF MAG_ANAART = M.SEL_CODART
            ELSE
               EXIT
            ENDIF
            IF MAG_GIACEN > 0
            ELSE
               SKIP +1
               LOOP
            ENDIF
            IF MAG_GIACEN > MAG_QTAIMP
            ELSE
               SKIP +1
               LOOP
            ENDIF
            V_GIACEN = V_GIACEN + (MAG_GIACEN - MAG_QTAIMP)
            SKIP +1
         ENDDO
      ENDIF
   ENDIF

   IF V_GIACEN < 1
      V_GIACEN = 0
   ENDIF

   *=> Accesso alla anagrafica articoli per intercettare se trattasi di articolo da movimentare in magazzino
   *=> in caso di articolo da non movimentare, viene forzata una giacenza altissima in modo da non scaturire
   *=> l'emissione automatica dell'ordine a fornitore (č il caso dell'acqua)  PROJECT 4/01/2005
   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.SEL_CODART) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
      OUT = .f.
   ELSE
      OUT = art_NONMOV
   ENDIF
   IF OUT
      V_GIACEN = 999999999
   ENDIF

   SELECT CURS_SALAMESCOLE
   REPLACE SEL_QTAGIA WITH V_GIACEN
   IF SEL_QTAGIA < SEL_QTANEC
      REPLACE SEL_QTADOR WITH SEL_QTANEC - SEL_QTAGIA		&& Qtŕ da ordinare (manca giacenza)
   ELSE
      REPLACE SEL_QTADOR WITH 0
   ENDIF

   SKIP +1

ENDDO


*=> ELABORAZIONE CURSORE SALA MESCOLE PER AGGIORNARE GLI ADESIVI DA ORDINARE
SELECT CURS_SALAMESCOLE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF SEL_LIVELL = 1
      SKIP +1
      LOOP
   ENDIF

   IF SEL_QTADOR > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   V_SEEK = '2'+M.SEL_CODART

   SELECT CUR_FABBISOGNI
   SET ORDER TO I_FABADE
   SEEK V_SEEK
   IF FOUND()
   ELSE
      APPEND BLANK
      REPLACE FAB_TIPART WITH '2'
      REPLACE FAB_CODART WITH M.SEL_CODART
      REPLACE FAB_DESART WITH M.SEL_DESART
      REPLACE FAB_CODCOL WITH SPACE(03)
      REPLACE FAB_DESCOL WITH SPACE(50)
      REPLACE FAB_CODMAT WITH '004'
      REPLACE FAB_DESMAT WITH 'ADESIVI'
      REPLACE FAB_SPESSO WITH 0
      REPLACE FAB_ALTEZZ WITH 0
	  REPLACE FAB_CDDIBA WITH M.SEL_CDDIBA
	  REPLACE FAB_CILRET WITH 0
	  REPLACE FAB_LUNGHE WITH 0
	  REPLACE FAB_NUMBOB WITH 1
	  REPLACE FAB_QTAML  WITH 0
	  REPLACE FAB_QTAMQ  WITH 0
	  REPLACE FAB_QTAKG  WITH 0
	  REPLACE FAB_CODIMB WITH M.SEL_CODIMB
	  REPLACE FAB_DESIMB WITH M.SEL_DESIMB
	  REPLACE FAB_SCORMI WITH M.SEL_SCORMI
	  REPLACE FAB_LOTMIN WITH M.SEL_LOTMIN
	  REPLACE FAB_UNITAM WITH M.SEL_UNITAM
   ENDIF
   REPLACE FAB_QTAKG     WITH FAB_QTAKG + M.SEL_QTADOR

   SELECT CURS_SALAMESCOLE
   SKIP +1

ENDDO

SELECT CUR_FABBISOGNI
SET ORDER TO I_FABBIS
GO TOP
IF PUB_NOGIAC
ELSE
   IF EOF()
      =MESSAGEBOX("Nessun fabbisogno da stampare, per film nudo e adesivi",16,"*** ATTENZIONE ***")
   ELSE
      *V_ARCH   = "CUR_FABBISOGNI"
      *V_REPORT = "FABBISOGNI.FRX"
      *DO PRG\MENUSTA WITH V_ARCH,.T.,.T.,"XXX","&V_REPORT","&V_REPORT"
   ENDIF
ENDIF

RETURN



***************************************************************************
PROCEDURE determina_fabbisogni_mandrini
***************************************************************************

RELEASE WMA_ALTEZZ,WMA_SPESSO,WMA_CODSYS,WMA_MANDRI,WMA_CODCLI,WMA_LUNGHE,WMA_NUMBOB,WMA_CODPER,WMA_CODMAN,WMA_DESMAN
PUBLIC  WMA_ALTEZZ,WMA_SPESSO,WMA_CODSYS,WMA_MANDRI,WMA_CODCLI,WMA_LUNGHE,WMA_NUMBOB,WMA_CODPER,WMA_CODMAN,WMA_DESMAN

CREATE CURSOR STA_MANDRI (MAN_CODMAN C(16), MAN_DESMAN C(50), MAN_ALTEZZ N(05), MAN_NUMMAN N(10), MAN_GIAMAN N(10), ;
                          MAN_ORFMAN N(10), MAN_SCOMIN N(10), MAN_ORDMAN N(10))
INDEX ON MAN_CODMAN 					TAG I_MANDRI ADDITIVE

DO rileva_fabb_attuale

IF PUB_NOGIAC
ELSE
   DO rileva_fabb_regresso
   DO rileva_fabb_giacenze
   DO rileva_fabb_ordforn
   SELECT STA_MANDRI
   SET ORDER TO I_MANDRI
   SET FILTER TO MAN_ORDMAN > 0
   GO TOP
   IF EOF()
   ELSE
      V_ARCH   = "STA_MANDRI"
      V_REPORT = "FABBISOGNI_MAN.FRX"
      DO PRG\MENUSTA WITH V_ARCH,.T.,.T.,"XXX","&V_REPORT","&V_REPORT"
   ENDIF
ENDIF

RETURN


***************************************************************************
PROCEDURE rileva_fabb_attuale
***************************************************************************

V_ARCH = "STA_RAPPRODR"

SELECT &V_ARCH
SET FILTER TO
INDEX ON RIBALTA2(STA_DATINI) + STA_CODMAC + STR(STA_PROGRE,6,0) TAG I_RAPPORTO ADDITIVE
SET ORDER TO I_RAPPORTO
GO TOP
IF EOF()
   RETURN
ENDIF

*=> Elenco dei mandrini necessari per la prg attuale
SELECT &V_ARCH
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   IF M.STA_TIPREC = 1
   ELSE
      SELECT &V_ARCH
      SKIP +1
      LOOP
   ENDIF

   WMA_ALTEZZ = STA_ALTMAG
   WMA_SPESSO = STA_SPEORD
   WMA_CODSYS = STA_SYSCLI
   WMA_MANDRI = SPACE(10)

   DO RILEVA_MANDRINO

   SELECT CUR_MANDRI
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      SCATTER MEMVAR MEMO
      SELECT STA_MANDRI
      SET ORDER TO I_MANDRI
      SEEK M.MAN_CODMAN
      IF FOUND()
         REPLACE MAN_NUMMAN WITH MAN_NUMMAN + M.MAN_NUMMAN
      ELSE
         APPEND BLANK
         GATHER MEMVAR MEMO
         REPLACE MAN_GIAMAN WITH 0
         REPLACE MAN_ORFMAN WITH 0
      ENDIF
      SELECT CUR_MANDRI
      SKIP +1
   ENDDO

   SELECT &V_ARCH
   SKIP +1

ENDDO

RETURN


