RETURN


***************************************************************************
PROCEDURE spalmatura_riepiloga
***************************************************************************

RELEASE XXX_CODSYS,XXX_PRIMA,XXX_PROGRE,XXX_LUNPRG,XXX_MISTAG,XXX_CLIELA,XXX_BOBPRG,XXX_QTAPRG,XXX_ALTEZZ,XXX_LUNGHE, ;
        XXX_BOBORD,XXX_QTAORD,XXX_SCARTO,XXX_SPESMA,XXX_NOTE,XXX_SOMMALUN,XXX_ALTPRG,XXX_ALTUSATA,XXX_NRTAGL
PUBLIC  XXX_CODSYS,XXX_PRIMA,XXX_PROGRE,XXX_LUNPRG,XXX_MISTAG,XXX_CLIELA,XXX_BOBPRG,XXX_QTAPRG,XXX_ALTEZZ,XXX_LUNGHE, ;
        XXX_BOBORD,XXX_QTAORD,XXX_SCARTO,XXX_SPESMA,XXX_NOTE,XXX_SOMMALUN,XXX_ALTPRG,XXX_ALTUSATA,XXX_NRTAGL
XXX_CODSYS   = SYS(2015)
XXX_PRIMA    = .T.
XXX_PROGRE   = 0
XXX_LUNPRG   = 0
XXX_MISTAG   = ""
XXX_CLIELA   = ""
XXX_BOBPRG   = 0
XXX_QTAPRG   = 0
XXX_BOBORD   = 0
XXX_QTAORD   = 0
XXX_SCARTO   = .F.
XXX_SPESMA   = 0
XXX_NOTE     = ""
XXX_SOMMALUN = .T.
XXX_ALTPRG   = 0
XXX_ALTUSATA = 0
XXX_NRTAGL   = 0

CREATE CURSOR CURS_LUNGHE (LUN_LUNGHE N(10), LUN_NUMBOB N(10), LUN_TOTLEN N(10))
SELECT CURS_LUNGHE
INDEX ON LUN_LUNGHE TAG I_LUNGHE ADDITIVE

SELECT CUR_SPALMATURA
INDEX ON SEL_PROGRE TAG I_SPALMA ADDITIVE
SET ORDER TO I_SPALMA
SET FILTER TO
GO TOP
IF EOF()
   RETURN
ENDIF

SCATTER MEMVAR MEMO

XXX_SPESMA = SEL_SPESSO

DO WHILE .T.

   IF EOF()
      *=> Determino la percentuale di scarto
      XXX_ALTUSATA = XXX_ALTPRG + ((XXX_NRTAGL-1) * V_TAGLIO) + V_CIMOSA
      V_SCCALC1    = 100 - (XXX_ALTUSATA * 100) / M.SEL_ALTMAG
      V_SCCALC2    = 100 - (XXX_ALTPRG * 100) / M.SEL_ALTMAG
      IF V_SCCALC1 > 0 .OR. V_SCCALC2 > 0
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "(Scarto A = " + ALLTRIM(STR(V_SCCALC2,6,2)) + " %  " + ;
                                                "Scarto B = " + ALLTRIM(STR(V_SCCALC1,6,2)) + " %)"
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + CHR(13)
      ENDIF
      DO SPALMATURA_DETERMINAOUTPUT
      XXX_PROGRE = XXX_PROGRE + 1
      SELECT RIE_SPALMATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_CODCLI WITH SPACE(10)
      REPLACE SEL_RAGSOC WITH SPACE(50)
      REPLACE SEL_NUMORD WITH SPACE(06)
      REPLACE SEL_DATORD WITH SPACE(10)
      REPLACE SEL_ALTEZZ WITH 0
      REPLACE SEL_LUNGHE WITH 0
      REPLACE SEL_BOBORD WITH XXX_BOBORD
      REPLACE SEL_QTAORD WITH XXX_QTAORD
      REPLACE SEL_LUNMAG WITH 0
      REPLACE SEL_UNIQUE WITH XXX_CODSYS
      REPLACE SEL_PROGRE WITH XXX_PROGRE
      REPLACE SEL_CODSYS WITH XXX_CODSYS
      REPLACE SEL_BOBPRG WITH XXX_BOBPRG
      REPLACE SEL_QTAPRG WITH XXX_QTAPRG
      REPLACE SEL_MISTAG WITH XXX_MISTAG
      REPLACE SEL_CLIELA WITH XXX_CLIELA
      REPLACE SEL_LUNPRG WITH XXX_LUNPRG
      REPLACE SEL_SCARTO WITH XXX_SCARTO
      REPLACE SEL_NOTE   WITH XXX_NOTE
      EXIT
   ENDIF

   *=> Verifica rottura sequenza (cambia programma)
   IF SEL_CODART = M.SEL_CODART .AND. SEL_CILRET = M.SEL_CILRET .AND. ;
      SEL_SPEMAG = M.SEL_SPEMAG .AND. SEL_ALTMAG = M.SEL_ALTMAG
   ELSE
      *=> Determino la percentuale di scarto
      XXX_ALTUSATA = XXX_ALTPRG + ((XXX_NRTAGL-1) * V_TAGLIO) + V_CIMOSA
      V_SCCALC1    = 100 - (XXX_ALTUSATA * 100) / M.SEL_ALTMAG
      V_SCCALC2    = 100 - (XXX_ALTPRG * 100) / M.SEL_ALTMAG
      IF V_SCCALC1 > 0 .OR. V_SCCALC2 > 0
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "(Scarto A = " + ALLTRIM(STR(V_SCCALC2,6,2)) + " %  " + ;
                                                "Scarto B = " + ALLTRIM(STR(V_SCCALC1,6,2)) + " %)"
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + CHR(13)
      ENDIF
      DO SPALMATURA_DETERMINAOUTPUT
      XXX_PROGRE = XXX_PROGRE + 1
      SELECT RIE_SPALMATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_CODCLI WITH SPACE(10)
      REPLACE SEL_RAGSOC WITH SPACE(50)
      REPLACE SEL_NUMORD WITH SPACE(06)
      REPLACE SEL_DATORD WITH SPACE(10)
      REPLACE SEL_ALTEZZ WITH 0
      REPLACE SEL_LUNGHE WITH 0
      REPLACE SEL_BOBORD WITH XXX_BOBORD
      REPLACE SEL_QTAORD WITH XXX_QTAORD
      REPLACE SEL_LUNMAG WITH 0
      REPLACE SEL_UNIQUE WITH XXX_CODSYS
      REPLACE SEL_PROGRE WITH XXX_PROGRE
      REPLACE SEL_CODSYS WITH XXX_CODSYS
      REPLACE SEL_BOBPRG WITH XXX_BOBPRG
      REPLACE SEL_QTAPRG WITH XXX_QTAPRG
      REPLACE SEL_MISTAG WITH XXX_MISTAG
      REPLACE SEL_CLIELA WITH XXX_CLIELA
      REPLACE SEL_LUNPRG WITH XXX_LUNPRG
      REPLACE SEL_SCARTO WITH XXX_SCARTO
      REPLACE SEL_NOTE   WITH XXX_NOTE
      SELECT CUR_SPALMATURA
      SCATTER MEMVAR MEMO
      XXX_CODSYS   = SYS(2015)
      XXX_PRIMA    = .T.
      XXX_LUNPRG   = 0
      XXX_MISTAG   = ""
      XXX_CLIELA   = ""
      XXX_BOBPRG   = 0
      XXX_QTAPRG   = 0
      XXX_BOBORD   = 0
      XXX_QTAORD   = 0
      XXX_SCARTO   = .F.
      XXX_NOTE     = ""
      XXX_SPESMA   = SEL_SPESSO
      XXX_NRTAGL   = 0
      XXX_ALTUSATA = 0
      XXX_ALTPRG   = 0
      LOOP
   ENDIF

   XX_CODCLI = SEL_CODCLI
   XX_RAGSOC = SEL_RAGSOC
   XX_UNIQUE = SEL_CODSYS
   XX_BOBPRG = SEL_BOBPRG
   XX_QTAPRG = SEL_QTAPRG
   XX_BOBORD = SEL_BOBORD
   XX_QTAORD = SEL_QTAORD
   XX_NRPAGI = SEL_PROGRE

   SELECT CU_PRG_CL
   SET ORDER TO I_PRGCL2
   SEEK 'SPA' + XXX_CODSYS + XX_UNIQUE
   IF FOUND()
      REPLACE PRG_BOBPRG WITH PRG_BOBPRG + XX_BOBPRG
      REPLACE PRG_QTAPRG WITH PRG_QTAPRG + XX_QTAPRG
   ELSE
      APPEND BLANK
      REPLACE PRG_TIPO   WITH 'SPA'
      REPLACE PRG_CODSYS WITH XXX_CODSYS
      REPLACE PRG_CODCLI WITH XX_CODCLI
      REPLACE PRG_RAGSOC WITH XX_RAGSOC
      REPLACE PRG_UNIQUE WITH XX_UNIQUE
      REPLACE PRG_BOBPRG WITH XX_BOBPRG
      REPLACE PRG_QTAPRG WITH XX_QTAPRG
   ENDIF

   REPLACE PRG_NUMPRG WITH _V_NUMPRG
   REPLACE PRG_DATPRG WITH _V_DATPRG
   REPLACE PRG_PROGRE WITH XX_NRPAGI

   XXX_BOBPRG = XXX_BOBPRG + XX_BOBPRG
   XXX_QTAPRG = XXX_QTAPRG + XX_QTAPRG

   XXX_BOBORD = XXX_BOBORD + XX_BOBORD
   XXX_QTAORD = XXX_QTAORD + XX_QTAORD

   SELECT CUR_SPALMATURA

   IF SEL_SCARTO
      XXX_SCARTO = .T.
   ENDIF

   IF SEL_PROGRE = M.SEL_PROGRE
   ELSE
      XXX_LUNPRG   = XXX_LUNPRG + ROUND((SEL_LUNGHE * SEL_BOBPRG) / SEL_ACCOPP,0)
      *=> Determino la percentuale di scarto
      XXX_ALTUSATA = XXX_ALTPRG + ((XXX_NRTAGL-1) * V_TAGLIO) + V_CIMOSA
      V_SCCALC1    = 100 - (XXX_ALTUSATA * 100) / M.SEL_ALTMAG
      V_SCCALC2    = 100 - (XXX_ALTPRG * 100) / M.SEL_ALTMAG
      IF V_SCCALC1 > 0 .OR. V_SCCALC2 > 0
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "(Scarto A = " + ALLTRIM(STR(V_SCCALC2,6,2)) + " %  " + ;
                                                "Scarto B = " + ALLTRIM(STR(V_SCCALC1,6,2)) + " %)" +CHR(13) + ;
                        "==========================="
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + CHR(13) + "==========================="
      ELSE
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "==========================="
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + "==========================="
      ENDIF
      M.SEL_PROGRE = SEL_PROGRE
      XXX_SOMMALUN = .T.
      XXX_ALTUSATA = 0
      XXX_NRTAGL   = 0
      XXX_ALTPRG   = 0
   ENDIF

   IF XXX_PRIMA
      XXX_LUNPRG   = ROUND((SEL_LUNGHE * SEL_BOBPRG) / SEL_ACCOPP,0)
      XXX_PRIMA    = .F.
      XXX_SOMMALUN = .T.
   ENDIF

   IF EMPTY(ALLTRIM(XXX_MISTAG))
      XXX_NRTAGL = SEL_ACCOPP
      XXX_ALTPRG = (SEL_ALTEZZ * SEL_ACCOPP)
      XXX_MISTAG = ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      XXX_CLIELA = ALLTRIM(SUBSTR(SEL_RAGSOC,1,23))
   ELSE
      XXX_NRTAGL = XXX_NRTAGL + SEL_ACCOPP
      XXX_ALTPRG = XXX_ALTPRG + (SEL_ALTEZZ * SEL_ACCOPP)
      XXX_MISTAG = XXX_MISTAG + CHR(13) + ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      XXX_CLIELA = XXX_CLIELA + CHR(13) + ALLTRIM(SUBSTR(SEL_RAGSOC,1,23))
   ENDIF

   *=> Gestione cursore delle lunghezze programmate per gestire successivamente il numero e la lunghezza della
   *=> bobine in output dalla spalmatura.
   QW_LUNGHE = SEL_LUNGHE
   QW_BOBPRG = SEL_BOBPRG
   QW_ACCOPP = SEL_ACCOPP
   SELECT CURS_LUNGHE
   SET ORDER TO I_LUNGHE
   SEEK QW_LUNGHE
   IF FOUND()
      IF XXX_SOMMALUN
         REPLACE LUN_TOTLEN WITH LUN_TOTLEN + ROUND((QW_LUNGHE * QW_BOBPRG) / QW_ACCOPP,0)
      ENDIF
   ELSE
      APPEND BLANK
      REPLACE LUN_LUNGHE WITH QW_LUNGHE
      REPLACE LUN_TOTLEN WITH ROUND((QW_LUNGHE * QW_BOBPRG) / QW_ACCOPP,0)
   ENDIF
   XXX_SOMMALUN = .F.

   SELECT CUR_SPALMATURA
   VV_UNIQUE = SEL_CODSYS
   SELECT NOP_SPALMATURA
   SET ORDER TO I_CODSYS
   SEEK VV_UNIQUE
   IF FOUND()
      REPLACE SELEZIONE WITH '=>'
   ENDIF
   SELECT CUR_SPALMATURA
   SKIP +1

ENDDO

RETURN


***************************************************************************
PROCEDURE SPALMATURA_DETERMINAOUTPUT
***************************************************************************

CREATE CURSOR CURS_SOMMALUNGHE (SOM_NUMBOB N(19), SOM_TOTLEN N(19), SOM_ELABOR L(01))
SELECT CURS_SOMMALUNGHE
INDEX ON SOM_TOTLEN TAG I_SOMLUN ADDITIVE

x_cond = "mic_spesso = " + ALLTRIM(STR(XXX_SPESMA,5,0))
cSql   = "select * from u_pro_my where " + x_cond
IF !ExecCommand(cSql,"U_PRO_MY")
   RETURN
ENDIF
SELECT U_PRO_MY
GO TOP
IF EOF()
   WE_LENMAX = 0
ELSE
   WE_LENMAX = MIC_LENMAX
ENDIF

IF WE_LENMAX = 0
   WE_LENMAX = XXX_LUNPRG
ENDIF

WE_LUNPRG   = XXX_LUNPRG
WE_NUMBOB1  = 0
WE_LUNBOB1  = 0

SELECT CURS_LUNGHE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF WE_LUNPRG = 0
      EXIT
   ENDIF

   IF LUN_TOTLEN <= WE_LENMAX
      IF WE_LUNBOB1 <= WE_LENMAX
      ELSE
         IF WE_LUNBOB1 > 0
            IF EMPTY(ALLTRIM(XXX_NOTE))
               XXX_NOTE  = "1 BOBINA DA " + ALLTRIM(STR(WE_LUNBOB1,10,0)) + " MTL."
            ELSE
               XXX_NOTE  = XXX_NOTE + CHR(13) + "1 BOBINA DA " + ALLTRIM(STR(WE_LUNBOB1,10,0)) + " MTL."
            ENDIF
            SELECT CURS_SOMMALUNGHE
            APPEND BLANK
            REPLACE SOM_NUMBOB WITH 1
            REPLACE SOM_TOTLEN WITH WE_LUNBOB1
            REPLACE SOM_ELABOR WITH .F.
            SELECT CURS_LUNGHE
            WE_LUNBOB1 = 0
            LOOP
         ENDIF
      ENDIF
   ELSE
      IF WE_LUNBOB1 > 0
         IF EMPTY(ALLTRIM(XXX_NOTE))
            XXX_NOTE  = "1 BOBINA DA " + ALLTRIM(STR(WE_LUNBOB1,10,0)) + " MTL."
         ELSE
            XXX_NOTE  = XXX_NOTE + CHR(13) + "1 BOBINA DA " + ALLTRIM(STR(WE_LUNBOB1,10,0)) + " MTL."
         ENDIF
         SELECT CURS_SOMMALUNGHE
         APPEND BLANK
         REPLACE SOM_NUMBOB WITH 1
         REPLACE SOM_TOTLEN WITH WE_LUNBOB1
         REPLACE SOM_ELABOR WITH .F.
         SELECT CURS_LUNGHE
      ENDIF

      IF LUN_LUNGHE = 0
         WE_CALC01  = 0
      ELSE
         WE_CALC01  = INT(WE_LENMAX / LUN_LUNGHE)
      ENDIF
      WE_CALC02    = WE_CALC01 * LUN_LUNGHE
      IF WE_CALC02 = 0
         WE_CALC1  = 0
      ELSE
         WE_CALC1     = INT(LUN_TOTLEN / WE_CALC02)
      ENDIF
      *WE_CALC1     = INT(LUN_TOTLEN / WE_LENMAX)

      IF WE_CALC1 = 0
      ELSE
         XXX_NOTE     = XXX_NOTE + CHR(13) + ALLTRIM(STR(WE_CALC1,6,0)) + " BOBINE DA " + ALLTRIM(STR(WE_CALC02,10,0)) + " MTL."
      ENDIF
      *XXX_NOTE     = XXX_NOTE + CHR(13) + ALLTRIM(STR(WE_CALC1,6,0)) + " BOBINE DA " + ALLTRIM(STR(WE_LENMAX,10,0)) + " MTL."

      SELECT CURS_SOMMALUNGHE
      APPEND BLANK
      REPLACE SOM_NUMBOB WITH WE_CALC1
      REPLACE SOM_TOTLEN WITH WE_CALC02
      *REPLACE SOM_TOTLEN WITH WE_LENMAX
      REPLACE SOM_ELABOR WITH .F.

      SELECT CURS_LUNGHE

      WE_LUNPRG    = WE_LUNPRG - LUN_TOTLEN
      WE_LUNBOB1   = LUN_TOTLEN - (WE_CALC1 * WE_CALC02)
      *WE_LUNBOB1   = LUN_TOTLEN - (WE_CALC1 * WE_LENMAX)

      SKIP +1
      LOOP

   ENDIF

   WE_LUNBOB1 = WE_LUNBOB1 + LUN_TOTLEN
   WE_LUNPRG  = WE_LUNPRG - LUN_TOTLEN

   SKIP +1

ENDDO

IF WE_LUNBOB1 > 0
   IF EMPTY(ALLTRIM(XXX_NOTE))
      XXX_NOTE = "1 BOBINA DA " + ALLTRIM(STR(WE_LUNBOB1,10,0)) + " MTL."
   ELSE
      XXX_NOTE = XXX_NOTE + CHR(13) + "1 BOBINA DA " + ALLTRIM(STR(WE_LUNBOB1,10,0)) + " MTL."
   ENDIF
   SELECT CURS_SOMMALUNGHE
   APPEND BLANK
   REPLACE SOM_NUMBOB WITH 1
   REPLACE SOM_TOTLEN WITH WE_LUNBOB1
   REPLACE SOM_ELABOR WITH .F.
   SELECT CURS_LUNGHE
ENDIF



CREATE CURSOR CURS_RIEPLUNGHE (SOM_NUMBOB N(10), SOM_TOTLEN N(10))
SELECT CURS_RIEPLUNGHE
INDEX ON SOM_TOTLEN TAG I_RIELUN DESCENDING ADDITIVE

SELECT CURS_SOMMALUNGHE
SET ORDER TO I_SOMLUN
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF SOM_ELABOR
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   WE_TROV = .F.

   SELECT CURS_RIEPLUNGHE
   SET ORDER TO I_RIELUN
   GO TOP

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF (SOM_TOTLEN + M.SOM_TOTLEN) > WE_LENMAX
         SKIP +1
         LOOP
      ENDIF

      REPLACE SOM_TOTLEN WITH SOM_TOTLEN + M.SOM_TOTLEN

      WE_TROV = .T.

      EXIT

   ENDDO

   IF WE_TROV
   ELSE
      SELECT CURS_RIEPLUNGHE
      APPEND BLANK
      GATHER MEMVAR
   ENDIF

   SELECT CURS_SOMMALUNGHE
   REPLACE SOM_ELABOR WITH .T.

   GO TOP

ENDDO

XXX_NOTE  = ""

SELECT CURS_RIEPLUNGHE
SET ORDER TO I_RIELUN
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF EMPTY(ALLTRIM(XXX_NOTE))
      IF SOM_NUMBOB > 1
         XXX_NOTE = ALLTRIM(STR(SOM_NUMBOB,10,0)) + " BOBINE DA " + ALLTRIM(STR(SOM_TOTLEN,10,0)) + " MTL."
      ELSE
         XXX_NOTE = ALLTRIM(STR(SOM_NUMBOB,10,0)) + " BOBINA DA " + ALLTRIM(STR(SOM_TOTLEN,10,0)) + " MTL."
      ENDIF
   ELSE
      IF SOM_NUMBOB > 1
         XXX_NOTE = XXX_NOTE + CHR(13) + ALLTRIM(STR(SOM_NUMBOB,10,0)) + " BOBINE DA " + ALLTRIM(STR(SOM_TOTLEN,10,0)) + " MTL."
      ELSE
         XXX_NOTE = XXX_NOTE + CHR(13) + ALLTRIM(STR(SOM_NUMBOB,10,0)) + " BOBINA DA " + ALLTRIM(STR(SOM_TOTLEN,10,0)) + " MTL."
      ENDIF
   ENDIF

   SKIP +1

ENDDO

SELECT CURS_LUNGHE
ZAP

SELECT CURS_SOMMALUNGHE
ZAP

SELECT CURS_RIEPLUNGHE
ZAP

RETURN


***************************************************************************
PROCEDURE spalmatura_riepiloga_outorder
***************************************************************************

RELEASE XXX_CODSYS,XXX_PRIMA,XXX_PROGRE,XXX_LUNPRG,XXX_MISTAG,XXX_CLIELA,XXX_BOBPRG,XXX_QTAPRG,XXX_ALTEZZ,XXX_LUNGHE, ;
        XXX_BOBORD,XXX_QTAORD,XXX_SCARTO
PUBLIC  XXX_CODSYS,XXX_PRIMA,XXX_PROGRE,XXX_LUNPRG,XXX_MISTAG,XXX_CLIELA,XXX_BOBPRG,XXX_QTAPRG,XXX_ALTEZZ,XXX_LUNGHE, ;
        XXX_BOBORD,XXX_QTAORD,XXX_SCARTO
XXX_CODSYS = SYS(2015)
XXX_PRIMA  = .T.
XXX_PROGRE = 0
XXX_LUNPRG = 0
XXX_MISTAG = ""
XXX_CLIELA = ""
XXX_BOBPRG = 0
XXX_QTAPRG = 0
XXX_BOBORD = 0
XXX_QTAORD = 0
XXX_SCARTO = .F.

SELECT CUR_SPALMATURA
INDEX ON SEL_PROGRE TAG I_SPALMA ADDITIVE
SET ORDER TO I_SPALMA
SET FILTER TO
GO TOP
IF EOF()
   RETURN
ENDIF

SCATTER MEMVAR MEMO

DO WHILE .T.

   IF EOF()
      XXX_PROGRE = XXX_PROGRE + 1
      SELECT RIE_SPALMATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_CODCLI WITH SPACE(10)
      REPLACE SEL_RAGSOC WITH SPACE(50)
      REPLACE SEL_NUMORD WITH SPACE(06)
      REPLACE SEL_DATORD WITH SPACE(10)
      REPLACE SEL_ALTEZZ WITH 0
      REPLACE SEL_LUNGHE WITH 0
      REPLACE SEL_BOBORD WITH XXX_BOBORD
      REPLACE SEL_QTAORD WITH XXX_QTAORD
      REPLACE SEL_LUNMAG WITH 0
      REPLACE SEL_UNIQUE WITH XXX_CODSYS
      REPLACE SEL_PROGRE WITH XXX_PROGRE
      REPLACE SEL_CODSYS WITH XXX_CODSYS
      REPLACE SEL_BOBPRG WITH XXX_BOBPRG
      REPLACE SEL_QTAPRG WITH XXX_QTAPRG
      REPLACE SEL_MISTAG WITH XXX_MISTAG
      REPLACE SEL_CLIELA WITH XXX_CLIELA
      REPLACE SEL_LUNPRG WITH XXX_LUNPRG
      REPLACE SEL_SCARTO WITH XXX_SCARTO
      EXIT
   ENDIF

   *=> Verifica rottura sequenza (cambia programma)
   IF SEL_CODART = M.SEL_CODART .AND. SEL_CILRET = M.SEL_CILRET .AND. ;
      SEL_SPEMAG = M.SEL_SPEMAG .AND. SEL_ALTMAG = M.SEL_ALTMAG
   ELSE
      XXX_PROGRE = XXX_PROGRE + 1
      SELECT RIE_SPALMATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_CODCLI WITH SPACE(10)
      REPLACE SEL_RAGSOC WITH SPACE(50)
      REPLACE SEL_NUMORD WITH SPACE(06)
      REPLACE SEL_DATORD WITH SPACE(10)
      REPLACE SEL_ALTEZZ WITH 0
      REPLACE SEL_LUNGHE WITH 0
      REPLACE SEL_BOBORD WITH XXX_BOBORD
      REPLACE SEL_QTAORD WITH XXX_QTAORD
      REPLACE SEL_LUNMAG WITH 0
      REPLACE SEL_UNIQUE WITH XXX_CODSYS
      REPLACE SEL_PROGRE WITH XXX_PROGRE
      REPLACE SEL_CODSYS WITH XXX_CODSYS
      REPLACE SEL_BOBPRG WITH XXX_BOBPRG
      REPLACE SEL_QTAPRG WITH XXX_QTAPRG
      REPLACE SEL_MISTAG WITH XXX_MISTAG
      REPLACE SEL_CLIELA WITH XXX_CLIELA
      REPLACE SEL_LUNPRG WITH XXX_LUNPRG
      REPLACE SEL_SCARTO WITH XXX_SCARTO
      SELECT CUR_SPALMATURA
      SCATTER MEMVAR MEMO
      XXX_CODSYS = SYS(2015)
      XXX_PRIMA  = .T.
      XXX_LUNPRG = 0
      XXX_MISTAG = ""
      XXX_CLIELA = ""
      XXX_BOBPRG = 0
      XXX_QTAPRG = 0
      XXX_BOBORD = 0
      XXX_QTAORD = 0
      XXX_SCARTO = .F.
      LOOP
   ENDIF

   XX_CODCLI = SEL_CODCLI
   XX_RAGSOC = SEL_RAGSOC
   XX_UNIQUE = SEL_CODSYS
   XX_BOBPRG = SEL_BOBPRG
   XX_QTAPRG = SEL_QTAPRG
   XX_BOBORD = SEL_BOBORD
   XX_QTAORD = SEL_QTAORD

   SELECT CX_PRG_CL
   SET ORDER TO I_PRGCL2
   SEEK 'SPA' + XXX_CODSYS + XX_UNIQUE
   IF FOUND()
      REPLACE PRG_BOBPRG WITH PRG_BOBPRG + XX_BOBPRG
      REPLACE PRG_QTAPRG WITH PRG_QTAPRG + XX_QTAPRG
   ELSE
      APPEND BLANK
      REPLACE PRG_TIPO   WITH 'SPA'
      REPLACE PRG_CODSYS WITH XXX_CODSYS
      REPLACE PRG_CODCLI WITH XX_CODCLI
      REPLACE PRG_RAGSOC WITH XX_RAGSOC
      REPLACE PRG_UNIQUE WITH XX_UNIQUE
      REPLACE PRG_BOBPRG WITH XX_BOBPRG
      REPLACE PRG_QTAPRG WITH XX_QTAPRG
   ENDIF

   XXX_BOBPRG = XXX_BOBPRG + XX_BOBPRG
   XXX_QTAPRG = XXX_QTAPRG + XX_QTAPRG

   XXX_BOBORD = XXX_BOBORD + XX_BOBORD
   XXX_QTAORD = XXX_QTAORD + XX_QTAORD

   SELECT CUR_SPALMATURA

   IF SEL_SCARTO
      XXX_SCARTO = .T.
   ENDIF

   IF SEL_PROGRE = M.SEL_PROGRE
   ELSE
      XXX_LUNPRG   = XXX_LUNPRG + ROUND((SEL_LUNGHE * SEL_BOBPRG) / SEL_ACCOPP,0)
      XXX_MISTAG   = XXX_MISTAG + CHR(13) + "=============================="
      XXX_CLIELA   = XXX_CLIELA + CHR(13) + "==========================="
      M.SEL_PROGRE = SEL_PROGRE
   ENDIF

   IF XXX_PRIMA
      XXX_PRIMA  = .F.
      XXX_LUNPRG = ROUND((SEL_LUNGHE * SEL_BOBPRG) / SEL_ACCOPP,0)
   ENDIF

   IF EMPTY(ALLTRIM(XXX_MISTAG))
      XXX_MISTAG = ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      XXX_CLIELA = ALLTRIM(SUBSTR(SEL_RAGSOC,1,23))
   ELSE
      XXX_MISTAG = XXX_MISTAG + CHR(13) + ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      XXX_CLIELA = XXX_CLIELA + CHR(13) + ALLTRIM(SUBSTR(SEL_RAGSOC,1,23))
   ENDIF

   SELECT CUR_SPALMATURA
   SKIP +1

ENDDO

RETURN


***************************************************************************
PROCEDURE ribobinatura_nontrovato_1
***************************************************************************

SELECT CUR_RIBOBINATURA
V_LUNRESTANTE  = RIB1_LUNMAG - RIB1_LUNPRG

IF V_LUNRESTANTE > 0
ELSE
   RETURN
ENDIF

REPLACE RIN_LUNPRG WITH SEL_LUNMAG FOR SEL_PROGRE = RIB1_PROGRE ALL

RETURN


***************************************************************************
PROCEDURE ribobinatura_trovato_1
***************************************************************************

SELECT RIN_RIBOBINATURA
ZAP

SELECT CUR_RIBOBINATURA

V_LUNRESTANTE  = RIB1_LUNMAG - RIB1_LUNPRG
RIB2_PROGRE    = SEL_PROGRE
RIB2_PROSUC    = RIB1_PROSUC + 1

IF V_LUNRESTANTE < RIN_LUNPRG
   V_NUMBOBINE = INT((V_LUNRESTANTE / SEL_LUNGHE))

   IF V_NUMBOBINE > 0
   ELSE
      REPLACE SEL_FLGELA WITH .T.
      RETURN
   ENDIF

   RIB2_LUNPRG = 0

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF SEL_PROGRE = RIB2_PROGRE
      ELSE
         EXIT
      ENDIF

      REPLACE RIN_BOBPRG WITH RIN_BOBPRG - V_NUMBOBINE
      REPLACE RIN_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTMAG,SEL_LUNGHE,RIN_BOBPRG)
      SELECT CUR_RIBOBINATURA
      REPLACE RIN_LUNPRG WITH SEL_LUNGHE * RIN_BOBPRG
      SCATTER MEMVAR MEMO

      SELECT RIN_RIBOBINATURA
      APPEND BLANK
      GATHER MEMVAR MEMO

      REPLACE SEL_PROGRE WITH RIB1_PROGRE
      REPLACE RIN_BOBPRG WITH V_NUMBOBINE
      REPLACE RIN_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTMAG,SEL_LUNGHE,RIN_BOBPRG)
      SELECT RIN_RIBOBINATURA
      REPLACE RIN_LUNPRG WITH SEL_LUNGHE * RIN_BOBPRG
      REPLACE SEL_PROSUC WITH RIB2_PROGRE

      RIB2_LUNPRG = RIN_LUNPRG

      SELECT CUR_RIBOBINATURA
      SKIP +1

   ENDDO

   SELECT RIN_RIBOBINATURA
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      SCATTER MEMVAR MEMO
      SELECT CUR_RIBOBINATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      SELECT RIN_RIBOBINATURA
      SKIP +1
   ENDDO

   V_LUNBOBINE = RIB1_LUNPRG + RIB2_LUNPRG

ELSE

   V_LUNBOBINE = RIB1_LUNPRG + RIN_LUNPRG
   REPLACE SEL_PROSUC WITH RIB2_PROGRE FOR SEL_PROGRE = RIB2_PROGRE ALL
   REPLACE SEL_PROGRE WITH RIB1_PROGRE FOR SEL_PROGRE = RIB2_PROGRE ALL

ENDIF

REPLACE RIN_LUNPRG WITH V_LUNBOBINE FOR SEL_PROGRE = RIB1_PROGRE ALL

RIB1_PROSUC = RIB2_PROSUC

RETURN



***************************************************************************
PROCEDURE ribobinatura_nontrovato
***************************************************************************

SELECT CUR_RIBOBINATURA
V_LUNRESTANTE  = RIB1_LUNMAG - RIB1_LUNPRG

IF V_LUNRESTANTE > 0
ELSE
   RETURN
ENDIF

SELECT CUR_RIBOBINATURA
APPEND BLANK
GATHER MEMVAR MEMO

REPLACE SEL_UNIQUE WITH SPACE(36)
REPLACE SEL_CODART WITH RIB1_CODART
REPLACE SEL_DESART WITH RIB1_DESART
REPLACE SEL_CODCLI WITH '9999999999'
REPLACE SEL_RAGSOC WITH 'FUORI ORDINE'
REPLACE SEL_NUMORD WITH SPACE(06)
REPLACE SEL_DATORD WITH SPACE(10)
REPLACE SEL_CODCOL WITH RIB1_CODCOL
REPLACE SEL_DESCOL WITH RIB1_DESCOL
REPLACE SEL_CODMAT WITH RIB1_CODMAT
REPLACE SEL_DESMAT WITH RIB1_DESMAT
REPLACE SEL_SPESSO WITH RIB1_SPEMAG
REPLACE SEL_ALTEZZ WITH RIB1_ALTMAG
REPLACE SEL_LUNGHE WITH V_LUNRESTANTE
REPLACE SEL_BOBORD WITH 0
REPLACE SEL_QTAORD WITH 0
REPLACE SEL_SPEMAG WITH RIB1_SPEMAG
REPLACE SEL_ALTMAG WITH RIB1_ALTMAG
REPLACE SEL_LUNMAG WITH RIB1_LUNMAG
REPLACE SEL_ACCOPP WITH 1
REPLACE SEL_BOBACC WITH 1
REPLACE SEL_BOBPRG WITH 1
