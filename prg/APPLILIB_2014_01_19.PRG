	             SELECT CU_CAL_LA
	             *=> Gestione del fine lavoro
		         IF V_ORELAV > 0
		         ELSE
	   	            EXIT
	             ENDIF
	          ENDDO
	      ENDIF
       ENDIF
	ENDIF

    IF XXX_TROV
       V_DATA     = XXX_DATA
       V_CDMAC    = XXX_CDMAC
       V_DSMAC    = XXX_DSMAC
    ELSE
       VVV_STOPPA = .T.
       V_CDMAC    = 'TGS'
       V_DSMAC    = 'TAGLIO NON PROGRAMMATO'
    ENDIF

