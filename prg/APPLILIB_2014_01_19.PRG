CREATE CURSOR CUR_TIPOMOV (TIP_CODICE N(03), TIP_DESCRI C(90), TIP_CMASCA C(06), TIP_DMASCA C(50), ;
                           TIP_CMACAR C(06), TIP_DMACAR C(50), TIP_CAUSCA C(03), TIP_CAUCAR C(03))
INDEX ON TIP_CODICE TAG I_TIPMOV ADDITIVE

SELECT CUR_TIPOMOV
APPEND BLANK
REPLACE TIP_CODICE WITH 10
REPLACE TIP_DESCRI WITH "Spostamento DAL mag. carico fornitore AL mag. carico per C.Q."
REPLACE TIP_CMASCA WITH PUB_CARORF
REPLACE TIP_DMASCA WITH DES_CARORF
REPLACE TIP_CMACAR WITH PUB_CARORF
REPLACE TIP_DMACAR WITH DES_CARORF

V_CAUSCA = SPACE(03)
V_CAUCAR = SPACE(03)
x_cond = "tipomov = " + ALLTRIM(STR(TIP_CODICE,3,0))
cSql   = "select * from para where " + x_cond
IF !ExecCommand(cSql,"cur_para")
   RETURN
ENDIF
SELECT CUR_PARA
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF SUBSTR(CODICE,1,3) = 'TOP'
   ELSE
      SKIP +1
      LOOP
   ENDIF
   IF SUBSTR(LIBERA,1,1) = 'S'
      V_CAUSCA = SUBSTR(CODICE,4,3)
   ENDIF
   IF SUBSTR(LIBERA,1,1) = 'C'
      V_CAUCAR = SUBSTR(CODICE,4,3)
   ENDIF
   SKIP +1
ENDDO
