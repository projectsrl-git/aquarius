      V_PROGRE = SEL_PROGRE
      V_CDART  = SEL_CODART
      V_DSART  = SEL_DESART
      V_MYORD  = SEL_SPESSO
      V_CILRE  = SEL_CILRET
      V_MYMAG  = SEL_SPEMAG
      V_CDCOL  = SEL_CODCOL
      V_DSCOL  = SEL_DESCOL
      V_CDMAT  = SEL_CODMAT
      V_DSMAT  = SEL_DESMAT
      V_ALMAG  = SEL_ALTMAG
      V_LUPRG  = SEL_LUNPRG
      V_MQPRG  = SEL_QTAPRG
      V_CDIBA  = SEL_CDDIBA
      V_CDMAC  = SEL_CODMAC
      V_DSMAC  = SEL_DESMAC
      V_MISTAG = SEL_MISTAG
      V_CLIELA = SEL_CLIELA
      V_SYSCLI = SEL_UNIQUE
      V_LUMAG  = SEL_LUNMAG
      V_NLINT  = SEL_NUMLOT
      V_TAGMIS = SEL_TAGMIS
      V_NOTE   = SPACE(10)
      V_DTINI  = SPACE(10)
      V_DTFIN  = SPACE(10)
      V_VELIN  = 0
      V_HHLAV  = 0
      V_TEMCG  = 0
      V_TEMCR  = 0
      V_NUMRIG = 1
      V_SCARTO = SEL_SCARTO
      DO RIBOBINATURA_REPORTS
      SELECT RIE_RIBOBINATURA
      SKIP +1
   ENDDO
ENDIF

RELEASE W_SETINI,W_SETFIN,W_DATINI,W_DATFIN,W_PRIMA
PUBLIC  W_SETINI,W_SETFIN,W_DATINI,W_DATFIN,W_PRIMA
W_SETINI = SPACE(07)
W_SETFIN = SPACE(07)
W_DATINI = SPACE(10)
W_DATFIN = SPACE(10)
W_PRIMA  = .T.

SELECT STA_RIBOBINATURA
SET ORDER TO
SET FILTER TO
GO TOP
IF EOF()
ELSE
   W_DATINI = STA_DATINI
   W_DATFIN = STA_DATFIN
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF STA_DATFIN = 'GG/MM/AAAA'
         SKIP +1
         LOOP
      ENDIF
      IF RIBALTA2(STA_DATFIN) > RIBALTA2(W_DATFIN)
         W_DATFIN = STA_DATFIN
      ENDIF
      SKIP +1
   ENDDO
ENDIF

IF EMPTY(ALLTRIM(W_DATINI))
ELSE
   x_cond = "cal_datamg = '" + RIBALTA2(W_DATINI) + "'"
   cSql   = "select * from u_cal_la where " + x_cond
   IF !ExecCommand(cSql,"U_CAL_LA")
      RETURN
   ENDIF
   SELECT U_CAL_LA
   GO TOP
   IF EOF()
   ELSE
      W_SETINI = CAL_SETT
   ENDIF
   x_cond = "cal_datamg = '" + RIBALTA2(W_DATFIN) + "'"
   cSql   = "select * from u_cal_la where " + x_cond
   IF !ExecCommand(cSql,"U_CAL_LA")
      RETURN
   ENDIF
   SELECT U_CAL_LA
   GO TOP
   IF EOF()
   ELSE
      W_SETFIN = CAL_SETT
   ENDIF
ENDIF

_V_DPRGDA = W_DATINI
_V_SPRGDA = W_SETINI
_V_DPRGAL = W_DATFIN
_V_SPRGAL = W_SETFIN

SELECT STA_RIBOBINATURA
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   REPLACE STA_SETTDA WITH _V_SPRGDA
   REPLACE STA_SETTAL WITH _V_SPRGAL
   REPLACE STA_DATADA WITH _V_DPRGDA
   REPLACE STA_DATAAL WITH _V_DPRGAL
   SKIP +1
ENDDO

RELEASE WMA_ALTEZZ,WMA_SPESSO,WMA_CODSYS,WMA_MANDRI,WMA_CODCLI,WMA_LUNGHE,WMA_NUMBOB,WMA_CODPER,WMA_CODMAN,WMA_DESMAN
PUBLIC  WMA_ALTEZZ,WMA_SPESSO,WMA_CODSYS,WMA_MANDRI,WMA_CODCLI,WMA_LUNGHE,WMA_NUMBOB,WMA_CODPER,WMA_CODMAN,WMA_DESMAN

*SET STEP ON

SELECT STA_RAPPRODR
SET FILTER TO
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   REPLACE STA_SETTDA WITH _V_SPRGDA
   REPLACE STA_SETTAL WITH _V_SPRGAL
   REPLACE STA_DATADA WITH _V_DPRGDA
   REPLACE STA_DATAAL WITH _V_DPRGAL
   WMA_ALTEZZ = STA_ALTMAG
   WMA_SPESSO = STA_SPEORD
   WMA_CODSYS = STA_SYSCLI
   WMA_MANDRI = SPACE(10)
   DO RILEVA_MANDRINO
   SELECT STA_RAPPRODR
   REPLACE MAN_MANDRI WITH WMA_MANDRI
   SKIP +1
ENDDO

RETURN


*************************
PROCEDURE RILEVA_MANDRINO
*************************

CREATE CURSOR CUR_MANDRINI (MAN_CODPER C(02), MAN_LUNGHE N(06), MAN_NUMMAN N(06))
INDEX ON MAN_CODPER + STR(MAN_LUNGHE,6,0) TAG I_MANDRI ADDITIVE

SELECT CU_PRG_CL
SET ORDER TO I_PRGCL1
SEEK 'RIB' + WMA_CODSYS
IF FOUND()
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF PRG_TIPO = 'RIB'
      ELSE
         EXIT
      ENDIF
      IF PRG_CODSYS = WMA_CODSYS
      ELSE
         EXIT
      ENDIF
      IF PRG_LUNGHE = 0
         SKIP +1
         LOOP
      ENDIF
      WMA_CODCLI = PRG_CODCLI
      WMA_LUNGHE = PRG_LUNGHE
      WMA_NUMBOB = PRG_BOBPRG
      x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
      x_codi = "cli_codcli = '" + ALLTRIM(WMA_CODCLI) + "'"
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
      IF !ExecCommand(cSql,"cur_cliente")
         return(.f.)
      ENDIF
      SELECT cur_cliente
      GO TOP
      IF EOF()
         WMA_CODPER = SPACE(02)
      ELSE
         WMA_CODPER = CLI_PERSMA
      ENDIF
      SELECT CUR_MANDRINI
      SET ORDER TO I_MANDRI
      SEEK WMA_CODPER + STR(WMA_LUNGHE,6,0)
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE MAN_CODPER WITH WMA_CODPER
         REPLACE MAN_LUNGHE WITH WMA_LUNGHE
         REPLACE MAN_NUMMAN WITH 0
      ENDIF
      REPLACE MAN_NUMMAN WITH MAN_NUMMAN + WMA_NUMBOB
      SELECT CU_PRG_CL
      SKIP +1
   ENDDO
ENDIF

CREATE CURSOR CUR_MANDRI (MAN_CODMAN C(16), MAN_DESMAN C(50), MAN_ALTEZZ N(05), MAN_NUMMAN N(06))
INDEX ON MAN_CODMAN TAG I_MANDRI ADDITIVE

SELECT CUR_MANDRINI
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   WMA_CODMAN = SPACE(16)
   WMA_DESMAN = SPACE(50)
   WMA_LUNGHE = MAN_LUNGHE
   WMA_CODPER = MAN_CODPER
   cSql = "select * from u_man_co where 1=1"
   IF !ExecCommand(cSql,"QW_MAN_CO")
      return(.f.)
   ENDIF
   SELECT QW_MAN_CO
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF MAN_ALTEDA <= WMA_ALTEZZ .AND. MAN_ALTEAL >= WMA_ALTEZZ
      ELSE
         SKIP +1
         LOOP
      ENDIF
      IF MAN_LUNGDA <= WMA_LUNGHE .AND. MAN_LUNGAL >= WMA_LUNGHE
      ELSE
         SKIP +1
         LOOP
      ENDIF
      IF MAN_SPESDA <= WMA_SPESSO .AND. MAN_SPESAL >= WMA_SPESSO
      ELSE
         SKIP +1
         LOOP
      ENDIF
      IF EMPTY(ALLTRIM(WMA_CODPER)) .AND. EMPTY(ALLTRIM(MAN_CODPER))
      ELSE
         IF MAN_CODPER = WMA_CODPER
         ELSE
            SKIP +1
            LOOP
         ENDIF
      ENDIF
      WMA_CODMAN = MAN_CODMAN
      WMA_DESMAN = MAN_DESMAN
      EXIT
   ENDDO
   SELECT CUR_MANDRINI
   IF EMPTY(ALLTRIM(WMA_CODMAN))
   ELSE
      WMA_NUMMAN = MAN_NUMMAN
      SELECT CUR_MANDRI
      SET ORDER TO I_MANDRI
      SEEK WMA_CODMAN
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE MAN_CODMAN WITH WMA_CODMAN
         REPLACE MAN_DESMAN WITH WMA_DESMAN
         REPLACE MAN_ALTEZZ WITH WMA_ALTEZZ
         REPLACE MAN_NUMMAN WITH 0
      ENDIF
      REPLACE MAN_NUMMAN WITH MAN_NUMMAN + WMA_NUMMAN
   ENDIF
   SELECT CUR_MANDRINI
   SKIP +1
ENDDO

WMA_MANDRI = SPACE(10)

SELECT CUR_MANDRI
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF EMPTY(ALLTRIM(WMA_MANDRI))
      WMA_MANDRI = ALLTRIM(STR(MAN_NUMMAN,6,0)) + " " + ALLTRIM(MAN_CODMAN) + " - " + ALLTRIM(MAN_DESMAN) + " h. " + ALLTRIM(STR(MAN_ALTEZZ,5,0))
   ELSE
      WMA_MANDRI = WMA_MANDRI + CHR(13) + ;
                   ALLTRIM(STR(MAN_NUMMAN,6,0)) + " " + ALLTRIM(MAN_CODMAN) + " - " + ALLTRIM(MAN_DESMAN) + " h. " + ALLTRIM(STR(MAN_ALTEZZ,5,0))
   ENDIF
   SELECT CUR_MANDRI
   SKIP +1
ENDDO

RETURN


***************************************************************************
PROCEDURE ribobinatura_calcolalunghezzaprogrammata
***************************************************************************

SELECT CUR_RIBOBINATURA
INDEX ON SEL_PROGRE TAG I_SPALMA ADDITIVE
INDEX ON ALLTRIM(STR(SEL_NUMLOT,8,0)) + ALLTRIM(STR(SEL_PROGRE,9,0)) TAG I_SPALME ADDITIVE
SET ORDER TO I_SPALME
SET FILTER TO
GO TOP
IF EOF()
   RETURN
ENDIF

QAZ_RECNO  = 0
QAZ_LUNPRG = 0
QAZ_NUMLOT = SEL_NUMLOT
QAZ_PROGRE = SEL_PROGRE
QAZ_NEWPRG = 1
QAZ_PRIMA  = .T.

DO WHILE .T.

   IF EOF()
      IF QAZ_RECNO = 0
      ELSE
         REPLACE SEL_LUNPRG WITH QAZ_LUNPRG FOR SEL_NUMLOT = QAZ_NUMLOT
         *REPLACE SEL_PROGRE WITH QAZ_NEWPRG FOR SEL_NUMLOT = QAZ_NUMLOT
      ENDIF
      EXIT
   ENDIF

   *=> Verifica rottura sequenza (cambia programma)
   IF SEL_NUMLOT = QAZ_NUMLOT
   ELSE
      REPLACE SEL_LUNPRG WITH QAZ_LUNPRG FOR SEL_NUMLOT = QAZ_NUMLOT
      *REPLACE SEL_PROGRE WITH QAZ_NEWPRG FOR SEL_NUMLOT = QAZ_NUMLOT
      GOTO QAZ_RECNO
      QAZ_NUMLOT = SEL_NUMLOT
      QAZ_PROGRE = SEL_PROGRE
      QAZ_LUNPRG = 0
      QAZ_PRIMA  = .T.
      QAZ_NEWPRG = QAZ_NEWPRG + 1
      LOOP
   ENDIF

   *=> Verifica rottura sequenza (cambia programma)
   IF SEL_PROGRE = QAZ_PROGRE
   ELSE
      QAZ_PRIMA = .T.
      QAZ_PROGRE = SEL_PROGRE
   ENDIF

   IF QAZ_PRIMA
      QAZ_PRIMA = .F.
      QAZ_LUNPRG = QAZ_LUNPRG + ROUND((SEL_LUNGHE * SEL_BOBPRG) / SEL_ACCOPP,0)
   ENDIF

   SKIP +1

   IF EOF()
   ELSE
      QAZ_RECNO = RECNO()
   ENDIF

ENDDO

RETURN


***************************************************************************
PROCEDURE ribobinatura_riepiloga
***************************************************************************

RELEASE XXX_CODSYS,XXX_PRIMA,XXX_PROGRE,XXX_LUNPRG,XXX_MISTAG,XXX_CLIELA,XXX_BOBPRG,XXX_QTAPRG,XXX_ALTEZZ,XXX_LUNGHE, ;
        XXX_BOBORD,XXX_QTAORD,XXX_SCARTO,XXX_LUNMAG,RIB_LUNGHE,RIB_NUMBOB,RIB_PROSUC,XXX_TAGMIS,XXX_ALTPRG,XXX_ALTUSATA,XXX_NRTAGL
PUBLIC  XXX_CODSYS,XXX_PRIMA,XXX_PROGRE,XXX_LUNPRG,XXX_MISTAG,XXX_CLIELA,XXX_BOBPRG,XXX_QTAPRG,XXX_ALTEZZ,XXX_LUNGHE, ;
        XXX_BOBORD,XXX_QTAORD,XXX_SCARTO,XXX_LUNMAG,RIB_LUNGHE,RIB_NUMBOB,RIB_PROSUC,XXX_TAGMIS,XXX_ALTPRG,XXX_ALTUSATA,XXX_NRTAGL
XXX_CODSYS = SYS(2015)
XXX_PRIMA  = .T.
XXX_PROGRE = 0
XXX_LUNPRG = 0
XXX_MISTAG = ""
XXX_CLIELA = ""
XXX_BOBPRG = 0
XXX_QTAPRG = 0
XXX_BOBORD = 0
XXX_QTAORD = 0
XXX_SCARTO = .F.
XXX_LUNMAG = 0
RIB_NUMBOB = 0
RIB_LUNGHE = 0
RIB_PROSUC = 0
XXX_TAGMIS = ""
XXX_ALTPRG   = 0
XXX_ALTUSATA = 0
XXX_NRTAGL   = 0

SELECT RIE_RIBOBINATURA
ZAP

SELECT CUR_RIBOBINATURA
INDEX ON SEL_PROGRE TAG I_SPALMA ADDITIVE
INDEX ON ALLTRIM(STR(SEL_NUMLOT,8,0)) + ALLTRIM(STR(SEL_PROSUC,6,0)) + ALLTRIM(STR(SEL_PROGRE,9,0)) TAG I_SPALME ADDITIVE
SET ORDER TO I_SPALME
SET FILTER TO
GO TOP
IF EOF()
   RETURN
ENDIF

SCATTER MEMVAR MEMO
RIB_LUNGHE = SEL_LUNGHE
RIB_NUMBOB = SEL_BOBPRG / SEL_ACCOPP
RIB_PROSUC = SEL_PROSUC
XXX_TAGMIS = ""

DO WHILE .T.

   IF EOF()
      *=> Determino la percentuale di scarto
      XXX_ALTUSATA = XXX_ALTPRG + ((XXX_NRTAGL-1) * V_TAGLIO)
      V_SCCALC1    = 100 - (XXX_ALTUSATA * 100) / M.SEL_ALTMAG
      V_SCCALC2    = 100 - (XXX_ALTPRG * 100) / M.SEL_ALTMAG
      IF V_SCCALC1 > 0 .OR. V_SCCALC2 > 0
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "(Scarto A = " + ALLTRIM(STR(V_SCCALC2,6,2)) + " %  " + ;
                                                "Scarto B = " + ALLTRIM(STR(V_SCCALC1,6,2)) + " %)"
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + CHR(13)
      ENDIF
      IF EMPTY(ALLTRIM(XXX_TAGMIS))
         XXX_TAGMIS = ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ELSE
         XXX_TAGMIS = XXX_TAGMIS + CHR(13) + ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ENDIF
      XXX_PROGRE = XXX_PROGRE + 1
      SELECT RIE_RIBOBINATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_CODCLI WITH SPACE(10)
      REPLACE SEL_RAGSOC WITH SPACE(50)
      REPLACE SEL_NUMORD WITH SPACE(06)
      REPLACE SEL_DATORD WITH SPACE(10)
      REPLACE SEL_ALTEZZ WITH 0
      REPLACE SEL_LUNGHE WITH 0
      REPLACE SEL_BOBORD WITH XXX_BOBORD
      REPLACE SEL_QTAORD WITH XXX_QTAORD
      REPLACE SEL_LUNMAG WITH XXX_LUNMAG
      REPLACE SEL_UNIQUE WITH XXX_CODSYS
      REPLACE SEL_PROGRE WITH XXX_PROGRE
      REPLACE SEL_CODSYS WITH XXX_CODSYS
      REPLACE SEL_BOBPRG WITH XXX_BOBPRG
      REPLACE SEL_QTAPRG WITH XXX_QTAPRG
      REPLACE SEL_MISTAG WITH XXX_MISTAG
      REPLACE SEL_TAGMIS WITH XXX_TAGMIS
      REPLACE SEL_CLIELA WITH XXX_CLIELA
      REPLACE SEL_LUNPRG WITH XXX_LUNPRG
      REPLACE SEL_SCARTO WITH XXX_SCARTO
      EXIT
   ENDIF

   *=> Verifica rottura sequenza (cambia programma)
   IF SEL_NUMLOT = M.SEL_NUMLOT
   ELSE
      *=> Determino la percentuale di scarto
      XXX_ALTUSATA = XXX_ALTPRG + ((XXX_NRTAGL-1) * V_TAGLIO)
      V_SCCALC1    = 100 - (XXX_ALTUSATA * 100) / M.SEL_ALTMAG
      V_SCCALC2    = 100 - (XXX_ALTPRG * 100) / M.SEL_ALTMAG
      IF V_SCCALC1 > 0 .OR. V_SCCALC2 > 0
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "(Scarto A = " + ALLTRIM(STR(V_SCCALC2,6,2)) + " %  " + ;
                                                "Scarto B = " + ALLTRIM(STR(V_SCCALC1,6,2)) + " %)"
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + CHR(13)
      ENDIF
      IF EMPTY(ALLTRIM(XXX_TAGMIS))
         XXX_TAGMIS = ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ELSE
         XXX_TAGMIS = XXX_TAGMIS + CHR(13) + ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ENDIF
      XXX_PROGRE = XXX_PROGRE + 1
      SELECT RIE_RIBOBINATURA
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_CODCLI WITH SPACE(10)
      REPLACE SEL_RAGSOC WITH SPACE(50)
      REPLACE SEL_NUMORD WITH SPACE(06)
      REPLACE SEL_DATORD WITH SPACE(10)
      REPLACE SEL_ALTEZZ WITH 0
      REPLACE SEL_LUNGHE WITH 0
      REPLACE SEL_BOBORD WITH XXX_BOBORD
      REPLACE SEL_QTAORD WITH XXX_QTAORD
      REPLACE SEL_LUNMAG WITH XXX_LUNMAG
      REPLACE SEL_UNIQUE WITH XXX_CODSYS
      REPLACE SEL_PROGRE WITH XXX_PROGRE
      REPLACE SEL_CODSYS WITH XXX_CODSYS
      REPLACE SEL_BOBPRG WITH XXX_BOBPRG
      REPLACE SEL_QTAPRG WITH XXX_QTAPRG
      REPLACE SEL_MISTAG WITH XXX_MISTAG
      REPLACE SEL_TAGMIS WITH XXX_TAGMIS
      REPLACE SEL_CLIELA WITH XXX_CLIELA
      REPLACE SEL_LUNPRG WITH XXX_LUNPRG
      REPLACE SEL_SCARTO WITH XXX_SCARTO
      SELECT CUR_RIBOBINATURA
      SCATTER MEMVAR MEMO
      XXX_CODSYS = SYS(2015)
      XXX_PRIMA  = .T.
      XXX_LUNPRG = 0
      XXX_MISTAG = ""
      XXX_CLIELA = ""
      XXX_BOBPRG = 0
      XXX_QTAPRG = 0
      XXX_BOBORD = 0
      XXX_QTAORD = 0
      XXX_SCARTO = .F.
      XXX_LUNMAG = 0
      RIB_LUNGHE = SEL_LUNGHE
      RIB_NUMBOB = SEL_BOBPRG / SEL_ACCOPP
      RIB_PROSUC = SEL_PROSUC
      XXX_TAGMIS = ""
      XXX_NRTAGL   = 0
      XXX_ALTUSATA = 0
      XXX_ALTPRG   = 0
      LOOP
   ENDIF

   XX_CODCLI = SEL_CODCLI
   XX_RAGSOC = SEL_RAGSOC
   XX_UNIQUE = SEL_CODSYS
   XX_BOBPRG = SEL_BOBPRG
   XX_QTAPRG = SEL_QTAPRG
   XX_BOBORD = SEL_BOBORD
   XX_QTAORD = SEL_QTAORD
   XX_LUNMAG = SEL_LUNMAG
   XX_NRPAGI = SEL_PROGRE
   XX_LUNGHE = SEL_LUNGHE						&& PROJECT 08/07/2005

   SELECT CU_PRG_CL
   SET ORDER TO I_PRGCL2
   SEEK 'RIB' + XXX_CODSYS + XX_UNIQUE
   IF FOUND()
      REPLACE PRG_BOBPRG WITH PRG_BOBPRG + XX_BOBPRG
      REPLACE PRG_QTAPRG WITH PRG_QTAPRG + XX_QTAPRG
   ELSE
      APPEND BLANK
      REPLACE PRG_TIPO   WITH 'RIB'
      REPLACE PRG_CODSYS WITH XXX_CODSYS
      REPLACE PRG_CODCLI WITH XX_CODCLI
      REPLACE PRG_RAGSOC WITH XX_RAGSOC
      REPLACE PRG_UNIQUE WITH XX_UNIQUE
      REPLACE PRG_BOBPRG WITH XX_BOBPRG
      REPLACE PRG_QTAPRG WITH XX_QTAPRG
      REPLACE PRG_LUNGHE WITH XX_LUNGHE			&& PROJECT 08/07/2005
   ENDIF

   REPLACE PRG_NUMPRG WITH _V_NUMPRG
   REPLACE PRG_DATPRG WITH _V_DATPRG
   REPLACE PRG_PROGRE WITH XX_NRPAGI

   XXX_BOBPRG = XXX_BOBPRG + XX_BOBPRG
   XXX_QTAPRG = XXX_QTAPRG + XX_QTAPRG

   XXX_BOBORD = XXX_BOBORD + XX_BOBORD
   XXX_QTAORD = XXX_QTAORD + XX_QTAORD

   XXX_LUNMAG = XX_LUNMAG

   SELECT CUR_RIBOBINATURA

   IF SEL_SCARTO
      XXX_SCARTO = .T.
   ENDIF

   IF SEL_PROGRE = M.SEL_PROGRE
   ELSE
      *XXX_LUNPRG   = XXX_LUNPRG + ROUND((SEL_LUNGHE * SEL_BOBPRG) / SEL_ACCOPP,0)
      XXX_LUNPRG   = SEL_LUNPRG
      *=> Determino la percentuale di scarto
      XXX_ALTUSATA = XXX_ALTPRG + ((XXX_NRTAGL-1) * V_TAGLIO)
      V_SCCALC1    = 100 - (XXX_ALTUSATA * 100) / M.SEL_ALTMAG
      V_SCCALC2    = 100 - (XXX_ALTPRG * 100) / M.SEL_ALTMAG
      IF V_SCCALC1 > 0 .OR. V_SCCALC2 > 0
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "(Scarto A = " + ALLTRIM(STR(V_SCCALC2,6,2)) + " %  " + ;
                                                "Scarto B = " + ALLTRIM(STR(V_SCCALC1,6,2)) + " %)" +CHR(13) + ;
                        "==========================="
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + CHR(13) + "==========================="
      ELSE
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "==========================="
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + "==========================="
      ENDIF
      M.SEL_PROGRE = SEL_PROGRE
      IF RIB_LUNGHE = SEL_LUNGHE
         IF RIB_PROSUC = SEL_PROSUC
            RIB_NUMBOB = RIB_NUMBOB + (SEL_BOBPRG / SEL_ACCOPP)
            RIB_PROSUC = SEL_PROSUC
         ENDIF
      ENDIF
      XXX_ALTUSATA = 0
      XXX_NRTAGL   = 0
      XXX_ALTPRG   = 0
   ENDIF

   IF XXX_PRIMA
      XXX_PRIMA  = .F.
      *XXX_LUNPRG = ROUND((SEL_LUNGHE * SEL_BOBPRG) / SEL_ACCOPP,0)
      XXX_LUNPRG = SEL_LUNPRG
   ENDIF

   IF EMPTY(ALLTRIM(XXX_MISTAG))
      IF SUBSTR(SEL_RAGSOC,1,12) = 'FUORI ORDINE'
      ELSE
         XXX_NRTAGL = SEL_ACCOPP
         XXX_ALTPRG = (SEL_ALTEZZ * SEL_ACCOPP)
      ENDIF
      XXX_MISTAG = ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      XXX_CLIELA = ALLTRIM(SUBSTR(SEL_RAGSOC,1,23))
   ELSE
      IF SUBSTR(SEL_RAGSOC,1,12) = 'FUORI ORDINE'
      ELSE
         XXX_NRTAGL = XXX_NRTAGL + SEL_ACCOPP
         XXX_ALTPRG = XXX_ALTPRG + (SEL_ALTEZZ * SEL_ACCOPP)
      ENDIF
      XXX_MISTAG = XXX_MISTAG + CHR(13) + ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      XXX_CLIELA = XXX_CLIELA + CHR(13) + ALLTRIM(SUBSTR(SEL_RAGSOC,1,23))
   ENDIF

   IF RIB_LUNGHE = SEL_LUNGHE
      IF RIB_PROSUC = SEL_PROSUC
      ELSE
         RIB_NUMBOB = RIB_NUMBOB + (SEL_BOBPRG / SEL_ACCOPP)
         RIB_PROSUC = SEL_PROSUC
      ENDIF
   ELSE
      IF EMPTY(ALLTRIM(XXX_TAGMIS))
         XXX_TAGMIS = ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ELSE
         XXX_TAGMIS = XXX_TAGMIS + CHR(13) + ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ENDIF
      RIB_NUMBOB = SEL_BOBPRG / SEL_ACCOPP
      RIB_LUNGHE = SEL_LUNGHE
      RIB_PROSUC = SEL_PROSUC
   ENDIF

   SELECT CUR_RIBOBINATURA
   SKIP +1

ENDDO

RETURN



