                           STA_FLGELI C(02),    STA_CLIELA M(04),   STA_FLGEND L(01),   STA_TIPREC N(03),  STA_NUMRIG N(03),   ;
                           NUD_CODFOR C(10),    NUD_DESFOR C(50),   NUD_LUNGHE N(06),   NUD_UNITAM C(03),  NUD_QTAMQ N(12,2),  ;
                           NUD_QTAKG N(12,2),   NUD_CODINT C(16),   NUD_NUMLOT N(08),   NUD_CODMAG C(06),  STA_CODDYD C(10),   ;
                           ADE_CODICE C(16),    ADE_DESCRI C(50),   ADE_DSDIBA C(50),   ADE_UNITAM C(03),  ADE_QTAGIA N(16,6), ;
                           ADE_QTANEC N(16,6),  ADE_QTADOR N(16,6), ADE_SCORMI N(16,6), ADE_CODIMB C(03),  ADE_DESIMB C(50),   ;
                           ADE_LOTMIN N(12,2),  ADE_LIVELL N(10,0), ADE_QTADIB N(16,6), ADE_CODINT C(16),  ADE_NUMLOT N(08),   ;
                           ADE_CODFOR C(10),    ADE_DESFOR C(50),   ADE_CODMAG C(06),    									   ;
                           MAG_QTAGIA N(16,2),  AVA_CODAVA C(03),   AVA_DESAVA C(50),   AVA_DATAVA C(10),  AVA_AMGAVA C(10),   ;
                           AVA_ORAAVA C(08),    AVA_CONMTL N(10),   ADE_QTASCA N(16,6))
SELECT STA_RAPPROD
INDEX ON STA_NUMPRG + STA_DATPRG + STR(STA_PROGRE,6,0) TAG I_INDICE ADDITIVE

SELECT CUR_SALAMESCOLE
INDEX ON SEL_PROGRE TAG I_MESCOLA ADDITIVE

*§°§ SELECT CUR_SALAMESCOLE							&& DISATTIVATO TEMPORANEAMENTE (IN ACCORDO CON LANDI IN DATA 03/02/2005 - PROJECT)
*§°§ INDEX ON SEL_PROGRE TAG I_MESCOLA ADDITIVE		&& DISATTIVATO TEMPORANEAMENTE (IN ACCORDO CON LANDI IN DATA 03/02/2005 - PROJECT)

SELECT RIE_SPALMATURA
GO TOP

IF !EOF()
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      V_PROGRE = SEL_PROGRE
      V_CDART  = SEL_CODART
      V_DSART  = SEL_DESART
      V_MYORD  = SEL_SPESSO
      V_CILRE  = SEL_CILRET
      V_MYMAG  = SEL_SPEMAG
      V_CDCOL  = SEL_CODCOL
      V_DSCOL  = SEL_DESCOL
      V_CDMAT  = SEL_CODMAT
      V_DSMAT  = SEL_DESMAT
