		ENDIF

    ENDIF

	IF __ORD_GN__ = "N" 				&& NOBILITATO

		_PERCPRO_PERSONALIZZATE			= PRV_PERPRN

		IF  ALLTRIM(PRV_COGLI06)	= __GRUPPO_PRODUTTIVO
