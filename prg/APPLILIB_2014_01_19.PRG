FUNCTION _DATONUMERICO
******************************
* CONTROLLO DEL CONTENUTO DI UN CAMPO CONSIDERANDO SOLO I CARATTERI NUMERICI
* __DATO = CAMPO DA CONTROLLARE

PARA __DATO

__RISPO = .T.		&& DATO OK

LEN__DATO = LEN(ALLTRIM(__DATO))

FOR K=1 TO LEN__DATO

   IF ASC(SUBSTR(__DATO,K,1)) => 48 .AND. ASC(SUBSTR(__DATO,K,1)) <= 57
      LOOP   && CARATTERE CORRETTO
   ENDIF

   __RISPO = .F.	&& DATO KO

NEXT

RETURN(__RISPO)
