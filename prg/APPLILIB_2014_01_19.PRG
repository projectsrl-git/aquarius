SELECT CU_PRG_CL
INDEX ON PRG_TIPO + PRG_CODSYS TAG I_PRGCL1 ADDITIVE

x_nprg = "sta_numprg = sta_numprg"
x_dprg = "sta_amgprg = sta_amgprg"
x_prog = "sta_progre = sta_progre"
x_fend = "sta_flgend = 0"
