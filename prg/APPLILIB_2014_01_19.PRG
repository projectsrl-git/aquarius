******************************
FUNCTION STAM_NOTE            && PERMETTE STAMPARE O MENO I COMMENTI
******************************
PARA _TIPON,_CODICEN

RELEASE _SOLOIT,_SOLOEX
PUBLIC  _SOLOIT,_SOLOEX
_SOLOIT = .F.
_SOLOEX = .F.

SS=STR(SELECT())

x_soci = "not_codsoc = '" + PUB_CODSOC + "'"
x_codi = "not_codice = '" + ALLTRIM(_CODICEN) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from note_com where " + x_cond + " order by not_codsoc,not_codice"
IF !ExecCommand(cSql,"note_com")
   return(.f.)
ENDIF
SELECT note_com
GO TOP

V_DS = .F.

IF reccount() <> 0

   DO CASE

      CASE _TIPON = "BOL"
           IF NOS_BOLLE
		      V_DS= .T.	
           ENDIF

      CASE _TIPON = "OFF"
           IF NOS_OFFERT
		      V_DS= .T.	
           ENDIF

      CASE _TIPON = "ORD"
           IF NOS_ORDINI
		      V_DS= .T.	
           ENDIF

      CASE _TIPON = "FAP"
           IF NOS_FATTPR
		      V_DS= .T.	
           ENDIF

      CASE _TIPON = "SPE"
           IF NOS_DISTSP
		      V_DS= .T.	
           ENDIF

      CASE _TIPON = "COM"
           IF NOS_COMME
		      V_DS= .T.	
           ENDIF

      CASE _TIPON = "FAT"
           IF NOS_FATTUR
		      V_DS= .T.	
           ENDIF

   ENDCASE

   _SOLOIT = NOS_SOLOIT
   _SOLOEX = NOS_SOLOEX

   IF _SOLOIT .AND. _SOLOEX      && STAMPA SEMPRE TUTTO
   ELSE
      IF _SOLOIT				&& SOLO PER CLIENTE/FORNITORE ITALIA
	     IF M.ORD_CODNAZ  <>  "ITA"
 	        V_DS= .F.	
	     ENDIF
      ENDIF
      IF _SOLOEX				&& SOLO PER CLIENTE/FORNITORE ESTERO
         IF M.ORD_CODNAZ  =  "ITA"
  	        V_DS= .F.	
	     ENDIF
      ENDIF
   ENDIF
ENDIF

