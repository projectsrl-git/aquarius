      ENDIF
      *=> Aggiornamento sul cursore della sala mescole delle quantita' necessarie alla produzione
      SELECT ADE_SALAMESCOLEOF
      REPLACE SEL_QTAGIA WITH V_GIACEN
   ENDIF

   SELECT WEXPLODE
   SKIP +1

ENDDO



SELECT ADE_SALAMESCOLEOF
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   IF SEL_QTAGIA < SEL_QTANEC
      V_CODADE = M.SEL_CODART
      V_DESADE = M.SEL_DESART
      SELECT ADE_MANCANTI
      SET ORDER TO I_MANCA
      SEEK M.SEL_CODART
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE ADE_CODICE WITH M.SEL_CODART
         REPLACE ADE_DESCRI WITH M.SEL_DESART
      ENDIF
   ENDIF

   SELECT ADE_SALAMESCOLEOF
   SKIP +1

ENDDO

RETURN


