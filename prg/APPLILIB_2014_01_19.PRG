*********************************
PROCEDURE CREA_LISTINI_DI_VENDITA
*********************************
LPARAMETERS _CLIENTE_,_RAGSOC_,_DATADAL_,_DATAAL_,_LIS_DATADAL_,_LIS_DATAAL_

WAIT WINDOW "Creazione archivio listini in corso..." NOWAIT


IF _CLIENTE_= 'TUTTI'
	V_CLIDAL = '0000000000'
	V_CLIAL  = '9999999999'
ELSE
	V_CLIDAL = ALLTRIM(_CLIENTE_)
	V_CLIAL  = ALLTRIM(_CLIENTE_)
ENDIF


PERLISDAL	= RIBALTA2(_LIS_DATADAL_)
PERLISAL	= RIBALTA2(_LIS_DATAAL_)

PERDAL	 	= RIBALTA2(_DATADAL_)
PERAL	 	= RIBALTA2(_DATAAL_)
AMDAL		= SUBSTR(PERDAL,1,4)+SUBSTR(PERDAL,6,2)
AMAL	 	= SUBSTR(PERAL,1,4)+SUBSTR(PERAL,6,2)




IF _CLIENTE_= 'TUTTI'
	WAIT WINDOW "Cancellazione listini del periodo dal "+ _LIS_DATADAL_+ " al " + _LIS_DATAAL_ + " in corso..." NOWAIT
	CSQL = "DELETE FROM U_LIS_TT WHERE LIS_DATLIS >= '" + PERLISDAL + "' AND LIS_ALLIST <= '" + PERLISAL + "'"
	IF !ExecCommand(CSQL,"U_LIS_TT")
		RETURN (.f.)
	ENDIF
ELSE
	WAIT WINDOW "Cancellazione listini del periodo dal "+ _LIS_DATADAL_+ " al " + _LIS_DATAAL_ + " del cliente "+ _RAGSOC_ + " in corso..." NOWAIT
	CSQL = "DELETE FROM U_LIS_TT WHERE LIS_DATLIS >= '" + PERLISDAL + "' AND LIS_ALLIST <= '" + PERLISAL + "' AND LIS_CODCLI = '" + _CLIENTE_ + "'"
	IF !ExecCommand(CSQL,"U_LIS_TT")
		RETURN (.f.)
	ENDIF
ENDIF


x_soci = "TT.ORD_CODSOC = '01'"
x_magg = "DD.ORD_MAGGIORAZ = 0"
x_data = "TT.ORD_DATORD BETWEEN '" + PERDAL + "' AND '" + PERAL + "'"
x_comm = "DD.ORD_DESART <> '*** COMMENTO ***'"
x_poli = "DD.ORD_CODART <> 'POLIECO'"
x_arti = "DD.ORD_CODART <> '.'"
x_Cond = x_soci  + " and " + x_magg + " and " + x_data + " and " + x_comm + " and " + x_poli + " and " + x_arti
IF _OPZ_PANNELLO
	x_cmat = "AR.ART_CODMAT = '008'"
	x_cfin = "DD.ORD_CODART NOT LIKE 'FINITURA%'"
	x_Cond = x_Cond + " and " + x_cmat  + " and " + x_cfin
ENDIF
IF _CLIENTE_ <> 'TUTTI'
	x_clie = "TT.ORD_CODCLI = '" + _CLIENTE_ + "'"
	x_Cond = x_Cond + " and " + x_clie
ENDIF


cSql=""
cNomeCursorSql="FATTURE_LISTINI"
TEXT TO cSql NOSHOW

      SELECT
             TT.ORD_CODSOC AS LIS_CODSOC,
             TT.ORD_CODCLI AS LIS_CODCLI,
             CL.CLI_RAGSOC AS LIS_RAGSOC,
             '<<PERLISDAL>>' AS LIS_DATLIS,
             '<<PERLISAL>>' AS LIS_ALLIST,
             TT.ORD_VALUTA AS LIS_CODVAL,
             DD.ORD_CODART AS LIS_CODART,
             AR.ART_DESCR AS LIS_DESART,
             DD.ORD_UM AS LIS_UMMAGA
       FROM U_FAT_DD AS DD
       INNER JOIN U_FAT_TT AS TT ON TT.TAGGANCIO = DD.DAGGANCIO
       LEFT OUTER JOIN U_CLI_AN AS CL ON CL.CLI_CODSOC = TT.ORD_CODSOC AND CL.CLI_CODCLI = TT.ORD_CODCLI
       INNER JOIN U_ART_PR AS AR ON AR.ART_CODSOC = TT.ORD_CODSOC AND AR.ART_CODPRI = DD.ORD_CODART
       WHERE <<x_Cond>>
       GROUP BY TT.ORD_CODSOC,TT.ORD_CODCLI,CL.CLI_RAGSOC,TT.ORD_VALUTA,DD.ORD_CODART,AR.ART_DESCR,DD.ORD_UM

ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

SELECT FATTURE_LISTINI
GO TOP
IF EOF()
	WAIT CLEAR
	MESSAGEBOX("Nessuna fattura da rielaborare",16,"Attenzione")
	RETURN
ENDIF
SCAN


	WAIT WINDOW "Creazione archivio listini - Caricamento dati (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT

    SCATTER MEMVAR


	cSql=""
	cNomeCursorSql="ULTIMO_PREZZO"
	TEXT TO cSql NOSHOW

		SELECT TOP 1
		       DD.ORD_PRZNET,
		       DD.ORD_CODART,
		       DD.ORD_DESART,
		       DD.ORD_UM,
		       TT.ORD_CODSOC,
		       TT.ORD_CODCLI,
		       TT.ORD_VALUTA,
		       TT.ORD_DATORD,
		       TT.ORD_NUMORD
		FROM U_FAT_DD AS DD
		INNER JOIN U_FAT_TT AS TT ON TT.TAGGANCIO = DD.DAGGANCIO
		WHERE
		       TT.ORD_CODSOC = '01' AND
		       TT.ORD_CODCLI = '<<M.LIS_CODCLI>>' AND
		       TT.ORD_VALUTA = '<<M.LIS_CODVAL>>' AND
		       DD.ORD_CODART = '<<M.LIS_CODART>>' AND
		       DD.ORD_UM = '<<M.LIS_UMMAGA>>'
		ORDER BY ORD_DATORD DESC, ORD_NUMORD DESC
	
	ENDTEXT
	
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF	

	SELECT ULTIMO_PREZZO
	GO TOP
	IF !EOF()
		SCATTER MEMVAR MEMO
			
		cSql = "select * from U_LIS_TT where 0=1"
		IF !ExecRW(cSql,"U_LIS_TT","R")
		  return(.f.)
		ENDIF
		
		SELECT U_LIS_TT
		APPEND BLANK
		REPLACE LIS_CODSOC WITH M.LIS_CODSOC
		REPLACE LIS_CODCLI WITH M.LIS_CODCLI
		REPLACE LIS_RAGSOC WITH M.LIS_RAGSOC
		REPLACE LIS_CODART WITH M.ORD_CODART
		REPLACE LIS_DESART WITH M.ORD_DESART
		=CAMBIADT(M.LIS_DATLIS,"LIS_DATLIS")
		=CAMBIADT(M.LIS_ALLIST,"LIS_ALLIST")
		REPLACE LIS_PREZZO WITH M.ORD_PRZNET
		REPLACE SELEZIONE  WITH ''
		REPLACE LIS_CODVAL WITH M.ORD_VALUTA
		REPLACE LIS_UMMAGA WITH M.ORD_UM	

		IF !ExecRW(cSql,"U_LIS_TT","W")
		  return(.f.)
		ENDIF
				
	ENDIF
	

	
	SELECT FATTURE_LISTINI
	
ENDSCAN

WAIT CLEAR


V_RIT= MESSAGEB('Creazione archivio listini terminata correttamente',62,'*** ATTENZIONE ***')


RETURN



****************************************************************************
FUNCTION GESTIONE_PERSONALIZZAZIONE_DOCUMENTI
****************************************************************************
LPARAMETERS _CLIENTE_,_RAGSOC_


_choice = ""
DEFINE POPUP generatePop SHORTCUT RELATIVE FROM MROW(),MCOL()
DEFINE BAR 1 OF generatePop PROMPT "\<Fatture"
DEFINE BAR 2 OF generatePop PROMPT "\<Ordini"
DEFINE BAR 3 OF generatePop PROMPT "\<Documenti di trasporto"

ON SELECTION BAR 1 OF generatePop _choice = "FAT"
ON SELECTION BAR 2 OF generatePop _choice = "ORD"
ON SELECTION BAR 3 OF generatePop _choice = "BOL"

ACTIVATE POPUP generatePop

IF _choice = ""
	RETURN
ENDIF


DO CASE

	CASE _choice = "FAT"
		DO FORM FORM\DOCUMENTI WITH "FAT","C",_CLIENTE_,ALLTRIM(_RAGSOC_),""
		
	CASE _choice = "ORD"
		MESSAGEBOX("Funzione non ancora disponibile per Ordini clienti",64,"Informazione")

	CASE _choice = "BOL"
		MESSAGEBOX("Funzione non ancora disponibile per DDT clienti",64,"Informazione")
		
	OTHERWISE
		RETURN .F.

ENDCASE



RETURN




