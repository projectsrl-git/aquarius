      XX_QUAN = ORD_QTAORD
      XX_VALO = ORD_VALORE
      XX_TIPO = " "					&& DA DEFINIRE NUOVO CAMPO SU TABELLA PER IL CELLOPHANE
      x_soci = "ven_codsoc = '" + PUB_CODSOC + "'"
      x_anno = "ven_anno = " + ALLTRIM(STR(XX_ANNO,4,0))
      x_mese = "ven_mese = " + ALLTRIM(STR(XX_MESE,2,0))
      x_clie = "ven_codcli = '" + ALLTRIM(XX_CLIE) + "'"
      x_arti = "ven_codart = '" + ALLTRIM(XX_ARTI) + "'"
      x_tipo = "ven_tipo   = '" + ALLTRIM(XX_TIPO) + "'"
      x_tdoc = "ven_tipdoc = '" + ALLTRIM(_TIPOARC) + "'"
      x_cond = x_soci + " and " + x_anno + " and " + x_mese + " and " + x_clie + " and " + x_arti + " and " + ;
               x_tipo + " and " + x_tdoc
      cSql   = "select * from u_ven_cl where " + x_cond
      IF !ExecRW(cSql,'U_VEN_CL',"R")
         return(.f.)
      ENDIF
      SELECT U_VEN_CL
      GO TOP
      IF EOF()
         APPEND BLANK
         REPLACE VEN_CODSOC WITH PUB_CODSOC
         REPLACE VEN_ANNO   WITH XX_ANNO
         REPLACE VEN_MESE   WITH XX_MESE
         REPLACE VEN_CODART WITH XX_ARTI
