************************************
FUNCTION DETERMINA_MAGAZZINO
************************************
PARAMETERS __TIPO___,__SPESSO,__TIPON

WIW=SELECT()


__CODMAGA 	= ""


DO CASE

	CASE	__TIPO___  = '008'  			&& GESTIONE ARTICOLI PANNELLI TRUCIOLARI

			DO CASE
			  CASE BETWEEN(__SPESSO,8,19)	&& SPESSORI DA 8mm A 19mm  : MAGAZZINO 5
				   __CODMAGA = PUB_LEVIGA1
			  CASE BETWEEN(__SPESSO,20,40)	&& SPESSORI DA 20mm A 40mm : MAGAZZINO 4
				   __CODMAGA = PUB_LEVIGA2
			  CASE BETWEEN(__SPESSO,41,60)	&& SPESSORI DA 41mm A 60mm : MAGAZZINO 10
				   __CODMAGA = PUB_LEVIGA3
			ENDCASE

			IF !EMPTY(__TIPON)				&& NOBILITATTO : MAGAZZINO 2
			   __CODMAGA = PUB_NOBILI
			ENDIF


	CASE	__TIPO___  = '011'  			&& GESTIONE ARTICOLI PANNELLI TRUCIOLARI : CARTE IMPREGNATE MAGAZZINO 3
 			__CODMAGA = PUB_CAIPPT



	OTHERWISE
			__CODMAGA    = PUB_CODM

ENDCASE


IF EMPTY(__CODMAGA)
	__CODMAGA    = PUB_CODM
ENDIF


SELECT(WIW)
RETURN(__CODMAGA)


***************************
FUNCTION CERCA_PREZZO_COSTO
***************************
LPARAMETERS _par_codart,_par_codfor

WW = SELECT()

_rit = 0

