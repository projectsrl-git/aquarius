SET FILTER TO
INDEX ON RIBALTA2(STA_DATINI) + STA_CODMAC + STR(STA_PROGRE,6,0) TAG I_RAPPORTO ADDITIVE
SET ORDER TO I_RAPPORTO
GO TOP
IF EOF()
   RETURN
ENDIF

*=> Elenco dei mandrini necessari per la prg attuale
SELECT &V_ARCH
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   IF M.STA_TIPREC = 1
   ELSE
      SELECT &V_ARCH
      SKIP +1
      LOOP
   ENDIF

   WMA_ALTEZZ = STA_ALTMAG
   WMA_SPESSO = STA_SPEORD
   WMA_CODSYS = STA_SYSCLI
   WMA_MANDRI = SPACE(10)

   DO RILEVA_MANDRINO

   SELECT CUR_MANDRI
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      SCATTER MEMVAR MEMO
      SELECT STA_MANDRI
      SET ORDER TO I_MANDRI
      SEEK M.MAN_CODMAN
      IF FOUND()
         REPLACE MAN_NUMMAN WITH MAN_NUMMAN + M.MAN_NUMMAN
      ELSE
         APPEND BLANK
         GATHER MEMVAR MEMO
         REPLACE MAN_GIAMAN WITH 0
         REPLACE MAN_ORFMAN WITH 0
      ENDIF
      SELECT CUR_MANDRI
      SKIP +1
   ENDDO

   SELECT &V_ARCH
   SKIP +1

ENDDO

RETURN


***************************************************************************
PROCEDURE rileva_fabb_giacenze
***************************************************************************

SELECT STA_MANDRI
SET ORDER TO I_MANDRI
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   WMA_GIACEN = 0

   x_soci   = "mag_codsoc = '" + PUB_CODSOC + "'"
   x_data   = "mag_datagg <> SPACE(10)"
   x_codi   = "mag_codart = '" + ALLTRIM(M.MAN_CODMAN) + "'"
   x_maga   = "mag_codmag = mag_codmag"
   x_forn   = "mag_fornit = mag_fornit"
   x_cond   = x_soci + " and " + x_data + " and " + x_codi + " and " + x_maga + " and " + x_forn
   Csql     = "select * from u_mag_gg where " + x_cond + " order by mag_codsoc,mag_datagg,mag_codart,mag_codmag,mag_fornit"
   IF !ExecCommand(cSql,"CUW_MAG_GG")
      return(.f.)
   ENDIF
   SELECT CUW_MAG_GG
   GO TOP

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF MAG_GIACEN > 0
      ELSE
         SKIP +1
         LOOP
      ENDIF

      WMA_GIACEN = WMA_GIACEN + MAG_GIACEN

      SKIP +1

   ENDDO

   SELECT STA_MANDRI
   REPLACE MAN_GIAMAN WITH WMA_GIACEN

   SKIP +1

ENDDO

RETURN


***************************************************************************
PROCEDURE rileva_fabb_ordforn
***************************************************************************

SELECT STA_MANDRI
SET ORDER TO I_MANDRI
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   WMA_SCORMIN = 0

   x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "art_codpri = '" + ALLTRIM(M.MAN_CODMAN) + "'"
   x_cond = x_soci + " and " + x_codi
   Csql   = "select * from u_art_pr where " + x_cond + " order by art_codsoc,art_codpri"
   IF !ExecCommand(cSql,"cur_articoli")
      return(.f.)
   ENDIF
   SELECT cur_articoli
   GO TOP
   IF EOF()
   ELSE
      WMA_SCORMIN = ART_SCORMI
   ENDIF

   WMA_ORDFORN = 0

   x_arti   = "ord_codart = '" + ALLTRIM(M.MAN_CODMAN) + "'"
   x_sald   = "ord_salcon <> 'S'"
   x_cond   = x_arti + " and " + x_sald
   Csql     = "select * from u_orf_dd where " + x_cond
   IF !ExecCommand(cSql,"CUW_ORF_DD")
      return(.f.)
   ENDIF
   SELECT CUW_ORF_DD
   GO TOP

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      WMA_ORDFORN = WMA_ORDFORN + ROUND(((ORD_NUMBOB * ORD_QTAEV) / ORD_QTAORD),0)

      SKIP +1

   ENDDO

   SELECT STA_MANDRI
   REPLACE MAN_ORFMAN WITH WMA_ORDFORN
   REPLACE MAN_SCOMIN WITH WMA_SCORMIN
   REPLACE MAN_ORDMAN WITH MAN_NUMMAN - MAN_GIAMAN - MAN_ORFMAN + MAN_SCOMIN

   SKIP +1

ENDDO

RETURN



