*************************************************************************************************************************
FUNCTION OK_SCONTI_CLIENTE_INCONDIZIONATO
*************************************************************************************************************************
**  ACCEDE ALLA ANAGRAFICA CLIENTI PER PRELEVARE LO SCONTO INCONDIZIONATO APPLICANDOLO AL PRIMO DEI 5 SCONTI ANCORA VUOTI
*************************************************************************************************************************

PARA _SOC,_CLI


S_S=STR(SELECT())


local_cliente 		= _CLI


x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
x_codi = "cli_codcli = '" + ALLTRIM(local_cliente) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"cu_cli_an")
   return(.f.)
ENDIF
SELECT cu_cli_an
GO TOP
IF !EOF()


*!*	    DO CASE
*!*	    	
*!*	    	CASE PUB_SC1 = 0
*!*	    		PUB_SC1 = CLI_SCINCO
*!*	    		
*!*	    	CASE PUB_SC2 = 0
*!*	    		PUB_SC2 = CLI_SCINCO
*!*	    		    	
*!*	    	CASE PUB_SC3 = 0
*!*	    		PUB_SC3 = CLI_SCINCO
*!*	    		    	
*!*	    	CASE PUB_SC4 = 0
*!*	    		PUB_SC4 = CLI_SCINCO
*!*	    		    	
*!*	    	CASE PUB_SC5 = 0
*!*	     		PUB_SC5 = CLI_SCINCO
*!*	     		
*!*	    ENDCASE
*!*	
*!*	    ORD_SC1	= PUB_SC1
*!*	    ORD_SC2	= PUB_SC2
*!*	    ORD_SC3	= PUB_SC3
*!*	    ORD_SC4	= PUB_SC4
*!*	    ORD_SC5	= PUB_SC5

	**=> ERASMO - INIZIO 13/12/2011
	IF CLI_SCINCO > 0
		_nSconti = 5
		FOR i = 1 TO _nSconti							
			_cFldName = "M.ORD_SC" + ALLTRIM(STR(i,1,0))
			IF &_cFldName > 0
			ELSE
				&_cFldName = CLI_SCINCO
				EXIT
			ENDIF
		ENDFOR
	ENDIF
	**=> ERASMO - FINE 13/12/2011

ENDIF


SELECT &S_S
RETURN


***************************************************************************
FUNCTION LABEL_NR_PEZZI_PRODOTTO_FINITO
***************************************************************************
** RESTITUISCE LA DESCRIZIONE DA FAR COMPARIRE NELLE ETICHETTE CHE INDICANO
** IL NUMERO PEZZI DEL PRODOTTO FINITO IN BASE AL TIPO DI PRODUZIONE ATTIVA
***************************************************************************

LPARAMETERS _par_tipo

IF PCOUNT() = 0
	_par_tipo = "ESTESA"
ENDIF

_RIT = ""

IF _par_tipo = "ESTESA"
	DO CASE
		CASE PUB_PRDFILM
			_RIT = "rotoli"
		CASE PUB_PRGPLET
			_RIT = "pannelli"
	 	OTHERWISE
	 		_RIT = "pezzi"
	ENDCASE
ENDIF

IF _par_tipo = "RIDOTTA"
	DO CASE
		CASE PUB_PRDFILM
			_RIT = "rot."
		CASE PUB_PRGPLET
			*_RIT = "fogli"		&& SERGIO 09/07/2013
			_RIT = "pezzi"		&& SERGIO 09/07/2013
	 	OTHERWISE
	 		_RIT = "pz."
	ENDCASE
ENDIF

RETURN _RIT

