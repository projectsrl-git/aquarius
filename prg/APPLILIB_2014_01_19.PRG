         ENDIF
      ELSE
         IF XX_SEGNO = '+'
            REPLACE VEN_QTAVEN WITH VEN_QTAVEN + XX_QUAN
            REPLACE VEN_VALVEN WITH VEN_VALVEN + XX_VALO
