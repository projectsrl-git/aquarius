PROCEDURE CARI_DIR
*******************
* RICARICO IN AUTOMATICO DEL MAGAZZINO DIREZIONALE

IF PUB_CLIDIR
   XX=SELECT()
   SCATTER MEMVAR MEMO
   x_aggi = "daggancio = '" + M.TAGGANCIO + "'"
   x_cond = x_aggi
   Csql   = "select * from u_bol_dd where " + x_cond + " order by daggancio"
   IF !ExecCommand(cSql,"curs_bol_dd")
