x_soci = "u_art_pr.art_codsoc = '" + PUB_CODSOC + "'"
*x_codi = "u_art_pr.art_codpri = '" + _art_2ndscelta + "'"
x_codi = "u_art_pr.art_codpri = '" + _art_Nscelta + "'"  && ERASMO - 22/06/2012
