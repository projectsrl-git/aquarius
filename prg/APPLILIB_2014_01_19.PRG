***************************************************************************
PROCEDURE taglio_generagiacenze						
***************************************************************************

WAIT WINDOWS "PROGRAMMAZIONE DEL TAGLIO : " + CHR(13) + ;
             "Stň riepilogando le giacenze di film spalmato giŕ ribobinato necessario alla programmazione" NOWAIT

RELEASE __DUEMAG,__STEPTG,__CALFAB
PUBLIC  __DUEMAG,__STEPTG,__CALFAB

x_codi = "codice = 'PDP01'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __DUEMAG = 'NO'
ELSE
   __DUEMAG = SUBSTR(LIBERA,1,2)
ENDIF

x_codi = "codice = 'PDP02'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __STEPTG = 'NO'
ELSE
   __STEPTG = SUBSTR(LIBERA,1,2)
ENDIF

x_codi = "codice = 'GCF01'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __CALFAB = 'NO'
ELSE
   __CALFAB = SUBSTR(LIBERA,1,2)
ENDIF

IF __STEPTG = 'SI'
   SET STEP ON
ENDIF

*=> Riepilogo delle giacenze di film spalmato gia' ribobinato presente a magazzino
x_data = "mag_datagg <> SPACE(10)"
x_giac = "mag_giacen > 0"
IF __DUEMAG = 'SI'
   x_maga = "mag_codmag = mag_codmag"
ELSE
   x_maga = "mag_codmag = '" + ALLTRIM(PUB_RIBSLR) + "'"
ENDIF
x_impe = "mag_qtaimp < mag_giacen"
x_ribo = "mag_flgrib = 1"
x_cond = x_data + " and " + x_giac + " and " + x_maga + " and " + x_impe + " and " + x_ribo
Csql   = "select * from u_mag_gg where " + x_cond + " order by mag_codmat,mag_codcol,mag_spesso,mag_altezz desc,mag_nrlint,MAG_QTAML desc"
IF !ExecCommand(Csql,"T_MAG_GG")
   return(.f.)
ENDIF
SELECT T_MAG_GG
REPLACE SELEZIONE WITH "=>" ALL

SELECT T_MAG_GG
INDEX ON ID_UNIQUE TAG I_RMAGG0 ADDITIVE

* -->> Inizio elaborazione per aggiungere le giacenze di film nudo a fronte di ordini clienti di sola ribobinatura
* -->> e/o taglio

SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF ORD_UM = 'KG' .OR. EMPTY(ALLTRIM(ORD_CDDIBA))
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Riepilogo delle giacenze di film spalmato presente a magazzino
   IF M.ORD_SPESSO > 0
      x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
      x_tmat = "mag_codmat = '" + M.ORD_CODMAT + "'"
      x_colo = "mag_codcol = '" + M.ORD_CODCOL + "'"
      x_spes = "mag_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
      x_alte = "mag_altezz >= " + ALLTRIM(STR(M.ORD_ALTEZZ,5,0))
      x_lung = "mag_lunghe = " + ALLTRIM(STR(M.ORD_LUNGHE,6,0))
      x_arti = "mag_codart = mag_codart"
      x_nrli = "mag_nrlint = mag_nrlint"
      x_maga = "mag_codmag = '" + ALLTRIM(PUB_CQUMPC) + "'"
      x_forn = "mag_fornit = mag_fornit"
      x_nide = "mag_numide = mag_numide"
      x_anno = "mag_anno = mag_anno"
      x_data = "mag_datagg <> SPACE(10)"
      x_giac = "mag_giacen > 0"
      x_impe = "mag_qtaimp < mag_giacen"
   ELSE
      x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
      x_tmat = "mag_codmat = mag_codmat"
      x_colo = "mag_codcol = '" + M.ORD_CODCOL + "'"
      x_spes = "mag_spesso = mag_spesso"
      x_alte = "mag_altezz >= " + ALLTRIM(STR(M.ORD_ALTEZZ,5,0))
      x_lung = "mag_lunghe = mag_lunghe"
      x_arti = "mag_codart = mag_codart"
      x_nrli = "mag_nrlint = mag_nrlint"
      x_maga = "mag_codmag = '" + ALLTRIM(PUB_CQUMPC) + "'"
      x_forn = "mag_fornit = mag_fornit"
      x_nide = "mag_numide = mag_numide"
      x_anno = "mag_anno = mag_anno"
      x_data = "mag_datagg <> SPACE(10)"
      x_giac = "mag_giacen > 0"
      x_impe = "mag_qtaimp < mag_giacen"
   ENDIF
   x_cond = x_soci + " and " + x_tmat + " and " + x_colo + " and " + x_spes + " and " + x_alte
   x_cond = x_cond + " and " + x_lung + " and " + x_arti + " and " + x_nrli + " and " + x_maga
   x_cond = x_cond + " and " + x_forn + " and " + x_nide + " and " + x_anno + " and " + x_data
   x_cond = x_cond + " and " + x_giac + " and " + x_impe
   cSql   = "select * from u_mag_gg where " + x_cond + " order by mag_datagg,mag_codart"
   IF !ExecCommand(cSql,'CUR_MAGAZZINO')
      return(.f.)
   ENDIF
   SELECT CUR_MAGAZZINO
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF M.ORD_SPESSO = 0
         IF MAG_FLGIMB
         ELSE
            SKIP +1
            LOOP
         ENDIF
      ENDIF
      SCATTER MEMVAR MEMO
      XS_UNIQUE = ID_UNIQUE
      SELECT T_MAG_GG
      SET ORDER TO I_RMAGG0
      SEEK XS_UNIQUE
      IF FOUND()
      ELSE
         APPEND BLANK
         GATHER MEMVAR MEMO
         REPLACE SELEZIONE WITH "=>"
      ENDIF
      SELECT CUR_MAGAZZINO
      SKIP +1
   ENDDO

   SELECT CU_ORD_DL
   SKIP +1

ENDDO

* -->> Inizio elaborazione per creazione cursori di giacenza

SELECT T_MAG_GG
SET FILTER TO
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
   IF __DUEMAG = 'SI'
      IF mag_codmag = PUB_RIBSLR .OR. mag_codmag = PUB_RIBPRO
      ELSE
         DELETE
         SKIP +1
         LOOP
      ENDIF
   ENDIF
   REPLACE MAG_NLPROV WITH 99999 - MAG_ALTEZZ	&& ALTEZZA COMPLEMENTATA
   REPLACE MAG_BYPASS WITH .F.
   REPLACE MAG_FLGMOD WITH .F.
   REPLACE MAG_ALTRES WITH MAG_ALTEZZ
   REPLACE MAG_GIACEN WITH MAG_GIACEN - MAG_QTAIMP
   REPLACE MAG_QTAKG  WITH MAG_QTAKG  - MAG_GKGIMP
   REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  - MAG_QTAIMP
   REPLACE MAG_QTAML  WITH MAG_QTAML  - MAG_GMLIMP
   REPLACE MAG_COMODO WITH MAG_GIACEN
   REPLACE MAG_QTAIMP WITH 0
   REPLACE MAG_GKGIMP WITH 0
   REPLACE MAG_GMLIMP WITH 0
   IF MAG_GIACEN > 0
      IF MAG_QTAKG > 0
         IF MAG_QTAMQ > 0
            IF MAG_QTAML > 0
            ELSE
               DELETE
            ENDIF
         ELSE
            DELETE
         ENDIF
      ELSE
         DELETE
      ENDIF
   ELSE
      DELETE
   ENDIF
   SKIP +1
ENDDO

SELECT T_MAG_GG
GO TOP
IF EOF()
ELSE
   *=> Se calcolo fabbisogni non devo visualizzare le giacenze per successiva selezione
   IF _V_FABBIS
      *=> Se il calcolo dei fabbisogni NON deve tenere conto delle giacenze esistenti al netto dell'impegnato, cancello
      *=> il cursore delle giacenze, in modo da generare un fabbisogno totale
      IF __CALFAB = 'NO'
      ELSE
         ZAP
      ENDIF
   ELSE
      IF PUB_VISGIAC
         RIT = MESSAGEBOX("Vuoi consultare le Bobine spalmate ribobinate in giacenza ?",292,"ATTENZIONE")
         IF RIT = 7
         ELSE
            _V_OPZORD1 = 1
            _V_OPZORD3 = 1
            _V_OPZORD4 = 1
            DO FORM FORM\VEDIGIACT LINKED
         ENDIF
      ENDIF
   ENDIF
ENDIF

SELECT T_MAG_GG
INDEX ON MAG_ANAART + MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_NLPROV,5,0) + ;
         STR(MAG_NRLINT,8,0)																		TAG I_TMAGG1 ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + ;
         STR(MAG_LUNGHE,6,0) + STR(MAG_NRLINT,8,0)  												TAG I_TMAGG2 ADDITIVE
INDEX ON ID_UNIQUE																					TAG I_TMAGG3 ADDITIVE
INDEX ON MAG_CODART + MAG_CODMAG									 								TAG I_TMAGG4 ADDITIVE
INDEX ON MAG_CODCOL													 								TAG I_TMAGG5 ADDITIVE
INDEX ON STR(MAG_NRLINT,8,0)  																		TAG I_TMAGG6 ADDITIVE

RETURN


***************************************************************************
PROCEDURE taglio_programmazione						
***************************************************************************


RELEASE V_DIBA,V_TROV,V_ALTEZZA,V_LUNGHEZ,V_ACCBOBI,V_PERCNOUSATA,V_ACCOPPIA,V_ALTUSATA, ;
        V_MAX_BOB_SPALM,V_LUNGORD,V_PROGRE,V_SCAR,V_SCAABU,V_ALMAFN,V_ALMIFN,V_LUMIFN,V_LUMAIN,__TOLL,__OLDNEW
PUBLIC  V_DIBA,V_TROV,V_ALTEZZA,V_LUNGHEZ,V_ACCBOBI,V_PERCNOUSATA,V_ACCOPPIA,V_ALTUSATA, ;
        V_MAX_BOB_SPALM,V_LUNGORD,V_PROGRE,V_SCAR,V_SCAABU,V_ALMAFN,V_ALMIFN,V_LUMIFN,V_LUMAIN,__TOLL,__OLDNEW
V_DIBA          = SPACE(16)
V_TROV          = .F.
V_ALTEZZA       = 0
V_LUNGHEZ       = 0
V_ACCBOBI       = 0
V_PERCNOUSATA   = 0
V_ACCOPPIA      = 0
V_ALTUSATA      = 0
V_MAX_BOB_SPALM = 0
V_LUNGORD       = 0
V_PROGRE        = 0
V_SCAR          = .F.
V_SCAABU        = 0
V_ALMAFN        = 0
V_ALMIFN        = 0
V_LUMIFN        = 0
V_LUMAIN        = 0

x_codi = "codice = 'GTP01'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __TOLL   = 'SI'
   __OLDNEW = 'NEW'
ELSE
   __TOLL   = SUBSTR(LIBERA,1,2)
   __OLDNEW = SUBSTR(DESIVA,1,3)
ENDIF
IF EMPTY(__OLDNEW)
   __OLDNEW = 'NEW'
ENDIF

CREATE CURSOR CUR_SELEZIONE (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50), SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                             SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03), SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                             SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05), SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                             SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05), SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                             SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16), SEL_SCARTO L(1),  ;
                             SEL_CODSYS C(10),   SEL_CILRET N(03), SEL_LUNPRG N(16))

CREATE CURSOR CUR_TAGLIO (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50),   SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                          SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03),   SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                          SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05),   SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                          SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05),   SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                          SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16),   SEL_PROGRE N(06), ;
                          SEL_CODMAC C(03),   SEL_DESMAC C(50), SEL_SCARTO L(01),   SEL_ALTCOM N(05),   SEL_CODSYS C(10), ;
                          SEL_FLGELI C(02),   SEL_CILRET N(03), SEL_MISTAG M(04),   SEL_CLIELA M(04),   SEL_LUNPRG N(16), ;
                          SEL_FLGELA L(01),   SEL_PROSUC N(06), SEL_NUMLOT N(08),   SEL_TAGMIS M(04),   SEL_NUMTAG N(10), ;
                          SEL_LEGSYS C(10))

CREATE CURSOR RIE_TAGLIO (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50),   SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                          SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03),   SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                          SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05),   SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                          SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05),   SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                          SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16),   SEL_PROGRE N(06), ;
                          SEL_CODMAC C(03),   SEL_DESMAC C(50), SEL_SCARTO L(01),   SEL_ALTCOM N(05),   SEL_CODSYS C(10), ;
                          SEL_FLGELI C(02),   SEL_CILRET N(03), SEL_MISTAG M(04),   SEL_CLIELA M(04),   SEL_LUNPRG N(16), ;
                          SEL_FLGELA L(01),   SEL_PROSUC N(06), SEL_NUMLOT N(08),   SEL_TAGMIS M(04),   SEL_NUMTAG N(10), ;
                          SEL_LEGSYS C(10))

CREATE CURSOR MAG_TAGLIO (MAG_ANAART C(16),   MAG_CODART C(16), MAG_DESART C(50),   MAG_CODCLI C(10),   MAG_RAGSOC C(50), ;
                          MAG_NUMORD C(06),   MAG_DATORD C(10), MAG_CODCOL C(03),   MAG_DESCOL C(30),   MAG_CODMAT C(03), ;
                          MAG_DESMAT C(30),   MAG_SPESSO N(05), MAG_ALTEZZ N(05),   MAG_LUNGHE N(06),   MAG_CODMAG C(06), ;
                          MAG_QTAMQ N(12,2),  MAG_QTAKG N(12,2), MAG_NUMPRG C(06),  MAG_DATPRG C(10),   MAG_SETTDA C(07), ;
                          MAG_SETTAL C(07),   MAG_DATADA C(10),  MAG_DATAAL C(10))
INDEX ON MAG_CODCLI+MAG_DATORD+MAG_NUMORD+MAG_CODMAG+MAG_ANAART+MAG_CODART TAG I_MAGTAG ADDITIVE

WAIT WINDOWS "PROGRAMMAZIONE DEL TAGLIO : " + CHR(13) + ;
             "Determinazione del numero di rotoli da tagliare" NOWAIT

*=> ******************************************************** <=*
*=>                                                          <=*
*=>    P R O G R A M M A Z I O N E   D E L   T A G L I O     <=*
*=>                                                          <=*
*=> ******************************************************** <=*

*=> Decurtazione delle quantitŕ giŕ programmate per il taglio
RELEASE X_NRBPRG,X_QTAPRG
PUBLIC  X_NRBPRG,X_QTAPRG

IF __STEPTG = 'SI'
   SET STEP ON
ENDIF

SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL NUMERO DI BOBINE DA TAGLIARE = 0
   IF ORD_NRBTGD > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   *=> Verifica della conferma dell'ordine
   x_agga = "taggancio = '" + DAGGANCIO + "'"
   x_cond = x_agga
   Csql   = "select * from u_ord_tt where " + x_cond
   IF !ExecCommand(cSql,"cur_testata")
      return(.f.)
   ENDIF
   SELECT cur_testata
   GO TOP
   IF EOF()
      SELECT CU_ORD_DL
      SKIP +1
      LOOP
   ENDIF
   IF ORD_FLGCON
   ELSE
      SELECT CU_ORD_DL
      SKIP +1
      LOOP
   ENDIF

   SELECT CU_ORD_DL

   SCATTER MEMVAR MEMO

   X_NRBPRG = 0
   X_QTAPRG = 0

   *=> VERIFICA ESISTENZA GIACENZE DISPONIBILI DA NON LAVORARE PERCHE' GIA' PRONTE PER LA SPEDIZIONE

   V_SEEK = M.ORD_CODART + M.ORD_CODMAT + M.ORD_CODCOL + STR(M.ORD_SPESSO,5,0)

   SET NEAR ON

   SELECT T_MAG_GG
   SET ORDER TO I_TMAGG1
   SEEK V_SEEK

   DO WHILE .T.

      *=> Verifica fine elaborazione

      IF EOF()
         EXIT
      ENDIF

      IF DELETED()
         SKIP +1
         LOOP
      ENDIF

      IF M.ORD_CODART = MAG_ANAART
      ELSE
         EXIT
      ENDIF

      IF M.ORD_CODMAT = MAG_CODMAT
      ELSE
         EXIT
      ENDIF

      IF M.ORD_CODCOL = MAG_CODCOL
      ELSE
         EXIT
      ENDIF

      IF M.ORD_SPESSO = MAG_SPESSO
      ELSE
         EXIT
      ENDIF

      *=> By-passo le giacenze a 0
      IF MAG_GIACEN > 0
      ELSE
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le giacenze giŕ impegnate
      IF MAG_QTAIMP > 0
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le altezze diverse dall'ordine
      IF M.ORD_ALTEZZ = MAG_ALTEZZ
      ELSE
         SKIP +1
         LOOP
      ENDIF

      *=> By-passo le lunghezze diverse dall'ordine
      IF M.ORD_LUNGHE = MAG_QTAML
      ELSE
         SKIP +1
         LOOP
      ENDIF

      IF M.ORD_NRBTGD > X_NRBPRG
      ELSE
         EXIT
      ENDIF

      *=> By-passo le giacenze con aggiunte solo se il cliente NON le accetta (vedi ITALPANNELLI)

      * IF ALLTRIM(SUBSTR(M.ORS_RAGSOC,1,7)) = 'ITALPAN'
      IF !ACCETTA_AGGIUNTE(M.ORS_CODCLI)
         IF MAG_FLGAGG
            SKIP +1
            LOOP
         ENDIF
      ENDIF

      ZZ_ANAART = MAG_ANAART
      ZZ_CODART = MAG_CODART
      ZZ_DESART = MAG_DESART
      ZZ_CODCOL = MAG_CODCOL
      ZZ_DESCOL = MAG_DESCOL
      ZZ_CODMAT = MAG_CODMAT
      ZZ_DESMAT = MAG_DESMAT
      ZZ_SPESSO = MAG_SPESSO
      ZZ_ALTEZZ = MAG_ALTEZZ
      ZZ_LUNGHE = MAG_QTAML
      ZZ_CODMAG = MAG_CODMAG
      ZZ_QTAMQ  = MAG_QTAMQ
      ZZ_QTAKG  = MAG_QTAKG

      X_NRBPRG = X_NRBPRG + 1
      X_QTAPRG = X_QTAPRG + TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_QTAML,1)

      SELECT MAG_TAGLIO
      APPEND BLANK
      REPLACE MAG_ANAART WITH ZZ_ANAART
      REPLACE MAG_CODART WITH ZZ_CODART
      REPLACE MAG_DESART WITH ZZ_DESART
      REPLACE MAG_CODCLI WITH M.ORS_CODCLI
      REPLACE MAG_RAGSOC WITH M.ORS_RAGSOC
      REPLACE MAG_NUMORD WITH M.ORS_NUMORD
      REPLACE MAG_DATORD WITH M.ORS_DATORD
      REPLACE MAG_CODCOL WITH ZZ_CODCOL
      REPLACE MAG_DESCOL WITH ZZ_DESCOL
      REPLACE MAG_CODMAT WITH ZZ_CODMAT
      REPLACE MAG_DESMAT WITH ZZ_DESMAT
      REPLACE MAG_SPESSO WITH ZZ_SPESSO
      REPLACE MAG_ALTEZZ WITH ZZ_ALTEZZ
      REPLACE MAG_LUNGHE WITH ZZ_LUNGHE
      REPLACE MAG_CODMAG WITH ZZ_CODMAG
      REPLACE MAG_QTAMQ  WITH ZZ_QTAMQ
      REPLACE MAG_QTAKG  WITH ZZ_QTAKG

      SELECT T_MAG_GG
      DELETE
      SKIP +1

   ENDDO

   SET NEAR OFF

   *=> AGGIORNO IL NUMERO DELLE BOBINE DA PROGRAMMARE
   SELECT CU_ORD_DL
   REPLACE ORD_NRBTGD WITH ORD_NRBTGD - X_NRBPRG
   REPLACE ORD_QTATGD WITH ORD_QTATGD - X_QTAPRG

   SKIP +1

ENDDO

RELEASE V__SCARTO
PUBLIC  V__SCARTO
V__SCARTO = V_SCARTO

*=> ELABORO TUTTE LE RIGHE D'ORDINE CLIENTE SELEZIONATE PER LA PRODUZIONE IN TAGLIO

DO WHILE .T.

   IF V__SCARTO > V_SCAMAX
      EXIT
   ENDIF

   SELECT T_MAG_GG
   REPLACE MAG_BYPASS WITH .F. ALL

   SELECT CU_ORD_DL
   REPLACE ORD_CODMAC WITH SPACE(03) ALL

	SELECT CU_ORD_DL
	SET ORDER TO I_PROGRA
	GO TOP

	DO WHILE .T.
	
	   IF EOF()
	      EXIT
	   ENDIF

	   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL NUMERO DI BOBINE DA TAGLIARE = 0
	   IF ORD_NRBTGD > 0
	   ELSE
	      SKIP +1
	      LOOP
	   ENDIF

	   *=> BY-PASSO QUELLE RIGHE CHE HO GIA' ELABORATO
	   IF ORD_CODMAC = 'TGS'
	      SKIP +1
	      LOOP
	   ENDIF

       *=> Verifica della conferma dell'ordine
       x_agga = "taggancio = '" + DAGGANCIO + "'"
       x_cond = x_agga
       Csql   = "select * from u_ord_tt where " + x_cond
       IF !ExecCommand(cSql,"cur_testata")
          return(.f.)
       ENDIF
       SELECT cur_testata
       GO TOP
       IF EOF()
          SELECT CU_ORD_DL
          SKIP +1
          LOOP
       ENDIF
       IF ORD_FLGCON
       ELSE
          SELECT CU_ORD_DL
          SKIP +1
          LOOP
       ENDIF

       SELECT CU_ORD_DL

	   WAIT WINDOWS "PROGRAMMAZIONE DEL TAGLIO : % alt.tol. = " + ALLTRIM(STR(V__SCARTO,6,2)) + CHR(13) + ;
	                "Stň elaborando art. " + ORD_CODART + " mm. " + ALLTRIM(STR(ORD_ALTEZZ,5,0)) + " x " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + " mtl." + CHR(13) + ;
	                "Nr.bob. : " + ALLTRIM(STR(ORD_NRBTGD,7,0)) + " Nr.Ord.: " + ORS_NUMORD + " del " + ORS_DATORD + " Cliente : " + ALLTRIM(ORS_RAGSOC) NOWAIT

	   SCATTER MEMVAR MEMO

	   V_DIBA = M.ORD_CDDIBA
	
	   *=> ACQUISISCO I PARAMETRI STANDARD PER LE CAPACITA PRODUTTIVE DELLE MACCHINE IN TAGLIO

	   V_ALMAFN = V_ALTMAT		&& ALTEZZA MASSIMA FILM SPALMATO IN INPUT
	   V_ALMIFN = V_ALTMIT		&& ALTEZZA MINIMA FILM SPALMATO IN INPUT
	   V_SCAABU = V__SCARTO		&& PERCENTUALE DI SCARTO TOLLERATO SU ALTEZZA BOBINA IN INPUT
	   V_LUMIFN = V_LUNMIT		&& LUNGHEZZA MINIMA FILM SPALMATO IN INPUT
	   V_LUMAIN = V_LUNMAR		&& LUNGHEZZA MASSIMA FILM SPALMATO IN INPUT
	
	   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL LEGAME CON LA MACCHINA DI PRODUZIONE SENZA ALTEZZA MAX FILM SPALMATO IN INPUT
	   IF V_ALMAFN = 0
	      SELECT CU_ORD_DL
	      REPLACE ORD_CODMAC WITH 'TGS'
	      SKIP +1
	      LOOP
	   ENDIF

	   *=> Calcolo della lunghezza tollerata +/- per il calcolo delle bobine da tagliare.
	   V_LENGTOL = ROUND(((M.ORD_LUNGHE * V_LUNGTOL) / 100),0)
	   V_LUNGMIN = M.ORD_LUNGHE - V_LENGTOL
	   V_LUNGMAX = M.ORD_LUNGHE + V_LENGTOL

	   *=> Ricerca giacenze riepilogate in ordine di altezza e lunghezza DISCENDENTE

	   IF M.ORD_SPESSO = 0
	      V_SEEK = M.ORD_CODCOL
	   ELSE
	      V_SEEK = M.ORD_CODART + M.ORD_CODMAT + M.ORD_CODCOL + STR(M.ORD_SPESSO,5,0)
	   ENDIF
	
	   SET NEAR ON

	   SELECT T_MAG_GG
	   IF M.ORD_SPESSO = 0
	      SET ORDER TO I_TMAGG5
	   ELSE
	      SET ORDER TO I_TMAGG1
	   ENDIF
	   SEEK V_SEEK
	
	   V_TROV = .F.
	   V_SCAR = .F.
	
	   DO WHILE .T.
	
	      IF EOF()
	         EXIT
	      ENDIF

	      IF DELETED()
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Se rottura chiave di ricerca, fermo l'elaborazione
	      IF M.ORD_SPESSO = 0
	         IF MAG_CODCOL = M.ORD_CODCOL
	         ELSE
	            EXIT
	         ENDIF
	      ELSE
	         IF MAG_ANAART = M.ORD_CODART .AND. MAG_CODMAT = M.ORD_CODMAT .AND. MAG_CODCOL = M.ORD_CODCOL .AND. MAG_SPESSO = M.ORD_SPESSO
	         ELSE
	            EXIT
	         ENDIF
	      ENDIF

          *=> By-passo le giacenze con aggiunte solo se il cliente NON le accetta (vedi ITALPANNELLI)

          * IF ALLTRIM(SUBSTR(M.ORS_RAGSOC,1,7)) = 'ITALPAN'
          IF !ACCETTA_AGGIUNTE(M.ORS_CODCLI)
             IF MAG_FLGAGG
                SKIP +1
                LOOP
             ENDIF
          ENDIF

	      *=> Gestione dell'ordinato imballo
	      IF M.ORD_SPESSO = 0
	         IF MAG_FLGIMB
	         ELSE
	            SKIP +1
	            LOOP
	         ENDIF
	      ELSE
	         IF MAG_FLGIMB
	            SKIP +1
	            LOOP
	         ENDIF
	      ENDIF

	      *=> By-passo le altezze inferiori dell'ordine
	      IF MAG_ALTEZZ < M.ORD_ALTEZZ
	         EXIT
	      ENDIF

	      *=> By-passo le bobine gia' esaminate ma non idonee per il troppo sfrido calcolato
	      IF MAG_BYPASS
	         V_SCAR = .T.
	         SKIP +1
	         LOOP
	      ENDIF
	
	      *=> By-passo le giacenze a 0
	      IF MAG_GIACEN > 0
	      ELSE
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le lunghezze inferiori dell'ordine
	      IF MAG_QTAML < V_LUNGMIN
	         SKIP +1
	         LOOP
	      ENDIF
	
	      *=> By-passo le lunghezze superiori alla tolleranza calcolata
	      IF MAG_QTAML > V_LUNGMAX
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le altezze superiori a quelle previste in input per il taglio
	      IF MAG_ALTEZZ > V_ALMAFN
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le altezze inferiori a quelle previste in input per il taglio
	      IF MAG_ALTRES < V_ALMIFN
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le lunghezze inferiori a quelle previste in input per il taglio
	      IF MAG_QTAML < V_LUMIFN
	         SKIP +1
	         LOOP
	      ENDIF

	      V_TROV = .T.

	      SCATTER MEMVAR MEMO

	      EXIT
	
	   ENDDO

	   SET NEAR OFF
	
	   V_BYPASS = .F.
	
	   *=> Test se č stata trovata giacenza compatibile con quanto ordinato
	   IF V_TROV
	      V_SCAR = .F.
	   ELSE
	      *=> Se non č stata trovata la giacenza ma sono state by-passate delle bobine per troppo scarto,
	      *=> la programmazione sulla bobina con minor scarto (altezza piů bassa) č possibile farla in base ad
	      *=> un parametro gestito dall'utente (se NO non programma)
	      IF __TOLL = 'NO'
	         IF V_SCAR
	            SELECT T_MAG_GG
	            REPLACE MAG_BYPASS WITH .F. ALL
	         ENDIF
	         SELECT CU_ORD_DL
	         REPLACE ORD_CODMAC WITH 'TGS'
	         SKIP +1
	         LOOP
	      ENDIF
	      IF V_SCAR
	         SELECT T_MAG_GG
	         IF MAG_BYPASS
	            V_BYPASS = .T.
	            V_TROV   = .T.
	            REPLACE MAG_BYPASS WITH .F.
	            SCATTER MEMVAR MEMO
	         ELSE
	            SKIP -1
	            DO WHILE .T.
	               IF BOF()
	                  EXIT
	               ENDIF
	               IF MAG_BYPASS
	                  *=> PROJECT 19/01/2005 - INIZIO
	                  IF MAG_ALTEZZ = MAG_ALTRES
	                     Q_ALTEZZA = MAG_ALTEZZ - V_CIMOSA
	                     Q_ALTEZZA = Q_ALTEZZA - (V_TAGLIO * 2)
	                  ELSE
	                     Q_ALTEZZA = MAG_ALTRES
	                  ENDIF
	                  IF Q_ALTEZZA < M.ORD_ALTEZZ
	                     SKIP -1
	                     LOOP
	                  ENDIF
	                  *=> PROJECT 19/01/2005 - FINE
	                  V_BYPASS = .T.
	                  V_TROV   = .T.
	                  REPLACE MAG_BYPASS WITH .F.
	                  SCATTER MEMVAR MEMO
	                  EXIT
	               ENDIF
	               SKIP -1
	            ENDDO
	         ENDIF
	      ENDIF
	      IF V_TROV
	      ELSE
	         IF V_SCAR
	            SELECT T_MAG_GG
	            REPLACE MAG_BYPASS WITH .F. ALL
	         ENDIF
	         SELECT CU_ORD_DL
	         REPLACE ORD_CODMAC WITH 'TGS'
	         SKIP +1
	         LOOP
	      ENDIF
	   ENDIF

	   *=> Imposto l'altezza e la lunghezza iniziale della bobina in giacenza
	   IF M.MAG_ALTEZZ = M.MAG_ALTRES
	      V_ALTEZZA = M.MAG_ALTEZZ
	      V_ALTEZZA = V_ALTEZZA - (V_TAGLIO * 2)
	   ELSE
	      V_ALTEZZA = M.MAG_ALTRES
	   ENDIF
	   V_LUNGHEZ = M.MAG_QTAML
	   V_ACCBOBI = 0

	   *=> Inizio loop di accoppiamento righe d'ordine con stessa lunghezza
	   SELECT CU_ORD_DL
	   V_LUNGORD = ORD_LUNGHE
	   V_CODMATE = ORD_CODMAT
	   V_CODCOLO = ORD_CODCOL
	   V_CODSPES = ORD_SPESSO
	   V_CODARTI = ORD_CODART
	   V_CODDIBA = ORD_CDDIBA
	   V_CILRETI = ORD_CILRET

	   IF V_ALTEZZA < ORD_ALTEZZ			&& PROJECT 19/01/2005
	      SELECT T_MAG_GG
	      REPLACE MAG_BYPASS WITH .T.
	      SELECT CUR_SELEZIONE
	      ZAP
	      SELECT CU_ORD_DL
	      SET ORDER TO I_PROGRA
	      GO TOP
	      LOOP
	   ENDIF
	
	   DO WHILE .T.
	
	      IF EOF()
	         EXIT
	      ENDIF

	      IF ORD_NRBTGD > 0
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

          *=> By-passo le righe d'ordine dei clienti che NON accettano le aggiunte se č stata selezionata una bobina con aggiunta (vedi ITALPANNELLI)

          * IF ALLTRIM(SUBSTR(ORS_RAGSOC,1,7)) = 'ITALPAN'
          IF !ACCETTA_AGGIUNTE(ORS_CODCLI)
             IF M.MAG_FLGAGG
   	            SELECT CU_ORD_DL
                SKIP +1
                LOOP
             ENDIF
          ENDIF
	
	      *=> Determino la percentuale di tolleranza sul reso in altezza
	      V_PERCNOUSATA = (V_ALTEZZA * 100) / M.MAG_ALTEZZ
	      IF V_PERCNOUSATA > V_SCAABU
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso tipo prodotto
	      IF ORD_CODMAT = V_CODMATE
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia della stessa di.ba.
	      IF ORD_CDDIBA = V_CODDIBA
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia con lo stesso cilindro retinato
	      IF ORD_CILRET = V_CILRETI
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso prodotto
	      IF ORD_CODART = V_CODARTI
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso colore
	      IF ORD_CODCOL = V_CODCOLO
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso spessore
	      IF ORD_SPESSO = V_CODSPES
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia della stessa lunghezza
	      IF ORD_LUNGHE = V_LUNGORD
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Determino quanti accoppiamenti riesco a fare con l'altezza della bobina in giacenza
	      V_ACCOPPIA = INT((V_ALTEZZA / ORD_ALTEZZ))
	      IF V_ACCOPPIA > ORD_NRBTGD
	         V_ACCOPPIA = ORD_NRBTGD
	      ENDIF
	
	      IF PUB_CLIDIR
	         V_ACCOPPIA = 1		&& PROJECT 18/01/2005
	      ENDIF
	
	      *=> Determino l'altezza usata per l'accoppiamento

	      V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
	      IF V_ACCOPPIA = 1
	         V_ALTUSATA = V_ALTUSATA
	      ELSE
	         V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
	      ENDIF
	
	      IF V_ALTUSATA > V_ALTEZZA
	         V_ACCOPPIA = V_ACCOPPIA - 1
	         V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
	         V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
	      ENDIF
	
	      *=> by-passo le righe che non riescono ad essere evasi con l'altezza della bobina in giacenza
	      IF V_ALTUSATA = 0
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      SELECT CU_ORD_DL
	      SCATTER MEMVAR MEMO

	      *=> Scrivo in un cursore di appoggio le righe d'ordine che riesco a programmare
	      SELECT CUR_SELEZIONE
	      APPEND BLANK
	      REPLACE SEL_UNIQUE WITH M.ID_UNIQUE
	      REPLACE SEL_CODART WITH M.ORD_CODART
	      REPLACE SEL_DESART WITH M.ORD_DESART
	      REPLACE SEL_CODCLI WITH M.ORS_CODCLI
	      REPLACE SEL_RAGSOC WITH M.ORS_RAGSOC
	      REPLACE SEL_NUMORD WITH M.ORS_NUMORD
	      REPLACE SEL_DATORD WITH M.ORS_DATORD
	      REPLACE SEL_CODCOL WITH M.ORD_CODCOL
	      REPLACE SEL_DESCOL WITH M.ORD_DESCOL
	      REPLACE SEL_CODMAT WITH M.ORD_CODMAT
	      REPLACE SEL_DESMAT WITH M.ORD_DESMAT
	      REPLACE SEL_SPESSO WITH M.ORD_SPESSO
	      REPLACE SEL_ALTEZZ WITH M.ORD_ALTEZZ
	      REPLACE SEL_LUNGHE WITH M.ORD_LUNGHE
	      REPLACE SEL_BOBORD WITH M.ORD_NRBTGD
	      REPLACE SEL_QTAORD WITH M.ORD_QTATGD
	      REPLACE SEL_SPEMAG WITH M.MAG_SPESSO
	      REPLACE SEL_ALTMAG WITH M.MAG_ALTEZZ
	      REPLACE SEL_LUNMAG WITH M.MAG_LUNGHE
	      REPLACE SEL_ACCOPP WITH V_ACCOPPIA
	      REPLACE SEL_BOBACC WITH INT((SEL_BOBORD / SEL_ACCOPP))
	      REPLACE SEL_BOBPRG WITH 0
	      REPLACE SEL_QTAPRG WITH 0
	      REPLACE SEL_LUNPRG WITH 0
	      REPLACE SEL_CDDIBA WITH V_DIBA
	      REPLACE SEL_SCARTO WITH V_SCAR
	      REPLACE SEL_CODSYS WITH M.ORD_CODSYS
	      REPLACE SEL_CILRET WITH M.ORD_CILRET
	
	      *=> Rilevo il numero di bobine piů basso (l'accoppiamento deve avvenire per stessa altezza e stesso
	      *=> numero di bobine da programmare

	      IF V_ACCBOBI = 0
	         V_ACCBOBI = SEL_BOBACC
	      ENDIF

	      IF SEL_BOBACC < V_ACCBOBI
	         V_ACCBOBI = SEL_BOBACC
	      ENDIF
	
	      *=> Determino la nuova altezza con cui si devono confrontare gli altri ordini diminuendola di quella usata

	      V_ALTEZZA = V_ALTEZZA - V_ALTUSATA
	
	      SELECT CU_ORD_DL
	      SKIP +1
	
	   ENDDO

	   SELECT CUR_SELEZIONE
	   GO TOP
	   IF EOF()
	   ELSE
	      IF V_BYPASS
	      ELSE
	         *=> Determino la percentuale di tolleranza sul reso in altezza
	         V_PERCNOUSATA = (V_ALTEZZA * 100) / M.MAG_ALTEZZ
	         IF V_PERCNOUSATA > V_SCAABU
	            SELECT T_MAG_GG
	            REPLACE MAG_BYPASS WITH .T.
	            SELECT CUR_SELEZIONE
	            ZAP
	            SELECT CU_ORD_DL
	            SET ORDER TO I_PROGRA
	            GO TOP
	            LOOP
	         ENDIF
	      ENDIF
	   ENDIF

	   *=> Riprendo in esame il cursore provvisorio con le righe d'ordine che sono riuscito ad accoppiare
	   *=> per determinerne le esatte quantitŕ

	   V_PROGRE = V_PROGRE + 1
	
	   SELECT CUR_SELEZIONE
	   GO TOP
	
	   *=> calcolo il numero massimo di bobine che riuscirei a spalmare con la lunghezza della bobina in giacenza
	   IF EOF()
	   ELSE
	      *V_MAX_BOB_SPALM = INT((V_LUNGHEZ / V_LUNGORD))
	      V_MAX_BOB_SPALM = ROUND((V_LUNGHEZ / V_LUNGORD),0)
	      IF V_ACCBOBI > V_MAX_BOB_SPALM
	         V_ACCBOBI = V_MAX_BOB_SPALM
	      ENDIF
	   ENDIF
	
	   DO WHILE .T.

	      IF EOF()
	         EXIT
	      ENDIF

	      *=> Determino il numero di bobine e la quantitŕ in MQ da programmare per la singola riga d'ordine
	      REPLACE SEL_LUNPRG WITH V_LUNGHEZ
	      REPLACE SEL_BOBPRG WITH V_ACCBOBI * SEL_ACCOPP
	      REPLACE SEL_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTEZZ,SEL_LUNPRG,SEL_BOBPRG)
	
	      SELECT CUR_SELEZIONE
	      SCATTER MEMVAR MEMO

	      *=> Accedo alle righe d'ordine selezionate dall'utente per aggiornarne le quantitŕ programmate
	      SELECT CU_ORD_DL
	      SET ORDER TO I_CODSYS
	      SEEK M.SEL_CODSYS
	      IF FOUND()
	         REPLACE ORD_NRBTGD WITH ORD_NRBTGD - M.SEL_BOBPRG
	         REPLACE ORD_QTATGD WITH ORD_QTATGD - M.SEL_QTAPRG
	         REPLACE ORD_NRBOBR WITH ORD_NRBOBR + M.SEL_BOBPRG
	         REPLACE ORD_QUANTR WITH ORD_QUANTR + M.SEL_QTAPRG
	         REPLACE ORD_NRBOBO WITH 0
	         REPLACE ORD_QUANTO WITH 0
	         REPLACE ORD_NRBTGP WITH ORD_NRBTGP + M.SEL_BOBPRG
	         REPLACE ORD_QTATGP WITH ORD_QTATGP + M.SEL_QTAPRG
	      ENDIF

	      *=> Accedo alle giacenze per aggiornarne le quantitŕ programmate
	      SELECT T_MAG_GG
	      REPLACE MAG_GIACEN WITH MAG_GIACEN - M.SEL_QTAPRG
	      REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  - M.SEL_QTAPRG
	      REPLACE MAG_QTAKG  WITH MAG_QTAKG  - TROVA_KG_DA_MQ(M.SEL_CODART,M.SEL_SPESSO,M.SEL_QTAPRG,1)

	      *=> Aggiorno la nuova altezza della bobina residua
	      SELECT T_MAG_GG
	      REPLACE MAG_ALTRES WITH V_ALTEZZA
	      REPLACE MAG_COMODO WITH 1
	      X_NUMLOT = MAG_NRLINT

	      *=> Scrivo su un nuovo cursore le righe d'ordine che sono riuscito ad accoppiare con le quantitŕ programmate
	      SELECT CUR_TAGLIO
	      APPEND BLANK
	      GATHER MEMVAR MEMO
	      REPLACE SEL_PROGRE WITH V_PROGRE
	      REPLACE SEL_CODMAC WITH 'TGS'
	      REPLACE SEL_DESMAC WITH 'TGS'
	      REPLACE SEL_SCARTO WITH V_SCAR
	      REPLACE SEL_ALTCOM WITH 99999 - SEL_ALTMAG		&& ALTEZZA COMPLEMENTATA A 99999 PER SORT ALTEZZA DISCENDENTE
	      REPLACE SEL_FLGELA WITH .F.
	      REPLACE SEL_NUMLOT WITH X_NUMLOT
	      REPLACE SEL_PROSUC WITH 1
	
	      SELECT CUR_SELEZIONE
	      SKIP +1

	   ENDDO

	   *=> Accedo alle giacenze per aggiornarne i metri lineari utilizzati e la lunghezza della bobina
	   SELECT T_MAG_GG
	   REPLACE MAG_QTAML  WITH 0
	   REPLACE MAG_ALTRES WITH MAG_ALTEZZ
	   REPLACE MAG_BYPASS WITH .F. ALL
	
	   SELECT CUR_SELEZIONE
	   ZAP
	
	   SELECT CU_ORD_DL
	   SET ORDER TO I_PROGRA
	   GO TOP
	
	ENDDO

    V__SCARTO = V__SCARTO + 1

ENDDO

RELEASE RIB1_PROGRE,RIB1_CODART,RIB1_DESART,RIB1_CODCOL,RIB1_DESCOL,RIB1_CODMAT,RIB1_DESMAT,RIB1_SPEMAG, ;
        RIB1_ALTMAG,RIB_LUNMAG,RIB1_LUNPRG,RIB1_PROSUC,RIB1_NRLINT
PUBLIC  RIB1_PROGRE,RIB1_CODART,RIB1_DESART,RIB1_CODCOL,RIB1_DESCOL,RIB1_CODMAT,RIB1_DESMAT,RIB1_SPEMAG, ;
        RIB1_ALTMAG,RIB_LUNMAG,RIB1_LUNPRG,RIB1_PROSUC,RIB1_NRLINT
RIB1_PROGRE = 0
RIB1_CODART = SPACE(16)
RIB1_DESART = SPACE(50)
RIB1_CODCOL = SPACE(03)
RIB1_DESCOL = SPACE(50)
RIB1_CODMAT = SPACE(03)
RIB1_DESMAT = SPACE(50)
RIB1_SPEMAG = 0
RIB1_ALTMAG = 0
RIB1_LUNMAG = 0
RIB1_LUNPRG = 0
RIB1_PROSUC = 0
RIB1_NRLINT = 0

RELEASE V_MISTAG,V_TROVATO,V_LUNRESTANTE,V_RECNO,V_ULTIMO,V_PROSUC
PUBLIC  V_MISTAG,V_TROVATO,V_LUNRESTANTE,V_RECNO,V_ULTIMO,V_PROSUC
V_MISTAG      = ""
V_TROVATO     = .F.
V_LUNRESTANTE = 0
V_RECNO       = 0
V_ULTIMO      = .F.
V_PROSUC      = 1
V_PRG         = 0


SELECT CUR_TAGLIO
INDEX ON SEL_PROGRE	TAG I_ORDRIN
SET FILTER TO
GO top
REPLACE SEL_FLGELA WITH .F. ALL

=DEFPUB(SELECT())
SCATTER MEMVAR MEMO BLANK
HH=AFIELDS(TRANSITO)
CREATE CURSOR RIN_TAGLIO FROM ARRAY TRANSITO

RELEASE V_NUMTAG
PUBLIC  V_NUMTAG
V_NUMTAG = 0

*=> Determinazione del numero di tagli da fare su ogni singola bobina
SELECT CUR_TAGLIO
SET FILTER TO
GO TOP
IF EOF()
ELSE
   RIB1_PROGRE = SEL_PROGRE
ENDIF

DO WHILE .T.

   IF EOF()
      IF V_ULTIMO
         REPLACE SEL_NUMTAG WITH V_NUMTAG FOR SEL_PROGRE = RIB1_PROGRE ALL
      ENDIF
      EXIT
   ENDIF

   IF SEL_PROGRE = RIB1_PROGRE
   ELSE
      V_RECNO = RECNO()
      REPLACE SEL_NUMTAG WITH V_NUMTAG FOR SEL_PROGRE = RIB1_PROGRE ALL
      GOTO V_RECNO
      RIB1_PROGRE = SEL_PROGRE
      V_NUMTAG    = 0
      LOOP
   ENDIF

   V_ULTIMO = .T.
   V_NUMTAG = V_NUMTAG + SEL_BOBPRG

   SELECT CUR_TAGLIO
   SKIP +1

ENDDO

SELECT CUR_TAGLIO
SET FILTER TO
GO top

RETURN


***************************************************************************
PROCEDURE ribobinatura_generagiacenze						
***************************************************************************

WAIT WINDOWS "PROGRAMMAZIONE DELLA RIBOBINATURA : " + CHR(13) + ;
             "Stň riepilogando le giacenze di film spalmato necessario alla programmazione" NOWAIT

RELEASE __DUEMAG
PUBLIC  __DUEMAG

x_codi = "codice = 'PDP01'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __DUEMAG = 'NO'
ELSE
   __DUEMAG = SUBSTR(LIBERA,1,2)
ENDIF

x_codi = "codice = 'PDP03'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __STEPRI = 'NO'
ELSE
   __STEPRI = SUBSTR(LIBERA,1,2)
ENDIF

x_codi = "codice = 'GCF01'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __CALFAB = 'NO'
ELSE
   __CALFAB = SUBSTR(LIBERA,1,2)
ENDIF

IF __STEPRI = 'SI'
   SET STEP ON
ENDIF

*=> Riepilogo delle giacenze di film spalmato presente a magazzino
x_data = "mag_datagg <> SPACE(10)"
x_giac = "mag_giacen > 0"
IF __DUEMAG = 'SI'
   x_maga = "mag_codmag = mag_codmag"
ELSE
   x_maga = "mag_codmag = '" + ALLTRIM(PUB_RIBSLR) + "'"
ENDIF
x_impe = "mag_qtaimp < mag_giacen"
x_ribo = "mag_flgrib = mag_flgrib"
x_cond = x_data + " and " + x_giac + " and " + x_maga + " and " + x_impe + " and " + x_ribo
Csql   = "select * from u_mag_gg where " + x_cond + " order by mag_codmat,mag_codcol,mag_spesso,mag_altezz desc,mag_nrlint,MAG_QTAML desc"
IF !ExecCommand(Csql,"R_MAG_GG")
   return(.f.)
ENDIF
SELECT R_MAG_GG
REPLACE SELEZIONE WITH "=>" ALL
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF MAG_FLGRIB
      V_IDUNIQUE = ID_UNIQUE
      V_QTAMLRIB = MAG_QTAML
      SELECT T_MAG_GG
      SET ORDER TO I_TMAGG3
      SEEK V_IDUNIQUE
      IF FOUND()
         IF V_QTAMLRIB = MAG_QTAML
         ELSE
            SELECT R_MAG_GG
            DELETE
         ENDIF
      ENDIF
   ENDIF
   SELECT R_MAG_GG
   SKIP +1
ENDDO

SELECT R_MAG_GG
INDEX ON ID_UNIQUE TAG I_RMAGG0 ADDITIVE

* -->> Inizio elaborazione per aggiungere le giacenze di film nudo a fronte di ordini clienti di sola ribobinatura
* -->> e/o taglio

SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   IF ORD_UM = 'KG' .OR. EMPTY(ALLTRIM(ORD_CDDIBA))
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Riepilogo delle giacenze di film spalmato presente a magazzino
   x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
   x_tmat = "mag_codmat = '" + M.ORD_CODMAT + "'"
   x_colo = "mag_codcol = '" + M.ORD_CODCOL + "'"
   x_spes = "mag_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
   x_alte = "mag_altezz >= " + ALLTRIM(STR(M.ORD_ALTEZZ,5,0))
   x_lung = "mag_lunghe >= " + ALLTRIM(STR(M.ORD_LUNGHE,6,0))
   x_arti = "mag_codart = mag_codart"
   x_nrli = "mag_nrlint = mag_nrlint"
   x_maga = "mag_codmag = '" + ALLTRIM(PUB_CQUMPC) + "'"
   x_forn = "mag_fornit = mag_fornit"
   x_nide = "mag_numide = mag_numide"
   x_anno = "mag_anno = mag_anno"
   x_data = "mag_datagg <> SPACE(10)"
   x_giac = "mag_giacen > 0"
   x_impe = "mag_qtaimp < mag_giacen"
   x_cond = x_soci + " and " + x_tmat + " and " + x_colo + " and " + x_spes + " and " + x_alte
   x_cond = x_cond + " and " + x_lung + " and " + x_arti + " and " + x_nrli + " and " + x_maga
   x_cond = x_cond + " and " + x_forn + " and " + x_nide + " and " + x_anno + " and " + x_data
   x_cond = x_cond + " and " + x_giac + " and " + x_impe
   cSql   = "select * from u_mag_gg where " + x_cond + " order by mag_datagg,mag_codart"
   IF !ExecCommand(cSql,'CUR_MAGAZZINO')
      return(.f.)
   ENDIF
   SELECT CUR_MAGAZZINO
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      SCATTER MEMVAR MEMO
      XS_UNIQUE = ID_UNIQUE
      SELECT R_MAG_GG
      SET ORDER TO I_RMAGG0
      SEEK XS_UNIQUE
      IF FOUND()
      ELSE
         APPEND BLANK
         GATHER MEMVAR MEMO
         REPLACE SELEZIONE WITH "=>"
      ENDIF
      SELECT CUR_MAGAZZINO
      SKIP +1
   ENDDO

   SELECT CU_ORD_DL
   SKIP +1

ENDDO

* -->> Inizio elaborazione per creazione cursori di giacenza

SELECT R_MAG_GG
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF __DUEMAG = 'SI'
      IF mag_codmag = PUB_RIBSLR .OR. mag_codmag = PUB_RIBPRO .OR. mag_codmag = PUB_SPAPRO
      ELSE
         DELETE
         SKIP +1
         LOOP
      ENDIF
   ENDIF
   REPLACE MAG_NLPROV WITH 99999 - MAG_ALTEZZ	&& ALTEZZA COMPLEMENTATA
   REPLACE MAG_BYPASS WITH .F.
   REPLACE MAG_FLGMOD WITH .F.
   REPLACE MAG_ALTRES WITH MAG_ALTEZZ
   REPLACE MAG_GIACEN WITH MAG_GIACEN - MAG_QTAIMP
   REPLACE MAG_QTAKG  WITH MAG_QTAKG  - MAG_GKGIMP
   REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  - MAG_QTAIMP
   REPLACE MAG_QTAML  WITH MAG_QTAML  - MAG_GMLIMP
   REPLACE MAG_COMODO WITH MAG_GIACEN
   REPLACE MAG_QTAIMP WITH 0
   REPLACE MAG_GKGIMP WITH 0
   REPLACE MAG_GMLIMP WITH 0
   IF MAG_GIACEN > 0
      IF MAG_QTAKG > 0
         IF MAG_QTAMQ > 0
            IF MAG_QTAML > 0
            ELSE
               DELETE
            ENDIF
         ELSE
            DELETE
         ENDIF
      ELSE
         DELETE
      ENDIF
   ELSE
      DELETE
   ENDIF
   SKIP +1
ENDDO

SELECT R_MAG_GG
GO TOP
REPLACE SELEZIONE WITH SPACE(10) FOR MAG_NRLINT > 49999999
GO TOP
IF EOF()
ELSE
   *=> Se calcolo fabbisogni non devo visualizzare le giacenze per successiva selezione
   IF _V_FABBIS
      *=> Se il calcolo dei fabbisogni NON deve tenere conto delle giacenze esistenti al netto dell'impegnato, cancello
      *=> il cursore delle giacenze, in modo da generare un fabbisogno totale
      IF __CALFAB = 'NO'
      ELSE
         ZAP
      ENDIF
   ELSE
      IF PUB_VISGIAC
         RIT = MESSAGEBOX("Vuoi consultare le Bobine spalmate in giacenza ?",292,"ATTENZIONE")
         IF RIT = 7
         ELSE
            _V_OPZORD1 = 1
            _V_OPZORD3 = 1
            _V_OPZORD4 = 1
            DO FORM FORM\VEDIGIACR LINKED
         ENDIF
      ENDIF
   ENDIF
ENDIF

SELECT R_MAG_GG
INDEX ON MAG_ANAART + MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_NLPROV,8,0) + ;
         STR(MAG_NRLINT,8,0)																		TAG I_RMAGG1 ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + STR(MAG_NRLINT,8,0)  TAG I_RMAGG2 ADDITIVE
INDEX ON MAG_CODART + MAG_CODMAG									 								TAG I_RMAGG4 ADDITIVE

RETURN


***************************************************************************
PROCEDURE ribobinatura_programmazione						
***************************************************************************


RELEASE V_DIBA,V_TROV,V_ALTEZZA,V_LUNGHEZ,V_ACCBOBI,V_PERCNOUSATA,V_ACCOPPIA,V_ALTUSATA, ;
        V_MAX_BOB_SPALM,V_LUNGORD,V_PROGRE,V_SCAR,V_SCAABU,V_ALMAFN,V_ALMIFN,V_LUMIFN,V_LUMAIN
PUBLIC  V_DIBA,V_TROV,V_ALTEZZA,V_LUNGHEZ,V_ACCBOBI,V_PERCNOUSATA,V_ACCOPPIA,V_ALTUSATA, ;
        V_MAX_BOB_SPALM,V_LUNGORD,V_PROGRE,V_SCAR,V_SCAABU,V_ALMAFN,V_ALMIFN,V_LUMIFN,V_LUMAIN
V_DIBA          = SPACE(16)
V_TROV          = .F.
V_ALTEZZA       = 0
V_LUNGHEZ       = 0
V_ACCBOBI       = 0
V_PERCNOUSATA   = 0
V_ACCOPPIA      = 0
V_ALTUSATA      = 0
V_MAX_BOB_SPALM = 0
V_LUNGORD       = 0
V_PROGRE        = 0
V_SCAR          = .F.
V_SCAABU        = 0
V_ALMAFN        = 0
V_ALMIFN        = 0
V_LUMIFN        = 0
V_LUMAIN        = 0

CREATE CURSOR CUR_SELEZIONE (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50), SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                             SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03), SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                             SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05), SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                             SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05), SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                             SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16), SEL_SCARTO L(1),  ;
                             SEL_CODSYS C(10),   SEL_CILRET N(03), SEL_LUNPRG N(16))

CREATE CURSOR CUR_RIBOBINATURA (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50),   SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                                SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03),   SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                                SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05),   SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                                SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05),   SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                                SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16),   SEL_PROGRE N(06), ;
                                SEL_CODMAC C(03),   SEL_DESMAC C(50), SEL_SCARTO L(01),   SEL_ALTCOM N(05),   SEL_CODSYS C(10), ;
                                SEL_FLGELI C(02),   SEL_CILRET N(03), SEL_MISTAG M(04),   SEL_CLIELA M(04),   SEL_LUNPRG N(16), ;
                                SEL_FLGELA L(01),   SEL_PROSUC N(06), SEL_NUMLOT N(08),   RIN_LUNPRG N(16),   RIN_BOBPRG N(06), ;
                                RIN_QTAPRG N(12,2), SEL_TAGMIS M(04))

CREATE CURSOR RIE_RIBOBINATURA (SEL_UNIQUE C(36),   SEL_CODART C(16), SEL_DESART C(50),   SEL_CODCLI C(10),   SEL_RAGSOC C(50), ;
                                SEL_NUMORD C(06),   SEL_DATORD C(10), SEL_CODCOL C(03),   SEL_DESCOL C(30),   SEL_CODMAT C(03), ;
                                SEL_DESMAT C(30),   SEL_SPESSO N(05), SEL_ALTEZZ N(05),   SEL_LUNGHE N(06),   SEL_BOBORD N(06), ;
                                SEL_QTAORD N(12,2), SEL_SPEMAG N(03), SEL_ALTMAG N(05),   SEL_LUNMAG N(16),   SEL_ACCOPP N(06), ;
                                SEL_BOBACC N(06),   SEL_BOBPRG N(06), SEL_QTAPRG N(12,2), SEL_CDDIBA C(16),   SEL_PROGRE N(06), ;
                                SEL_CODMAC C(03),   SEL_DESMAC C(50), SEL_SCARTO L(01),   SEL_ALTCOM N(05),   SEL_CODSYS C(10), ;
                                SEL_FLGELI C(02),   SEL_CILRET N(03), SEL_MISTAG M(04),   SEL_CLIELA M(04),   SEL_LUNPRG N(16), ;
                                SEL_FLGELA L(01),   SEL_PROSUC N(06), SEL_NUMLOT N(08),   RIN_LUNPRG N(16),   RIN_BOBPRG N(06), ;
                                RIN_QTAPRG N(12,2), SEL_TAGMIS M(04))



*=> ************************************************************************ <=*
*=>                                                                          <=*
*=>    P R O G R A M M A Z I O N E   D E L L A   R I B O B I N A T U R A     <=*
*=>                                                                          <=*
*=> ************************************************************************ <=*

RELEASE __STEPRI,__TOLL,__OLDNEW
PUBLIC  __STEPRI,__TOLL,__OLDNEW

x_codi = "codice = 'PDP03'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __STEPRI = 'NO'
ELSE
   __STEPRI = SUBSTR(LIBERA,1,2)
ENDIF

IF __STEPRI = 'SI'
   SET STEP ON
ENDIF

x_codi = "codice = 'GTP01'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __TOLL   = 'SI'
   __OLDNEW = 'NEW'
ELSE
   __TOLL   = SUBSTR(LIBERA,1,2)
   __OLDNEW = SUBSTR(DESIVA,1,3)
ENDIF
IF EMPTY(__OLDNEW)
   __OLDNEW = 'NEW'
ENDIF

*=> Decurtazione delle quantitŕ giŕ programmate per la ribobinatura
RELEASE X_NRBPRG,X_QTAPRG
PUBLIC  X_NRBPRG,X_QTAPRG

SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL NUMERO DI BOBINE DA RIBOBINARE = 0
   IF ORD_NRBRID > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF EMPTY(ALLTRIM(ORD_CODSYS))
      SKIP +1
      LOOP
   ENDIF

   X_NRBPRG = 0
   X_QTAPRG = 0

   XQ_UNIQUE = ORD_CODSYS

   *=> DETERMINO IL NUMERO DELLE BOBINE GIA' PROGRAMMATE
   DO CERCA_PROGRAMMA WITH 'RIB',XQ_UNIQUE

   *=> AGGIORNO IL NUMERO DELLE BOBINE DA PROGRAMMARE
   SELECT CU_ORD_DL
   REPLACE ORD_NRBRID WITH ORD_NRBRID - X_NRBPRG
   REPLACE ORD_QTARID WITH TROVA_MQ_DA_AL(ORD_ALTEZZ,ORD_LUNGHE,ORD_NRBRID)

   SKIP +1

ENDDO

*=> ELABORO TUTTE LE RIGHE D'ORDINE FORNITORE SELEZIONATE PER LA PRODUZIONE IN RIBOBINATURA

RELEASE V__SCARTO
PUBLIC  V__SCARTO
V__SCARTO = V_SCARTO

*=> ELABORO TUTTE LE RIGHE D'ORDINE FORNITORE SELEZIONATE PER LA PRODUZIONE IN TAGLIO

DO WHILE .T.

   IF V__SCARTO > V_SCAMAX
      EXIT
   ENDIF

   SELECT R_MAG_GG
   REPLACE MAG_BYPASS WITH .F. ALL

   SELECT CU_ORD_DL
   REPLACE ORD_CODMAC WITH SPACE(03) ALL

	SELECT CU_ORD_DL
	SET ORDER TO I_PROGRA
	GO TOP

	DO WHILE .T.
	
	   IF EOF()
	      EXIT
	   ENDIF

	   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL NUMERO DI BOBINE DA RIBOBINARE = 0
	   IF ORD_NRBRID > 0
	   ELSE
	      SKIP +1
	      LOOP
	   ENDIF

	   *=> BY-PASSO QUELLE RIGHE CHE HO GIA' ELABORATO
	   IF ORD_CODMAC = 'RIS'
	      SKIP +1
	      LOOP
	   ENDIF

	   WAIT WINDOWS "PROGRAMMAZIONE DELLA RIBOBINATURA : % in alt. tollerata = " + ALLTRIM(STR(V__SCARTO,6,2)) + CHR(13) + ;
	                "Stň elaborando l'articolo " + ORD_CODART + " " + ALLTRIM(ord_codcol) + " mm. " + ALLTRIM(STR(ORD_ALTEZZ,5,0)) + " x mtl. " + ALLTRIM(STR(ORD_LUNGHE,6,0)) + CHR(13) + ;
	                "Nr.bob. : " + ALLTRIM(STR(ORD_NRBRID,7,0)) + " Nr.Ordine : " + ORS_NUMORD + " del " + ORS_DATORD + " Cliente : " + ORS_RAGSOC NOWAIT

	
	   SCATTER MEMVAR MEMO

	   V_DIBA = M.ORD_CDDIBA
	
	   *=> ACQUISISCO I PARAMETRI STANDARD PER LE CAPACITA PRODUTTIVE DELLE MACCHINE IN RIBOBINATURA

	   V_ALMAFN = V_ALTMAR		&& ALTEZZA MASSIMA FILM SPALMATO IN INPUT
	   V_ALMIFN = V_ALTMIR		&& ALTEZZA MINIMA FILM SPALMATO IN INPUT
	   V_SCAABU = V__SCARTO		&& PERCENTUALE DI SCARTO TOLLERATO SU ALTEZZA BOBINA IN INPUT
	   V_LUMIFN = V_LUNMIR		&& LUNGHEZZA MINIMA FILM SPALMATO IN INPUT
	   V_LUMAIN = V_LUNMAR		&& LUNGHEZZA MASSIMA FILM SPALMATO IN INPUT
	
	   *=> BY-PASSO QUELLE RIGHE CHE HANNO IL LEGAME CON LA MACCHINA DI PRODUZIONE SENZA ALTEZZA MAX FILM SPALMATO IN INPUT
	   IF V_ALMAFN = 0
	      SELECT CU_ORD_DL
	      REPLACE ORD_CODMAC WITH 'RIS'
	      SKIP +1
	      LOOP
	   ENDIF

	   *=> Ricerca giacenze riepilogate in ordine di altezza e lunghezza DISCENDENTE

	   V_SEEK = M.ORD_CODART + M.ORD_CODMAT + M.ORD_CODCOL + STR(M.ORD_SPESSO,5,0)

	   SET NEAR ON

	   SELECT R_MAG_GG
	   SET ORDER TO I_RMAGG1
	   SEEK V_SEEK
	
	   V_TROV = .F.
	   V_SCAR = .F.
	
	   DO WHILE .T.
	
	      IF EOF()
	         EXIT
	      ENDIF

	      IF DELETED()
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Se rottura chiave di ricerca, fermo l'elaborazione
	      IF MAG_ANAART = M.ORD_CODART .AND. MAG_CODMAT = M.ORD_CODMAT .AND. MAG_CODCOL = M.ORD_CODCOL .AND. MAG_SPESSO = M.ORD_SPESSO
	      ELSE
	         EXIT
	      ENDIF

	      *=> By-passo le altezze inferiori dell'ordine
	      IF MAG_ALTEZZ < M.ORD_ALTEZZ
	         EXIT
	      ENDIF

	      *=> By-passo le bobine gia' esaminate ma non idonee per il troppo sfrido calcolato
	      IF MAG_BYPASS
	         V_SCAR = .T.
	         SKIP +1
	         LOOP
	      ENDIF
	
	      *=> By-passo le giacenze a 0
	      IF MAG_GIACEN > 0
	      ELSE
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le lunghezze inferiori dell'ordine
	      IF MAG_LUNGHE < M.ORD_LUNGHE
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le altezze superiori a quelle previste in input per il taglio
	      IF MAG_ALTEZZ > V_ALMAFN
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le altezze inferiori a quelle previste in input per il taglio
	      IF MAG_ALTRES < V_ALMIFN
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le lunghezze inferiori a quelle previste in input per il taglio
	      IF MAG_QTAML < V_LUMIFN
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le lunghezze superiori a quelle previste in input per la ribobinatura
	      IF MAG_QTAML > V_LUMAIN
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le lunghezze inferiori a quelle dell'ordine
	      IF MAG_QTAML < M.ORD_LUNGHE
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> By-passo le lunghezze uguali all'ordine gia' ribobinate
	      IF MAG_LUNGHE = M.ORD_LUNGHE
	         IF MAG_FLGRIB
    	        SKIP +1
 	            LOOP
	         ENDIF
	      ENDIF

	      V_TROV = .T.

	      SCATTER MEMVAR MEMO
	      EXIT
	
	   ENDDO

	   SET NEAR OFF
	
	   V_BYPASS = .F.
	
	   *=> Test se č stata trovata giacenza compatibile con quanto ordinato
	   IF V_TROV
	      V_SCAR = .F.
	   ELSE
	      *=> Se non č stata trovata la giacenza ma sono state by-passate delle bobine per troppo scarto,
	      *=> la programmazione sulla bobina con minor scarto (altezza piů bassa) č possibile farla in base ad
	      *=> un parametro gestito dall'utente (se NO non programma)
	      IF __TOLL = 'NO'
	         IF V_SCAR
	            SELECT R_MAG_GG
	            REPLACE MAG_BYPASS WITH .F. ALL
	         ENDIF
	         SELECT CU_ORD_DL
	         REPLACE ORD_CODMAC WITH 'RIS'
	         SKIP +1
	         LOOP
	      ENDIF
	      IF V_SCAR
	         SELECT R_MAG_GG
	         IF MAG_BYPASS
	            V_BYPASS = .T.
	            V_TROV   = .T.
	            REPLACE MAG_BYPASS WITH .F.
	            SCATTER MEMVAR MEMO
	         ELSE
	            SKIP -1
	            DO WHILE .T.
	               IF BOF()
	                  EXIT
	               ENDIF
	               IF MAG_BYPASS
	                  *=> PROJECT 19/01/2005 - INIZIO
	                  IF MAG_ALTEZZ = MAG_ALTRES
	                     Q_ALTEZZA = MAG_ALTEZZ - V_CIMOSA
	                     Q_ALTEZZA = Q_ALTEZZA - (V_TAGLIO * 2)
	                  ELSE
	                     Q_ALTEZZA = MAG_ALTRES
	                  ENDIF
	                  IF Q_ALTEZZA < M.ORD_ALTEZZ
	                     SKIP -1
	                     LOOP
	                  ENDIF
	                  *=> PROJECT 19/01/2005 - FINE
	                  V_BYPASS = .T.
	                  V_TROV   = .T.
	                  REPLACE MAG_BYPASS WITH .F.
	                  SCATTER MEMVAR MEMO
	                  EXIT
	               ENDIF
	               SKIP -1
	            ENDDO
	         ENDIF
	      ENDIF
	      IF V_TROV
	      ELSE
	         IF V_SCAR
	            SELECT R_MAG_GG
	            REPLACE MAG_BYPASS WITH .F. ALL
	         ENDIF
	         SELECT CU_ORD_DL
	         REPLACE ORD_CODMAC WITH 'RIS'
	         SKIP +1
	         LOOP
	      ENDIF
	   ENDIF

	   *=> Imposto l'altezza e la lunghezza iniziale della bobina in giacenza
	   IF M.MAG_ALTEZZ = M.MAG_ALTRES
	      V_ALTEZZA = M.MAG_ALTEZZ
	      V_ALTEZZA = V_ALTEZZA - (V_TAGLIO * 2)
	   ELSE
	      V_ALTEZZA = M.MAG_ALTRES
	   ENDIF
	   V_LUNGHEZ = M.MAG_QTAML
	   V_ACCBOBI = 0

	   *=> Inizio loop di accoppiamento righe d'ordine con stessa lunghezza
	   SELECT CU_ORD_DL
	   V_LUNGORD = ORD_LUNGHE
	   V_CODMATE = ORD_CODMAT
	   V_CODCOLO = ORD_CODCOL
	   V_CODSPES = ORD_SPESSO
	   V_CODARTI = ORD_CODART
	   V_CODDIBA = ORD_CDDIBA
	   V_CILRETI = ORD_CILRET

	   IF V_ALTEZZA < ORD_ALTEZZ			&& PROJECT 19/01/2005
	      SELECT R_MAG_GG
	      REPLACE MAG_BYPASS WITH .T.
	      SELECT CUR_SELEZIONE
	      ZAP
	      SELECT CU_ORD_DL
	      SET ORDER TO I_PROGRA
	      GO TOP
	      LOOP
	   ENDIF
	
	   DO WHILE .T.
	
	      IF EOF()
	         EXIT
	      ENDIF

	      IF ORD_NRBRID > 0
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF
	
	      *=> Determino la percentuale di tolleranza sul reso in altezza
	      V_PERCNOUSATA = (V_ALTEZZA * 100) / M.MAG_ALTEZZ
	      IF V_PERCNOUSATA > V_SCAABU
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso tipo prodotto
	      IF ORD_CODMAT = V_CODMATE
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia della stessa di.ba.
	      IF ORD_CDDIBA = V_CODDIBA
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia con lo stesso cilindro retinato
	      IF ORD_CILRET = V_CILRETI
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso prodotto
	      IF ORD_CODART = V_CODARTI
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso colore
	      IF ORD_CODCOL = V_CODCOLO
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia dello stesso spessore
	      IF ORD_SPESSO = V_CODSPES
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Verifico che la riga d'ordine che stň elaborando sia della stessa lunghezza
	      IF ORD_LUNGHE = V_LUNGORD
	      ELSE
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      *=> Determino quanti accoppiamenti riesco a fare con l'altezza della bobina in giacenza
	      V_ACCOPPIA = INT((V_ALTEZZA / ORD_ALTEZZ))
	      IF V_ACCOPPIA > ORD_NRBRID
	         V_ACCOPPIA = ORD_NRBRID
	      ENDIF

	      *=> Determino l'altezza usata per l'accoppiamento
	      V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
	      IF V_ACCOPPIA = 1
	         V_ALTUSATA = V_ALTUSATA
	      ELSE
	         V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
	      ENDIF
	
	      IF V_ALTUSATA > V_ALTEZZA
	         V_ACCOPPIA = V_ACCOPPIA - 1
	         V_ALTUSATA = ORD_ALTEZZ * V_ACCOPPIA
	         V_ALTUSATA = V_ALTUSATA + (V_ACCOPPIA * V_TAGLIO)
	      ENDIF
	
	      *=> by-passo le righe che non riescono ad essere evasi con l'altezza della bobina in giacenza
	      IF V_ALTUSATA = 0
	         SELECT CU_ORD_DL
	         SKIP +1
	         LOOP
	      ENDIF

	      SELECT CU_ORD_DL
	      SCATTER MEMVAR MEMO

	      *=> Scrivo in un cursore di appoggio le righe d'ordine che riesco a programmare
	      SELECT CUR_SELEZIONE
	      APPEND BLANK
	      REPLACE SEL_UNIQUE WITH M.ID_UNIQUE
	      REPLACE SEL_CODART WITH M.ORD_CODART
	      REPLACE SEL_DESART WITH M.ORD_DESART
	      REPLACE SEL_CODCLI WITH M.ORS_CODCLI
	      REPLACE SEL_RAGSOC WITH M.ORS_RAGSOC
	      REPLACE SEL_NUMORD WITH M.ORS_NUMORD
	      REPLACE SEL_DATORD WITH M.ORS_DATORD
	      REPLACE SEL_CODCOL WITH M.ORD_CODCOL
	      REPLACE SEL_DESCOL WITH M.ORD_DESCOL
	      REPLACE SEL_CODMAT WITH M.ORD_CODMAT
	      REPLACE SEL_DESMAT WITH M.ORD_DESMAT
	      REPLACE SEL_SPESSO WITH M.ORD_SPESSO
	      REPLACE SEL_ALTEZZ WITH M.ORD_ALTEZZ
	      REPLACE SEL_LUNGHE WITH M.ORD_LUNGHE
	      REPLACE SEL_BOBORD WITH M.ORD_NRBRID
	      REPLACE SEL_QTAORD WITH M.ORD_QTARID
	      REPLACE SEL_SPEMAG WITH M.MAG_SPESSO
	      REPLACE SEL_ALTMAG WITH M.MAG_ALTEZZ
	      REPLACE SEL_LUNMAG WITH M.MAG_LUNGHE
	      REPLACE SEL_ACCOPP WITH V_ACCOPPIA
	      REPLACE SEL_BOBACC WITH INT((SEL_BOBORD / SEL_ACCOPP))
	      REPLACE SEL_BOBPRG WITH 0
	      REPLACE SEL_QTAPRG WITH 0
	      REPLACE SEL_LUNPRG WITH 0
	      REPLACE SEL_CDDIBA WITH V_DIBA
	      REPLACE SEL_SCARTO WITH V_SCAR
	      REPLACE SEL_CODSYS WITH M.ORD_CODSYS
	      REPLACE SEL_CILRET WITH M.ORD_CILRET
	
	      *=> Rilevo il numero di bobine piů basso (l'accoppiamento deve avvenire per stessa altezza e stesso
	      *=> numero di bobine da programmare

	      IF V_ACCBOBI = 0
	         V_ACCBOBI = SEL_BOBACC
	      ENDIF

	      IF SEL_BOBACC < V_ACCBOBI
	         V_ACCBOBI = SEL_BOBACC
	      ENDIF
	
	      *=> Determino la nuova altezza con cui si devono confrontare gli altri ordini diminuendola di quella usata

	      V_ALTEZZA = V_ALTEZZA - V_ALTUSATA
	
	      SELECT CU_ORD_DL
	      SKIP +1
	
	   ENDDO

	   SELECT CUR_SELEZIONE
	   GO TOP
	   IF EOF()
	   ELSE
	      IF V_BYPASS
	      ELSE
	         *=> Determino la percentuale di tolleranza sul reso in altezza
	         V_PERCNOUSATA = (V_ALTEZZA * 100) / M.MAG_ALTEZZ
	         IF V_PERCNOUSATA > V_SCAABU
	            SELECT R_MAG_GG
	            REPLACE MAG_BYPASS WITH .T.
	            SELECT CUR_SELEZIONE
	            ZAP
	            SELECT CU_ORD_DL
	            SET ORDER TO I_PROGRA
	            GO TOP
	            LOOP
	         ENDIF
	      ENDIF
	   ENDIF

	   *=> Riprendo in esame il cursore provvisorio con le righe d'ordine che sono riuscito ad accoppiare
	   *=> per determinerne le esatte quantitŕ

	   V_PROGRE = V_PROGRE + 1
	
	   SELECT CUR_SELEZIONE
	   GO TOP
	
	   *=> calcolo il numero massimo di bobine che riuscirei a spalmare con la lunghezza della bobina in giacenza
	   IF EOF()
	   ELSE
	      V_MAX_BOB_SPALM = INT((V_LUNGHEZ / V_LUNGORD))
	      IF V_ACCBOBI > V_MAX_BOB_SPALM
	         V_ACCBOBI = V_MAX_BOB_SPALM
	      ENDIF
	   ENDIF
	
	   DO WHILE .T.

	      IF EOF()
	         EXIT
	      ENDIF

	      *=> Determino il numero di bobine e la quantitŕ in MQ da programmare per la singola riga d'ordine
	      REPLACE SEL_BOBPRG WITH V_ACCBOBI * SEL_ACCOPP
	      REPLACE SEL_QTAPRG WITH TROVA_MQ_DA_AL(SEL_ALTEZZ,SEL_LUNGHE,SEL_BOBPRG)
	      REPLACE SEL_LUNPRG WITH SEL_BOBPRG * SEL_LUNGHE / SEL_ACCOPP
	      SELECT CUR_SELEZIONE
	      SCATTER MEMVAR MEMO

	      *=> Accedo alle righe d'ordine selezionate dall'utente per aggiornarne le quantitŕ programmate
	      SELECT CU_ORD_DL
	      SET ORDER TO I_CODSYS
	      SEEK M.SEL_CODSYS
	      IF FOUND()
	         REPLACE ORD_NRBRID WITH ORD_NRBRID - M.SEL_BOBPRG
	         REPLACE ORD_QTARID WITH ORD_QTARID - M.SEL_QTAPRG
	         REPLACE ORD_NRBOBR WITH ORD_NRBOBR + M.SEL_BOBPRG
	         REPLACE ORD_QUANTR WITH ORD_QUANTR + M.SEL_QTAPRG
	         REPLACE ORD_NRBOBO WITH 0
	         REPLACE ORD_QUANTO WITH 0
	         REPLACE ORD_NRBRIP WITH ORD_NRBRIP + M.SEL_BOBPRG
	         REPLACE ORD_QTARIP WITH ORD_QTARIP + M.SEL_QTAPRG
	      ENDIF

	      *=> Accedo alle giacenze per aggiornarne le quantitŕ programmate
	      SELECT R_MAG_GG
	      REPLACE MAG_GIACEN WITH MAG_GIACEN - M.SEL_QTAPRG
	      REPLACE MAG_QTAMQ  WITH MAG_QTAMQ  - M.SEL_QTAPRG
	      REPLACE MAG_QTAKG  WITH MAG_QTAKG  - TROVA_KG_DA_MQ(M.SEL_CODART,M.SEL_SPESSO,M.SEL_QTAPRG,1)

	      *=> Aggiorno la nuova altezza della bobina residua
	      SELECT R_MAG_GG
	      REPLACE MAG_ALTRES WITH V_ALTEZZA
	      REPLACE MAG_COMODO WITH 1
	      X_NUMLOT = MAG_NRLINT

	      *=> Scrivo su un nuovo cursore le righe d'ordine che sono riuscito ad accoppiare con le quantitŕ programmate
	      SELECT CUR_RIBOBINATURA
	      APPEND BLANK
	      GATHER MEMVAR MEMO
	      REPLACE SEL_PROGRE WITH V_PROGRE
	      REPLACE SEL_CODMAC WITH 'RIS'
	      REPLACE SEL_DESMAC WITH 'RIS'
	      REPLACE SEL_SCARTO WITH V_SCAR
	      REPLACE SEL_ALTCOM WITH 99999 - SEL_ALTMAG		&& ALTEZZA COMPLEMENTATA A 99999 PER SORT ALTEZZA DISCENDENTE
	      REPLACE SEL_FLGELA WITH .F.
	      REPLACE SEL_NUMLOT WITH X_NUMLOT
	      REPLACE SEL_PROSUC WITH 1
	
	      SELECT CUR_SELEZIONE
	      SKIP +1

	   ENDDO

	   *=> Accedo alle giacenze per aggiornarne i metri lineari utilizzati e la lunghezza della bobina
	   SELECT R_MAG_GG
	   REPLACE MAG_QTAML  WITH MAG_QTAML - (V_ACCBOBI * V_LUNGORD)
	   REPLACE MAG_ALTRES WITH MAG_ALTEZZ
	   REPLACE MAG_BYPASS WITH .F. ALL
	
	   SELECT CUR_SELEZIONE
	   ZAP
	
	   SELECT CU_ORD_DL
	   SET ORDER TO I_PROGRA
	   GO TOP
	
	ENDDO

    V__SCARTO = V__SCARTO + 1

ENDDO


RELEASE RIB1_PROGRE,RIB1_DESART,RIB1_CODCOL,RIB1_DESCOL,RIB1_CODMAT,RIB1_DESMAT,RIB1_SPEMAG, ;
        RIB1_ALTMAG,RIB_LUNMAG,RIB1_LUNPRG,RIB1_PROSUC,RIB1_NRLINT
PUBLIC  RIB1_PROGRE,RIB1_CODART,RIB1_DESART,RIB1_CODCOL,RIB1_DESCOL,RIB1_CODMAT,RIB1_DESMAT,RIB1_SPEMAG, ;
        RIB1_ALTMAG,RIB_LUNMAG,RIB1_LUNPRG,RIB1_PROSUC,RIB1_NRLINT
RIB1_PROGRE = 0
RIB1_CODART = SPACE(16)
RIB1_DESART = SPACE(50)
RIB1_CODCOL = SPACE(03)
RIB1_DESCOL = SPACE(50)
RIB1_CODMAT = SPACE(03)
RIB1_DESMAT = SPACE(50)
RIB1_SPEMAG = 0
RIB1_ALTMAG = 0
RIB1_LUNMAG = 0
RIB1_LUNPRG = 0
RIB1_PROSUC = 0
RIB1_NRLINT = 0

RELEASE V_MISTAG,V_TROVATO,V_LUNRESTANTE,V_RECNO,V_ULTIMO,V_PROSUC
PUBLIC  V_MISTAG,V_TROVATO,V_LUNRESTANTE,V_RECNO,V_ULTIMO,V_PROSUC
V_MISTAG      = ""
V_TROVATO     = .F.
V_LUNRESTANTE = 0
V_RECNO       = 0
V_ULTIMO      = .F.
V_PROSUC      = 1
V_PRG         = 0

SELECT CUR_RIBOBINATURA
INDEX ON SEL_PROGRE	TAG I_ORDRIN
SET FILTER TO
GO top
REPLACE SEL_FLGELA WITH .F. ALL

=DEFPUB(SELECT())
SCATTER MEMVAR MEMO BLANK
HH=AFIELDS(TRANSITO)
CREATE CURSOR RIN_RIBOBINATURA FROM ARRAY TRANSITO

*=> Calcola la lunghezza programmata su tutte le righe
DO ribobinatura_calcolalunghezzaprogrammata

*=> Legame di programmazione sulla stessa bobina per ordini diversi se risultano bobine con lunghezza restante da ribobinare
*!*	SELECT CUR_RIBOBINATURA
*!*	INDEX ON SEL_NUMLOT TAG I_SPALMI ADDITIVE
*!*	SET ORDER TO I_SPALMI
*!*	SET FILTER TO
*!*	GO TOP
*!*	ZQE_NEWPRG = 1
*!*	ZQE_NUMLOT = SEL_NUMLOT
*!*	DO WHILE .T.
*!*	   IF EOF()
*!*	      EXIT
*!*	   ENDIF
*!*	   IF SEL_NUMLOT = ZQE_NUMLOT
*!*	      REPLACE SEL_PROGRE WITH ZQE_NEWPRG
*!*	   ELSE
*!*	      ZQE_NUMLOT = SEL_NUMLOT
*!*	      ZQE_NEWPRG = ZQE_NEWPRG + 1
*!*	      LOOP
*!*	   ENDIF
*!*	   SKIP +1
*!*	ENDDO

SELECT CUR_RIBOBINATURA
INDEX ON SEL_PROGRE TAG I_SPALMA ADDITIVE
INDEX ON ALLTRIM(STR(SEL_NUMLOT,8,0)) + ALLTRIM(STR(SEL_PROGRE,9,0)) TAG I_SPALME ADDITIVE
SET ORDER TO I_SPALME
SET FILTER TO SEL_LUNPRG <> SEL_LUNMAG
GO TOP
IF EOF()
ELSE
   RIB1_PROGRE = SEL_PROGRE
   RIB1_CODART = SEL_CODART
   RIB1_DESART = SEL_DESART
   RIB1_CODCOL = SEL_CODCOL
   RIB1_DESCOL = SEL_DESCOL
   RIB1_CODMAT = SEL_CODMAT
   RIB1_DESMAT = SEL_DESMAT
   RIB1_ALTMAG = SEL_ALTMAG
   RIB1_SPEMAG = SEL_SPEMAG
   RIB1_LUNMAG = SEL_LUNMAG
   RIB1_LUNPRG = SEL_LUNPRG
   RIB1_PROSUC = SEL_PROSUC
   RIB1_NRLINT = SEL_NUMLOT
ENDIF

V_PRIMA  = .T.
V_ULTIMO = .F.

DO WHILE .T.

   IF EOF()
      IF V_ULTIMO
         DO RIBOBINATURA_NONTROVATO
      ENDIF
      EXIT
   ENDIF

*   IF SEL_PROGRE = RIB1_PROGRE
   IF SEL_NUMLOT = RIB1_NRLINT
   ELSE

      V_TROVATO = .F.
*!*	      DO WHILE .T.
*!*	         IF EOF()
*!*	            EXIT
*!*	         ENDIF
*!*	         IF SEL_FLGELA
*!*	            SKIP +1
*!*	            LOOP
*!*	         ENDIF
*!*	         IF RIB1_NRLINT = SEL_NUMLOT
*!*	         ELSE
*!*	            SKIP +1
*!*	            LOOP
*!*	         ENDIF
*!*	         V_TROVATO = .T.
*!*	         EXIT
*!*	      ENDDO

      IF V_TROVATO
         DO RIBOBINATURA_TROVATO
         SELECT CUR_RIBOBINATURA
         IF SEL_FLGELA
            SKIP +1
            LOOP
         ENDIF
         REPLACE SEL_FLGELA WITH .F. ALL
         GO TOP
         IF EOF()
         ELSE
            RIB1_PROGRE = SEL_PROGRE
            RIB1_CODART = SEL_CODART
            RIB1_DESART = SEL_DESART
            RIB1_CODCOL = SEL_CODCOL
			RIB1_DESCOL = SEL_DESCOL
   			RIB1_CODMAT = SEL_CODMAT
   			RIB1_DESMAT = SEL_DESMAT
   			RIB1_ALTMAG = SEL_ALTMAG
   			RIB1_SPEMAG = SEL_SPEMAG
   			RIB1_LUNMAG = SEL_LUNMAG
   			RIB1_LUNPRG = SEL_LUNPRG
   			RIB1_PROSUC = SEL_PROSUC
   			RIB1_NRLINT = SEL_NUMLOT
            V_PRIMA = .T.
         ENDIF
         LOOP
      ELSE
         DO RIBOBINATURA_NONTROVATO
         SELECT CUR_RIBOBINATURA
         REPLACE SEL_FLGELA WITH .F. ALL
         GO TOP
         IF EOF()
         ELSE
            RIB1_PROGRE = SEL_PROGRE
            RIB1_CODART = SEL_CODART
            RIB1_DESART = SEL_DESART
            RIB1_CODCOL = SEL_CODCOL
			RIB1_DESCOL = SEL_DESCOL
   			RIB1_CODMAT = SEL_CODMAT
   			RIB1_DESMAT = SEL_DESMAT
   			RIB1_ALTMAG = SEL_ALTMAG
   			RIB1_SPEMAG = SEL_SPEMAG
   			RIB1_LUNMAG = SEL_LUNMAG
   			RIB1_LUNPRG = SEL_LUNPRG
   			RIB1_PROSUC = SEL_PROSUC
   			RIB1_NRLINT = SEL_NUMLOT
            V_PRIMA = .T.
         ENDIF
         LOOP
      ENDIF

   ENDIF

   V_ULTIMO = .T.

   SELECT CUR_RIBOBINATURA
   SKIP +1

ENDDO

SELECT CUR_RIBOBINATURA
SET FILTER TO
GO top

RETURN


***************************************************************************
PROCEDURE spalmatura_generagiacenze						
***************************************************************************

WAIT WINDOWS "PROGRAMMAZIONE DELLA SPALMATURA : " + CHR(13) + ;
             "Stň riepilogando le giacenze di film nudo e adesivi necessari alla programmazione" NOWAIT

x_codi = "codice = 'PDP04'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __STEPSP = 'NO'
ELSE
   __STEPSP = SUBSTR(LIBERA,1,2)
ENDIF

x_codi = "codice = 'GCF01'"
Csql   = "select * from para where " + x_codi
IF !ExecCommand(cSql,"cur_para")
   return(.f.)
ENDIF
SELECT cur_para
GO TOP
IF EOF()
   __CALFAB = 'NO'
ELSE
   __CALFAB = SUBSTR(LIBERA,1,2)
ENDIF

IF __STEPSP = 'SI'
   SET STEP ON
ENDIF

RELEASE V_DIBA
PUBLIC  V_DIBA
V_DIBA = SPACE(16)

*=> Riepilogo delle giacenze di film nudo presente a magazzino
x_data = "mag_datagg <> SPACE(10)"
x_giac = "mag_giacen > 0"
x_maga = "mag_codmag = '" + ALLTRIM(PUB_CQUMPC) + "'"
x_impe = "mag_qtaimp < mag_giacen"
x_cond = x_data + " and " + x_giac + " and " + x_maga + " and " + x_impe
Csql   = "select * from u_mag_gg where " + x_cond + " order by mag_codmat,mag_codcol,mag_spesso,mag_altezz desc,mag_nrlint,MAG_QTAML desc"
IF !ExecCommand(Csql,"G_mag_gg")
   return(.f.)
ENDIF
SELECT G_MAG_GG
REPLACE SELEZIONE WITH "=>" ALL
REPLACE MAG_NLPROV WITH 99999 - MAG_ALTEZZ FOR MAG_SPESSO > 0 && ALTEZZA COMPLEMENTATA
GO TOP
IF EOF()
ELSE
   *=> Se calcolo fabbisogni non devo visualizzare le giacenze per successiva selezione
   IF _V_FABBIS
      *=> Se il calcolo dei fabbisogni NON deve tenere conto delle giacenze esistenti al netto dell'impegnato, cancello
      *=> il cursore delle giacenze, in modo da generare un fabbisogno totale
      IF __CALFAB = 'NO'
      ELSE
         ZAP
      ENDIF
   ELSE
      IF PUB_VISGIAC
         RIT = MESSAGEBOX("Vuoi consultare le Materie Prime in giacenza ?",292,"ATTENZIONE")
         IF RIT = 7
         ELSE
            _V_OPZORD1 = 1
            _V_OPZORD3 = 1
            _V_OPZORD4 = 1
            DO FORM FORM\VEDIGIACB LINKED
         ENDIF
      ENDIF
   ENDIF
ENDIF
SELECT G_MAG_GG
INDEX ON MAG_CODMAT + MAG_CODCOL									 								TAG I_GMAGG1 ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) 						TAG I_GMAGG2 ADDITIVE
INDEX ON MAG_ANAART													 								TAG I_GMAGG3 ADDITIVE
INDEX ON MAG_CODART + MAG_CODMAG									 								TAG I_GMAGG4 ADDITIVE

*=> Riepilogo delle giacenze sul magazzino di carico / controllo qualitŕ
x_data = "mag_datagg <> SPACE(10)"
x_giac = "mag_giacen > 0"
x_maga = "mag_codmag = '" + ALLTRIM(PUB_CARORF) + "'"
x_impe = "mag_qtaimp < mag_giacen"
x_cond = x_data + " and " + x_giac + " and " + x_maga + " and " + x_impe
Csql   = "select * from u_mag_gg where " + x_cond + " order by mag_codmat,mag_codcol,mag_spesso,mag_altezz desc,mag_nrlint,MAG_QTAML desc"
IF !ExecCommand(Csql,"CQ_mag_gg")
   return(.f.)
ENDIF
SELECT CQ_mag_gg
REPLACE MAG_NLPROV WITH 99999 - MAG_ALTEZZ FOR MAG_SPESSO > 0 && ALTEZZA COMPLEMENTATA
INDEX ON MAG_ANAART 																				TAG I_INDICE2 ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_NLPROV,8,0) + STR(MAG_SPESSO,5,0) + ;
         STR(MAG_NRLINT,8,0)																		TAG I_INDICE3 ADDITIVE

*=> Aggiunta delle giacenze del Controllo Qualitŕ in caso di determinazione dei fabbisogni
IF _V_FABBIS
   SELECT CQ_MAG_GG
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      SCATTER MEMVAR MEMO
      SELECT G_MAG_GG
      APPEND BLANK
      GATHER MEMVAR MEMO
      SELECT CQ_MAG_GG
      SKIP +1
   ENDDO
   *=> Se il calcolo dei fabbisogni NON deve tenere conto delle giacenze esistenti al netto dell'impegnato, cancello
   *=> il cursore delle giacenze, in modo da generare un fabbisogno totale
   IF __CALFAB = 'NO'
   ELSE
      SELECT G_MAG_GG	
      ZAP
   ENDIF
ENDIF

*=> Riepilogo dell'ordinato a fornitori di film nudo e adesivi in essere
x_sald = "ord_salcon <> 'S'"
x_cond = x_sald
Csql   = "select * from u_orf_dl where " + x_cond + " order by ord_codmat,ord_codcol,ord_spesso,ord_altezz desc,ord_lunghe desc"
IF !ExecCommand(Csql,"G_orf_dl")
   return(.f.)
ENDIF
SELECT G_ORF_DL
REPLACE ORD_ALTCOM WITH 99999 - ORD_ALTEZZ FOR ORD_SPESSO > 0 && ALTEZZA COMPLEMENTATA
INDEX ON ORD_CODART 																				TAG I_INDICE2 ADDITIVE
INDEX ON ORD_CODMAT + ORD_CODCOL + STR(ORD_ALTCOM,5,0) + STR(ORD_SPESSO,5,0)						TAG I_INDICE3 ADDITIVE

*=> Aggiunta dell'ordinato a fornitore in caso di determinazione dei fabbisogni
IF _V_FABBIS
   SELECT G_ORF_DL
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF EMPTY(ALLTRIM(ORD_CODART))
         SKIP +1
         LOOP
      ENDIF
      V_TIPO = CERCATIPO(ORD_CODART)
*!*	      IF V_TIPO = "1" .OR. V_TIPO = '2'
*!*	      ELSE
*!*	         SKIP +1
*!*	         LOOP
*!*	      ENDIF
      IF V_TIPO = '1'
         VVFF_GIACEN = ORD_QTAMQ - ORD_QTAMQE
      ELSE
         VVFF_GIACEN = ORD_QTAKG - ORD_QTAKGE
      ENDIF
      IF VVFF_GIACEN > 0
      ELSE
         SKIP +1
         LOOP
      ENDIF
      SCATTER MEMVAR MEMO
      SELECT G_MAG_GG
      APPEND BLANK
      REPLACE MAG_CODSOC WITH PUB_CODSOC
      REPLACE MAG_DATAGG WITH RIBALTA2(DTOC(DATE()))
      REPLACE MAG_CODART WITH M.ORD_CODART
      REPLACE MAG_DESART WITH M.ORD_DESART
      REPLACE MAG_CODMAG WITH 'ORF'
      IF M.ORD_CODMAT <> '001' .AND. M.ORD_CODMAT <> '004'
         REPLACE MAG_GIACEN WITH M.ORD_QTAMQ - M.ORD_QTAMQE
      ELSE
         REPLACE MAG_GIACEN WITH M.ORD_QTAKG - M.ORD_QTAKGE
      ENDIF
      REPLACE MAG_CODMAT WITH M.ORD_CODMAT
      REPLACE MAG_DESMAT WITH M.ORD_DESMAT
      REPLACE MAG_CODCOL WITH M.ORD_CODCOL
      REPLACE MAG_DESCOL WITH M.ORD_DESCOL
      REPLACE MAG_SPESSO WITH M.ORD_SPESSO
      REPLACE MAG_ALTEZZ WITH M.ORD_ALTEZZ
      REPLACE MAG_LUNGHE WITH M.ORD_LUNGHE
      REPLACE MAG_QTAMQ  WITH M.ORD_QTAMQ - M.ORD_QTAMQE
      REPLACE MAG_QTAKG  WITH M.ORD_QTAKG - M.ORD_QTAKGE
      REPLACE MAG_QTAML  WITH M.ORD_QTAML - M.ORD_QTAMLE
      REPLACE MAG_LUNGHE WITH MAG_QTAML
      REPLACE MAG_ANAART WITH M.ORD_CODART
      SELECT G_ORF_DL
      SKIP +1
   ENDDO
   *=> Se il calcolo dei fabbisogni NON deve tenere conto delle giacenze esistenti al netto dell'impegnato, cancello
   *=> il cursore delle giacenze, in modo da generare un fabbisogno totale
   IF __CALFAB = 'NO'
   ELSE
      SELECT G_MAG_GG	
      ZAP
   ENDIF
ENDIF

* -->> Creazione cursore giacenze riepilogate magazzino M.P.
* ----------------------------------------------------------
IF !ExecCommand("select * from u_mag_gg where 0=1","u_mag_gg")
   return(.f.)
ENDIF
SELECT U_MAG_GG
=DEFPUB(SELECT())
SCATTER MEMVAR MEMO BLANK
HH=AFIELDS(TRANSITO)
CREATE CURSOR CURS_MAG_GG FROM ARRAY TRANSITO
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + STR(MAG_LUNGHE,6,0) 	TAG I_INDICE1 ADDITIVE
INDEX ON MAG_ANAART 																				TAG I_INDICE2 ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_NLPROV,8,0) + STR(MAG_SPESSO,5,0) + ;
         STR(MAG_NRLINT,8,0)																		TAG I_INDICE3 ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0)					 	TAG I_INDICE4 ADDITIVE

CREATE CURSOR NOP_MAG_GG FROM ARRAY TRANSITO
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + STR(MAG_LUNGHE,6,0) 	TAG I_INDICE1 ADDITIVE
INDEX ON MAG_ANAART 																				TAG I_INDICE2 ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_NLPROV,8,0) + STR(MAG_SPESSO,5,0) + ;
         STR(MAG_NRLINT,8,0)																		TAG I_INDICE3 ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0)					 	TAG I_INDICE4 ADDITIVE

CREATE CURSOR DETTA_MAG_GG FROM ARRAY TRANSITO
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) 						TAG I_DETTA ADDITIVE

* -->> Creazione cursore giacenze riepilogate ordini a fornitori giŕ emessi (residuo)
* -----------------------------------------------------------------------------------
IF !ExecCommand("select * from u_mag_gg where 0=1","u_mag_gg")
   return(.f.)
ENDIF
SELECT U_MAG_GG
=DEFPUB(SELECT())
SCATTER MEMVAR MEMO BLANK
HH=AFIELDS(TRANSITO)
CREATE CURSOR CURS_MAG_OR FROM ARRAY TRANSITO
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + STR(MAG_LUNGHE,6,0) 	TAG I_INDICE1 ADDITIVE
INDEX ON MAG_ANAART 																				TAG I_INDICE2 ADDITIVE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_NLPROV,8,0) + STR(MAG_SPESSO,5,0) 						TAG I_INDICE3 ADDITIVE

* -->> Creazione cursore giacenze riepilogate magazzino M.P. bobine da ordinare riepilogate
* -----------------------------------------------------------------------------------------
CREATE CURSOR CUR_MAG_DO (MAG_CODART C(16), MAG_DESART C(50),   MAG_ANAART C(16),  MAG_CODMAT C(03),  MAG_DESMAT C(50),  ;
                           MAG_CODCOL C(03), MAG_DESCOL C(50),   MAG_SPESSO N(05),  MAG_ALTEZZ N(05),  MAG_LUNGHE N(06),  ;
                           MAG_ALTRES N(05), MAG_GIACEN N(12,2), MAG_QTAMQ N(18,2), MAG_QTAKG N(18,2), MAG_QTAML N(18,2), ;
                           MAG_CDDIBA C(16), MAG_LUNORD N(15))

SELECT CUR_MAG_DO
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + STR(MAG_LUNGHE,6,0) 	TAG I_INDICE1 ADDITIVE
INDEX ON MAG_ANAART 																				TAG I_INDICE2 ADDITIVE
INDEX ON STR(MAG_ALTEZZ,5,0) + STR(MAG_QTAML,6,0)													TAG I_INDICE3 DESCENDING ADDITIVE


* -->> Creazione cursore giacenze riepilogate magazzino M.P. bobine da ordinare dettagliate
* -----------------------------------------------------------------------------------------
CREATE CURSOR CUR_MAG_DE (MAG_CODART C(16), MAG_DESART C(50),   MAG_ANAART C(16),  MAG_CODMAT C(03),  MAG_DESMAT C(50),  ;
                           MAG_CODCOL C(03), MAG_DESCOL C(50),   MAG_SPESSO N(05),  MAG_ALTEZZ N(05),  MAG_LUNGHE N(06),  ;
                           MAG_ALTRES N(05), MAG_GIACEN N(12,2), MAG_QTAMQ N(18,2), MAG_QTAKG N(18,2), MAG_QTAML N(18,2), ;
                           MAG_CDDIBA C(16), MAG_LUNORD N(15))

SELECT CUR_MAG_DE
INDEX ON MAG_CODMAT + MAG_CODCOL + STR(MAG_SPESSO,5,0) + STR(MAG_ALTEZZ,5,0) + STR(MAG_LUNGHE,6,0) 	TAG I_INDICE1 ADDITIVE
INDEX ON MAG_ANAART 																				TAG I_INDICE2 ADDITIVE
INDEX ON STR(MAG_ALTEZZ,5,0) + STR(MAG_QTAML,6,0)													TAG I_INDICE3 DESCENDING ADDITIVE


* -->> Inizio elaborazione per creazione cursori di giacenza

SELECT CU_ORD_DL
SET ORDER TO I_PROGRA
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Acquisizione dello spessore compatibile
   *=> - accedo con key = spessore del film ordinato
   *=> - acquisisco dalla tabella lo spessore del film nudo compatibile.
   x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
   x_tmat = "mic_codmat = '" + ALLTRIM(M.ORD_CODMAT) + "'"
   x_cond = x_spes + " and " + x_tmat
   Csql   = "select * from u_pro_my where " + x_cond
   IF !ExecCommand(Csql,"u_pro_my")
      return(.f.)
   ENDIF
   SELECT U_PRO_MY
   GO TOP
   IF EOF()
      x_spes = "mic_spesso = " + ALLTRIM(STR(M.ORD_SPESSO,5,0))
      x_tmat = "mic_codmat = SPACE(03)"
      x_cond = x_spes + " and " + x_tmat
      Csql   = "select * from u_pro_my where " + x_cond
      IF !ExecCommand(Csql,"u_pro_my")
         return(.f.)
      ENDIF
      SELECT U_PRO_MY
      GO TOP
      IF EOF()
         SELECT CU_ORD_DL
         SKIP +1
         LOOP
      ENDIF
   ENDIF
   SCATTER MEMVAR

   *=> Riepilogo delle giacenze di film nudo per il prodotto ordinato

   V_SEEK = M.ORD_CODMAT + M.ORD_CODCOL
   SELECT G_MAG_GG
   SET ORDER TO I_GMAGG1
   SEEK V_SEEK
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
