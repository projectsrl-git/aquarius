********************************************************************************
PROCEDURE BOLRIMAGA  && RICARICA IL MAGAZZINO (FASE DI AGGIORNAMENTO GESTIONALE)
********************************************************************************



SELECT CU_BOL_DD
SET FILTER TO
GO TOP



DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SELECT CU_BOL_DD
      SKIP +1
      LOOP
   ENDIF

   IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
      SELECT CU_BOL_DD
      SKIP +1
      LOOP
   ENDIF

   IF ORD_FLGMOD = 'A' .OR. ORD_FLGMOD = 'M'
   ELSE
      IF ORD_FLGMOD = 'I'
         U_AGGIORNA = .T.
      ENDIF
      SELECT CU_BOL_DD
      SKIP +1
      LOOP
   ENDIF

   * SI CREA LE VARIABILI DAL RECORD
   SCATTER MEMVAR MEMO	 	

   **=> ERASMO - INIZIO 25/02/2009
   SELECT CU_BOL_DD
   x_agga = "leg_agganc = '" + DAGGANCIO + "'"
   x_lega = "leg_sysbol = '" + ORD_CODSYS + "'"
   x_cond = x_agga + " and " + x_lega
   CSQL="SELECT * FROM U_BOL_LE WHERE " + x_cond
   IF !ExecCommand(CSQL,"PRENOT_BOL_LE")
      RETURN (.f.)
   ENDIF
   **=> ERASMO - FINE 25/02/2009

   DO MAG_IN_AGG WITH "CU_BOL_DD","U_BOL_DD","+","BOL"

   **=> ERASMO - INIZIO 25/02/2009
   *** REIMPOSTO IL PRENOTATO SU GIACENZA SE ARTICOLO PRESENTE SULLE TABELLE DI PRODUZIONE
   SELECT PRENOT_BOL_LE
   GO TOP
   SCAN
      _CODINT = ALLTRIM(LEG_CODART)
      _INPROD = .F.
      x_codi = "pr5_codint = '" + _CODINT + "'"
      x_cond = x_codi
      cSql   = "SELECT * FROM U_PRD_D5 WHERE " + x_cond
      IF !ExecCommand(CSQL,"FND_PRD_D5")
         RETURN (.f.)
      ENDIF
      SELECT FND_PRD_D5
      GO TOP
      IF EOF()
         x_codi = "pr5_codint = '" + _CODINT + "'"
         x_cond = x_codi
         cSql   = "SELECT * FROM U_PRD_PK WHERE " + x_cond
         IF !ExecCommand(CSQL,"FND_PRD_PK")
            RETURN (.f.)
         ENDIF
         SELECT FND_PRD_PK
         GO TOP
         IF EOF()
         ELSE
            _INPROD = .T.
         ENDIF
      ELSE
         _INPROD = .T.
      ENDIF
      IF _INPROD
         x_codi = "MAG_CODART = '" + _CODINT + "'"
         x_cond = x_codi
         cSql   = "UPDATE U_MAG_GG SET MAG_PRENOT = 1 WHERE " + x_cond
         IF !ExecCommand(CSQL,"UPD_MAG_GG")
            RETURN (.f.)
         ENDIF
      ENDIF
   ENDSCAN
   **=> ERASMO - FINE 25/02/2009

   SELECT CU_BOL_DD
   SCATTER MEMVAR MEMO

   **==> Gestione del file delle bolle trasferite per i pdv
   x_uniq = "orf_unique = '" + ALLTRIM(M.ORD_CODSYS) + "'"
   x_lega = "orf_agganc = '" + ALLTRIM(M.ORD_LEGAME) + "'"
   x_cond = x_uniq + " and " + x_lega
   Csql   = "select * from u_orf_po where " + x_cond
   IF !ExecRW(Csql,"U_ORF_PO","R")
      return(.f.)
   ENDIF
   SELECT U_ORF_PO
   IF EOF()
   ELSE
      REPLACE ORF_QTASPE WITH ORF_QTASPE - M.ORD_QTAORD
   ENDIF
   IF !ExecRW(Csql,"u_orf_po","W")
      return(.f.)
   ENDIF

   **  Lancio procedura di carico/scarico componenti in automatico se TOP lo prevede
   IF CSC = 'X'
      SSSS=SELECT()
      x_soci = "dit_codsoc = '" + PUB_CODSOC + "'"
      x_codi = "dit_gruppo = '" + ALLTRIM(M.ORD_CODART) + "'"
      x_cond = x_soci + " and " + x_codi
      Csql   = "select * from u_dis_tt where " + x_cond + " order by dit_codsoc,dit_gruppo"
      IF !ExecCommand(cSql,"cur_diba")
         return(.f.)
      ENDIF
      SELECT cur_diba
      GO TOP
      IF EOF()
      ELSE
         TP = 'C'
         RELEASE W_MAGAZ,W_QUANTI
         PUBLIC  W_MAGAZ,W_QUANTI
         W_MAGAZ  = M.ORD_MAGA
         W_QUANTI = M.ORD_QTAORD
         DO ALBERELLO WITH .F.,M.ORD_CODART
         DO CARI_COMP WITH "BOL"
      ENDIF
      SELECT(SSSS)
   ENDIF

   SELECT CU_BOL_DD
   SKIP +1

ENDDO

RETURN


