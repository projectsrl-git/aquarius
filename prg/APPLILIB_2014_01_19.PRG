   IF !ExecCommand(cSql,"PARA")
      return(.f.)
   ENDIF
   SELECT PARA
   GO TOP
   IF EOF()
      X_DESACQ = SPACE(03)
   ELSE
      X_DESACQ = DESCRI
   ENDIF

   RELEASE ZZZ_LEGAME
   PUBLIC  ZZZ_LEGAME
   ZZZ_LEGAME = SYS(2015)

   x_dove = "alt_dadove = 'BFOCAMAG'"
   x_maga = "alt_codmag = '" + ALLTRIM(M.ORD_MAGA) + "'"
   x_csys = "alt_legame = '" + ZZZ_LEGAME + "'"
   x_cond = x_dove + " and " + x_maga + " and " + x_csys
   cSql   = "SELECT * FROM U_ALT_DA WHERE " + x_cond
   IF !ExecRW(cSql,"U_ALT_DA","R")
      return(.f.)
   ENDIF
   SELECT U_ALT_DA
   GO TOP
   IF EOF()
      APPEND BLANK
      REPLACE ALT_UNIQUE WITH SYS(2015)
   ENDIF
   REPLACE ALT_DADOVE WITH 'BFOCAMAG'
   REPLACE ALT_CODMAG WITH M.ORD_MAGA
   REPLACE ALT_LEGAME WITH ZZZ_LEGAME
   REPLACE ALT_NUMORF WITH M.ORS_NUMORC
   IF M.ORS_DATORC = SPACE(10) .OR. M.ORS_DATORC = '  /  /    ' .OR. EMPTY(M.ORS_DATORC)
      REPLACE ALT_DATORF WITH SPACE(10)
   ELSE
      IF SUBSTR(M.ORS_DATORC,3,1) = '/'
         REPLACE ALT_DATORF WITH RIBALTA2(M.ORS_DATORC)
      ELSE
         REPLACE ALT_DATORF WITH M.ORS_DATORC
      ENDIF
   ENDIF
   REPLACE ALT_PAGAME WITH M.ORS_CODCPA
   REPLACE ALT_CODACQ WITH M.ORS_CODACQ
   REPLACE ALT_DESACQ WITH X_DESACQ
   REPLACE ALT_SC1    WITH M.ORD_SC1
   REPLACE ALT_SC2    WITH M.ORD_SC2
   REPLACE ALT_SC3    WITH M.ORD_SC3
   REPLACE ALT_NUMIDE WITH M.ORS_NUMIDE
   REPLACE ALT_CODBUN WITH M.ORS_CODBUN
   REPLACE ALT_ANNO   WITH M.ORS_ANNO
   REPLACE ALT_CODCLI WITH M.ORS_CODCLI
   REPLACE ALT_DTASCA WITH M.ORD_DTASCA
   REPLACE ALT_FLGTRA WITH .F.
   REPLACE ALT_CODMAT WITH _CODMAT
   REPLACE ALT_DESMAT WITH _DESMAT
   REPLACE ALT_TIPART WITH _TIPART
   REPLACE ALT_ARTORF WITH M.ORD_CODART
   REPLACE ALT_FLGCEL WITH M.ORD_FLGCEL
   REPLACE ALT_QTACON WITH M.ORD_QTACON
   REPLACE ALT_SERIE  WITH M.ORD_SERIE
   REPLACE ALT_SERBOL WITH M.ORD_SERBOL
   REPLACE ALT_SERNUM WITH M.ORD_SERNUM
   REPLACE ALT_NUMEDA WITH M.ORD_NUMEDA
   REPLACE ALT_NUMEAL WITH M.ORD_NUMEAL
   REPLACE ALT_AAPROD WITH M.ORD_AAPROD
   REPLACE ALT_CBFISC WITH M.ORD_CBFISC
   REPLACE ALT_NUMBOB WITH M.ORD_NUMBOB
   REPLACE ALT_ALTEZZ WITH M.ORD_ALTEZZ
   IF !ExecRW(cSql,"U_ALT_DA","W")
      return(.f.)
   ENDIF

   IF V_TIPO = '1' .OR. V_TIPO = '2'
      SELECT CU_BFO_DL
      SET FILTER TO
      SET FILTER TO DAGGANCIO = M.DAGGANCIO .AND. ORD_AGGORF = M.ORD_LEGAME .AND. ORD_SYSORF = M.ORD_LEGASY .AND. ORD_TIPMOV <> 'A'
      SET ORDER TO I_ORDINE
      GO TOP
      IF EOF()
      ELSE
         DO WHILE .T.
            IF EOF()
               EXIT
            ENDIF
            IF ORD_UM = 'KG'
               V_QTACTRL = ORD_QTAKG
            ELSE
               V_QTACTRL = ORD_QTAMQ
            ENDIF
            IF V_QTACTRL > 0
            ELSE
               SKIP +1
               LOOP
            ENDIF
            IF EMPTY(ALLTRIM(ORD_ARTORF)) .OR. ORD_ARTORF = ORD_CODART .OR. ORD_NRLINT = 0
               REPLACE ORD_ARTORF WITH ORD_CODART
               V_ANNO   = SUBSTR(DTOC(DATE()),10,1)
               SS       = SELECT()

               *=> In base al valore di PUB_TIPOBOB viene assegnato il codice tipo
               *=> - FNU = FILM NUDO  (M.P.)
               *=> - ADE = ADESIVI    (M.P.)
               *=> - COL = COLLA      (S.L.)
               *=> - SPA = BOBINA SPALMATA
               *=> - RIB = BOBINA RIBOBINATA
               *=> - IMB = BOBINA RIBOBINATA BUONA SOLO PER L'IMBALLO
               *=> - TAG = BOBINA TAGLIATA
               V_TIPO = '0'
               IF PUB_TIPOBOB = 'FNU'
                  V_TIPO = '1'
               ENDIF
               IF PUB_TIPOBOB = 'ADE'
                  V_TIPO = '2'
               ENDIF
               IF PUB_TIPOBOB = 'COL'
                  V_TIPO = '3'
               ENDIF
               IF PUB_TIPOBOB = 'SPA'
                  V_TIPO = '4'
               ENDIF
               IF PUB_TIPOBOB = 'RIB'  .OR. PUB_TIPOBOB = 'IMB'
                  V_TIPO = '5'
               ENDIF
               IF PUB_TIPOBOB = 'TAG'
                  V_TIPO = '6'
               ENDIF

               v_seek   = 'NUMBOB'+V_TIPO
               v_chiave = "codice"
               cSql="select * from para where " + v_chiave + " = '" + v_seek + "'"
               IF !ExecRW(cSql,"PARA","R")
                  return(.f.)
               ENDIF
               SELECT PARA
               IF RECCOUNT() <> 0
               ELSE
                  APPEND BLANK
                  REPLACE CODICE WITH 'NUMBOB' + V_TIPO
                  REPLACE DESCRI WITH 'PROGRESSIVO NUMERO LOTTO INTERNO PER BOBINE ' + PUB_TIPOBOB
                  REPLACE LIBERA WITH '0000000'
               ENDIF
               V2 = VAL(SUBSTR(LIBERA,1,7)) + 1
               REPLACE LIBERA WITH SUBSTR(STR(V2,7,0),1,7)
               V_CODART = ALLTRIM(SUBSTR(STR(V2,7,0),1,7))
               IF !ExecRW(cSql,"PARA","W")
                  return(.f.)
               ENDIF
               SELECT(SS)
               PUB_LNO  = 6
               V_CODART = TRC(PUB_LNO,ALLTRIM(V_CODART))
               V_CODART = V_TIPO + V_ANNO + V_CODART
               SELECT CU_BFO_DL
               REPLACE ORD_NRLINT WITH VAL(V_CODART)
               V_CDARTI = ALLTRIM(ORD_ARTORF)
               IF LEN(V_CDARTI) > 7
                  V_CODART = SUBSTR(V_CDARTI,1,7) + '.' + V_CODART
               ELSE
                  V_CODART = V_CDARTI + '.' + V_CODART
               ENDIF
               REPLACE ORD_CODART WITH V_CODART
            ENDIF
            SCATTER MEMVAR MEMO

            XXY_CODINT = ORD_CODART
            XXY_NRLINT = ORD_NRLINT

            x_soci = "lot_codsoc = '" + PUB_CODSOC + "'"
            x_nlin = "lot_nloini = " + ALLTRIM(STR(M.ORD_NRLINT,8,0))
            x_data = "lot_datope = '" + RIBALTA2(DTOC(DATE())) + "'"
            x_nlfi = "lot_nlofin = " + ALLTRIM(STR(M.ORD_NRLINT,8,0))
            x_cond = x_soci + " and " + x_nlin + " and " + x_data + " and " + x_nlfi
            cSql   = "SELECT * FROM U_LOT_RI WHERE " + x_cond
            IF !ExecRW(cSql,"U_LOT_RI","R")
               return(.f.)
            ENDIF
            SELECT U_LOT_RI
            GO TOP
            IF EOF()
               APPEND BLANK
            ENDIF
            REPLACE LOT_CODSOC WITH PUB_CODSOC
            REPLACE LOT_NLOINI WITH M.ORD_NRLINT
            REPLACE LOT_DATOPE WITH RIBALTA2(DTOC(DATE()))
            REPLACE LOT_ORAOPE WITH TIME()
            REPLACE LOT_MAGSCA WITH SPACE(06)
            REPLACE LOT_MAGCAR WITH M.ORD_MAGA
            REPLACE LOT_CODCAU WITH M.ORD_CAUS
            REPLACE LOT_NLOFIN WITH M.ORD_NRLINT
            IF !ExecRW(cSql,"U_LOT_RI","W")
               return(.f.)
            ENDIF

            x_dove = "alt_dadove = 'BFOCAMAG'"
            x_maga = "alt_codmag = '" + ALLTRIM(M.ORD_MAGA) + "'"
            x_csys = "alt_legame = '" + ZZZ_LEGAME + "'"
