*******************************************
PROCEDURE GESTIONE_COMMENTO_CLASSI_DOGANALI
*******************************************
LPARAMETERS _par_CurName,_par_CodNaz

IF PCOUNT() >= 2
ELSE
	RETURN
ENDIF

SELECT &_par_CurName

DELETE FOR ORD_CODICE = "CLAS_DOG" AND ALLTRIM(ORD_DESART) == '*** COMMENTO ***'
*REPLACE ORD_FLGMOD WITH 'A' FOR ORD_CODICE = "CLAS_DOG" AND ALLTRIM(ORD_DESART) == '*** COMMENTO ***'  && ERASMO/SERGIO - 08/04/2013  && NON VA BENE PERCHE' NON TUTTI I DOCUMENTI GESTISCONO L'ORD_FLGMOD

GO TOP
IF EOF()
	RETURN
ENDIF

*CREATE CURSOR CU_CLASSI_DOGANALI (CODICE C(20), DESCRIZIONE C(200))
CREATE CURSOR CU_CLASSI_DOGANALI (CODICE C(20), DESCRIZIONE C(200), ARTICOLI M)  && ERASMO/LUCA 21/02/2013
INDEX ON ALLTRIM(CODICE) TAG I_RAGGRU

IF ALLTRIM(_par_CodNaz) == ALLTRIM(PUB_NAZI)
	RETURN
ENDIF

SELECT &_par_CurName
GO TOP
DO WHILE !EOF()
	IF DELETED()
		SKIP +1
		LOOP
	ENDIF
	
	IF ALLTRIM(ORD_FLGMOD) == 'A'
		SKIP +1
		LOOP
	ENDIF
	
	IF ALLTRIM(ORD_DESART) == '*** COMMENTO ***'
		SKIP +1
		LOOP
	ENDIF
	
	_CODICE = ""
	_DESCRIZIONE = ""
	_ARTICOLO = ""  && ERASMO/LUCA 21/02/2013
	SELECT &_par_CurName
	x_soci = "u_art_pr.art_codsoc = '" + PUB_CODSOC + "'"
	x_codi = "u_art_pr.art_codpri = '" + ALLTRIM(ORD_CODART) + "'"
	x_cond = x_soci + " and " + x_codi
	Csql   = "select u_art_pr.art_codpri, u_art_pr.art_cldog, coalesce(para.descri,'') as art_descldog from u_art_pr left outer join para " + ;
		"on para.codice = 'DOG'+u_art_pr.art_cldog where " + x_cond
	IF !ExecCommand(cSql,"CX_ART_PR")
	   return(.f.)
	ENDIF
	SELECT CX_ART_PR
	GO TOP
	IF !EOF()
		_CODICE = art_cldog
		_DESCRIZIONE = ALLTRIM(art_descldog)
		_ARTICOLO = ALLTRIM(art_codpri)  && ERASMO/LUCA 21/02/2013
	ENDIF
	
	IF EMPTY(_CODICE)
		SELECT &_par_CurName
		SKIP +1
		LOOP
	ENDIF
	
	_SEEK = ALLTRIM(_CODICE)
	
	SELECT CU_CLASSI_DOGANALI
	SET ORDER TO I_RAGGRU
	GO TOP
	SEEK _SEEK
	IF !FOUND()
		APPEND BLANK
		REPLACE CODICE WITH _CODICE
		REPLACE DESCRIZIONE WITH _DESCRIZIONE
		REPLACE ARTICOLI WITH ''  && ERASMO/LUCA 21/02/2013
	ENDIF
	**=> ERASMO - INIZIO 25/02/2013
	IF ALLTRIM(_ARTICOLO) $ ARTICOLI
	ELSE
		REPLACE ARTICOLI WITH ALLTRIM(ARTICOLI) + IIF(EMPTY(ARTICOLI),'',' ; ') + ALLTRIM(_ARTICOLO)
	ENDIF
	**=> ERASMO - FINE 25/02/2013
	

