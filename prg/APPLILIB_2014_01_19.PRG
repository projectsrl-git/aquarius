		ENDIF
		IF  ALLTRIM(PRV_COGLI04)	= __GRUPPO_PRODUTTIVO
			_PERCPRO_PERSONALIZZATE		= PRV_PEGLI04
		ENDIF
		IF  ALLTRIM(PRV_COGLI05)	= __GRUPPO_PRODUTTIVO
