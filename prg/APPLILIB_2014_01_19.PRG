   ENDIF
   SKIP +1
ENDDO
SELECT CUR_TIPOMOV
REPLACE TIP_CAUSCA WITH V_CAUSCA
REPLACE TIP_CAUCAR WITH V_CAUCAR

SELECT CUR_TIPOMOV
APPEND BLANK
REPLACE TIP_CODICE WITH 180
REPLACE TIP_DESCRI WITH "Spostamento DAL reparto produzione taglio AL mag. P.F. da spedire al cliente"
REPLACE TIP_CMASCA WITH PUB_TAGPRO
REPLACE TIP_DMASCA WITH DES_TAGPRO
REPLACE TIP_CMACAR WITH PUB_TAGPFO
REPLACE TIP_DMACAR WITH DES_TAGPFO

V_CAUSCA = SPACE(03)
V_CAUCAR = SPACE(03)
x_cond = "tipomov = " + ALLTRIM(STR(TIP_CODICE,3,0))
cSql   = "select * from para where " + x_cond
IF !ExecCommand(cSql,"cur_para")
   RETURN
ENDIF
SELECT CUR_PARA
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF SUBSTR(CODICE,1,3) = 'TOP'
   ELSE
      SKIP +1
      LOOP
   ENDIF
   IF SUBSTR(LIBERA,1,1) = 'S'
      V_CAUSCA = SUBSTR(CODICE,4,3)
   ENDIF
   IF SUBSTR(LIBERA,1,1) = 'C'
      V_CAUCAR = SUBSTR(CODICE,4,3)
   ENDIF
   SKIP +1
ENDDO
SELECT CUR_TIPOMOV
REPLACE TIP_CAUSCA WITH V_CAUSCA
REPLACE TIP_CAUCAR WITH V_CAUCAR

RETURN


***************************************************************************
PROCEDURE BOBSPA_DARIB
***************************************************************************

PARAMETERS __V_NOMECUR,__V_CODMAG,__V_PGIACE,__V_DATVER,__V_OPZSTA,__V_CODART

__V_DTVRIB = RIBALTA2(__V_DATVER)

x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
x_tmat = "mag_codmat = mag_codmat"
x_colo = "mag_codcol = mag_codcol"
x_spes = "mag_spesso = mag_spesso"
x_alte = "mag_altezz = mag_altezz"
x_lung = "mag_lunghe = mag_lunghe"
x_arti = IIF(EMPTY(ALLTRIM(__V_CODART)) .OR. __V_CODART = SPACE(16),"mag_anaart = mag_anaart","mag_anaart = '" + ALLTRIM(__V_CODART) + "'")
x_nrli = "mag_nrlint = mag_nrlint"
x_maga = "mag_codmag = '" + ALLTRIM(__V_CODMAG) + "'"
x_forn = "mag_fornit = mag_fornit"
x_nide = "mag_numide = mag_numide"
x_anno = "mag_anno = mag_anno"
x_data = "mag_datagg <> SPACE(10)"
x_giac = "mag_giacen > 0"

x_cond = x_soci + " and " + x_tmat + " and " + x_colo + " and " + x_spes + " and " + x_alte
x_cond = x_cond + " and " + x_lung + " and " + x_arti + " and " + x_nrli + " and " + x_maga
x_cond = x_cond + " and " + x_forn + " and " + x_nide + " and " + x_anno + " and " + x_data + " and " + x_giac

cSql   = "select * from U_MAG_GG where " + x_cond + " order by mag_anaart,mag_nrlint,mag_codmat,mag_datagg"
IF !ExecCommand(cSql,"U_MAG_GG")
   return(.f.)
ENDIF

*****RIEMPIMENTO CURSORE __V_NOMECUR

SELECT &__V_NOMECUR
ZAP

SELECT U_MAG_GG
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   * -->> Selezione di soli spalmati
   _V_NRLINT = SUBSTR(ALLTRIM(STR(MAG_NRLINT,12,0)),1,1)
   IF _V_NRLINT = '4'
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SCATTER MEMVAR MEMO
   SELECT U_MAG_GG

   * -->> Calcolo giorni di giacenza
   * ----------------------------------------------
   _V_DATA1 = ""
   _V_DATA2 = ""
   _V_POSITIVO = .F.

   IF __V_DTVRIB >= M.MAG_DATAGG
      _V_DATA1 = M.MAG_DATAGG
      _V_DATA2 = __V_DTVRIB
      _V_POSITIVO = .T.
   ELSE
      _V_DATA1 = __V_DTVRIB
      _V_DATA2 = M.MAG_DATAGG
      _V_POSITIVO = .F.
   ENDIF

   _V_DATA1DATE = CTOD(RIBALTA2(_V_DATA1))
   _V_DATA2DATE = CTOD(RIBALTA2(_V_DATA2))

   _X_CONTA = (_V_DATA2DATE - _V_DATA1DATE) + 1

   IF _V_POSITIVO = .F.  &&METTO IN NEGATIVO SE DATA VERIFICA PRECEDE DATA GIAGENZA
      _X_CONTA = _X_CONTA - (2 * (_X_CONTA))
   ENDIF

   SELECT &__V_NOMECUR
   APPEND BLANK
   GATHER MEMVAR MEMO

   REPLACE MAG_GGGIAC WITH _X_CONTA
   REPLACE MAG_DATAGG WITH RIBALTA2(M.MAG_DATAGG)
   REPLACE MAG_GGRITA WITH (MAG_GGGIAC - __V_PGIACE)

   SELECT U_MAG_GG
   SKIP +1

ENDDO
* -->> Elimino giacenze con ritardo negativo (Opzione Solo ritardi)
* -----------------------------------------------------------------
IF __V_OPZSTA = 1

   SELECT &__V_NOMECUR
   GO TOP

   DO WHILE .T.

      IF EOF()
         EXIT
      ENDIF

      IF MAG_GGRITA > 0
      ELSE
         DELETE
      ENDIF

      SELECT &__V_NOMECUR
      SKIP +1

   ENDDO

ENDIF

RETURN


***************************************************************************
PROCEDURE GESTIONE_RIEPILOGO		&& GESTIONE RIEPILOGHI SU U_VEN_CL
***************************************************************************

PARA _TIPOINT,_TIPOARC,_CAUSALE,_AGGANCIO

XX_SELECT = SELECT()

*=> Verifica se deve gestire i riepiloghi di vendita per anno/mese/cliente/articolo
x_codi = "codice = 'RDV" + PUB_CODSOC + "'"
x_cond = x_codi
cSql   = "select * from PARA where " + x_cond
IF !ExecCommand(cSql,'PARA')
   return(.f.)
ENDIF
SELECT PARA
GO TOP
IF EOF()
   SELECT(XX_SELECT)
   RETURN
ENDIF

IF SUBSTR(LIBERA,1,2) = 'SI'
ELSE
   SELECT(XX_SELECT)
   RETURN
ENDIF

*=> Definizione del nome della tabella da leggere
IF _TIPOARC = 'ORD'
   XX_TABLE_TT = 'U_ORD_TT'
   XX_TABLE_DD = 'U_ORD_DD'
ENDIF
IF _TIPOARC = 'BOL'
   XX_TABLE_TT = 'U_BOL_TT'
   XX_TABLE_DD = 'U_BOL_DD'
ENDIF
IF _TIPOARC = 'FAT'
   XX_TABLE_TT = 'U_FAT_TT'
   XX_TABLE_DD = 'U_FAT_DD'
ENDIF
IF _TIPOARC = 'ORF'
   XX_TABLE_TT = 'U_ORF_TT'
   XX_TABLE_DD = 'U_ORF_DD'
ENDIF

*=> Se trattasi di inserimento, la tabella č il cursore (con la C davanti)
IF _TIPOINT = 'INS'
   XX_TABLE_TT = 'C'+XX_TABLE_TT
   XX_TABLE_DD = 'C'+XX_TABLE_DD
ENDIF

*=> Acquisizione del segno della causale
x_codi = "codice = 'TOP" + ALLTRIM(_CAUSALE) + "'"
x_cond = x_codi
cSql   = "select * from PARA where " + x_cond
IF !ExecCommand(cSql,'PARA')
   return(.f.)
ENDIF
SELECT PARA
GO TOP
IF EOF()
   XX_SEGNO = '+'
ELSE
   IF SUBSTR(LIBERA,1,1) = 'S' .OR. SUBSTR(LIBERA,1,1) = 'D'   && (NATURA C=CARICO - S=SCARICO - D=DARE - A=AVERE)
      XX_SEGNO = '+'
   ELSE
      XX_SEGNO = '-'
   ENDIF
ENDIF

*=> Gestione di variazione/annullo di un articolo giŕ inserito nel gestionale
IF _TIPOINT = 'ANN'				
   *=> Loop su tutte le righe del documento per ripristinare i valori (qta e valore)
   x_agga = "daggancio = '" + ALLTRIM(_AGGANCIO) + "'"
   x_cond = x_agga
   cSql   = "select * from " + XX_TABLE_DD + " where " + x_cond
   IF !ExecCommand(cSql,XX_TABLE_DD)
      return(.f.)
   ENDIF
   SELECT &XX_TABLE_DD
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF ORD_DESART = "*** COMMENTO ***"
         SKIP +1
         LOOP
      ENDIF
      IF SUBSTR(ORS_DATORD,3,1) = '/'
         XX_ANNO = VAL(SUBSTR(ORS_DATORD,7,4))
         XX_MESE = VAL(SUBSTR(ORS_DATORD,4,2))
      ELSE
         XX_ANNO = VAL(SUBSTR(ORS_DATORD,1,4))
         XX_MESE = VAL(SUBSTR(ORS_DATORD,6,2))
      ENDIF
      XX_ARTI = ORD_CODART
      XX_DESC = ORD_DESART
      XX_CLIE = ORS_CODCLI
      XX_RAGS = ORS_RAGSOC
      XX_QUAN = ORD_QTAORD
      XX_VALO = ORD_VALORE
      XX_TIPO = " "					&& DA DEFINIRE NUOVO CAMPO SU TABELLA PER IL CELLOPHANE
      x_soci = "ven_codsoc = '" + PUB_CODSOC + "'"
      x_anno = "ven_anno = " + ALLTRIM(STR(XX_ANNO,4,0))
      x_mese = "ven_mese = " + ALLTRIM(STR(XX_MESE,2,0))
      x_clie = "ven_codcli = '" + ALLTRIM(XX_CLIE) + "'"
      x_arti = "ven_codart = '" + ALLTRIM(XX_ARTI) + "'"
      x_tipo = "ven_tipo   = '" + ALLTRIM(XX_TIPO) + "'"
      x_tdoc = "ven_tipdoc = '" + ALLTRIM(_TIPOARC) + "'"
      x_cond = x_soci + " and " + x_anno + " and " + x_mese + " and " + x_clie + " and " + x_arti + " and " + ;
               x_tipo + " and " + x_tdoc
      cSql   = "select * from u_ven_cl where " + x_cond
      IF !ExecRW(cSql,'U_VEN_CL',"R")
         return(.f.)
      ENDIF
      SELECT U_VEN_CL
      GO TOP
      IF EOF()
         APPEND BLANK
         REPLACE VEN_CODSOC WITH PUB_CODSOC
         REPLACE VEN_ANNO   WITH XX_ANNO
         REPLACE VEN_MESE   WITH XX_MESE
         REPLACE VEN_CODART WITH XX_ARTI
         REPLACE VEN_DESART WITH XX_DESC
         REPLACE VEN_CODCLI WITH XX_CLIE
         REPLACE VEN_DESCLI WITH XX_RAGS
         REPLACE VEN_TIPO   WITH XX_TIPO
         REPLACE VEN_TIPDOC WITH _TIPOARC
         IF XX_SEGNO = '+'
            REPLACE VEN_QTAVEN WITH XX_QUAN * -1
            REPLACE VEN_VALVEN WITH XX_VALO * -1
         ELSE
            REPLACE VEN_QTAVEN WITH XX_QUAN
            REPLACE VEN_VALVEN WITH XX_VALO
         ENDIF
      ELSE
         IF XX_SEGNO = '+'
            REPLACE VEN_QTAVEN WITH VEN_QTAVEN - XX_QUAN
            REPLACE VEN_VALVEN WITH VEN_VALVEN - XX_VALO
         ELSE
            REPLACE VEN_QTAVEN WITH VEN_QTAVEN + XX_QUAN
            REPLACE VEN_VALVEN WITH VEN_VALVEN + XX_VALO
         ENDIF
      ENDIF
      IF !ExecRW(cSql,'U_VEN_CL',"W")
         return(.f.)
      ENDIF
      SELECT &XX_TABLE_DD
      SKIP +1
   ENDDO

ENDIF

*=> Gestione di inserimento di un articolo non presente nel gestionale
IF _TIPOINT = 'INS'					
   *=> Aggiornamento dei valori sulla tabella dei riepiloghi delle vendite per cliente/articolo
   SELECT &XX_TABLE_DD
   GO TOP
   DO WHILE .T.
      IF EOF()
