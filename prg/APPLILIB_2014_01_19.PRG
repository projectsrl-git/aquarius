************************************
FUNCTION TROVA_NR_PEZZI_DA_QTA_IN_UM
************************************
PARAMETERS _par_anaart,_par_quantita,_par_um,_par_spesso,_par_altezz,_par_lunghe

IF PCOUNT() >= 6
ELSE
	RETURN 0
ENDIF

LOCAL _ACT_SELECT
_ACT_SELECT = STR(SELECT())

_par_um = UPPER(ALLTRIM(_par_um))

_QTANR = 0

_X_TIPO = CERCATIPO(_par_anaart)

DO CASE
	CASE _X_TIPO = '6'  && PANNELLI TRUCIOLARI
		DO CASE
			CASE _par_um = "MQ"
				_QTANR = ROUND((_par_quantita * 1000000) / (_par_altezz * _par_lunghe),0)
			CASE _par_um = "MC"
				_QTANR = ROUND((_par_quantita * 1000000000) / (_par_altezz * _par_lunghe * _par_spesso),0)
			OTHERWISE
				_QTANR = 0
		ENDCASE
		
	CASE _X_TIPO = '1'  && BOBINE
		DO CASE
			CASE _par_um = "MQ"
				_QTANR = ROUND((_par_quantita * 1000) / (_par_altezz * _par_lunghe),0)
			CASE _par_um = "ML"
				_QTANR = ROUND(_par_quantita / _par_lunghe,0)
			OTHERWISE
				_QTANR = 0
		ENDCASE
	
	**=> ERASMO - INIZIO 11/07/2013
	CASE _X_TIPO = '9'  && DADI PRESSATI
		DO CASE
			CASE _par_um = "MQ"
				_QTANR = ROUND((_par_quantita * 1000000) / (_par_altezz * _par_lunghe),0)
			CASE _par_um = "MC"
				_QTANR = ROUND((_par_quantita * 1000000000) / (_par_altezz * _par_lunghe * _par_spesso),0)
			OTHERWISE
				_QTANR = 0
		ENDCASE
	**=> ERASMO - FINE 11/07/2013
ENDCASE

SELECT &_ACT_SELECT

RETURN(_QTANR)


********************************
PROCEDURE GESTIONE_MAGGIORAZIONI
********************************
LPARAMETERS _par_CurName

IF PCOUNT() > 0
ELSE
	RETURN
ENDIF

SELECT &_par_CurName
DELETE FOR ORD_MAGGIORAZ = .T.
GO TOP
IF EOF()
	RETURN
ENDIF

CREATE CURSOR CU_MAGGIORAZIONI (CODART C(16), DESART C(200), UM C(3), QTA N(17,4), PREZZO N(17,6), CODIVA C(3))
INDEX ON ALLTRIM(CODART)+ALLTRIM(UM)+ALLTRIM(STR(PREZZO,17,6))+ALLTRIM(CODIVA) TAG I_RAGGRU

SELECT &_par_CurName
GO TOP
DO WHILE !EOF()
	IF DELETED()
		SKIP +1
		LOOP
	ENDIF
	
	IF ALLTRIM(ORD_FLGMOD) == 'A'
		SKIP +1
		LOOP
	ENDIF
	
	IF ALLTRIM(ORD_DESART) == '*** COMMENTO ***'
		SKIP +1
		LOOP
	ENDIF
	
	*** MAGGIORAZIONE FINITURA
	SELECT &_par_CurName
	IF ORD_PRZFIN > 0
		_CODART = "FINITURA"
		_DESART = ""
		_UM = ORD_UMFIN
		_QTA = 0
		_PREZZO = ORD_PRZFIN
		_CODIVA = ORD_IVA
		SELECT &_par_CurName
		_finitura = ""
		x_soci = "u_art_pr.art_codsoc = '" + PUB_CODSOC + "'"
		x_codi = "u_art_pr.art_codpri = '" + ALLTRIM(ORD_CODART) + "'"
		x_cond = x_soci + " and " + x_codi
		Csql   = "select u_art_pr.art_codpri, coalesce(u_art_an.art_fini,'') as art_fini, coalesce(para.descri,'') as art_desfini from u_art_pr left outer join u_art_an  " + ;
			"on u_art_pr.art_codsoc = u_art_an.art_codsoc and u_art_pr.art_codpri = u_art_an.art_codpri left outer join para " + ;
			"on para.codice = 'FIN'+u_art_an.art_fini where " + x_cond
		IF !ExecCommand(cSql,"CX_ART_PN")
		   return(.f.)
		ENDIF
		SELECT CX_ART_PN
		GO TOP
		IF !EOF()
			_CODART = _CODART + " " + ALLTRIM(art_fini)
			_DESART = ALLTRIM(art_desfini)
		ENDIF
		
		SELECT &_par_CurName
		_cNomeCampoQta = "ORD_QTA" + ALLTRIM(_UM)
		IF TYPE(_cNomeCampoQta) == 'N'
		ELSE
			_cNomeCampoQta = "ORD_QTAORD"
		ENDIF
		_QTA = &_cNomeCampoQta
		
		_SEEK = ALLTRIM(_CODART)+ALLTRIM(_UM)+ALLTRIM(STR(_PREZZO,17,6))+ALLTRIM(_CODIVA)
		
		SELECT CU_MAGGIORAZIONI
		SET ORDER TO I_RAGGRU
		GO TOP
		SEEK _SEEK
		IF FOUND()
			REPLACE QTA WITH QTA + _QTA
		ELSE
			APPEND BLANK
			REPLACE CODART WITH _CODART
			REPLACE DESART WITH _DESART
			REPLACE UM WITH _UM
			REPLACE QTA WITH _QTA
			REPLACE PREZZO WITH _PREZZO
			REPLACE CODIVA WITH _CODIVA
		ENDIF	
	ENDIF
	
	*** MAGGIORAZIONE BARRIERA
	SELECT &_par_CurName
	IF ORD_PRZBAR > 0
		_CODART = "BARRIERA"
		_DESART = ""
		_UM = ORD_UMBAR
		_QTA = 0
		_PREZZO = ORD_PRZBAR
		_CODIVA = ORD_IVA
		
		SELECT &_par_CurName
		_cNomeCampoQta = "ORD_QTA" + ALLTRIM(_UM)
		IF TYPE(_cNomeCampoQta) == 'N'
		ELSE
			_cNomeCampoQta = "ORD_QTAORD"
		ENDIF
		_QTA = &_cNomeCampoQta
		
		_SEEK = ALLTRIM(_CODART)+ALLTRIM(_UM)+ALLTRIM(STR(_PREZZO,17,6))+ALLTRIM(_CODIVA)
		
		SELECT CU_MAGGIORAZIONI
		SET ORDER TO I_RAGGRU
		GO TOP
		SEEK _SEEK
		IF FOUND()
			REPLACE QTA WITH QTA + _QTA
		ELSE
			APPEND BLANK
			REPLACE CODART WITH _CODART
			REPLACE DESART WITH _DESART
			REPLACE UM WITH _UM
			REPLACE QTA WITH _QTA
			REPLACE PREZZO WITH _PREZZO
			REPLACE CODIVA WITH _CODIVA
		ENDIF	
	ENDIF
	
	*** MAGGIORAZIONE SEZIONATURA
	SELECT &_par_CurName
	IF ORD_PRZSEZ > 0
		_CODART = "SEZIONATURA"
		_DESART = ""
		_UM = ORD_UMSEZ
		_QTA = 0
		_PREZZO = ORD_PRZSEZ
		_CODIVA = ORD_IVA
		
		SELECT &_par_CurName
		_cNomeCampoQta = "ORD_QTA" + ALLTRIM(_UM)
		IF TYPE(_cNomeCampoQta) == 'N'
		ELSE
			_cNomeCampoQta = "ORD_QTAORD"
		ENDIF
		_QTA = &_cNomeCampoQta
		
		_SEEK = ALLTRIM(_CODART)+ALLTRIM(_UM)+ALLTRIM(STR(_PREZZO,17,6))+ALLTRIM(_CODIVA)
		
		SELECT CU_MAGGIORAZIONI
		SET ORDER TO I_RAGGRU
		GO TOP
		SEEK _SEEK
		IF FOUND()
			REPLACE QTA WITH QTA + _QTA
		ELSE
			APPEND BLANK
			REPLACE CODART WITH _CODART
			REPLACE DESART WITH _DESART
			REPLACE UM WITH _UM
			REPLACE QTA WITH _QTA
			REPLACE PREZZO WITH _PREZZO
			REPLACE CODIVA WITH _CODIVA
		ENDIF	
	ENDIF

	SELECT &_par_CurName
	SKIP +1
	LOOP
ENDDO

_ULTIMO_ORD_SEQUEN = 0
SELECT MAX(ORD_SEQUEN) AS ULT_SEQUEN FROM &_par_CurName INTO CURSOR TMP_ULT_SEQUEN
SELECT TMP_ULT_SEQUEN
GO TOP
IF !EOF()
	IF !ISNULL(ULT_SEQUEN)
		_ULTIMO_ORD_SEQUEN = ULT_SEQUEN
	ENDIF
ENDIF

SELECT &_par_CurName
GO TOP
__X_NUMORD = ORS_NUMORD
__X_DATORD = ORS_DATORD
__X_CODCLI = ORS_CODCLI
__X_RAGSOC = ORS_RAGSOC
__X_CODEMI = ORS_CODEMI
__X_RAGEMI = ORS_RAGEMI
__X_TIPORD = ORS_TIPORD
__X_AGGANC = DAGGANCIO

SELECT CU_MAGGIORAZIONI
GO TOP
SCAN
	SCATTER MEMVAR
	SELECT &_par_CurName
	APPEND BLANK
	
	REPLACE ORD_MAGGIORAZ WITH  .T.
	
	REPLACE ORD_CODART WITH M.CODART
	REPLACE ORD_DESART WITH M.DESART
	REPLACE ORD_UM WITH M.UM
	REPLACE ORD_QTAORD WITH M.QTA
	REPLACE ORD_PREZZO WITH M.PREZZO
	REPLACE ORD_IVA WITH M.CODIVA
	
	REPLACE ORD_PRZNET WITH ROUND(ORD_PREZZO,6)

	__X_VALORE = CALCOLA_VALORE_RIGA_DOCUMENTO(ORD_PRZNET,ORD_QTAORD)
	IF !CHECKNUM(__X_VALORE,17,3)
		__X_VALORE = 0
	ENDIF
	REPLACE ORD_VALORE WITH __X_VALORE
	
	REPLACE ORD_SEQUEN WITH _ULTIMO_ORD_SEQUEN + 10
	_ULTIMO_ORD_SEQUEN = ORD_SEQUEN
	PUB_SEQUEN_TESTO   = _ULTIMO_ORD_SEQUEN
	
	REPLACE ORD_FLGMOD WITH 'I'
	
	REPLACE ORS_NUMORD WITH __X_NUMORD
	REPLACE ORS_DATORD WITH __X_DATORD
	REPLACE ORS_CODCLI WITH __X_CODCLI
	REPLACE ORS_RAGSOC WITH __X_RAGSOC
	REPLACE ORS_CODEMI WITH __X_CODEMI
	REPLACE ORS_RAGEMI WITH __X_RAGEMI
	REPLACE ORS_TIPORD WITH __X_TIPORD
	
	REPLACE ORD_CODSYS WITH SYS(2015)
	
	REPLACE DAGGANCIO WITH __X_AGGANC

ENDSCAN

ENDPROC


***********************************************
PROCEDURE RICALCOLA_QTAEV_NUMPZ_BOLLE_DA_ORDINI
***********************************************
PARAMETERS _par_UPDATE

IF PARAMETERS() >= 1
ELSE
	RETURN .F.
ENDIF

SWS=SELECT()

X_TIPO = CERCATIPO(_RIF_CODART)

_act_QTAEV = 0
_act_NUMBOE = 0
*** CERCO LA QUANTITA' EFFETTIVAMENTE EVASA SULLE RIGHE BOLLE LEGATE
x_lsys = "ord_legsys = '" + _RIF_LEGSYS + "'"
x_comm = "ord_desart != '*** COMMENTO ***'"
x_cond = x_lsys + " and " + x_comm
cSql = "select DAGGANCIO,ORD_QTAORD,ORD_NUMBOB from u_bol_dd where " + x_cond
IF !ExecCommand(cSql,"CHK_BOL_DD")
	RETURN .F.
ENDIF
SELECT CHK_BOL_DD
GO TOP
SCAN
	_act_QTAEV = _act_QTAEV + ORD_QTAORD
	_act_NUMBOE = _act_NUMBOE + ORD_NUMBOB
	_RIF_DDTLEG = IIF(EMPTY(_RIF_DDTLEG),"",_RIF_DDTLEG + CHR(13)) + "N°" + ALLTRIM(ORS_NUMORD) + " del " + RIBALTA2(ORS_DATORD)
ENDSCAN

IF _par_UPDATE
	
	X_CONDITION = .F.
	IF X_TIPO = '6'  && PANNELLI TRUCIOLARI
		X_CONDITION = (_act_NUMBOE <> _RIF_NUMBOE)
	ELSE
		X_CONDITION = (_act_QTAEV <> _RIF_QTAEV)
	ENDIF
	
	IF X_CONDITION
		
		x_csys = "ord_legsys = '" + _RIF_LEGSYS + "'"
		x_comm = "ord_desart != '*** COMMENTO ***'"
		x_cond = x_lsys + " and " + x_comm
		cSql = "update u_ord_dd set ORD_QTAEV = " + ALLTRIM(STRTRAN(STR(_act_QTAEV,17,6),',','.')) + ", ORD_NUMBOE = " + ALLTRIM(STR(_act_NUMBOE,17,0)) + ;
			" where " + x_cond
		IF !ExecCommand(cSql,"UPD_ORD_DD")
			RETURN .F.
		ENDIF
		
		cSql = "SELECT * FROM u_ord_dd where " + x_cond
		IF !ExecCommand(cSql,"CHK_ORD_DD")
			RETURN .F.
		ENDIF
		SELECT CHK_ORD_DD
		GO TOP
		IF !EOF()
			
			X_CONDITION = .F.
			IF X_TIPO = '6'  && PANNELLI TRUCIOLARI
				X_CONDITION = (ORD_NUMBOE >= ORD_NUMBOB)
			ELSE
				X_CONDITION = (ORD_QTAEV >= ORD_QTAORD)
			ENDIF
				
			IF X_CONDITION
			
				cSql = "update u_ord_dd set ORD_CHIUSO = 1 where " + x_cond
				IF !ExecCommand(cSql,"UPD_ORD_DD")
					RETURN .F.
				ENDIF
				
			ELSE
			
*!*					cSql = "update u_ord_dd set ORD_CHIUSO = 0 where " + x_cond
*!*					IF !ExecCommand(cSql,"UPD_ORD_DD")
*!*						RETURN .F.
*!*					ENDIF
			
			ENDIF
		ENDIF
	ENDIF

ENDIF

_RIF_NUMBOE = _act_NUMBOE
_RIF_QTAEV = _act_QTAEV

SELECT(SWS)

ENDPROC


