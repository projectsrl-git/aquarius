PUBLIC  _RIC_CODMAG,_RIC_DESMAG,_RIC_CODART,_RIC_DESART,_RIC_CODMAT,_RIC_UMMAGA,_RIC_PESOSP,_RIC_FATTCONV,_RIC_QTAMC
