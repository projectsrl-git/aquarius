************************
FUNCTION DATA_AAAAMMGG
************************
PARA _DATA

IF _DATA = '  /  /    ' .OR. _DATA = SPACE(10) .OR. ;
   _DATA = '    /  /  ' .OR. EMPTY(_DATA)
   RETURN SPACE(10)
ELSE
   IF SUBSTR(_DATA,3,1) = '/'
      RETURN  RIBALTA2(_DATA)
   ENDIF
   RETURN  _DATA
ENDIF


************************
FUNCTION DATA_GGMMAAAA
************************
PARA _DATA

IF _DATA = '  /  /    ' .OR. _DATA = SPACE(10) .OR. ;
   _DATA = '    /  /  ' .OR. EMPTY(_DATA)
   RETURN SPACE(10)
ELSE
   IF SUBSTR(_DATA,3,1) = '/'
	   RETURN  _DATA
   ENDIF
   RETURN  RIBALTA2(_DATA)
ENDIF



***************************************************************************
PROCEDURE GESTIONESCORTEMINIME
***************************************************************************

CREATE CURSOR RIE_FAT_DD (ORD_CODART C(16),   ORD_DESART C(50),  ORD_CODMAT C(3),     ORD_DESMAT C(30),   ;
                          ORD_CODCOL C(3),    ORD_DESCOL C(30),  ORD_SPESSO N(5,0),   ORD_ALTEZZ N(5,0),  ;
                          ORD_LUNGHE N(6,0),  ORD_UM C(02),      ORD_NUMBOB N(6,0),   ORD_QTAORD N(14,2))

SELECT RIE_FAT_DD
INDEX ON ORD_CODART+ORD_CODMAT+ORD_CODCOL+STR(ORD_ALTEZZ,5,0)+STR(ORD_LUNGHE,6,0) TAG I_ARTALT  ADDITIVE                                       					

*=> Riepilogo del cursore per articolo, altezza e lunghezza
SELECT CU_FAT_DD
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   V_TIPO = CERCATIPO(ORD_CODART)
   IF V_TIPO = "1"
   ELSE
      SKIP +1
      LOOP
   ENDIF
   IF ORD_SPESSO > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF
   IF ORD_ALTEZZ > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF
   IF ORD_LUNGHE > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF
   IF ORD_NUMBOB > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF
   IF ORD_QTAORD > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF
   SCATTER MEMVAR MEMO
   V_SEEK = M.ORD_CODART+M.ORD_CODMAT+M.ORD_CODCOL+STR(M.ORD_ALTEZZ,5,0)+STR(M.ORD_LUNGHE,6,0)
   SELECT RIE_FAT_DD
   SET ORDER TO I_ARTALT
   SEEK V_SEEK
   IF FOUND()
   ELSE
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE ORD_NUMBOB WITH 0
      REPLACE ORD_QTAORD WITH 0
   ENDIF
   REPLACE ORD_NUMBOB WITH ORD_NUMBOB + M.ORD_NUMBOB
   REPLACE ORD_QTAORD WITH ORD_QTAORD + M.ORD_QTAMQ
   SELECT CU_FAT_DD
   SKIP +1
ENDDO

