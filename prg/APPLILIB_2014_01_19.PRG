    SELECT CU_DETTAGLI_PROVVIGIONI				&& CREA DETTAGLI PROVVIGIONI

    ** VERIFICA SE LE PROVVIGIONI DI RIGA SONO STATE MODIFICATE ALTRIMENTI CONSIDERA LE * DI TESTATA FATTURA
    IF __PROVVIGIONI_RIGA__  <> 0

   		IF _PERCPRO_TESTATA <> 0
   		
   			IF _PERCPRO_TESTATA <> __PROVVIGIONI_RIGA__
   				
   				ESISTE_RIGA_CON_PROVVIGIONE_MODIFICATA = .T.
   			
   			ENDIF
   		
   		ENDIF

    ENDIF

    __PROVVIGIONI_PERSONALIZZATE = .F.
    _PERCPRO_PERSONALIZZATE 	 = 0

    =CERCA_PROVVIGIONI_PERSONALIZZATE(__ORD_GN,_CODICE_AGENTE,_CODICE_CLIENTE,__GRUPPO_PRODUTTIVO)


    SELECT CU_DETTAGLI_PROVVIGIONI						&& CREA DETTAGLI PROVVIGIONI
