****************************************************************************************************
FUNCTION CERCA_IN_TABELLE
****************************************************************************************************
*** RICERCA NELLE TABELLE RICHIESTE LA DESCRIZIONE DELLA STRINGA DESIDERATA
*** LA RICERCA AVVIENE SIA SUL CODICE ARTICOLO CHE SULLA DESCRIZIONE DELL'ARTICOLO
***
*** PARAMETRI:
***
*** 	- _par_cStringa       = Stringa da ricercare
*** 	- [_par_nSelezione]   = Numero (0/1/2) indicante il tipo di selezione da poter effettuare
*** 	                        (0 = nessuna selezione / 1 = selezione singola / 2 = selezione multipla)
*** 	- _par_cTabSource1    = U_ART_PR
*** 	- _par_cNome_campo1a  = Nome campo in cui ricercare la stringa
*** 	- _par_cNome_campo1b  = Nome campo in cui ricercare la stringa
***
***     >>>>>>>> MOSTRA : ARTICOLO DESCRIZIONE ARTICOLO UNITA DI MISURA ACQUISTO PREZZO DI COSTO
***
***
*** 	- _par_cTabSource2    = U_LIF_TT
*** 	- _par_cNome_campo2a  = Nome campo in cui ricercare la stringa
*** 	- _par_cNome_campo2b  = Nome campo in cui ricercare la stringa
***
*** 	- _par_cTabSource3    = U_MAG_GG
*** 	- _par_cNome_campo3a  = Nome campo in cui ricercare la stringa
*** 	- _par_cNome_campo3b  = Nome campo in cui ricercare la stringa
***
***
***
*** ESEMPIO:
*** 	DO PRG\CERCA_IN_TABELLE WITH _cTestoDaRicercare_,_par_nSelezione_,_par_cTabSource1_,_par_cNome_campo1a_,_par_cNome_campo1b_
***
***
*** VARIABILI DI RITORNO
*** 	1) Cursore "CUR_DOCS" popolante la griglia di visualizzazione dei risultati di ricerca
*** 	2) Variabile di ritorno di tipo stringa _VAR_RIT contenente l'aggancio al primo documento
*** 	   selezionato (solo se _par_nSelezione >= 1)
***
***
****************************************************************************************************
LPARAMETERS _par_cStringa,_par_nSelezione,_par_cTabSource1,_par_cNome_campo1a,_par_cNome_campo1b,_par_cTabSource2,_par_cNome_campo2a,_par_cNome_campo2b,_par_cTabSource3,_par_cNome_campo3a,_par_cNome_campo3b


RELEASE _VAR_RIT
PUBLIC _VAR_RIT
_VAR_RIT = ""

IF PCOUNT() >= 5
ELSE
	MESSAGEBOX("Parametri insufficienti",16,"Attenzione")
	RETURN _VAR_RIT
ENDIF

IF TYPE("_par_cStringa") <> 'C'
	MESSAGEBOX("Parametro stringa da cercare non di tipo STRINGA",16,"Attenzione")
	RETURN _VAR_RIT
ENDIF

_par_cStringa = ALLTRIM(_par_cStringa)


CREATE CURSOR CUR_TABLE (SELEZIONE L, TIPDOC C(03), ;
						CODART C(16), DESART C(100), UM C(3), PREZZO N(17,6), GIACENZA N(17,3))


SELECT CUR_TABLE
INDEX ON TIPDOC + CODART TAG I_CODART DESCENDING ADDITIVE
INDEX ON PREZZO 		 TAG I_PREZZO DESCENDING ADDITIVE

_TotFields_CUR_TABLE = AFIELDS(_Fields_CUR_TABLE)


** 	######################################################## ACCESSO A U_ART_PR ##########################################################
	
_par_cStringa 		= ALLTRIM(_par_cStringa)
_par_cTabSource1  	= ALLTRIM(_par_cTabSource1)
_par_cNome_campo1a  = ALLTRIM(_par_cNome_campo1a)
_par_cNome_campo1b  = ALLTRIM(_par_cNome_campo1b)


x_cart = "art_codpri LIKE '%" + _par_cStringa + "%'"
x_dart = "art_descr LIKE '%" + _par_cStringa + "%'"
x_cond = x_cart + " or " + x_dart


Csql1 = "select CAST(0 AS BIT) AS SELEZIONE,'ART' AS TIPDOC,ART_CODPRI AS CODART , ART_DESCR AS DESART, art_unimis AS UM , art_przcos AS PREZZO , 0 AS GIACENZA from " +_par_cTabSource1 +" where "
Csql2 = x_cond +" order by "+_par_cNome_campo1a

Csql = Csql1 + Csql2

IF !ExecCommand(cSql,"CX_ART_PR")
  return(.f.)
ENDIF
SELECT CX_ART_PR
GO TOP


SCAN
	SELECT CUR_TABLE
	APPEND BLANK
	FOR I=1 TO _TotFields_CUR_TABLE
		SELECT CX_ART_PR
		_NomeCampo = _Fields_CUR_TABLE[I,1]
		_NomeVar = "_X_" + ALLTRIM(_NomeCampo)
		&_NomeVar = IIF(!ISNULL(&_NomeCampo),&_NomeCampo,IIF(TYPE(_NomeCampo)=='N',0,IIF(TYPE(_NomeCampo)=='L',.F.,"")))  && ERASMO - 26/04/2012
		SELECT CUR_TABLE
		REPLACE &_NomeCampo WITH &_NomeVar
	NEXT
ENDSCAN

**=> ERASMO - INIZIO 11/01/2013
SELECT CUR_TABLE
GO TOP
SCAN
	_GIACENZA = 0
	_ww_codsoc = PUB_CODSOC
	_ww_anaart = CODART
	_ww_codmag = ""
	_ww_prenot = .F.  && GIACENZE PRENOTATE E NON
	_ww_codint = ""
	_ww_altezz = 0
	_ww_lunghe = 0
	_ww_fila_x = ""
	_ww_pian_x = ""
	_ww_ubic_x = ""
	_GIACENZA = AQM_RILEVA_GIACENZE_DISPONIBILI(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x)
	SELECT CUR_TABLE
	REPLACE GIACENZA WITH _GIACENZA
ENDSCAN
**=> ERASMO - FINE 11/01/2013

SELECT CUR_TABLE
SET ORDER TO I_PREZZO
GO TOP
PUB_RECORD_SELEZIONATO =.F.
DO FORM FORM\CERCA_IN_TABELLE WITH _par_nSelezione LINKED
IF PUB_RECORD_SELEZIONATO
	
	SELECT CUR_TABLE
    _VAR_RIT = CODART

ELSE

	SELECT CUR_TABLE
    _VAR_RIT = ""
	
ENDIF



RETURN _VAR_RIT

ENDFUNC



*********************************************************************************************************
FUNCTION CHECK_ORDINE_CLIENTE_CHIUSO
*********************************************************************************************************
*** VERIFICA SE LE RIGHE ORDINE SONO TUTTE CHIUSE E AGGIORNA IL FLAG DI CHIUSURA SULLA TABELLA DI TESTATA
***
*** PARAMETRI:
***
*** 	- _par_taggancio 	= Aggancio Identificativo dell'ordine (TAGGANCIO/DAGGANCIO)
***
*** 	- [_par_update] 	= Abilita la funzione a chiudere la tabella di testata dell'ordine
***							  se tutte le righe della tabella di dettaglio sono chiuse
***
*** ESEMPIO:
***		SELECT CU_ORD_TT
***		_lCLOSED = CHECK_ORDINE_CLIENTE_CHIUSO(TAGGANCIO,.T.)
*** 	IF _lCLOSED
***			...
***		ELSE
***			...
***		ENDIF
***
*** VARIABILI DI RITORNO:
*** 	1) Variabile di ritorno di tipo BIT (TRUE/FALSE) che contiene lo stato effettivo dell'ordine
***		   in base ai dettagli
*********************************************************************************************************

LPARAMETERS _par_taggancio,_par_update

IF PCOUNT() > 0
ELSE
	RETURN .F.
ENDIF

IF PCOUNT() > 1
ELSE
	_par_update = .F.
ENDIF

IF EMPTY(_par_taggancio)
	RETURN .F.
ENDIF

_RIT = .F.

_OLD_SELECT = SELECT()

lOPEN = .F.
x_agga = "daggancio = '" + _par_taggancio + "'"
x_comm = "ord_desart <> '*** COMMENTO ***'"
x_cond = x_agga + " and " + x_comm
cSql = "SELECT ORD_CHIUSO FROM U_ORD_DD WHERE " + x_cond
IF !ExecCommand(cSql,"TMP_ORD_DD")
	return(.f.)
ENDIF
SELECT TMP_ORD_DD
GO TOP
DO WHILE .T.
	IF EOF()
		EXIT
	ENDIF
	IF ORD_CHIUSO
	ELSE
		lOPEN = .T.
		EXIT
	ENDIF
	SKIP +1
ENDDO

IF lOPEN
ELSE
	_RIT = .T.
ENDIF

IF !lOPEN AND _par_update
	x_agga = "taggancio = '" + _par_taggancio + "'"
	x_cond = x_agga
	cSql   = "UPDATE U_ORD_TT SET ORD_CHIUSO = 1 WHERE " + x_cond
	IF !ExecCommand(cSql,"UPD_ORD_TT")
		return(.f.)
	ENDIF
ENDIF

SELECT(_OLD_SELECT)

RETURN _RIT

ENDFUNC

