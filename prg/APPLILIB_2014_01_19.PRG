   REPLACE STA_ORELAV WITH V_HHLAV		
   REPLACE STA_DATINI WITH V_DTINI		
   REPLACE STA_DATFIN WITH V_DTFIN		
   REPLACE STA_NOTE   WITH IIF(EMPTY(ALLTRIM(V_NOTE)),V_TAGMIS,ALLTRIM(V_TAGMIS)+CHR(13)+ALLTRIM(V_NOTE)) 	
   REPLACE STA_CDDIBA WITH V_CDIBA
   REPLACE STA_CODMAC WITH V_CDMAC
   REPLACE STA_DESMAC WITH V_DSMAC
   REPLACE STA_SETTDA WITH _V_SPRGDA
   REPLACE STA_SETTAL WITH _V_SPRGAL
   REPLACE STA_DATADA WITH _V_DPRGDA
   REPLACE STA_DATAAL WITH _V_DPRGAL
   REPLACE STA_NUMPRG WITH _V_NUMPRG
   REPLACE STA_DATPRG WITH _V_DATPRG
   REPLACE STA_MISTAG WITH V_MISTAG
   REPLACE STA_CLIELA WITH V_CLIELA
   REPLACE STA_TAGMIS WITH V_TAGMIS
   REPLACE STA_PROGRE WITH V_PROGRE
   REPLACE STA_TEMCCG WITH XXX_TEMCCG
   REPLACE STA_TEMCCR WITH XXX_TEMCCR
   REPLACE STA_SCARTO WITH V_SCARTO
   REPLACE STA_ORAINI WITH XX_ORAINI
   REPLACE STA_ORAFIN WITH XX_ORAFIN
   REPLACE STA_SYSCLI WITH V_SYSCLI
   REPLACE STA_FLGELI WITH SPACE(02)

   REPLACE STA_LEGSYS WITH V_LEGSYS					&& SYS CHE LO LEGA ALL'ARCHIVIO DEI DETTAGLI DELLE ALTEZZE DA TAGLIARE (STA_LEGATAGLIO)

   *=> Tipo record = 1 significa che contiene le bobine di film spalmato

   x_uniq = "mag_unique = '" + M.MAG_UNIQUE + "'"
   x_cond = x_uniq
   Csql   = "select * from u_mag_gg where " + x_cond
   IF !ExecCommand(Csql,"GIACENZE")
      return(.f.)
   ENDIF
   SELECT GIACENZE
   GO TOP
   IF EOF()
   ELSE
      M.MAG_QTAML  = MAG_QTAML  - MAG_GMLIMP
      M.MAG_QTAKG  = MAG_QTAKG  - MAG_GKGIMP
      M.MAG_QTAMQ  = MAG_QTAMQ  - MAG_QTAIMP
      M.MAG_GIACEN = MAG_GIACEN - MAG_QTAIMP
   ENDIF

   SELECT STA_RAPPRODT
   REPLACE STA_TIPREC WITH 1
   REPLACE STA_NUMRIG WITH V_NUMRIG

   REPLACE NUD_CODMAG WITH M.MAG_CODMAG
   REPLACE NUD_CODFOR WITH M.MAG_FORNIT
   REPLACE NUD_DESFOR WITH M.MAG_DESFOR
   REPLACE NUD_CODINT WITH M.MAG_CODART
   REPLACE NUD_NUMLOT WITH M.MAG_NRLINT
   REPLACE NUD_UNITAM WITH 'MQ'
   REPLACE NUD_LUNGHE WITH M.MAG_QTAML
   REPLACE NUD_QTAMQ  WITH M.MAG_QTAMQ
   REPLACE NUD_QTAKG  WITH M.MAG_QTAKG

   SELECT STA_RAPPRODT
   XXX_QTAMQ = NUD_QTAMQ
   XXX_QTAKG = NUD_QTAKG
   XXX_QTAML = NUD_LUNGHE

   SELECT STA_RAPPRODT
   REPLACE ADE_CODICE WITH SPACE(16)
   REPLACE ADE_DESCRI WITH SPACE(50)
   REPLACE ADE_DSDIBA WITH SPACE(50)
   REPLACE ADE_UNITAM WITH SPACE(03)
   REPLACE ADE_QTAGIA WITH 0
   REPLACE ADE_QTANEC WITH 0
   REPLACE ADE_QTADOR WITH 0
   REPLACE ADE_SCORMI WITH 0
   REPLACE ADE_CODIMB WITH SPACE(16)
   REPLACE ADE_DESIMB WITH SPACE(50)
   REPLACE ADE_LOTMIN WITH 0
   REPLACE ADE_LIVELL WITH 0
   REPLACE ADE_QTADIB WITH 0
   REPLACE ADE_CODINT WITH SPACE(16)
   REPLACE ADE_NUMLOT WITH 0
   REPLACE ADE_CODFOR WITH SPACE(10)
   REPLACE ADE_DESFOR WITH SPACE(50)
   REPLACE ADE_CODMAG WITH PUB_CQUMPC
   REPLACE ADE_CODMAG WITH SPACE(06)

   REPLACE MAG_QTAGIA WITH 0
   REPLACE AVA_CODAVA WITH SPACE(03)
   REPLACE AVA_DESAVA WITH SPACE(50)
   REPLACE AVA_DATAVA WITH SPACE(10)
   REPLACE AVA_AMGAVA WITH SPACE(10)
   REPLACE AVA_ORAAVA WITH SPACE(08)
   REPLACE AVA_CONMTL WITH 0

   V_LENSCA = V_LENSCA - XXX_QTAML
   V_NUMRIG = V_NUMRIG + 1

   SELECT T_MAG_GG
   REPLACE MAG_QTAIMP WITH MAG_QTAIMP + XXX_QTAMQ
   REPLACE MAG_GMLIMP WITH MAG_GMLIMP + XXX_QTAML
   REPLACE MAG_GKGIMP WITH MAG_GKGIMP + XXX_QTAKG
   REPLACE MAG_FLGMOD WITH .T.

   SKIP +1

ENDDO

*=> INIZIO - GESTIONE DELLA PROGRAMMAZIONE SOLO NELLE SETTIMANE PREVISTE
IF V_PROGRE = 1
   *=> ACCESSO AL CALENDARIO LAVORATIVO GENERALE PER PRELEVARE LA SETTIMANA DI INIZIO LAVORO
   x_data = "cal_data = '" + V_DTINI + "'"
   Csql   = "select * from u_cal_la where " + x_data
   IF !ExecCommand(Csql,"cux_cal_la")
      return(.f.)
   ENDIF
   SELECT CUX_CAL_LA
   GO TOP
   IF EOF()
      VVV_SETINI = _V_SPRGDA
   ELSE
      VVV_SETINI = CAL_SETT
   ENDIF
   VVV_NUMSET = VAL(SUBSTR(VVV_SETINI,1,2)) + V_SETIMP - 1
   VVV_NUMANN = VAL(SUBSTR(VVV_SETINI,4,4))
   IF VVV_NUMSET > 52
      VVV_NUMSET = VVV_NUMSET - 52
      VVV_NUMANN = VVV_NUMANN + 1
   ENDIF
   VVV_NUMSEX = ALLTRIM(STR(VVV_NUMSET,2,0))
   IF VVV_NUMSET > 9
   ELSE
      VVV_NUMSEX = '0' + VVV_NUMSEX
   ENDIF
   VVV_SETTIM = VVV_NUMSEX + '/' + ALLTRIM(STR(VVV_NUMANN,4,0))
ENDIF
*=> ACCESSO AL CALENDARIO LAVORATIVO GENERALE PER PRELEVARE LA SETTIMANA DI FINE LAVORO
x_data = "cal_data = '" + V_DTFIN + "'"
Csql   = "select * from u_cal_la where " + x_data
IF !ExecCommand(Csql,"cux_cal_la")
   return(.f.)
ENDIF
SELECT CUX_CAL_LA
GO TOP
IF EOF()
   VVV_SETFIN = _V_SPRGAL
ELSE
   VVV_SETFIN = CAL_SETT
ENDIF
*=> DETERMINAZIONE DELLE SETTIMANE ELABORATE
IF VAL(SUBSTR(VVV_SETFIN,4,4)) = VAL(SUBSTR(VVV_SETINI,4,4))
   VVV_SETDIF = VAL(SUBSTR(VVV_SETFIN,1,2)) - VAL(SUBSTR(VVV_SETINI,1,2)) + 1
ELSE
   VVV_SETDIF = 53 - VAL(SUBSTR(VVV_SETINI,1,2)) + VAL(SUBSTR(VVV_SETINI,1,2))
ENDIF
IF VVV_SETDIF < V_SETIMP
ELSE
   VVV_VERIFICA = .T.
ENDIF
*=> FINE - GESTIONE DELLA PROGRAMMAZIONE SOLO NELLE SETTIMANE PREVISTE

RETURN


***************************************************************************
PROCEDURE ribobinatura_reports
***************************************************************************

RELEASE XXX_TEMCCG,XXX_TEMCCR
PUBLIC  XXX_TEMCCG,XXX_TEMCCR
XXX_TEMCCG = 0
XXX_TEMCCR = 0

V_CILRE = 0
V_VELIN = 300
V_TEMCG = 0
V_TEMCR = 0

RELEASE V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
PUBLIC  V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
V_ORELAV     = 0
V_DIFFERENZA = 0
V_ORE        = 0
XX_ORAINI    = SPACE(08)
XX_ORAFIN    = SPACE(08)
V_PRIMAVOLTA = .T.

IF VVV_STOPPA
   XXX_TROV = .F.
   V_CDMAC    = 'RIS'
   V_DSMAC    = 'RIBOBINATURA NON PROGRAMMATA'
   *=> Determinazione delle quantitŕ in MQ da spalmare (tutta la bobina in altezza)
   V_MQPRG = TROVA_MQ_DA_AL(V_ALMAG,V_LUPRG,1)
   SELECT CUR_RIBOBINATURA
   V_MM = 0
   IF V_PROGRE = 1
      V_MM = V_MM + V_TEMCG
      XXX_TEMCCG = V_TEMCG
      V_MM = V_MM + V_TEMCR
      XXX_TEMCCR = V_TEMCR
*!*	   ELSE
*!*	      *=> Determinazione del tempo necessario per il cambio cilindro gommato (se cambia l'altezza)
*!*	      IF V_ALMAG = XXX_ALTE
*!*	      ELSE
*!*	         V_MM = V_MM + V_TEMCG
*!*	         XXX_TEMCCG = V_TEMCG
*!*	      ENDIF
   ENDIF
   *=> Determinazione delle ore necessarie alla lavorazione
   V_MMLAV = (V_LUPRG / V_VELIN) + V_MM
   V_HHLAV = ROUND((V_MMLAV / 60),1)
   *=> Accesso alla tabella degli impegni di produzione per prelevare la data di inizio/fine lavoro
   *=> Da fare
   V_ORELAV     = V_HHLAV
   V_DIFFERENZA = 0
   V_ORE        = 0
   XX_ORAINI    = SPACE(08)
   XX_ORAFIN    = SPACE(08)
   IF EMPTY(ALLTRIM(_V_DATPRG)) .OR. _V_DATPRG = '  /  /    '
      _V_DATPRG = DTOC(DATE())
   ENDIF
   IF EMPTY(ALLTRIM(_V_DPRGDA))
      _V_DPRGDA = PUB_DATINI
   ENDIF
   IF RIBALTA2(_V_DPRGDA) < RIBALTA2(DTOC(DATE()))
      _V_DPRGDA = PUB_DATINI
   ENDIF
   V_DTINI      = PUB_DATINI
   V_DTFIN      = PUB_DATINI
   V_PRIMA      = .T.
ELSE
    *=> Assegnazione della macchina di produzione con una programmazione che prevede la saturazione delle capacitŕ
    *=> delle ribobinatrici all'interno della stessa giornata (impegni su tutte le ribobinatrici nel giorno, poi passa
    *=> ad impegnare il giorno/i successivi
    RELEASE V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
    PUBLIC  V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
    V_CDMAC    = SPACE(03)
    V_DSMAC    = SPACE(50)
    V_DATA     = V_DTINI
    XXX_DATA   = V_DTINI
    XXX_SETT   = SPACE(07)
    XXX_CDMAC  = SPACE(03)
    XXX_DSMAC  = SPACE(50)
    XXX_TROV   = .F.
    XXX_ORELAV = 0
    XXX_ORAINI = SPACE(08)

    SELECT SETTPROD
    SET ORDER TO I_ORDINE
    GO TOP

    DO WHILE .T.

       IF EOF()
          SELECT * FROM SETTPROD WHERE SET_FATTO = .F. INTO CURSOR ANCORAUNO
          SELECT ANCORAUNO
          GO TOP
          IF EOF()
             VVV_STOPPA = .T.
          ENDIF
          EXIT
       ENDIF

       *=> By-passo la macchina+giorno giŕ elaborati o senza ore di lavoro da impegnare
       IF SET_FATTO
          SKIP +1
          LOOP
       ENDIF

       *=> Acquisizione delle capacitŕ della ribobinatrice
       x_clav = "cap_codlav = 'RIB'"
       x_cmac = "cap_codmac = '" + ALLTRIM(SET_CODICE) + "'"
       x_cond = x_clav + " and " + x_cmac
       Csql   = "select * from u_pro_ca where " + x_cond
       IF !ExecCommand(Csql,"cux_pro_ca")
          return(.f.)
       ENDIF
       SELECT CUX_PRO_CA
       GO TOP
       IF EOF()
          H_ALTMAX = 1600
          H_LUNMAX = 1500
       ELSE
          H_ALTMAX = CAP_ALMAFN
          H_LUNMAX = CAP_LUMAIN
       ENDIF
       *=> Verifico che l'altezza della bobina da ribobinare sia compatibile con la ribobinatrice in linea
       IF V_ALMAG > H_ALTMAX
          SELECT SETTPROD
          SKIP +1
          LOOP
       ENDIF
       *=> Verifico che la lunghezza della bobina da ribobinare sia compatibile con la ribobinatrice in linea
       IF V_LUMAG > H_LUNMAX
          SELECT SETTPROD
          SKIP +1
          LOOP
       ENDIF

       *=> INIZIO PROJECT 19/12/2006
       IF V_LUMAG >= CAP_ALTD01 .AND. V_LUMAG <= CAP_ALTA01
          V_VELIN = CAP_VELM01
       ENDIF
       IF V_LUMAG >= CAP_ALTD02 .AND. V_LUMAG <= CAP_ALTA02
          V_VELIN = CAP_VELM02
       ENDIF
       IF V_LUMAG >= CAP_ALTD03 .AND. V_LUMAG <= CAP_ALTA03
          V_VELIN = CAP_VELM03
       ENDIF
       IF V_LUMAG >= CAP_ALTD04 .AND. V_LUMAG <= CAP_ALTA04
          V_VELIN = CAP_VELM04
       ENDIF
       IF V_LUMAG >= CAP_ALTD05 .AND. V_LUMAG <= CAP_ALTA05
          V_VELIN = CAP_VELM05
       ENDIF
       IF V_LUMAG >= CAP_ALTD06 .AND. V_LUMAG <= CAP_ALTA06
          V_VELIN = CAP_VELM06
       ENDIF
       IF V_LUMAG >= CAP_ALTD07 .AND. V_LUMAG <= CAP_ALTA07
          V_VELIN = CAP_VELM07
       ENDIF
       IF V_LUMAG >= CAP_ALTD08 .AND. V_LUMAG <= CAP_ALTA08
          V_VELIN = CAP_VELM08
       ENDIF
       IF V_LUMAG >= CAP_ALTD09 .AND. V_LUMAG <= CAP_ALTA09
          V_VELIN = CAP_VELM09
       ENDIF
       IF V_LUMAG >= CAP_ALTD10 .AND. V_LUMAG <= CAP_ALTA10
          V_VELIN = CAP_VELM10
       ENDIF
       IF V_VELIN = 0
          V_VELIN = 300
       ENDIF
       *=> FINE PROJECT 19/12/2006

       SELECT SETTPROD
       XXX_CDMAC  = SET_CODICE
       XXX_DSMAC  = SET_DESCRI
       XXX_DATA   = RIBALTA2(SET_DATA)
       XXX_SETT   = SET_SETT
       XXX_ORELAV = SET_ORELAV
       XXX_ORAINI = SET_ORAINI

       *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
  	   SELECT CU_PRO_IM
	   SET FILTER TO
	   SET ORDER TO I_IMPEGNI
	   SEEK 'RIB' + XXX_CDMAC + RIBALTA2(XXX_DATA)
       IF FOUND()
       ELSE
          APPEND BLANK
		  REPLACE IMP_CODLAV WITH 'RIB'
		  REPLACE IMP_DESLAV WITH 'RIBOBINATURA'
		  REPLACE IMP_CODMAC WITH XXX_CDMAC
		  REPLACE IMP_DESMAC WITH XXX_DSMAC
		  REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
		  REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
          REPLACE IMP_NRPRG1 WITH _V_NUMPRG
	      REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
	      REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
	      REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
	      REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
	      REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
	      REPLACE IMP_NRPRG2 WITH SPACE(06)
	      REPLACE IMP_DTPRG2 WITH SPACE(10)
	      REPLACE IMP_SDPRG2 WITH SPACE(07)
	      REPLACE IMP_SAPRG2 WITH SPACE(07)
	      REPLACE IMP_DDPRG2 WITH SPACE(10)
	      REPLACE IMP_DAPRG2 WITH SPACE(10)
	      REPLACE IMP_ORELAV WITH XXX_ORELAV
	      REPLACE IMP_OREIMP WITH 0
	      REPLACE IMP_QTAMQ  WITH 0
	      REPLACE IMP_QTAML  WITH 0
	      REPLACE IMP_QTAKG  WITH 0
	      REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
	      REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
	      REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
	      REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
	      REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
	      REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
	      REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
	      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
	      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
	      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
	      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
	      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
	      REPLACE IMP_FLGMOD WITH .F.
	      REPLACE IMP_ORAINI WITH XXX_ORAINI
	      REPLACE IMP_ORAFIN WITH XXX_ORAINI
          SELECT SETTPROD
          LOOP
       ENDIF

       *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
       *=> la macchina+data
       IF IMP_ORELAV > IMP_OREIMP
       ELSE
          SELECT SETTPROD
          REPLACE SET_FATTO WITH .T.
          SKIP +1
          LOOP
       ENDIF

       IF V_PRIMAVOLTA
          V_PRIMAVOLTA = .F.
          *=> Prelievo di dati dalla tabella delle capacitŕ delle macchine per determinare i tempi di lavoro
          x_clav = "cap_codlav = 'RIB'"
          x_cmac = "cap_codmac = '" + XXX_CDMAC + "'"
          x_cond = x_clav + " and " + x_cmac
          cSql   = "select * from u_pro_ca where " + x_cond
          IF !ExecCommand(cSql,"U_PRO_CA")
             return(.f.)
          ENDIF
          SELECT U_PRO_CA
          GO TOP
          IF EOF()
             SELECT SETTPROD
             SKIP +1
             LOOP
          ENDIF
          *=> INIZIO PROJECT 19/12/2006
          IF V_LUMAG >= CAP_ALTD01 .AND. V_LUMAG <= CAP_ALTA01
             V_VELIN = CAP_VELM01
          ENDIF
          IF V_LUMAG >= CAP_ALTD02 .AND. V_LUMAG <= CAP_ALTA02
             V_VELIN = CAP_VELM02
          ENDIF
          IF V_LUMAG >= CAP_ALTD03 .AND. V_LUMAG <= CAP_ALTA03
             V_VELIN = CAP_VELM03
          ENDIF
          IF V_LUMAG >= CAP_ALTD04 .AND. V_LUMAG <= CAP_ALTA04
             V_VELIN = CAP_VELM04
          ENDIF
          IF V_LUMAG >= CAP_ALTD05 .AND. V_LUMAG <= CAP_ALTA05
             V_VELIN = CAP_VELM05
          ENDIF
          IF V_LUMAG >= CAP_ALTD06 .AND. V_LUMAG <= CAP_ALTA06
             V_VELIN = CAP_VELM06
          ENDIF
          IF V_LUMAG >= CAP_ALTD07 .AND. V_LUMAG <= CAP_ALTA07
             V_VELIN = CAP_VELM07
          ENDIF
          IF V_LUMAG >= CAP_ALTD08 .AND. V_LUMAG <= CAP_ALTA08
             V_VELIN = CAP_VELM08
          ENDIF
          IF V_LUMAG >= CAP_ALTD09 .AND. V_LUMAG <= CAP_ALTA09
             V_VELIN = CAP_VELM09
          ENDIF
          IF V_LUMAG >= CAP_ALTD10 .AND. V_LUMAG <= CAP_ALTA10
             V_VELIN = CAP_VELM10
          ENDIF
          IF V_VELIN = 0
             V_VELIN = CAP_VELMAC
          ENDIF
          *V_VELIN = CAP_VELMAC
          *=> FINE PROJECT 19/12/2006
          V_TEMCG = CAP_TEMCCG
          V_TEMCR = CAP_TEMCCR
          *=> Determinazione delle quantitŕ in MQ da spalmare (tutta la bobina in altezza)
          V_MQPRG = TROVA_MQ_DA_AL(V_ALMAG,V_LUPRG,1)
          SELECT CUR_RIBOBINATURA
          V_MM = 0
          IF V_PROGRE = 1
             V_MM = V_MM + V_TEMCG
             XXX_TEMCCG = V_TEMCG
             V_MM = V_MM + V_TEMCR
             XXX_TEMCCR = V_TEMCR
*!*	          ELSE
*!*	             *=> Determinazione del tempo necessario per il cambio cilindro gommato (se cambia l'altezza)
*!*	             IF V_ALMAG = XXX_ALTE
*!*	             ELSE
*!*	                V_MM = V_MM + V_TEMCG
*!*	                XXX_TEMCCG = V_TEMCG
*!*	             ENDIF
          ENDIF
          *=> Determinazione delle ore necessarie alla lavorazione
          V_MMLAV      = (V_LUPRG / V_VELIN) + V_MM
          V_HHLAV      = ROUND((V_MMLAV / 60),1)
          V_ORELAV     = V_HHLAV
          V_DIFFERENZA = 0
          V_ORE        = 0
          XX_ORAINI    = SPACE(08)
          XX_ORAFIN    = SPACE(08)
          IF EMPTY(ALLTRIM(_V_DATPRG)) .OR. _V_DATPRG = '  /  /    '
             _V_DATPRG = DTOC(DATE())
          ENDIF
          IF EMPTY(ALLTRIM(_V_DPRGDA))
             _V_DPRGDA = PUB_DATINI
          ENDIF
          IF RIBALTA2(_V_DPRGDA) < RIBALTA2(DTOC(DATE()))
             _V_DPRGDA = PUB_DATINI
          ENDIF
          V_DTINI      = PUB_DATINI
          V_DTFIN      = PUB_DATINI
          V_PRIMA      = .T.
          V_PRIMAEXIT  = .T.
       ENDIF

  	   SELECT CU_PRO_IM

       *=> Determino il tempo che č possibile impegnare per la giornata in questione
       V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP

       *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
   	   V_TRASF      = ((V_TOLFGG * 100) / 60) / 100

       *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
   	   IF V_DIFFERENZA > V_TRASF
   	   ELSE
     	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
     	     IF V_PRIMAEXIT
     	        V_PRIMAEXIT  = .F.
     	        V_PRIMAVOLTA = .T.
     	     ENDIF
             SELECT SETTPROD
             REPLACE SET_FATTO WITH .T.
             SKIP +1
             LOOP
   	      ENDIF
       ENDIF

       V_PRIMAEXIT = .F.

       *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
       *=> il lavoro
   	   IF V_ORELAV > V_DIFFERENZA
     	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
    	     V_ORELAV = V_ORELAV - V_DIFFERENZA
	         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
          ELSE	
	         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
    	     V_ORELAV = 0
	      ENDIF
	   ELSE
	      REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
	      V_ORELAV = 0
	   ENDIF

       *=> Assegno la data di inizio/fine lavoro in cui sono arrivato
	   IF V_PRIMA
	      V_PRIMA = .F.
	      V_DTINI = XXX_DATA
	   ENDIF
	   V_DTFIN = XXX_DATA

       *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
       XXX_TROV  = .T.

       *=> Memorizzo i dati della programmazione
	   IF IMP_NRPRG1 = _V_NUMPRG
	   ELSE
	      REPLACE IMP_NRPRG2 WITH _V_NUMPRG
	      REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
	      REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
	      REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
	      REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
	      REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
	      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
	      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
	      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
	      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
	      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
	   ENDIF

       *=> Aggiorno il flag di impegno elaborato (per il contraggiornamento in fase di registrazione)
	   REPLACE IMP_FLGMOD WITH .T.

       *=> Determino l'orario di inizio e fine lavoro
	   IF EMPTY(ALLTRIM(XX_ORAINI))
	      XX_ORAINI = IMP_ORAFIN
	   ENDIF
	   REPLACE IMP_ORAFIN WITH CALCOLAORA(IMP_ORAINI,IMP_OREIMP)
	   XX_ORAFIN = IMP_ORAFIN
       IF V_DTINI = V_DTFIN
          IF XX_ORAINI > XX_ORAFIN
             XX_ORAINI = IMP_ORAINI
          ENDIF
       ENDIF

       *=> Gestione del fine lavoro
	   IF V_ORELAV = 0
          IF IMP_ORELAV > IMP_OREIMP
          ELSE
             SELECT SETTPROD
             REPLACE SET_FATTO WITH .T.
          ENDIF
          EXIT
       ENDIF

       *=> Se la giornata č stata totalmente impegnata, ma restano ancora delle ore da impegnare, contraggiorno
       *=> la tabella per by-passare la macchina+data
       IF IMP_ORELAV > IMP_OREIMP
       ELSE
          SELECT SETTPROD
          REPLACE SET_FATTO WITH .T.
          SKIP +1
          LOOP
       ENDIF

       EXIT

    ENDDO

    IF V_ORELAV > 0
       IF VVV_STOPPA
          IF XXX_TROV
	   	      SELECT CU_CAL_LA
			  SET ORDER TO I_DATAMG
			  SET FILTER TO
			  SEEK RIBALTA2(PUB_DATFIN)
	  	      DO WHILE .T.
			     IF EOF()
			        EXIT
			     ENDIF
			     IF V_ORELAV > 0
			     ELSE
			        EXIT
			     ENDIF
			     IF CAL_LAVO
			     ELSE
			        SKIP +1
			        LOOP
			     ENDIF
			     IF CAL_ORELAV > 0
			     ELSE
			        SKIP +1
			        LOOP
			     ENDIF
	             IF CAL_DATAMG = RIBALTA2(PUB_DATFIN)
	                SKIP +1
	                LOOP
	             ENDIF
	             XXX_ORELAV = CAL_ORELAV
	             XXX_ORAINI = CAL_ORAINI
	             XXX_SETT   = CAL_SETT
	             XXX_DATA   = CAL_DATA
	             *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
	  	         SELECT CU_PRO_IM
		         SET FILTER TO
		         SET ORDER TO I_IMPEGNI
		         SEEK 'RIB' + XXX_CDMAC + RIBALTA2(XXX_DATA)
	             IF FOUND()
	             ELSE
	                APPEND BLANK
			        REPLACE IMP_CODLAV WITH 'RIB'
			        REPLACE IMP_DESLAV WITH 'RIBOBINATURA'
			        REPLACE IMP_CODMAC WITH XXX_CDMAC
	   		        REPLACE IMP_DESMAC WITH XXX_DSMAC
			        REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
			        REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
	                REPLACE IMP_NRPRG1 WITH _V_NUMPRG
		            REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
		            REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
		            REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
		            REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
		            REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
		            REPLACE IMP_NRPRG2 WITH SPACE(06)
		            REPLACE IMP_DTPRG2 WITH SPACE(10)
		            REPLACE IMP_SDPRG2 WITH SPACE(07)
		            REPLACE IMP_SAPRG2 WITH SPACE(07)
		            REPLACE IMP_DDPRG2 WITH SPACE(10)
		            REPLACE IMP_DAPRG2 WITH SPACE(10)
		            REPLACE IMP_ORELAV WITH XXX_ORELAV
		            REPLACE IMP_OREIMP WITH 0
		            REPLACE IMP_QTAMQ  WITH 0
		            REPLACE IMP_QTAML  WITH 0
		            REPLACE IMP_QTAKG  WITH 0
		            REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
		            REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
		            REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
		            REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
		            REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
		            REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
		            REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
		            REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
		            REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
		            REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
		            REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
		            REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
		            REPLACE IMP_FLGMOD WITH .F.
		            REPLACE IMP_ORAINI WITH XXX_ORAINI
		            REPLACE IMP_ORAFIN WITH XXX_ORAINI
	     	        SELECT CU_CAL_LA
	                LOOP
	             ENDIF
	             *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
	             *=> la macchina+data
	             IF IMP_ORELAV > IMP_OREIMP
	             ELSE
	     	        SELECT CU_CAL_LA
	                SKIP +1
	                LOOP
	             ENDIF
	             *=> Determino il tempo che č possibile impegnare per la giornata in questione
	             V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP
	             *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
	   	         V_TRASF      = ((V_TOLFGG * 100) / 60) / 100
	             *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
	   	         IF V_DIFFERENZA > V_TRASF
	   	         ELSE
	     	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
	     	           SELECT CU_CAL_LA
	                   SKIP +1
	                   LOOP
	     	        ENDIF
	             ENDIF
	             *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
	             *=> il lavoro
	   	         IF V_ORELAV > V_DIFFERENZA
	     	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
	    	           V_ORELAV = V_ORELAV - V_DIFFERENZA
		               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
	                ELSE	
		               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
	    	           V_ORELAV = 0
		            ENDIF
		         ELSE
		            REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
		            V_ORELAV = 0
		         ENDIF
	             *=> Assegno la data di fine lavoro in cui sono arrivato
	     	     IF V_PRIMA
		            V_PRIMA = .F.
		            V_DTINI = XXX_DATA
		         ENDIF
		         V_DTFIN = XXX_DATA
	             *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
	             XXX_TROV  = .T.
	             *=> Memorizzo i dati della programmazione
		         IF IMP_NRPRG1 = _V_NUMPRG
		         ELSE
		            REPLACE IMP_NRPRG2 WITH _V_NUMPRG
		            REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
		            REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
		            REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
		            REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
		            REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
		            REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
		            REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
		            REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
		            REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
		            REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
		         ENDIF
	             *=> Aggiorno il flag di impegno elaborato (per il contraggiornamento in fase di registrazione)
		         REPLACE IMP_FLGMOD WITH .T.
	             *=> Determino l'orario di inizio e fine lavoro
		         IF EMPTY(ALLTRIM(XX_ORAINI))
		            XX_ORAINI = IMP_ORAFIN
		         ENDIF
		         REPLACE IMP_ORAFIN WITH CALCOLAORA(IMP_ORAINI,IMP_OREIMP)
		         XX_ORAFIN = IMP_ORAFIN
	             IF V_DTINI = V_DTFIN
	                IF XX_ORAINI > XX_ORAFIN
	                   XX_ORAINI = IMP_ORAINI
	                ENDIF
	             ENDIF
	             SELECT CU_CAL_LA
	             *=> Gestione del fine lavoro
		         IF V_ORELAV > 0
		         ELSE
	   	            EXIT
	             ENDIF
	          ENDDO
	      ENDIF
       ENDIF
	ENDIF

    IF XXX_TROV
       V_DATA     = XXX_DATA
       V_CDMAC    = XXX_CDMAC
       V_DSMAC    = XXX_DSMAC
    ELSE
       VVV_STOPPA = .T.
       V_CDMAC    = 'RIS'
       V_DSMAC    = 'RIBOBINATURA NON PROGRAMMATA'
    ENDIF

ENDIF

V_NOTE   = SPACE(100)

*=> Scrittura del record nel cursore da stampare nel programma di ribobinatura per la logistica
SELECT STA_RIBOBINATURA
APPEND BLANK
REPLACE STA_CODART WITH V_CDART
REPLACE STA_DESART WITH V_DSART
REPLACE STA_SPEORD WITH V_MYORD
REPLACE STA_CILRET WITH V_CILRE
