	Csql   = "select * from u_art_pr where " + x_cond
	IF !ExecCommand(cSql,"cx_art_pr")
	   return(.f.)
	ENDIF
	SELECT cx_art_pr
	GO TOP
	IF EOF()
		SELECT(_ACT_SELECT)  && ERASMO - 31/08/2012
		RETURN _RIT
	ELSE
		SCATTER MEMVAR MEMO
		
		x_soci = "art_codsoc = '" + PUB_CODSOC + "'"
		x_codi = "art_codpri = '" + _par_art1sc + "'"
		x_cond = x_soci + " and " + x_codi
		Csql   = "select * from u_art_an where " + x_cond
		IF !ExecCommand(cSql,"cx_art_an")
		   return(.f.)
		ENDIF
		SELECT cx_art_an
		GO TOP
		IF EOF()
			SELECT(_ACT_SELECT)  && ERASMO - 31/08/2012
			RETURN _RIT
		ENDIF
		
		SCATTER MEMVAR MEMO
		*M.ART_SCELTA = '2'
		M.ART_SCELTA = _cNew_Scelta  && ERASMO - 22/06/2012
		*M.ART_CODPRI = _art_2ndscelta
		M.ART_CODPRI = _art_Nscelta  && ERASMO - 22/06/2012
		M.ART_DATINS = RIBALTA2(DTOC(DATE()))
		M.ART_ULDSCA = ""
		M.ART_ULDCAR = ""
		M.ART_DATVAR = RIBALTA2(DTOC(DATE()))
		M.ART_DATCOM = ""
		M.ART_DATCON = ""
		M.ART_DTDUPL = RIBALTA2(DTOC(DATE()))
		
		M.ART_DESCOL=""
		IF !EMPTY(M.ART_CODCOL)
			v_seek	 = 'COL'+ALLTRIM(M.ART_CODCOL)
			v_chiave = "codice"
			IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
			   SELECT CUR_PARA
			   M.ART_DESCOL=SUBSTR(DESCRI,1,30)
			ENDIF
		ENDIF
		
		M.ART_DESTIPOG=""
		IF !EMPTY(M.ART_TIPOG)
			v_seek	 = 'TIG'+ALLTRIM(M.ART_TIPOG)
			v_chiave = "codice"
			IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
			   SELECT CUR_PARA
			   M.ART_DESTIPOG=SUBSTR(DESCRI,1,30)
			ENDIF
		ENDIF
		
		M.ART_DESTIPON=""
		IF !EMPTY(M.ART_TIPON)
			v_seek	 = 'TNO'+ALLTRIM(M.ART_TIPON)
			v_chiave = "codice"
			IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
			   SELECT CUR_PARA
			   M.ART_DESTIPON=SUBSTR(DESCRI,1,30)
			ENDIF
		ENDIF
		
		M.ART_DESCOLRET=""
		IF !EMPTY(M.ART_CODCOLRET)
			v_seek	 = 'COL'+ALLTRIM(M.ART_CODCOLRET)
			v_chiave = "codice"
			IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
			   SELECT CUR_PARA
			   M.ART_DESCOLRET=SUBSTR(DESCRI,1,30)
			ENDIF
		ENDIF
		
		M.ART_DESFINI=""
		IF !EMPTY(M.ART_FINI)
			v_seek	 = 'FIN'+ALLTRIM(M.ART_FINI)
			v_chiave = "codice"
			IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
			   SELECT CUR_PARA
			   M.ART_DESFINI=SUBSTR(DESCRI,1,30)
			ENDIF
		ENDIF
		
		*__ART_SCELTA = ""
		*IF !EMPTY(ALLTRIM(M.ART_SCELTA))
		*	__ART_SCELTA = ALLTRIM(M.ART_SCELTA)+'^'
		*ENDIF
		**=> ERASMO - INIZIO 23/08/2012
		__ART_SCELTA = ""
		IF !EMPTY(ALLTRIM(M.ART_SCELTA))
		    IF ALLTRIM(M.ART_SCELTA) = '4' OR ALLTRIM(M.ART_SCELTA) = '5' OR ALLTRIM(M.ART_SCELTA) = '6'  && BARRIERATO
				DO CASE
					CASE ALLTRIM(M.ART_SCELTA) = '4'	&& BARRIERATO DI PRIMA SCELTA
						__ART_SCELTA = 'BARR. 1'+'^'		
					CASE ALLTRIM(M.ART_SCELTA) = '5'	&& BARRIERATO DI SECONDA SCELTA
						__ART_SCELTA = 'BARR. 2'+'^'		
					CASE ALLTRIM(M.ART_SCELTA) = '6'	&& BARRIERATO DI TERZA SCELTA
						__ART_SCELTA = 'BARR. 3'+'^'		
				ENDCASE
		    ELSE
				__ART_SCELTA = ALLTRIM(M.ART_SCELTA)+'^'
			ENDIF
		ENDIF
		**=> ERASMO - FINE 23/08/2012
				
		M.art_descr = ALLTRIM(m.ART_DESTIPOG) + ALLTRIM(m.ART_DESTIPON) + ' ' +ALLTRIM(m.art_descol) +' '+ ALLTRIM(m.art_desfini) +' '+ALLTRIM(__ART_SCELTA)
		**=> ERASMO - INIZIO 11/12/2012
		*** ELIMINO I DOPPI SPAZI
		DO WHILE SPACE(2) $ M.ART_DESCR
			M.ART_DESCR = STRTRAN(ALLTRIM(M.ART_DESCR),SPACE(2),SPACE(1))
		ENDDO
		**=> ERASMO - FINE 11/12/2012

		M.ART_CODSOC = PUB_CODSOC  && ERASMO - 14/09/2012
		
		IF !ExecCommand("SELECT * FROM U_ART_PR WHERE 1=0","TMP_ART_PR")
		   return(.f.)
		ENDIF
		SELECT TMP_ART_PR
		APPEND BLANK
		DO U_ART_PR
		IF !ExecRW('','U_ART_PR','I','','TMP_ART_PR')
		   return(.f.)
		ENDIF
		
		IF !ExecCommand("SELECT * FROM U_ART_AN WHERE 1=0","TMP_ART_AN")
		   return(.f.)
		ENDIF
		SELECT TMP_ART_AN
		APPEND BLANK
		DO U_ART_AN
		IF !ExecRW('','U_ART_AN','I','','TMP_ART_AN')
		   return(.f.)
		ENDIF
		
		_RIT = M.ART_CODPRI
		
		VERIFICA_E_CREA_DISTINTA_BASE(M.ART_CODPRI,.T.)  && ERASMO - 14/09/2012
		
	ENDIF
ELSE
	*IF ART_SCELTA <> '2'
	*	RETURN _RIT
	*ENDIF
	_RIT = _art_Nscelta  && ERASMO - 22/06/2012
ENDIF

SELECT(_ACT_SELECT)  && ERASMO - 31/08/2012

RETURN _RIT


***************************************************************************
FUNCTION STRINGA_SCONTI_REPORT_DOCUMENTI
***************************************************************************
** CREA UNA STRINGA CONTENENTE GLI SCONTI DELLA RIGA DOCUMENTO
***************************************************************************

_RIT = ""

FOR I = 1 TO 5
	_nome_sconto = "ORD_SC" + ALLTRIM(STR(I,1,0))
	IF &_nome_sconto <> 0
		_str_sconto_iesimo = ""
		IF (&_nome_sconto - INT(&_nome_sconto)) <> 0
			_str_sconto_iesimo = STR(&_nome_sconto,7,2)  && CON DECIMALI
		ELSE
			_str_sconto_iesimo = STR(&_nome_sconto,7,0)  && SENZA DECIMALI
		ENDIF
		_RIT = ALLTRIM(_RIT + SPACE(1) + ALLTRIM(_str_sconto_iesimo))
	ENDIF
NEXT

RETURN _RIT

******************************
FUNCTION CREA_NOTE_CLIENTE            && CREA NOTE STANDARD PER CLIENTE
******************************

PARA _TIPO_DOC,_CLIENTE,_CURSORE,___DAGGANCIO___,___PESO


STXTS=STR(SELECT())


x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
x_codi = "cli_codcli = '" + ALLTRIM(_CLIENTE) + "'"
x_cond = x_soci + " and " + x_codi
Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecCommand(cSql,"cu_cli_an")
   return(.f.)
ENDIF
SELECT cu_cli_an
GO TOP
IF !EOF()
   ___CLI_TXTORD=CLI_TXTORD
   ___CLI_TXTBOL=CLI_TXTBOL
   ___CLI_TXTFAT=CLI_TXTFAT
   ___CLI_TXTFAP=CLI_TXTFAP
ELSE
   ___CLI_TXTORD=""
   ___CLI_TXTBOL=""
   ___CLI_TXTFAT=""
   ___CLI_TXTFAP=""
ENDIF

DO CASE

	CASE _TIPO_DOC = "ORD" AND !EMPTY(___CLI_TXTORD)
	
		=CANCELLA_TESTO_CLIENTE("TESTO_ORD",_CURSORE,___DAGGANCIO___)
		=INSERISCE_TESTO_CLIENTE("TESTO_ORD",_CURSORE,___CLI_TXTORD,___PESO)
	
	CASE _TIPO_DOC = "BOL" AND !EMPTY(___CLI_TXTBOL)
		
		=CANCELLA_TESTO_CLIENTE("TESTO_BOL",_CURSORE,___DAGGANCIO___)
		=INSERISCE_TESTO_CLIENTE("TESTO_BOL",_CURSORE,___CLI_TXTBOL,___PESO)
	

	CASE _TIPO_DOC = "FAT" AND !EMPTY(___CLI_TXTFAT)
		
		=CANCELLA_TESTO_CLIENTE("TESTO_FAT",_CURSORE,___DAGGANCIO___)
		=INSERISCE_TESTO_CLIENTE("TESTO_FAT",_CURSORE,___CLI_TXTFAT,___PESO)

		
	CASE _TIPO_DOC = "FAP" AND !EMPTY(___CLI_TXTFAP)
	
		=CANCELLA_TESTO_CLIENTE("TESTO_FAP",_CURSORE,___DAGGANCIO___)
		=INSERISCE_TESTO_CLIENTE("TESTO_FAP",_CURSORE,___CLI_TXTFAP,___PESO)



ENDCASE


SELECT &STXTS

RETURN

