***************************************************************************
PROCEDURE spalmatura_riassegnatempi
***************************************************************************

RELEASE V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
PUBLIC  V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
V_ORELAV     = 0
V_DIFFERENZA = 0
V_ORE        = 0
XX_ORAINI    = SPACE(08)
XX_ORAFIN    = SPACE(08)
V_PRIMAVOLTA = .T.

*=> Assegnazione della macchina di produzione con una programmazione che prevede la saturazione delle capacitŕ
*=> delle spalmatrici all'interno della stessa giornata (impegni su tutte le spalmatrici nel giorno, poi passa
*=> ad impegnare il giorno/i successivi
RELEASE V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
PUBLIC  V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
V_CDMAC    = SPACE(03)
V_DSMAC    = SPACE(50)
V_DATA     = V_DTINI
XXX_DATA   = V_DTINI
XXX_SETT   = SPACE(07)
XXX_CDMAC  = SPACE(03)
XXX_DSMAC  = SPACE(50)
XXX_TROV   = .F.
XXX_ORELAV = 0
XXX_ORAINI = SPACE(08)

V_ORELAV = M.STA_ORELAV

SELECT SETTPROD
SET ORDER TO I_ORDINE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> By-passo la macchina+giorno giŕ elaborati o senza ore di lavoro da impegnare
   IF SET_FATTO
      SKIP +1
      LOOP
   ENDIF

   IF SET_CODICE = M.STA_CODMAC
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SELECT SETTPROD
   XXX_CDMAC  = SET_CODICE
   XXX_DSMAC  = SET_DESCRI
   XXX_DATA   = RIBALTA2(SET_DATA)
   XXX_SETT   = SET_SETT
   XXX_ORELAV = SET_ORELAV
   XXX_ORAINI = SET_ORAINI

   *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
   SELECT CU_PRO_IM
   SET FILTER TO
   SET ORDER TO I_IMPEGNI
   SEEK 'SPA' + XXX_CDMAC + RIBALTA2(XXX_DATA)
   IF FOUND()
   ELSE
      APPEND BLANK
	  REPLACE IMP_CODLAV WITH 'SPA'
	  REPLACE IMP_DESLAV WITH 'SPALMATURA'
	  REPLACE IMP_CODMAC WITH XXX_CDMAC
	  REPLACE IMP_DESMAC WITH XXX_DSMAC
	  REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
	  REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
      REPLACE IMP_NRPRG1 WITH _V_NUMPRG
      REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
      REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
      REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
      REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
      REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
      REPLACE IMP_NRPRG2 WITH SPACE(06)
      REPLACE IMP_DTPRG2 WITH SPACE(10)
      REPLACE IMP_SDPRG2 WITH SPACE(07)
      REPLACE IMP_SAPRG2 WITH SPACE(07)
      REPLACE IMP_DDPRG2 WITH SPACE(10)
      REPLACE IMP_DAPRG2 WITH SPACE(10)
      REPLACE IMP_ORELAV WITH XXX_ORELAV
      REPLACE IMP_OREIMP WITH 0
      REPLACE IMP_QTAMQ  WITH 0
      REPLACE IMP_QTAML  WITH 0
      REPLACE IMP_QTAKG  WITH 0
      REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
      REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
      REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
      REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
      REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
      REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
      REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
      REPLACE IMP_FLGMOD WITH .F.
      REPLACE IMP_ORAINI WITH XXX_ORAINI
      REPLACE IMP_ORAFIN WITH XXX_ORAINI
      SELECT SETTPROD
      LOOP
   ENDIF

   *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
   *=> la macchina+data
   IF IMP_ORELAV > IMP_OREIMP
   ELSE
      SELECT SETTPROD
      REPLACE SET_FATTO WITH .T.
      SKIP +1
      LOOP
   ENDIF

   IF V_PRIMAVOLTA
      V_PRIMAVOLTA = .F.
      *=> Determinazione delle ore necessarie alla lavorazione
      V_DIFFERENZA = 0
      V_ORE        = 0
      XX_ORAINI    = SPACE(08)
      XX_ORAFIN    = SPACE(08)
      IF EMPTY(ALLTRIM(_V_DATPRG)) .OR. _V_DATPRG = '  /  /    '
         _V_DATPRG = DTOC(DATE())
      ENDIF
      IF EMPTY(ALLTRIM(_V_DPRGDA))
         _V_DPRGDA = PUB_DATINI
      ENDIF
      IF RIBALTA2(_V_DPRGDA) < RIBALTA2(DTOC(DATE()))
         _V_DPRGDA = PUB_DATINI
      ENDIF
      V_DTINI      = PUB_DATINI
      V_DTFIN      = PUB_DATINI
      V_PRIMA      = .T.
      V_PRIMAEXIT  = .T.
   ENDIF

   SELECT CU_PRO_IM

   *=> Determino il tempo che č possibile impegnare per la giornata in questione
   V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP

   *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
   V_TRASF      = ((V_TOLFGG * 100) / 60) / 100

   *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
   IF V_DIFFERENZA > V_TRASF
   ELSE
 	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
 	     IF V_PRIMAEXIT
 	        V_PRIMAEXIT  = .F.
 	        V_PRIMAVOLTA = .T.
 	     ENDIF
         SELECT SETTPROD
         REPLACE SET_FATTO WITH .T.
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   V_PRIMAEXIT = .F.

   *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
   *=> il lavoro
   IF V_ORELAV > V_DIFFERENZA
 	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
	     V_ORELAV = V_ORELAV - V_DIFFERENZA
         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
      ELSE	
         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
	     V_ORELAV = 0
      ENDIF
   ELSE
      REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
      V_ORELAV = 0
   ENDIF

   *=> Assegno la data di inizio/fine lavoro in cui sono arrivato
   IF V_PRIMA
      V_PRIMA = .F.
      V_DTINI = XXX_DATA
   ENDIF
   V_DTFIN = XXX_DATA

   *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
   XXX_TROV  = .T.

   *=> Memorizzo i dati della programmazione
   IF IMP_NRPRG1 = _V_NUMPRG
   ELSE
      REPLACE IMP_NRPRG2 WITH _V_NUMPRG
      REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
      REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
      REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
      REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
      REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
   ENDIF

   *=> Aggiorno il flag di impegno elaborato (per il contraggiornamento in fase di registrazione)
   REPLACE IMP_FLGMOD WITH .T.

   *=> Determino l'orario di inizio e fine lavoro
   IF EMPTY(ALLTRIM(XX_ORAINI))
      XX_ORAINI = IMP_ORAFIN
   ENDIF
   REPLACE IMP_ORAFIN WITH CALCOLAORA(IMP_ORAINI,IMP_OREIMP)
   XX_ORAFIN = IMP_ORAFIN
   IF V_DTINI = V_DTFIN
      IF XX_ORAINI > XX_ORAFIN
         XX_ORAINI = IMP_ORAINI
      ENDIF
   ENDIF

   *=> Gestione del fine lavoro
   IF V_ORELAV = 0
      IF IMP_ORELAV > IMP_OREIMP
      ELSE
         SELECT SETTPROD
         REPLACE SET_FATTO WITH .T.
      ENDIF
      EXIT
   ENDIF

   *=> Se la giornata č stata totalmente impegnata, ma restano ancora delle ore da impegnare, contraggiorno
   *=> la tabella per by-passare la macchina+data
   IF IMP_ORELAV > IMP_OREIMP
   ELSE
      SELECT SETTPROD
      REPLACE SET_FATTO WITH .T.
      SKIP +1
      LOOP
   ENDIF

   EXIT

ENDDO

IF V_ORELAV > 0
   IF XXX_TROV
      SELECT CU_CAL_LA
	  SET ORDER TO I_DATAMG
	  SET FILTER TO
	  SEEK RIBALTA2(PUB_DATFIN)
  	  DO WHILE .T.
	     IF EOF()
	        EXIT
	     ENDIF
	     IF V_ORELAV > 0
	     ELSE
	        EXIT
	     ENDIF
	     IF CAL_LAVO
	     ELSE
	        SKIP +1
	        LOOP
	     ENDIF
	     IF CAL_ORELAV > 0
	     ELSE
	        SKIP +1
	        LOOP
	     ENDIF
         IF CAL_DATAMG = RIBALTA2(PUB_DATFIN)
            SKIP +1
            LOOP
         ENDIF
         XXX_ORELAV = CAL_ORELAV
         XXX_ORAINI = CAL_ORAINI
         XXX_SETT   = CAL_SETT
         XXX_DATA   = CAL_DATA
         *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
         SELECT CU_PRO_IM
         SET FILTER TO
         SET ORDER TO I_IMPEGNI
         SEEK 'SPA' + XXX_CDMAC + RIBALTA2(XXX_DATA)
         IF FOUND()
         ELSE
            APPEND BLANK
		    REPLACE IMP_CODLAV WITH 'SPA'
	        REPLACE IMP_DESLAV WITH 'SPALMATURA'
	        REPLACE IMP_CODMAC WITH XXX_CDMAC
   	        REPLACE IMP_DESMAC WITH XXX_DSMAC
	        REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
	        REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
            REPLACE IMP_NRPRG1 WITH _V_NUMPRG
	        REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
	        REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
	        REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
	        REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
            REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
            REPLACE IMP_NRPRG2 WITH SPACE(06)
            REPLACE IMP_DTPRG2 WITH SPACE(10)
            REPLACE IMP_SDPRG2 WITH SPACE(07)
            REPLACE IMP_SAPRG2 WITH SPACE(07)
            REPLACE IMP_DDPRG2 WITH SPACE(10)
            REPLACE IMP_DAPRG2 WITH SPACE(10)
            REPLACE IMP_ORELAV WITH XXX_ORELAV
            REPLACE IMP_OREIMP WITH 0
            REPLACE IMP_QTAMQ  WITH 0
            REPLACE IMP_QTAML  WITH 0
            REPLACE IMP_QTAKG  WITH 0
            REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
            REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
            REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
            REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
            REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
            REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
            REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
            REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
            REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
            REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
            REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
            REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
            REPLACE IMP_FLGMOD WITH .F.
            REPLACE IMP_ORAINI WITH XXX_ORAINI
            REPLACE IMP_ORAFIN WITH XXX_ORAINI
   	        SELECT CU_CAL_LA
            LOOP
         ENDIF
         *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
         *=> la macchina+data
         IF IMP_ORELAV > IMP_OREIMP
         ELSE
   	        SELECT CU_CAL_LA
            SKIP +1
            LOOP
         ENDIF
         *=> Determino il tempo che č possibile impegnare per la giornata in questione
         V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP
         *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
         V_TRASF      = ((V_TOLFGG * 100) / 60) / 100
         *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
         IF V_DIFFERENZA > V_TRASF
         ELSE
  	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
   	           SELECT CU_CAL_LA
               SKIP +1
               LOOP
   	        ENDIF
         ENDIF
         *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
         *=> il lavoro
         IF V_ORELAV > V_DIFFERENZA
   	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
   	           V_ORELAV = V_ORELAV - V_DIFFERENZA
               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
            ELSE	
               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
   	           V_ORELAV = 0
            ENDIF
         ELSE
            REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
            V_ORELAV = 0
         ENDIF
         *=> Assegno la data di fine lavoro in cui sono arrivato
   	     IF V_PRIMA
            V_PRIMA = .F.
            V_DTINI = XXX_DATA
         ENDIF
         V_DTFIN = XXX_DATA
         *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
         XXX_TROV  = .T.
         *=> Memorizzo i dati della programmazione
         IF IMP_NRPRG1 = _V_NUMPRG
         ELSE
            REPLACE IMP_NRPRG2 WITH _V_NUMPRG
            REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
            REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
            REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
            REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
            REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
            REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
            REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
            REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
            REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
            REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
         ENDIF
         *=> Aggiorno il flag di impegno elaborato (per il contraggiornamento in fase di registrazione)
         REPLACE IMP_FLGMOD WITH .T.
         *=> Determino l'orario di inizio e fine lavoro
         IF EMPTY(ALLTRIM(XX_ORAINI))
            XX_ORAINI = IMP_ORAFIN
         ENDIF
         REPLACE IMP_ORAFIN WITH CALCOLAORA(IMP_ORAINI,IMP_OREIMP)
         XX_ORAFIN = IMP_ORAFIN
         IF V_DTINI = V_DTFIN
            IF XX_ORAINI > XX_ORAFIN
               XX_ORAINI = IMP_ORAINI
            ENDIF
         ENDIF
         SELECT CU_CAL_LA
         *=> Gestione del fine lavoro
         IF V_ORELAV > 0
         ELSE
            EXIT
         ENDIF
      ENDDO
   ENDIF
ENDIF

IF XXX_TROV
   V_DATA     = XXX_DATA
   V_CDMAC    = XXX_CDMAC
   V_DSMAC    = XXX_DSMAC
ELSE
   RETURN
ENDIF

*=> Aggiornamento del cursore da stampare nel programma di spalmatura per la logistica
SELECT STA_SPALMATURA
REPLACE STA_DATINI WITH V_DTINI			
REPLACE STA_DATFIN WITH V_DTFIN		
REPLACE STA_SETTDA WITH _V_SPRGDA
REPLACE STA_SETTAL WITH _V_SPRGAL
REPLACE STA_DATADA WITH _V_DPRGDA
REPLACE STA_DATAAL WITH _V_DPRGAL
REPLACE STA_ORAINI WITH XX_ORAINI
REPLACE STA_ORAFIN WITH XX_ORAFIN

*=> Aggiornamento del cursore da stampare nel rapporto di produzione per i reparti

SELECT STA_RAPPROD
SET ORDER TO I_INDICE
SEEK M.STA_NUMPRG + M.STA_DATPRG + STR(M.STA_PROGRE,6,0)
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF STA_NUMPRG = M.STA_NUMPRG .AND. STA_DATPRG = M.STA_DATPRG AND STA_PROGRE = M.STA_PROGRE
   ELSE
      EXIT
   ENDIF
   REPLACE STA_DATINI WITH V_DTINI		
   REPLACE STA_DATFIN WITH V_DTFIN		
   REPLACE STA_CODMAC WITH V_CDMAC
   REPLACE STA_DESMAC WITH V_DSMAC
   REPLACE STA_SETTDA WITH _V_SPRGDA
   REPLACE STA_SETTAL WITH _V_SPRGAL
   REPLACE STA_DATADA WITH _V_DPRGDA
   REPLACE STA_DATAAL WITH _V_DPRGAL
   REPLACE STA_ORAINI WITH XX_ORAINI
   REPLACE STA_ORAFIN WITH XX_ORAFIN
   SKIP +1
ENDDO

RETURN


***************************************************************************
PROCEDURE ribobinatura_riassegnatempi
***************************************************************************

RELEASE V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
PUBLIC  V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
V_ORELAV     = 0
V_DIFFERENZA = 0
V_ORE        = 0
XX_ORAINI    = SPACE(08)
XX_ORAFIN    = SPACE(08)
V_PRIMAVOLTA = .T.

*=> Assegnazione della macchina di produzione con una programmazione che prevede la saturazione delle capacitŕ
*=> delle ribobinatrici all'interno della stessa giornata (impegni su tutte le ribobinatrici nel giorno, poi passa
*=> ad impegnare il giorno/i successivi
RELEASE V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
PUBLIC  V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
V_CDMAC    = SPACE(03)
V_DSMAC    = SPACE(50)
V_DATA     = V_DTINI
XXX_DATA   = V_DTINI
XXX_SETT   = SPACE(07)
XXX_CDMAC  = SPACE(03)
XXX_DSMAC  = SPACE(50)
XXX_TROV   = .F.
XXX_ORELAV = 0
XXX_ORAINI = SPACE(08)

V_ORELAV = M.STA_ORELAV

SELECT SETTPROD
SET ORDER TO I_ORDINE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> By-passo la macchina+giorno giŕ elaborati o senza ore di lavoro da impegnare
   IF SET_FATTO
      SKIP +1
      LOOP
   ENDIF

   IF SET_CODICE = M.STA_CODMAC
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SELECT SETTPROD
   XXX_CDMAC  = SET_CODICE
   XXX_DSMAC  = SET_DESCRI
   XXX_DATA   = RIBALTA2(SET_DATA)
   XXX_SETT   = SET_SETT
   XXX_ORELAV = SET_ORELAV
   XXX_ORAINI = SET_ORAINI

   *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
   SELECT CU_PRO_IM
   SET FILTER TO
   SET ORDER TO I_IMPEGNI
   SEEK 'RIB' + XXX_CDMAC + RIBALTA2(XXX_DATA)
   IF FOUND()
   ELSE
      APPEND BLANK
	  REPLACE IMP_CODLAV WITH 'RIB'
	  REPLACE IMP_DESLAV WITH 'RIBOBINATURA'
	  REPLACE IMP_CODMAC WITH XXX_CDMAC
	  REPLACE IMP_DESMAC WITH XXX_DSMAC
	  REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
	  REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
      REPLACE IMP_NRPRG1 WITH _V_NUMPRG
      REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
      REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
      REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
      REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
      REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
      REPLACE IMP_NRPRG2 WITH SPACE(06)
      REPLACE IMP_DTPRG2 WITH SPACE(10)
      REPLACE IMP_SDPRG2 WITH SPACE(07)
      REPLACE IMP_SAPRG2 WITH SPACE(07)
      REPLACE IMP_DDPRG2 WITH SPACE(10)
      REPLACE IMP_DAPRG2 WITH SPACE(10)
      REPLACE IMP_ORELAV WITH XXX_ORELAV
      REPLACE IMP_OREIMP WITH 0
      REPLACE IMP_QTAMQ  WITH 0
      REPLACE IMP_QTAML  WITH 0
      REPLACE IMP_QTAKG  WITH 0
      REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
      REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
      REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
      REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
      REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
      REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
      REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
      REPLACE IMP_FLGMOD WITH .F.
      REPLACE IMP_ORAINI WITH XXX_ORAINI
      REPLACE IMP_ORAFIN WITH XXX_ORAINI
      SELECT SETTPROD
      LOOP
   ENDIF

   *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
   *=> la macchina+data
   IF IMP_ORELAV > IMP_OREIMP
   ELSE
      SELECT SETTPROD
      REPLACE SET_FATTO WITH .T.
      SKIP +1
      LOOP
   ENDIF

   IF V_PRIMAVOLTA
      V_PRIMAVOLTA = .F.
      *=> Determinazione delle ore necessarie alla lavorazione
      V_DIFFERENZA = 0
      V_ORE        = 0
      XX_ORAINI    = SPACE(08)
      XX_ORAFIN    = SPACE(08)
      IF EMPTY(ALLTRIM(_V_DATPRG)) .OR. _V_DATPRG = '  /  /    '
         _V_DATPRG = DTOC(DATE())
      ENDIF
      IF EMPTY(ALLTRIM(_V_DPRGDA))
         _V_DPRGDA = PUB_DATINI
      ENDIF
      IF RIBALTA2(_V_DPRGDA) < RIBALTA2(DTOC(DATE()))
         _V_DPRGDA = PUB_DATINI
      ENDIF
      V_DTINI      = PUB_DATINI
      V_DTFIN      = PUB_DATINI
      V_PRIMA      = .T.
      V_PRIMAEXIT  = .T.
   ENDIF

   SELECT CU_PRO_IM

   *=> Determino il tempo che č possibile impegnare per la giornata in questione
   V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP

   *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
   V_TRASF      = ((V_TOLFGG * 100) / 60) / 100

   *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
   IF V_DIFFERENZA > V_TRASF
   ELSE
 	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
 	     IF V_PRIMAEXIT
 	        V_PRIMAEXIT  = .F.
 	        V_PRIMAVOLTA = .T.
 	     ENDIF
         SELECT SETTPROD
         REPLACE SET_FATTO WITH .T.
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   V_PRIMAEXIT = .F.

   *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
   *=> il lavoro
   IF V_ORELAV > V_DIFFERENZA
 	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
	     V_ORELAV = V_ORELAV - V_DIFFERENZA
         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
      ELSE	
         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
	     V_ORELAV = 0
      ENDIF
   ELSE
      REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
      V_ORELAV = 0
   ENDIF

   *=> Assegno la data di inizio/fine lavoro in cui sono arrivato
   IF V_PRIMA
      V_PRIMA = .F.
      V_DTINI = XXX_DATA
   ENDIF
   V_DTFIN = XXX_DATA

   *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
   XXX_TROV  = .T.

   *=> Memorizzo i dati della programmazione
   IF IMP_NRPRG1 = _V_NUMPRG
   ELSE
      REPLACE IMP_NRPRG2 WITH _V_NUMPRG
      REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
      REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
      REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
      REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
      REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
   ENDIF

   *=> Aggiorno il flag di impegno elaborato (per il contraggiornamento in fase di registrazione)
   REPLACE IMP_FLGMOD WITH .T.

   *=> Determino l'orario di inizio e fine lavoro
   IF EMPTY(ALLTRIM(XX_ORAINI))
      XX_ORAINI = IMP_ORAFIN
   ENDIF
   REPLACE IMP_ORAFIN WITH CALCOLAORA(IMP_ORAINI,IMP_OREIMP)
   XX_ORAFIN = IMP_ORAFIN
   IF V_DTINI = V_DTFIN
      IF XX_ORAINI > XX_ORAFIN
         XX_ORAINI = IMP_ORAINI
      ENDIF
   ENDIF

   *=> Gestione del fine lavoro
   IF V_ORELAV = 0
      IF IMP_ORELAV > IMP_OREIMP
      ELSE
         SELECT SETTPROD
         REPLACE SET_FATTO WITH .T.
      ENDIF
      EXIT
   ENDIF

   *=> Se la giornata č stata totalmente impegnata, ma restano ancora delle ore da impegnare, contraggiorno
   *=> la tabella per by-passare la macchina+data
   IF IMP_ORELAV > IMP_OREIMP
   ELSE
      SELECT SETTPROD
      REPLACE SET_FATTO WITH .T.
      SKIP +1
      LOOP
   ENDIF

   EXIT

ENDDO

IF V_ORELAV > 0
   IF XXX_TROV
      SELECT CU_CAL_LA
	  SET ORDER TO I_DATAMG
	  SET FILTER TO
	  SEEK RIBALTA2(PUB_DATFIN)
  	  DO WHILE .T.
	     IF EOF()
	        EXIT
	     ENDIF
	     IF V_ORELAV > 0
	     ELSE
	        EXIT
	     ENDIF
	     IF CAL_LAVO
	     ELSE
	        SKIP +1
	        LOOP
	     ENDIF
	     IF CAL_ORELAV > 0
	     ELSE
	        SKIP +1
	        LOOP
	     ENDIF
         IF CAL_DATAMG = RIBALTA2(PUB_DATFIN)
            SKIP +1
            LOOP
         ENDIF
         XXX_ORELAV = CAL_ORELAV
         XXX_ORAINI = CAL_ORAINI
         XXX_SETT   = CAL_SETT
         XXX_DATA   = CAL_DATA
         *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
         SELECT CU_PRO_IM
         SET FILTER TO
         SET ORDER TO I_IMPEGNI
         SEEK 'RIB' + XXX_CDMAC + RIBALTA2(XXX_DATA)
         IF FOUND()
         ELSE
            APPEND BLANK
		    REPLACE IMP_CODLAV WITH 'RIB'
	        REPLACE IMP_DESLAV WITH 'RIBOBINATURA'
	        REPLACE IMP_CODMAC WITH XXX_CDMAC
   	        REPLACE IMP_DESMAC WITH XXX_DSMAC
	        REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
	        REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
            REPLACE IMP_NRPRG1 WITH _V_NUMPRG
	        REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
	        REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
	        REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
	        REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
            REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
            REPLACE IMP_NRPRG2 WITH SPACE(06)
            REPLACE IMP_DTPRG2 WITH SPACE(10)
            REPLACE IMP_SDPRG2 WITH SPACE(07)
            REPLACE IMP_SAPRG2 WITH SPACE(07)
            REPLACE IMP_DDPRG2 WITH SPACE(10)
            REPLACE IMP_DAPRG2 WITH SPACE(10)
            REPLACE IMP_ORELAV WITH XXX_ORELAV
            REPLACE IMP_OREIMP WITH 0
            REPLACE IMP_QTAMQ  WITH 0
            REPLACE IMP_QTAML  WITH 0
            REPLACE IMP_QTAKG  WITH 0
            REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
            REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
            REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
            REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
            REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
            REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
            REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
            REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
            REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
            REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
            REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
            REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
            REPLACE IMP_FLGMOD WITH .F.
            REPLACE IMP_ORAINI WITH XXX_ORAINI
            REPLACE IMP_ORAFIN WITH XXX_ORAINI
   	        SELECT CU_CAL_LA
            LOOP
         ENDIF
         *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
         *=> la macchina+data
         IF IMP_ORELAV > IMP_OREIMP
         ELSE
   	        SELECT CU_CAL_LA
            SKIP +1
            LOOP
         ENDIF
         *=> Determino il tempo che č possibile impegnare per la giornata in questione
         V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP
         *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
         V_TRASF      = ((V_TOLFGG * 100) / 60) / 100
         *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
         IF V_DIFFERENZA > V_TRASF
         ELSE
  	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
   	           SELECT CU_CAL_LA
               SKIP +1
               LOOP
   	        ENDIF
         ENDIF
         *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
         *=> il lavoro
         IF V_ORELAV > V_DIFFERENZA
   	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
   	           V_ORELAV = V_ORELAV - V_DIFFERENZA
               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
            ELSE	
               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
   	           V_ORELAV = 0
            ENDIF
         ELSE
            REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
            V_ORELAV = 0
         ENDIF
         *=> Assegno la data di fine lavoro in cui sono arrivato
   	     IF V_PRIMA
            V_PRIMA = .F.
            V_DTINI = XXX_DATA
         ENDIF
         V_DTFIN = XXX_DATA
         *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
         XXX_TROV  = .T.
         *=> Memorizzo i dati della programmazione
         IF IMP_NRPRG1 = _V_NUMPRG
         ELSE
            REPLACE IMP_NRPRG2 WITH _V_NUMPRG
            REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
            REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
            REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
            REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
            REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
            REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
            REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
            REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
            REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
            REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
         ENDIF
         *=> Aggiorno il flag di impegno elaborato (per il contraggiornamento in fase di registrazione)
         REPLACE IMP_FLGMOD WITH .T.
         *=> Determino l'orario di inizio e fine lavoro
         IF EMPTY(ALLTRIM(XX_ORAINI))
            XX_ORAINI = IMP_ORAFIN
         ENDIF
         REPLACE IMP_ORAFIN WITH CALCOLAORA(IMP_ORAINI,IMP_OREIMP)
         XX_ORAFIN = IMP_ORAFIN
         IF V_DTINI = V_DTFIN
            IF XX_ORAINI > XX_ORAFIN
               XX_ORAINI = IMP_ORAINI
            ENDIF
         ENDIF
         SELECT CU_CAL_LA
         *=> Gestione del fine lavoro
         IF V_ORELAV > 0
         ELSE
            EXIT
         ENDIF
      ENDDO
   ENDIF
ENDIF

IF XXX_TROV
   V_DATA     = XXX_DATA
   V_CDMAC    = XXX_CDMAC
   V_DSMAC    = XXX_DSMAC
ELSE
   RETURN
ENDIF

*=> Aggiornamento del cursore da stampare nel programma di RIBOBINATURA per la logistica
SELECT STA_RIBOBINATURA
REPLACE STA_DATINI WITH V_DTINI			
REPLACE STA_DATFIN WITH V_DTFIN		
REPLACE STA_SETTDA WITH _V_SPRGDA
REPLACE STA_SETTAL WITH _V_SPRGAL
REPLACE STA_DATADA WITH _V_DPRGDA
REPLACE STA_DATAAL WITH _V_DPRGAL
REPLACE STA_ORAINI WITH XX_ORAINI
REPLACE STA_ORAFIN WITH XX_ORAFIN

*=> Aggiornamento del cursore da stampare nel rapporto di produzione per i reparti

SELECT STA_RAPPRODR
SET ORDER TO I_INDICE
SEEK M.STA_NUMPRG + M.STA_DATPRG + STR(M.STA_PROGRE,6,0)
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF STA_NUMPRG = M.STA_NUMPRG .AND. STA_DATPRG = M.STA_DATPRG AND STA_PROGRE = M.STA_PROGRE
   ELSE
      EXIT
   ENDIF
   REPLACE STA_DATINI WITH V_DTINI		
   REPLACE STA_DATFIN WITH V_DTFIN		
   REPLACE STA_CODMAC WITH V_CDMAC
   REPLACE STA_DESMAC WITH V_DSMAC
   REPLACE STA_SETTDA WITH _V_SPRGDA
   REPLACE STA_SETTAL WITH _V_SPRGAL
   REPLACE STA_DATADA WITH _V_DPRGDA
   REPLACE STA_DATAAL WITH _V_DPRGAL
   REPLACE STA_ORAINI WITH XX_ORAINI
   REPLACE STA_ORAFIN WITH XX_ORAFIN
   SKIP +1
ENDDO

RETURN



***************************************************************************
PROCEDURE taglio_riassegnatempi
***************************************************************************

RELEASE V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
PUBLIC  V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
V_ORELAV     = 0
V_DIFFERENZA = 0
V_ORE        = 0
XX_ORAINI    = SPACE(08)
XX_ORAFIN    = SPACE(08)
V_PRIMAVOLTA = .T.

*=> Assegnazione della macchina di produzione con una programmazione che prevede la saturazione delle capacitŕ
*=> delle taglierine all'interno della stessa giornata (impegni su tutte le taglierine nel giorno, poi passa
*=> ad impegnare il giorno/i successivi
RELEASE V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
PUBLIC  V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
V_CDMAC    = SPACE(03)
V_DSMAC    = SPACE(50)
V_DATA     = V_DTINI
XXX_DATA   = V_DTINI
XXX_SETT   = SPACE(07)
XXX_CDMAC  = SPACE(03)
XXX_DSMAC  = SPACE(50)
XXX_TROV   = .F.
XXX_ORELAV = 0
XXX_ORAINI = SPACE(08)

V_ORELAV = M.STA_ORELAV

SELECT SETTPROD
SET ORDER TO I_ORDINE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   *=> By-passo la macchina+giorno giŕ elaborati o senza ore di lavoro da impegnare
   IF SET_FATTO
      SKIP +1
      LOOP
   ENDIF

   IF SET_CODICE = M.STA_CODMAC
   ELSE
      SKIP +1
      LOOP
   ENDIF

   SELECT SETTPROD
   XXX_CDMAC  = SET_CODICE
   XXX_DSMAC  = SET_DESCRI
   XXX_DATA   = RIBALTA2(SET_DATA)
   XXX_SETT   = SET_SETT
   XXX_ORELAV = SET_ORELAV
   XXX_ORAINI = SET_ORAINI

   *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
   SELECT CU_PRO_IM
   SET FILTER TO
   SET ORDER TO I_IMPEGNI
   SEEK 'TAG' + XXX_CDMAC + RIBALTA2(XXX_DATA)
   IF FOUND()
   ELSE
      APPEND BLANK
	  REPLACE IMP_CODLAV WITH 'TAG'
	  REPLACE IMP_DESLAV WITH 'TAGLIO'
	  REPLACE IMP_CODMAC WITH XXX_CDMAC
	  REPLACE IMP_DESMAC WITH XXX_DSMAC
	  REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
	  REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
      REPLACE IMP_NRPRG1 WITH _V_NUMPRG
      REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
      REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
      REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
      REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
      REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
      REPLACE IMP_NRPRG2 WITH SPACE(06)
      REPLACE IMP_DTPRG2 WITH SPACE(10)
      REPLACE IMP_SDPRG2 WITH SPACE(07)
      REPLACE IMP_SAPRG2 WITH SPACE(07)
      REPLACE IMP_DDPRG2 WITH SPACE(10)
      REPLACE IMP_DAPRG2 WITH SPACE(10)
      REPLACE IMP_ORELAV WITH XXX_ORELAV
      REPLACE IMP_OREIMP WITH 0
      REPLACE IMP_QTAMQ  WITH 0
      REPLACE IMP_QTAML  WITH 0
      REPLACE IMP_QTAKG  WITH 0
      REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
      REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
      REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
      REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
      REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
      REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
      REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
      REPLACE IMP_FLGMOD WITH .F.
      REPLACE IMP_ORAINI WITH XXX_ORAINI
      REPLACE IMP_ORAFIN WITH XXX_ORAINI
      SELECT SETTPROD
      LOOP
   ENDIF

   *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
   *=> la macchina+data
   IF IMP_ORELAV > IMP_OREIMP
   ELSE
      SELECT SETTPROD
      REPLACE SET_FATTO WITH .T.
      SKIP +1
      LOOP
   ENDIF

   IF V_PRIMAVOLTA
      V_PRIMAVOLTA = .F.
      *=> Determinazione delle ore necessarie alla lavorazione
      V_DIFFERENZA = 0
      V_ORE        = 0
      XX_ORAINI    = SPACE(08)
      XX_ORAFIN    = SPACE(08)
      IF EMPTY(ALLTRIM(_V_DATPRG)) .OR. _V_DATPRG = '  /  /    '
         _V_DATPRG = DTOC(DATE())
      ENDIF
      IF EMPTY(ALLTRIM(_V_DPRGDA))
         _V_DPRGDA = PUB_DATINI
      ENDIF
      IF RIBALTA2(_V_DPRGDA) < RIBALTA2(DTOC(DATE()))
         _V_DPRGDA = PUB_DATINI
      ENDIF
      V_DTINI      = PUB_DATINI
      V_DTFIN      = PUB_DATINI
      V_PRIMA      = .T.
      V_PRIMAEXIT  = .T.
   ENDIF

   SELECT CU_PRO_IM

   *=> Determino il tempo che č possibile impegnare per la giornata in questione
   V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP

   *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
   V_TRASF      = ((V_TOLFGG * 100) / 60) / 100

   *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
   IF V_DIFFERENZA > V_TRASF
   ELSE
 	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
 	     IF V_PRIMAEXIT
 	        V_PRIMAEXIT  = .F.
 	        V_PRIMAVOLTA = .T.
 	     ENDIF
         SELECT SETTPROD
         REPLACE SET_FATTO WITH .T.
         SKIP +1
         LOOP
      ENDIF
   ENDIF

   V_PRIMAEXIT = .F.

   *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
   *=> il lavoro
   IF V_ORELAV > V_DIFFERENZA
 	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
	     V_ORELAV = V_ORELAV - V_DIFFERENZA
         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
      ELSE	
         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
	     V_ORELAV = 0
      ENDIF
   ELSE
      REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
      V_ORELAV = 0
   ENDIF

   *=> Assegno la data di inizio/fine lavoro in cui sono arrivato
   IF V_PRIMA
      V_PRIMA = .F.
      V_DTINI = XXX_DATA
   ENDIF
   V_DTFIN = XXX_DATA

   *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
   XXX_TROV  = .T.

   *=> Memorizzo i dati della programmazione
   IF IMP_NRPRG1 = _V_NUMPRG
   ELSE
      REPLACE IMP_NRPRG2 WITH _V_NUMPRG
      REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
      REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
      REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
      REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
      REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
   ENDIF

   *=> Aggiorno il flag di impegno elaborato (per il contraggiornamento in fase di registrazione)
   REPLACE IMP_FLGMOD WITH .T.

   *=> Determino l'orario di inizio e fine lavoro
   IF EMPTY(ALLTRIM(XX_ORAINI))
      XX_ORAINI = IMP_ORAFIN
   ENDIF
   REPLACE IMP_ORAFIN WITH CALCOLAORA(IMP_ORAINI,IMP_OREIMP)
   XX_ORAFIN = IMP_ORAFIN
   IF V_DTINI = V_DTFIN
      IF XX_ORAINI > XX_ORAFIN
         XX_ORAINI = IMP_ORAINI
      ENDIF
   ENDIF

   *=> Gestione del fine lavoro
   IF V_ORELAV = 0
      IF IMP_ORELAV > IMP_OREIMP
      ELSE
         SELECT SETTPROD
         REPLACE SET_FATTO WITH .T.
      ENDIF
      EXIT
   ENDIF

   *=> Se la giornata č stata totalmente impegnata, ma restano ancora delle ore da impegnare, contraggiorno
   *=> la tabella per by-passare la macchina+data
   IF IMP_ORELAV > IMP_OREIMP
   ELSE
      SELECT SETTPROD
      REPLACE SET_FATTO WITH .T.
      SKIP +1
      LOOP
   ENDIF

   EXIT

ENDDO

IF V_ORELAV > 0
   IF XXX_TROV
      SELECT CU_CAL_LA
	  SET ORDER TO I_DATAMG
	  SET FILTER TO
	  SEEK RIBALTA2(PUB_DATFIN)
  	  DO WHILE .T.
	     IF EOF()
	        EXIT
	     ENDIF
	     IF V_ORELAV > 0
	     ELSE
	        EXIT
	     ENDIF
	     IF CAL_LAVO
	     ELSE
	        SKIP +1
	        LOOP
	     ENDIF
	     IF CAL_ORELAV > 0
	     ELSE
	        SKIP +1
	        LOOP
	     ENDIF
         IF CAL_DATAMG = RIBALTA2(PUB_DATFIN)
            SKIP +1
            LOOP
         ENDIF
         XXX_ORELAV = CAL_ORELAV
         XXX_ORAINI = CAL_ORAINI
         XXX_SETT   = CAL_SETT
         XXX_DATA   = CAL_DATA
         *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
         SELECT CU_PRO_IM
         SET FILTER TO
         SET ORDER TO I_IMPEGNI
         SEEK 'TAG' + XXX_CDMAC + RIBALTA2(XXX_DATA)
         IF FOUND()
         ELSE
            APPEND BLANK
		    REPLACE IMP_CODLAV WITH 'TAG'
	        REPLACE IMP_DESLAV WITH 'TAGLIO'
	        REPLACE IMP_CODMAC WITH XXX_CDMAC
   	        REPLACE IMP_DESMAC WITH XXX_DSMAC
	        REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
	        REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
            REPLACE IMP_NRPRG1 WITH _V_NUMPRG
	        REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
	        REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
	        REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
	        REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
            REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
            REPLACE IMP_NRPRG2 WITH SPACE(06)
            REPLACE IMP_DTPRG2 WITH SPACE(10)
            REPLACE IMP_SDPRG2 WITH SPACE(07)
            REPLACE IMP_SAPRG2 WITH SPACE(07)
            REPLACE IMP_DDPRG2 WITH SPACE(10)
            REPLACE IMP_DAPRG2 WITH SPACE(10)
            REPLACE IMP_ORELAV WITH XXX_ORELAV
            REPLACE IMP_OREIMP WITH 0
            REPLACE IMP_QTAMQ  WITH 0
            REPLACE IMP_QTAML  WITH 0
            REPLACE IMP_QTAKG  WITH 0
            REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
            REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
            REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
            REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
            REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
            REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
            REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
            REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
            REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
            REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
            REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
            REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
            REPLACE IMP_FLGMOD WITH .F.
            REPLACE IMP_ORAINI WITH XXX_ORAINI
            REPLACE IMP_ORAFIN WITH XXX_ORAINI
   	        SELECT CU_CAL_LA
            LOOP
         ENDIF
         *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
         *=> la macchina+data
         IF IMP_ORELAV > IMP_OREIMP
         ELSE
   	        SELECT CU_CAL_LA
            SKIP +1
            LOOP
         ENDIF
         *=> Determino il tempo che č possibile impegnare per la giornata in questione
         V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP
         *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
         V_TRASF      = ((V_TOLFGG * 100) / 60) / 100
         *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
         IF V_DIFFERENZA > V_TRASF
         ELSE
  	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
   	           SELECT CU_CAL_LA
               SKIP +1
               LOOP
   	        ENDIF
         ENDIF
         *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
         *=> il lavoro
         IF V_ORELAV > V_DIFFERENZA
   	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
   	           V_ORELAV = V_ORELAV - V_DIFFERENZA
               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
            ELSE	
               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
   	           V_ORELAV = 0
            ENDIF
         ELSE
            REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
            V_ORELAV = 0
         ENDIF
         *=> Assegno la data di fine lavoro in cui sono arrivato
   	     IF V_PRIMA
            V_PRIMA = .F.
            V_DTINI = XXX_DATA
         ENDIF
         V_DTFIN = XXX_DATA
         *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
         XXX_TROV  = .T.
         *=> Memorizzo i dati della programmazione
         IF IMP_NRPRG1 = _V_NUMPRG
         ELSE
            REPLACE IMP_NRPRG2 WITH _V_NUMPRG
            REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
            REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
            REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
            REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
            REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
            REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
            REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
            REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
            REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
            REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
         ENDIF
         *=> Aggiorno il flag di impegno elaborato (per il contraggiornamento in fase di registrazione)
         REPLACE IMP_FLGMOD WITH .T.
         *=> Determino l'orario di inizio e fine lavoro
         IF EMPTY(ALLTRIM(XX_ORAINI))
            XX_ORAINI = IMP_ORAFIN
         ENDIF
         REPLACE IMP_ORAFIN WITH CALCOLAORA(IMP_ORAINI,IMP_OREIMP)
         XX_ORAFIN = IMP_ORAFIN
         IF V_DTINI = V_DTFIN
            IF XX_ORAINI > XX_ORAFIN
               XX_ORAINI = IMP_ORAINI
            ENDIF
         ENDIF
         SELECT CU_CAL_LA
         *=> Gestione del fine lavoro
         IF V_ORELAV > 0
         ELSE
            EXIT
         ENDIF
      ENDDO
   ENDIF
ENDIF

IF XXX_TROV
   V_DATA     = XXX_DATA
   V_CDMAC    = XXX_CDMAC
   V_DSMAC    = XXX_DSMAC
ELSE
   RETURN
ENDIF

*=> Aggiornamento del cursore da stampare nel programma di TAGLIO per la logistica
SELECT STA_TAGLIO
REPLACE STA_DATINI WITH V_DTINI			
REPLACE STA_DATFIN WITH V_DTFIN		
REPLACE STA_SETTDA WITH _V_SPRGDA
REPLACE STA_SETTAL WITH _V_SPRGAL
REPLACE STA_DATADA WITH _V_DPRGDA
REPLACE STA_DATAAL WITH _V_DPRGAL
REPLACE STA_ORAINI WITH XX_ORAINI
REPLACE STA_ORAFIN WITH XX_ORAFIN

*=> Aggiornamento del cursore da stampare nel rapporto di produzione per i reparti

SELECT STA_RAPPRODT
SET ORDER TO I_INDICE
SEEK M.STA_NUMPRG + M.STA_DATPRG + STR(M.STA_PROGRE,6,0)
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF STA_NUMPRG = M.STA_NUMPRG .AND. STA_DATPRG = M.STA_DATPRG AND STA_PROGRE = M.STA_PROGRE
   ELSE
      EXIT
   ENDIF
   REPLACE STA_DATINI WITH V_DTINI		
   REPLACE STA_DATFIN WITH V_DTFIN		
   REPLACE STA_CODMAC WITH V_CDMAC
   REPLACE STA_DESMAC WITH V_DSMAC
   REPLACE STA_SETTDA WITH _V_SPRGDA
   REPLACE STA_SETTAL WITH _V_SPRGAL
   REPLACE STA_DATADA WITH _V_DPRGDA
   REPLACE STA_DATAAL WITH _V_DPRGAL
   REPLACE STA_ORAINI WITH XX_ORAINI
   REPLACE STA_ORAFIN WITH XX_ORAFIN
   SKIP +1
ENDDO

RETURN


***************************************************************************
PROCEDURE taglio_riepiloga
***************************************************************************

RELEASE XXX_CODSYS,XXX_PRIMA,XXX_PROGRE,XXX_LUNPRG,XXX_MISTAG,XXX_CLIELA,XXX_BOBPRG,XXX_QTAPRG,XXX_ALTEZZ,XXX_LUNGHE, ;
        XXX_BOBORD,XXX_QTAORD,XXX_SCARTO,XXX_LUNMAG,RIB_LUNGHE,RIB_NUMBOB,RIB_PROSUC,XXX_TAGMIS,XXX_NRTAG,XXX_LUMAG,  ;
        XXX_LEGSYS,XXX_ALTPRG,XXX_ALTUSATA,XXX_NRTAGL
PUBLIC  XXX_CODSYS,XXX_PRIMA,XXX_PROGRE,XXX_LUNPRG,XXX_MISTAG,XXX_CLIELA,XXX_BOBPRG,XXX_QTAPRG,XXX_ALTEZZ,XXX_LUNGHE, ;
        XXX_BOBORD,XXX_QTAORD,XXX_SCARTO,XXX_LUNMAG,RIB_LUNGHE,RIB_NUMBOB,RIB_PROSUC,XXX_TAGMIS,XXX_NRTAG,XXX_LUMAG,  ;
        XXX_LEGSYS,XXX_ALTPRG,XXX_ALTUSATA,XXX_NRTAGL
XXX_CODSYS = SYS(2015)
XXX_PRIMA  = .T.
XXX_PROGRE = 0
XXX_LUNPRG = 0
XXX_MISTAG = ""
XXX_CLIELA = ""
XXX_BOBPRG = 0
XXX_QTAPRG = 0
XXX_BOBORD = 0
XXX_QTAORD = 0
XXX_SCARTO = .F.
XXX_LUNMAG = 0
RIB_NUMBOB = 0
RIB_LUNGHE = 0
RIB_PROSUC = 0
XXX_TAGMIS = ""
XXX_NRTAG  = 0
XXX_LUMAG  = 0
XXX_LEGSYS = SPACE(10)
XXX_ALTPRG   = 0
XXX_ALTUSATA = 0
XXX_NRTAGL   = 0

CREATE CURSOR STA_LEGATAGLIO (LEG_LEGSYS C(10), LEG_ALTEZZ N(05), LEG_NUMBOB N(05), LEG_CLIENT C(50), LEG_NUMORD C(06),  ;
                              LEG_DATORD C(10), LEG_CODART C(16), LEG_DESART C(50), LEG_LUNGHE N(06), LEG_SYSORD C(10))
INDEX ON LEG_LEGSYS TAG I_LEGA ADDITIVE

SELECT RIE_TAGLIO
ZAP

SELECT CUR_TAGLIO
INDEX ON SEL_PROGRE TAG I_SPALMA ADDITIVE
SET ORDER TO I_SPALMA
SET FILTER TO
GO TOP
IF EOF()
   RETURN
ENDIF

SCATTER MEMVAR MEMO
RIB_LUNGHE = SEL_LUNGHE
RIB_NUMBOB = SEL_BOBPRG / SEL_ACCOPP
RIB_PROSUC = SEL_PROSUC
XXX_TAGMIS = ""
XXX_NRTAG  = SEL_NUMTAG
XXX_LUMAG  = SEL_LUNMAG
XXX_LEGSYS = SPACE(10)

DO WHILE .T.

   IF EOF()
      *=> Determino la percentuale di scarto
      XXX_ALTUSATA = XXX_ALTPRG + ((XXX_NRTAGL-1) * V_TAGLIO)
      V_SCCALC1    = 100 - (XXX_ALTUSATA * 100) / M.SEL_ALTMAG
      V_SCCALC2    = 100 - (XXX_ALTPRG * 100) / M.SEL_ALTMAG
      IF V_SCCALC1 > 0 .OR. V_SCCALC2 > 0
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "(Scarto A = " + ALLTRIM(STR(V_SCCALC2,6,2)) + " %  " + ;
                                                "Scarto B = " + ALLTRIM(STR(V_SCCALC1,6,2)) + " %)"
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + CHR(13)
      ENDIF
      IF EMPTY(ALLTRIM(XXX_TAGMIS))
         XXX_TAGMIS = ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ELSE
         XXX_TAGMIS = XXX_TAGMIS + CHR(13) + ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ENDIF
      XXX_PROGRE = XXX_PROGRE + 1
      SELECT RIE_TAGLIO
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_CODCLI WITH SPACE(10)
      REPLACE SEL_RAGSOC WITH SPACE(50)
      REPLACE SEL_NUMORD WITH SPACE(06)
      REPLACE SEL_DATORD WITH SPACE(10)
      REPLACE SEL_ALTEZZ WITH 0
      REPLACE SEL_LUNGHE WITH 0
      REPLACE SEL_BOBORD WITH XXX_BOBORD
      REPLACE SEL_QTAORD WITH XXX_QTAORD
      REPLACE SEL_LUNMAG WITH XXX_LUNMAG
      REPLACE SEL_UNIQUE WITH XXX_CODSYS
      REPLACE SEL_PROGRE WITH XXX_PROGRE
      REPLACE SEL_CODSYS WITH XXX_CODSYS
      REPLACE SEL_BOBPRG WITH XXX_BOBPRG
      REPLACE SEL_QTAPRG WITH XXX_QTAPRG
      REPLACE SEL_MISTAG WITH XXX_MISTAG
      REPLACE SEL_TAGMIS WITH XXX_TAGMIS
      REPLACE SEL_CLIELA WITH XXX_CLIELA
      REPLACE SEL_LUNPRG WITH XXX_LUNPRG
      REPLACE SEL_SCARTO WITH XXX_SCARTO
      REPLACE SEL_LEGSYS WITH XXX_LEGSYS
      EXIT
   ENDIF

   *=> Verifica rottura sequenza (cambia programma)
   IF SEL_NUMLOT = M.SEL_NUMLOT
   ELSE
      *=> Determino la percentuale di scarto
      XXX_ALTUSATA = XXX_ALTPRG + ((XXX_NRTAGL-1) * V_TAGLIO)
      V_SCCALC1    = 100 - (XXX_ALTUSATA * 100) / M.SEL_ALTMAG
      V_SCCALC2    = 100 - (XXX_ALTPRG * 100) / M.SEL_ALTMAG
      IF V_SCCALC1 > 0 .OR. V_SCCALC2 > 0
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "(Scarto A = " + ALLTRIM(STR(V_SCCALC2,6,2)) + " %  " + ;
                                                "Scarto B = " + ALLTRIM(STR(V_SCCALC1,6,2)) + " %)"
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + CHR(13)
      ENDIF
      IF EMPTY(ALLTRIM(XXX_TAGMIS))
         XXX_TAGMIS = ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ELSE
         XXX_TAGMIS = XXX_TAGMIS + CHR(13) + ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ENDIF
      XXX_PROGRE = XXX_PROGRE + 1
      SELECT RIE_TAGLIO
      APPEND BLANK
      GATHER MEMVAR MEMO
      REPLACE SEL_CODCLI WITH SPACE(10)
      REPLACE SEL_RAGSOC WITH SPACE(50)
      REPLACE SEL_NUMORD WITH SPACE(06)
      REPLACE SEL_DATORD WITH SPACE(10)
      REPLACE SEL_ALTEZZ WITH 0
      REPLACE SEL_LUNGHE WITH 0
      REPLACE SEL_BOBORD WITH XXX_BOBORD
      REPLACE SEL_QTAORD WITH XXX_QTAORD
      REPLACE SEL_LUNMAG WITH XXX_LUNMAG
      REPLACE SEL_UNIQUE WITH XXX_CODSYS
      REPLACE SEL_PROGRE WITH XXX_PROGRE
      REPLACE SEL_CODSYS WITH XXX_CODSYS
      REPLACE SEL_BOBPRG WITH XXX_BOBPRG
      REPLACE SEL_QTAPRG WITH XXX_QTAPRG
      REPLACE SEL_MISTAG WITH XXX_MISTAG
      REPLACE SEL_TAGMIS WITH XXX_TAGMIS
      REPLACE SEL_CLIELA WITH XXX_CLIELA
      REPLACE SEL_LUNPRG WITH XXX_LUNPRG
      REPLACE SEL_SCARTO WITH XXX_SCARTO
      REPLACE SEL_LEGSYS WITH XXX_LEGSYS
      SELECT CUR_TAGLIO
      SCATTER MEMVAR MEMO
      XXX_CODSYS = SYS(2015)
      XXX_PRIMA  = .T.
      XXX_LUNPRG = 0
      XXX_MISTAG = ""
      XXX_CLIELA = ""
      XXX_BOBPRG = 0
      XXX_QTAPRG = 0
      XXX_BOBORD = 0
      XXX_QTAORD = 0
      XXX_SCARTO = .F.
      XXX_LUNMAG = 0
      RIB_LUNGHE = SEL_LUNGHE
      RIB_NUMBOB = SEL_BOBPRG / SEL_ACCOPP
      RIB_PROSUC = SEL_PROSUC
      XXX_TAGMIS = ""
      XXX_NRTAG  = SEL_NUMTAG
      XXX_LUMAG  = SEL_LUNMAG
      XXX_LEGSYS = SPACE(10)
      XXX_NRTAGL   = 0
      XXX_ALTUSATA = 0
      XXX_ALTPRG   = 0
      LOOP
   ENDIF

   XX_CODCLI = SEL_CODCLI
   XX_RAGSOC = SEL_RAGSOC
   XX_UNIQUE = SEL_CODSYS
   XX_BOBPRG = SEL_BOBPRG
   XX_QTAPRG = SEL_QTAPRG
   XX_BOBORD = SEL_BOBORD
   XX_QTAORD = SEL_QTAORD
   XX_LUNMAG = SEL_LUNMAG
   XX_NRPAGI = SEL_PROGRE

   SELECT CU_PRG_CL
   SET ORDER TO I_PRGCL2
   SEEK 'TAG' + XXX_CODSYS + XX_UNIQUE
   IF FOUND()
      REPLACE PRG_BOBPRG WITH PRG_BOBPRG + XX_BOBPRG
      REPLACE PRG_QTAPRG WITH PRG_QTAPRG + XX_QTAPRG
   ELSE
      APPEND BLANK
      REPLACE PRG_TIPO   WITH 'TAG'
      REPLACE PRG_CODSYS WITH XXX_CODSYS
      REPLACE PRG_CODCLI WITH XX_CODCLI
      REPLACE PRG_RAGSOC WITH XX_RAGSOC
      REPLACE PRG_UNIQUE WITH XX_UNIQUE
      REPLACE PRG_BOBPRG WITH XX_BOBPRG
      REPLACE PRG_QTAPRG WITH XX_QTAPRG
   ENDIF

   REPLACE PRG_NUMPRG WITH _V_NUMPRG
   REPLACE PRG_DATPRG WITH _V_DATPRG
   REPLACE PRG_PROGRE WITH XX_NRPAGI

   XXX_BOBPRG = XXX_BOBPRG + XX_BOBPRG
   XXX_QTAPRG = XXX_QTAPRG + XX_QTAPRG

   XXX_BOBORD = XXX_BOBORD + XX_BOBORD
   XXX_QTAORD = XXX_QTAORD + XX_QTAORD

   XXX_LUNMAG = XX_LUNMAG

   SELECT CUR_TAGLIO

   IF SEL_SCARTO
      XXX_SCARTO = .T.
   ENDIF

   IF SEL_PROGRE = M.SEL_PROGRE
   ELSE
      XXX_LUNPRG   = XXX_LUNPRG + ROUND((SEL_LUNGHE * SEL_BOBPRG) / SEL_ACCOPP,0)
      *=> Determino la percentuale di scarto
      XXX_ALTUSATA = XXX_ALTPRG + ((XXX_NRTAGL-1) * V_TAGLIO)
      V_SCCALC1    = 100 - (XXX_ALTUSATA * 100) / M.SEL_ALTMAG
      V_SCCALC2    = 100 - (XXX_ALTPRG * 100) / M.SEL_ALTMAG
      IF V_SCCALC1 > 0 .OR. V_SCCALC2 > 0
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "(Scarto A = " + ALLTRIM(STR(V_SCCALC2,6,2)) + " %  " + ;
                                                "Scarto B = " + ALLTRIM(STR(V_SCCALC1,6,2)) + " %)" +CHR(13) + ;
                        "==========================="
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + CHR(13) + "==========================="
      ELSE
         XXX_MISTAG   = XXX_MISTAG + CHR(13) + "==========================="
         XXX_CLIELA   = XXX_CLIELA + CHR(13) + "==========================="
      ENDIF
      M.SEL_PROGRE = SEL_PROGRE
      IF RIB_LUNGHE = SEL_LUNGHE
         IF RIB_PROSUC = SEL_PROSUC
            RIB_NUMBOB = RIB_NUMBOB + (SEL_BOBPRG / SEL_ACCOPP)
            RIB_PROSUC = SEL_PROSUC
         ENDIF
      ENDIF
      XXX_NRTAGL   = 0
      XXX_ALTUSATA = 0
      XXX_ALTPRG   = 0
   ENDIF

   IF XXX_PRIMA
      XXX_PRIMA  = .F.
      XXX_LUNPRG = ROUND((SEL_LUNGHE * SEL_BOBPRG) / SEL_ACCOPP,0)
   ENDIF

   IF EMPTY(ALLTRIM(XXX_MISTAG))
      XXX_NRTAGL = SEL_ACCOPP
      XXX_ALTPRG = (SEL_ALTEZZ * SEL_ACCOPP)
      XXX_MISTAG = ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      XXX_CLIELA = ALLTRIM(SUBSTR(SEL_RAGSOC,1,23))
   ELSE
      XXX_NRTAGL = XXX_NRTAGL + SEL_ACCOPP
      XXX_ALTPRG = XXX_ALTPRG + (SEL_ALTEZZ * SEL_ACCOPP)
      XXX_MISTAG = XXX_MISTAG + CHR(13) + ALLTRIM(STR(SEL_BOBPRG,6,0)) + " Bobine da " + ALLTRIM(STR(SEL_ALTEZZ,5,0)) + " mm. X " + ALLTRIM(STR(SEL_LUNGHE,6,0)) + " mtl"
      XXX_CLIELA = XXX_CLIELA + CHR(13) + ALLTRIM(SUBSTR(SEL_RAGSOC,1,23))
   ENDIF

   IF RIB_LUNGHE = SEL_LUNGHE
      IF RIB_PROSUC = SEL_PROSUC
      ELSE
         RIB_NUMBOB = RIB_NUMBOB + (SEL_BOBPRG / SEL_ACCOPP)
         RIB_PROSUC = SEL_PROSUC
      ENDIF
   ELSE
      IF EMPTY(ALLTRIM(XXX_TAGMIS))
         XXX_TAGMIS = ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ELSE
         XXX_TAGMIS = XXX_TAGMIS + CHR(13) + ALLTRIM(STR(RIB_NUMBOB,6,0)) + " Bobine da " + ALLTRIM(STR(RIB_LUNGHE,6,0)) + " mtl"
      ENDIF
      RIB_NUMBOB = SEL_BOBPRG / SEL_ACCOPP
      RIB_LUNGHE = SEL_LUNGHE
      RIB_PROSUC = SEL_PROSUC
   ENDIF

   WW_ALTEZZ = SEL_ALTEZZ
   WW_ACCOPP = SEL_ACCOPP
   WW_RAGSOC = SEL_RAGSOC
   WW_NUMORD = SEL_NUMORD
   WW_DATORD = SEL_DATORD
   WW_CODART = SEL_CODART
   WW_DESART = SEL_DESART
   WW_LUNGHE = SEL_LUNGHE
   WW_CODSYS = SEL_CODSYS
   IF EMPTY(ALLTRIM(XXX_LEGSYS))
      XXX_LEGSYS = SYS(2015)
   ENDIF

   SELECT STA_LEGATAGLIO
   APPEND BLANK
   REPLACE LEG_LEGSYS WITH XXX_LEGSYS
   REPLACE LEG_ALTEZZ WITH WW_ALTEZZ
   REPLACE LEG_NUMBOB WITH WW_ACCOPP
   REPLACE LEG_CLIENT WITH WW_RAGSOC
   REPLACE LEG_NUMORD WITH WW_NUMORD
   REPLACE LEG_DATORD WITH WW_DATORD
   REPLACE LEG_CODART WITH WW_CODART
   REPLACE LEG_DESART WITH WW_DESART
   REPLACE LEG_LUNGHE WITH WW_LUNGHE
   REPLACE LEG_SYSORD WITH WW_CODSYS

   SELECT CUR_TAGLIO
   SKIP +1

ENDDO

RETURN


****************************
PROCEDURE GENERA_RIEPORDINE1
****************************

PARAMETERS _NOMARC,_TIPO

SELECT &_NOMARC
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF STA_DATINI = 'GG/MM/AAAA'
      SKIP +1
      LOOP
   ENDIF	

   WEC_SYSCLI = STA_SYSCLI

   SELECT CU_PRG_CL
   SET ORDER TO I_PRGCL1
   SEEK _TIPO + WEC_SYSCLI
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF PRG_TIPO = _TIPO .AND. PRG_CODSYS = WEC_SYSCLI
      ELSE
         EXIT
      ENDIF
      WEC_CODSYS = PRG_UNIQUE
      WEC_BOBPRG = PRG_BOBPRG

      x_csys = "ord_codsys = '" + ALLTRIM(WEC_CODSYS) + "'"
      x_cond = x_csys
      cSql   = "select * from U_ORD_DD where " + x_cond + " order by ors_codcli,ors_numord,ors_datord"
      IF !ExecCommand(cSql,'UXU_ORD_DD')
         return(.f.)
      ENDIF
      SELECT UXU_ORD_DD
      GO TOP
      IF EOF()
         WEC_AGGANC = SPACE(10)
      ELSE
         WEC_AGGANC = DAGGANCIO
      ENDIF

      SELECT CURS_ORDINE
      SET ORDER TO I_ORDINE
      SEEK WEC_CODSYS
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE STA_SYSCLI WITH WEC_CODSYS
         REPLACE STA_AGGANC WITH WEC_AGGANC
         REPLACE STA_NRBSPP WITH 0
         REPLACE STA_NRBRIP WITH 0
         REPLACE STA_NRBTGP WITH 0
      ENDIF
      IF _TIPO = 'SPA'
         REPLACE STA_NRBSPP WITH STA_NRBSPP + WEC_BOBPRG
      ENDIF
      IF _TIPO = 'RIB'
         REPLACE STA_NRBRIP WITH STA_NRBRIP + WEC_BOBPRG
      ENDIF
      IF _TIPO = 'TAG'
         REPLACE STA_NRBTGP WITH STA_NRBTGP + WEC_BOBPRG
      ENDIF
      SELECT CU_PRG_CL
      SKIP +1
   ENDDO

   SELECT &_NOMARC
   SKIP +1

ENDDO

RETURN


****************************
PROCEDURE GENERA_RIEPORDINE2
****************************

PARAMETERS _NOMARC,_TIPO

SELECT &_NOMARC
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF STA_DATINI = 'GG/MM/AAAA'
      SKIP +1
      LOOP
   ENDIF	

   WEC_SYSCLI = STA_SYSCLI

   * Accesso alla tabella delle programmazioni per cliente (tutte le programmazioni legate alla riga d'ordine cliente)
   * mettendo in chiave il codice sys che lega la riga d'ordine del cliente
   x_tipo = "prg_tipo = '" + _TIPO + "'"
   x_csys = "prg_codsys = '" + WEC_SYSCLI + "'"
   x_cond = x_tipo + " and " + x_csys
   Csql   = "select * from u_prg_cl where " + x_cond
   IF !ExecCommand(cSql,"CURS_PRG_CL")
      return(.f.)
   ENDIF
   SELECT CURS_PRG_CL
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      WEC_CODSYS = PRG_UNIQUE

      x_csys = "ord_codsys = '" + ALLTRIM(WEC_CODSYS) + "'"
      x_cond = x_csys
      cSql   = "select * from U_ORD_DD where " + x_cond + " order by ors_codcli,ors_numord,ors_datord"
      IF !ExecCommand(cSql,'UXU_ORD_DD')
         return(.f.)
      ENDIF
      SELECT UXU_ORD_DD
      GO TOP
      IF EOF()
         WEC_AGGANC = SPACE(10)
      ELSE
         WEC_AGGANC = DAGGANCIO
      ENDIF

      SELECT CURS_ORDINE
      SET ORDER TO I_ORDINE
      SEEK WEC_CODSYS
      IF FOUND()
      ELSE
         APPEND BLANK
         REPLACE STA_SYSCLI WITH WEC_CODSYS
         REPLACE STA_AGGANC WITH WEC_AGGANC
      ENDIF
      SELECT CURS_PRG_CL
      SKIP +1
   ENDDO

   SELECT &_NOMARC
   SKIP +1

ENDDO

RETURN


**************************
PROCEDURE GENERA_SITORDINE
**************************


CREATE CURSOR CURS_ORD_DD (ORS_CODCLI C(9),     ORS_RAGSOC C(40),   ORD_CODART C(16),   ORD_ALTEZZ N(5,0),  ;
                           ORD_LUNGHE N(15,0),  ORS_NUMORD C(6),    ORS_DATORD C(10),   ORD_NUMBOB N(6,0),  ;
                           ORD_NUMBOE N(15,0),  ORD_NUMBDE N(15,0), ORD_NRBSPP N(15,0), ORD_NRBRIP N(15,0), ;
                           ORD_NRBTGP N(15,0),  ORD_NUMBOG N(15,0), ORD_SETTCC C(7),    ORD_SETTPR C(7),    ;
                           ORD_SETTPI C(7),     ORD_SETTRA N(2,0),  ORD_SETTRC N(2,0),  DAGGANCIO C(10),    ;
                           ORD_CODSYS C(10))
SELECT CURS_ORD_DD
INDEX ON ORS_CODCLI + ORS_DATORD + ORD_CODART TAG I_CODCLI ADDITIVE
INDEX ON DAGGANCIO							  TAG I_AGGANC ADDITIVE
INDEX ON ORD_CODSYS							  TAG I_CODSYS ADDITIVE

SELECT CURS_ORDINE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   WEC_AGGANC = STA_AGGANC

   SELECT CURS_ORD_DD
   SET ORDER TO I_AGGANC
   SEEK WEC_AGGANC

   IF EOF()
   ELSE
      SELECT CURS_ORDINE
      SKIP +1
      LOOP
   ENDIF

   x_agga = "daggancio = '" + ALLTRIM(WEC_AGGANC) + "'"
   x_cond = x_agga
   cSql   = "select * from U_ORD_DD where " + x_cond + " order by ors_codcli,ors_numord,ors_datord"
   IF !ExecCommand(cSql,'UXU_ORD_DD')
      return(.f.)
   ENDIF
   SELECT UXU_ORD_DD
   GO TOP
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF DAGGANCIO = WEC_AGGANC
      ELSE
         EXIT
      ENDIF
      IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
         SKIP +1
         LOOP
      ENDIF
      SCATTER MEMVAR MEMO
      SELECT CURS_ORD_DD
      APPEND BLANK
      GATHER MEMVAR
      SELECT UXU_ORD_DD
      SKIP +1
   ENDDO

   SELECT CURS_ORDINE
   SKIP +1

ENDDO


SELECT CURS_ORD_DD
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   _X_DIFFSETA = (VAL(SUBSTR(ALLTRIM(M.ORD_SETTPR),4,4)) - VAL(SUBSTR(ALLTRIM(M.ORD_SETTPR),4,4))) * 52
   _X_DIFFSETS = (VAL(SUBSTR(ALLTRIM(M.ORD_SETTPR),1,2)) - VAL(SUBSTR(ALLTRIM(M.ORD_SETTPR),1,2)))
   _V_SETTRA   = _X_DIFFSETS + _X_DIFFSETA
   _X_DIFFSETA = (VAL(SUBSTR(ALLTRIM(M.ORD_SETTPR),4,4)) - VAL(SUBSTR(ALLTRIM(M.ORD_SETTPR),4,4))) * 52
   _X_DIFFSETS = (VAL(SUBSTR(ALLTRIM(M.ORD_SETTCC),1,2)) - VAL(SUBSTR(ALLTRIM(M.ORD_SETTPR),1,2)))
   _V_SETTRC   = _X_DIFFSETS + _X_DIFFSETA

   x_agga = "mag_sysord = '" + ALLTRIM(M.ORD_CODSYS) + "'"
   x_cond = x_agga
   cSql   = "select * from u_mag_gg where " + x_cond + " order by mag_codart,mag_datagg"
   IF !ExecCommand(cSql,'CUYY_MAG_GG')
      return(.f.)
   ENDIF
   SELECT CUYY_MAG_GG
   GO TOP
   WEC_NRBMAG = 0
   DO WHILE .T.
      IF EOF()
         EXIT
      ENDIF
      IF MAG_GIACEN > 0
         WEC_NRBMAG = WEC_NRBMAG + 1
      ENDIF
      SKIP +1
   ENDDO

   SELECT CURS_ORDINE
   SET ORDER TO I_ORDINE
   SEEK M.ORD_CODSYS
   IF EOF()
      WEC_NRBSPP = 0
      WEC_NRBRIP = 0
      WEC_NRBTGP = 0
   ELSE
      WEC_NRBSPP = STA_NRBSPP
      WEC_NRBRIP = STA_NRBRIP
      WEC_NRBTGP = STA_NRBTGP
   ENDIF

   SELECT CURS_ORD_DD
   REPLACE ORS_DATORD WITH RIBALTA2(M.ORS_DATORD)
   REPLACE ORD_NUMBDE WITH (ORD_NUMBOB - ORD_NUMBOE )
   REPLACE ORD_SETTRA WITH _V_SETTRA
   REPLACE ORD_SETTRC WITH _V_SETTRC
   IF V_AGGIO
      REPLACE ORD_NRBSPP WITH ORD_NRBSPP + WEC_NRBSPP		&& SOLO IL PROGRAMMATO IN SPALMATURA
      REPLACE ORD_NRBRIP WITH ORD_NRBRIP + WEC_NRBRIP		&& SOLO IL PROGRAMMATO IN RIBOBINATURA
      REPLACE ORD_NRBTGP WITH ORD_NRBTGP + WEC_NRBTGP		&& SOLO IL PROGRAMMATO IN TAGLIO
   ENDIF
   REPLACE ORD_NUMBOG WITH WEC_NRBMAG

   SKIP +1

ENDDO

RETURN


