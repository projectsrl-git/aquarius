**************************************************
FUNCTION CERCA_TIPOLOGIA_PAESE_E_NAZIONE_INTRASTAT
**************************************************
PARAMETERS __NAZIONE__

_RIT = ""

WWXY=SELECT()


IF __NAZIONE__ = 'ITA' OR __NAZIONE__ = 'IT'
	_RIT  = "ITA"
ELSE
	v_seek	 = 'STA'+__NAZIONE__
	v_chiave = "codice"
	IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
	   SELECT CUR_PARA
	   _TIPO  =SUBSTR(DESIVA,11,1)	&& STATOCEE: S = CEE / STATOCEE: N = EXT / SE NAZIONE ITA = ITA
	ELSE
	   _TIPO  =""
	ENDIF
	DO CASE
		CASE _TIPO  = "S"	&& PAESE CEE
			_RIT  = "CEE"	
		CASE _TIPO  = "N"	&& PAESE EXTRA CEE	
			_RIT  = "EXT"
		OTHERWISE			&& PAESE ITALIA	
			_RIT  = "ITA"		
	ENDCASE
ENDIF



SELECT(WWXY)
RETURN _RIT




*************************************************************************
FUNCTION ALLINEA_CAMPO
*************************************************************************
* PROCDURA PER ALLINEARE I CAMPI RIEMPIENDOLI CON IL CARATTERE DESIDERATO
* __CAMPO__ 			: CAMPO IN INGRESSO DA GESTIRE
* __LUNGHEZZA_CAMPO__	: LUNGHEZZA CAMPO DA GESTIRE
* __TIPO_ALLINEAMENTO__	: SX - ALLINEAMENTO DA SINISTRA A DESTRA
* 						: DX - ALLINEAMENTO DA DESTRA A SINISTRA
* __TIPO_CARATTERE__	: CARATTERE DA USARE PER IL RIEMPIMENTO DURANTE L'ALLINEAMENTO
*
* ESEMPIO				: =ALLINEA_CAMPO(__CAMPO,__LUNGHEZZA_CAMPO,__TIPO_ALLINEAMENTO,__TIPO_CARATTERE)
*						: __CAMPO 				= '1956,66'
*						: __LUNGHEZZA_CAMPO 	= 20 	&& 20 CHR
*						: __TIPO_ALLINEAMENTO 	= "SX"
*						: __TIPO_CARATTERE		= "0"
*						:
*						: RISULTATO : "00000000000001956,66"
*
*
LPARAMETERS __CAMPO__,__LUNGHEZZA_CAMPO__,__TIPO_ALLINEAMENTO__,__TIPO_CARATTERE__

__WWXY=SELECT()

_RIT = __CAMPO__
__CAMPO__=ALLTRIM(__CAMPO__)
IF LEN(__CAMPO__) > __LUNGHEZZA_CAMPO__
 RETURN(_RIT )
ENDIF

IF __TIPO_ALLINEAMENTO__ = 'SX' OR __TIPO_ALLINEAMENTO__ = 'DX'
ELSE
	__TIPO_ALLINEAMENTO__ = 'SX'
ENDIF

_LUN1=__LUNGHEZZA_CAMPO__- LEN(__CAMPO__)
IF __TIPO_ALLINEAMENTO__ = 'SX'
	_RIT=REPLICATE(__TIPO_CARATTERE__,_LUN1)+__CAMPO__			&& ALLINEAMENTO A SINISTRA
ELSE
	_RIT=__CAMPO__+REPLICATE(__TIPO_CARATTERE__,_LUN1)			&& ALLINEAMENTO A DESTRA
ENDIF

SELECT(__WWXY)
RETURN _RIT




