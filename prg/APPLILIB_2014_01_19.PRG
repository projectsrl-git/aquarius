   SELECT U_CAL_LA
   GO TOP
   IF EOF()
   ELSE
      W_SETFIN = CAL_SETT
   ENDIF
ENDIF

_V_DPRGDA = W_DATINI
_V_SPRGDA = W_SETINI
_V_DPRGAL = W_DATFIN
_V_SPRGAL = W_SETFIN

