*=> Gestione delle singole bobine di film spalmato in giacenza programmate per la produzione della ribobinatura
V_LENSCA = V_LUPRG		&& variabile in cui metto la lunghezza totale in mtl delle bobine da scaricare

V_SEEK = V_CDMAT + V_CDCOL + STR(V_MYMAG,3,0) + STR(V_ALMAG,5,0) + STR(V_NLINT,8,0)

SELECT R_MAG_GG
SET ORDER TO I_RMAGG2
SEEK V_SEEK

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   *=> Se rottura chiave di ricerca, fermo l'elaborazione
   IF MAG_CODMAT = V_CDMAT .AND. MAG_CODCOL = V_CDCOL .AND. MAG_SPESSO = V_MYMAG .AND. MAG_ALTEZZ = V_ALMAG .AND. MAG_NRLINT = V_NLINT
   ELSE
      EXIT
   ENDIF

   IF MAG_COMODO > 0
   ELSE
      SKIP +1
      LOOP
   ENDIF

   IF V_LENSCA < 1
      EXIT
   ENDIF

   SCATTER MEMVAR MEMO

   *=> Scrittura del record nel cursore da stampare nel rapporto di produzione per i reparti
   *=> da notare che la prima parte dei records contiene le stesse cose di quello della logistica

   SELECT STA_RAPPRODR
   APPEND BLANK
   REPLACE STA_CODART WITH V_CDART
   REPLACE STA_DESART WITH V_DSART
   REPLACE STA_SPEORD WITH V_MYORD
   REPLACE STA_CILRET WITH V_CILRE
   REPLACE STA_SPEMAG WITH V_MYMAG
   REPLACE STA_CODCOL WITH V_CDCOL
   REPLACE STA_DESCOL WITH V_DSCOL
   REPLACE STA_CODMAT WITH V_CDMAT
   REPLACE STA_DESMAT WITH V_DSMAT
   REPLACE STA_ALTMAG WITH V_ALMAG
   REPLACE STA_ALTCOM WITH 99999 - STA_ALTMAG		&& ALTEZZA COMPLEMENTATA A 99999 PER SORT ALTEZZA DISCENDENTE
   REPLACE STA_VELLIN WITH V_VELIN
   REPLACE STA_LUNPRG WITH V_LUPRG
   REPLACE STA_MQPROG WITH V_MQPRG
   REPLACE STA_ORELAV WITH V_HHLAV		
   REPLACE STA_DATINI WITH V_DTINI		
   REPLACE STA_DATFIN WITH V_DTFIN		
   REPLACE STA_NOTE   WITH IIF(EMPTY(ALLTRIM(V_NOTE)),V_TAGMIS,ALLTRIM(V_TAGMIS)+CHR(13)+ALLTRIM(V_NOTE)) 	
   REPLACE STA_CDDIBA WITH V_CDIBA
   REPLACE STA_CODMAC WITH V_CDMAC
   REPLACE STA_DESMAC WITH V_DSMAC
   REPLACE STA_SETTDA WITH _V_SPRGDA
   REPLACE STA_SETTAL WITH _V_SPRGAL
   REPLACE STA_DATADA WITH _V_DPRGDA
   REPLACE STA_DATAAL WITH _V_DPRGAL
   REPLACE STA_NUMPRG WITH _V_NUMPRG
   REPLACE STA_DATPRG WITH _V_DATPRG
   REPLACE STA_MISTAG WITH V_MISTAG
   REPLACE STA_CLIELA WITH V_CLIELA
   REPLACE STA_TAGMIS WITH V_TAGMIS
   REPLACE STA_PROGRE WITH V_PROGRE
   REPLACE STA_TEMCCG WITH XXX_TEMCCG
   REPLACE STA_TEMCCR WITH XXX_TEMCCR
   REPLACE STA_SCARTO WITH V_SCARTO
   REPLACE STA_ORAINI WITH XX_ORAINI
   REPLACE STA_ORAFIN WITH XX_ORAFIN
   REPLACE STA_SYSCLI WITH V_SYSCLI
   REPLACE STA_FLGELI WITH SPACE(02)

   *=> Tipo record = 1 significa che contiene le bobine di film spalmato

   x_uniq = "mag_unique = '" + M.MAG_UNIQUE + "'"
   x_cond = x_uniq
   Csql   = "select * from u_mag_gg where " + x_cond
   IF !ExecCommand(Csql,"GIACENZE")
      return(.f.)
   ENDIF
   SELECT GIACENZE
   GO TOP
   IF EOF()
   ELSE
      M.MAG_QTAML  = MAG_QTAML  - MAG_GMLIMP
      M.MAG_QTAKG  = MAG_QTAKG  - MAG_GKGIMP
      M.MAG_QTAMQ  = MAG_QTAMQ  - MAG_QTAIMP
      M.MAG_GIACEN = MAG_GIACEN - MAG_QTAIMP
   ENDIF

   SELECT STA_RAPPRODR
   REPLACE STA_TIPREC WITH 1
   REPLACE STA_NUMRIG WITH V_NUMRIG

   REPLACE NUD_CODMAG WITH M.MAG_CODMAG
   REPLACE NUD_CODFOR WITH M.MAG_FORNIT
   REPLACE NUD_DESFOR WITH M.MAG_DESFOR
   REPLACE NUD_CODINT WITH M.MAG_CODART
   REPLACE NUD_NUMLOT WITH M.MAG_NRLINT
   REPLACE NUD_UNITAM WITH 'MQ'
   IF V_LENSCA > (M.MAG_QTAML - MAG_GMLIMP)
      REPLACE NUD_LUNGHE WITH (M.MAG_QTAML - MAG_GMLIMP)
      REPLACE NUD_QTAMQ  WITH (M.MAG_QTAMQ - MAG_QTAIMP)
      REPLACE NUD_QTAKG  WITH (M.MAG_QTAKG - MAG_GKGIMP)
   ELSE
      REPLACE NUD_LUNGHE WITH V_LENSCA
      REPLACE NUD_QTAMQ  WITH TROVA_MQ_DA_AL(STA_ALTMAG,NUD_LUNGHE,1)
      REPLACE NUD_QTAKG  WITH TROVA_KG_DA_MQ(M.MAG_ANAART,STA_SPEMAG,NUD_QTAMQ,1)
   ENDIF

   SELECT STA_RAPPRODR
   XXX_QTAMQ = NUD_QTAMQ
   XXX_QTAKG = NUD_QTAKG
   XXX_QTAML = NUD_LUNGHE

   SELECT STA_RAPPRODR
   REPLACE ADE_CODICE WITH SPACE(16)
   REPLACE ADE_DESCRI WITH SPACE(50)
   REPLACE ADE_DSDIBA WITH SPACE(50)
   REPLACE ADE_UNITAM WITH SPACE(03)
   REPLACE ADE_QTAGIA WITH 0
   REPLACE ADE_QTANEC WITH 0
   REPLACE ADE_QTADOR WITH 0
   REPLACE ADE_SCORMI WITH 0
   REPLACE ADE_CODIMB WITH SPACE(16)
   REPLACE ADE_DESIMB WITH SPACE(50)
   REPLACE ADE_LOTMIN WITH 0
   REPLACE ADE_LIVELL WITH 0
   REPLACE ADE_QTADIB WITH 0
   REPLACE ADE_CODINT WITH SPACE(16)
   REPLACE ADE_NUMLOT WITH 0
   REPLACE ADE_CODFOR WITH SPACE(10)
   REPLACE ADE_DESFOR WITH SPACE(50)
   REPLACE ADE_CODMAG WITH PUB_CQUMPC
   REPLACE ADE_CODMAG WITH SPACE(06)

   REPLACE MAG_QTAGIA WITH 0
   REPLACE AVA_CODAVA WITH SPACE(03)
   REPLACE AVA_DESAVA WITH SPACE(50)
   REPLACE AVA_DATAVA WITH SPACE(10)
   REPLACE AVA_AMGAVA WITH SPACE(10)
   REPLACE AVA_ORAAVA WITH SPACE(08)
   REPLACE AVA_CONMTL WITH 0

   V_LENSCA = V_LENSCA - XXX_QTAML
   V_NUMRIG = V_NUMRIG + 1

   SELECT R_MAG_GG
   REPLACE MAG_QTAIMP WITH MAG_QTAIMP + XXX_QTAMQ
   REPLACE MAG_GMLIMP WITH MAG_GMLIMP + XXX_QTAML
   REPLACE MAG_GKGIMP WITH MAG_GKGIMP + XXX_QTAKG
   REPLACE MAG_FLGMOD WITH .T.

   SKIP +1

ENDDO

*=> INIZIO - GESTIONE DELLA PROGRAMMAZIONE SOLO NELLE SETTIMANE PREVISTE
IF V_PROGRE = 1
   *=> ACCESSO AL CALENDARIO LAVORATIVO GENERALE PER PRELEVARE LA SETTIMANA DI INIZIO LAVORO
   x_data = "cal_data = '" + V_DTINI + "'"
   Csql   = "select * from u_cal_la where " + x_data
   IF !ExecCommand(Csql,"cux_cal_la")
      return(.f.)
   ENDIF
   SELECT CUX_CAL_LA
   GO TOP
   IF EOF()
      VVV_SETINI = _V_SPRGDA
   ELSE
      VVV_SETINI = CAL_SETT
   ENDIF
   VVV_NUMSET = VAL(SUBSTR(VVV_SETINI,1,2)) + V_SETIMP - 1
   VVV_NUMANN = VAL(SUBSTR(VVV_SETINI,4,4))
   IF VVV_NUMSET > 52
      VVV_NUMSET = VVV_NUMSET - 52
      VVV_NUMANN = VVV_NUMANN + 1
   ENDIF
   VVV_NUMSEX = ALLTRIM(STR(VVV_NUMSET,2,0))
   IF VVV_NUMSET > 9
   ELSE
      VVV_NUMSEX = '0' + VVV_NUMSEX
   ENDIF
   VVV_SETTIM = VVV_NUMSEX + '/' + ALLTRIM(STR(VVV_NUMANN,4,0))
ENDIF
*=> ACCESSO AL CALENDARIO LAVORATIVO GENERALE PER PRELEVARE LA SETTIMANA DI FINE LAVORO
x_data = "cal_data = '" + V_DTFIN + "'"
Csql   = "select * from u_cal_la where " + x_data
IF !ExecCommand(Csql,"cux_cal_la")
   return(.f.)
ENDIF
SELECT CUX_CAL_LA
GO TOP
IF EOF()
   VVV_SETFIN = _V_SPRGAL
ELSE
   VVV_SETFIN = CAL_SETT
ENDIF
*=> DETERMINAZIONE DELLE SETTIMANE ELABORATE
IF VAL(SUBSTR(VVV_SETFIN,4,4)) = VAL(SUBSTR(VVV_SETINI,4,4))
   VVV_SETDIF = VAL(SUBSTR(VVV_SETFIN,1,2)) - VAL(SUBSTR(VVV_SETINI,1,2)) + 1
ELSE
   VVV_SETDIF = 53 - VAL(SUBSTR(VVV_SETINI,1,2)) + VAL(SUBSTR(VVV_SETINI,1,2))
ENDIF
IF VVV_SETDIF < V_SETIMP
ELSE
   VVV_VERIFICA = .T.
ENDIF
*=> FINE - GESTIONE DELLA PROGRAMMAZIONE SOLO NELLE SETTIMANE PREVISTE

RETURN


