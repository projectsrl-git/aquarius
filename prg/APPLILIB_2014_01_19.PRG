REPLACE STA_ALTCOM WITH 99999 - STA_ALTMAG		&& ALTEZZA COMPLEMENTATA A 99999 PER SORT ALTEZZA DISCENDENTE
REPLACE STA_VELLIN WITH V_VELIN
REPLACE STA_LUNPRG WITH V_LUPRG
REPLACE STA_MQPROG WITH V_MQPRG
REPLACE STA_ORELAV WITH V_HHLAV
REPLACE STA_DATINI WITH V_DTINI			
REPLACE STA_DATFIN WITH V_DTFIN		
REPLACE STA_NOTE   WITH V_NOTE		
REPLACE STA_CDDIBA WITH V_CDIBA
