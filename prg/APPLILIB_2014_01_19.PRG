         H_TIPO   = 'GIA'
         H_IMPE   = ""
         H_MAGSCA = M.ORD_MAGA
         H_MAGCAR = ""
         H_CODART = M.ORD_CODART
         H_TOPSCA = M.ORD_CAUS
         H_TOPCAR = ""
