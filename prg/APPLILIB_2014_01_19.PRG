***************************************************************************
PROCEDURE taglio_reports
***************************************************************************

RELEASE XXX_TEMCCG,XXX_TEMCCR
PUBLIC  XXX_TEMCCG,XXX_TEMCCR
XXX_TEMCCG = 0
XXX_TEMCCR = 0

V_NUTAG = 3
V_TECBI = 5
V_VETAG = 4
V_TEMCG = 0
V_TEMCR = 0

RELEASE V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
PUBLIC  V_ORELAV,V_DIFFERENZA,V_ORE,XX_ORAINI,XX_ORAFIN,V_PRIMAVOLTA
V_ORELAV     = 0
V_DIFFERENZA = 0
V_ORE        = 0
XX_ORAINI    = SPACE(08)
XX_ORAFIN    = SPACE(08)
V_PRIMAVOLTA = .T.

IF VVV_STOPPA
   XXX_TROV = .F.
   V_CDMAC    = 'TGS'
   V_DSMAC    = 'TAGLIO NON PROGRAMMATO'
   *=> Determinazione delle quantitŕ in MQ da tagliare (tutta la bobina in altezza)
   V_MQPRG = TROVA_MQ_DA_AL(V_ALMAG,V_LUPRG,1)
   SELECT CUR_TAGLIO
   V_MM = 0
   IF V_PROGRE = 1
      V_MM = V_MM + V_TEMCG
      XXX_TEMCCG = V_TEMCG
      V_MM = V_MM + V_TEMCR
      XXX_TEMCCR = V_TEMCR
   ENDIF
   *=> Determinazione delle ore necessarie alla lavorazione
   IF V_NUMTAG = 1
      V_SSLAV  = ((V_NRTAG + 2) * V_VETAG)		&& 2 TAGLI SONO LA CIMOSA
      V_MMLAV  = ROUND((V_SSLAV / 60),2)
   ELSE
      V_SSLAV  = V_VETAG
      V_MMLAV  = ROUND((V_SSLAV / 60),2)
   ENDIF
   V_MMLAV     = V_MM + V_MMLAV + V_TECBI
   V_HHLAV     = ROUND((V_MMLAV / 60),2)
   *=> Accesso alla tabella degli impegni di produzione per prelevare la data di inizio/fine lavoro
   *=> Da fare
   V_ORELAV     = V_HHLAV
   V_DIFFERENZA = 0
   V_ORE        = 0
   XX_ORAINI    = SPACE(08)
   XX_ORAFIN    = SPACE(08)
   IF EMPTY(ALLTRIM(_V_DATPRG)) .OR. _V_DATPRG = '  /  /    '
      _V_DATPRG = DTOC(DATE())
   ENDIF
   IF EMPTY(ALLTRIM(_V_DPRGDA))
      _V_DPRGDA = PUB_DATINI
   ENDIF
   IF RIBALTA2(_V_DPRGDA) < RIBALTA2(DTOC(DATE()))
      _V_DPRGDA = PUB_DATINI
   ENDIF
   V_DTINI      = PUB_DATINI
   V_DTFIN      = PUB_DATINI
   V_PRIMA      = .T.
ELSE
    *=> Assegnazione della macchina di produzione con una programmazione che prevede la saturazione delle capacitŕ
    *=> delle taglierine all'interno della stessa giornata (impegni su tutte le taglierine nel giorno, poi passa
    *=> ad impegnare il giorno/i successivi
    RELEASE V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
    PUBLIC  V_DATA,XXX_DATA,XXX_SETT,XXX_CDMAC,XXX_DSMAC,XXX_TROV,XXX_ORELAV,XXX_ORAINI
    V_CDMAC    = SPACE(03)
    V_DSMAC    = SPACE(50)
    V_DATA     = V_DTINI
    XXX_DATA   = V_DTINI
    XXX_SETT   = SPACE(07)
    XXX_CDMAC  = SPACE(03)
    XXX_DSMAC  = SPACE(50)
    XXX_TROV   = .F.
    XXX_ORELAV = 0
    XXX_ORAINI = SPACE(08)

    SELECT SETTPROD
    SET ORDER TO I_ORDINE
    GO TOP
    DO WHILE .T.

       IF EOF()
          SELECT * FROM SETTPROD WHERE SET_FATTO = .F. INTO CURSOR ANCORAUNO
          SELECT ANCORAUNO
          GO TOP
          IF EOF()
             VVV_STOPPA = .T.
          ENDIF
          EXIT
       ENDIF

       *=> By-passo la macchina+giorno giŕ elaborati o senza ore di lavoro da impegnare
       IF SET_FATTO
          SKIP +1
          LOOP
       ENDIF

       *=> Acquisizione delle capacitŕ della ribobinatrice
       x_clav = "cap_codlav = 'TAG'"
       x_cmac = "cap_codmac = '" + ALLTRIM(SET_CODICE) + "'"
       x_cond = x_clav + " and " + x_cmac
       Csql   = "select * from u_pro_ca where " + x_cond + " order by cap_codlav"
       IF !ExecCommand(Csql,"cux_pro_ca")
          return(.f.)
       ENDIF
       SELECT CUX_PRO_CA
       GO TOP
       IF EOF()
          SELECT SETTPROD
          SKIP +1
          LOOP
       ENDIF

       V_OKPASSA = .F.

       *=> LA TA1 (CAPACITA' NUMERO TAGLI = 1) HA LE SEGUENTI 2 POSSIBILITA' NON REGISTRATE IN TABELLA :
       *=> 1) FINO AD UNA ALTEZZA DI 500 MTL - TUTTI GLI SPESSORI
       *=> 2) FINO AD UNA ALTEZZA DI 1000 MTL - CON SPESSORE COMPRESO TRA 40 E 50
       *=> 3) FINO AD UNA ALTEZZA DI 1000 MTL - CON PIU' DI DUE BOBINE DA TAGLIARE (AGGIUNTO IN DATA 17/11/2004)

       IF CAP_NUMTAG = 1			&& PROBABILMENTE E' LA TA1
          IF V_ALMAG <= CAP_ALMAFN
             IF V_LUMAG < 501
                V_OKPASSA = .T.
             ELSE
                IF V_LUMAG < 1001
                   IF V_MYMAG > 39 .AND. V_MYMAG < 51
                      V_OKPASSA = .T.
                   ELSE
                      IF V_NRTAG > 2
                         V_OKPASSA = .T.
                      ENDIF
                   ENDIF
                ENDIF
             ENDIF
          ENDIF
          IF V_OKPASSA
          ELSE
             SELECT SETTPROD
             SKIP +1
             LOOP
          ENDIF
       ENDIF

       *=> Verifico che l'altezza della bobina da tagliare sia compatibile con la taglierina in linea
       IF V_ALMAG <= CAP_ALMAFN
       ELSE
          SELECT SETTPROD
          SKIP +1
          LOOP
       ENDIF

      *=> Spessore a zero sta ad indicare che trattasi di ordine film x imballo, ed in tal caso puň essere
      *=> programmata ssolo e soltanto sulla taglierina piccola - troncatrice (TG1)
      IF V_MYORD > 0
      ELSE
         IF CAP_CODMAC = 'TG1'
         ELSE
            SELECT SETTPROD
            SKIP +1
            LOOP
         ENDIF
      ENDIF


       SELECT SETTPROD
       XXX_CDMAC  = SET_CODICE
       XXX_DSMAC  = SET_DESCRI
       XXX_DATA   = RIBALTA2(SET_DATA)
       XXX_SETT   = SET_SETT
       XXX_ORELAV = SET_ORELAV
       XXX_ORAINI = SET_ORAINI

       *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
  	   SELECT CU_PRO_IM
	   SET FILTER TO
	   SET ORDER TO I_IMPEGNI
	   SEEK 'TAG' + XXX_CDMAC + RIBALTA2(XXX_DATA)
       IF FOUND()
       ELSE
          APPEND BLANK
		  REPLACE IMP_CODLAV WITH 'TAG'
		  REPLACE IMP_DESLAV WITH 'TAGLIO'
		  REPLACE IMP_CODMAC WITH XXX_CDMAC
		  REPLACE IMP_DESMAC WITH XXX_DSMAC
		  REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
		  REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
          REPLACE IMP_NRPRG1 WITH _V_NUMPRG
	      REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
	      REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
	      REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
	      REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
	      REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
	      REPLACE IMP_NRPRG2 WITH SPACE(06)
	      REPLACE IMP_DTPRG2 WITH SPACE(10)
	      REPLACE IMP_SDPRG2 WITH SPACE(07)
	      REPLACE IMP_SAPRG2 WITH SPACE(07)
	      REPLACE IMP_DDPRG2 WITH SPACE(10)
	      REPLACE IMP_DAPRG2 WITH SPACE(10)
	      REPLACE IMP_ORELAV WITH XXX_ORELAV
	      REPLACE IMP_OREIMP WITH 0
	      REPLACE IMP_QTAMQ  WITH 0
	      REPLACE IMP_QTAML  WITH 0
	      REPLACE IMP_QTAKG  WITH 0
	      REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
	      REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
	      REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
	      REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
	      REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
	      REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
	      REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
	      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
	      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
	      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
	      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
	      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
	      REPLACE IMP_FLGMOD WITH .F.
	      REPLACE IMP_ORAINI WITH XXX_ORAINI
	      REPLACE IMP_ORAFIN WITH XXX_ORAINI
          SELECT SETTPROD
          LOOP
       ENDIF

       *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
       *=> la macchina+data
       IF IMP_ORELAV > IMP_OREIMP
       ELSE
          SELECT SETTPROD
          REPLACE SET_FATTO WITH .T.
          SKIP +1
          LOOP
       ENDIF

       IF V_PRIMAVOLTA
          V_PRIMAVOLTA = .F.
          *=> Prelievo di dati dalla tabella delle capacitŕ delle macchine per determinare i tempi di lavoro
          x_clav = "cap_codlav = 'TAG'"
          x_cmac = "cap_codmac = '" + XXX_CDMAC + "'"
          x_cond = x_clav + " and " + x_cmac
          cSql   = "select * from u_pro_ca where " + x_cond
          IF !ExecCommand(cSql,"U_PRO_CA")
             return(.f.)
          ENDIF
          SELECT U_PRO_CA
          GO TOP
          IF EOF()
             SELECT SETTPROD
             SKIP +1
             LOOP
          ENDIF
          V_NUTAG = CAP_NUMTAG
          V_TECBI = CAP_TEMCBI
          V_VETAG = CAP_VELTAG
          V_TEMCG = CAP_TEMCCG
          V_TEMCR = CAP_TEMCCR
          *=> Determinazione delle quantitŕ in MQ da spalmare (tutta la bobina in altezza)
          V_MQPRG = TROVA_MQ_DA_AL(V_ALMAG,V_LUPRG,1)
          SELECT CUR_TAGLIO
          V_MM = 0
          IF V_PROGRE = 1
             V_MM = V_MM + V_TEMCG
             XXX_TEMCCG = V_TEMCG
             V_MM = V_MM + V_TEMCR
             XXX_TEMCCR = V_TEMCR
          ENDIF
          *=> Determinazione delle ore necessarie alla lavorazione
          IF V_NUMTAG = 1
             V_SSLAV  = ((V_NRTAG + 2) * V_VETAG)		&& 2 TAGLI SONO LA CIMOSA
             V_MMLAV  = ROUND((V_SSLAV / 60),2)
          ELSE
             V_SSLAV  = V_VETAG
             V_MMLAV  = ROUND((V_SSLAV / 60),2)
		  ENDIF
          V_MMLAV     = V_MM + V_MMLAV + V_TECBI
          V_HHLAV     = ROUND((V_MMLAV / 60),2)
          V_ORELAV    = V_HHLAV
          V_DIFFERENZA = 0
          V_ORE        = 0
          XX_ORAINI    = SPACE(08)
          XX_ORAFIN    = SPACE(08)
          IF EMPTY(ALLTRIM(_V_DATPRG)) .OR. _V_DATPRG = '  /  /    '
             _V_DATPRG = DTOC(DATE())
          ENDIF
          IF EMPTY(ALLTRIM(_V_DPRGDA))
             _V_DPRGDA = PUB_DATINI
          ENDIF
          IF RIBALTA2(_V_DPRGDA) < RIBALTA2(DTOC(DATE()))
             _V_DPRGDA = PUB_DATINI
          ENDIF
          V_DTINI      = PUB_DATINI
          V_DTFIN      = PUB_DATINI
          V_PRIMA      = .T.
          V_PRIMAEXIT  = .T.
       ENDIF

  	   SELECT CU_PRO_IM

       *=> Determino il tempo che č possibile impegnare per la giornata in questione
       V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP

       *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
   	   V_TRASF      = ((V_TOLFGG * 100) / 60) / 100

       *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
   	   IF V_DIFFERENZA > V_TRASF
   	   ELSE
     	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
     	     IF V_PRIMAEXIT
     	        V_PRIMAEXIT  = .F.
     	        V_PRIMAVOLTA = .T.
     	     ENDIF
             SELECT SETTPROD
             REPLACE SET_FATTO WITH .T.
             SKIP +1
             LOOP
   	      ENDIF
       ENDIF

       V_PRIMAEXIT = .F.

       *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
       *=> il lavoro
   	   IF V_ORELAV > V_DIFFERENZA
     	  IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
    	     V_ORELAV = V_ORELAV - V_DIFFERENZA
	         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
          ELSE	
	         REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
    	     V_ORELAV = 0
	      ENDIF
	   ELSE
	      REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
	      V_ORELAV = 0
	   ENDIF

       *=> Assegno la data di inizio/fine lavoro in cui sono arrivato
	   IF V_PRIMA
	      V_PRIMA = .F.
	      V_DTINI = XXX_DATA
	   ENDIF
	   V_DTFIN = XXX_DATA

       *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
       XXX_TROV  = .T.

       *=> Memorizzo i dati della programmazione
	   IF IMP_NRPRG1 = _V_NUMPRG
	   ELSE
	      REPLACE IMP_NRPRG2 WITH _V_NUMPRG
	      REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
	      REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
	      REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
	      REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
	      REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
	      REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
	      REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
	      REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
	      REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
	      REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
	   ENDIF

       *=> Aggiorno il flag di impegno elaborato (per il contraggiornamento in fase di registrazione)
	   REPLACE IMP_FLGMOD WITH .T.

       *=> Determino l'orario di inizio e fine lavoro
	   IF EMPTY(ALLTRIM(XX_ORAINI))
	      XX_ORAINI = IMP_ORAFIN
	   ENDIF
	   REPLACE IMP_ORAFIN WITH CALCOLAORA(IMP_ORAINI,IMP_OREIMP)
	   XX_ORAFIN = IMP_ORAFIN
       IF V_DTINI = V_DTFIN
          IF XX_ORAINI > XX_ORAFIN
             XX_ORAINI = IMP_ORAINI
          ENDIF
       ENDIF

       *=> Gestione del fine lavoro
	   IF V_ORELAV = 0
          IF IMP_ORELAV > IMP_OREIMP
          ELSE
             SELECT SETTPROD
             REPLACE SET_FATTO WITH .T.
          ENDIF
          EXIT
       ENDIF

       *=> Se la giornata č stata totalmente impegnata, ma restano ancora delle ore da impegnare, contraggiorno
       *=> la tabella per by-passare la macchina+data
       IF IMP_ORELAV > IMP_OREIMP
       ELSE
          SELECT SETTPROD
          REPLACE SET_FATTO WITH .T.
          SKIP +1
          LOOP
       ENDIF

       EXIT

    ENDDO

    IF V_ORELAV > 0
       IF VVV_STOPPA
          IF XXX_TROV
	   	      SELECT CU_CAL_LA
			  SET ORDER TO I_DATAMG
			  SET FILTER TO
			  SEEK RIBALTA2(PUB_DATFIN)
	  	      DO WHILE .T.
			     IF EOF()
			        EXIT
			     ENDIF
			     IF V_ORELAV > 0
			     ELSE
			        EXIT
			     ENDIF
			     IF CAL_LAVO
			     ELSE
			        SKIP +1
			        LOOP
			     ENDIF
			     IF CAL_ORELAV > 0
			     ELSE
			        SKIP +1
			        LOOP
			     ENDIF
	             IF CAL_DATAMG = RIBALTA2(PUB_DATFIN)
	                SKIP +1
	                LOOP
	             ENDIF
	             XXX_ORELAV = CAL_ORELAV
	             XXX_ORAINI = CAL_ORAINI
	             XXX_SETT   = CAL_SETT
	             XXX_DATA   = CAL_DATA
	             *=> Ricerca di un eventuale impegno precedente per la macchina selezionata per la giornata in questione
	  	         SELECT CU_PRO_IM
		         SET FILTER TO
		         SET ORDER TO I_IMPEGNI
		         SEEK 'TAG' + XXX_CDMAC + RIBALTA2(XXX_DATA)
	             IF FOUND()
	             ELSE
	                APPEND BLANK
			        REPLACE IMP_CODLAV WITH 'TAG'
			        REPLACE IMP_DESLAV WITH 'TAGLIO'
			        REPLACE IMP_CODMAC WITH XXX_CDMAC
	   		        REPLACE IMP_DESMAC WITH XXX_DSMAC
			        REPLACE IMP_SETIMP WITH RIBALTASET(XXX_SETT)
			        REPLACE IMP_DATIMP WITH RIBALTA2(XXX_DATA)
	                REPLACE IMP_NRPRG1 WITH _V_NUMPRG
		            REPLACE IMP_DTPRG1 WITH RIBALTA2(_V_DATPRG)
		            REPLACE IMP_SDPRG1 WITH RIBALTASET(_V_SPRGDA)
		            REPLACE IMP_SAPRG1 WITH RIBALTASET(_V_SPRGAL)
		            REPLACE IMP_DDPRG1 WITH RIBALTA2(_V_DPRGDA)
		            REPLACE IMP_DAPRG1 WITH RIBALTA2(_V_DPRGAL)
		            REPLACE IMP_NRPRG2 WITH SPACE(06)
		            REPLACE IMP_DTPRG2 WITH SPACE(10)
		            REPLACE IMP_SDPRG2 WITH SPACE(07)
		            REPLACE IMP_SAPRG2 WITH SPACE(07)
		            REPLACE IMP_DDPRG2 WITH SPACE(10)
		            REPLACE IMP_DAPRG2 WITH SPACE(10)
		            REPLACE IMP_ORELAV WITH XXX_ORELAV
		            REPLACE IMP_OREIMP WITH 0
		            REPLACE IMP_QTAMQ  WITH 0
		            REPLACE IMP_QTAML  WITH 0
		            REPLACE IMP_QTAKG  WITH 0
		            REPLACE INV_SETIMP WITH RIBALTASET(IMP_SETIMP)
		            REPLACE INV_DATIMP WITH RIBALTA2(IMP_DATIMP)
		            REPLACE INV_DTPRG1 WITH RIBALTA2(IMP_DTPRG1)
		            REPLACE INV_SDPRG1 WITH RIBALTASET(IMP_SDPRG1)
		            REPLACE INV_SAPRG1 WITH RIBALTASET(IMP_SAPRG1)
		            REPLACE INV_DDPRG1 WITH RIBALTA2(IMP_DDPRG1)
		            REPLACE INV_DAPRG1 WITH RIBALTA2(IMP_DAPRG1)
		            REPLACE INV_DTPRG2 WITH RIBALTA2(IMP_DTPRG2)
		            REPLACE INV_SDPRG2 WITH RIBALTASET(IMP_SDPRG2)
		            REPLACE INV_SAPRG2 WITH RIBALTASET(IMP_SAPRG2)
		            REPLACE INV_DDPRG2 WITH RIBALTA2(IMP_DDPRG2)
		            REPLACE INV_DAPRG2 WITH RIBALTA2(IMP_DAPRG2)
		            REPLACE IMP_FLGMOD WITH .F.
		            REPLACE IMP_ORAINI WITH XXX_ORAINI
		            REPLACE IMP_ORAFIN WITH XXX_ORAINI
	     	        SELECT CU_CAL_LA
	                LOOP
	             ENDIF
	             *=> Verifica se ci sono ore di lavoro residue da fare ed in caso negativo, contraggiorno la tabella per by-passare
	             *=> la macchina+data
	             IF IMP_ORELAV > IMP_OREIMP
	             ELSE
	     	        SELECT CU_CAL_LA
	                SKIP +1
	                LOOP
	             ENDIF
	             *=> Determino il tempo che č possibile impegnare per la giornata in questione
	             V_DIFFERENZA = IMP_ORELAV - IMP_OREIMP
	             *=> Determino il tempo (in centesimi di secondo), di tolleranza in piů/meno nella giornata lavorativa
	   	         V_TRASF      = ((V_TOLFGG * 100) / 60) / 100
	             *=> Gestisco il caso di tempo residuo da NON impegnare perchč vicino al fine giornata
	   	         IF V_DIFFERENZA > V_TRASF
	   	         ELSE
	     	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
	     	           SELECT CU_CAL_LA
	                   SKIP +1
	                   LOOP
	     	        ENDIF
	             ENDIF
	             *=> Determino le ore da impegnare considerando il tempo di tolleranza in piů ma solo se necessario a finire
	             *=> il lavoro
	   	         IF V_ORELAV > V_DIFFERENZA
	     	        IF V_ORELAV > (V_DIFFERENZA + V_TRASF)
	    	           V_ORELAV = V_ORELAV - V_DIFFERENZA
		               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_DIFFERENZA
	                ELSE	
		               REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
	    	           V_ORELAV = 0
		            ENDIF
		         ELSE
		            REPLACE IMP_OREIMP WITH IMP_OREIMP + V_ORELAV
		            V_ORELAV = 0
		         ENDIF
	             *=> Assegno la data di fine lavoro in cui sono arrivato
	     	     IF V_PRIMA
		            V_PRIMA = .F.
		            V_DTINI = XXX_DATA
		         ENDIF
		         V_DTFIN = XXX_DATA
	             *=> Inizializzo flag che mi indica all'uscita dal ciclo do while che ho individuato una macchina+data
	             XXX_TROV  = .T.
	             *=> Memorizzo i dati della programmazione
		         IF IMP_NRPRG1 = _V_NUMPRG
		         ELSE
		            REPLACE IMP_NRPRG2 WITH _V_NUMPRG
		            REPLACE IMP_DTPRG2 WITH RIBALTA2(_V_DATPRG)
		            REPLACE IMP_SDPRG2 WITH RIBALTASET(_V_SPRGDA)
		            REPLACE IMP_SAPRG2 WITH RIBALTASET(_V_SPRGAL)
		            REPLACE IMP_DDPRG2 WITH RIBALTA2(_V_DPRGDA)
		            REPLACE IMP_DAPRG2 WITH RIBALTA2(_V_DPRGAL)
