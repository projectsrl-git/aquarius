REPLACE STA_DESMAC WITH V_DSMAC
REPLACE STA_SETTDA WITH _V_SPRGDA
REPLACE STA_SETTAL WITH _V_SPRGAL
REPLACE STA_DATADA WITH _V_DPRGDA
REPLACE STA_DATAAL WITH _V_DPRGAL
REPLACE STA_NUMPRG WITH _V_NUMPRG
REPLACE STA_DATPRG WITH _V_DATPRG
REPLACE STA_MISTAG WITH V_MISTAG
REPLACE STA_CLIELA WITH V_CLIELA
REPLACE STA_TAGMIS WITH V_TAGMIS
REPLACE STA_PROGRE WITH V_PROGRE
REPLACE STA_TEMCCG WITH XXX_TEMCCG
REPLACE STA_TEMCCR WITH XXX_TEMCCR
REPLACE STA_SCARTO WITH V_SCARTO
REPLACE STA_ORAINI WITH XX_ORAINI
REPLACE STA_ORAFIN WITH XX_ORAFIN
REPLACE STA_SYSCLI WITH V_SYSCLI
REPLACE STA_FLGELI WITH SPACE(02)

IF VVV_STOPPA
   IF XXX_TROV
   ELSE
      REPLACE STA_DATINI WITH 'GG/MM/AAAA'			
      REPLACE STA_DATFIN WITH 'GG/MM/AAAA'		
      REPLACE STA_ORAINI WITH 'HH:MM:SS'
      REPLACE STA_ORAFIN WITH 'HH:MM:SS'
      RETURN
   ENDIF
