   REPLACE STA_SETTAL WITH _V_SPRGAL
   REPLACE STA_DATADA WITH _V_DPRGDA
   REPLACE STA_DATAAL WITH _V_DPRGAL
   SKIP +1
ENDDO

SELECT NOP_SPALMATURA
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   SCATTER MEMVAR MEMO
   SELECT CU_ORD_DL
   SET ORDER TO I_CODSYS
   SEEK M.SEL_CODSYS
   IF FOUND()
      REPLACE ORD_NRBSPD WITH ORD_NRBSPD + M.SEL_BOBPRG
      REPLACE ORD_QTASPD WITH ORD_QTASPD + M.SEL_QTAPRG
      REPLACE ORD_NRBOBX WITH ORD_NRBOBX - M.SEL_BOBPRG
      REPLACE ORD_QUANTX WITH ORD_QUANTX - M.SEL_BOBPRG
      REPLACE ORD_CODMAC WITH SPACE(03)
   ENDIF
   SELECT NOP_SPALMATURA
   SKIP +1
ENDDO

