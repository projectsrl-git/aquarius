         REPLACE ADE_QTANEC WITH M.MAG_COMODO
      ELSE
         REPLACE ADE_QTANEC WITH V_QTASCA
      ENDIF
      REPLACE ADE_CODMAG WITH M.MAG_CODMAG

      V_QTACOM = ADE_QTANEC

      SELECT G_MAG_GG
      REPLACE MAG_COMODO WITH MAG_COMODO - V_QTACOM

      SELECT STA_RAPPROD
      REPLACE NUD_CODFOR WITH SPACE(10)
      REPLACE NUD_DESFOR WITH SPACE(50)
