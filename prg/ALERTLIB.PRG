GO TOP

IF !EOF()
	_LIBERA=LIBERA 
	_DESTINATARI = TOKENIZER(_LIBERA,"DESTINATARI")
ENDIF

SELECT &_eNomeCursorSql
USE

SELECT(_ACT_SEL_DESTINATARI_EVENTO)
RETURN _DESTINATARI




***********************************
PROCEDURE GRUPPO_EVENTO
***********************************

LPARAMETERS _TIPOLOGIA

LOCAL _GRUPPO,_STR_GRUPPO,_ACT_SEL_GRUPPO_EVENTO,_eSql,_LIBERA

_STR_GRUPPO=""
_GRUPPO=""
_ACT_SEL_GRUPPO_EVENTO= SELECT()


*** CAMBIA STATO SU DB
_eSql=""
_eNomeCursorSql="_TEMP"+SYS(2015)
TEXT TO _eSql NOSHOW

	SELECT LIBERA FROM PARA WHERE CODICE ='TEV<<_TIPOLOGIA>>' 
		
ENDTEXT

IF !ExecPreparedCommand(_eSql,_eNomeCursorSql)
	SELECT(_ACT_SEL_GRUPPO_EVENTO)
