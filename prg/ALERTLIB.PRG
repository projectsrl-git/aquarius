**********************************************************************
PROCEDURE DEFINIZIONE_COSTANTI
**************************************************************
RELEASE EVENTO_INVIATO,EVENTO_VISUALIZZATO,EVENTO_POSTICIPATO,EVENTO_ELIMINATO
PUBLIC EVENTO_INVIATO,EVENTO_VISUALIZZATO,EVENTO_POSTICIPATO,EVENTO_ELIMINATO

EVENTO_INVIATO="INVIATO"
EVENTO_VISUALIZZATO="VISUALIZZATO"
EVENTO_POSTICIPATO="POSTICIPATO"
EVENTO_ELIMINATO="ELIMINATO"  

RETURN

**********************************************************************
* DEFINIZIONE CLASSE PER TIMER DI CONTROLLO PER VISUALIZZAZIONE ALERTS

DEFINE CLASS AqVerificaAlert AS Timer

	PROCEDURE Timer
		
		**=> ERASMO - INIZIO 12/03/2015
		*** VARIABILE PER ABILITARE/DISABILITARE TEMPORANEAMENTE LE ESECUZIONI VERSO DB SQL DA PARTE DEGLI ALERT, QUESTO PER EVITARE
		*** ACCAVALLAMENTI DI ESECUZIONI CHE RICHIEDONO Asynchronous MODE .T. (GLI ALERT RICHIEDONO LA NORMALE Asynchronous MODE .F.)
		*** COME AD ESEMPIO LE ESECUZIONI CON POSSIBILITA' DI ANNULLARE LA QUERY SQL (FORM\SQLEXECUTION_CANSTOP)
		IF !PUB_ABILITA_AqVerificaAlert
			RETURN .F.
		ENDIF
		**=> ERASMO - FINE 12/03/2015

		DO VISUALIZZA_ALERT
		
	ENDPROC
	
ENDDEFINE

	
**********************************************************************
PROCEDURE VERIFICA_ALERT
**********************************************************************
* LA PROCEDURA NON CONSIDERA GLI EVENTI EMAIL IN QUANTO GESTITI SEPARATAMENTE
*!*	LPARAMETERS _par_waitmsg

*!*	IF PCOUNT() > 0
*!*	ELSE
*!*		_par_waitmsg = .T.
*!*	ENDIF


LOCAL _ACT_SEL,_eSql
_ACT_SEL = SELECT()

IF TYPE("VARIABILE_TEST_VERIFICA_ALERT") = "L"
ELSE
	RELEASE VARIABILE_TEST_VERIFICA_ALERT
	PUBLIC VARIABILE_TEST_VERIFICA_ALERT
	VARIABILE_TEST_VERIFICA_ALERT = .T.
ENDIF


IF VARIABILE_TEST_VERIFICA_ALERT


	**=> SERGIO/ERASMO - INIZIO 20/02/2014
	*** MODIFICA PER PERDITA VARIABILE PUBBLICA PUB_CODOPE (BUCO SOFTWARE)
	IF TYPE("PUB_CODOPE") <> "C"
	    *WAIT WINDOWS "BBBBACONE-01-"
		RELEASE PUB_CODOPE
		PUBLIC PUB_CODOPE
		PUB_CODOPE = SAVE_PUB_CODOPE
	ENDIF
	**=> SERGIO/ERASMO - FINE 20/02/2014

	_eSql=""
	_eNomeCursorSql="_TEMP_LOG_EVENTI"
	
	**=> ERASMO - INIZIO 12/03/2015
	IF USED(_eNomeCursorSql)
	    SELECT &_eNomeCursorSql
	    USE
	ENDIF
	**=> ERASMO - FINE 12/03/2015

	TEXT TO _eSql NOSHOW

		SELECT COUNT(*) as CONTA_EVENTI FROM LOG_EVENTI WHERE STATO_EVENTO='' AND RUOLO_DEST LIKE '%<<PUB_CODOPE>>%' AND COD_USER NOT LIKE '%<<PUB_CODOPE>>%'
			
	ENDTEXT

	
	IF !ExecPreparedCommand(_eSql,_eNomeCursorSql)
		return(.F.)
	ENDIF

ENDIF



SELECT(_ACT_SEL)
	
ENDPROC


**********************************************************************
PROCEDURE VISUALIZZA_POPUP_EVENTO
**********************************************************************

SELECT _TEMP_LOG_EVENTI

GO TOP

DO WHILE !EOF()
	_x_titolo = "Attenzione"
	_x_messaggio = DESCRIZIONE+CHR(13)+CHR(13)+"("+ALLTRIM(COD_USER)+") - "+RIBALTA2(DATA_EVENTO)+" - "+ORA_EVENTO
	
	
	RELEASE PUB_POSPONI_ALERT,PUB_ELIMINA_ALERT
	PUBLIC PUB_POSPONI_ALERT,PUB_ELIMINA_ALERT
	
	PUB_POSPONI_ALERT=.F.
	PUB_ELIMINA_ALERT=.F.
	
	DO FORM FORM\ALERT_TEST WITH _x_titolo,_x_messaggio LINKED
	
	DO DOPO_VISUALIZZAZIONE_EVENTO
	
	SELECT _TEMP_LOG_EVENTI
	SKIP
ENDDO

RETURN


**********************************************************************
PROCEDURE DOPO_VISUALIZZAZIONE_EVENTO
**********************************************************************
LOCAL _ACT_SEL_DOPO_VISUALIZZAZIONE_EVENTO,_ID_EVENTO,_eSql

_ACT_SEL_DOPO_VISUALIZZAZIONE_EVENTO= SELECT()

SELECT _TEMP_LOG_EVENTI

_ID_EVENTO=ID_EVENTO

*** POSPONI ALERT
IF PUB_POSPONI_ALERT

	_eSql=""
	_eNomeCursorSql="_TEMP_UPDATE_EVENTI"
	TEXT TO _eSql NOSHOW

		UPDATE LOG_EVENTI SET STATO_EVENTO='POSTICIPATO' WHERE ID_EVENTO='<<_ID_EVENTO>>'
			
	ENDTEXT

	IF !ExecPreparedCommand(_eSql,_eNomeCursorSql)
		return(.F.)
	ENDIF
	
	SELECT(_ACT_SEL_DOPO_VISUALIZZAZIONE_EVENTO)
	RETURN 
	
ENDIF

*** ELIMINA ALERT
IF PUB_ELIMINA_ALERT

	_eSql=""
	_eNomeCursorSql="_TEMP_UPDATE_EVENTI"
	TEXT TO _eSql NOSHOW

		UPDATE LOG_EVENTI SET STATO_EVENTO='ELIMINATO' WHERE ID_EVENTO='<<_ID_EVENTO>>'
			
	ENDTEXT

	IF !ExecPreparedCommand(_eSql,_eNomeCursorSql)
		return(.F.)
	ENDIF
	
	SELECT(_ACT_SEL_DOPO_VISUALIZZAZIONE_EVENTO)
	RETURN 
	
ENDIF


SELECT(_ACT_SEL_DOPO_VISUALIZZAZIONE_EVENTO)

RETURN 


***********************************
PROCEDURE SEND_EVENTO_COMPLETO
***********************************

PARAMETERS _DESCRIZIONE,_TIPO_EVENTO,_MITTENTE,_DESTINATARI,_GRUPPO_EVENTO,_CAMPO_MODIFICATO,_VALORE_PREC,_VALORE_SUCC,_RISPOSTA,_ID_EVENTO_SUCC

LOCAL _DATA_EVENTO,_ORA_EVENTO,_STATO_EVENTO,_COD_USER,_CURSOR,_eSql,nRows, IDX_DEST ,_ID_EVENTO 
LOCAL ARRAY A_DESTINATARI(100)

IF !USED("TEMP_EVENTI")
	_eSql="SELECT * FROM LOG_EVENTI WHERE 1=0"
	_CURSOR=SYS(2015)+"_LOG_EVENTI"
	IF !ExecCommand("SELECT * FROM LOG_EVENTI WHERE 0=1",_CURSOR)
	   return(.f.)
	ENDIF
	SELECT &_CURSOR 
	AFIELDS(_FIELDS)
	CREATE CURSOR TEMP_EVENTI FROM ARRAY _FIELDS
ENDIF

nRows = ALINES(A_DESTINATARI, STRTRAN(_DESTINATARI,",",CHR(13)))


FOR IDX_DEST = 1 TO nRows 

	SELECT TEMP_EVENTI
	APPEND BLANK

	_ID_EVENTO=SYS(2015) 
	
	REPLACE ID_EVENTO 			WITH _ID_EVENTO 
	REPLACE COD_USER 			WITH _MITTENTE
	REPLACE GRUPPO_EVENTO 		WITH _GRUPPO_EVENTO
	REPLACE DESCRIZIONE 		WITH _DESCRIZIONE
	REPLACE TIPO_EVENTO 		WITH _TIPO_EVENTO
	REPLACE DATA_EVENTO 		WITH RIBALTA2(DTOC(DATE()))
	REPLACE ORA_EVENTO 			WITH TIME()
	REPLACE RUOLO_DEST 			WITH A_DESTINATARI[IDX_DEST]
	REPLACE CAMPO_MODIFICATO 	WITH _CAMPO_MODIFICATO
	REPLACE VALORE_PREC 		WITH _VALORE_PREC
	REPLACE VALORE_SUCC 		WITH _VALORE_SUCC
	REPLACE RISPOSTA	 		WITH _RISPOSTA
	IF _RISPOSTA 
		REPLACE ID_EVENTO_SUCC 		WITH _ID_EVENTO_SUCC	
	ELSE
		REPLACE ID_EVENTO_SUCC 		WITH ""	
	ENDIF

NEXT

SELECT TEMP_EVENTI
GO TOP
IF !ExecRW('','LOG_EVENTI','I','','TEMP_EVENTI')
   return(.f.)
ENDIF

SELECT TEMP_EVENTI
ZAP


***********************************
PROCEDURE SEND_EVENTO
***********************************

PARAMETERS _DESCRIZIONE,_TIPO_EVENTO,_RUOLO_DESTINAZIONE,_GRUPPO_EVENTO,_CAMPO_MODIFICATO,_VALORE_PREC,_VALORE_SUCC,_RISPOSTA,_ID_EVENTO_SUCC

LOCAL _ID_EVENTO,_MITTENTE

_MITTENTE = PUB_CODOPE

SEND_EVENTO_COMPLETO(_DESCRIZIONE,_TIPO_EVENTO,_MITTENTE,_RUOLO_DESTINAZIONE,_GRUPPO_EVENTO,_CAMPO_MODIFICATO,_VALORE_PREC,_VALORE_SUCC,_RISPOSTA,_ID_EVENTO_SUCC)

RETURN


***********************************
PROCEDURE SEND_EVENTO_PARAMETRIZZATO
***********************************

PARAMETERS _DESCRIZIONE,_TIPO_EVENTO,_CAMPO_MODIFICATO,_VALORE_PREC,_VALORE_SUCC,_RISPOSTA,_ID_EVENTO_SUCC

LOCAL _ID_EVENTO,_MITTENTE,_RUOLO_DESTINAZIONE,_GRUPPO_EVENTO

_RUOLO_DESTINAZIONE=DESTINATARI_EVENTO(_TIPO_EVENTO)
IF EMPTY(_RUOLO_DESTINAZIONE)
	*MESSAGEBOX("Non č presente la configurazione per il tipo evento "+_TIPO_EVENTO,48,"Attenzione")
	RETURN
ENDIF

_GRUPPO_EVENTO=GRUPPO_EVENTO(_TIPO_EVENTO)
IF EMPTY(_GRUPPO_EVENTO)
	*MESSAGEBOX("Non č presente la configurazione per il tipo evento "+_TIPO_EVENTO,48,"Attenzione")
	RETURN
ENDIF

_MITTENTE = PUB_CODOPE

SEND_EVENTO_COMPLETO(_DESCRIZIONE,_TIPO_EVENTO,_MITTENTE,_RUOLO_DESTINAZIONE,_GRUPPO_EVENTO,_CAMPO_MODIFICATO,_VALORE_PREC,_VALORE_SUCC,_RISPOSTA,_ID_EVENTO_SUCC)

RETURN



***********************************
PROCEDURE VISUALIZZA_ALERT
***********************************
LOCAL _ACT_SEL_VISUALIZZA_ALERT,_LAST_RUN
_ACT_SEL_VISUALIZZA_ALERT = SELECT()


*!*	IF TYPE("PUB_ALERT_CONTA_SECONDI") = "N"
*!*	ELSE
*!*		RELEASE PUB_ALERT_CONTA_SECONDI
*!*		PUBLIC PUB_ALERT_CONTA_SECONDI
*!*		PUB_ALERT_CONTA_SECONDI =0
*!*	ENDIF

*!*	_LAST_RUN=PUB_ALERT_CONTA_SECONDI 

*!*	IF INT(SECONDS()) - _LAST_RUN < 60
*!*		SELECT(_ACT_SEL_VISUALIZZA_ALERT)
*!*		RETURN
*!*	ENDIF

*!*	PUB_ALERT_CONTA_SECONDI = INT(SECONDS())
*!*		
*!*	DO VERIFICA_ALERT

*!*	SELECT _TEMP_LOG_EVENTI
*!*	GO TOP 

*!*	_CONTA_EVENTI=0


*!*	DO WHILE !EOF()

*!*		ZTA.Command10.Visible= .T.
*!*		ZTA.Command10.Caption=ALLTRIM(STR(CONTA_EVENTI))

*!*		SELECT _TEMP_LOG_EVENTI
*!*		SKIP
*!*	ENDDO


*!*	SELECT _TEMP_LOG_EVENTI
*!*	USE

*!*	SELECT(_ACT_SEL_VISUALIZZA_ALERT)

**=> ERASMO - INIZIO 19/02/2014
*** SE ESISTE ALMENO UN EVENTO, VISUALIZZA IL PULSANTE DEGLI EVENTI SULLA TOOLBAR, ALTRIMENTI LO NASCONDE
*** E IN CASO DI AUMENTO DEGLI EVENTI RISPETTO A QUELLI PRECEDENTI, MOSTRA UN MESSAGGIO IN BASSO A DESTRA
LOCAL _conta_eventi,_nessun_evento,_old_n_eventi
_conta_eventi = 0
_nessun_evento = .T.
_old_n_eventi = 0

DO VERIFICA_ALERT

**=> ERASMO - INIZIO 12/03/2015
IF USED("_TEMP_LOG_EVENTI")
ELSE
	RETURN .F.
ENDIF
**=> ERASMO - FINE 12/03/2015

SELECT _TEMP_LOG_EVENTI
GO TOP
IF !EOF()
	_conta_eventi = CONTA_EVENTI
ENDIF
USE

SELECT(_ACT_SEL_VISUALIZZA_ALERT)

IF _conta_eventi > 0
	_nessun_evento = .F.
	_old_n_eventi = VAL(ZTA.Command10.Caption)
	ZTA.Command10.Caption = ALLTRIM(STR(_conta_eventi,10,0))
	ZTA.Command10.Visible = .T.
	ZTA.REFRESH
	IF _conta_eventi > _old_n_eventi
		LOCAL _x_titolo,_x_messaggio
		_x_titolo = "Attenzione"
		IF _conta_eventi - _old_n_eventi > 1
			_x_messaggio = "Hai " + ALLTRIM(STR(_conta_eventi - _old_n_eventi,10,0)) + " eventi non ancora visualizzati"
		ELSE
			_x_messaggio = "Hai un evento non ancora visualizzato"
		ENDIF
		RELEASE _X_VISUALIZZA_EVENTI
		PUBLIC _X_VISUALIZZA_EVENTI
		_X_VISUALIZZA_EVENTI = .F.
		DO FORM FORM\ALERT_POPUP WITH _x_titolo,_x_messaggio LINKED
		IF _X_VISUALIZZA_EVENTI
			ZTA.Command10.Click
		ENDIF
	ENDIF
ELSE
	ZTA.Command10.Visible = .F.
	ZTA.Command10.Caption = ""
	ZTA.REFRESH
ENDIF
**=> ERASMO - FINE 19/02/2014


RETURN



***********************************
PROCEDURE CAMBIA_STATO_EVENTO
***********************************

LPARAMETERS _ID_EVENTO,_NUOVO_STATO

LOCAL _ACT_SEL_CAMBIA_STATO_EVENTO

_ACT_SEL_CAMBIA_STATO_EVENTO= SELECT()


*** CAMBIA STATO SU DB
_eSql=""
_eNomeCursorSql="_TEMP_UPDATE_EVENTI"
TEXT TO _eSql NOSHOW

	UPDATE LOG_EVENTI SET STATO_EVENTO='<<_NUOVO_STATO>>' WHERE ID_EVENTO='<<_ID_EVENTO>>'
		
ENDTEXT

IF !ExecPreparedCommand(_eSql,_eNomeCursorSql)
	
	SELECT(_ACT_SEL_CAMBIA_STATO_EVENTO)
	return(.F.)
ENDIF

RETURN




***********************************
PROCEDURE DESTINATARI_EVENTO
***********************************

LPARAMETERS _TIPOLOGIA

LOCAL _DESTINATARI,_ACT_SEL_DESTINATARI_EVENTO,_eSql,_LIBERA

_DESTINATARI=""

_ACT_SEL_DESTINATARI_EVENTO= SELECT()


*** CAMBIA STATO SU DB
_eSql=""
_eNomeCursorSql="_TEMP"+SYS(2015)
TEXT TO _eSql NOSHOW

	SELECT LIBERA FROM PARA WHERE CODICE ='TEV<<_TIPOLOGIA>>' 
		
ENDTEXT

IF !ExecPreparedCommand(_eSql,_eNomeCursorSql)
	SELECT(_ACT_SEL_DESTINATARI_EVENTO)
	return(.F.)
ENDIF


