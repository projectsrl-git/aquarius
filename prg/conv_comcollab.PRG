PUBLIC Y_CAMPO,V_CAMPO,_CTR
Y_CAMPO = ""
V_CAMPO = ""
_CTR    = 0

CREATE CURSOR TRANSITO (TRA_RECORD C(250))

SELECT TRANSITO
APPEND FROM &V_PATH SDF

*SELECT TRANSITO  
*gcTable = GETFILE('', 'Seleziona file compensi mensili collaboratori da convertire', 'Converti',0)
*IF empty(gcTable) .or. gcTable = ""
*   =MESSAGEBOX("Nessun file selezionato, operazione abbandonata",62,"ATTENZIONE")
*   RETURN
*ENDIF
*SELECT TRANSITO
*APPEND FROM &gcTable SDF

SELECT TRANSITO
GO TOP

DELETE FOR SUBSTR(TRA_RECORD,2,7) = "Azienda"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,3,30) = SPACE(30)  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,21,2) = "Da"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,21,10) = "Definitiva"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,21,6) = "Valori"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,4) = "Anno"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,19,7) = "Credito"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,28,5) = "Lordo"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,15) = "in Associazione"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,9) = "in Prest."  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,5) = "Total"  ALL
GO TOP

V_CONTA = 0

SELECT TRANSITO
GO TOP

M.PER_CODSOC = PUB_CODSOC

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF SUBSTR(TRA_RECORD,5,1) = ' '
   ELSE
      M.PER_CODPDV = SUBSTR(TRA_RECORD,3,3)
      PUB_LNO      = 3
      M.PER_CODPDV = TRC(PUB_LNO,ALLTRIM(M.PER_CODPDV))
      M.PER_DESPDV = ALLTRIM(SUBSTR(TRA_RECORD,7,30))
      M.PER_DESPDV = UPPER(M.PER_DESPDV)
      M.PER_DESPDV = APITOSPA(M.PER_DESPDV)
      SKIP +1
      LOOP
   ENDIF

   IF SUBSTR(TRA_RECORD,5,1) = ' '
      IF SUBSTR(TRA_RECORD,3,1) <> ' ' .AND. SUBSTR(TRA_RECORD,4,1) <> ' '
      ELSE
         M.PER_CODICE = ALLTRIM(M.PER_CODPDV) + ALLTRIM(SUBSTR(TRA_RECORD,1,5))
         M.PER_RAGSOC = ALLTRIM(SUBSTR(TRA_RECORD,7,30))
         M.PER_RAGSOC = UPPER(M.PER_RAGSOC)
         M.PER_RAGSOC = APITOSPA(M.PER_RAGSOC)
         SKIP +1
         LOOP
      ENDIF
   ENDIF
   
   M.PER_ANNO   = ALLTRIM(SUBSTR(TRA_RECORD,1,4))
   M.PER_MESE   = SUBSTR(TRA_RECORD,11,2)
   IF SUBSTR(M.PER_MESE,1,1) = ' '
      M.PER_MESE = '0' + SUBSTR(M.PER_MESE,2,1)
   ENDIF

   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,23,10))
   DO TOGLI_PUNTI
   M.PER_COMLOR = VAL(ALLTRIM(Y_CAMPO))

   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,36,10))
   DO TOGLI_PUNTI
   M.PER_VARLOR = VAL(ALLTRIM(Y_CAMPO))

   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,47,5))
   DO TOGLI_PUNTI
   M.PER_PERABB = VAL(ALLTRIM(Y_CAMPO))

   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,53,5))
   DO TOGLI_PUNTI
   M.PER_PERRAC = VAL(ALLTRIM(Y_CAMPO))

   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,63,10))
   DO TOGLI_PUNTI
   M.PER_RITENU = VAL(ALLTRIM(Y_CAMPO))

   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,76,10))
   DO TOGLI_PUNTI
   M.PER_VARNET = VAL(ALLTRIM(Y_CAMPO))

   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,91,10))
   DO TOGLI_PUNTI
   M.PER_NETTO  = VAL(ALLTRIM(Y_CAMPO))

   M.PER_FLAG   = ALLTRIM(SUBSTR(TRA_RECORD,102,1))

   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,108,10))
   DO TOGLI_PUNTI
   M.PER_RETBAS  = VAL(ALLTRIM(Y_CAMPO))

   M.PER_CODCON = ALLTRIM(SUBSTR(TRA_RECORD,119,7))
   M.PER_DSCONT = ALLTRIM(SUBSTR(TRA_RECORD,127,27))
   M.PER_DSCONT = UPPER(M.PER_DSCONT)
   M.PER_DSCONT = APITOSPA(M.PER_DSCONT)
   M.PER_TIPCON = ALLTRIM(SUBSTR(TRA_RECORD,150,4))
   M.PER_TIPCON = UPPER(M.PER_TIPCON)
   M.PER_TIPCON = APITOSPA(M.PER_TIPCON)

   DO GESTIONE_COM

   SELECT TRANSITO      
   SKIP +1

ENDDO

cSql = "select * from u_cnt_an where cnt_tipo = 'CO2'"
IF !ExecRW(cSql,"U_CNT_AN","R")
   return(.f.)
ENDIF
SELECT U_CNT_AN
REPLACE CNT_DATFIN WITH RIBALTA2(DTOC(DATE()))
REPLACE CNT_ORAFIN WITH TIME()
REPLACE CNT_NUMREC WITH V_CONTA
IF !ExecRW(cSql,"U_CNT_AN","W")
   return(.f.)
ENDIF

=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

RETURN


*********************
PROCEDURE TOGLI_PUNTI
*********************

YY      = LEN(V_CAMPO)
XX      = 1
Y_CAMPO =  ' '
DO WHILE .T.
   IF XX > YY
      EXIT
   ENDIF
   IF SUBSTR(V_CAMPO,XX,1) = '.' 
   ELSE
      Y_CAMPO = Y_CAMPO + SUBSTR(V_CAMPO,XX,1) 
   ENDIF
   XX = XX + 1
ENDDO

RETURN


**********************
PROCEDURE GESTIONE_COM
**********************

v_seek   = ALLTRIM(M.PER_CODCON)
v_chiave = "con_codice"
cSql     = "select * from u_con_pe where " + v_chiave + " = '" + v_seek + "'"
IF !ExecRW(cSql,"U_CON_PE","R")
   return(.f.)
ENDIF
SELECT U_CON_PE
IF RECCOUNT() <> 0
   M.PER_PFTCON = CON_SIGLA
ELSE
   APPEND BLANK
   REPLACE CON_CODICE WITH M.PER_CODCON
   REPLACE CON_DESCRI WITH M.PER_DSCONT
   M.PER_PFTCON = SUBSTR(M.PER_CODCON,4,2)
   REPLACE CON_SIGLA  WITH M.PER_PFTCON
   IF M.PER_TIPCON = 'P.O.'
      REPLACE CON_TIPCON WITH '004'
      REPLACE CON_DESCON WITH "PRESTAZIONE D^OPERA"
   ELSE
      REPLACE CON_TIPCON WITH '002'
      REPLACE CON_DESCON WITH "ASSOCIATO"
   ENDIF
   REPLACE CON_COMLOR WITH M.PER_COMLOR
ENDIF
IF !ExecRW(cSql,"U_CON_PE","W")
   return(.f.)
ENDIF

x_soci = "per_codsoc = '" + ALLTRIM(M.PER_CODSOC) + "'"
x_codi = "per_codice = '" + ALLTRIM(M.PER_CODICE) + "'"
x_cond = x_soci + " and " + x_codi
cSql   = "select * from u_per_an where " + x_cond + " order by per_codsoc,per_codice"
IF !ExecRW(cSql,"u_per_an","R")
   return
ENDIF
SELECT u_per_an
IF EOF()
   m.id_unique = ""
   APPEND BLANK
   REPLACE PER_CODSOC WITH M.PER_CODSOC
   REPLACE PER_CODICE WITH M.PER_CODICE
   REPLACE PER_RAGSOC WITH M.PER_RAGSOC
   REPLACE PER_INDIRI WITH SPACE(100)
   REPLACE PER_LOCALI WITH SPACE(100)
   REPLACE PER_CAP    WITH SPACE(5)
   REPLACE PER_PROVIN WITH SPACE(2)
   REPLACE PER_TEL    WITH SPACE(20)
   REPLACE PER_CELL   WITH SPACE(20)
   REPLACE PER_FAX    WITH SPACE(20)
   REPLACE PER_EMAIL  WITH SPACE(50)
   REPLACE PER_TIPCON WITH '002'
   REPLACE PER_DESCON WITH "ASSOCIATO"
   REPLACE PER_DATCON WITH SPACE(10)
   REPLACE PER_ORELAV WITH 0
   REPLACE PER_CODFIS WITH SPACE(16)
   REPLACE PER_PARIVA WITH SPACE(11)
   REPLACE PER_TIPPER WITH SPACE(1)
   REPLACE PER_CODPDV WITH M.PER_CODPDV
   REPLACE PER_DESPDV WITH M.PER_DESPDV
   REPLACE PER_NOTGEN WITH SPACE(10)
   REPLACE PER_CODCON WITH SPACE(07)
   REPLACE PER_DSCONT WITH SPACE(50)
   REPLACE PER_DATINI WITH SPACE(10)
   REPLACE PER_DATFIN WITH SPACE(10)
   REPLACE PER_CONTO  WITH SPACE(13)
   REPLACE PER_COMLOR WITH 0
   REPLACE PER_RITACC WITH 0
   REPLACE PER_PERCON WITH 0
   REPLACE PER_NOTCON WITH SPACE(10)
   REPLACE PER_PFTCON WITH SPACE(2)
ENDIF
IF M.PER_TIPCON = 'P.O.'
   REPLACE PER_TIPCON WITH '004'
   REPLACE PER_DESCON WITH "PRESTAZIONE D^OPERA"
ENDIF
REPLACE PER_CODCON WITH M.PER_CODCON
REPLACE PER_DSCONT WITH M.PER_DSCONT
REPLACE PER_COMLOR WITH M.PER_COMLOR
REPLACE PER_RITACC WITH M.PER_PERRAC
REPLACE PER_PFTCON WITH M.PER_PFTCON
IF !ExecRW(cSql,"u_per_an","W")
   return
ENDIF

x_soci = "per_codsoc = '" + ALLTRIM(M.PER_CODSOC) + "'"
x_codi = "per_codice = '" + ALLTRIM(M.PER_CODICE) + "'"
x_cpdv = "per_codpdv = '" + ALLTRIM(M.PER_CODPDV) + "'"
x_anno = "per_anno = '" + ALLTRIM(M.PER_ANNO) + "'"
x_mese = "per_mese = '" + ALLTRIM(M.PER_MESE) + "'"
x_cond = x_soci + " and " + x_codi + " and " + x_cpdv + " and " + x_anno + " and " + x_mese
cSql   = "select * from u_per_co where " + x_cond + " order by per_codsoc,per_codice,per_codpdv,per_anno,per_mese"
IF !ExecRW(cSql,"u_per_co","R")
   return
ENDIF
SELECT u_per_co
IF EOF()
   m.id_unique = ""
   APPEND BLANK
ENDIF
REPLACE PER_CODSOC WITH M.PER_CODSOC
REPLACE PER_CODICE WITH M.PER_CODICE
REPLACE PER_RAGSOC WITH M.PER_RAGSOC
REPLACE PER_CODPDV WITH M.PER_CODPDV
REPLACE PER_DESPDV WITH M.PER_DESPDV
REPLACE PER_ANNO   WITH M.PER_ANNO
REPLACE PER_MESE   WITH M.PER_MESE
REPLACE PER_COMLOR WITH M.PER_COMLOR
REPLACE PER_VARLOR WITH M.PER_VARLOR
REPLACE PER_PERABB WITH M.PER_PERABB
REPLACE PER_PERRAC WITH M.PER_PERRAC
REPLACE PER_RITENU WITH M.PER_RITENU
REPLACE PER_VARNET WITH M.PER_VARNET
REPLACE PER_NETTO  WITH M.PER_NETTO
REPLACE PER_FLAG   WITH M.PER_FLAG
REPLACE PER_RETBAS WITH M.PER_RETBAS
REPLACE PER_CODCON WITH M.PER_CODCON
REPLACE PER_DSCONT WITH M.PER_DSCONT
REPLACE PER_TIPCON WITH M.PER_TIPCON
REPLACE SELEZIONE  WITH SPACE(10)
REPLACE PER_PAGATO WITH .T.
REPLACE PER_COGE   WITH .T.
REPLACE PER_COGEAS WITH .T.
REPLACE PER_DATASS WITH SPACE(10)
IF !ExecRW(cSql,"u_per_co","W")
   return
ENDIF

V_CONTA = V_CONTA + 1

_CTR = _CTR +1
WAIT WINDOWS "RECORDS SCRITTI : "+STR(_CTR,10,0) NOWAIT

RETURN