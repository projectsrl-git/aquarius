PUBLIC Y_CAMPO,V_CAMPO,_CTR
Y_CAMPO = ""
V_CAMPO = ""
_CTR    = 0

CREATE CURSOR TRANSITO (TRA_RECORD C(200))

SELECT TRANSITO
APPEND FROM &V_PATH SDF

*SELECT TRANSITO  
*gcTable = GETFILE('', 'Seleziona file piano mdei conti da convertire', 'Converti',0)
*IF empty(gcTable) .or. gcTable = ""
*   =MESSAGEBOX("Nessun file selezionato, operazione abbandonata",62,"ATTENZIONE")
*   RETURN
*ENDIF
*APPEND FROM &gcTable SDF
*GO TOP

DELETE FOR SUBSTR(TRA_RECORD,2,5) = "-----"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,3,7) = "Azienda"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,2) = "Ms"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,9) = "Pagamento"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,52,8) = "Telefono"  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,4,1) = "."  ALL
GO TOP
DELETE FOR SUBSTR(TRA_RECORD,1,200) = SPACE(200)  ALL
GO TOP

V_CONTA = 0

SELECT TRANSITO
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF

   IF SUBSTR(TRA_RECORD,1,8) = SPACE(08)
      SKIP +1
      LOOP
   ENDIF

   M.CLI_CODSOC = '01'
   M.CLI_CODCLI = ALLTRIM(SUBSTR(TRA_RECORD,1,2)) +  ALLTRIM(SUBSTR(TRA_RECORD,4,5))    
   M.CLI_CODCLI = TRC(PUB_LCL,ALLTRIM(M.CLI_CODCLI))
   M.CLI_RAGSOC = ALLTRIM(SUBSTR(TRA_RECORD,11,40))      
   M.CLI_INDIR  = ALLTRIM(SUBSTR(TRA_RECORD,52,40))      
   M.CLI_CAP    = ALLTRIM(SUBSTR(TRA_RECORD,93,5))
   M.CLI_LOCALI = ALLTRIM(SUBSTR(TRA_RECORD,99,30))
   M.CLI_PROVIN = ALLTRIM(SUBSTR(TRA_RECORD,130,2))

   M.CLI_AGE    = PUB_AGE
   M.CLI_VALUTA = PUB_VALU
   M.CLI_NAZION = PUB_NAZI
   M.CLI_DATNEW = RIBALTA2(DTOC(DATE()))
   M.CLI_DATINS = RIBALTA2(DTOC(DATE()))
   M.CLI_CONPAG = PUB_CPA
   M.CLI_CODIVA = PUB_IVA

   M.CLI_PARIVA = SPACE(11)
   M.CLI_CODFIS = SPACE(16)
   M.CLI_SC1    = 0
   M.CLI_SC2    = 0
   M.CLI_NUMTEL = SPACE(20)
   M.CLI_TELEX  = SPACE(20)
   M.CLI_TELEFA = SPACE(20)

   SKIP +1
   IF EOF()
      DO VERIFICA_CLIENTE
      EXIT
   ENDIF

   IF SUBSTR(TRA_RECORD,1,8) <> SPACE(08)
      IF SUBSTR(TRA_RECORD,3,1) = SPACE(01)
         DO VERIFICA_CLIENTE
         SELECT TRANSITO
         LOOP
      ENDIF
   ENDIF

   M.CLI_DESPAG = ALLTRIM(SUBSTR(TRA_RECORD,1,30))
   M.CLI_PARIVA = ALLTRIM(SUBSTR(TRA_RECORD,32,11))
   M.CLI_CODFIS = ALLTRIM(SUBSTR(TRA_RECORD,49,16))
   M.CLI_DESBAN = ALLTRIM(SUBSTR(TRA_RECORD,66,25))
   M.CLI_AGE    = ALLTRIM(SUBSTR(TRA_RECORD,93,2))
   M.CLI_DESAGE = ALLTRIM(SUBSTR(TRA_RECORD,96,30))
   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,127,5))
   DO TOGLI_PUNTI
   M.CLI_SC1    = VAL(ALLTRIM(Y_CAMPO))
   V_CAMPO      = ALLTRIM(SUBSTR(TRA_RECORD,133,5))
   DO TOGLI_PUNTI
   M.CLI_SC2    = VAL(ALLTRIM(Y_CAMPO))

   v_seek   = 'AGE'+M.CLI_AGE
   v_chiave = "codice"
   cSql     = "select * from para where " + v_chiave + " = '" + v_seek + "'"
   IF !ExecRW(cSql,"PARA","R")
      return(.f.)
   ENDIF
   SELECT PARA
   IF RECCOUNT() <> 0
	  REPLACE DESCRI WITH M.CLI_DESAGE
   ELSE
	  APPEND BLANK
	  REPLACE CODICE WITH 'AGE'+M.CLI_AGE
	  REPLACE DESCRI WITH M.CLI_DESAGE
   ENDIF
   IF !ExecRW(cSql,"PARA","W")
      return(.f.)
   ENDIF

   x_soci = "age_codsoc = '" + PUB_CODSOC + "'"
   x_codi = "age_codice = '" + ALLTRIM(M.CLI_AGE) + "'"
   x_cond = x_soci + " and " + x_codi
   cSql   = "select * from u_age_an where " + x_cond + " order by age_codsoc,age_codice"
   IF !ExecRW(cSql,"U_AGE_AN","R")
      return(.f.)
   ENDIF
   SELECT U_AGE_AN
   IF RECCOUNT() <> 0
      REPLACE AGE_RAGSOC WITH M.CLI_DESAGE
   ELSE
	  APPEND BLANK
      REPLACE AGE_CODSOC WITH PUB_CODSOC
      REPLACE AGE_CODICE WITH M.CLI_AGE
      REPLACE AGE_RAGSOC WITH M.CLI_DESAGE
   ENDIF
   IF !ExecRW(cSql,"U_AGE_AN","W")
      return(.f.)
   ENDIF

   SELECT TRANSITO
   SKIP +1
   IF EOF()
      DO VERIFICA_CLIENTE
      EXIT
   ENDIF

   IF SUBSTR(TRA_RECORD,1,8) <> SPACE(08)
      IF SUBSTR(TRA_RECORD,3,1) = SPACE(01)
         DO VERIFICA_CLIENTE
         SELECT TRANSITO
         LOOP
      ENDIF
   ENDIF

   M.CLI_TELEFO = ALLTRIM(SUBSTR(TRA_RECORD,52,20))
   M.CLI_TELEX  = ALLTRIM(SUBSTR(TRA_RECORD,73,20))
   M.CLI_FAX    = ALLTRIM(SUBSTR(TRA_RECORD,94,20))

   DO VERIFICA_CLIENTE

   SELECT TRANSITO      
   SKIP +1

ENDDO

cSql = "select * from u_cnt_an where cnt_tipo = 'CLI'"
IF !ExecRW(cSql,"U_CNT_AN","R")
   return(.f.)
ENDIF
SELECT U_CNT_AN
REPLACE CNT_DATFIN WITH RIBALTA2(DTOC(DATE()))
REPLACE CNT_ORAFIN WITH TIME()
REPLACE CNT_NUMREC WITH V_CONTA
IF !ExecRW(cSql,"U_CNT_AN","W")
   return(.f.)
ENDIF

=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

RETURN

   
*********************
PROCEDURE TOGLI_PUNTI
*********************

YY      = LEN(V_CAMPO)
XX      = 1
Y_CAMPO =  ' '
DO WHILE .T.
   IF XX > YY
      EXIT
   ENDIF
   IF SUBSTR(V_CAMPO,XX,1) = '.' 
   ELSE
      Y_CAMPO = Y_CAMPO + SUBSTR(V_CAMPO,XX,1) 
   ENDIF
   XX = XX + 1
ENDDO

RETURN


**************************
PROCEDURE VERIFICA_CLIENTE
**************************

x_soci = "cli_codsoc = '" + M.CLI_CODSOC + "'"
x_codi = "cli_codcli = '" + M.CLI_CODCLI + "'"
x_cond = x_soci + " and " + x_codi
cSql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
IF !ExecRW(cSql,"u_cli_an","R")
   return
ENDIF
SELECT u_cli_an
IF EOF()
   m.id_unique = ""
   APPEND BLANK
ENDIF
M.CLI_RAGSOC = UPPER(M.CLI_RAGSOC)
M.CLI_RAGSOC = APITOSPA(M.CLI_RAGSOC)
M.CLI_INDIR  = UPPER(M.CLI_INDIR)
M.CLI_INDIR  = APITOSPA(M.CLI_INDIR)
M.CLI_LOCALI = UPPER(M.CLI_LOCALI)
M.CLI_LOCALI = APITOSPA(M.CLI_LOCALI)
M.CLI_PROVIN = UPPER(M.CLI_PROVIN)
M.CLI_PROVIN = APITOSPA(M.CLI_PROVIN)
M.CLI_CODFIS = UPPER(M.CLI_CODFIS)
M.CLI_CODFIS = APITOSPA(M.CLI_CODFIS)

REPLACE CLI_CODSOC WITH M.CLI_CODSOC
REPLACE CLI_CODCLI WITH M.CLI_CODCLI
REPLACE CLI_RAGSOC WITH M.CLI_RAGSOC
REPLACE CLI_INDIR  WITH M.CLI_INDIR
REPLACE CLI_CAP    WITH M.CLI_CAP
REPLACE CLI_LOCALI WITH M.CLI_LOCALI
REPLACE CLI_PROVIN WITH M.CLI_PROVIN
REPLACE CLI_PARIVA WITH M.CLI_PARIVA
REPLACE CLI_CODFIS WITH M.CLI_CODFIS
REPLACE CLI_AGE    WITH M.CLI_AGE
REPLACE CLI_SC1    WITH M.CLI_SC1
REPLACE CLI_SC2    WITH M.CLI_SC2
REPLACE CLI_TELEFO WITH M.CLI_TELEFO
REPLACE CLI_TELEX  WITH M.CLI_TELEX
REPLACE CLI_FAX    WITH M.CLI_FAX
REPLACE CLI_VALUTA WITH PUB_VALU
REPLACE CLI_NAZION WITH PUB_NAZI
REPLACE CLI_DATNEW WITH RIBALTA2(DTOC(DATE()))
REPLACE CLI_DATINS WITH RIBALTA2(DTOC(DATE()))
REPLACE CLI_CONPAG WITH PUB_CPA
REPLACE CLI_CODIVA WITH PUB_IVA
REPLACE CLI_BDAL   WITH "0108"
REPLACE CLI_BAL    WITH "3108"
REPLACE CLI_GG1    WITH "1009"
REPLACE CLI_B2DAL  WITH "2012"
REPLACE CLI_B2AL   WITH "3112"
REPLACE CLI_GG2    WITH "1001"
REPLACE CLI_TIPFAT WITH "FDV"
REPLACE CLI_FLGTRA WITH .T.

IF !ExecRW(cSql,"u_cli_an","W")
   return
ENDIF

V_CONTA = V_CONTA + 1

_CTR = _CTR +1
WAIT WINDOWS "RECORDS SCRITTI : "+STR(_CTR,10,0) NOWAIT

RETURN