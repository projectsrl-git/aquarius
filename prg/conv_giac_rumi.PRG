** ASSEGNAZIONE DELLA VARIABILE PATH **************************
V_PATH = ""
=OPENDB("PERCORSO")
SELECT PERCORSO
SET ORDER TO I_TIPO
GO TOP
SEEK "RUM"
IF FOUND()
	V_PATH = ALLTRIM(PER_PATH)
ELSE
	MESSAGEBOX("Percorso 'RUM' non configurato" + CHR(13) + CHR(13) + ;
		"Controllare il file PERCORSO.DBF",16,"Attenzione")
	USE
	RETURN .F.
ENDIF

IF DIRECTORY(V_PATH)
ELSE
	MESSAGEBOX("Percorso '" + ALLTRIM(V_PATH) + "' non trovato!" + CHR(13) + CHR(13) + ;
		"Controllare il file PERCORSO.DBF",16,"Attenzione")
	RETURN .F.
ENDIF

SET DEFAULT TO &V_PATH

**** CARICAMENTO DEL FILE IN FORMATO EXCEL 5.0 !!!!!!!!!!!!!! IL FORMATO OFFICE 2007 IN POI NON FUNZIONA
gcFile = GETFILE('XLS', '', 'Browse', 1, 'Seleziona')
SET DEFAULT TO &PUB_DIR

IF EMPTY(gcFile)
	MESSAGEBOX("Nessun file selezionato",64,"Informazione")
	RETURN
ENDIF

RIT = MESSAGEBOX("Conversione giacenze di magazzino da foglio Excel: " + REPLICATE(CHR(13),2) + ;
		ALLTRIM(V_PATH) + REPLICATE(CHR(13),2) + "Continuare?",4+32+256,"ATTENZIONE")
		
IF RIT = 7
   MESSAGEBOX("Operazione abbandonata",48,"Informazione")
   RETURN
ENDIF


RIT = MESSAGEBOX("Vui cancellare la tabella di magazzino vecchia ??",292,"ATTENZIONE")
	IF RIT <> 7

	WAIT WINDOWS "Cancellazione vecchie giacenze e movimenti in corso..." NOWAIT

	cSql = "DELETE FROM U_MAG_GG"
	IF !ExecCommand(cSql,"DEL_MAG_GG")
	   return
	ENDIF

	cSql = "DELETE FROM U_MAG_MO"
	IF !ExecCommand(cSql,"DEL_MAG_MO")
	   return
	ENDIF


ENDIF



_V_ANNORIF = "2013"

_TOT_COUNT = 0
_ULT_NUMORD = 0

WAIT WINDOWS "Conversione Giacenze in corso..." NOWAIT


IF USED("CU_BFO_DD")
	SELECT CU_BFO_DD
	USE
ENDIF
IF !ExecCommand("select * from u_bfo_dd where 0=1","CU_BFO_DD")
   return(.f.)
ENDIF
SELECT CU_BFO_DD
INDEX ON ORD_SEQUEN TAG SEQUEN ADDITIVE



CREATE CURSOR IMPORTAXLS ( ;
	ORDINE1		C(100), ;
	ORDINE2		C(100), ;
	ORDINE3		C(100), ;
	DESART		C(100), ;
	ARUNMIS1	C(100), ;
	GENSCOMIN	C(100), ;
	GENSCOMAX	C(100), ;
	MAGSCOMIN	C(100), ;
	MAGSCOMAX	C(100), ;
	ESISTENZA	C(100), ;
	RISERVATO	C(100), ;
	ORDINATO	C(100), ;
	IMPEGNATO	C(100), ;
	FORNITORE	C(100), ;
	LOTTO		C(100), ;
	ARTICOLO	C(100), ;
	MAGAZZINO	C(100), ;
	ORDFO		C(100), ;
	KEYSAL		C(100), ;
	PRQTAMIN	C(100), ;
	CPCCCHK		C(100), ;
	RICERCA		C(100), ;
	LOTRIO		C(100))

APPEND FROM (gcFile) TYPE XLS



SELECT IMPORTAXLS
GO TOP
DO WHILE !EOF()


	WAIT WINDOWS "Conversione Giacenze di magazzino " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + ;
		" (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 
	
	SCATTER MEMVAR
	

    IF DELETED()
       SELECT IMPORTAXLS  && scarto i record cancellati
       SKIP +1
       LOOP
    ENDIF 
    
    IF UPPER(ALLTRIM(ORDINE1)) = "ORDINE1"  && SCARTO PRIMO RECORD (INTESTAZIONI DI COLONNA)
       SELECT IMPORTAXLS  && SCARTO I RECORD CANCELLATI
       SKIP +1
       LOOP
    ENDIF 


	PUB_DATREG = DTOC(DATE())

	SELECT CU_BFO_DD
	SET ORDER TO
	ZAP

	_X_CODMAT = ""
	_X_UMMAGA = ""
	_X_DESART = ""
	_X_ALTEZZ = 0
	_X_LUNGHE = 0
	_X_SPESSO = 0
	_X_MAGDEF = ""
	_X_CODIVA = ""
	
	_X_CODART = ALLTRIM(SUBSTR(M.ARTICOLO,1,13))
	_X_CODART = ALLTRIM(STRTRAN(_X_CODART,".",""))    			&& tolgo i .


	
*!*		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
*!*		x_codi = "ART_CODPRI = '" + ALLTRIM(_X_CODART) + "'"
*!*		x_cond = x_soci + " and " + x_codi
*!*		Csql   = "SELECT ART_DESCR, ART_UMMAGA, ART_CODMAT, ART_ALTEZZ, ART_LUNGHE, ART_SPESSO, ART_MAGA, ART_CODIVA FROM U_ART_PR WHERE " + x_cond
*!*		IF !ExecCommand(cSql,"TMP_ART_PR")
*!*		   return(.f.)
*!*		ENDIF
*!*		SELECT TMP_ART_PR
*!*		GO TOP
*!*		IF EOF()
*!*			WAIT WINDOWS "Articolo :" + _X_CODART + " non trovato in anagrafica" nowait
*!*			SELECT IMPORTAXLS
*!*			SKIP +1
*!*			LOOP
*!*		ELSE
*!*			_X_CODMAT = ART_CODMAT
*!*			_X_UMMAGA = ALLTRIM(ART_UMMAGA)
*!*			_X_DESART = ALLTRIM(ART_DESCR)
*!*			_X_ALTEZZ = ART_ALTEZZ
*!*			_X_LUNGHE = ART_LUNGHE
*!*			_X_SPESSO = ART_SPESSO
*!*			_X_MAGDEF = ART_MAGA
*!*			_X_CODIVA = ART_CODIVA 
*!*		ENDIF
	


	x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
	x_codi = "ART_CODPRI = '" + ALLTRIM(_X_CODART) + "'"
	x_cond = x_soci + " and " + x_codi
	cSql="SELECT * FROM U_ART_PR WHERE " + x_cond + " order by art_codpri"
	IF !ExecRW(cSql,'U_ART_PR',"R")
	   RETURN .F.
	ENDIF
	SELECT U_ART_PR
	GO TOP
	IF EOF()
		WAIT WINDOWS "Articolo :" + _X_CODART + " non trovato in anagrafica" nowait
		SELECT IMPORTAXLS
		SKIP +1
		LOOP
	ELSE
		_X_CODMAT = ART_CODMAT
		_X_UMMAGA = ALLTRIM(ART_UMMAGA)
		_X_DESART = ALLTRIM(ART_DESCR)
		_X_ALTEZZ = ART_ALTEZZ
		_X_LUNGHE = ART_LUNGHE
		_X_SPESSO = ART_SPESSO
		_X_MAGDEF = ART_MAGA
		_X_CODIVA = ART_CODIVA 
	ENDIF

    REPLACE ART_SCORMI	WITH VAL(M.GENSCOMIN)		&& AGGIORNA SCORTA MINIMA

	IF !ExecRW('','U_ART_PR','W','','U_ART_PR')
	   return(.f.)
	ENDIF
	
	
	SELECT IMPORTAXLS

	_X_PRZACQ = 0
	_D_CODMAG = "SEDE"
	_D_DESMAG = ''
	x_cond = "codice = 'MAG" + ALLTRIM(_D_CODMAG) + "'"
	cSql   = "select CODICE, DESCRI from para where " + x_cond
	IF !ExecCommand(cSql,'CX_PARA')
	   return(.f.)
	ENDIF
	SELECT CX_PARA
	GO TOP
	IF EOF()
	   _D_DESMAG = ""
	ELSE
	   _D_DESMAG = DESCRI
	ENDIF

	SELECT CU_BFO_DD
	APPEND BLANK
	REPLACE DAGGANCIO  WITH '1111111111'
	REPLACE ORD_CODART WITH ALLTRIM(_X_CODART)
	REPLACE ORD_NUMBOB WITH 0
	REPLACE ORD_UM     WITH ALLTRIM(M.ARUNMIS1)
	REPLACE ORD_IVA    WITH _X_CODIVA 
	REPLACE ORD_DESART WITH _X_DESART
	REPLACE ORD_MAGA   WITH _D_CODMAG			
	REPLACE ORD_QTAORD WITH VAL(m.ESISTENZA)
	REPLACE ORD_PREZZO WITH _X_PRZACQ
	REPLACE ORD_SC1    WITH 0
	REPLACE ORD_SC2    WITH 0
	REPLACE ORD_SC3    WITH 0
	REPLACE ORD_PRZNET WITH _X_PRZACQ
	REPLACE ORD_VALORE WITH ROUND((ORD_PRZNET*ORD_QTAORD),2)
	REPLACE ORD_DATCON WITH RIBALTA2(DTOC(DATE()))
	REPLACE ORD_CODSYS WITH SYS(2015)
	REPLACE ORS_CODCLI WITH PUB_CFDEF
	REPLACE ORS_RAGSOC WITH ""  
	REPLACE ORS_NUMORD WITH "INV" + ALLTRIM(_V_ANNORIF)
	REPLACE ORS_DATORD WITH PUB_DATREG
	REPLACE ORS_VALUTA WITH PUB_VALU
	REPLACE ORD_SEQUEN WITH 0
	REPLACE ORD_LEGAME WITH '1111111111'
	REPLACE ORD_LEGSYS WITH SYS(2015)
	REPLACE ORD_FLGMOD WITH 'I'
	REPLACE ORS_NUMIDE WITH ""
	REPLACE ORS_ANNO   WITH SUBSTR(PUB_DATREG,1,4)
	REPLACE ORD_LEGASY WITH SYS(2015)
	REPLACE ORD_SALCON WITH 'S'
	REPLACE ORD_DTASCA WITH RIBALTA2(DTOC(DATE()))
	REPLACE ORD_QTAML  WITH 0
	REPLACE ORD_QTAMQ  WITH 0
	REPLACE ORD_QTAKG  WITH 0
	*REPLACE ORD_QTAMC  WITH M.QTAMCPROD 
	REPLACE ORD_QTAML1 WITH 0
	REPLACE ORD_QTAMQ1 WITH 0
	REPLACE ORD_QTAKG1 WITH 0
	REPLACE ORD_ALTEZZ WITH _X_ALTEZZ
	REPLACE ORD_LUNGHE WITH _X_LUNGHE
	REPLACE ORD_SPESSO WITH _X_SPESSO
	REPLACE ORD_CODMAT WITH _X_CODMAT 
	REPLACE ORD_CODCOL WITH "" 
	REPLACE ORD_DESMAT WITH ""
	REPLACE ORD_FILA_X WITH "" 
	REPLACE ORD_PIAN_X WITH ""
	REPLACE ORD_UBIC_X WITH ""
	REPLACE ORD_FILA_N WITH 0
	REPLACE ORD_PIAN_N WITH 0
	REPLACE ORD_UBIC_N WITH 0
	REPLACE ORD_SYSMAG WITH SYS(2015)
	*REPLACE ORD_TIPBOB WITH PUB_TIPOBOB
	*REPLACE ORD_QUAPRO WITH IIF(M.FLGNONCONF,"99","01")
	REPLACE ORD_CLIENT WITH ""

	SCATTER MEMVAR MEMO
	
	M.ORD_CAUS   = PUB_CAUMOV
	M.ORD_NUMORD = M.ORS_NUMORD
	M.ORD_DATORD = M.ORS_DATORD
	M.ORD_CODCLI = M.ORS_CODCLI
	M.ORD_RAGSOC = M.ORS_RAGSOC
	M.ORD_CODACQ = M.ORS_CODACQ
	M.ORD_VALUTA = M.ORS_VALUTA
	M.ORD_NUMIDE = AQM_NEW_NUMIDE()
	M.ORD_CODBUN = ""

	SELECT CU_BFO_DD
	GO TOP

	XXY_CODINT = ""
	XXY_NRLINT = 0
	XXY_UNIQUE = ""
	=AQM_GESTIONE_CARICHI_BFO()
	_W_CODINT = XXY_CODINT
	_W_MAG_UNIQUE = XXY_UNIQUE 
		
	_TOT_COUNT = _TOT_COUNT + 1
	
	SELECT IMPORTAXLS
	SKIP +1
	
ENDDO

WAIT CLEAR

MESSAGEBOX("Operazione terminata correttamente" + REPLICATE(CHR(13),2) + ;
	"Totale giacenze convertite: " + ALLTRIM(STR(_TOT_COUNT,10,0)),64,"Informazione")

RETURN


 