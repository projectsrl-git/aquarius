************************************
* ORDINI_NON_EVASI_CON_DATA_CONSEGNA_MODIFICATA
************************************

LPARAMETERS _GIORNI_PRECEDENTI

IF PCOUNT()<1
	RETURN .F.
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO,V_GIORNI_PRECEDENTI
PUBLIC V_TITOLO,V_GIORNI_PRECEDENTI

V_GIORNI_PRECEDENTI = _GIORNI_PRECEDENTI

V_TITOLO	= "Ordini fornitori non evasi con data di consegna modificata"

WAIT WINDOWS "ESEGUE PROGRAMMA ORDINI_FORNITORI_NON_EVASI_CON_DATA_CONSEGNA_MODIFICATA" TIMEOUT 3

*** REPORT RIEPILOGO
cSql=""     
cNomeCursorSql="CU_ORDINATO_FORNITORE"
TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
		
	SELECT * FROM (
		SELECT 	
			CODICE_FORNITORE,
			FORNITORE,
			NUM_ORDINE,
			DATA_ORDINE_RIBALTATA, 
			DATA_ORDINE,
			CODICE_ARTICOLO,
			DESCRIZIONE_ARTICOLO,
			UM,
			QTA_ORDINATA,
			CENTRO_COSTO,
			DESCRIZIONE_CENTRO_COSTO,
			DATA_CONSEGNA_RIBALTATA,
			DATA_CONSEGNA,
			(SELECT TOP 1 VALORE_PREC FROM LOG_EVENTI 
			 WHERE TIPO_EVENTO='ORDFOR' AND CAMPO_MODIFICATO='DATA CONSEGNA' 
			 AND DATA_EVENTO = convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111) 
			 AND DESCRIZIONE LIKE 'ARTICOLO ' + RTRIM(CODICE_ARTICOLO) + ' (%'
			 AND VALORE_SUCC = DATA_CONSEGNA
			 AND NUM_ORDINE=SUBSTRING(GRUPPO_EVENTO,18,6)
			 ORDER BY DATA_EVENTO+ORA_EVENTO DESC
			) AS DATA_PREC,
			VALORE
		FROM (
			SELECT T1.*,CCO.CON_DESCR AS DESCRIZIONE_CENTRO_COSTO FROM (
			SELECT
				TT.ORD_CODCLI AS CODICE_FORNITORE,
				TT.ORD_RAGSOC AS FORNITORE,
				TT.ORD_NUMORD AS NUM_ORDINE,
				TT.ORD_DATORD AS DATA_ORDINE_RIBALTATA,
				SUBSTRING(TT.ORD_DATORD,9,2)+'/'+SUBSTRING(TT.ORD_DATORD,6,2)+'/'+SUBSTRING(TT.ORD_DATORD,1,4) AS DATA_ORDINE,
				DD.ORD_CCODET AS CENTRO_COSTO,
				DD.ORD_CODART AS CODICE_ARTICOLO,
				DD.ORD_DESART AS DESCRIZIONE_ARTICOLO,
				DD.ORD_DATCON AS DATA_CONSEGNA_RIBALTATA,
				SUBSTRING(DD.ORD_DATCON,9,2)+'/'+SUBSTRING(DD.ORD_DATCON,6,2)+'/'+SUBSTRING(DD.ORD_DATCON,1,4) AS DATA_CONSEGNA,
				DD.ORD_UM AS UM,
				DD.ORD_QTAORD AS QTA_ORDINATA,
				TT.ORD_CAMBIO * DD.ORD_VALORE AS VALORE
			FROM U_ORF_TT AS TT
			LEFT OUTER JOIN U_ORF_DD AS DD
			ON TT.TAGGANCIO=DD.DAGGANCIO
			WHERE 
				DD.ORD_QTAORD>0
				AND DD.ORD_CHIUSO=0 
				AND TT.ORD_CHIUSO=0
				AND TT.ORD_TIPOLOGIA NOT IN (SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'TPO%' AND CODPGO='ANNULLATO')
			) AS T1
			LEFT OUTER JOIN (SELECT DISTINCT CON_CONTO, CON_DESCR FROM  CCOSTO) AS CCO
			ON T1.CENTRO_COSTO = CON_CONTO
			WHERE 
				--T1.CODICE_FORNITORE <> (SELECT TOP 1 AZI_CODCLI FROM U_AZI_AN)
				T1.CODICE_ARTICOLO NOT LIKE '.%'
			) AS MAIN
		WHERE NUM_ORDINE+' DEL '+DATA_ORDINE_RIBALTATA IN (SELECT SUBSTRING(GRUPPO_EVENTO,18,21) AS NUMORD FROM LOG_EVENTI WHERE TIPO_EVENTO='ORDFOR' AND CAMPO_MODIFICATO='DATA CONSEGNA' AND DATA_EVENTO = convert(varchar, DATEADD(day, -<<_GIORNI_PRECEDENTI>>, GETDATE()), 111) AND DESCRIZIONE NOT LIKE 'ARTICOLO .%' )
		--GROUP BY CENTRO_COSTO,DESCRIZIONE_CENTRO_COSTO,CODICE_FORNITORE,FORNITORE,NUM_ORDINE,DATA_ORDINE_RIBALTATA,DATA_ORDINE,DATA_CONSEGNA_RIBALTATA,DATA_CONSEGNA
		) AS MAIN2
	WHERE DATA_PREC <> ''
	ORDER BY DESCRIZIONE_CENTRO_COSTO,FORNITORE,NUM_ORDINE,CODICE_ARTICOLO,DATA_CONSEGNA_RIBALTATA


ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF


SELECT CU_ORDINATO_FORNITORE

_PDF_REPORT_ 		=ALLTRIM(CERCAREPO("XXX","ORDINI_FORNITORI_NON_EVASI_CON_DATA_CONSEGNA_MODIFICATA","ORDINI_FORNITORI_NON_EVASI_CON_DATA_CONSEGNA_MODIFICATA.FRX"))
_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "CU_ORDINATO_FORNITORE"

IF !EMPTY(_PDF_SUBDIR_ )
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
