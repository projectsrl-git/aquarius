		SKIP

	ENDDO
 



	WAIT WINDOWS "CLIENTI INSERITI ????? :" + STR(__CONTA_INS,5,0)
	
	=MESSAGEBOX("OPERAZIONE TERMINATA CORRETTAMENTE ",62,"ATTENZIONE")

	SET DEFAULT TO &PUB_DIR

	RETURN




RETURN



************************************************
FUNCTION DECODIFICA_BANCA_NOSTRA
************************************************ 
PARA CODICE_BANCA_NOSTRA

* LA PROCEDURA DECODIFICA LA BANCA NOSTRA DAL CODICE IBAN E SALVA LE INFORMAZIONE SUL CURSORE U_CLI_AN PER L'AGGIORNAMENTO SUCCESSIVO

IF EMPTY(ALLTRIM(CODICE_BANCA_NOSTRA))
	RETURN
ENDIF


IF SUBSTR(ALLTRIM(CODICE_BANCA_NOSTRA),1,2) = "IT"
ELSE
    __PROSEGUO_DECODIFICA_BANCA = .F.
	=DECODIFICA_IBAN(CODICE_BANCA_NOSTRA)
	IF !__PROSEGUO_DECODIFICA_BANCA 
	  RETURN
	ENDIF
ENDIF


* CODICE IBAN
* IT28P0306955681000006636110
* NAZIONE 		: SUBSTR(CODICE_BANCA_NOSTRA,01,02)
* CHECK DIGIT 	: SUBSTR(CODICE_BANCA_NOSTRA,03,02)
* CIN			: SUBSTR(CODICE_BANCA_NOSTRA,05,01)
* ABI 			: SUBSTR(CODICE_BANCA_NOSTRA,06,05)
* CAB 			: SUBSTR(CODICE_BANCA_NOSTRA,11,05)
* CC 			: SUBSTR(CODICE_BANCA_NOSTRA,16,12)


M.CLI_NAZFOR = SUBSTR(CODICE_BANCA_NOSTRA,01,02)
M.CLI_CHEFOR = SUBSTR(CODICE_BANCA_NOSTRA,03,02)
M.CLI_CINFOR = SUBSTR(CODICE_BANCA_NOSTRA,05,01)
M.CLI_ABIFOR = SUBSTR(CODICE_BANCA_NOSTRA,06,05)
M.CLI_CABFOR = SUBSTR(CODICE_BANCA_NOSTRA,11,05)
M.CLI_NCCFOR = SUBSTR(CODICE_BANCA_NOSTRA,16,12)

M.CLI_BAEFOR = ALLTRIM(M.CLI_ABIFOR) + ALLTRIM(M.CLI_CABFOR)

M.CLI_IBAFOR = CODICE_BANCA_NOSTRA

SELECT U_CLI_AN
REPLACE CLI_NAZFOR WITH M.CLI_NAZFOR 
REPLACE CLI_CHEFOR WITH M.CLI_CHEFOR
REPLACE CLI_CINFOR WITH M.CLI_CINFOR
REPLACE CLI_ABIFOR WITH M.CLI_ABIFOR
REPLACE CLI_CABFOR WITH M.CLI_CABFOR
REPLACE CLI_NCCFOR WITH M.CLI_NCCFOR
REPLACE CLI_BAEFOR WITH M.CLI_BAEFOR
REPLACE CLI_IBAFOR WITH M.CLI_IBAFOR

REPLACE CLI_NOTE   WITH ""						&& RIPULISCE IL CAMPO NOTE PER OTTENERE SOLO GLI ERRORI DI BANCHE NOSTRE NON CODIFICATE DALLA STAMPA PER NOTE

   	
   	
   	
RETURN



************************************************
FUNCTION DECODIFICA_IBAN
************************************************ 
PARA CODICE_IBAN


__PROSEGUO_DECODIFICA_BANCA = .F.

POSIZIONE_PAROLA = (AT(" ",CODICE_IBAN) + 1)

IF SUBSTR(CODICE_IBAN,POSIZIONE_PAROLA,2) = "IT"
	__PROSEGUO_DECODIFICA_BANCA = .T.
	CODICE_BANCA_NOSTRA = ALLTRIM(SUBSTR(CODICE_IBAN,POSIZIONE_PAROLA,50))
ENDIF



RETURN




