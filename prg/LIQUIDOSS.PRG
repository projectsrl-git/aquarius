   REPLACE ITO_DESIVA  WITH V_DESIVA
   REPLACE ITO_IMPONI  WITH V_IMPONI
   REPLACE ITO_IMPOST  WITH V_IMPOST
     
   SELECT CU_IVA_TO
   SKIP + 1

ENDDO

