*************************
PROCEDURE IVAERA 
*************************
*RECUPERO IVA PRECEDENTE*
    
x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
x_anno = "iva_anno = " + ANNO
x_cond = x_soci + " and " + x_anno
CSQL   = "select * from u_iva_cr where " + x_cond + " order by iva_codsoc,iva_anno" 
IF !ExecCommand(CSQL,"u_iva_cr")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_CR
GO TOP
IF !EOF()
   IF OK_TRIM = 0
      IF VAL(MESE_DAL) = 1
         E_IMPOST = IVA_GENNAI
      ENDIF
      IF VAL(MESE_DAL) = 2
         E_IMPOST = IVA_FEBBRA
      ENDIF
      IF VAL(MESE_DAL) = 3
         E_IMPOST = IVA_MARZO
      ENDIF
      IF VAL(MESE_DAL) = 4
         E_IMPOST = IVA_APRILE
      ENDIF
      IF VAL(MESE_DAL) = 5
         E_IMPOST = IVA_MAGGIO
      ENDIF
      IF VAL(MESE_DAL) = 6
         E_IMPOST = IVA_GIUGNO
      ENDIF
      IF VAL(MESE_DAL) = 7
         E_IMPOST = IVA_LUGLIO
      ENDIF
      IF VAL(MESE_DAL) = 8
         E_IMPOST = IVA_AGOSTO
      ENDIF
      IF VAL(MESE_DAL) = 9
         E_IMPOST = IVA_SETTEM
      ENDIF
      IF VAL(MESE_DAL) = 10
         E_IMPOST = IVA_OTTOBR
      ENDIF
      IF VAL(MESE_DAL) = 11
         E_IMPOST = IVA_NOVEMB
      ENDIF
      IF VAL(MESE_DAL) = 12
         E_IMPOST = IVA_DICEMB
      ENDIF
   ENDIF
   IF OK_TRIM = 1
      E_IMPOST = IVA_GENNAI + IVA_FEBBRA + IVA_MARZO
   ENDIF
   IF OK_TRIM = 2
      E_IMPOST = IVA_APRILE + IVA_MAGGIO + IVA_GIUGNO
   ENDIF
   IF OK_TRIM = 3
      E_IMPOST = IVA_LUGLIO + IVA_AGOSTO + IVA_SETTEM
   ENDIF
   IF OK_TRIM = 4
      E_IMPOST = IVA_OTTOBR + IVA_NOVEMB + IVA_DICEMB
   ENDIF
ELSE
   E_IMPOST  = 0 
ENDIF 


