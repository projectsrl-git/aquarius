SELECT U_IVA_TO
GO TOP

DO WHILE .T. 

   IF EOF()
      EXIT
   ENDIF

   V_CODIVA = ITO_CODIVA 
   V_FATNOT = ITO_FATNOT 
   V_DESIVA = ITO_DESIVA
   V_IMPONI = ITO_IMPONI
   V_IMPOST = ITO_IMPOST
  
   ** IVE INDEDUCIBILI  
 
   v_seek	= 'IVA'+V_CODIVA
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      TIPOIVA   = SUBSTR(LIBERA,100,1)
   ELSE
      TIPOIVA   = " "
   ENDIF
   
   SELECT U_IVA_TO

   IND_100 = ' '
   IF ITO_IND100 = 'S'  && IVA INDEDUCIBILE AL 100%
      IND_100   = "S"
   ENDIF

   IF IND_100 = 'S'	.OR. "*" $ V_CODIVA	 && IMPOSTE INDEDUCIBILI  
      IF IND_100 = 'S'
	     IF V_FATNOT = "F" 
	 	    IMPONIB_X =  IMPONIB_X  + ITO_IMPONI + ITO_IMPOST  && IVE INDEDUCIBILI AL 100%
			IMPOSTA_X =  IMPOSTA_X  + ITO_IMPOST
	 		V_IMPONI  =  ITO_IMPONI + ITO_IMPOST 				&& IVE INDEDUCIBILI AL 100%
		 ELSE
			IMPONIB_X =  IMPONIB_X  - ITO_IMPONI - ITO_IMPOST  && PER NOTE C. TOGLIE
			IMPOSTA_X =  IMPOSTA_X  - ITO_IMPOST
	 		V_IMPONI  =  ITO_IMPONI + ITO_IMPOST 				&& IVE INDEDUCIBILI AL 100%
		 ENDIF
      ELSE
         IF V_FATNOT = "F" 
		    IMPONIB_X =  IMPONIB_X  + ITO_IMPONI  				&& IVE INDEDUCIBILI AL 100%
		    IMPOSTA_X =  IMPOSTA_X  + ITO_IMPOST
		 ELSE
		    IMPONIB_X =  IMPONIB_X  - ITO_IMPONI  				&& IVE INDEDUCIBILI AL 100%
		    IMPOSTA_X =  IMPOSTA_X  - ITO_IMPOST
		 ENDIF
 	  ENDIF	 
   ELSE 
      IF V_FATNOT = "F" 
         IMPONIB_F =  IMPONIB_F  + ITO_IMPONI  && IVE FATTURE
         IMPOSTA_F =  IMPOSTA_F  + ITO_IMPOST
      ENDIF 
      IF V_FATNOT = "N" 
         IMPONIB_F =  IMPONIB_F  - ITO_IMPONI  && IVE NOTE CREDITO
         IMPOSTA_F =  IMPOSTA_F  - ITO_IMPOST
      ENDIF 
   ENDIF

   SELECT IVA_CL
   PUB_RIGA = PUB_RIGA + 1   
   IF PUB_RIGA > SALTO_PAG
      DO IVATESTO             && TESTATA BOLLATO
   ENDIF

   SELECT IVA_CL
   APPEND BLANK

   *====>>> RIGA DI DETTAGLIO
  
   IF ALLTRIM(V_FATNOT) = "N"
	  _ABIT_IMPONI = V_IMPONI * -1
	  _ABIT_IMPOST = V_IMPOST * -1
   ELSE
	  _ABIT_IMPONI = V_IMPONI 
	  _ABIT_IMPOST = V_IMPOST 
   ENDIF

   IF IND_100 = 'S'	.OR. "*" $ V_CODIVA	 && IMPOSTE INDEDUCIBILI  
	  RIGA_D = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA +  " | " +SPACE(18)+ " | " +SPACE(18)
	  RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(_ABIT_IMPONI,"999,999,999,999.99"),1,18) 
	  RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(_REVERSECHANGE_IMPOST,"999,999,999,999.99"),1,18)
   ELSE
	  RIGA_D = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
	  RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(_REVERSECHANGE_IMPONI,"999,999,999,999.99"),1,18) 
	  RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(_REVERSECHANGE_IMPOST,"999,999,999,999.99"),1,18)+  " | " +SPACE(18)+ " | "
   ENDIF	

   REPLACE RIGAT       WITH RIGA_D 
   REPLACE RIGA        WITH SPACE(50)
   REPLACE CHIAVE      WITH 888666
   REPLACE CHIAVE_R    WITH "TOC"

   REPLACE ITO_CODIVA  WITH V_CODIVA 
   REPLACE ITO_FATNOT  WITH V_FATNOT 
   REPLACE ITO_DESIVA  WITH V_DESIVA
   REPLACE ITO_IMPONI  WITH V_IMPONI
   REPLACE ITO_IMPOST  WITH V_IMPOST
     
   SELECT U_IVA_TO
   SKIP + 1

ENDDO

