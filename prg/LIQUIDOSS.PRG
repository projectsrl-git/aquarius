*************************
PROCEDURE OK_SPOOL 
*************************
****** INIZIO: TOTALE PER OGNI CODICE IVA DI TUTTI I MESI CONSIDERATI ... FABIANO

_XXX_SSS=SELECT()

SELECT IVA_CL
GO TOP

DO WHILE .T. 

   IF EOF()
      EXIT
   ENDIF

   IF DELETED()
  	  SKIP +1
	  LOOP 
   ENDIF

   ****** INIZIO: SCARTA I DETTAGLI --> CHIAVE_R="DET"
   IF CHIAVE_R="DET"
	  SELECT IVA_CL
	  SKIP +1
	  LOOP 
   ENDIF
   ****** FINE: SCARTA I DETTAGLI --> CHIAVE_R="DET"

   SCATTER MEMVAR MEMO
   V_CODIVA=ITO_CODIVA
   V_CHIAVE=STR(CHIAVE,6,0)
   V_FATNOT=ITO_FATNOT
   V_DESIVA=ITO_DESIVA
   V_IND100=ITO_IND100
   IF EMPTY(V_CODIVA)
      SELECT IVACLTOT
      APPEND BLANK
      GATHER MEMVAR
   ELSE
      SELECT IVACLTOT
      SET ORDER TO ITO_CODIVA
      SEEK V_CHIAVE+V_CODIVA+V_FATNOT
      IF !FOUND()
         APPEND BLANK
         GATHER MEMVAR
         IF V_CHIAVE="777777"
            IF V_IND100 = 'S'	.OR. "*" $ V_CODIVA	 && IMPOSTE INDEDUCIBILI  
               _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA  +  " | " +SPACE(18)+ " | " +SPACE(18)
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPOST,"999,999,999,999.99"),1,18)
            ELSE
               _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPOST,"999,999,999,999.99"),1,18) +  " | " +SPACE(18)+ " | " +SPACE(18)
            ENDIF
         ELSE
            _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA
            _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
            _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPOST,"999,999,999,999.99"),1,18)
         ENDIF
         REPLACE RIGAT WITH _XXX_RIGA
      ELSE
         REPLACE ITO_IMPONI WITH ITO_IMPONI+M.ITO_IMPONI
         REPLACE ITO_IMPOST WITH ITO_IMPOST+M.ITO_IMPOST
         IF V_CHIAVE="777777"
            IF V_IND100 = 'S'	.OR. "*" $ V_CODIVA	 && IMPOSTE INDEDUCIBILI  
               _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA  +  " | " +SPACE(18)+ " | " +SPACE(18)
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPOST,"99,999,999,999.99"),1,18)
            ELSE
               _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
               _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPOST,"999,999,999,999.99"),1,18) +  " | " +SPACE(18)+ " | " +SPACE(18)
            ENDIF
         ELSE
            _XXX_RIGA = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA
            _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPONI,"999,999,999,999.99"),1,18) 
            _XXX_RIGA = _XXX_RIGA + " | " + SUBSTR(TRANSFORM(ITO_IMPOST,"999,999,999,999.99"),1,18)
         ENDIF
         REPLACE RIGAT WITH _XXX_RIGA
      ENDIF
   ENDIF
  
   SELECT IVA_CL
   SKIP +1

ENDDO

SELECT IVACLTOT
SET ORDER TO
SELECT(_XXX_SSS)

****** FINE: TOTALE PER OGNI CODICE IVA DI TUTTI I MESI CONSIDERATI ... FABIANO

SELECT IVACLTOT
SET ORDER TO
GO TOP

DO WHILE .NOT. EOF()
   V_RIGAT=RIGAT
   SELECT IVA_STA
   APPEND BLANK
   REPLACE RIGAT WITH V_RIGAT
   SELECT IVACLTOT
   SKIP +1
ENDDO

