RIGA_D=SPACE(50)
REPLACE RIGAT     WITH REPLICATE(PUB_CAROR,124) 
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 777777
REPLACE CHIAVE_R  WITH "TOC"

*** >>>>>  TOTALI IVA CLIENTI 

IMPONIB_F = 0  && IVE FATTURE
IMPOSTA_F = 0
IMPONIB_N = 0  && IVE NOTE CREDITO
IMPOSTA_N = 0
IMPONIB_C = 0  && IVE CORRISPETTIVI
IMPOSTA_C = 0
IMPONIB_X = 0  && IVE INDEDUCIBILI
IMPOSTA_X = 0

x_soci = "ito_codsoc = '" + PUB_CODSOC + "'"
x_anno = "ito_anno = '" + ANNO + "'"
x_mese = "ito_mese >= '" + MESE_DAL + "'"
x_tipo = "(ito_clifor = 'C' or ito_clifor = 'R')"
x_cond = x_soci + " and " + x_anno + " and " + x_mese + " and " + x_tipo
CSQL   = "select * from u_iva_to where " + x_cond + " order by ito_codsoc,ito_anno,ito_mese,ito_clifor" 
IF !ExecCommand(CSQL,"u_iva_to")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_TO
GO TOP

DO WHILE .T. 

   IF EOF()
      EXIT
   ENDIF

   IF ITO_MESE < MESE_DAL .OR. ITO_MESE > MESE_AL
      SKIP + 1
      LOOP
   ENDIF


   IF PUB_NFATDIFFERITA
	   IF ITO_CLIFOR = "D"   && NON ELABORA I MOVIMENTI RELATIVI ALLE FATTURE CREATE AUTOMATICAMENTE DA DDT
	      SKIP +1
	   	  LOOP
	   ENDIF
   ENDIF

   V_CODIVA = ITO_CODIVA 
   V_FATNOT = ITO_FATNOT 
   V_DESIVA = ITO_DESIVA
   V_IMPONI = ITO_IMPONI
   V_IMPOST = ITO_IMPOST
   V_IND100 = ITO_IND100
 
   v_seek	= 'IVA'+V_CODIVA
   v_chiave = "codice"
   IF seek_std('para',v_seek,v_chiave,'CUR_PARA')
      SELECT CUR_PARA
      TIPOIVA   = SUBSTR(LIBERA,100,1)
   ELSE
      TIPOIVA   = " "
   ENDIF

   SELECT U_IVA_TO
 
   IF TIPOIVA <> "I"
      IF V_FATNOT = "F" 
         IMPONIB_F =  IMPONIB_F  + ITO_IMPONI  && IVE FATTURE
         IMPOSTA_F =  IMPOSTA_F  + ITO_IMPOST
      ENDIF 
   ENDIF  

   IF TIPOIVA <> "I"
      IF V_FATNOT = "N" 
         IMPONIB_N =  IMPONIB_N  + ITO_IMPONI  && IVE NOTE CREDITO
         IMPOSTA_N =  IMPOSTA_N  + ITO_IMPOST
      ENDIF 
   ENDIF 

   IF TIPOIVA <> "I"
      IF V_FATNOT = "C" 
         IMPONIB_C =  IMPONIB_C  + ITO_IMPONI  && IVE CORRISPETTIVI
         IMPOSTA_C =  IMPOSTA_C  + ITO_IMPOST
      ENDIF 
   ENDIF 

   IF TIPOIVA = "I" 
      IMPONIB_X =  IMPONIB_X  + ITO_IMPONI  && IVE INDEDUCIBILI 
      IMPOSTA_X =  IMPOSTA_X  + ITO_IMPOST
   ENDIF 

   SELECT IVA_CL
   PUB_RIGA = PUB_RIGA + 1   
   IF PUB_RIGA > SALTO_PAG
      DO IVATESTO             && TESTATA BOLLATO
   ENDIF

   SELECT IVA_CL
   APPEND BLANK
 
   IF ALLTRIM(V_FATNOT) = "N"
  	  S_IMPONI = V_IMPONI * -1
	  S_IMPOST = V_IMPOST * -1
   ELSE
	  S_IMPONI = V_IMPONI 
	  S_IMPOST = V_IMPOST 
   ENDIF

   RIGA_D = V_CODIVA + "  " + V_FATNOT + " " + V_DESIVA 
   RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(S_IMPONI,"999,999,999,999.99"),1,18) 
   RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(S_IMPOST,"999,999,999,999.99"),1,18)

   REPLACE RIGAT       WITH RIGA_D 
   REPLACE RIGA        WITH SPACE(50)
   REPLACE CHIAVE      WITH 666666
   REPLACE CHIAVE_R    WITH "TOC"

   REPLACE ITO_CODIVA  WITH V_CODIVA 
   REPLACE ITO_FATNOT  WITH V_FATNOT 
   REPLACE ITO_DESIVA  WITH V_DESIVA
   REPLACE ITO_IMPONI  WITH V_IMPONI
   REPLACE ITO_IMPOST  WITH V_IMPOST
   REPLACE ITO_IND100  WITH V_IND100
  
   SELECT U_IVA_TO
   SKIP + 1

ENDDO

SELECT IVA_CL

* AZZERO L'IVA INDEDUC. PERCHE' NON DEVE ESSERE TOLTA DAL TOTALE MA SOLO NON FIGURARE

IMPONIB_X=0
IMPOSTA_X=0

** TOTALI IVA CLIENTI
** ==================

SELECT IVA_CL
PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
   PUB_RIGA = PUB_RIGA + 1
   APPEND BLANK
   RIGA_D=SPACE(50)
   REPLACE RIGAT     WITH REPLICATE(PUB_CAROR,124) 
   REPLACE RIGA      WITH SPACE(50)
   REPLACE CHIAVE    WITH 666666
   REPLACE CHIAVE_R  WITH "TOC"
   PUB_RIGA = PUB_RIGA + 1
   APPEND BLANK 
   PERI=MESE_C + " " +ANNO
   REPLACE RIGAT     WITH "		  		SEZIONE VENDITE RELATIVA AL PERIODO " + PERI  REPLACE RIGA      WITH SPACE(50)
   REPLACE CHIAVE    WITH 666666
   REPLACE CHIAVE_R  WITH "TOC"
ENDIF

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
RIGA_D=SPACE(50)
REPLACE RIGAT     WITH REPLICATE(PUB_CAROR,124) 
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 777777
REPLACE CHIAVE_R  WITH "TOC"

APPEND BLANK
REPLACE IMPONI    WITH IMPONIB_F - IMPONIB_N - IMPONIB_X
REPLACE IMPOST    WITH IMPOSTA_F - IMPOSTA_N - IMPOSTA_X

REPLACE CHIAVE_R  WITH "TOC"
REPLACE CHIAVE    WITH 666666

** SOMMA IVA VENDITE + CORRISPETTIVI - NOTE CREDITO
**=================================================
V_IMPONI = IMPONIB_F + IMPONIB_C - IMPONIB_N - IMPONIB_X
V_IMPOST = IMPOSTA_F + IMPOSTA_C - IMPOSTA_N - IMPOSTA_X
C_IMPONI = IMPONIB_F + IMPONIB_C - IMPONIB_N - IMPONIB_X
C_IMPOST = IMPOSTA_F + IMPOSTA_C - IMPOSTA_N - IMPOSTA_X

RIGA_D = " >>>>> TOTALI GENERALI   " 
RIGA_D = RIGA_D + SPACE(12) + " | " + SUBSTR(TRANSFORM(V_IMPONI,"999,999,999,999.99"),1,18)
RIGA_D = RIGA_D + " | " + SUBSTR(TRANSFORM(V_IMPOST,"999,999,999,999.99"),1,18) 
REPLACE RIGAT     WITH RIGA_D 
REPLACE RIGA      WITH SPACE(50)

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
RIGA_D=SPACE(50)
REPLACE CHIAVE_R  WITH "TOC"
REPLACE RIGAT     WITH REPLICATE(PUB_CAROR,124) 
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666666

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
  DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
REPLACE CHIAVE_R  WITH "TOC"
REPLACE RIGAT     WITH SPACE(50)
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666666

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
REPLACE CHIAVE_R  WITH "TOC"
REPLACE RIGAT     WITH SPACE(50)
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666666

PUB_RIGA = PUB_RIGA + 1
IF PUB_RIGA > SALTO_PAG
   DO IVATESTO             && TESTATA BOLLATO
ENDIF

APPEND BLANK
REPLACE CHIAVE_R  WITH "TOC"
REPLACE RIGAT     WITH SPACE(50)
REPLACE RIGA      WITH SPACE(50)
REPLACE CHIAVE    WITH 666666

RETURN


