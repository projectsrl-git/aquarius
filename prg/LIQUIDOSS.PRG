*************************
PROCEDURE IVAMENSILE
*************************


IF VAL(MESE_DAL) < 12

    MESE_SUCCESSIVO = VAL(MESE_DAL) + 1

    IF MESE_SUCCESSIVO = 1
        M.IVA_GENNAI = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 2
        M.IVA_FEBBRA = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 3
        M.IVA_MARZO  = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 4
        M.IVA_APRILE = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 5
        M.IVA_MAGGIO = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 6
        M.IVA_GIUGNO = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 7
        M.IVA_LUGLIO = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 8
        M.IVA_AGOSTO = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 9
        M.IVA_SETTEM = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 10
        M.IVA_OTTOBR = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 11
        M.IVA_NOVEMB = ABS(SAVE_T_IMPOST) 
    ENDIF
    IF MESE_SUCCESSIVO = 12
        M.IVA_DICEMB = ABS(SAVE_T_IMPOST) 
    ENDIF

ELSE

        M.IVA_DARIPO = ABS(SAVE_T_IMPOST) 		&& RIPORTA IL CREDITO IVA NEL CAMPO IVA DA RECUPPERARE PER L'ANNO SUCCESSIVO
    
ENDIF


RETURN


*************************
PROCEDURE IVATRIMESTRALE
*************************

IF OK_TRIM = 1						&& primo trimestre : riportol'iva nel secondo trimestre
     M.IVA_GIUGNO = ABS(SAVE_T_IMPOST) 
ENDIF     

IF OK_TRIM = 2						&& secondo trimestre : riportol'iva nel terzo trimestre
     M.IVA_SETTEM = ABS(SAVE_T_IMPOST) 
ENDIF     

IF OK_TRIM = 3						&& terzo trimestre : riportol'iva nel quarto trimestre
     M.IVA_DICEMB = ABS(SAVE_T_IMPOST) 
ENDIF     

IF OK_TRIM = 4						&& quarto trimestre : riportol'iva nel campo iva da recuperare per l'anno successivo
     M.IVA_DARIPO = ABS(SAVE_T_IMPOST) 
ENDIF     


RETURN


