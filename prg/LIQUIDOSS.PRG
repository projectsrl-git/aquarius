*************************
PROCEDURE IVADET 
*************************
* DETTAGLIO BOLLATO IVA *

x_soci = "iva_codsoc = '" + PUB_CODSOC + "'"
x_anno = "iva_anno = '" + PUB_ANNO + "'"
x_mese = "iva_mese = '" + MESE_DAL + "'"
x_cond = x_soci + " and " + x_anno + " and " + x_mese
CSQL   = "select * from u_iva_cl where " + x_cond + " order by iva_codsoc,iva_anno,iva_mese" 
IF !ExecCommand(CSQL,"u_iva_cl")
   RETURN (.f.)
ENDIF 
SELECT U_IVA_CL
GO TOP
CTRELAB=0
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   IF DELETED()
      SKIP +1
   	  LOOP
   ENDIF	
   IF VAL(IVA_MESE) > VAL(MESE_AL)
   	  EXIT
   ENDIF
   IF VAL(IVA_MESE) < VAL(MESE_DAL)
   	  SKIP +1
   	  LOOP
   ENDIF
   IF IVA_FATNOT = "C"      && NON ELABORA I MOVIMENTI IVA CORRISPETTIVI 
      SKIP +1
   	  LOOP
   ENDIF
   IF !EMPTY(IVA_NUMCEE)    && NON ELABORA I MOVIMENTI DI ACQUISTI CEE
   	  SKIP +1
   	  LOOP
   ENDIF
   SCATTER MEMVAR MEMO
   SELECT ANNI_TMP
   APPEND BLANK
   GATHER MEMVAR MEMO
   CTRELAB=CTRELAB+1
   =CONTATORE("Movimenti Iva",CTRELAB)
   SELECT U_IVA_CL
   SKIP +1
ENDDO

SELECT ANNI_TMP       
INDEX ON  IVA_CHIAVE TAG NUM_FAT   && INDICE PER NUMERO DI FATTURA
SET ORDER TO NUM_FAT
GO TOP

KEY_PRE   = 0

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
      SKIP +1
      LOOP
   ENDIF
    
   WDTCREA   = RIBALTA2(IVA_DTCREA)
   WNUMFAT   = IVA_NUMFAT
   WNUMDOC   = IVA_NUMDOC
   WDTFATT   = RIBALTA2(IVA_DTFATT)
   WCODCLI   = IVA_CODCLI
   WRAGSOC   = IVA_RAGSOC
   WIMPONI   = IVA_IMPONI
   WIMPOST   = IVA_IMPOST
   WCODIVA   = IVA_CODIVA
   WDESIVA   = IVA_DESIVA
   WTOTALE   = IVA_TOTALE
   WLOCALI   = IVA_LOCALI
   WCAP      = IVA_CAP
   WINDIRI   = IVA_INDIRI
   WFATNOT   = IVA_FATNOT
   WPIVA     = IVA_PARIVA
   WAGE		= IVA_CODAGE
   KEY_ATT   = IVA_CHIAVE
   WVALUTA   = IVA_VALUTA
   WCAMBIO   = IVA_CAMBIO 

   IF WFATNOT = "N"
      WT="NCR"
   ELSE
      WT="VEN"  
   ENDIF

   IF KEY_ATT = KEY_PRE         && SBIANCA SOLO SE HO PIU' RECORD=XFATT
      WRAGSOC  = SPACE(35)     
      WNUMFAT  = SPACE(06)
      WNUMDOC  = SPACE(08)
      WDTFATT  = SPACE(10)
      WCODCLI  = SPACE(12)
      WPIVA    = SPACE(16)
	  WT       = SPACE(03) 
   ENDIF 

   IF OK_PROTCL < 0                   && RINUMERA NUMERO DI PROTOCOLLO
   ELSE
      IF !EMPTY(WNUMFAT)
	     OK_PROTCL = OK_PROTCL + 1
	     WNUMFAT   = STR(OK_PROTCL,6,0)
	  ENDIF    
   ENDIF    

   IF !EMPTY(WNUMDOC)
	  IF OK_NFAGE   && SATMPA BOLLATO CON CODICE AGENTE
	     WNUMDOC=ALLTRIM(WNUMDOC)+"/"+ALLTRIM(WAGE)
	     WNUMDOC=ALLTRIM(WNUMDOC)+REPLICATE(" ",7 - LEN(ALLTRIM(WNUMDOC)))
	  ELSE
	     WNUMDOC=ALLTRIM(WNUMFAT)
	     WNUMDOC=ALLTRIM(WNUMDOC)+REPLICATE(" ",7 - LEN(ALLTRIM(WNUMDOC)))
	  ENDIF
   ELSE
	  WNUMDOC=ALLTRIM(WNUMFAT)
	  WNUMDOC=ALLTRIM(WNUMDOC)+REPLICATE(" ",7 - LEN(ALLTRIM(WNUMDOC)))
   ENDIF	
  
   KEY_PRE   = KEY_ATT
  
   SELECT IVA_CL
   APPEND BLANK
   REPLACE DTCREA   WITH WDTCREA
   REPLACE NUMFAT   WITH WNUMFAT 
   REPLACE NUMDOC   WITH WNUMDOC 
   REPLACE DTFATT   WITH WDTFATT 
   REPLACE CODCLI   WITH WCODCLI
   REPLACE RAGSOC   WITH WRAGSOC
   REPLACE IMPONI   WITH WIMPONI
   REPLACE IMPOST   WITH WIMPOST
   REPLACE CODIVA   WITH WCODIVA
   REPLACE DESIVA   WITH WDESIVA
   REPLACE TOTALE   WITH WTOTALE
   REPLACE LOCALI   WITH WLOCALI
   REPLACE CAP      WITH WCAP
   REPLACE INDIRI   WITH WINDIRI
   REPLACE FATNOT   WITH WFATNOT
   REPLACE PIVA     WITH WPIVA 

   ** DATI PER DETTAGLIO STAMPA 

   IF OK_FORMATO = 3
	  IF !EMPTY(WNUMDOC)
	     RIGA_D = "|"+ SUBSTR(WNUMFAT,1,6)+" "+ WDTFATT  +"|"+ WT+" "+ WNUMDOC + WDTFATT +"|"+SUBSTR(WRAGSOC,1,30) +" "+ "|"+ WCODIVA +" |"+ SUBSTR(TRANSFORM(WIMPONI,"99,999,999,999.99"),1,17) +"|   "+ SUBSTR(TRANSFORM(WIMPOST,"9999,999,999.99"),1,15)+"| "+ SUBSTR(TRANSFORM(WTOTALE,"999,999,999,999.99"),1,18)+" |"
	  ELSE
		 RIGA_D = "|"+ SUBSTR(WNUMFAT,1,6)+" "+ WDTFATT  +"|"+ WT+" "+ '       ' + WDTFATT +"|"+SUBSTR(WRAGSOC,1,30) +" "+ "|"+ WCODIVA +" |"+ SUBSTR(TRANSFORM(WIMPONI,"99,999,999,999.99"),1,17) +"|   "+ SUBSTR(TRANSFORM(WIMPOST,"9999,999,999.99"),1,15)+"| "+ SUBSTR(TRANSFORM(WTOTALE,"999,999,999,999.99"),1,18)+" |"
	  ENDIF        
   ELSE
      IF LEN(ALLTRIM(WDESIVA)) > 18
         WDESIVA=SUBSTR(WDESIVA,1,18)
      ELSE
         WDESIVA=ALLTRIM(WDESIVA)+REPLICATE(" ",18-LEN(ALLTRIM(WDESIVA)))
      ENDIF
  	  IF !EMPTY(WNUMDOC)
	     RIGA_D = "|"+ SUBSTR(WNUMFAT,1,6)+" "+ WDTFATT  +"|"+ WT+" "+ WNUMDOC + WDTFATT +"|"+SUBSTR(WRAGSOC,1,35) +"  "+WPIVA+ "|"+ WCODIVA +" |"+ WDESIVA +"|"+SUBSTR(WVALUTA,1,3)+"  |"+STR(WCAMBIO,11,6)+"|"+ SUBSTR(TRANSFORM(WIMPONI,"999,999,999,999.99"),1,18) +"|   "+ SUBSTR(TRANSFORM(WIMPOST,"999,999,999,999.99"),1,18)+"|  "+ SUBSTR(TRANSFORM(WTOTALE,"999,999,999,999.99"),1,18)+" |"
	  ELSE
		 RIGA_D = "|"+ SUBSTR(WNUMFAT,1,6)+" "+ WDTFATT  +"|"+ WT+" "+ '       ' + WDTFATT +"|"+SUBSTR(WRAGSOC,1,35) +"  "+WPIVA+ "|"+ WCODIVA +" |"+ WDESIVA +"|"+SUBSTR(WVALUTA,1,3)+"  |"+STR(WCAMBIO,11,6)+"|"+ SUBSTR(TRANSFORM(WIMPONI,"999,999,999,999.99"),1,18) +"|   "+ SUBSTR(TRANSFORM(WIMPOST,"999,999,999,999.99"),1,18)+"|  "+ SUBSTR(TRANSFORM(WTOTALE,"999,999,999,999.99"),1,18)+" |"
	  ENDIF        
   ENDIF

   REPLACE RIGA     WITH RIGA_D 
   REPLACE CHIAVE   WITH VAL(WNUMFAT)
   REPLACE CHIAVE_R WITH "DET" 

   SELECT ANNI_TMP
   SKIP +1

ENDDO  

RETURN


