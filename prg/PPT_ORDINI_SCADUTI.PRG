************************************
* ORDINI SCADUTI
************************************
LPARAMETERS _NR_GIORNI

IF PCOUNT()<1
	RETURN .F.
ENDIF

LOCAL _SAVE_SEL,_PDF_SUBDIR_,_FILE_DA_ALLEGARE,_PDF_DESCRIZIONE_,_PDF_SELECT_ ,_PDF_REPORT_ ,_PROGRESSIVO_PROGRAMMA,_ALLEGATI

_SAVE_SEL = SELECT()
_PROGRESSIVO_PROGRAMMA = SYS(2015)

_ALLEGATI=""
_FILE_DA_ALLEGARE=""
_PDF_DESCRIZIONE_=""
_PDF_SELECT_ =""
_PDF_REPORT_ =""
_PDF_SUBDIR_ = LEGGE_CONFIG("AQ_SCHEDULER_CONFIG.CFG","PATH_EMAIL")	&& RICERCA DIRECTORY E SOTTODIRECTORY CONTENENTE IL FILE PDF DA CREARE

RELEASE V_TITOLO,V_NR_GIORNI
PUBLIC V_TITOLO,V_NR_GIORNI

V_NR_GIORNI = _NR_GIORNI
V_TITOLO	= "Ordini clienti scaduti da piů di " + ALLTRIM(STR(_NR_GIORNI,10,0)) + " giorni"

WAIT WINDOWS "ESEGUE PROGRAMMA ORDINI IN PROSSIMA CONSEGNA" TIMEOUT 3

*** VARIABILI PUBBLICHE DI UTILIZZO IN PROCEDURE RICHIAMATE
RELEASE PUB_CC,PUB_FF,PUB_SOTTOG,PUB_OPZRSK,PUB_ALIQ,PUB_BOLLA,PUB_FATTU,PUB_IVA,PUB_GGRIBA,PUB_CONTO,PUB_PRDFILM,PUB_PRGPLET,PUB_PRDFPR
PUBLIC PUB_CC,PUB_FF,PUB_SOTTOG,PUB_OPZRSK,PUB_ALIQ,PUB_BOLLA,PUB_FATTU,PUB_IVA,PUB_GGRIBA,PUB_CONTO,PUB_PRDFILM,PUB_PRGPLET,PUB_PRDFPR
PUB_CC = 0
PUB_FF = 0
PUB_SOTTOG = 0
PUB_OPZRSK = 0
PUB_ALIQ = 0
PUB_BOLLA = ""
PUB_FATTU = ""
PUB_IVA = ""
PUB_GGRIBA = 0
PUB_CONTO = ""
PUB_PRDFILM = .F.
PUB_PRGPLET = .F.
PUB_PRDFPR = .F.
=AQUADOCU()

IF USED("C_ORD_DD")
	SELECT C_ORD_DD
	USE	
ENDIF

IF !ExecCommand("select SPACE(50) AS CLIENTE, SPACE(50) AS ARTICOLO, SPACE(3) AS COLORE_FRONTE, SPACE(3) AS COLORE_RETRO, SPACE(1) AS FINITURA, " + ;
	"SPACE(10) AS OLD_NUMPRG, 0 AS OLD_NUMBOP, SPACE(40) AS OLD_NOTA, SPACE(100) AS OLD_NOTEPRO, SPACE(100) AS OLD_NOTESPE, SPACE(100) AS OLD_NOTEVAR, SPACE(20) AS OLD_STAPRO, " + ;
	"0 AS OLD_NPZPRD1, 0 AS OLD_NPZPRD2, 0 AS OLD_NPZPRD3, 0 AS ORD_NRIGAP, 0 AS N_ORDINE, SPACE(254) AS ORS_DESTIN, * from U_ORD_DD where 0=1","C_ORD_DD")
  return(.f.)
ENDIF

SELECT C_ORD_DD
INDEX ON FINITURA+COLORE_FRONTE+COLORE_RETRO+STR(ORD_ALTEZZ)+STR(ORD_LUNGHE) TAG I_ORDINA ADDITIVE
SET ORDER TO I_ORDINA

x_test = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORD_TT)"
x_comm = "ORD_CODART <> '' AND ORD_DESART <> '*** COMMENTO ***'"
x_evas = "(ORD_CHIUSO = 0 and ORD_QTAORD > ORD_QTAEV)"
x_clie = "ORS_CODCLI <> (SELECT TOP 1 AZI_CODCLI FROM U_AZI_AN)"
x_dcon = "ORD_DATCON <= convert(varchar, DATEADD(day, -" + ALLTRIM(STR(V_NR_GIORNI,10,0)) + ", GETDATE()), 111)"
x_cond = x_test + " and " + x_comm + " and " + x_evas + " and " + x_clie + " and " + x_dcon 
cSql = 	"SELECT ORD_NUMPRG AS OLD_NUMPRG, ORD_NUMBOP AS OLD_NUMBOP, ORD_NOTA AS OLD_NOTA, ORD_NOTEPRO AS OLD_NOTEPRO, ORD_NOTESPE AS OLD_NOTESPE, ORD_NOTEVAR AS OLD_NOTEVAR, " + ;
		"ORD_STAPRO AS OLD_STAPRO, ORD_NPZPRD1 AS OLD_NPZPRD1, ORD_NPZPRD2 AS OLD_NPZPRD2, ORD_NPZPRD3 AS OLD_NPZPRD3, * from U_ORD_DD LEFT OUTER JOIN (" + ;
		"select u_art_pr.art_codpri, u_art_pr.art_codcol AS COLORE_FRONTE, coalesce(u_art_an.art_codcolret,'') as COLORE_RETRO, " + ;
		"coalesce(u_art_an.art_fini,'') as FINI, coalesce(u_art_an.art_tipog,'') as TIPOG, coalesce(u_art_an.art_tipon,'') as TIPON from u_art_pr left outer join u_art_an on u_art_pr.art_codsoc = u_art_an.art_codsoc " + ;
		"and u_art_pr.art_codpri = u_art_an.art_codpri) AS ANAART ON U_ORD_DD.ORD_CODART = ANAART.ART_CODPRI " + ;
		"LEFT OUTER JOIN (select CODICE, descri as DESFINI from para) as PARA_FIN ON PARA_FIN.CODICE = 'FIN'+ANAART.FINI WHERE " + x_cond
IF !ExecCommand(cSql,"CX_ORD_DD")
  return(.f.)
ENDIF
SELECT CX_ORD_DD
GO TOP
SCAN
    SCATTER MEMVAR MEMO
    
	_ORS_DESTIN = ""
	x_agga = "TAGGANCIO = '" + M.DAGGANCIO + "'"
	x_cond = x_agga 
	cSql = 	"SELECT TAGGANCIO,ORD_RAGC,ORD_AGE,ORD_INDC,ORD_CAPC,ORD_LOCC,ORD_PROC,ORD_RAGSOC,ORD_INDIRI,ORD_CAP,ORD_LOCALI,ORD_PROVIN FROM U_ORD_TT WHERE " + x_cond
	IF !ExecCommand(cSql,"TMP_ORD_TT")
	  return(.f.)
	ENDIF
	SELECT TMP_ORD_TT
	GO TOP
	IF !EOF()
		IF !EMPTY(ORD_RAGC)
			_ORS_DESTIN = ALLTRIM(ORD_RAGC)+" - "+ALLTRIM(ORD_INDC)+' - '+ALLTRIM(ORD_CAPC)+" - "+ALLTRIM(ORD_LOCC)+" ("+ALLTRIM(ORD_PROC)+")"
		ELSE
			_ORS_DESTIN = ALLTRIM(ORD_RAGSOC)+" - "+ALLTRIM(ORD_INDIRI)+' - '+ALLTRIM(ORD_CAP)+" - "+ALLTRIM(ORD_LOCALI)+" ("+ALLTRIM(ORD_PROVIN)+")"
		ENDIF
	ELSE
		SELECT CX_ORD_DD
		LOOP		
	ENDIF
	
*!*		IF !EMPTY(_V_DESTIN)
*!*			IF UPPER(ALLTRIM(_V_DESTIN)) $ UPPER(ALLTRIM(_ORS_DESTIN))
*!*			ELSE
*!*				SELECT CX_ORD_DD
*!*				LOOP
*!*			ENDIF
*!*		ENDIF
*!*		
*!*		IF !EMPTY(_V_CODAGE)
*!*			IF ALLTRIM(_V_CODAGE) == ALLTRIM(ORD_AGE)
*!*			ELSE
*!*				SELECT CX_ORD_DD
*!*				LOOP
*!*			ENDIF
*!*		ENDIF
    
    SELECT C_ORD_DD
    APPEND BLANK
    GATHER MEMVAR MEMO
    
    REPLACE CLIENTE WITH ALLTRIM(ORS_RAGSOC)  + ' (' + ALLTRIM(ORS_CODCLI) + ')'
    REPLACE ARTICOLO WITH ALLTRIM(ORD_DESART)
    REPLACE COLORE_FRONTE WITH M.COLORE_FRONTE 
    REPLACE COLORE_RETRO WITH M.COLORE_RETRO 
    REPLACE FINITURA WITH IIF(ISNULL(M.FINI) OR EMPTY(M.FINI),"",ALLTRIM(M.FINI))
    REPLACE ORS_DESTIN WITH _ORS_DESTIN
    IF !EMPTY(M.ORD_CDAPRD) AND ALLTRIM(M.ORD_CDAPRD) <> ALLTRIM(M.ORD_CODART)
    	REPLACE ORD_CDAPRD WITH M.ORD_CDAPRD
    ELSE
    	REPLACE ORD_CDAPRD WITH ""
    ENDIF
   
ENDSCAN

IF USED("STA_ORD_DD")
	SELECT STA_ORD_DD
	USE	
ENDIF

SELECT SPACE(100) AS NOTECONTAB, CAST('' AS MEMO) AS NOTEANAGR, SPACE(200) AS ORD_NOTESPEVAR, SPACE(100) AS ORS_RAGC, * FROM C_ORD_DD ORDER BY CLIENTE,ORS_DESTIN,ORS_DATORD,ORS_NUMORD INTO CURSOR STA_ORD_DD READWRITE

_OLD_CLIENTE = ""
_OLD_NOTECONTAB = ""
_OLD_NOTEANAGR = ""
SELECT STA_ORD_DD
GO TOP
SCAN
	_ACT_CLIENTE = CLIENTE
	IF ALLTRIM(_ACT_CLIENTE) == ALLTRIM(_OLD_CLIENTE)
	ELSE
		_OLD_NOTECONTAB = ""
		SELECT STA_ORD_DD
		DO VERIFICA_ESPOSIZIONE_CLIENTE WITH ORS_CODCLI,DTOC(DATE())
		IF V_FIDOCLIENTE+V_FIDOCLIENTEA=0
		ELSE
			IF V_ESPOSIZIONE > (V_FIDOCLIENTE+V_FIDOCLIENTEA)
			   _OLD_NOTECONTAB = "ESPOSIZIONE SUPERIORE AL FIDO"
			ENDIF
		ENDIF
		
		_OLD_NOTEANAGR = ""
		SELECT STA_ORD_DD
		x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
		x_codi = "cli_codcli = '" + ORS_CODCLI + "'"
		x_cond = x_soci + " and " + x_codi
		cSql = 	"SELECT CLI_CODCLI,CLI_NOTSPA,CLI_NOTTAG,CLI_NOTSPE FROM U_CLI_AN WHERE " + x_cond
		IF !ExecCommand(cSql,"CX_CLI_AN")
		  return(.f.)
		ENDIF
		SELECT CX_CLI_AN
		GO TOP
		IF !EOF()
			_OLD_NOTEANAGR = _OLD_NOTEANAGR+IIF(!EMPTY(CLI_NOTSPA),IIF(!EMPTY(_OLD_NOTEANAGR),CHR(13),"")+ALLTRIM(CLI_NOTSPA),"")
			_OLD_NOTEANAGR = _OLD_NOTEANAGR+IIF(!EMPTY(CLI_NOTTAG),IIF(!EMPTY(_OLD_NOTEANAGR),CHR(13),"")+ALLTRIM(CLI_NOTTAG),"")
			_OLD_NOTEANAGR = _OLD_NOTEANAGR+IIF(!EMPTY(CLI_NOTSPE),IIF(!EMPTY(_OLD_NOTEANAGR),CHR(13),"")+ALLTRIM(CLI_NOTSPE),"")
		ENDIF
		
		SELECT STA_ORD_DD
		_OLD_CLIENTE = CLIENTE
	ENDIF
	
	SELECT STA_ORD_DD
	_ORS_DESTIN = ""
	x_agga = "TAGGANCIO = '" + DAGGANCIO + "'"
	x_cond = x_agga 
	cSql = 	"SELECT TAGGANCIO,ORD_RAGC,ORD_INDC,ORD_CAPC,ORD_LOCC,ORD_PROC FROM U_ORD_TT WHERE " + x_cond
	IF !ExecCommand(cSql,"CX_ORD_TT")
	  return(.f.)
	ENDIF
	SELECT CX_ORD_TT
	GO TOP
	IF !EOF()
		IF !EMPTY(ORD_RAGC)
			_ORS_DESTIN = ALLTRIM(ORD_RAGC)+" - "+ALLTRIM(ORD_INDC)+' - '+ALLTRIM(ORD_CAPC)+" - "+ALLTRIM(ORD_LOCC)+" ("+ALLTRIM(ORD_PROC)+")"
		ENDIF
	ENDIF
	
	SELECT STA_ORD_DD
	REPLACE NOTECONTAB WITH _OLD_NOTECONTAB
	REPLACE NOTEANAGR WITH _OLD_NOTEANAGR
	_NOTESPEVAR = ALLTRIM(ORD_NOTESPE)
	_NOTESPEVAR = _NOTESPEVAR + IIF(EMPTY(_NOTESPEVAR),"",CHR(13)) + ALLTRIM(ORD_NOTEVAR)
	REPLACE ORD_NOTESPEVAR WITH _NOTESPEVAR
	REPLACE ORS_DESTIN WITH _ORS_DESTIN
ENDSCAN

SELECT STA_ORD_DD
GO TOP

_PDF_REPORT_		= ALLTRIM(CERCAREPO("XXX","PPT_ORDINI_SCADUTI","PPT_ORDINI_SCADUTI.FRX"))
_PDF_DESCRIZIONE_	= V_TITOLO+_PROGRESSIVO_PROGRAMMA 
_PDF_SELECT_ 		= "STA_ORD_DD"

IF !EMPTY(_PDF_SUBDIR_ )
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_,_PDF_SUBDIR_ )
ELSE
	=CREA_FILE_PDF(_PDF_SELECT_,_PDF_REPORT_,_PDF_DESCRIZIONE_)
ENDIF

_FILE_DA_ALLEGARE = ALLTRIM(_PDF_DESCRIZIONE_)+".PDF"

_ALLEGATI = _ALLEGATI + IIF(EMPTY(_ALLEGATI),"",";")+_FILE_DA_ALLEGARE 


_ERRORE =.F.
DO PRG\INVIA_MAIL_SCHEDULATE WITH _ERRORE,_ALLEGATI ,_ID_EMAIL_DA_INVIARE


SELECT(_SAVE_SEL )
	
