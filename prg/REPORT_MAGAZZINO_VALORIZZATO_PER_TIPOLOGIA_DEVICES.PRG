
_SEC_INI = SECONDS()

R_CODART = ""
X_COND = ""

_risp = MESSAGEBOX("Estrarre il report magazzino valorizzato per tipologia devices per tutti gli articoli di con Linea prodotto 1,2,2E,3,3F,4 ?",4+32,"Attenzione")
IF _risp = 6
ELSE
	_C_CODART = PJ_INPUTBOX("Inserire l'articolo con Linea prodotto 1,2,2E,3,3F,4 per cui estrarre il report","Digitazione articolo","")
	IF EMPTY(_C_CODART)
		MESSAGEBOX("Nessun articolo digitato",48,"Attenzione")
		RETURN .F.
	ENDIF
	R_CODART = ALLTRIM(_C_CODART)
ENDIF

IF !EMPTY(R_CODART)
	X_COND = "T.CODART_BASE = '" + ALLTRIM(R_CODART) + "' AND "
ENDIF

_risp = MESSAGEBOX("Continuare con l'estrazione del report" + IIF(!EMPTY(ALLTRIM(R_CODART))," per l'articolo " + ALLTRIM(R_CODART)," per tutti gli articoli in giacenza con Linea prodotto 1,2,2E,3,3F,4") + " ?",4+32,"Attenzione")
IF _risp = 6
ELSE
	RETURN .T.
ENDIF

WAIT WINDOWS "Estrazione in corso..." NOWAIT

CREATE CURSOR GIACENZE_DIBA (CODART C(30), DESART C(200), LINEA C(3), CODMAG C(6), GIACEN NUMERIC(19,2), QTAIMP NUMERIC(19,2), VALEFF NUMERIC(19,2), VALSTD NUMERIC(19,2), VALULT NUMERIC(19,2), CODGMI M, DESGMI M, PADRI_PREF_8 M)
INDEX ON ALLTRIM(CODART)+ALLTRIM(CODMAG) TAG I_ARTMAG

cSql=""
cNomeCursorSql="CX_GIACENZE_DIBA"
TEXT TO cSql NOSHOW
	
	SELECT
		 T.CODART_BASE
		,PR_BASE.ART_DESCR AS DESART
		,PR_BASE.ART_LINEA AS LINEA
		,T.PADRE_PREF_8
		,GG.MAG_CODMAG AS CODMAG
		,GG.MAG_GIACEN AS GIACEN
		,GG.MAG_QTAIMP AS QTAIMP
		,GG.MAG_VALEFF AS VALEFF
		,PR_BASE.ART_PRZCOS * GG.MAG_GIACEN AS VALSTD
		,PR_BASE.ART_ULPCAR * GG.MAG_GIACEN AS VALULT
		,AN.ART_CODGMI AS CODGMI
		,COALESCE(PARA_GMI.DESCRI,'') AS DESGMI
	FROM ELENCO_IMPLOSIONE_DIBA_CON_PADRE_PREF_8 AS T
	INNER JOIN (SELECT MAG_CODMAG, MAG_ANAART, SUM(MAG_GIACEN) AS MAG_GIACEN, SUM(MAG_QTAIMP) AS MAG_QTAIMP, SUM(MAG_PRZVALU * MAG_GIACEN) AS MAG_VALEFF FROM V_MAG_GG GROUP BY MAG_CODMAG, MAG_ANAART) AS GG 
		ON GG.MAG_ANAART = T.CODART_BASE AND GG.MAG_GIACEN > 0
	LEFT OUTER JOIN U_ART_PR AS PR_BASE ON PR_BASE.ART_CODPRI = T.CODART_BASE
	LEFT OUTER JOIN U_ART_PR AS PR ON PR.ART_CODPRI = T.PADRE_PREF_8
	LEFT OUTER JOIN U_ART_AN AS AN ON AN.ART_CODPRI = PR.ART_CODPRI
	LEFT OUTER JOIN PARA AS PARA_GMI ON PARA_GMI.CODICE = 'GMI'+AN.ART_CODGMI 
	--WHERE <<X_COND>> T.CODART_BASE IN (SELECT ART_CODPRI FROM U_ART_PR WHERE ART_OBSOL <> 'S' AND ART_TIPART = 'A' AND ART_NONMOV = 0)
	WHERE <<X_COND>> T.CODART_BASE IN (SELECT ART_CODPRI FROM U_ART_PR WHERE ART_OBSOL <> 'S' AND ART_LINEA IN ('1','2','2E','3','3F','4') AND ART_NONMOV = 0)  -- ERASMO - 14/04/2023
	ORDER BY T.CODART_BASE, GG.MAG_CODMAG

ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql,.T.)
	return(.F.)
ENDIF
*** SE L'UTENTE HA ANNULLATO LA QUERY IL CURSORE POTREBBE NON ESISTERE, 
*** QUINDI NON PERMETTO DI ANDARE AVANTI
IF !USED("CX_GIACENZE_DIBA")
	RETURN .F.
ENDIF

SELECT CX_GIACENZE_DIBA
GO TOP
IF EOF()
	MESSAGEBOX("Nessun dato da estrarre per i filtri selezionati",64,"Informazione")
	RETURN .T.
ENDIF


SELECT CX_GIACENZE_DIBA
GO TOP
SCAN
	WAIT WINDOWS "Elaborazione in corso... " + ALLTRIM(STR(RECNO() / RECCOUNT() * 100)) + "%" NOWAIT
	
	SCATTER MEMVAR MEMO
	
	SELECT GIACENZE_DIBA
	SET ORDER TO I_CODART
	GO TOP
	SEEK ALLTRIM(M.CODART_BASE)+ALLTRIM(M.CODMAG)
	
	IF !FOUND()
		APPEND BLANK
		REPLACE CODART WITH M.CODART_BASE
		REPLACE DESART WITH M.DESART 
		REPLACE LINEA WITH M.LINEA 
		REPLACE CODMAG WITH M.CODMAG 
		REPLACE GIACEN WITH M.GIACEN 
		REPLACE QTAIMP WITH M.QTAIMP 
		REPLACE VALEFF WITH M.VALEFF 
		REPLACE VALSTD WITH M.VALSTD 
		REPLACE VALULT WITH M.VALULT 
		REPLACE CODGMI WITH ALLTRIM(M.CODGMI)
		REPLACE DESGMI WITH ALLTRIM(M.DESGMI)
		REPLACE PADRI_PREF_8 WITH "*"+ALLTRIM(M.PADRE_PREF_8)+"*"
	ELSE
		REPLACE CODGMI WITH ALLTRIM(CODGMI) + IIF(ALLTRIM(M.CODGMI) $ ALLTRIM(CODGMI),"",", " + ALLTRIM(M.CODGMI))
		REPLACE DESGMI WITH ALLTRIM(DESGMI) + IIF(ALLTRIM(M.DESGMI) $ ALLTRIM(DESGMI),"",", " + ALLTRIM(M.DESGMI))		
		REPLACE PADRI_PREF_8 WITH ALLTRIM(PADRI_PREF_8) + IIF("*"+ALLTRIM(M.PADRE_PREF_8)+"*" $ ALLTRIM(PADRI_PREF_8),"",", " + "*"+ALLTRIM(M.PADRE_PREF_8)+"*")
	ENDIF
ENDSCAN

_SEC_FIN = SECONDS()
*MESSAGEBOX("TOTALE SECONDI IMPIEGATI: " + ALLTRIM(STR(_SEC_FIN - _SEC_INI)),64,"Informazione")

_TITOLO_EXCEL1 = "Report magazzino valorizzato per tipologia devices"
_TITOLO_EXCEL2 = IIF(!EMPTY(ALLTRIM(R_CODART)),"Articolo: " + ALLTRIM(R_CODART),"Tutti gli articoli in giacenza")
_TITOLO_EXCEL3 = ""
_TOTALI_GENERALI = .T.
DO ESTRXLS WITH "GIACENZE_DIBA",_TITOLO_EXCEL1,_TITOLO_EXCEL2,_TITOLO_EXCEL3,_TOTALI_GENERALI

MESSAGEBOX("Fine elaborazione",64,"Informazione")


