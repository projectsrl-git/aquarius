**************************************************************************
PROCEDURE CALCOLO_DEL_BILANCIO_GESTIONALE
**************************************************************************

LPARAMETERS _PAR_ANNO_INIZIALE  ,_PAR_MESE_INIZIALE  ,_PAR_ANNO_FINALE ,_PAR_MESE_FINALE ,_CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI,__ESCLUDE_RATEI_RISCONTI


IF PCOUNT()<4
   PUB_ERRORE=MESSAGEBOX("E' necessario valorizzare il mese inizale o il mese finale",48,"Attenzione") 
   RETURN .F.
ENDIF

IF PCOUNT()<5
	_CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI = .F.
   __ESCLUDE_RATEI_RISCONTI = .F.
   RETURN .F.
ENDIF

IF PCOUNT()<6
   __ESCLUDE_RATEI_RISCONTI = .F.
   RETURN .F.
ENDIF

IF (_PAR_MESE_INIZIALE  > 12) .OR. (_PAR_MESE_INIZIALE  < 1)
   PUB_ERRORE=MESSAGEBOX("Mese iniziale "+_PAR_MESE_INIZIALE +" non valido",48,"Attenzione") 
   RETURN .F.
ENDIF
IF (_PAR_MESE_FINALE > 12) .OR. (_PAR_MESE_FINALE < 1)
   PUB_ERRORE=MESSAGEBOX("Mese finale "+_PAR_MESE_FINALE +" non valido",48,"Attenzione") 
   RETURN .F.
ENDIF

PUB_DESBLOCCOPN = ""	&& SERGIO 2015/03/11 SERVE PER LA VERIFICA FINALE SUL CONTROLLO DI CONTEMPORANEITA PRIMA NOTA-CALCOLO BILANCIO-CARICAMENTO BOLLATIIVA

***************************************************************************************
__CODICE_DA_RICERCARE	= "100"		&& VERIFICA SE AGGIORNAMENTO PRIMA NOTA IN CORSO
__VALORE_DA_AGGIORNARE	= "SI"
__ELABORAZIONE_IN_CORSO=VERIFICA_ELABORAZIONI_CONTABILI(__CODICE_DA_RICERCARE)
IF __ELABORAZIONE_IN_CORSO = "SI"
   RETURN(.F.)
ENDIF
***************************************************************************************

***************************************************************************************
__CODICE_DA_RICERCARE	= "200"		&& VERIFICA SE CALCOLO BILANCIO IN CORSO
__VALORE_DA_AGGIORNARE	= "SI"
__ELABORAZIONE_IN_CORSO=VERIFICA_ELABORAZIONI_CONTABILI(__CODICE_DA_RICERCARE)
IF __ELABORAZIONE_IN_CORSO = "SI"
   RETURN(.F.)
ENDIF
***************************************************************************************

***************************************************************************************
__CODICE_DA_RICERCARE	= "300"		&& VERIFICA SE CARICAMENTO BOLLATO IVA IN CORSO
__VALORE_DA_AGGIORNARE	= "SI"
__ELABORAZIONE_IN_CORSO=VERIFICA_ELABORAZIONI_CONTABILI(__CODICE_DA_RICERCARE)
IF __ELABORAZIONE_IN_CORSO = "SI"
   RETURN(.F.)
ENDIF
***************************************************************************************

*!*	IF PUB_NOBLOPN	&& SERGIO 2015/03/10 NON GESTISCE IL CONTROLLO SULLA PRESENZA CONTEMPORANEA DI PRIMANOTA-CALCOLO-BILANCIO-BOLLATI

*!*		IF !EMPTY(PUB_DESBLOCCOPN)
*!*		
*!*			_MESSAGGIO = CHR(13)+ALLTRIM(PUB_DESBLOCCOPN)+CHR(10)+CHR(10)+;
*!*				 "ATTENZIONE : Vuoi proseguire COMUNQUE nel calcolo del bilancio?"
*!*			IF !MESSAGGIO_PICCOLO_BLU_RISPOSTA_SI_NO(_MESSAGGIO) = "SI"
*!*				RETURN .F.		
*!*			ENDIF 	
*!*		
*!*		ENDIF
*!*	ENDIF

**=> ERASMO - INIZIO 08/04/2019
WAIT WINDOW "Preparazione dati per il calcolo del bilancio gestionale in corso - attendere prego..."  NOWAIT  
Csql = "UPDATE MOV_CONT SET MOV_DTCOMP = MOV_DTDOC WHERE MOV_DTCOMP = ''"
IF !ExecCommand(Csql,"UPD_MOV_CONT")
   return(.f.)
ENDIF	
**=> ERASMO - FINE 08/04/2019

*******************************************************************************************************
WAIT WINDOW "Calcolo del bilancio in corso esercizio contabile "+PUB_ANNO+" attendere prego..."  NOWAIT  

***************************************************************************
__CODICE_DA_RICERCARE	= "200"		&& INIZIO CALCOLO BILANCIO
__VALORE_DA_AGGIORNARE	= "SI"
=AGGIORNA_ELABORAZIONI_CONTABILI(__CODICE_DA_RICERCARE,__VALORE_DA_AGGIORNARE)
***************************************************************************

DO BILANCIO_RICREA_SALDI_ANNO_GESTIONALE WITH _PAR_ANNO_INIZIALE  ,_PAR_MESE_INIZIALE  ,_PAR_ANNO_FINALE ,_PAR_MESE_FINALE ,_CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI,__ESCLUDE_RATEI_RISCONTI 

SELECT CU_CONTI
GO TOP

PAT_DARE    = 0
PAT_AVERE   = 0
PAT_SALDO   = 0

ECO_DARE    = 0
ECO_AVERE   = 0
ECO_SALDO   = 0

TOT_DARE	= 0
TOT_AVERE	= 0
TOT_SALDO	= 0

SUM CON_IMP_D TO PAT_DARE 	FOR LEN(ALLTRIM(CON_CONTO))>=PUB_SOTTOG AND CON_POSBIL='P'
SUM CON_IMP_A TO PAT_AVERE	FOR LEN(ALLTRIM(CON_CONTO))>=PUB_SOTTOG AND CON_POSBIL='P'

PAT_SALDO   = PAT_DARE - PAT_AVERE

SUM CON_IMP_D TO ECO_DARE    FOR LEN(ALLTRIM(CON_CONTO))>=PUB_SOTTOG AND CON_POSBIL='E'
SUM CON_IMP_A TO ECO_AVERE   FOR LEN(ALLTRIM(CON_CONTO))>=PUB_SOTTOG AND CON_POSBIL='E'

ECO_SALDO   = ECO_DARE - ECO_AVERE   

TOT_SALDO   = PAT_SALDO   + ECO_SALDO   


*** FAB - 12/11/2011 ARROTONDAMENTO DEI CENTESIMI
***
*** SE HO UNO SBILANCIO MINORE DI +/- 10 CENT. FACCIO UN UPDATE DELLO SBILANCIO SU
*** 1) IL CONTO IMPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
*** 2) SE 1) NON ESISTE SU PARA OPPURE ESISTE SU PARA MA NON SU CONTI, ALLORA FACCIO UN UPDATE SUL PRIMO CONTO CHE TROVO SULL'ANNO E RICALCOLO I SALDI


IF TOT_SALDO <> 0 .AND. ABS(TOT_SALDO) < 0.10

	_MESE_DA_AGGIORNARE=PADL(ALLTRIM(STR(_PAR_MESE_INIZIALE ,2,0)),2,"0")

	_strdelta = ALLTRIM(STRTRAN(STR(TOT_SALDO,20,2),',','.'))
	
	*** CERCO IL CONTO INPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
	
	Csql   = "SELECT * FROM PARA WHERE CODICE='CAA"+PUB_ANNO+"'"
	IF !ExecCommand(Csql,"UPD_CONTI")
	   return(.f.)
	ENDIF	
	
	SELECT UPD_CONTI
	
	_CONTO_ARROTONDAMENTI = ""
	_CONTO_ARROTONDAMENTI_PAT_ECO = "E"
	
	IF !EOF()
		_CONTO_ARROTONDAMENTI = ALLTRIM(LIBERA)
	ENDIF
	
	*** IL CONTO PER GLI ARROTONDAMENTI E' IMPOSTATO SU PARA
	*** ORA LO CERCO SU CONTI
	
	Csql   = "SELECT CON_CONTO,CON_POSBIL FROM CONTI WHERE CON_CONTO='"+_CONTO_ARROTONDAMENTI+"' AND CON_ANNO='"+PUB_ANNO+"' " 
	IF !ExecCommand(Csql,"UPD_CONTI")
	   return(.f.)
	ENDIF	
	
	SELECT UPD_CONTI
	IF EOF()
		_CONTO_ARROTONDAMENTI = ""
	ELSE
		_CONTO_ARROTONDAMENTI_PAT_ECO = CON_POSBIL	
	ENDIF	
	
	IF !EMPTY(_CONTO_ARROTONDAMENTI )
		*** FACCIO UN UPDATE SUL CONTO IMPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		Csql   = "UPDATE CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO='" +_CONTO_ARROTONDAMENTI  + "' AND " + x_anno
		
		_MASTRO_CONTO_ARROTONDAMENTI = SUBSTR(ALLTRIM(_CONTO_ARROTONDAMENTI ),1,PUB_SOTTOG-1)
		*** FACCIO UN UPDATE SUL MASTRO DEL CONTO IMPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		Csql_MASTRO   = "UPDATE CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO='" +_MASTRO_CONTO_ARROTONDAMENTI   + "' AND " + x_anno
	ELSE
		*** FACCIO UN UPDATE SUL PRIMO CONTO CHE TROVO SULL'ANNO E RICALCOLO I SALDI
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		x_cont = "LEN(CON_CONTO) >= "+ ALLTRIM(STR(PUB_SOTTOG))
		x_pbil = "CON_POSBIL = 'E'"
		x_cimp = "CON_IMP_D <> CON_IMP_A"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont + " and " + x_pbil + " and " + x_cimp 
		Csql   = "UPDATE CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO IN " + ;
				"(SELECT TOP 1 CON_CONTO FROM CONTI WHERE " + x_cond + " ORDER BY CON_CONTO ) AND " + x_anno
				
				
		*** FACCIO UN UPDATE SUL  PRIMO MASTRO CHE TROVO SULL'ANNO E RICALCOLO I SALDI
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		x_cont = "LEN(CON_CONTO) = "+ ALLTRIM(STR(PUB_SOTTOG-1))
		x_pbil = "CON_POSBIL = 'E'"
		x_cimp = "CON_IMP_D <> CON_IMP_A"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont + " and " + x_pbil + " and " + x_cimp 
		Csql_MASTRO   = "UPDATE CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO IN " + ;
				"(SELECT TOP 1 CON_CONTO FROM CONTI WHERE " + x_cond + " ORDER BY CON_CONTO ) AND " + x_anno
	
	ENDIF 	
	
	IF !ExecCommand(Csql,"UPD_CONTI")
	   return(.f.)
	ENDIF
	
	IF !ExecCommand(Csql_MASTRO,"UPD_CONTI")
	   return(.f.)
	ENDIF
	
	DO CASE
		CASE _CONTO_ARROTONDAMENTI_PAT_ECO ="P"
			PAT_DARE = PAT_DARE - TOT_SALDO 
		CASE _CONTO_ARROTONDAMENTI_PAT_ECO ="E"
			ECO_DARE = ECO_DARE - TOT_SALDO 
	ENDCASE
	
	PAT_SALDO   = PAT_DARE - PAT_AVERE

	ECO_SALDO   = ECO_DARE - ECO_AVERE   

	TOT_SALDO   = PAT_SALDO   + ECO_SALDO   	
	
ENDIF


***************************************************************************
__CODICE_DA_RICERCARE	= "200"		&& FINE  CALCOLO BILANCIO
__VALORE_DA_AGGIORNARE	= ""
=AGGIORNA_ELABORAZIONI_CONTABILI(__CODICE_DA_RICERCARE,__VALORE_DA_AGGIORNARE)
***************************************************************************

RETURN



**************************************************************************
PROCEDURE BILANCIO_RICREA_SALDI_ANNO_GESTIONALE
**************************************************************************
* RICREA I SALDI DI TUTTO L'ANNO
**************************************************************************
LPARAMETERS _PAR_ANNO_INIZIALE,_PAR_MESE_INIZIALE ,_PAR_ANNO_FINALE,_PAR_MESE_FINALE,_CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI,__ESCLUDE_RATEI_RISCONTI 

LOCAL _CALBIL_MESE

*** azzero i conti dell'anno
WAIT WINDOW "Azzera e ricrea i saldi dell'anno contabile "+PUB_ANNO+"..."  NOWAIT

* SERGIO 2015/12/12
DO VERIFICA_ESISTENZA_GRUPPI_SOTTOGRUPPI_SU_CURSORE_CONTI_GESTIONALE
* SERGIO 2015/12/12



X_SOCI = "CON_SOC = '" + PUB_CODSOC + "'"
X_ANNO = "CON_ANNO = '" + PUB_ANNO + "'"
X_COND = X_SOCI + " AND " + X_ANNO
CSQL   = "SELECT * FROM CONTI WHERE " + X_COND + " ORDER BY CON_SOC,CON_ANNO,CON_CONTO"
IF !ExecRW(cSql,"CONTI","R")
   RETURN(.F.)
ENDIF
SELECT CONTI
AFIELDS(_STRUTTURA_DATI)
CREATE CURSOR CU_CONTI FROM ARRAY _STRUTTURA_DATI
SELECT CU_CONTI
INDEX ON CON_SOC + CON_ANNO + CON_CONTO TAG I_CONTO ADDITIVE



SELECT CONTI
GO TOP

DO WHILE !EOF()

	REPLACE CON_IMP_D WITH 0
	REPLACE CON_IMP_A WITH 0
		
	REPLACE PRE_IMP_D WITH 0
	REPLACE PRE_IMP_A WITH 0
	
	FOR _INDICE_MESE=1 TO 12     
    
		_STR_INDICE_MESE= PADL(ALLTRIM(STR(_INDICE_MESE,2,0)),2,"0")

		REPLACE CON_DA&_STR_INDICE_MESE WITH 0
		REPLACE CON_AV&_STR_INDICE_MESE WITH 0

		REPLACE PRE_DA&_STR_INDICE_MESE WITH 0
  		REPLACE PRE_AV&_STR_INDICE_MESE WITH 0
		
	NEXT

    SCATTER MEMVAR MEMO

	*** RICREA IN CU_CONTI GLI STESSI RECORD DI CONTI
	SELECT CU_CONTI
	APPEND BLANK
	GATHER MEMVAR MEMO

	SELECT CONTI
	SKIP +1

ENDDO  


WAIT WINDOW "Ricreazione saldi in corso esercizio contabile "+PUB_ANNO+" attendere prego..."  NOWAIT  

_CALBIL_MOVIMENTI_CONTABILI_ELABORATI = 0

**** ELABORO MOV_CONT PER CACOLARE DARE / AVERE VALORIZZATI AL CAMBIO DELLA SINGOLA REGISTRAZIONE
DO BILANCIO_CARICA_PRIMA_NOTA_GESTIONALE WITH _PAR_ANNO_INIZIALE,_PAR_MESE_INIZIALE ,_PAR_ANNO_FINALE,_PAR_MESE_FINALE ,_CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI,__ESCLUDE_RATEI_RISCONTI 

** CONTROAGGIORNA IL DATABASE CONTI ARROTONDANDO UNA SOLA VOLTA A DUE DECIMALI E PRENDENDO I VALORI DA CU_CONTI

SELECT CU_CONTI
GO TOP


WAIT WINDOW "Aggiornamento archivio CONTI in corso esercizio contabile "+PUB_ANNO+" attendere prego..."  NOWAIT  


** CONTROAGGIORNA IL DATABASE CONTI ARROTONDANDO UNA SOLA VOLTA A DUE DECIMALI E PRENDENDO I VALORI DA CU_CONTI

SELECT CONTI
GO TOP
DO WHILE !EOF()

    XCONTO = ALLTRIM(CON_CONTO)

	SELECT CU_CONTI
	SET ORDER TO I_CONTO
	___SEEK = PUB_CODSOC+PUB_ANNO+ALLTRIM(XCONTO)
	SEEK ___SEEK 
	IF !FOUND()
        WAIT WINDOW "Creazione saldi anno "+PUB_ANNO+" - conto inesistente "+XCONTO  
        SELECT CONTI
		SKIP 
		LOOP 
	ENDIF

	SCATTER MEMVAR 
	
	SELECT CONTI
				
	FOR _CALBIL_MESE = _PAR_MESE_INIZIALE TO _PAR_MESE_FINALE 
	    
	    V_MM = PADL(ALLTRIM(STR(_CALBIL_MESE,2,0)),2,"0")

	    REPLACE CON_DA&V_MM WITH M.CON_DA&V_MM
	    REPLACE CON_AV&V_MM WITH M.CON_AV&V_MM

	    IF _CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI
		    REPLACE PRE_DA&V_MM WITH M.PRE_DA&V_MM
		    REPLACE PRE_AV&V_MM WITH M.PRE_AV&V_MM			
		ENDIF

	NEXT

	REPLACE CON_IMP_D WITH M.CON_IMP_D
	REPLACE CON_IMP_A WITH M.CON_IMP_A

    IF _CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI
   		REPLACE PRE_IMP_D WITH M.PRE_IMP_D
   		REPLACE PRE_IMP_A WITH M.PRE_IMP_A
	ENDIF		
	
	SELECT CONTI
	SKIP 
	
ENDDO

SELECT CONTI
GO TOP

IF !ExecRW(cSql,"CONTI","W")
   return(.f.)
ENDIF

**WAIT WINDOWS "Fine ricalcolo saldi..." nowait

RETURN

****************************************************************************
PROCEDURE VERIFICA_ESISTENZA_GRUPPI_SOTTOGRUPPI_SU_CURSORE_CONTI_GESTIONALE
****************************************************************************


**  VERIFICA/AGGIORNA GRUPPI

cSql=""    
cNomeCursorSql="_TEMP" 

TEXT TO cSql NOSHOW      && INIZIO SCRITTURA QUERY

INSERT INTO CONTI (CON_SOC,CON_ANNO,CON_CONTO,CON_DESCR,CON_TIPOCO,CON_POSBIL)
SELECT
        CON_SOC,
        CON_ANNO,
        SUBSTRING(CON_CONTO,1,<<PUB_MASTRO>>-1) AS CON_CONTO,
        'GRUPPO CONTABILE' AS CON_DESCR,
        'X' AS CON_TIPOCO,
        CON_POSBIL
FROM CONTI AS CO
WHERE CON_ANNO='<<PUB_ANNO>>'
        AND LEN(CON_CONTO)>=<<PUB_MASTRO>>
        AND SUBSTRING(CON_CONTO,1,<<PUB_MASTRO>>-1) NOT IN (SELECT CON_CONTO FROM CONTI
                                                                             WHERE CON_ANNO='<<PUB_ANNO>>'
                                                                             AND LEN(CON_CONTO)<= <<PUB_MASTRO-1>> )
        GROUP BY CON_SOC,CON_ANNO,SUBSTRING(CON_CONTO,1,<<PUB_MASTRO>>-1),CON_POSBIL

ENDTEXT                                 && FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
        return(.f.)
ENDIF

** VERIFICA AGGIORNA SOTTOGRUPPI

cSql=""    
cNomeCursorSql="_TEMP" 

TEXT TO cSql NOSHOW      && INIZIO SCRITTURA QUERY

INSERT INTO CONTI (CON_SOC,CON_ANNO,CON_CONTO,CON_DESCR,CON_TIPOCO,CON_POSBIL)
SELECT
        CON_SOC,
        CON_ANNO,
        SUBSTRING(CON_CONTO,1,<<PUB_SOTTOG>>-1) AS CON_CONTO,
        'SOTTOGRUPPO CONTABILE' AS CON_DESCR,
        'X' AS CON_TIPOCO,
        CON_POSBIL
FROM CONTI AS CO
WHERE CON_ANNO='<<PUB_ANNO>>'
        AND LEN(CON_CONTO)>=<<PUB_SOTTOG>>
        AND SUBSTRING(CON_CONTO,1,<<PUB_SOTTOG>>-1) NOT IN (SELECT CON_CONTO FROM CONTI
                                                                             WHERE CON_ANNO='<<PUB_ANNO>>'
                                                                             AND LEN(CON_CONTO)<= <<PUB_SOTTOG-1>> )
        GROUP BY CON_SOC,CON_ANNO,SUBSTRING(CON_CONTO,1,<<PUB_SOTTOG>>-1),CON_POSBIL

ENDTEXT                                 && FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
        return(.f.)
ENDIF





RETURN 


**************************************************************************
PROCEDURE BILANCIO_CARICA_PRIMA_NOTA_GESTIONALE
**************************************************************************
LPARAMETERS _PAR_ANNO_INIZIALE,_PAR_MESE_INIZIALE ,_PAR_ANNO_FINALE,_PAR_MESE_FINALE ,_CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI,__ESCLUDE_RATEI_RISCONTI 

LOCAL _V_DARE,_V_AVERE ,_V_MESE_INIZIALE ,_V_MESE_FINALE,_CALBIL_MOVIMENTI_CONTABILI_ELABORATI 

_V_MESE_INIZIALE = PADL(ALLTRIM(STR(_PAR_MESE_INIZIALE ,2,0)),2,"0")     
_V_MESE_FINALE   = PADL(ALLTRIM(STR(_PAR_MESE_FINALE ,2,0)),2,"0")  

WAIT WINDOW "Aggiornamento archivio CONTI in corso esercizio contabile "+PUB_ANNO+" attendere prego..."  NOWAIT  

&& NON TRATTA I MOVIMENTI DI CHIUSURA
X_COND_CHIUSURA =" AND MOV_TOP <> 'CHI' "

cSql=""     
cNomeCursorSql="BIL_MOV_CONT"

TEXT TO cSql NOSHOW

SELECT 
	MOV_SOC,
	MOV_ANNO,
	MOV_CONTO,
	MOV_NREGIS, 
	MOV_DTCOMP,
	MOV_IMP,
	MOV_TMOV,
	MOV_VALUTA,
	MOV_CAMBIO,
	MOV_REGAUT,
	MOV_CONTABILITA_PREVISIONALE 
FROM MOV_CONT 
WHERE MOV_SOC='<<PUB_CODSOC>>' 
AND MOV_ANNO ='<<PUB_ANNO>>'  
AND MOV_DTCOMP <= '<<_PAR_ANNO_FINALE>>/<<_V_MESE_FINALE>>/31' <<X_COND_CHIUSURA>>

ENDTEXT

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF	

_CALBIL_MOVIMENTI_CONTABILI_ELABORATI =0

SELECT BIL_MOV_CONT
GO TOP

DO WHILE !EOF()
  
	_V_DARE  = 0
	_V_AVERE  = 0

	IF MOV_TMOV  = "D" .OR. MOV_TMOV  = "A"
	ELSE
	WAIT WINDOW "Registrazione senza D/A"+STR(MOV_NREGIS,10,0)+"<<<<<<<<<<<<"
		SELECT BIL_MOV_CONT
		SKIP +1
		LOOP
	ENDIF

    SELECT BIL_MOV_CONT
    
    IF PUB_VALRIF ='EUR' AND MOV_VALUTA ='EUR'
		_V_VALORE= MOV_IMP
	ELSE
		_V_VALORE=CAMBIO(MOV_VALUTA,MOV_IMP,MOV_CAMBIO,(MOV_SOC+MOV_ANNO+MOV_CONTO),.F.,10) 
	ENDIF
	
	DO CASE
	
		CASE MOV_TMOV  = "D"
			_V_DARE =   _V_VALORE
			
		CASE MOV_TMOV  = "A"
			_V_AVERE =  _V_VALORE

	ENDCASE

    SELECT BIL_MOV_CONT
 
	_V_CONTO 	= MOV_CONTO 
	_V_DATAREG	= MOV_DTCOMP 
	
	**=> ERASMO - INIZIO 09/04/2019
	IF SUBSTR(_V_DATAREG,1,4) <> ALLTRIM(PUB_ANNO)
		_V_DATAREG = ALLTRIM(PUB_ANNO)+'/01/01'
	ENDIF
	**=> ERASMO - FINE 09/04/2019
 
	IF MOV_CONTABILITA_PREVISIONALE = 'P'  		

	    IF __ESCLUDE_RATEI_RISCONTI 
	    	IF ALLTRIM(MOV_REGAUT) <> "RAT-RIS"
				DO BILANCIO_RICALCOLA_PREVISIONALI_GESTIONALE WITH _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG
			ENDIF
	    ELSE
			IF _CALBIL_INCLUDE_ANCHE_MOVIMENTI_CONTABILI_PREVISIONALI   		
				DO BILANCIO_RICALCOLA_PREVISIONALI_GESTIONALE WITH _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG
			ENDIF
		ENDIF

	ELSE
		DO BILANCIO_RICALCOLA_EFFETTIVI_GESTIONALE WITH _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG
	ENDIF 

	_CALBIL_MOVIMENTI_CONTABILI_ELABORATI = _CALBIL_MOVIMENTI_CONTABILI_ELABORATI + 1

	SELECT BIL_MOV_CONT
	SKIP +1
   
ENDDO



RETURN




**************************************************************************
PROCEDURE BILANCIO_RICALCOLA_EFFETTIVI_GESTIONALE
**************************************************************************
LPARAMETERS _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG

LOCAL _FLAG_PREVISIONALE

_FLAG_PREVISIONALE = .F.

DO BILANCIO_AGGIORNA_SINGOLO_MESE_GESTIONALE WITH _V_CONTO,_FLAG_PREVISIONALE,_V_DARE,_V_AVERE ,_V_DATAREG



**************************************************************************
PROCEDURE BILANCIO_RICALCOLA_PREVISIONALI_GESTIONALE
**************************************************************************
LPARAMETERS _V_CONTO,_V_DARE,_V_AVERE,_V_DATAREG

LOCAL _FLAG_PREVISIONALE

_FLAG_PREVISIONALE = .T.

DO BILANCIO_AGGIORNA_SINGOLO_MESE_GESTIONALE WITH _V_CONTO,_FLAG_PREVISIONALE,_V_DARE,_V_AVERE ,_V_DATAREG



**************************************************************************
PROCEDURE BILANCIO_AGGIORNA_SINGOLO_MESE_GESTIONALE
**************************************************************************
LPARAMETERS _V_CONTO,_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG

*!* AGGIORNA SALDO CONTO DI TIPO ELEMENTARE SU CU_CONTI
DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI_GESTIONALE  WITH _V_CONTO,_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG

*!* AGGIORNA SALDO CONTO DI TIPO SOTTOGRUPPO SU CU_CONTI
DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI_GESTIONALE  WITH ALLTRIM(SUBSTR(_V_CONTO,1,PUB_SOTTOG-1)),_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG

*!* AGGIORNA SALDO CONTO DI TIPO MASTRO SU CU_CONTI
DO BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI_GESTIONALE  WITH ALLTRIM(SUBSTR(_V_CONTO,1,PUB_MASTRO-1)),_V_FLAG_PREVISIONALE,_V_DARE,_V_AVERE,_V_DATAREG



**************************************************************************
PROCEDURE BILANCIO_AGGIORNA_SINGOLO_MESE_SU_CU_CONTI_GESTIONALE  
**************************************************************************
LPARAMETERS _V_CONTO,_V_FLAG_PREVISIONALE,_V_DARE ,_V_AVERE ,_V_DATAREG

LOCAL ___SEEK ,MESEXX ,_SAVE_SEL  

_SAVE_SEL  =SELECT()

SELECT CU_CONTI  
SET ORDER TO I_CONTO
___SEEK = PUB_CODSOC+PUB_ANNO+ALLTRIM(_V_CONTO)
SEEK ___SEEK 

IF !FOUND()
    WAIT WINDOW "Ricalcola bilancio - Conto inesistente :"+___SEEK 
    SELECT(_SAVE_SEL)
    RETURN 
ENDIF
	
MESEXX   = SUBSTR(_V_DATAREG,6,2)

IF _V_FLAG_PREVISIONALE
*** AGGIORNAMENTO SINGOLO MESE PREVISIONALE
	D_ARE    = "PRE_DA"+MESEXX
	A_VERE   = "PRE_AV"+MESEXX
	P_IMPD   = "PRE_IMP_D"
	P_IMPA   = "PRE_IMP_A"
ELSE
*** AGGIORNAMENTO SINGOLO MESE EFFETTIVO
	D_ARE    = "CON_DA"+MESEXX
	A_VERE   = "CON_AV"+MESEXX
	P_IMPD   = "CON_IMP_D"
	P_IMPA   = "CON_IMP_A"
ENDIF

_V_DARE= ROUND(_V_DARE,2)

_V_AVERE= ROUND(_V_AVERE,2)

IF _V_DARE<> 0
   REPLACE &D_ARE      	WITH &D_ARE		+_V_DARE && SINGOLO MESE
   REPLACE &P_IMPD   	WITH &P_IMPD	+_V_DARE && TOTALE
ENDIF

IF _V_AVERE<> 0
   REPLACE &A_VERE     	WITH &A_VERE	+_V_AVERE && SINGOLO MESE
   REPLACE &P_IMPA		WITH &P_IMPA 	+_V_AVERE && TOTALE
ENDIF	 
	
	
SELECT(_SAVE_SEL)
RETURN 	



*********************************************************************************************
PROCEDURE BILANCIO_DI_ESERCIZIO_GESTIONALE
*********************************************************************************************
*
* ELABORA IL BILANCIO DI ESERCIZIO PER L'ANNO SOLARE PUB_ANNO
*
* RESTITUISCE UN CURSORE CU_CONTI CON LA STESSA STRUTTURA DELLA TABELLA CONTI
*
* Parametri: _FLAG_SALDI_A_ZERO: .T./.F. - SE E' .T. ESTRAE ANCHE I SALDI A ZERO
*
*********************************************************************************************
LPARAMETERS _PAR_FLAG_SALDI_A_ZERO

LOCAL _FLAG_SALDI_A_ZERO

_FLAG_SALDI_A_ZERO=.F.
IF PCOUNT()=1
	_FLAG_SALDI_A_ZERO=_PAR_FLAG_SALDI_A_ZERO
ENDIF

ELABORA_MOV_CONT_E_CALCOLA_BILANCIO_GESTIONALE("",_FLAG_SALDI_A_ZERO)

COPIA_BILANCIO_IN_CURSORE_CONTI()

RETURN



*********************************************************************************************
PROCEDURE BILANCIO_PER_CENTRO_DI_COSTO_GESTIONALE
*********************************************************************************************
* ELABORA IL BILANCIO DI ESERCIZIO PER L'ANNO SOLARE PUB_ANNO
* PER CENTRO DI COSTO PER IL CENTRO DI COSTO PASSATO COME PARAMETRO
*
* RESTITUISCE UN CURSORE CU_CONTI CON LA STESSA STRUTTURA DELLA TABELLA CONTI
*
* Parametri: _CENTRO_DI_COSTO  : CENTRO DI COSTO DA ELABORARE
*            _FLAG_SALDI_A_ZERO: .T./.F. - SE E' .T. ESTRAE ANCHE I SALDI A ZERO
*
*********************************************************************************************
LPARAMETERS _CENTRO_DI_COSTO,_PAR_FLAG_SALDI_A_ZERO

LOCAL _FLAG_SALDI_A_ZERO

IF PCOUNT()<1
	MESSAGEBOX("BILANCIO_PER_CENTRO_DI_COSTO: centro di costo non valorizzato",48,"ERRORE PARAMETRI")
	RETURN
ENDIF

_FLAG_SALDI_A_ZERO=.F.
IF PCOUNT()=2
	_FLAG_SALDI_A_ZERO=_PAR_FLAG_SALDI_A_ZERO
ENDIF


ELABORA_MOV_CONT_E_CALCOLA_BILANCIO_GESTIONALE(_CENTRO_DI_COSTO,_FLAG_SALDI_A_ZERO)

COPIA_BILANCIO_IN_CURSORE_CONTI()

RETURN



*********************************************************************************************
PROCEDURE ELABORA_MOV_CONT_E_CALCOLA_BILANCIO_GESTIONALE
*********************************************************************************************
* Parametri:
*
* _V_CDC: CODICE CENTRO DI COSTO - se valorizzato la procedura calcola il bilancio 
*                                  elaborando solo i movimenti relativi al centro di costo 
*                                  (bilancio per centro di costo)
*
*********************************************************************************************

LPARAMETERS _V_CDC,_FLAG_SALDI_A_ZERO

LOCAL _NOME_CURS_TEMP, _WHERE_CONDITION_CDC,_WHERE_CONDITION_ESCLUDI_SALDI_A_ZERO

_WHERE_CONDITION_CDC=""

IF !EMPTY(_V_CDC) 
	_WHERE_CONDITION_CDC=" AND MOV_CCO = '"+_V_CDC+"'"
ENDIF

_WHERE_CONDITION_ESCLUDI_SALDI_A_ZERO=""

IF !_FLAG_SALDI_A_ZERO 
	_WHERE_CONDITION_ESCLUDI_SALDI_A_ZERO=" AND (CON_IMP_D-CON_IMP_A <> 0 OR PRE_IMP_D-PRE_IMP_A <> 0) "
ENDIF


_NOME_CURS_TEMP = "CU_BILANCIO"

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY

SELECT 
	CON_ANNO  ,
	CON_CONTO ,
	CON_DESCR ,
	CON_POSBIL,
	CON_TIPOCO,
	COALESCE(CON_IMP_D , 0) AS CON_IMP_D ,
	COALESCE(CON_IMP_A , 0) AS CON_IMP_A ,
	COALESCE(CON_DA01  , 0) AS CON_DA01  ,
	COALESCE(CON_AV01  , 0) AS CON_AV01  ,
	COALESCE(CON_DA02  , 0) AS CON_DA02  ,
	COALESCE(CON_AV02  , 0) AS CON_AV02  ,
	COALESCE(CON_DA03  , 0) AS CON_DA03  ,
	COALESCE(CON_AV03  , 0) AS CON_AV03  ,
	COALESCE(CON_DA04  , 0) AS CON_DA04  ,
	COALESCE(CON_AV04  , 0) AS CON_AV04  ,
	COALESCE(CON_DA05  , 0) AS CON_DA05  ,
	COALESCE(CON_AV05  , 0) AS CON_AV05  ,
	COALESCE(CON_DA06  , 0) AS CON_DA06  ,
	COALESCE(CON_AV06  , 0) AS CON_AV06  ,
	COALESCE(CON_DA07  , 0) AS CON_DA07  ,
	COALESCE(CON_AV07  , 0) AS CON_AV07  ,
	COALESCE(CON_DA08  , 0) AS CON_DA08  ,
	COALESCE(CON_AV08  , 0) AS CON_AV08  ,
	COALESCE(CON_DA09  , 0) AS CON_DA09  ,
	COALESCE(CON_AV09  , 0) AS CON_AV09  ,
	COALESCE(CON_DA10  , 0) AS CON_DA10  ,
	COALESCE(CON_AV10  , 0) AS CON_AV10  ,
	COALESCE(CON_DA11  , 0) AS CON_DA11  ,
	COALESCE(CON_AV11  , 0) AS CON_AV11  ,
	COALESCE(CON_DA12  , 0) AS CON_DA12  ,
	COALESCE(CON_AV12  , 0) AS CON_AV12  ,
	COALESCE(PRE_IMP_D , 0) AS PRE_IMP_D ,
	COALESCE(PRE_IMP_A , 0) AS PRE_IMP_A ,
	COALESCE(PRE_DA01  , 0) AS PRE_DA01  ,
	COALESCE(PRE_AV01  , 0) AS PRE_AV01  ,
	COALESCE(PRE_DA02  , 0) AS PRE_DA02  ,
	COALESCE(PRE_AV02  , 0) AS PRE_AV02  ,
	COALESCE(PRE_DA03  , 0) AS PRE_DA03  ,
	COALESCE(PRE_AV03  , 0) AS PRE_AV03  ,
	COALESCE(PRE_DA04  , 0) AS PRE_DA04  ,
	COALESCE(PRE_AV04  , 0) AS PRE_AV04  ,
	COALESCE(PRE_DA05  , 0) AS PRE_DA05  ,
	COALESCE(PRE_AV05  , 0) AS PRE_AV05  ,
	COALESCE(PRE_DA06  , 0) AS PRE_DA06  ,
	COALESCE(PRE_AV06  , 0) AS PRE_AV06  ,
	COALESCE(PRE_DA07  , 0) AS PRE_DA07  ,
	COALESCE(PRE_AV07  , 0) AS PRE_AV07  ,
	COALESCE(PRE_DA08  , 0) AS PRE_DA08  ,
	COALESCE(PRE_AV08  , 0) AS PRE_AV08  ,
	COALESCE(PRE_DA09  , 0) AS PRE_DA09  ,
	COALESCE(PRE_AV09  , 0) AS PRE_AV09  ,
	COALESCE(PRE_DA10  , 0) AS PRE_DA10  ,
	COALESCE(PRE_AV10  , 0) AS PRE_AV10  ,
	COALESCE(PRE_DA11  , 0) AS PRE_DA11  ,
	COALESCE(PRE_AV11  , 0) AS PRE_AV11  ,
	COALESCE(PRE_DA12  , 0) AS PRE_DA12  
FROM 
(SELECT 
	CONTI.CON_ANNO,
	CONTI.CON_CONTO,
	CONTI.CON_DESCR,
	CONTI.CON_POSBIL,
	CONTI.CON_TIPOCO,
	T2.*
FROM CONTI AS CONTI 
LEFT OUTER JOIN 
		(SELECT 
			CONTO,
			ANNO,
			SUM(DARE) AS CON_IMP_D,
			SUM(AVERE) AS CON_IMP_A,
			SUM((CASE WHEN MESE ='01' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA01,
			SUM((CASE WHEN MESE ='01' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV01,
			SUM((CASE WHEN MESE ='02' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA02,
			SUM((CASE WHEN MESE ='02' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV02,
			SUM((CASE WHEN MESE ='03' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA03,
			SUM((CASE WHEN MESE ='03' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV03,
			SUM((CASE WHEN MESE ='04' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA04,
			SUM((CASE WHEN MESE ='04' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV04,
			SUM((CASE WHEN MESE ='05' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA05,
			SUM((CASE WHEN MESE ='05' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV05,
			SUM((CASE WHEN MESE ='06' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA06,
			SUM((CASE WHEN MESE ='06' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV06,
			SUM((CASE WHEN MESE ='07' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA07,
			SUM((CASE WHEN MESE ='07' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV07,
			SUM((CASE WHEN MESE ='08' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA08,
			SUM((CASE WHEN MESE ='08' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV08,
			SUM((CASE WHEN MESE ='09' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA09,
			SUM((CASE WHEN MESE ='09' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV09,
			SUM((CASE WHEN MESE ='10' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA10,
			SUM((CASE WHEN MESE ='10' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV10,
			SUM((CASE WHEN MESE ='11' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA11,
			SUM((CASE WHEN MESE ='11' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV11,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA12,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV12,
			SUM(DARE_PREV) AS PRE_IMP_D,
			SUM(AVERE_PREV) AS PRE_IMP_A,
			SUM((CASE WHEN MESE ='01' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA01,
			SUM((CASE WHEN MESE ='01' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV01,
			SUM((CASE WHEN MESE ='02' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA02,
			SUM((CASE WHEN MESE ='02' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV02,
			SUM((CASE WHEN MESE ='03' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA03,
			SUM((CASE WHEN MESE ='03' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV03,
			SUM((CASE WHEN MESE ='04' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA04,
			SUM((CASE WHEN MESE ='04' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV04,
			SUM((CASE WHEN MESE ='05' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA05,
			SUM((CASE WHEN MESE ='05' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV05,
			SUM((CASE WHEN MESE ='06' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA06,
			SUM((CASE WHEN MESE ='06' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV06,
			SUM((CASE WHEN MESE ='07' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA07,
			SUM((CASE WHEN MESE ='07' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV07,
			SUM((CASE WHEN MESE ='08' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA08,
			SUM((CASE WHEN MESE ='08' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV08,
			SUM((CASE WHEN MESE ='09' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA09,
			SUM((CASE WHEN MESE ='09' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV09,
			SUM((CASE WHEN MESE ='10' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA10,
			SUM((CASE WHEN MESE ='10' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV10,
			SUM((CASE WHEN MESE ='11' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA11,
			SUM((CASE WHEN MESE ='11' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV11,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA12,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV12
		FROM (SELECT 
				MOV_CONTO AS CONTO,
				MOV_ANNO AS ANNO,
				SUBSTRING(MOV_DTCOMP,6,2) AS MESE,
				SUM((CASE WHEN MOV_TMOV ='D' AND MOV_CONTABILITA_PREVISIONALE<>'P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS DARE,
				SUM((CASE WHEN MOV_TMOV ='A' AND MOV_CONTABILITA_PREVISIONALE<>'P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS AVERE,
				SUM((CASE WHEN MOV_TMOV ='D' AND MOV_CONTABILITA_PREVISIONALE='P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS DARE_PREV,
				SUM((CASE WHEN MOV_TMOV ='A' AND MOV_CONTABILITA_PREVISIONALE='P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS AVERE_PREV
			FROM MOV_CONT 
			WHERE 
				MOV_ANNO='<<PUB_ANNO>>' AND MOV_TOP <> 'CHI' 
				<<_WHERE_CONDITION_CDC>>
			GROUP BY 
				MOV_CONTO,
				MOV_ANNO,
				SUBSTRING(MOV_DTCOMP,6,2) ) AS T1 
		GROUP BY ANNO,CONTO	) AS T2
ON 
	CONTI.CON_CONTO = T2.CONTO 
	AND CONTI.CON_ANNO = T2.ANNO 
WHERE LEN(CONTI.CON_CONTO)>=<<PUB_SOTTOG>>

UNION 

SELECT 
	CONTI.CON_ANNO,
	CONTI.CON_CONTO,
	CONTI.CON_DESCR,
	CONTI.CON_POSBIL,
	CONTI.CON_TIPOCO,
	T2.*
FROM CONTI AS CONTI 
LEFT OUTER JOIN 
		(SELECT 
			CONTO,
			ANNO,
			SUM(DARE) AS CON_IMP_D,
			SUM(AVERE) AS CON_IMP_A,
			SUM((CASE WHEN MESE ='01' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA01,
			SUM((CASE WHEN MESE ='01' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV01,
			SUM((CASE WHEN MESE ='02' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA02,
			SUM((CASE WHEN MESE ='02' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV02,
			SUM((CASE WHEN MESE ='03' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA03,
			SUM((CASE WHEN MESE ='03' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV03,
			SUM((CASE WHEN MESE ='04' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA04,
			SUM((CASE WHEN MESE ='04' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV04,
			SUM((CASE WHEN MESE ='05' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA05,
			SUM((CASE WHEN MESE ='05' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV05,
			SUM((CASE WHEN MESE ='06' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA06,
			SUM((CASE WHEN MESE ='06' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV06,
			SUM((CASE WHEN MESE ='07' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA07,
			SUM((CASE WHEN MESE ='07' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV07,
			SUM((CASE WHEN MESE ='08' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA08,
			SUM((CASE WHEN MESE ='08' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV08,
			SUM((CASE WHEN MESE ='09' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA09,
			SUM((CASE WHEN MESE ='09' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV09,
			SUM((CASE WHEN MESE ='10' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA10,
			SUM((CASE WHEN MESE ='10' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV10,
			SUM((CASE WHEN MESE ='11' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA11,
			SUM((CASE WHEN MESE ='11' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV11,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * DARE) AS CON_DA12,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * AVERE) AS CON_AV12,
			SUM(DARE_PREV) AS PRE_IMP_D,
			SUM(AVERE_PREV) AS PRE_IMP_A,
			SUM((CASE WHEN MESE ='01' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA01,
			SUM((CASE WHEN MESE ='01' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV01,
			SUM((CASE WHEN MESE ='02' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA02,
			SUM((CASE WHEN MESE ='02' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV02,
			SUM((CASE WHEN MESE ='03' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA03,
			SUM((CASE WHEN MESE ='03' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV03,
			SUM((CASE WHEN MESE ='04' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA04,
			SUM((CASE WHEN MESE ='04' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV04,
			SUM((CASE WHEN MESE ='05' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA05,
			SUM((CASE WHEN MESE ='05' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV05,
			SUM((CASE WHEN MESE ='06' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA06,
			SUM((CASE WHEN MESE ='06' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV06,
			SUM((CASE WHEN MESE ='07' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA07,
			SUM((CASE WHEN MESE ='07' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV07,
			SUM((CASE WHEN MESE ='08' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA08,
			SUM((CASE WHEN MESE ='08' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV08,
			SUM((CASE WHEN MESE ='09' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA09,
			SUM((CASE WHEN MESE ='09' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV09,
			SUM((CASE WHEN MESE ='10' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA10,
			SUM((CASE WHEN MESE ='10' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV10,
			SUM((CASE WHEN MESE ='11' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA11,
			SUM((CASE WHEN MESE ='11' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV11,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * DARE_PREV) AS PRE_DA12,
			SUM((CASE WHEN MESE ='12' THEN 1 ELSE 0 END  ) * AVERE_PREV) AS PRE_AV12
		FROM (SELECT 
				SUBSTRING(MOV_CONTO,1,<<PUB_SOTTOG-1>>) AS CONTO,
				MOV_ANNO AS ANNO,
				SUBSTRING(MOV_DTCOMP,6,2) AS MESE,
				SUM((CASE WHEN MOV_TMOV ='D' AND MOV_CONTABILITA_PREVISIONALE<>'P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS DARE,
				SUM((CASE WHEN MOV_TMOV ='A' AND MOV_CONTABILITA_PREVISIONALE<>'P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS AVERE,
				SUM((CASE WHEN MOV_TMOV ='D' AND MOV_CONTABILITA_PREVISIONALE='P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS DARE_PREV,
				SUM((CASE WHEN MOV_TMOV ='A' AND MOV_CONTABILITA_PREVISIONALE='P' THEN 1 ELSE 0 END  ) * MOV_IMP * MOV_CAMBIO ) AS AVERE_PREV
			FROM MOV_CONT 
			WHERE 
				MOV_ANNO='<<PUB_ANNO>>' AND MOV_TOP <> 'CHI' 
				<<_WHERE_CONDITION_CDC>>
			GROUP BY 
				SUBSTRING(MOV_CONTO,1,<<PUB_SOTTOG-1>>),
				MOV_ANNO,
				SUBSTRING(MOV_DTCOMP,6,2) ) AS T1 
		GROUP BY ANNO,CONTO) AS T2
ON 
	CONTI.CON_CONTO = T2.CONTO 
	AND CONTI.CON_ANNO = T2.ANNO 
WHERE LEN(CONTI.CON_CONTO)=<<PUB_SOTTOG-1>>	
) AS T3
WHERE CON_ANNO='<<PUB_ANNO>>' <<_WHERE_CONDITION_ESCLUDI_SALDI_A_ZERO>>
ORDER BY CON_CONTO

ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,_NOME_CURS_TEMP)
	return(.F.)
ENDIF

RETURN 


*********************************************************************************************
PROCEDURE COPIA_BILANCIO_IN_CURSORE_CONTI_GESTIONALE
*********************************************************************************************
* PROCEDURA DI SUPPORTO AL CALCOLO DEL BILANCIO
* COPIA IL CURSORE CU_BILANCIO IN UN CURSORE CU_CONTI CHE HA CON LA STESSA STRUTTURA
* DELLA TABELLA CONTI
*********************************************************************************************
RELEASE PAT_DARE	,;
	PAT_AVERE   ,;
	PAT_SALDO   ,;
	ECO_DARE    ,;
	ECO_AVERE   ,;
	ECO_SALDO   ,;
	TOT_DARE	,;
	TOT_AVERE	,;
	TOT_SALDO	,;
	BILANCIO_ATTIVITA,;
	BILANCIO_PASSIVITA,;
	BILANCIO_RISULTATO_ECONOMICI,;
	BILANCIO_COSTI,;
	BILANCIO_RICAVI,;
	BILANCIO_RISULTATO_PATRIMONIALI,;
	BILANCIO_SALDO

PUBLIC PAT_DARE	,;
	PAT_AVERE   ,;
	PAT_SALDO   ,;
	ECO_DARE    ,;
	ECO_AVERE   ,;
	ECO_SALDO   ,;
	TOT_DARE	,;
	TOT_AVERE	,;
	TOT_SALDO	,;
	BILANCIO_ATTIVITA,;
	BILANCIO_PASSIVITA,;
	BILANCIO_RISULTATO_ECONOMICI,;
	BILANCIO_COSTI,;
	BILANCIO_RICAVI,;
	BILANCIO_RISULTATO_PATRIMONIALI,;
	BILANCIO_SALDO
	
LOCAL _ROUND_DECIMAL,_REPLACE,_MESE_STRING,_SALDO_PARZIALE

*** ARROTONDO A 2 DECIMALI GLI IMPORTI IN CENTESIMI
_ROUND_DECIMAL=ALLTRIM(STR(2))
	

*** FACCIO UNA SELECT SENZA RIGHE SU CONTI PER RICAVARE LA STRUTTURA COMPLETA DELLA TABELLA

TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
	SELECT * FROM CONTI WHERE 1=0
	
ENDTEXT					&& FINE SCRITTURA QUERY

IF !ExecPreparedCommand(cSql,"CU_CONTI")
	return(.F.)
ENDIF

PAT_DARE    = 0
PAT_AVERE   = 0
PAT_SALDO   = 0

ECO_DARE    = 0
ECO_AVERE   = 0
ECO_SALDO   = 0

TOT_DARE	= 0
TOT_AVERE	= 0
TOT_SALDO	= 0

BILANCIO_ATTIVITA =0 
BILANCIO_PASSIVITA=0
BILANCIO_RISULTATO_ECONOMICI=0
BILANCIO_COSTI=0
BILANCIO_RICAVI=0
BILANCIO_RISULTATO_PATRIMONIALI=0
BILANCIO_SALDO=0


SELECT CU_BILANCIO
GO TOP
DO WHILE !EOF()
	
	SCATTER MEMVAR MEMO
	
	SELECT CU_CONTI
	
	APPEND BLANK 
	GATHER MEMVAR MEMO
	REPLACE CON_SOC WITH PUB_CODSOC

	_REPLACE=""	
	_REPLACE="REPLACE CON_IMP_D WITH ROUND(CON_IMP_D,"+_ROUND_DECIMAL+")"
	&_REPLACE

	_REPLACE=""	
	_REPLACE="REPLACE CON_IMP_A WITH ROUND(CON_IMP_A,"+_ROUND_DECIMAL+")"
	&_REPLACE
	
	_REPLACE=""	
	_REPLACE="REPLACE PRE_IMP_D WITH ROUND(PRE_IMP_D,"+_ROUND_DECIMAL+")"
	&_REPLACE
	
	_REPLACE=""	
	_REPLACE="REPLACE PRE_IMP_A WITH ROUND(PRE_IMP_A,"+_ROUND_DECIMAL+")"
	&_REPLACE

	FOR I=1 TO 12
		_MESE_STRING=PADL(ALLTRIM(STR(I)),2,"0")
		
		_REPLACE=""	
		_REPLACE="REPLACE CON_DA"+_MESE_STRING+" WITH ROUND(CON_DA"+_MESE_STRING+","+_ROUND_DECIMAL+")"
		&_REPLACE
		
		_REPLACE=""	
		_REPLACE="REPLACE CON_AV"+_MESE_STRING+" WITH ROUND(CON_AV"+_MESE_STRING+","+_ROUND_DECIMAL+")"
		&_REPLACE
		
		_REPLACE=""	
		_REPLACE="REPLACE PRE_DA"+_MESE_STRING+" WITH ROUND(PRE_DA"+_MESE_STRING+","+_ROUND_DECIMAL+")"
		&_REPLACE
		
		_REPLACE=""	
		_REPLACE="REPLACE PRE_AV"+_MESE_STRING+" WITH ROUND(PRE_AV"+_MESE_STRING+","+_ROUND_DECIMAL+")"
		&_REPLACE
	NEXT
	
	
	_SALDO_PARZIALE=0
	
	_SALDO_PARZIALE = CON_IMP_D - CON_IMP_A 
	
	IF LEN(ALLTRIM(CON_CONTO))>=PUB_SOTTOG 
		DO CASE 
			CASE CON_POSBIL='P'
				PAT_DARE 	= PAT_DARE 	+CON_IMP_D 
				PAT_AVERE   = PAT_AVERE	+CON_IMP_A 
				
				IF _SALDO_PARZIALE  >=0 
					BILANCIO_ATTIVITA = BILANCIO_ATTIVITA +_SALDO_PARZIALE 
				ELSE
					BILANCIO_PASSIVITA= BILANCIO_PASSIVITA - _SALDO_PARZIALE 
				ENDIF
				
			CASE CON_POSBIL='E'
				ECO_DARE    = ECO_DARE 	+CON_IMP_D 
				ECO_AVERE   = ECO_AVERE +CON_IMP_A 
				
				IF _SALDO_PARZIALE  >=0 
					BILANCIO_COSTI= BILANCIO_COSTI +_SALDO_PARZIALE 
				ELSE
					BILANCIO_RICAVI= BILANCIO_RICAVI -_SALDO_PARZIALE 
				ENDIF
		ENDCASE
	ENDIF	
	
	
	SELECT CU_BILANCIO
	SKIP
	
ENDDO

SELECT CU_BILANCIO
USE

SELECT CU_CONTI
GO TOP
 

PAT_DARE 	= ROUND(PAT_DARE,2)
PAT_AVERE 	= ROUND(PAT_AVERE ,2)
ECO_DARE  	= ROUND(ECO_DARE  ,2)
ECO_AVERE   = ROUND(ECO_AVERE   ,2)

BILANCIO_ATTIVITA 	= ROUND(BILANCIO_ATTIVITA ,2)
BILANCIO_PASSIVITA 	= ROUND(BILANCIO_PASSIVITA ,2)
BILANCIO_COSTI		= ROUND(BILANCIO_COSTI,2)
BILANCIO_RICAVI 	= ROUND(BILANCIO_RICAVI ,2)

PAT_SALDO   = PAT_DARE - PAT_AVERE

ECO_SALDO   = ECO_DARE - ECO_AVERE   

TOT_SALDO   = PAT_SALDO   + ECO_SALDO   


*** FAB - 17/08/2014 ARROTONDAMENTO DEI CENTESIMI
***
*** SE HO UNO SBILANCIO MINORE DI +/- 10 CENT. FACCIO UN UPDATE DELLO SBILANCIO SU
*** 1) IL CONTO IMPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
*** 2) SE 1) NON ESISTE SU PARA OPPURE ESISTE SU PARA MA NON SU CONTI, ALLORA FACCIO UN UPDATE SUL PRIMO CONTO CHE TROVO SULL'ANNO E RICALCOLO I SALDI

IF TOT_SALDO<>0 AND ABS(TOT_SALDO) < 0.10

	_MESE_DA_AGGIORNARE="01"

	_strdelta = ALLTRIM(STRTRAN(STR(TOT_SALDO,20,2),',','.'))
	
	*** CERCO IL CONTO INPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
	
	Csql   = "SELECT * FROM PARA WHERE CODICE='CAA"+PUB_ANNO+"'"
	IF !ExecCommand(Csql,"UPD_CONTI")
	   return(.f.)
	ENDIF	
	
	SELECT UPD_CONTI
	
	_CONTO_ARROTONDAMENTI = ""
	_CONTO_ARROTONDAMENTI_PAT_ECO = "E"
	
	IF !EOF()
		_CONTO_ARROTONDAMENTI = ALLTRIM(LIBERA)
	ENDIF
	
	*** IL CONTO PER GLI ARROTONDAMENTI E' IMPOSTATO SU PARA
	*** ORA LO CERCO SU CONTI
	
	Csql   = "SELECT CON_CONTO,CON_POSBIL FROM CONTI WHERE CON_CONTO='"+_CONTO_ARROTONDAMENTI+"' AND CON_ANNO='"+PUB_ANNO+"' " 
	IF !ExecCommand(Csql,"UPD_CONTI")
	   return(.f.)
	ENDIF	
	
	SELECT UPD_CONTI
	IF EOF()
		_CONTO_ARROTONDAMENTI = ""
	ELSE
		_CONTO_ARROTONDAMENTI_PAT_ECO = CON_POSBIL	
	ENDIF	
	
	IF !EMPTY(_CONTO_ARROTONDAMENTI )
		*** FACCIO UN UPDATE SUL CONTO IMPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		Csql   = "UPDATE CU_CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO='" +_CONTO_ARROTONDAMENTI  + "' AND " + x_anno
		
		_MASTRO_CONTO_ARROTONDAMENTI = SUBSTR(ALLTRIM(_CONTO_ARROTONDAMENTI ),1,PUB_SOTTOG-1)
		*** FACCIO UN UPDATE SUL MASTRO DEL CONTO IMPOSTATO NEI PARAMETRI COME CONTO DI ARROTONDAMENTO
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		Csql_MASTRO   = "UPDATE CU_CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO='" +_MASTRO_CONTO_ARROTONDAMENTI   + "' AND " + x_anno
	ELSE
		*** FACCIO UN UPDATE SUL PRIMO CONTO CHE TROVO SULL'ANNO E RICALCOLO I SALDI
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		x_cont = "LEN(CON_CONTO) >= "+ ALLTRIM(STR(PUB_SOTTOG))
		x_pbil = "CON_POSBIL = 'E'"
		x_cimp = "CON_IMP_D <> CON_IMP_A"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont + " and " + x_pbil + " and " + x_cimp 
		Csql   = "UPDATE CU_CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO IN " + ;
				"(SELECT TOP 1 CON_CONTO FROM CU_CONTI WHERE " + x_cond + " ORDER BY CON_CONTO ) AND " + x_anno
				
				
		*** FACCIO UN UPDATE SUL  PRIMO MASTRO CHE TROVO SULL'ANNO E RICALCOLO I SALDI
		x_soci = "con_soc = '" + PUB_CODSOC + "'"
		x_anno = "con_anno = '" + PUB_ANNO + "'"
		x_cont = "LEN(CON_CONTO) = "+ ALLTRIM(STR(PUB_SOTTOG-1))
		x_pbil = "CON_POSBIL = 'E'"
		x_cimp = "CON_IMP_D <> CON_IMP_A"
		x_cond = x_soci + " and " + x_anno + " and " + x_cont + " and " + x_pbil + " and " + x_cimp 
		Csql_MASTRO   = "UPDATE CU_CONTI SET CON_DA"+_MESE_DA_AGGIORNARE+" = CON_DA"+_MESE_DA_AGGIORNARE+" - (&_strdelta) , CON_IMP_D = CON_IMP_D - (&_strdelta) where CON_CONTO IN " + ;
				"(SELECT TOP 1 CON_CONTO FROM CU_CONTI WHERE " + x_cond + " ORDER BY CON_CONTO ) AND " + x_anno
	
	ENDIF 	
	
	&Csql
	&Csql_MASTRO
	
	DO CASE
		CASE _CONTO_ARROTONDAMENTI_PAT_ECO ="P"
		
			PAT_DARE = PAT_DARE - TOT_SALDO 

			BILANCIO_ATTIVITA = BILANCIO_ATTIVITA - TOT_SALDO 
			
		CASE _CONTO_ARROTONDAMENTI_PAT_ECO ="E"
		
			ECO_DARE = ECO_DARE - TOT_SALDO 
			
			BILANCIO_COSTI = BILANCIO_COSTI - TOT_SALDO 
	ENDCASE
	
	PAT_SALDO   = PAT_DARE - PAT_AVERE

	ECO_SALDO   = ECO_DARE - ECO_AVERE   

	TOT_SALDO   = PAT_SALDO   + ECO_SALDO   	

	
ENDIF

BILANCIO_RISULTATO_PATRIMONIALI	=BILANCIO_ATTIVITA 	- 	BILANCIO_PASSIVITA

BILANCIO_RISULTATO_ECONOMICI	=BILANCIO_COSTI		-	BILANCIO_RICAVI

BILANCIO_SALDO=ABS(BILANCIO_RISULTATO_PATRIMONIALI)	- ABS( BILANCIO_RISULTATO_ECONOMICI	)

SELECT CU_CONTI
GO TOP

RETURN




