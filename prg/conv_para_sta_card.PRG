RIT = MESSAGEBOX("Procedo con la conversione degli Stati Esteri dalla tabella CARD_STATIEST/CARD_CLIFO/CARD_TABCONT?",292,"ATTENZIONE")
IF RIT = 7
   =MESSAGEBOX("Operazione abbandonata",62,"ATTENZIONE")
   RETURN
ENDIF


WAIT WINDOWS "Cancellazione vecchie Nazioni in corso..." NOWAIT

cSql = "DELETE FROM PARA WHERE CODICE LIKE 'STA%'"
IF !ExecCommand(cSql,"DEL_PARA_STA")
   return
ENDIF


WAIT WINDOWS "Cancellazione vecchie Zone in corso..." NOWAIT

cSql = "DELETE FROM PARA WHERE CODICE LIKE 'ZON%'"
IF !ExecCommand(cSql,"DEL_PARA_ZON")
   return
ENDIF


*** AGGIORNAMENTO PARAMETRO 'GEN' PER DETERMINAZIONE CONTI IN TRASFERIMENTI CONTABILI
cSql = "UPDATE PARA SET NOTE = '' WHERE CODICE LIKE 'GEN%' AND CODICE <> 'GEN01'"
IF !ExecCommand(cSql,"UPD_PARA_GEN")
	RETURN .F.
ENDIF

*** AGGIORNAMENTO PARAMETRO 'CGN' PER DETERMINAZIONE CONTI IN TRASFERIMENTI CONTABILI PER TIPO NAZIONE / GRUPPO MERC. IND.
cSql = "DELETE FROM PARA WHERE CODICE LIKE 'CGN%'"
IF !ExecCommand(cSql,"DEL_PARA_CGN")
   return
ENDIF

WAIT WINDOWS "Conversione Nazioni in corso..." NOWAIT


*** AGGIORNAMENTO TABELLA DELLE NAZIONI
_TOT_COUNT = 0
cSql = "SELECT * FROM CARD_STATIEST ORDER BY DENOMINAZI"
IF !ExecCommand(cSql,"CX_CARD_STATIEST")
	RETURN .F.
ENDIF
SELECT CX_CARD_STATIEST
GO TOP
SCAN

	WAIT WINDOWS "Conversione Nazione " + ALLTRIM(STR(RECNO(),10,0)) + " di " + ALLTRIM(STR(RECCOUNT(),10,0)) + ;
		" (" + ALLTRIM(STR(RECNO() * 100 / RECCOUNT(),10,0)) + "%)" NOWAIT 
		
	SCATTER MEMVAR
	
	M.CODICE_OLD = M.CODICE
	M.CODICE_AQUARIUS = APITOSPA(ALLTRIM(SUBSTR(M.DENOMINAZI,1,3)))
	
	_lUnivoco = .F.
	_nTentativi = 0
	DO WHILE !_lUnivoco
		_nTentativi = _nTentativi + 1
		
		x_codi = "CODICE = 'STA" + ALLTRIM(M.CODICE_AQUARIUS) + "'"
		x_cond = x_codi
		cSql = "SELECT * FROM PARA WHERE " + x_cond
		IF !ExecCommand(cSql,"TMP_PARA")
			RETURN .F.
		ENDIF
		SELECT TMP_PARA
		GO TOP
		IF !EOF()
			_cChr = ALLTRIM(SUBSTR(M.DENOMINAZI,3 + _nTentativi,1))
			_nChr = ASC(_cChr)
			IF (_nChr >= 65 AND _nChr <= 90) OR (_nChr >= 97 AND _nChr <= 122)
			ELSE
				LOOP
			ENDIF
			M.CODICE_AQUARIUS = APITOSPA(ALLTRIM(SUBSTR(M.DENOMINAZI,1,2))) + _cChr
		ELSE
			_lUnivoco = .T.
		ENDIF
		
		IF _nTentativi > 10
			EXIT
		ENDIF
	ENDDO
	
	IF !_lUnivoco
		SELECT CX_CARD_STATIEST
		LOOP
	ENDIF
	
	*** ADESSO IL NUOVO CODICE AQUARIUS E' SICURAMENTE UNIVOCO
	x_codi = "CODICE = 'STA" + ALLTRIM(M.CODICE_AQUARIUS) + "'"
	x_cond = x_codi
	cSql = "SELECT * FROM PARA WHERE " + x_cond
	IF !ExecRW(cSql,"PARA","R")
		RETURN .F.
	ENDIF
	SELECT PARA
	GO TOP
	APPEND BLANK
	
	REPLACE CODICE WITH "STA" + ALLTRIM(M.CODICE_AQUARIUS)
	REPLACE DESCRI WITH ALLTRIM(M.DENOMINAZI)
	REPLACE LIBERA WITH IIF(!ISNULL(M.STATOINTRA),ALLTRIM(M.STATOINTRA),"")
	REPLACE DESIVA WITH IIF(!ISNULL(M.STATOCEE),'STATOCEE: ' + ALLTRIM(M.STATOCEE),"")
	REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))
	
	IF !ExecRW(cSql,"PARA","W")
		RETURN .F.
	ENDIF


	
	*** AGGIORNAMENTO CODICE ZON IN BASE AL CAMPO STATO INTRASTAT

	IF !ISNULL(M.STATOINTRA)
		_STATOINTRA = M.STATOINTRA
	ELSE
		_STATOINTRA = ""	
	ENDIF

    IF !EMPTY(_STATOINTRA)
		x_codi = "CODICE = 'ZON" + ALLTRIM(_STATOINTRA) + "'"
		x_cond = x_codi
		cSql = "SELECT * FROM PARA WHERE " + x_cond
		IF !ExecRW(cSql,"PARA","R")
			RETURN .F.
		ENDIF
		SELECT PARA
		GO TOP
		IF EOF()
			APPEND BLANK
			REPLACE CODICE WITH "ZON" + ALLTRIM(_STATOINTRA)
			REPLACE DESCRI WITH ALLTRIM(M.DENOMINAZI)
			REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))
		ENDIF
		IF !ExecRW(cSql,"PARA","W")
			RETURN .F.
		ENDIF
	ENDIF




	*** AGGIORNAMENTO CODICE NAZIONE IN ANAGRAFICA CLIENTI AQUARIUS
	x_nazi = "CLI_NAZION = '" + ALLTRIM(M.CODICE_AQUARIUS) + "'"
	x_stat = "COD_NAZION = '" + ALLTRIM(M.CODICE_OLD) + "'"
	cSql = "UPDATE U_CLI_AN SET " + x_nazi + " WHERE CLI_CODCLI IN " + ;
	       "(SELECT CODICE FROM CARD_CLIFO WHERE TIPO = 'C' AND " + x_stat + ")"
	IF !ExecCommand(cSql,"UPD_CLI_AN")
		RETURN .F.
	ENDIF

	*** AGGIORNAMENTO CODICE NAZIONE IN ANAGRAFICA FORNITORI AQUARIUS
	x_nazi = "FOR_NAZION = '" + ALLTRIM(M.CODICE_AQUARIUS) + "'"
	x_stat = "COD_NAZION = '" + ALLTRIM(M.CODICE_OLD) + "'"
	cSql = "UPDATE U_FOR_AN SET " + x_nazi + " WHERE FOR_CODCLI IN " + ;
	       "(SELECT CODICE FROM CARD_CLIFO WHERE TIPO = 'F' AND " + x_stat + ")"
	IF !ExecCommand(cSql,"UPD_FOR_AN")
		RETURN .F.
	ENDIF
	
	
	
	*** AGGIORNAMENTO PARAMETRO 'GEN' PER DETERMINAZIONE CONTI IN TRASFERIMENTI CONTABILI
	IF !ISNULL(M.STATOCEE)
		IF ALLTRIM(M.STATOCEE) == 'S'
			x_codi = "CODICE = 'GEN" + "CE" + "'"
			x_cond = x_codi
			cSql = "SELECT * FROM PARA WHERE " + x_cond
			IF !ExecRW(cSql,"PARA","R")
				RETURN .F.
			ENDIF
			SELECT PARA
			GO TOP
			IF !EOF()
				REPLACE NOTE WITH IIF(EMPTY(NOTE), "."+ALLTRIM(M.CODICE_AQUARIUS)+".", ALLTRIM(NOTE)+ALLTRIM(M.CODICE_AQUARIUS)+".")
			ENDIF
			IF !ExecRW(cSql,"PARA","W")
				RETURN .F.
			ENDIF
			
			x_codi = "CODICE = 'GEN" + "CO" + "'"
			x_cond = x_codi
			cSql = "SELECT * FROM PARA WHERE " + x_cond
			IF !ExecRW(cSql,"PARA","R")
				RETURN .F.
			ENDIF
			SELECT PARA
			GO TOP
			IF !EOF()
				REPLACE NOTE WITH IIF(EMPTY(NOTE), "."+ALLTRIM(M.CODICE_AQUARIUS)+".", ALLTRIM(NOTE)+ALLTRIM(M.CODICE_AQUARIUS)+".")
			ENDIF
			IF !ExecRW(cSql,"PARA","W")
				RETURN .F.
			ENDIF
		ELSE
			x_codi = "CODICE = 'GEN" + "EX" + "'"
			x_cond = x_codi
			cSql = "SELECT * FROM PARA WHERE " + x_cond
			IF !ExecRW(cSql,"PARA","R")
				RETURN .F.
			ENDIF
			SELECT PARA
			GO TOP
			IF !EOF()
				REPLACE NOTE WITH IIF(EMPTY(NOTE), "."+ALLTRIM(M.CODICE_AQUARIUS)+".", ALLTRIM(NOTE)+ALLTRIM(M.CODICE_AQUARIUS)+".")
			ENDIF
			IF !ExecRW(cSql,"PARA","W")
				RETURN .F.
			ENDIF
			
			x_codi = "CODICE = 'GEN" + "ES" + "'"
			x_cond = x_codi
			cSql = "SELECT * FROM PARA WHERE " + x_cond
			IF !ExecRW(cSql,"PARA","R")
				RETURN .F.
			ENDIF
			SELECT PARA
			GO TOP
			IF !EOF()
				REPLACE NOTE WITH IIF(EMPTY(NOTE), "."+ALLTRIM(M.CODICE_AQUARIUS)+".", ALLTRIM(NOTE)+ALLTRIM(M.CODICE_AQUARIUS)+".")
			ENDIF
			IF !ExecRW(cSql,"PARA","W")
				RETURN .F.
			ENDIF
		ENDIF	
	ENDIF
	
*!*		*** AGGIORNAMENTO PARAMETRO 'CGN' PER DETERMINAZIONE CONTI IN TRASFERIMENTI CONTABILI PER TIPO NAZIONE / GRUPPO MERC. IND.
*!*		IF !ISNULL(M.STATOCEE)
*!*			IF ALLTRIM(M.STATOCEE) == 'S'
*!*				x_tipo = "TIPOCONTP = '002'"  && TIPO CONTO "VENDITE CEE"
*!*				cSql = "SELECT * FROM CARD_TABCONT WHERE " + x_tipo
*!*				IF !ExecCommand(cSql,"CX_CARD_TABCONT")
*!*					RETURN .F.
*!*				ENDIF
*!*				SELECT CX_CARD_TABCONT
*!*				GO TOP
*!*				SCAN
*!*					SCATTER MEMVAR
*!*					
*!*					cSql = "SELECT * FROM PARA WHERE 1=0"
*!*					IF !ExecRW(cSql,"PARA","R")
*!*						RETURN .F.
*!*					ENDIF
*!*					SELECT PARA
*!*					APPEND BLANK
*!*					
*!*					REPLACE CODICE WITH "CGN" + ALLTRIM(M.GRUPPMERC) + ALLTRIM(M.CODICE_AQUARIUS)
*!*					REPLACE DESCRI WITH "CONTO VENDITA PER GRUPPO MERC. IND. '" + ALLTRIM(M.GRUPPMERC) + "' / NAZIONE '" + ALLTRIM(M.DENOMINAZI) + "'"
*!*					REPLACE LIBERA WITH ALLTRIM(M.SOTRICAV)
*!*					REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))
*!*					
*!*					IF !ExecRW(cSql,"PARA","W")
*!*						RETURN .F.
*!*					ENDIF
*!*				ENDSCAN
*!*			ELSE
*!*				x_tipo = "TIPOCONTP = '003'"  && TIPO CONTO "VENDITE EXTRACEE"
*!*				cSql = "SELECT * FROM CARD_TABCONT WHERE " + x_tipo
*!*				IF !ExecCommand(cSql,"CX_CARD_TABCONT")
*!*					RETURN .F.
*!*				ENDIF
*!*				SELECT CX_CARD_TABCONT
*!*				GO TOP
*!*				SCAN
*!*					SCATTER MEMVAR
*!*					
*!*					cSql = "SELECT * FROM PARA WHERE 1=0"
*!*					IF !ExecRW(cSql,"PARA","R")
*!*						RETURN .F.
*!*					ENDIF
*!*					SELECT PARA
*!*					APPEND BLANK
*!*					
*!*					REPLACE CODICE WITH "CGN" + ALLTRIM(M.GRUPPMERC) + ALLTRIM(M.CODICE_AQUARIUS)
*!*					REPLACE DESCRI WITH "CONTO VENDITA PER GRUPPO MERC. IND. '" + ALLTRIM(M.GRUPPMERC) + "' / NAZIONE '" + ALLTRIM(M.DENOMINAZI) + "'"
*!*					REPLACE LIBERA WITH ALLTRIM(M.SOTRICAV)
*!*					REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))
*!*					
*!*					IF !ExecRW(cSql,"PARA","W")
*!*						RETURN .F.
*!*					ENDIF
*!*				ENDSCAN
*!*			ENDIF	
*!*		ENDIF
	
	_TOT_COUNT = _TOT_COUNT + 1

ENDSCAN


*** AGGIUNTA MANUALE CODICE NAZIONE 'ITA'
x_codi = "CODICE = 'STA" + ALLTRIM(M.CODICE_AQUARIUS) + "'"
x_cond = x_codi
cSql = "SELECT * FROM PARA WHERE " + x_cond
IF !ExecRW(cSql,"PARA","R")
	RETURN .F.
ENDIF
SELECT PARA
GO TOP
APPEND BLANK

REPLACE CODICE WITH "STAITA"
REPLACE DESCRI WITH "ITALIA"
REPLACE LIBERA WITH ""
REPLACE DESIVA WITH 'STATOCEE: S'
REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))

IF !ExecRW(cSql,"PARA","W")
	RETURN .F.
ENDIF

*** AGGIORNAMENTO CODICE NAZIONE IN ANAGRAFICA CLIENTI AQUARIUS
cSql = "UPDATE U_CLI_AN SET CLI_NAZION = 'ITA' WHERE CLI_NAZION = ''"
IF !ExecCommand(cSql,"UPD_CLI_AN")
	RETURN .F.
ENDIF

*** AGGIORNAMENTO CODICE NAZIONE IN ANAGRAFICA FORNITORI AQUARIUS
cSql = "UPDATE U_FOR_AN SET FOR_NAZION = 'ITA' WHERE FOR_NAZION = ''"
IF !ExecCommand(cSql,"UPD_FOR_AN")
	RETURN .F.
ENDIF

*** AGGIORNAMENTO PARAMETRO 'GEN' PER DETERMINAZIONE CONTI IN TRASFERIMENTI CONTABILI
x_codi = "CODICE = 'GEN" + "IT" + "'"
x_cond = x_codi
cSql = "SELECT * FROM PARA WHERE " + x_cond
IF !ExecRW(cSql,"PARA","R")
	RETURN .F.
ENDIF
SELECT PARA
GO TOP
IF !EOF()
	REPLACE NOTE WITH IIF(EMPTY(NOTE), ".ITA.", ALLTRIM(NOTE)+"ITA.")
ENDIF
IF !ExecRW(cSql,"PARA","W")
	RETURN .F.
ENDIF

x_codi = "CODICE = 'GEN" + "IN" + "'"
x_cond = x_codi
cSql = "SELECT * FROM PARA WHERE " + x_cond
IF !ExecRW(cSql,"PARA","R")
	RETURN .F.
ENDIF
SELECT PARA
GO TOP
IF !EOF()
	REPLACE NOTE WITH IIF(EMPTY(NOTE), ".ITA.", ALLTRIM(NOTE)+"ITA.")
ENDIF
IF !ExecRW(cSql,"PARA","W")
	RETURN .F.
ENDIF

