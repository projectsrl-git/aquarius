*!*	x_tipo = "TIPOCONTP = '001'"  && TIPO CONTO "VENDITE ITALIA"
*!*	cSql = "SELECT * FROM CARD_TABCONT WHERE " + x_tipo
*!*	IF !ExecCommand(cSql,"CX_CARD_TABCONT")
*!*		RETURN .F.
*!*	ENDIF
*!*	SELECT CX_CARD_TABCONT
*!*	GO TOP
*!*	SCAN
*!*		SCATTER MEMVAR
*!*		
*!*		cSql = "SELECT * FROM PARA WHERE 1=0"
*!*		IF !ExecRW(cSql,"PARA","R")
*!*			RETURN .F.
*!*		ENDIF
*!*		SELECT PARA
*!*		APPEND BLANK
*!*		
*!*		REPLACE CODICE WITH "CGN" + ALLTRIM(M.GRUPPMERC) + "ITA"
*!*		REPLACE DESCRI WITH "CONTO VENDITA PER GRUPPO MERC. IND. '" + ALLTRIM(M.GRUPPMERC) + "' / NAZIONE 'ITALIA'"
*!*		REPLACE LIBERA WITH ALLTRIM(M.SOTRICAV)
*!*		REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))
*!*		
*!*		IF !ExecRW(cSql,"PARA","W")
*!*			RETURN .F.
*!*		ENDIF
*!*	ENDSCAN

*** AGGIORNAMENTO PARAMETRO 'CGN' PER DETERMINAZIONE CONTI IN TRASFERIMENTI CONTABILI PER TIPO NAZIONE / GRUPPO MERC. IND.
cSql = "SELECT * FROM CARD_TABCONT ORDER BY TIPOCONTP, GRUPPMERC"
IF !ExecCommand(cSql,"CX_CARD_TABCONT")
	RETURN .F.
ENDIF
SELECT CX_CARD_TABCONT
GO TOP
SCAN
	SCATTER MEMVAR
	
	cSql = "SELECT * FROM PARA WHERE 1=0"
	IF !ExecRW(cSql,"PARA","R")
		RETURN .F.
	ENDIF
	SELECT PARA
	APPEND BLANK
	
	DO CASE
		CASE M.TIPOCONTP = '001' && TIPO CONTO "VENDITE ITALIA"
			REPLACE CODICE WITH "CGN" + "ITA" + ALLTRIM(M.GRUPPMERC)
			REPLACE DESCRI WITH "CONTO VENDITA ITALIA / GRUPPO MERC. IND. " + ALLTRIM(M.GRUPPMERC)
		CASE M.TIPOCONTP = '002' && TIPO CONTO "VENDITE CEE"
			REPLACE CODICE WITH "CGN" + "CEE" + ALLTRIM(M.GRUPPMERC)
			REPLACE DESCRI WITH "CONTO VENDITA NAZIONI CEE / GRUPPO MERC. IND. " + ALLTRIM(M.GRUPPMERC)
		CASE M.TIPOCONTP = '003' && TIPO CONTO "VENDITE EXTRACEE"
			REPLACE CODICE WITH "CGN" + "EXT" + ALLTRIM(M.GRUPPMERC)
			REPLACE DESCRI WITH "CONTO VENDITA NAZIONI EXTRA CEE / GRUPPO MERC. IND. " + ALLTRIM(M.GRUPPMERC)
	ENDCASE
	REPLACE LIBERA WITH ALLTRIM(M.SOTRICAV)
	REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE()))
	
	IF !ExecRW(cSql,"PARA","W")
		RETURN .F.
	ENDIF
ENDSCAN

WAIT CLEAR

MESSAGEBOX("Operazione terminata correttamente" + REPLICATE(CHR(13),2) + ;
	"Totale Nazioni convertite: " + ALLTRIM(STR(_TOT_COUNT,10,0)),64,"Informazione")

RETURN


 