SS=SELECT()

CREATE CURSOR CU_RIEP (RIE_PROGRE N(3), RIE_CODICE C(03), RIE_DESCRI C(50), RIE_NUMSCO N(3),;
                       RIE_IMPINC N(17,2), RIE_IMPPAG N(17,2), RIE_SALDO N(17,2))
INDEX ON RIE_CODICE TAG I_RIEP ADDITIVE
INDEX ON RIE_PROGRE TAG I_PROG ADDITIVE

RELEASE XXX_CODICE,XXX_PROGRE,XXX_DESCRI,XXX_CONT,XXX_TOTPAG,XXX_TOTINC,XXX_TOTSCO, ;
        XXX_SALDO
PUBLIC  XXX_CODICE,XXX_PROGRE,XXX_DESCRI,XXX_CONT,XXX_TOTPAG,XXX_TOTINC,XXX_TOTSCO, ;
        XXX_SALDO
XXX_TOTPAG = 0
XXX_TOTINC = 0
XXX_TOTSCO = 0
XXX_SALDO  = 0

x_maga = "cas_codpdv = '" + ALLTRIM(PUB_CODBUN) + "'"
x_dat1 = RIBALTA2(DTOC(DATE()))
x_data = "cas_datope = '" + x_dat1 + "'"
x_cond = x_maga + " and " + x_data
cSql   = "SELECT * FROM U_PDV_OP WHERE " + x_cond
IF !ExecCommand(cSql,"CUR_PDV_OP")
   return(.f.)
ENDIF
SELECT CUR_PDV_OP
GO TOP

XXX_CONT = 0

DO WHILE .T.
   
   IF EOF()
      EXIT
   ENDIF
   
   SCATTER MEMVAR MEMO
   
   XXX_CODICE = SUBSTR(M.CAS_TIPINC,1,2)
   XXX_SEEK   = XXX_CODICE + '-'
   x_cond     = "pdv_codice = '" + XXX_SEEK + "'"
   cSql       = "SELECT * FROM U_PDV_CC WHERE " + x_cond
   IF !ExecCommand(cSql,"CUR_PDV_CC")
      return(.f.)
   ENDIF
   SELECT CUR_PDV_CC
   GO TOP
   IF !EOF()
      IF SUBSTR(PDV_DESCRI,1,6) = 'PREL. ' 
         XXX_DESCRI = SUBSTR(PDV_DESCRI,7,24)
      ELSE
         IF SUBSTR(PDV_DESCRI,1,9) = 'PRELIEVO ' 
            XXX_DESCRI = SUBSTR(PDV_DESCRI,10,21)
         ELSE
            XXX_DESCRI = PDV_DESCRI
         ENDIF
      ENDIF
      XXX_PROGRE = PDV_PROGRE
   ENDIF
   
   SELECT CU_RIEP
   SET ORDER TO I_RIEP
   SEEK XXX_CODICE
   IF FOUND()
   ELSE
      APPEND BLANK
      REPLACE RIE_CODICE WITH XXX_CODICE
      REPLACE RIE_DESCRI WITH XXX_DESCRI
      REPLACE RIE_PROGRE WITH XXX_PROGRE
      REPLACE RIE_NUMSCO WITH 0
      REPLACE RIE_IMPINC WITH 0
      REPLACE RIE_IMPPAG WITH 0
      REPLACE RIE_SALDO  WITH 0
      XXX_CONT = XXX_CONT + 1
   ENDIF
   
   IF (M.CAS_SEGNO = '-')
      REPLACE RIE_IMPPAG WITH (RIE_IMPPAG + M.CAS_IMPORT)
   ELSE
      REPLACE RIE_IMPINC WITH (RIE_IMPINC + M.CAS_IMPORT)
   ENDIF
   
   SELECT CUR_PDV_OP
   SKIP +1
   
ENDDO

x_maga = "cas_codpdv = '" + ALLTRIM(PUB_CODBUN) + "'"
x_dat1 = RIBALTA2(DTOC(DATE()))
x_data = "cas_datope = '" + x_dat1 + "'"
x_cond = x_maga + " and " + x_data
cSql   = "SELECT * FROM U_PDV_CA WHERE " + x_cond + "order by cas_codpdv,cas_progre,cas_datope,cas_oraope,cas_sequen"
IF !ExecCommand(cSql,"CUR_PDV_IN")
   return(.f.)
ENDIF
SELECT CUR_PDV_IN
GO TOP
IF EOF()
   =MESSAGEBOX("Nessun incasso da elaborare per la chiusura di cassa",16,"Attenzione")
   RETURN
ENDIF   

V_CODPDV   = CAS_CODPDV
V_PROGRE   = CAS_PROGRE

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
   
   IF CAS_CODPDV = V_CODPDV .AND. ;
      CAS_PROGRE = V_PROGRE
   ELSE
      SELECT CUR_PDV_IN
      V_CODPDV   = CAS_CODPDV
      V_PROGRE   = CAS_PROGRE
      LOOP
   ENDIF

   IF CAS_TIPINC = SPACE(03) .OR. EMPTY(CAS_TIPINC)
   ELSE
      SCATTER MEMVAR MEMO
      M.CAS_CODPAG = CAS_TIPINC
      SELECT CU_RIEP
      SET ORDER TO I_RIEP
      SEEK M.CAS_TIPINC
      IF FOUND()
         REPLACE RIE_DESCRI WITH M.CAS_DESART
         REPLACE RIE_IMPINC WITH (RIE_IMPINC + M.CAS_IMPORT)
      ELSE
         APPEND BLANK
         REPLACE RIE_CODICE WITH M.CAS_TIPINC
         REPLACE RIE_DESCRI WITH M.CAS_DESART
         REPLACE RIE_IMPINC WITH (RIE_IMPINC + M.CAS_IMPORT)
         REPLACE RIE_IMPPAG WITH 0
         REPLACE RIE_SALDO  WITH 0
         XXX_CONT = XXX_CONT + 1       
      ENDIF
      SELECT CUR_PDV_IN
      SKIP +1
      LOOP
   ENDIF

   SELECT CUR_PDV_IN
   SKIP +1
   
ENDDO

XXX_TOTPAG = 0
XXX_TOTINC = 0
XXX_TOTSCO = 0
XXX_SALDO  = 0
       
SELECT CU_RIEP
SET ORDER TO I_PROG
GO TOP
DO WHILE .T.
   IF EOF()
      EXIT
   ENDIF
   *REPLACE RIE_SALDO WITH RIE_IMPINC - RIE_IMPPAG
   XXX_TOTINC = XXX_TOTINC + RIE_IMPINC
   XXX_TOTPAG = XXX_TOTPAG + RIE_IMPPAG
   SELECT CU_RIEP
   SKIP +1
ENDDO

XXX_SALDO = XXX_TOTINC - XXX_TOTPAG 

RETURN