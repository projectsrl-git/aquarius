*** CREAZIONE CURSORE PER SUCCESSIVA SELEZIONE MOVIMENTI CONTABILI DA IMPORTARE COME CESPITI
cSql = ""
TEXT TO cSql NOSHOW
	SELECT
		SPACE(10) AS SELEZIONE,
		SPACE(20) AS MOV_CONTO_FORN, 
		SPACE(100) AS CON_RAG_SOC, 
		SPACE(100) AS CON_DESCR, 
		SPACE(100) AS MOV_DESTOP, 
		SPACE(2) AS TIPO_BENE,
		CAST(0 AS NUMERIC(6,2)) AS PERAMM_BASE, * 
	FROM MOV_CONT WHERE 1=0
ENDTEXT
IF !ExecPreparedCommand(cSql,"SEL_MOV_CONT")
  return(.f.)
ENDIF

_CONTA_CAT = 0
SELECT SEL_CONTI
SET FILTER TO SELEZI = .T.
GO TOP
SCAN
	SCATTER MEMVAR MEMO
	
	*** SCRITTURA CATEGORIE SU DB CATEGORIE
	x_codi = "AMM_CODAMM = '" + M.CON_CONTO + "'"
	cSql   = "SELECT * FROM U_AMM_CA WHERE " + x_codi
	IF !ExecRW(cSql,"U_AMM_CA","R")
	  return(.f.)
	ENDIF
	SELECT U_AMM_CA
	GO TOP
	IF EOF()
		APPEND BLANK
		REPLACE AMM_CODAMM WITH M.CON_CONTO
		REPLACE AMM_DESCR2 WITH ""
		REPLACE AMM_DESCR3 WITH ""
		REPLACE AMM_CONTAB WITH ""
		REPLACE AMM_CONPAR WITH ""
	ENDIF
	REPLACE AMM_DESCR1 WITH UPPER(ALLTRIM(M.CON_DESCR))
	REPLACE AMM_PERAMM WITH M.PERAMM_BASE
	IF !ExecRW(cSql,"U_AMM_CA","W")
	  return(.f.)
	ENDIF
		
	IF USED("TMP_MOV_CONT")
		SELECT TMP_MOV_CONT
		USE
	ENDIF
	
	*** SCRITTURA MOVIMENTI CONTABILI SU CURSORE (DA SELEZIONARE SUCCESSIVAMENTE IN UNICA BROWSEVIEW
	cSql = ""
	TEXT TO cSql NOSHOW
		SELECT 
			INDICE.MOV_CONTO AS MOV_CONTO_FORN, 
			COALESCE(CONTI_FORN.CON_DESCR,'') AS CON_RAG_SOC, 
			COALESCE(CONTI.CON_DESCR,'') AS CON_DESCR, 
			COALESCE(PARA_TOP.DESCRI,'') AS MOV_DESTOP, 
			MOV_CONT.* 
		FROM MOV_CONT
		LEFT OUTER JOIN INDICE ON INDICE.MOV_NUMPRO = MOV_CONT.MOV_NUMPRO
		LEFT OUTER JOIN CONTI ON CONTI.CON_ANNO = '<<PUB_ANNO>>' AND CONTI.CON_CONTO = MOV_CONT.MOV_CONTO
		LEFT OUTER JOIN CONTI AS CONTI_FORN ON CONTI_FORN.CON_ANNO = '<<PUB_ANNO>>' AND CONTI_FORN.CON_CONTO = INDICE.MOV_CONTO
		LEFT OUTER JOIN PARA AS PARA_TOP ON PARA_TOP.CODICE = 'TOP'+MOV_CONT.MOV_TOP AND CONTI_FORN.CON_CONTO = INDICE.MOV_CONTO
		WHERE
		MOV_CONT.MOV_SOC = '<<PUB_CODSOC>>' AND 
		MOV_CONT.MOV_CONTO = '<<M.CON_CONTO>>' AND 
		MOV_CONT.MOV_TMOV = 'D' AND 
		MOV_CONT.MOV_TOP <> 'APE' AND  -- ERASMO - 10/07/2020
		RTRIM(MOV_CONT.MOV_CONTO)+MOV_CONT.MOV_TOP+MOV_CONT.MOV_DTREG+MOV_CONT.MOV_NREGIS NOT IN (SELECT RTRIM(AMD_CONTO)+AMD_TOP+AMD_DTREG+AMD_NREGIS FROM U_AMM_AD)
		ORDER BY MOV_CONT.MOV_DTREG, MOV_CONT.MOV_NREGIS
	ENDTEXT
	IF !ExecPreparedCommand(cSql,"TMP_MOV_CONT")
	  return(.f.)
	ENDIF
	SELECT TMP_MOV_CONT
	GO TOP
	SCAN
		SCATTER MEMVAR MEMO
		SELECT SEL_MOV_CONT
		APPEND BLANK
		GATHER MEMVAR MEMO
	ENDSCAN
	
	_CONTA_CAT = _CONTA_CAT + 1
	
ENDSCAN

_CONTA_CES = 0

SELECT SEL_MOV_CONT
GO TOP
IF EOF()
	MESSAGEBOX("Nessuna registrazioine contabile da selezionare per il popolamento dei cespiti",64,"Attenzione")
ELSE

	DO prg\browseview WITH "SEL_MOV_CONT","Selezione Cespiti da movimenti contabili", ;
		"MOV_TOP:Top,W:5;MOV_DESTOP:Descrizione,W:15;MOV_CONTO_FORN:Conto principale,W:8;CON_RAG_SOC:Descrizione,W:20;MOV_CONTO:Conto,W:8;CON_DESCR:Descrizione,W:20;MOV_DTREG:Dt.Reg.,W:10;MOV_NREGIS:N.Reg.,W:10;" + ;
		"MOV_DTDOC:Dt.Doc.,W:10;MOV_NDOC:N.Doc.,W:10;MOV_IMP:Importo,W:10;MOV_VALUTA:Valuta,W:5;",800,1030,.T.
	*!*	IF NumeroRecordLetti = 0
	*!*		MESSAGEBOX("Operazione abbandonata",64,"Informazione")
	*!*		RETURN
	*!*	ENDIF

	SELECT SEL_MOV_CONT
	SET FILTER TO SELEZIONE = "==>"
	GO TOP
	SCAN
		SCATTER MEMVAR MEMO
		
		M.AMM_CODCES = ""
		_seek = 'NUMCES'+PUB_CODSOC
		TEXT TO cSql NOSHOW
			SELECT *
			FROM para
			where codice = ?_seek
			order by codice
		ENDTEXT
		IF !ExecRW(cSql,"para","R")
		  return(.f.)
		ENDIF
		IF RECCOUNT() > 0
			S_NUM = SUBSTR(LIBERA,11,6)
			IF S_NUM  <> "999999"						  && SOLO SE <> 999999
				N_NUM	  		 = VAL(S_NUM)
				INC_NUM			 = N_NUM + 1
				S_INC_NUM 		 = STR(INC_NUM,6,0)
				M.AMM_CODCES	 = ALLTRIM(S_INC_NUM)
				IF SUBSTR(M.AMM_CODCES,1,1)  <  "A"
					M.AMM_CODCES = TRC(6,ALLTRIM(M.AMM_CODCES))
			  	ENDIF
				REPLACE LIBERA WITH '0000000000' + S_INC_NUM 
			ENDIF	
		ELSE
			*MESSAGEBOX('Parametro << NUMCES >> non trovato',16,'*** ATTENZIONE ***')
		ENDIF
		IF !ExecRW(cSql,"para","W")
		  return(.f.)
		ENDIF
		
		M.AMM_TIPCAT = ""
		M.AMM_PERBAS = 0
		
		*** SCRITTURA DETTAGLI CESPITI SU DB
		cSql = "SELECT * FROM U_AMM_AD WHERE 1=0"
		IF !ExecRW(cSql,"U_AMM_AD","R")
		  return(.f.)
		ENDIF
		SELECT U_AMM_AD
		APPEND BLANK
		REPLACE AMD_CODCES WITH M.AMM_CODCES 
		REPLACE AMD_TIPDOC WITH M.MOV_TMOV
		REPLACE AMD_NUMDOC WITH M.MOV_NDOC
		REPLACE AMD_DATDOC WITH M.MOV_DTDOC
		REPLACE AMD_VALORE WITH M.MOV_IMP * MOV_CAMBIO
		REPLACE AMD_SEQUEN WITH 10 
		REPLACE AMD_CONTO  WITH M.MOV_CONTO
		REPLACE AMD_TOP    WITH M.MOV_TOP
		REPLACE AMD_DESTOP WITH M.MOV_DESTOP
		REPLACE AMD_NREGIS WITH M.MOV_NREGIS
		REPLACE AMD_NPART  WITH M.MOV_NPART
		REPLACE AMD_ANNO   WITH M.MOV_ANNO
		REPLACE AMD_DTREG  WITH M.MOV_DTREG
		IF !ExecRW(cSql,"U_AMM_AD","W")
		  return(.f.)
		ENDIF
		
		*** SCRITTURA TESTATE CESPITI SU DB
		cSql = "SELECT * FROM U_AMM_AT WHERE 1=0"
		IF !ExecRW(cSql,"U_AMM_AT","R")
		  return(.f.)
		ENDIF
		SELECT U_AMM_AT
		APPEND BLANK
		REPLACE AMM_CODCES WITH M.AMM_CODCES
		REPLACE AMM_DESCRI WITH IIF(EMPTY(M.MOV_DESMOV),"???",ALLTRIM(M.MOV_DESMOV))
		REPLACE AMM_CODCAT WITH M.MOV_CONTO
		REPLACE AMM_TIPCAT WITH M.TIPO_BENE
		REPLACE AMM_FLGUSO WITH "NO"
		REPLACE AMM_PERSPE WITH 100
		REPLACE AMM_FLGNEW WITH "N"
		REPLACE AMM_DATUTI WITH IIF(EMPTY(M.MOV_DTDOC) OR M.MOV_DTDOC = '    /  /  ' OR M.MOV_DTDOC = '  /  /    ', M.MOV_DTREG, M.MOV_DTDOC)
		REPLACE AMM_QTEAMM WITH 0
		REPLACE AMM_PERBAS WITH M.PERAMM_BASE
		REPLACE AMM_PERANT WITH 0
		REPLACE AMM_PERACC WITH 0
		REPLACE AMM_MATRIC WITH ""
		REPLACE AMM_NOTE   WITH ""
		REPLACE AMM_CONFON WITH ""
		REPLACE AMM_CONCES WITH ""
		REPLACE AMM_VALSTO WITH M.MOV_IMP * MOV_CAMBIO
		REPLACE AMM_VALRES WITH M.MOV_IMP * MOV_CAMBIO
		REPLACE AMM_TIPCES WITH 0  && NIENTE
		REPLACE AMM_DATCES WITH ""
		REPLACE AMM_VALCES WITH 0
		REPLACE AMM_PLUMIN WITH 0
		REPLACE AMM_VALORD WITH 0
		REPLACE AMM_VALANT WITH 0
		REPLACE AMM_VALACC WITH 0
		REPLACE AMM_TOTAMM WITH 0
		REPLACE AMM_DATREG WITH M.MOV_DTREG
		IF !ExecRW(cSql,"U_AMM_AT","W")
		  return(.f.)
		ENDIF
		
		_CONTA_CES = _CONTA_CES + 1
		
	ENDSCAN
ENDIF

MESSAGEBOX(	"Totale Categorie inserite/aggiornate: " + ALLTRIM(STR(_CONTA_CAT,10,0)) + REPLICATE(CHR(13),2) + ;
			"Totale Cespiti inseriti: " + ALLTRIM(STR(_CONTA_CES,10,0)),64,"Informazione")

RETURN .T.
