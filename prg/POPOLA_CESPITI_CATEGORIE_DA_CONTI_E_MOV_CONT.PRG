*** SE CATEGORIA GIA' ESISTENTE, PROPONGO PERCENTUALE DI AMMORTAMENTO BASE E TIPO 
SCAN
	__CON_CONTO = CON_CONTO 
	
	x_codi = "AMM_CODAMM = '" + __CON_CONTO + "'"
	cSql   = "SELECT AMM_PERAMM FROM U_AMM_CA WHERE " + x_codi
	IF !ExecCommand(cSql,"TMP_AMM_CA")
	  return(.f.)
	ENDIF
	SELECT TMP_AMM_CA
	GO TOP
	IF !EOF()
		__PERAMM_BASE = AMM_PERAMM
		SELECT SEL_CONTI
		REPLACE PERAMM_BASE WITH __PERAMM_BASE
		*REPLACE SELEZI WITH .T.
	ENDIF
	
	x_codi = "AMM_CODCAT = '" + __CON_CONTO + "'"
	cSql   = "SELECT TOP 1 AMM_CODCES, AMM_TIPCAT FROM U_AMM_AT WHERE " + x_codi + " ORDER BY AMM_CODCES DESC"
	IF !ExecCommand(cSql,"TMP_AMM_AT")
	  return(.f.)
	ENDIF
	SELECT TMP_AMM_AT
	GO TOP
	IF !EOF()
		__TIPCAT = AMM_TIPCAT
		SELECT SEL_CONTI
		REPLACE TIPO_BENE WITH __TIPCAT
		REPLACE SELEZI WITH .T.
	ENDIF
ENDSCAN
