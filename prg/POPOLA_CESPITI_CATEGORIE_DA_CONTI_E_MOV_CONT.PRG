cSql = ""
TEXT TO cSql NOSHOW
	SELECT 
	CAST(0 AS BIT) AS SELEZI, 
	CONTI_M.CON_CONTO AS CAPO_MASTRO, 
	CONTI_M.CON_DESCR AS DESCR_CAPO_MASTRO, 
	CAST(0 AS NUMERIC(6,2)) AS PERAMM_BASE, 
	CAST('' AS VARCHAR(2)) AS TIPO_BENE, 
	CONTI.* 
	FROM CONTI 
	LEFT OUTER JOIN CONTI AS CONTI_M ON CONTI_M.CON_CONTO = SUBSTRING(CONTI.CON_CONTO,1,<<ALLTRIM(STR(PUB_SOTTOG - 1))>>) AND CONTI_M.CON_ANNO = '<<PUB_ANNO>>' 
	WHERE
	CONTI.CON_SOC = '<<PUB_CODSOC>>' AND 
	CONTI.CON_ANNO = '<<PUB_ANNO>>' AND 
	LEN(RTRIM(CONTI.CON_CONTO)) >= <<ALLTRIM(STR(PUB_SOTTOG))>> AND 
	CONTI.CON_TIPOCO = 'X' AND 
	CONTI.CON_POSBIL = 'P'
	ORDER BY CON_CONTO
ENDTEXT
IF !ExecPreparedCommand(cSql,"SEL_CONTI")
  return(.f.)
ENDIF

SELECT SEL_CONTI
GO TOP
IF EOF()
	MESSAGEBOX("Nessun conto da selezionare",48,"Attenzione")
	RETURN .F.
ENDIF

