PROCEDURE ELABORA_TAPPETO
**********************************************************
PARAMETERS oForm

WAIT WINDOW "CREAZIONE TAPPETO IN CORSO... ATTENDERE PREGO..." NOWAIT

CREA_TAPPETO(oForm)

WAIT WINDOW "DISPOSIZIONE ROTOLI IN CORSO... ATTENDERE PREGO..." NOWAIT

DO DISPONI_ROTOLI_NO_ARLECCHINO

WAIT WINDOW "VERIFICA DEL CONTENUTO DELLE BARRE DA TAGLIARE IN CORSO... ATTENDERE PREGO..." NOWAIT

DO CREA_CIFRA_DI_PATTERN_DELLE_SEZIONI

