

**********************************************************
PROCEDURE CREA_LOG
**********************************************************

	CREATE CURSOR LOGTAPPETO (;
		DATALOG	  C(10),;
		ORALOG 	  C(8),;
		TESTO C(254))
		
* Fine - PROCEDURE CREA_LOG
**********************************************************

**********************************************************
PROCEDURE SCRIVI_LOG
**********************************************************
LPARAMETERS _TESTO

	LOCAL _SWWS
	_SWWS=SELECT()
	
	IF !USED("LOGTAPPETO")
		USE LOGTAPPETO
	ENDIF
	
	SELECT LOGTAPPETO

	APPEND BLANK
	REPLACE DATALOG WITH DTOC(DATE()),;
	        ORALOG WITH TIME(),;
	        TESTO WITH _TESTO
		
	SELECT(_SWWS)
	
* Fine - PROCEDURE SCRIVI_LOG
**********************************************************

