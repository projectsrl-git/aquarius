		_CODART_BOBINA=ART_CODPRI
		_DESART_BOBINA=ART_DESCR
		_SPESSO_BOBINA=ART_SPESSO
		
		*** FINE CALCOLO BONINA PER FASCIA
		
		SELECT CAMBI_BOBINA
		
		*** aggiorna U_PRD_D2 solo se cambio fascia
		***
		IF _FASCIA<>_FASCIA_PRECEDENTE
		
			_CONTATORE_FASCE =_CONTATORE_FASCE+1
			
			_STR_FASCIA          = STR_FILL_ZERO(_FASCIA,5)
			_STR_CONTATORE_FASCE = STR_FILL_ZERO(_CONTATORE_FASCE,3)
			
			_PJ_PRGPRD2 = "FASCIA_"+_STR_CONTATORE_FASCE+"_"+_STR_FASCIA
			
			SELECT U_PRD_D2
			
			IF !EOF()
				REPLACE PR2_NUMBOB WITH _NUMERO_BOBINE
			ENDIF
			
			APPEND BLANK
	
			REPLACE PJ_PRGPRD1 WITH PUB_PJ_PRGPRD1
			REPLACE PJ_PRGPRD2 WITH _PJ_PRGPRD2
			REPLACE PR2_FASCIA WITH _FASCIA
			REPLACE PR2_SEQUEN WITH _STR_CONTATORE_FASCE
	
			*** CALCOLO DATA DI PRODUZIONE DELLA SEQUENZA/FASCIA		
    		_MINUTI_FINALI_FASCIA=0
			IF VELOCITA_SPALM>0
				_MINUTI_FINALI_FASCIA=ROUND(CALCOLA_LUNGHEZZA_TAPPETO_FINO_ALLA_SEZIONE(_SEZIONE_INIZIALE)/VELOCITA_SPALM,0)
			ENDIF
			_TIMESTAMP_FASCIA=CALCOLA_DATA_ORA(_MINUTI_FINALI_FASCIA)
    
		    _PR2_DATSEQ = RIBALTA2(SUBSTR(_TIMESTAMP_FASCIA,1,10))

			REPLACE PR2_DATSEQ WITH _PR2_DATSEQ
			
			REPLACE PR2_CODADE WITH PUB_CODICE_ADESIVO
			REPLACE PR2_DESADE WITH PUB_DESCRI_ADESIVO
			REPLACE PR2_SPEBOB WITH _SPESSO_BOBINA
			
			REPLACE PR2_UNIMIS WITH _UNIMIS
			REPLACE PR2_CODART WITH _CODART_BOBINA
			REPLACE PR2_DESART WITH _DESART_BOBINA
			
			
			_FASCIA_PRECEDENTE=_FASCIA
			_NUMERO_BOBINE=0
		ENDIF
		
		*******************************************************
		*** FINE AGGIORNAMENTO U_PRD_D2
		*******************************************************
		
		
		_NUMERO_BOBINE=_NUMERO_BOBINE+1
		
		
		*******************************************************
		*** INIZIO AGGIORNAMENTO U_PRD_D3
		*******************************************************
		
		SELECT CAMBI_BOBINA
		
		SCATTER MEMVAR MEMO
		
		_PR3_SPESSO	= M.SPESS

		*** CALCOLA QTA ADESIVO
		***
		
		SELECT TAPPETO
		SET ORDER TO SEZIONE
		SEEK _SEZIONE_INIZIALE
		_CODART= ALLTRIM(CODART)
		
		cSql = "SELECT DIS_QTA AS QTA_ADESIVO FROM U_DIS_DD WHERE  DIS_GRUPPO='"+_CODART+"' AND DIS_CODART='"+PUB_CODICE_ADESIVO+"' "
	    IF !ExecCommand(CSQL,"CUR_ADESIVO")
	       RETURN (.f.)
	    ENDIF  
	    SELECT CUR_ADESIVO
	    _QTA_ADESIVO=0
	    IF !EOF()
	    	_QTA_ADESIVO=QTA_ADESIVO
	    ENDIF
			
		*** CALCOLA QTA ADESIVO
		***	FINE
	    
		SELECT U_PRD_D3
		
		_PJ_PRGPRD3="BOBINA_"+STR_FILL_ZERO(M.BOBINA,5)
		
		APPEND BLANK
		REPLACE PJ_PRGPRD1 WITH PUB_PJ_PRGPRD1
		
		REPLACE PJ_PRGPRD2 WITH _PJ_PRGPRD2
		
		REPLACE PJ_PRGPRD3 WITH _PJ_PRGPRD3

		REPLACE PR3_CODBOB WITH _CODART_BOBINA
		REPLACE PR3_DESBOB WITH _DESART_BOBINA
		
		REPLACE PR3_ALTEZZ WITH _FASCIA_PRECEDENTE
		REPLACE PR3_LUNGHE WITH M.LUNGH
		REPLACE PR3_SPESSO WITH _SPESSO_BOBINA
		
		REPLACE PR3_CODINT WITH ""
		REPLACE PR3_ALTCAR WITH 0 
		REPLACE PR3_LUNCAR WITH 0 
		REPLACE PR3_SPECAR WITH 0 
		REPLACE PR3_CODADE WITH PUB_CODICE_ADESIVO
		REPLACE PR3_DESADE WITH PUB_DESCRI_ADESIVO
		REPLACE PR3_CDADIN WITH ""
		REPLACE PR3_QUANTI WITH TROVA_MQ_DA_AL(_FASCIA_PRECEDENTE, M.LUNGH,1) * _QTA_ADESIVO 
		REPLACE PR3_QTACAR WITH 0 
		
		
		*******************************************************
		*** FINE AGGIORNAMENTO U_PRD_D3
		*******************************************************
		

		*******************************************************
		*** INIZIO AGGIORNAMENTO U_PRD_D4
		*******************************************************
		
		SELECT SEZIONI
		SET ORDER TO SEZIONE
		SEEK _SEZIONE_INIZIALE
		_PJ_PRGPRD4=""
		
		DO WHILE !EOF()
		
			IF SEZIONE >_SEZIONE_FINALE
				EXIT
			ENDIF
		
			IF DELETED()
				SKIP
				LOOP
			ENDIF
			
			
			SCATTER MEMVAR MEMO

			_LUNGHEZZA_TOTALE_SPALMATURA=_LUNGHEZZA_TOTALE_SPALMATURA+LUNGH
			_CONTATORE_BARRE=_CONTATORE_BARRE+1
			
			SELECT U_PRD_D2
			REPLACE PR2_DBARRE WITH _CONTATORE_BARRE
			
			_PR4_PROGRE=STR_FILL_ZERO(M.SEZIONE,5)
			_PJ_PRGPRD4="BARRA_"+_PR4_PROGRE

			SELECT TAPPETO
			SET ORDER TO SEZIONE
			SEEK M.SEZIONE
			_CODART= CODART
			_DESART= DESART
			
			SELECT U_PRD_D4
			
			APPEND BLANK
			
			REPLACE PJ_PRGPRD1 WITH PUB_PJ_PRGPRD1
			REPLACE PJ_PRGPRD2 WITH _PJ_PRGPRD2
			REPLACE PJ_PRGPRD3 WITH _PJ_PRGPRD3
			REPLACE PJ_PRGPRD4 WITH _PJ_PRGPRD4
			REPLACE PR4_CODART WITH _CODART 
			REPLACE PR4_DESART WITH _DESART 
			REPLACE PR4_UNIMIS WITH _UNIMIS
			REPLACE PJ_PATTERN WITH M.PATTERN 
			REPLACE PR4_PROGRE WITH _PR4_PROGRE
			REPLACE PR4_ALTEZZ WITH M.ALTEZ
			REPLACE PR4_LUNGHE WITH M.LUNGH
			REPLACE PR4_SPESSO WITH _SPESSO_BOBINA
			REPLACE PR4_CODINT WITH ""
			REPLACE PR4_ALTCAR WITH 0
			REPLACE PR4_LUNCAR WITH 0
			REPLACE PR4_SPECAR WITH 0
			REPLACE PR4_DATAVA WITH ""
			REPLACE PR4_ORAAVA WITH ""
			REPLACE PR4_CODEVE WITH ""
			REPLACE PR4_QUALIT WITH 0
			REPLACE PR4_GRAMMA WITH 0
			REPLACE PR4_NRTTAG WITH 0
			REPLACE PR4_FORTAG WITH ""
			REPLACE PR4_DARIBO WITH .F.
			REPLACE PR4_RIBOBI WITH .F.
			REPLACE PR4_DAMCRF WITH .F.	
			
			
			*******************************************************
			*** INIZIO AGGIORNAMENTO U_PRD_D5
			*******************************************************			
			
			SELECT SEZIONI
			_SEZIONE_ATTUALE=SEZIONE
			
			SELECT TAPPETO
			SET ORDER TO SEZIONE
			SEEK _SEZIONE_ATTUALE
			
			DO WHILE !EOF()
			
				IF DELETED()
					SKIP
					LOOP
				ENDIF
				
				IF SEZIONE <>_SEZIONE_ATTUALE
					EXIT
				ENDIF
		
				SCATTER MEMVAR MEMO
			
				_CONTATORE_ROTOLI=_CONTATORE_ROTOLI+1
				_PR4_PROGRE=STR_FILL_ZERO(_CONTATORE_ROTOLI,5)
				
				SELECT U_PRD_D5
				
				APPEND BLANK
				
				REPLACE PJ_PRGPRD1 WITH PUB_PJ_PRGPRD1
				REPLACE PJ_PRGPRD2 WITH _PJ_PRGPRD2
				REPLACE PJ_PRGPRD3 WITH _PJ_PRGPRD3
				REPLACE PJ_PRGPRD4 WITH _PJ_PRGPRD4
				REPLACE PJ_PRGPRD5 WITH "ROTOLO_"+_PR4_PROGRE
				REPLACE PR5_CODCLI WITH M.CODCLI 
				REPLACE PR5_RAGSOC WITH M.RAGSOC 
				REPLACE PR5_NUMORD WITH M.NUMORD 
				REPLACE PR5_DATORD WITH M.DATORD 
				REPLACE PR5_CODART WITH M.CODART 
				REPLACE PR5_DESART WITH M.DESART
				REPLACE PR5_UNIMIS WITH _UNIMIS 
				REPLACE PR5_PROGRE WITH _PR4_PROGRE 
				REPLACE PR5_ALTEZZ WITH M.ALTEZ
				REPLACE PR5_LUNGHE WITH M.LUNGH
				REPLACE PR5_SPESSO WITH _SPESSO_BOBINA
				REPLACE PR5_CODINT WITH ""
				REPLACE PR5_ALTTAG WITH 0
				REPLACE PR5_LUNTAG WITH 0
				REPLACE PR5_SPETAG WITH 0
				REPLACE PR5_DATAVA WITH ""
				REPLACE PR5_ORAAVA WITH ""
				REPLACE PR5_CODEVE WITH ""
				REPLACE PR5_DATCON WITH M.DTCONS
				REPLACE PR5_DTCON2 WITH M.DTCONS		
				

				SELECT TAPPETO
				SKIP
					
			ENDDO
			
			*******************************************************
			*** FINE AGGIORNAMENTO U_PRD_D5
			*******************************************************			
			
			SELECT SEZIONI
			SKIP
				
		ENDDO		
		
		SELECT CAMBI_BOBINA
		SKIP
		
    ENDDO
	
    SELECT U_PRD_D2
	IF !EOF()
		REPLACE PR2_NUMBOB WITH _NUMERO_BOBINE
	ENDIF
	
	
	*******************************************************
	*** INIZIO AGGIORNAMENTO U_PRD_D1
	*******************************************************		
	
    SELECT U_PRD_D1
    APPEND BLANK
    
    REPLACE PJ_PRGPRD1 WITH PUB_PJ_PRGPRD1
    REPLACE PR1_NUMPIA WITH PUB_PR1_NUMPIA
    REPLACE PR1_DATPIA WITH PUB_PR1_DATPIA
    REPLACE PR1_NUMPRG WITH PUB_PR1_NUMPIA
    REPLACE PR1_DATPRG WITH PUB_PR1_DATPIA
    
    *** PR1_DTINPR = data inizio prevista (quella che si vede in basso a sinistra del tappeto)
    *** 
    *** PR1_DTFIPR = data fine prevista  (quella che si vede in basso a destra del tappeto)
    *** 
    *** PR1_HRINPR = ora inizio previsto  (quella che si vede in basso a sinistra del tappeto)
    *** 
    *** PR1_HRFIPR = ora fine prevista  (quella che si vede in basso a destra del tappeto)
    
    _MINUTI_FINALI=0
	IF VELOCITA_SPALM>0
		_MINUTI_FINALI=ROUND(_LUNGHEZZA_TOTALE_SPALMATURA/VELOCITA_SPALM,0)
	ENDIF
	_TIMESTAMP_FINE		=CALCOLA_DATA_ORA(_MINUTI_FINALI)
    
    
    _PR1_DTINPR = RIBALTA2(DATA_INIZIO_SPLAM)
    _PR1_DTFIPR = RIBALTA2(SUBSTR(_TIMESTAMP_FINE,1,10))
    
    _PR1_HRINPR = ORA_INIZIO_SPALM
    _PR1_HRFIPR = SUBSTR(_TIMESTAMP_FINE,12)
    
    REPLACE PR1_DTINPR WITH _PR1_DTINPR
    REPLACE PR1_DTFIPR WITH _PR1_DTFIPR
    REPLACE PR1_HRINPR WITH _PR1_HRINPR
    REPLACE PR1_HRFIPR WITH _PR1_HRFIPR
	
    REPLACE PR1_DTINEF WITH _PR1_DTINPR
    REPLACE PR1_DTFIEF WITH _PR1_DTFIPR
    REPLACE PR1_HRINEF WITH _PR1_HRINPR
    REPLACE PR1_HRFIEF WITH _PR1_HRFIPR
    
    REPLACE PR1_STAPRG WITH "002"
    
    REPLACE PR1_DATINS WITH RIBALTA2(DTOC(DATE()))
    REPLACE PR1_OPEINS WITH PUB_CODOPE
    
    REPLACE PR1_DATMOD WITH RIBALTA2(DTOC(DATE()))
    REPLACE PR1_OPEMOD WITH PUB_CODOPE
    
	*******************************************************
	*** FINE AGGIORNAMENTO U_PRD_D1
	*******************************************************			
	
	
	IF !ExecRW("","U_PRD_D1","W")
		return(.f.)
	ENDIF	
	
	IF !ExecRW("","U_PRD_D2","W")
		return(.f.)
	ENDIF
	
	IF !ExecRW("","U_PRD_D3","W")
		return(.f.)
	ENDIF

	IF !ExecRW("","U_PRD_D4","W")
		return(.f.)
	ENDIF
	
	IF !ExecRW("","U_PRD_D5","W")
		return(.f.)
	ENDIF	
			
