DO RAGGRUPPA_BARRE_CON_LO_STESSO_PATTERN

* FINE PROCEDURE ELABORA_TAPPETO
**********************************************************



**********************************************************
PROCEDURE DISPONI_ROTOLI_NO_ARLECCHINO
**********************************************************

LOCAL _NUMORD,;
	  _DTCONS,;
	  _ALTEZ,;
	  _LUNGH,;
	  _QTA,;
	  _RAGSOC,;
	  _DATORD,;
	  _CODCLI,;
	  _CODICE_SEZIONE_VALIDO
	  
SELECT * FROM PROGPROD ORDER BY DTCONS,NUMORD,LUNGH,ALTEZ INTO CURSOR PROGPROD_ELAB

SELECT PROGPROD_ELAB
GO TOP

DO WHILE !EOF()
	
	IF DELETED()	
		SKIP
		LOOP
	ENDIF

	_NUMORD      = NUMORD
	_DTCONS      = DTCONS
	_ALTEZ       = ALTEZ
	_LUNGH       = LUNGH
	_QTA         = QTA
	_RAGSOC	     = RAGSOC
	_DATORD      = DATORD
	_CODCLI      = CODCLI 
	_CODART      = CODART
	_DESART      = DESART
	_GRP_PROD    = GRP_PROD
	_MICROFORATO = MICROFORATO
	_ADESIVO     = ADESIVO
	_GGEVAS      = GGEVAS 
	
	FOR I=1 TO _QTA	

		_CODICE_SEZIONE_VALIDO=0
		
		SELECT SEZIONI
		SET ORDER TO LUNGH
		GO TOP
			
		DO WHILE !EOF()
		
			IF DELETED()
				SKIP
				LOOP
			ENDIF
			
			IF LUNGH<_LUNGH
				SKIP
				LOOP
			ENDIF
			
			IF LUNGH>_LUNGH
				EXIT
			ENDIF
		
			*** TROVA UNA SEZIONE GIA' CREATA CHE SIA CANDIDATA A CONTENERE
			*** IL MIO ROTOLO CHE STO ELABORANDO
			*** OSSIA ALTA MENO DELL'ALTEZZA DELLA BOBINA MADRE SOTRATTA DELL'ALTEZZA DEL ROTOLO
			*** E LUNGA COME IL ROTOLO
			***
			IF ALTEZ+_ALTEZ<=ALTEZZA_BOBINA
				_CODICE_SEZIONE_VALIDO=SEZIONE
				EXIT
			ENDIF
			
			SKIP 
			LOOP
		ENDDO
		
		*** NON TROVA NESSUNA SEZIONE GIA' CREATA CHE SIA CANDIDATA A CONTENERE
		*** IL MIO ROTOLO CHE STO ELABORANDO
		***
		IF _CODICE_SEZIONE_VALIDO=0
			SELECT SEZIONI
			SET ORDER TO SEZIONE
			GO BOTT
			_CODICE_SEZIONE_VALIDO=SEZIONE+1

			*** creo una nuova sezione
			*** di lunghezza opportuna
			***
			APPEND BLANK
			REPLACE SEZIONE WITH _CODICE_SEZIONE_VALIDO
			REPLACE LUNGH   WITH _LUNGH
		ENDIF
		
		*** aggiorna la tabella delle SEZIONI
		***
		SELECT SEZIONI
		REPLACE ALTEZ WITH ALTEZ +_ALTEZ
				
		*** AGGIORNO IL CURSORE TEMPORANEO DEI ROTOLI
		*** 
		SELECT TAPPETO_TMP0 
		APPEND BLANK
		REPLACE NUMORD WITH _NUMORD,;
				DTCONS WITH _DTCONS,;
				SEZIONE WITH _CODICE_SEZIONE_VALIDO,;
				ALTEZ WITH _ALTEZ,;
				LUNGH WITH _LUNGH,;
				RAGSOC WITH _RAGSOC,;
				CODCLI WITH _CODCLI,;
		        DATORD WITH _DATORD,;
		        CODART WITH _CODART,;
				DESART WITH _DESART,;
		        CESTINO WITH .F.,;
				GRP_PROD WITH _GRP_PROD,;
				MICROFORATO WITH _MICROFORATO,;
				ADESIVO WITH _ADESIVO,;
				GGEVAS WITH _GGEVAS 

	NEXT

	SELECT PROGPROD_ELAB
	SKIP
ENDDO

SELECT TAPPETO_TMP0 

* FINE PROCEDURE DISPONI_ROTOLI_NO_ARLECCHINO
**********************************************************

**********************************************************
PROCEDURE CREA_CIFRA_DI_PATTERN_DELLE_SEZIONI
**********************************************************
LOCAL _SEZIONE,_CONTATORE_DI_SEZIONE

_CONTATORE_DI_SEZIONE=0

SELECT SEZIONI
GO TOP
DO WHILE !EOF()

	_SEZIONE   =SEZIONE
	_PATTERN =""

	SELECT * FROM TAPPETO_TMP0 WHERE !DELETED() AND !CESTINO AND SEZIONE=_SEZIONE ORDER BY NUMORD,DATORD,ALTEZ INTO CURSOR _CUR_TAPPETO
	SELECT _CUR_TAPPETO
	GO TOP
	
	DO WHILE !EOF()	
		
		_NUMORD=ALLTRIM(NUMORD)
		_DATORD=ALLTRIM(DATORD)
		_ALTEZZA_ROTOLO =ALLTRIM(STR(ALTEZ))
		_LUNGHEZZA_ROTOLO=ALLTRIM(STR(LUNGH))
		
		SELECT SEZIONI
		
		_PATTERN= _PATTERN + _NUMORD+_DATORD+_ALTEZZA_ROTOLO+_LUNGHEZZA_ROTOLO
		
		SELECT _CUR_TAPPETO
		SKIP 
		
	ENDDO
	
	SELECT SEZIONI
	REPLACE PATTERN WITH _PATTERN
	SKIP
	
ENDDO

* FINE PROCEDURE CREA_CIFRA_DI_PATTERN_DELLE_SEZIONI
**********************************************************


**********************************************************
PROCEDURE RIORDINA_IN_ALTEZZA
**********************************************************
LOCAL _SEZIONE,_CONTATORE_DI_SEZIONE

SELECT * FROM SEZIONI ORDER BY ALTEZ DESC, SEZIONE INTO CURSOR BARRECUNEO

DO CREA_SEZIONI

_CONTATORE_DI_SEZIONE=0

SELECT BARRECUNEO
GO TOP
DO WHILE !EOF()

	_SEZIONE=SEZIONE
	_CONTATORE_DI_SEZIONE=_CONTATORE_DI_SEZIONE+1
	
	SELECT * FROM TAPPETO_TMP0 WHERE SEZIONE=_SEZIONE ORDER BY NUMORD,DATORD,ALTEZ INTO CURSOR _CUR_TAPPETO
	SELECT _CUR_TAPPETO
	GO TOP
	
	DO WHILE !EOF()	
		
		SCATTER MEMVAR
		SELECT TAPPETO
		APPEND BLANK
		GATHER MEMVAR
		
		REPLACE SEZIONE WITH _CONTATORE_DI_SEZIONE
		
		SELECT _CUR_TAPPETO
		SKIP 
		
	ENDDO
	
	
	SELECT BARRECUNEO
	SCATTER MEMVAR 
	
	SELECT SEZIONI
	APPEND BLANK
	GATHER MEMVAR
