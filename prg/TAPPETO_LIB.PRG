		ID_ROTOLO C(20),;
		RAGSOC	C(80),;
		CODCLI  C(10),;
		NUMORD 	C(10),;
		DATORD  C(10),;
		GGEVAS  N(3),;
		DTCONS 	C(10),;
		DTPRPR  C(10),;
		DTCEFF  C(10),;
		GGDIFF  N(3),;
		MINUTI  N(10),;
		CODART  C(30),;
		DESART  C(50),;
		XCOORD0 N(5),;
		XCOORD1 N(5),;
		SEZIONE	N(5),;
		ALTEZ	N(5),;
		LUNGH	N(5),;	
		YCOORD0 N(5),;
		CESTINO L,;
		SPESS	N(5),;
		GRP_PROD C(10),;
		MICROFORATO C(1),;
		ADESIVO C(30),;
		DESADE  C(50))
		
	INDEX ON ALTEZ TAG ALTEZ	
	INDEX ON SEZIONE TAG SEZIONE	
	INDEX ON ID_ROTOLO TAG ID_ROTOLO 
