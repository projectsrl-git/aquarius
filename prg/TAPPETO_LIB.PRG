**********************************************************
PROCEDURE RAGGRUPPA_BARRE_CON_LO_STESSO_PATTERN
**********************************************************
LOCAL _CONTATORE_DI_SEZIONE,_PATTERN_SEZIONE_PRECEDENTE,_NUMERO_SEZIONI_RAGGRUPPATE,_SAVE_RECNO

_PATTERN_SEZIONE_PRECEDENTE="************************"
_NUMERO_SEZIONI_RAGGRUPPATE=0

SELECT SEZIONI
SET ORDER TO SEZIONE

GO TOP
DO WHILE !EOF()

	_SAVE_RECNO=RECNO()
	
	IF PATTERN!=_PATTERN_SEZIONE_PRECEDENTE
		REPLACE FLGVIEW WITH .T.
		
		REPLACE NUMSEZRAGG WITH _NUMERO_SEZIONI_RAGGRUPPATE FOR PATTERN=_PATTERN_SEZIONE_PRECEDENTE
		REPLACE FLGMULTI WITH .T. FOR PATTERN=_PATTERN_SEZIONE_PRECEDENTE
		
		_NUMERO_SEZIONI_RAGGRUPPATE=1
		
	ELSE
		REPLACE FLGVIEW WITH .F.
		_NUMERO_SEZIONI_RAGGRUPPATE=_NUMERO_SEZIONI_RAGGRUPPATE+1
	ENDIF
		
	SELECT SEZIONI
	GO _SAVE_RECNO
	
	_PATTERN_SEZIONE_PRECEDENTE=PATTERN
	
	SKIP
	
ENDDO


