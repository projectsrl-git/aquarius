**********************************************************
PROCEDURE SELEZIONAORDINI
**********************************************************

LOCAL _NUMORD,;
	_DTCONS,;
	_QTA   ,;
	_ALTEZ ,;
	_LUNGH ,;
	_SPESS ,;
	_DATORD,;
	_DTCONS,;
	_RAGSOC,;
	_CODCLI,;
	_CODART,;
	_DESART,;
	_ADESIVO,;
	_DESADE,;
	_MICROFORATO,;
	_GRP_PROD,;
	_GGEVAS 
	
 	

SELECT CURPROD     
GO TOP
 
DO WHILE !EOF()
	
	_NUMORD      = ORDINE 
	_DTCONS	     = DATACONS 
	_QTA	     = VAL(QTA )
	_ALTEZ	     = VAL(ALTEZZA )
	_LUNGH	     = VAL (LUNGHEZZA )
	_SPESS	     = VAL(SPESSORE )
	_DATORD      = DATORD
	_RAGSOC      = RAGCLI 
	_CODCLI      = CODCLI 
	_CODART      = PRODOTTO
	_DESART      = DESART
	_ADESIVO     = ADESIVO
	_MICROFORATO = MICROFORATO
	_GRP_PROD    = GRP_PROD
	_DESADE      = DESADE
	_GGEVAS      = GGEVAS 
	
	SELECT PROGPROD 
	APPEND BLANK
	REPLACE NUMORD 	    WITH _NUMORD,;
			DTCONS 	    WITH _DTCONS,;
			QTA		    WITH _QTA,;
			ALTEZ       WITH _ALTEZ,;
			LUNGH       WITH _LUNGH,;
			SPESS       WITH _SPESS,;
			DATORD	    WITH _DATORD,;
			CODCLI      WITH _CODCLI,;
			CODART      WITH _CODART,;
			DESART      WITH _DESART,;
			RAGSOC	    WITH _RAGSOC,;
			GRP_PROD    WITH _GRP_PROD,;
			MICROFORATO WITH _MICROFORATO,;
			ADESIVO     WITH _ADESIVO,;
			DESADE      WITH _DESADE,;
			GGEVAS      WITH _GGEVAS 

			
	SELECT CURPROD                          
	SKIP
ENDDO


SELECT PROGPROD 
GO TOP

* FINE - PROCEDURE SELEZIONAORDINI
**********************************************************



