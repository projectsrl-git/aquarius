**********************************************************
PROCEDURE ADD_CAMBIO_BOBINA
**********************************************************
	LPARAMETERS _NUOVO_PROGR,_SEZIONE_INIZIALE,_SEZIONE_FINALE,_LUNGHEZZA_BOBINA
	
	LOCAL _SWWS, _NOME_OGGETTO,posizione_x0, altezza_in_pixel, _NUOVO_PROGR

	_SWWS=SELECT()

	_NOME_OGGETTO="CAMBIO_"+SYS(2015)
	
	SELECT CAMBI_BOBINA
	
	APPEND BLANK
	REPLACE ID WITH ALLTRIM(_NOME_OGGETTO)
	REPLACE ALTEZ    WITH ALTEZZA_BOBINA
	REPLACE SPESS    WITH SPESSORE_BOBINA
	REPLACE LUNGH    WITH _LUNGHEZZA_BOBINA
	REPLACE SEZINI   WITH _SEZIONE_INIZIALE 
	REPLACE SEZFIN   WITH _SEZIONE_FINALE 
	REPLACE BOBINA   WITH _NUOVO_PROGR
	REPLACE NUMBARRE WITH _SEZIONE_FINALE-_SEZIONE_INIZIALE+1
	
	SELECT(_SWWS)
	
* FINE - PROCEDURE ADD_CAMBIO_BOBINA
**********************************************************



**********************************************************
PROCEDURE REMOVE_OGGETTI_NON_ROTOLI
**********************************************************
	LPARAMETERS _OFORM
	
	LOCAL _OBJ,_COMANDO
	
	IF USED("OGGETTI_NON_ROTOLI")
		SELECT OGGETTI_NON_ROTOLI
		GO TOP
		DO WHILE !EOF()
				
			_COMANDO="_OFORM."+ALLTRIM(ID)
			
			
			IF TYPE(_COMANDO) = "O" AND NOT ISNULL(&_COMANDO)
			   * Object exists
				_OFORM.RemoveObject(ALLTRIM(ID))
			ELSE
			   * Object does not exist
			ENDIF
			SKIP
		ENDDO
	ENDIF	
	
	DO CREA_OGGETTI_NON_ROTOLI

* FINE - PROCEDURE REMOVE_OGGETTI_NON_ROTOLI
**********************************************************

**********************************************************
PROCEDURE REMOVE_ROTOLI
**********************************************************
	LPARAMETERS _OFORM
	
	IF !USED("TAPPETO")
		RETURN
	ENDIF	
	
	SELECT TAPPETO
	GO TOP
	DO WHILE !EOF()
		IF EMPTY(ID_ROTOLO)
			SKIP
			LOOP
		ENDIF
		
		IF CESTINO
			SKIP
			LOOP
		ENDIF
		
		_COMANDO="_OFORM."+ALLTRIM(ID_ROTOLO)
		
		
		IF TYPE(_COMANDO) = "O" AND NOT ISNULL(&_COMANDO)
		   * Object exists
			_OFORM.RemoveObject(ALLTRIM(ID_ROTOLO))
		ELSE
		   * Object does not exist
		ENDIF
					

		SKIP
	ENDDO
	
* FINE - PROCEDURE REMOVE_ROTOLI
**********************************************************


**********************************************************
PROCEDURE REFRESH_SINGOLA_SEZIONE
**********************************************************
	LPARAMETERS _OFORM,_SEZIONE
	
	LOCAL _YCOORD_ULTIMO_ROTOLO_POSIZIONATO
	
	SELECT * FROM TAPPETO ORDER BY YCOORD0 DESC WHERE SEZIONE = _SEZIONE INTO CURSOR SINGOLA_SEZIONE READWRITE
		
	SELECT SINGOLA_SEZIONE
	GO TOP
	
	_YCOORD_ULTIMO_ROTOLO_POSIZIONATO=TAPPETO_TOP+TAPPETO_HEIGHT
	
	DO WHILE !EOF()

		_YCOORD_ULTIMO_ROTOLO_POSIZIONATO=_YCOORD_ULTIMO_ROTOLO_POSIZIONATO-ALTEZZA2PIXEL(ALTEZ)
		_ID_ROTOLO=ID_ROTOLO
		
		SELECT TAPPETO
		SET ORDER TO ID_ROTOLO
		SEEK _ID_ROTOLO
		REPLACE YCOORD0 WITH _YCOORD_ULTIMO_ROTOLO_POSIZIONATO
		
		_comando="oRotolo=_OFORM."+_ID_ROTOLO
		&_comando
		oRotolo.Top=YCOORD0
		
		SELECT SINGOLA_SEZIONE
		SKIP
	ENDDO

	
* FINE - PROCEDURE REFRESH_SINGOLA_SEZIONE
**********************************************************


**********************************************************
PROCEDURE LUNGEZZA2PIXEL
**********************************************************
	LPARAMETERS _LUNGHEZZA
	
	RETURN ROUND(_LUNGHEZZA*LUNGHEZZA_TAPPETO_SROTOLATO/LUNGHEZZA_BOBINA,0)

* FINE - PROCEDURE LUNGEZZA2PIXEL
**********************************************************

**********************************************************
PROCEDURE ALTEZZA2PIXEL
**********************************************************
	LPARAMETERS _ALTEZZA
	
	RETURN ROUND(_ALTEZZA*TAPPETO_HEIGHT/ALTEZZA_BOBINA,0)
	
* FINE - PROCEDURE ALTEZZA2PIXEL
**********************************************************


**********************************************************
* Classe Rotolo
**********************************************************
DEFINE CLASS Rotolo AS Shape
	
	ID_ROTOLO=""

	*****************************
	* Metodo PROCEDURE Init
	*****************************
	PROCEDURE Init
		
		WITH this
			.ID_ROTOLO=.NAME
		ENDWITH	
		
	RETURN
	*- FINE Metodo: Init
    ***************************	
    	
    
	*****************************
	* Metodo PROCEDURE RightClick
	*****************************
	PROCEDURE RightClick
	
	RETURN
	*- FINE Metodo: RightClick
    ***************************	
        
	*****************************
	* Metodo PROCEDURE DragDrop
	*****************************
	PROCEDURE DragDrop
	
		LPARAMETERS oSource, nXCoord, nYCoord
	
		LOCAL _ROTOLO_TOP,_ROTOLO_LEFT,_ROTOLO_RIGHT,;
				_SEZIONE_DI_DESTINAZIONE,_SEZIONE_DI_PARTENZA,;
				_ULTIMA_SEZIONE,_ULTIMO_TAGLIO,;
				_ESISTE_UNA_SEZIONE_DI_DESTINAZIONE_VALIDA
				
				
		_ALTEZZA_SEZIONE=0
		_ROTOLO_LEFT=0
		_ROTOLO_RIGHT=0
		_SEZIONE_DI_DESTINAZIONE=0
		_ESISTE_UNA_SEZIONE_DI_DESTINAZIONE_VALIDA=.F.
		
			
		IF !GESTIONE_CLICK_SU_ROTOLO(THIS)
			RETURN
		ENDIF
		
		*** Individuo la sezione di partenza
		*** cercando nel cursor TAPPETO
		*** il rotolo che sto considerando
		***		
		SELECT TAPPETO
		SET ORDER TO ID_ROTOLO
		SEEK oSource.ID_ROTOLO
		_ALTEZZA_ROTOLO=ALTEZ
		_LUNGHEZZA_ROTOLO=LUNGH
		_SEZIONE_DI_PARTENZA = SEZIONE
		_SEZIONE_DI_DESTINAZIONE=0
		_ESISTE_UNA_SEZIONE_DI_DESTINAZIONE_VALIDA=.F.
		_POSIZIONE_IN_METRI_DELLA_SEZIONE=0
		_X0_SEZIONE=0
		_X1_SEZIONE=0
		
		SELECT SEZIONI
		SET ORDER TO SEZIONE
		GO TOP

		DO WHILE !EOF()
		
			IF DELETED()
				SKIP
				LOOP
			ENDIF

			IF !FLGVIEW
				SKIP
				LOOP
			ENDIF

			IF SEZIONE<SEZIONE_TAGLIO_INIZIALE 
				SKIP
				LOOP
			ENDIF
			
			IF SEZIONE>SEZIONE_TAGLIO_FINALE
				EXIT
			ENDIF
			
			_RECNO=RECNO()
			_SEZIONE_ATTUALE=SEZIONE
			
			_POSIZIONE_INIZIALE_IN_METRI_DELLA_SEZIONE=SEZIONE2LUNGHEZZA(_SEZIONE_ATTUALE)
			_POSIZIONE_FINALE_IN_METRI_DELLA_SEZIONE=SEZIONE2LUNGHEZZA(_SEZIONE_ATTUALE)+LUNGH
			_X0_SEZIONE=LUNGEZZA2PIXEL(_POSIZIONE_INIZIALE_IN_METRI_DELLA_SEZIONE)
			_X1_SEZIONE=LUNGEZZA2PIXEL(_POSIZIONE_FINALE_IN_METRI_DELLA_SEZIONE)
			
			SELECT SEZIONI
			SET ORDER TO SEZIONE
			GO _RECNO
			
			IF !(nXCoord>=_X0_SEZIONE AND  nXCoord<=_X1_SEZIONE)
				SKIP
				LOOP
			ENDIF
			
			
			*** HO INDIVIDUATO LA SEZIONE IN CUI VOGLIO SPOSTARE
			*** PER PRIMA COSA VERIFICO SE E' UGUALE A QUELLA DI PARTENZA
			*** IN TAL CASO NON SPOSTO
			***
			IF SEZIONE=_SEZIONE_DI_PARTENZA
				RETURN
			ENDIF
			

			_ESISTE_UNA_SEZIONE_DI_DESTINAZIONE_VALIDA=.T.	
			EXIT		
			
		ENDDO

		*** Se non esiste una sezione di taglio valida 
		*** ne inauguro una nuova
		*** 
		IF 	!_ESISTE_UNA_SEZIONE_DI_DESTINAZIONE_VALIDA
		
			RETURN
						
		ENDIF

		*** CALCOLO L'ALTEZZA TOTALE CHE HA RAGGIUNTO LA SEZIONE
		*** 			
		_ALTEZZA_SEZIONE=ALTEZ
		_ROTOLO_LEFT =_X0_SEZIONE
		_ROTOLO_RIGHT=_X1_SEZIONE
		_SEZIONE_DI_DESTINAZIONE=SEZIONE
		_LUNGHEZZA_SEZIONE=LUNGH
		
		*** Se non non ci sta nella nuova sezione perchč sfora in altezza
		*** 
		IF 	_ALTEZZA_SEZIONE+_ALTEZZA_ROTOLO>ALTEZZA_BOBINA
			MESSAGEBOX("Non č possibile spostare il rotolo selezionato in questa sezione di taglio:"+;
				chr(13)+"la dimensione disponibile in altezza č inferiore all'altezza del rotolo",48,"Attenzione")
			RETURN
		ENDIF
		
		*** Se non ci sta nella nuova sezione PERCHE' di LUNGHEZZA DIVERSA
		*** 
		IF FLAG_LUNGHEZZE_DIVERSE=0
			IF 	_LUNGHEZZA_ROTOLO<>_LUNGHEZZA_SEZIONE
				MESSAGEBOX("Non č possibile spostare il rotolo selezionato in questa sezione di taglio:"+;
					chr(13)+"la dimensione disponibile in lunghezza č diversa dalla lunghezza del rotolo",48,"Attenzione")
				RETURN
			ENDIF
		ENDIF
		
		*** calcolo la posizione TOP dove finisce il rotolo spostato
		*** nella nuova sezione
		***
		_ROTOLO_TOP=ALTEZZA2PIXEL(_ALTEZZA_SEZIONE+_ALTEZZA_ROTOLO)

		WITH oSource
			.Top=ALTEZZA2TOP(.PARENT,_ROTOLO_TOP)
			.Left=LUNGHEZZA2LEFT(.PARENT,_ROTOLO_LEFT)
		ENDWITH	

		*** ORA CHE HO SPOSTATO CAMBIO LA POSIZIONE NEL TAPPETO
		***
		
		SELECT TAPPETO
		SET ORDER TO ID_ROTOLO
		SEEK oSource.ID_ROTOLO
		
		WITH oSource
			.Width=LUNGEZZA2PIXEL(LUNGH)
			.Height=ALTEZZA2PIXEL(ALTEZ)
		ENDWITH	
						
		REPLACE XCOORD0 WITH _ROTOLO_LEFT
		REPLACE XCOORD1 WITH _ROTOLO_RIGHT
		REPLACE SEZIONE WITH _SEZIONE_DI_DESTINAZIONE
		
		IF !CESTINO
			REFRESH_SINGOLA_SEZIONE(oSource.Parent,_SEZIONE_DI_PARTENZA)
		ELSE
			REPLACE CESTINO WITH .F.
			REFRESH_CESTINO(oSource.PARENT)
		ENDIF
		
		

	ENDPROC
	*- FINE Metodo: DragDrop
    ***************************


ENDDEFINE
*- FINE CLASSE Rotolo
**********************************************************


**********************************************************
PROCEDURE REFRESH_ROTOLI
**********************************************************
	LPARAMETERS _OFORM

	PUB_ROTOLO					=""
	PUB_NUMORD					=""
	PUB_CODCLI					=""
	PUB_RAGSOC                  =""
	
	WAIT WINDOW "REFRESH VISUALIZZAZIONE ROTOLI IN CORSO... ATTENDERE PREGO..." NOWAIT

	
	LOCAL _CONTATORE ,_POSIZIONE_Y,_POSIZIONE_X,_LUNGHEZZA_SEZIONE,_CODICE_SEZIONE,_SEZIONE_ATTUALE,;
			_FLAG_DISPOSTO_PRIMO_ROTOLO_SEZIONE_INIZIALE,_NUMERO_SEZIONI_RAGGRUPPATE,_ALTEZZA_BARRA

	REMOVE_OGGETTI_NON_ROTOLI(_OFORM)
	
	REMOVE_ROTOLI(_OFORM)

		
	SELECT TAPPETO
	SET ORDER TO SEZIONE
	GO TOP
	_CONTATORE =0
	_CODICE_SEZIONE =0
	
	_FLAG_DISPOSTO_PRIMO_ROTOLO_SEZIONE_INIZIALE=.F.
	
	DO WHILE !EOF()

		IF DELETED()
			SELECT TAPPETO
			SKIP
			LOOP
		ENDIF
		
		IF CESTINO
			SELECT TAPPETO
			SKIP
			LOOP
		ENDIF
		
		*** VERIFICO SE LA SEZIONE E' DA VISUALIZZARE
				
		_SEZIONE_ATTUALE=SEZIONE
		
		SELECT SEZIONI
		SET ORDER TO SEZIONE
		SEEK _SEZIONE_ATTUALE
		
		IF !FOUND()
			SELECT TAPPETO
			SKIP
			LOOP
		ENDIF
		
		IF !FLGVIEW
			SELECT TAPPETO
			SKIP
			LOOP
		ENDIF
		
		_NUMERO_SEZIONI_RAGGRUPPATE= NUMSEZRAGG
		_ALTEZZA_BARRA=ALTEZ
		
		SELECT TAPPETO
		
		*** DISEGNO I ROTOLI
	
		IF SEZIONE <SEZIONE_TAGLIO_INIZIALE 
			REPLACE ID_ROTOLO WITH ""
			SKIP 
			LOOP
		ENDIF
		
		IF SEZIONE >SEZIONE_TAGLIO_FINALE 
			REPLACE ID_ROTOLO WITH ""
			SKIP 
			LOOP
		ENDIF
		
		IF SEZIONE=SEZIONE_TAGLIO_INIZIALE AND !_FLAG_DISPOSTO_PRIMO_ROTOLO_SEZIONE_INIZIALE
			_CONTATORE 			=0
			_POSIZIONE_Y		=0		
			_POSIZIONE_X		=0
			_LUNGHEZZA_SEZIONE	=LUNGH
			_CODICE_SEZIONE		=SEZIONE
			_FLAG_DISPOSTO_PRIMO_ROTOLO_SEZIONE_INIZIALE=.T.
		ENDIF
		
		
		*** SE CAMBIO SEZIONE SEGNO IL TAGLIO DELLA BOBINA
		*** 
		IF SEZIONE!=_CODICE_SEZIONE
		
			*** AZZERO LA POSIZIONE Y 
			*** PER RIPARTIRE DAL PRIMO ROTOLO DELLA SEZIONE
			*** E 
			*** PER DISEGNARE RIGA DI TAGLIO E ANCORAGGIO	
			*** 
			_POSIZIONE_Y=0
	
			*** DISEGNO L'ANCORAGGIO DELLA SEZIONE CHE STO ELABORANDO
			***
			___SEEK_SEZIONE=SEZIONE
			SELECT SEZIONI
			SET ORDER TO SEZIONE
			SEEK ___SEEK_SEZIONE
			IF ALTEZ=0
				SKIP -1
			ENDIF
			___ALTEZZA_SEZIONE=ALTEZ
			
			SELECT TAPPETO
			_ETICHETTA_ANCORA = " H.Rimanente= "+ALLTRIM(STR(ALTEZZA_BOBINA-___ALTEZZA_SEZIONE))+" mm | L= "+ALLTRIM(STR(_LUNGHEZZA_SEZIONE))
			_OFORM.DisegnaAncora(ALTEZZA_BOBINA,_LUNGHEZZA_SEZIONE,_POSIZIONE_X,_POSIZIONE_Y,_ETICHETTA_ANCORA)
			
			*** AGGIORNO LA POSIZIONE X
			*** DA CUI PARTIRANNO I PROSSIMI ROTOLO
			*** E' LA POSIZIONE X DELLA NUOVA SEZIONE
			***
			_POSIZIONE_X=_POSIZIONE_X+_LUNGHEZZA_SEZIONE	
			_CODICE_SEZIONE=SEZIONE
			
			_OFORM.DisegnaRigaTaglio(_POSIZIONE_X)
			
			SELECT TAPPETO
			*** RE-IMPOSTO LA LUNGHEZZA DELLA SEZIONE PRIMA DEL PROSSIMO TAGLIO
			*** CON LA LUNGHEZZA DEL PRIMO ROTOLO DELLA SEZIONE
			_LUNGHEZZA_SEZIONE=LUNGH
			
			
			SELECT TAPPETO
			
		ENDIF
		
		_CONTATORE =_CONTATORE +1
		
		_ETICHETTA = " NR.BARRE= "+ALLTRIM(STR(_NUMERO_SEZIONI_RAGGRUPPATE))+" H.Barra= "+ALLTRIM(STR(_ALTEZZA_BARRA))+" mm | H= "+ALLTRIM(STR(ALTEZ))+" mm L= "+ALLTRIM(STR(LUNGH))+" ML - Ord.Nr. "+ALLTRIM(NUMORD)+" del "+ribalta2(DATORD)+" - "+ALLTRIM(ragsoc)
		_OFORM.DisegnaRotolo(NUMORD,_CONTATORE ,ALTEZ,LUNGH,_POSIZIONE_X,_POSIZIONE_Y,_ETICHETTA)
			
		_POSIZIONE_Y=_POSIZIONE_Y+ALTEZ 
	
		SKIP
	ENDDO
	
	*** AL TERMINE DELLA LETTURA DEL TAPPETO
	*** 1) DISEGNO L'ULTIMA RIGA DI TAGLIO
	*** 2) L'ANCORAGGIO SUCCESSIVO ALLA RIGA DI TAGLIO
	*** 3) L'ULTIMO ANCORAGGIO
	***
	_POSIZIONE_Y=0
	___SEEK_SEZIONE=SEZIONE
	SELECT SEZIONI
	SET ORDER TO SEZIONE
	SEEK ___SEEK_SEZIONE
	IF ALTEZ=0
		SKIP -1
	ENDIF
	
	___ALTEZZA_SEZIONE=ALTEZ
	
	SELECT TAPPETO
	_ETICHETTA_ANCORA = " H.Rimanente= "+ALLTRIM(STR(ALTEZZA_BOBINA-___ALTEZZA_SEZIONE))+" mm | L= "+ALLTRIM(STR(_LUNGHEZZA_SEZIONE))
	_OFORM.DisegnaAncora(ALTEZZA_BOBINA,_LUNGHEZZA_SEZIONE,_POSIZIONE_X,_POSIZIONE_Y,_ETICHETTA_ANCORA)
	
	_POSIZIONE_X=_POSIZIONE_X+_LUNGHEZZA_SEZIONE	
	_CODICE_SEZIONE=SEZIONE
	
	_OFORM.DisegnaRigaTaglio(_POSIZIONE_X)
	
	SELECT TAPPETO
			
	_LUNGHEZZA_SEZIONE=LUNGHEZZA_BOBINA - _POSIZIONE_X
	
	_CONTATORE =_CONTATORE +1
	
	___SEEK_SEZIONE=SEZIONE
	SELECT SEZIONI
	SET ORDER TO SEZIONE
	SEEK ___SEEK_SEZIONE
	IF ALTEZ=0
		SKIP -1
	ENDIF
	___ALTEZZA_SEZIONE=ALTEZ
	
	SELECT TAPPETO
	
	_ETICHETTA_ANCORA = " H.Rimanente= "+ALLTRIM(STR(ALTEZZA_BOBINA-___ALTEZZA_SEZIONE))+" mm | L= "+ALLTRIM(STR(_LUNGHEZZA_SEZIONE))
	_OFORM.DisegnaAncora(ALTEZZA_BOBINA,_LUNGHEZZA_SEZIONE,_POSIZIONE_X,_POSIZIONE_Y,_ETICHETTA_ANCORA)
	
	_OFORM.Tappeto.ZOrder(1)
	_OFORM.linea_copri_bobina_sinistra.ZOrder(1)
	_OFORM.BObina.ZOrder(1)
	_OFORM.TONDO_SOPRA.ZOrder(1)

	SELECT SEZIONI
	SET ORDER TO SEZIONE
	GO BOTT
	PUB_NR_BOBINE= BOBINA
	
			
	DISEGNA_CAMBI_BOBINA(_OFORM)
	
	_LUNGHEZZA_INIZIO_PRODUZIONE=SEZIONE2LUNGHEZZA(PUB_SEZIONE_INIZIO_PRODUZIONE)
	IF _LUNGHEZZA_INIZIO_PRODUZIONE>=0
		_OFORM.DisegnaAncoraInizioProduzione(_LUNGHEZZA_INIZIO_PRODUZIONE)
	ENDIF
	
	_LUNGHEZZA_FINE_PRODUZIONE=POSTSEZIONE2LUNGHEZZA(PUB_SEZIONE_FINE_PRODUZIONE)
	IF _LUNGHEZZA_FINE_PRODUZIONE>=0
		_OFORM.DisegnaAncoraFineProduzione(_LUNGHEZZA_FINE_PRODUZIONE)
	ENDIF

	REFRESH_CESTINO(_OFORM)

			
* FINE PROCEDURE REFRESH_ROTOLI
**********************************************************


**********************************************************
PROCEDURE DISEGNA_CAMBI_BOBINA
**********************************************************
	LPARAMETERS _OFORM
	
	LOCAL LUNGHEZZA,_SWWS
		
	_SWWS=SELECT()
	
	SELECT CAMBI_BOBINA
	SET ORDER TO SEZIONE
	GO TOP
	DO WHILE !EOF()
	
		_LUNGHEZZA=POSTSEZIONE2LUNGHEZZA(SEZFIN)
		IF _LUNGHEZZA>=0
			_OFORM.DisegnaCambioBobina(_LUNGHEZZA)
		ENDIF
		
		SELECT CAMBI_BOBINA
		SKIP
	ENDDO
	
	SELECT(_SWWS)	
	
* FINE PROCEDURE DISEGNA_CAMBI_BOBINA
**********************************************************



**********************************************************
PROCEDURE REFRESH_CESTINO
**********************************************************
	LPARAMETERS _OFORM
	
	WAIT WINDOW "REFRESH VISUALIZZAZIONE CESTINO IN CORSO... ATTENDERE PREGO..." NOWAIT

	LOCAL _CONTATORE 
	
	SELECT TAPPETO
	SET ORDER TO ALTEZ
	GO TOP
	
	_CONTATORE=0
	DO WHILE !EOF()

		IF DELETED()
			SELECT TAPPETO
			SKIP
			LOOP
		ENDIF
		
		IF !CESTINO
			SELECT TAPPETO
			SKIP
			LOOP
		ENDIF
		
		_CONTATORE=_CONTATORE+1
		
		_ETICHETTA = " H= "+ALLTRIM(STR(ALTEZ))+" mm L= "+ALLTRIM(STR(LUNGH))+" ML - Ord.Nr. "+ALLTRIM(NUMORD)+" del "+ribalta2(DATORD)+" - "+ALLTRIM(ragsoc)
		DisegnaRotoloInCestino(_OFORM,ID_ROTOLO,_CONTATORE ,_ETICHETTA)	
		
		SKIP
	ENDDO
	
	
	
* FINE PROCEDURE REFRESH_CESTINO
**********************************************************


**********************************************************
PROCEDURE DisegnaRotoloInCestino
**********************************************************
	LPARAMETERS _OFORM,_ID_ROTOLO,contatore,etichetta
	
	PRIVATE nome_rotolo,codice_colore,altezza_in_pixel,lunghezza_in_pixel,posizione_x,posizione_y,numero_ordine
	
	posizione_x0=_OFORM.CESTINO.Left
	posizione_y0=_OFORM.CESTINO.Top+_OFORM.CESTINO.Height

	altezza_in_pixel=30
	lunghezza_in_pixel=10
	
	posizione_x=posizione_x0+((contatore-1)-INT((contatore-1)/8)*8)*lunghezza_in_pixel
	posizione_y=posizione_y0-altezza_in_pixel-altezza_in_pixel*INT((contatore-1)/8)

	_comando="oRotolo=_OFORM."+ALLTRIM(_ID_ROTOLO)
	&_comando
	
	oRotolo.Move(posizione_x ,posizione_y ,  lunghezza_in_pixel , altezza_in_pixel)
	oRotolo.FillStyle=0

	_OFORM.Refresh()
* FINE PROCEDURE DisegnaRotoloInCestino
**********************************************************



**********************************************************
PROCEDURE PAGINAZIONE_INIZIALE_TAPPETO
**********************************************************
LOCAL _LUNGHEZZA_TOTALE_VISUALIZZATA,_SEZIONE_ATTUALE,MINUTI_INIZIALI,MINUTI_FINALI,_LUNGHEZZA_EFFETTIVA

SELECT SEZIONI
SET ORDER TO SEZIONE
GO BOTTOM
PUB_SEZIONE_FINE_PRODUZIONE=SEZIONE

SELECT SEZIONI
SET ORDER TO SEZIONE
GO TOP

_LUNGHEZZA_TOTALE_VISUALIZZATA=LUNGH

_LUNGHEZZA_EFFETTIVA=0

_SEZIONE_ATTUALE=SEZIONE
SEZIONE_TAGLIO_INIZIALE=1

DO WHILE !EOF()

	_LUNGHEZZA_EFFETTIVA=_LUNGHEZZA_EFFETTIVA+	LUNGH

	IF !FLGVIEW
		SKIP
		LOOP
	ENDIF
	
	IF _SEZIONE_ATTUALE!=SEZIONE
		
		IF _LUNGHEZZA_TOTALE_VISUALIZZATA+LUNGH>LUNGHEZZA_BOBINA
			_LUNGHEZZA_EFFETTIVA=_LUNGHEZZA_EFFETTIVA-	LUNGH
			EXIT
		ENDIF
		
		_SEZIONE_ATTUALE=SEZIONE
		_LUNGHEZZA_TOTALE_VISUALIZZATA=_LUNGHEZZA_TOTALE_VISUALIZZATA+LUNGH
	ENDIF

		
	SKIP
	
ENDDO


SEZIONE_TAGLIO_FINALE = _SEZIONE_ATTUALE

ML_INIZIO	=0
ML_FINE		=_LUNGHEZZA_EFFETTIVA


IF VELOCITA_SPALM=0
	MINUTI_INIZIALI=0
ELSE
	MINUTI_INIZIALI=ROUND(ML_INIZIO/VELOCITA_SPALM,0)
ENDIF


IF VELOCITA_SPALM=0
	MINUTI_FINALI=0
ELSE
	MINUTI_FINALI=ROUND(ML_FINE/VELOCITA_SPALM,0)
ENDIF

TIMESTAMP_INIZIO	=CALCOLA_DATA_ORA(MINUTI_INIZIALI)
TIMESTAMP_FINE		=CALCOLA_DATA_ORA(MINUTI_FINALI)

* FINE PROCEDURE PAGINAZIONE_INIZIALE_TAPPETO
**********************************************************

**********************************************************
PROCEDURE PAGINAZIONE_TAPPETO
**********************************************************
LOCAL _LUNGHEZZA_VISUALIZZATA,_SEZIONE_ATTUALE,_LUNGHEZZA_INIZIALE_VISUALIZZATA


SELECT SEZIONI
SET ORDER TO SEZIONE
SEEK SEZIONE_TAGLIO_INIZIALE

DO WHILE !EOF()
	
	IF !FLGVIEW
		SKIP
		LOOP
	ENDIF
	
	SEZIONE_TAGLIO_INIZIALE= SEZIONE
	
	EXIT 
ENDDO


SELECT SEZIONI
SET ORDER TO SEZIONE
GO TOP
_LUNGHEZZA_INIZIALE_VISUALIZZATA=0
_LUNGHEZZA_VISUALIZZATA=0
_SEZIONE_ATTUALE=0

DO WHILE !EOF()

	IF !FLGVIEW
		SKIP
		LOOP
	ENDIF
	
	IF SEZIONE <SEZIONE_TAGLIO_INIZIALE 
		_LUNGHEZZA_INIZIALE_VISUALIZZATA=_LUNGHEZZA_INIZIALE_VISUALIZZATA+LUNGH
		SKIP 
		LOOP
	ENDIF
	
	IF _SEZIONE_ATTUALE!=SEZIONE 
		IF _LUNGHEZZA_VISUALIZZATA+LUNGH>LUNGHEZZA_BOBINA
			EXIT	
		ENDIF
		_SEZIONE_ATTUALE=SEZIONE 
		_LUNGHEZZA_VISUALIZZATA=_LUNGHEZZA_VISUALIZZATA+LUNGH
		
	ENDIF
	
	SKIP
ENDDO


SEZIONE_TAGLIO_FINALE=_SEZIONE_ATTUALE

ML_INIZIO	=_LUNGHEZZA_INIZIALE_VISUALIZZATA
ML_FINE		=_LUNGHEZZA_VISUALIZZATA+_LUNGHEZZA_INIZIALE_VISUALIZZATA


IF VELOCITA_SPALM=0
	MINUTI_INIZIALI=0
ELSE
	MINUTI_INIZIALI=ROUND(ML_INIZIO/VELOCITA_SPALM,0)
ENDIF


IF VELOCITA_SPALM=0
	MINUTI_FINALI=0
ELSE
	MINUTI_FINALI=ROUND(ML_FINE/VELOCITA_SPALM,0)
ENDIF

TIMESTAMP_INIZIO	=CALCOLA_DATA_ORA(MINUTI_INIZIALI)
TIMESTAMP_FINE		=CALCOLA_DATA_ORA(MINUTI_FINALI)

* FINE PROCEDURE PAGINAZIONE_TAPPETO
**********************************************************


**********************************************************
PROCEDURE MINUTI_DA_ORARIO
**********************************************************
LPARAMETERS _ORARIO

RETURN VAL(SUBSTR(_ORARIO,4,2))

* FINE PROCEDURE MINUTI_DA_ORARIO
**********************************************************

**********************************************************
PROCEDURE ORE_DA_ORARIO
**********************************************************
LPARAMETERS _ORARIO

RETURN VAL(SUBSTR(_ORARIO,1,2))

* FINE PROCEDURE ORE_DA_ORARIO
**********************************************************


**********************************************************
PROCEDURE CALCOLA_DATA_ORA
**********************************************************
LPARAMETERS _MINUTI
LOCAL 		MINUTI_INIZIALI,MINUTI_FINALI

MINUTI_INIZIALI	=MINUTI_DA_ORARIO(ORA_INIZIO_SPALM)
ORE_INIZIALI	=ORE_DA_ORARIO(ORA_INIZIO_SPALM)
GIORNO_INIZIALE =VAL(SUBSTR(DATA_INIZIO_SPLAM,1,2))
MESE_INIZIALE 	=VAL(SUBSTR(DATA_INIZIO_SPLAM,4,2))
ANNO_INIZIALE 	=VAL(SUBSTR(DATA_INIZIO_SPLAM,7))

MINUTI_FINALI 	=MINUTI_INIZIALI
ORE_FINALI		=ORE_INIZIALI
GIORNO_FINALE 	=GIORNO_INIZIALE 
MESE_FINALE 	=MESE_INIZIALE 
ANNO_FINALE 	=ANNO_INIZIALE 

IF MINUTI_INIZIALI+_MINUTI<=59
	MINUTI_FINALI =MINUTI_INIZIALI+_MINUTI
ELSE
	ORE_FINALI=ORE_FINALI+1
	ORE_FINALI=ORE_FINALI+INT((_MINUTI-(60-MINUTI_INIZIALI))/60)
	_MINUTI=(_MINUTI-(60-MINUTI_INIZIALI))-INT((_MINUTI-(60-MINUTI_INIZIALI))/60)*60
	MINUTI_FINALI = _MINUTI

	IF 	ORE_FINALI>=24
		***GIORNO_FINALE=GIORNO_FINALE+1
		GIORNO_FINALE=GIORNO_FINALE+INT((ORE_FINALI -(24-ORE_FINALI))/24)
		ORE_FINALI=(ORE_FINALI-(24-ORE_FINALI))-INT((ORE_FINALI-(24-ORE_FINALI))/24)*24
		
		IF 	GIORNO_FINALE>=31
			***MESE_FINALE=MESE_FINALE+1
			MESE_FINALE=MESE_FINALE+INT((GIORNO_FINALE-(31-GIORNO_FINALE))/31)
			GIORNO_FINALE=(GIORNO_FINALE-(31-GIORNO_FINALE))-INT((GIORNO_FINALE-(31-GIORNO_FINALE))/31)*31
			
			IF 	MESE_FINALE>=12
				***ANNO_FINALE =ANNO_FINALE +1
				ANNO_FINALE =ANNO_FINALE +INT((MESE_FINALE-(12-MESE_FINALE))/12)
				MESE_FINALE=(MESE_FINALE-(12-MESE_FINALE))-INT((MESE_FINALE-(12-MESE_FINALE))/12)*12
			ENDIF
			
		ENDIF
		
	ENDIF
ENDIF

ORE_FINALI		="00"+ALLTRIM(STR(ORE_FINALI))
MINUTI_FINALI 	="00"+ALLTRIM(STR(MINUTI_FINALI))

GIORNO_FINALE	="00"+ALLTRIM(STR(GIORNO_FINALE))
MESE_FINALE 	="00"+ALLTRIM(STR(MESE_FINALE ))
ANNO_FINALE 	=ALLTRIM(STR(ANNO_FINALE ))

RETURN SUBSTR(GIORNO_FINALE,LEN(GIORNO_FINALE)-1)+"/"+SUBSTR(MESE_FINALE ,LEN(MESE_FINALE )-1)+"/"+ANNO_FINALE+" "+SUBSTR(ORE_FINALI,LEN(ORE_FINALI)-1)+":"+SUBSTR(MINUTI_FINALI ,LEN(MINUTI_FINALI )-1)

* FINE PROCEDURE CALCOLA_DATA_ORA
**********************************************************


**********************************************************
PROCEDURE VISUALIZZAZIONE_STANDARD
**********************************************************
SELECT SEZIONI
REPLACE FLGVIEW WITH .T. ALL
REPLACE FLGMULTI WITH .F. ALL
REPLACE NUMSEZRAGG WITH 1 ALL

* FINE PROCEDURE VISUALIZZAZIONE_STANDARD
**********************************************************

