**********************************************************
PROCEDURE CALCOLA_FASCIA
**********************************************************
	LPARAMETERS _ALTEZZA
	
	LOCAL _SWWS,_FASCIA
		
	_SWWS=SELECT()		
	
	cSql = "SELECT * FROM U_ART_PR WHERE  ART_CODCAT='BO' AND ART_GRUPRD='"+ALLTRIM(PUB_GRUPPO_PRODUTTIVO)+"' AND ART_ALTEZZ >="+ALLTRIM(STR(_ALTEZZA))+" ORDER BY ART_ALTEZZ"
	IF !ExecCommand(cSql,"FASCE")
		SELECT(_SWWS)
		return -1
	ENDIF
	SELECT FASCE
	GO TOP
	IF EOF()
		SELECT(_SWWS)
		RETURN -1
	ENDIF
	
    _FASCIA=ART_ALTEZZ
    
    SELECT(_SWWS)
    
    RETURN _FASCIA
    
* FINE - PROCEDURE CALCOLA_FASCIA
**********************************************************

**********************************************************
PROCEDURE CALCOLA_LUNGHEZZA_TAPPETO_FINO_ALLA_SEZIONE
**********************************************************
	LPARAMETERS _SEZIONE
	
	LOCAL _SWWS,_LUNGHEZZA
		
	_SWWS=SELECT()		
	
	_LUNGHEZZA=0
	
    SELECT SEZIONI
    SET ORDER TO SEZIONE
    GO TOP
    DO WHILE !EOF()
    
    	IF DELETED()
    		SKIP
    		LOOP
    	ENDIF

    	IF SEZIONE > _SEZIONE
    		EXIT
    	ENDIF
    	    
    	_LUNGHEZZA=_LUNGHEZZA+LUNGH
    	
    	SKIP
    ENDDO
    
    SELECT(_SWWS)
    
    RETURN _LUNGHEZZA
    
* FINE - PROCEDURE CALCOLA_LUNGHEZZA_TAPPETO_FINO_ALLA_SEZIONE
**********************************************************



**********************************************************
PROCEDURE DB2TAPPETO
**********************************************************
	LPARAMETERS _oform

	IF !EMPTY(PUB_PR1_NUMPIA)
		IF 6!=MESSAGEBOX("Vuoi ripristinare il PROGRAMMA DI PRODUZIONE "+ALLTRIM(PUB_PR1_NUMPIA)+" del "+RIBALTA2(PUB_PR1_DATPIA)+"?",4+32,"Ripristino piano di produzione")
			RETURN
		ENDIF
		
	ELSE
		RETURN
		
	ENDIF
		
	
	DO CREA_PROGPROD
	
	CREA_TAPPETO(_oform)

	DO RESTORETABLES
	
	_oform.srotola()	
		
	***DO ELABORA_TAPPETO WITH _oform
	
	IF FLAG_VISUALIZZAZIONE_RAGGRUPPATA=0
		DO VISUALIZZAZIONE_STANDARD
	ENDIF
	
	
	DO PAGINAZIONE_INIZIALE_TAPPETO
	
	REFRESH_ROTOLI(_oform)

	_oform.TASTO_ELABORA.Enabled= .T.	

* FINE PROCEDURE TAPPETO2DB
**********************************************************

**********************************************************
PROCEDURE RESTORETABLES
**********************************************************

	LOCAL cSql

	WAIT WINDOW "RIPRISTINO PROGRAMMA DI PRODUZIONE: caricamento dati " NOWAIT
		
	cSql = "select * from U_PRD_HY WHERE PJ_PRGPRD1='"+ALLTRIM(PUB_PJ_PRGPRD1)+"'"
	IF !ExecRW(cSql,"U_PRD_HY","R")
		return(.f.)
	ENDIF
		
	SELECT U_PRD_HY
	GO TOP
	DO WHILE !EOF()
	
		IF DELETED()
			SKIP
			LOOP
		ENDIF
		
		SCATTER MEMVAR MEMO
	
		SELECT &HY_TIPO
		WAIT WINDOW "RIPRISTINO PROGRAMMA DI PRODUZIONE: caricamento dati "+HY_TIPO NOWAIT
		APPEND BLANK
		GATHER MEMVAR MEMO
	
		SELECT U_PRD_HY
		SKIP
			
	ENDDO
	
* FINE PROCEDURE RESTORETABLE
**********************************************************



**********************************************************
PROCEDURE STAMPA_RIEPILOGO_ORDINI
**********************************************************

	IF EMPTY(PUB_PJ_PRGPRD1)
		MESSAGEBOX("Salvare/Creare un piano di produzione abbinato al tappeto corrente",48,"Attenzione!")
		RETURN
	ENDIF
	
	IF VELOCITA_SPALM=0
		MESSAGEBOX("Valorizzare la velocita' di spalmatura",48,"Attenzione!")
		RETURN
	ENDIF
	


	_SEZIONE_ATTUALE=0	
	SELECT TAPPETO
	SET ORDER TO SEZIONE
	GO TOP
	

	DO WHILE !EOF()
		
		IF DELETED()
			SKIP
			LOOP
		ENDIF

		IF _SEZIONE_ATTUALE<>SEZIONE
			
			_SEZIONE_ATTUALE=SEZIONE
					
			*** CALCOLO LUNGHEZZA PRODOTTA		
			SELECT SEZIONI
				
			_ALIAS=SYS(2015)
			SELECT SUM(LUNGH) AS LUNGH FROM SEZIONI WHERE SEZIONE<_SEZIONE_ATTUALE INTO CURSOR &_ALIAS
			SELECT &_ALIAS
			
			IF EOF()	
				_LUNGHEZZA_PRODOTTA=0
			ELSE
				_LUNGHEZZA_PRODOTTA=LUNGH
			ENDIF
			
			SELECT &_ALIAS
			USE
			
			SELECT TAPPETO

		ENDIF
			
		
		_MINUTI=ROUND(_LUNGHEZZA_PRODOTTA/VELOCITA_SPALM,0)
		
		_TIMESTAMP_PRODUZIONE	=CALCOLA_DATA_ORA(_MINUTI)
		_DATA_PREVISTA_PRODUZIONE=RIBALTA2(SUBSTR(_TIMESTAMP_PRODUZIONE,1,10))
		
		_DATA_EFFETTIVA_CONSEGNA=_DATA_PREVISTA_PRODUZIONE
		_GIORNI_DIFFERENZA=0
		
		REPLACE DTPRPR WITH _DATA_PREVISTA_PRODUZIONE
		REPLACE DTCEFF WITH _DATA_EFFETTIVA_CONSEGNA
		REPLACE GGDIFF WITH _GIORNI_DIFFERENZA
		
		SELECT TAPPETO
		SKIP
		
	ENDDO
	
	SELECT TAPPETO
	GO TOP
	
	cSql=""     
	cNomeCursorSql="CUR_ORDINI"
			
	TEXT TO cSql NOSHOW  	&& INIZIO SCRITTURA QUERY
	
		SELECT TT.TAGGANCIO,
			   TT.ORD_NUMORD,
			   TT.ORD_DATORD,
			   TT.ORD_CODCLI,
			   TT.ORD_RAGSOC,
			   TT.ORD_VALORE,
			   DD.ORD_NUMBOB AS ORD_QTAROT,
			   (SELECT SUM(ORD_QTAORD) FROM U_ORD_DD WHERE DAGGANCIO=TT.TAGGANCIO) AS ORD_QTAMQ,
			   (SELECT MIN(ORD_DATCON) FROM U_ORD_DD WHERE DAGGANCIO=TT.TAGGANCIO) AS ORD_DTCONS,
			   DD.ORD_DATCON AS DD_DTCONS,	
		       DD.ORD_CODART,
			   DD.ORD_ALTEZZ,
			   DD.ORD_LUNGHE,
               DD.ORD_UM,
               DD.ORD_IVA,
               CAST(SUBSTRING(IVA.LIBERA,1,3) AS INT) AS PERC_IVA,
               DD.ORD_DESART,
               DD.ORD_QTAORD,
		       COALESCE(LOC.LOC_GGEVAS,LOC.LOC_GGEVAS,'0') AS CLI_GGEVAS 
		FROM U_ORD_TT AS TT
		LEFT OUTER JOIN U_LOC_AN AS LOC
		ON LOC.LOC_CODCLI=TT.ORD_CODCLI AND LOC_CODLOC=TT.ORD_CODLOC  
		LEFT OUTER JOIN U_ORD_DD AS DD
		ON DD.DAGGANCIO=TT.TAGGANCIO AND DD.ORD_DESART!='*** COMMENTO ***'
        LEFT OUTER JOIN PARA AS IVA
        ON IVA.CODICE = 'IVA'+RTRIM(DD.ORD_IVA)
        WHERE RTRIM(ORD_NUMORD)+ORD_DATORD IN (SELECT RTRIM(PR5_NUMORD)+PR5_DATORD FROM U_PRD_D5 WHERE PJ_PRGPRD1='<<PUB_PJ_PRGPRD1>>') 
        ORDER BY TAGGANCIO
			
	ENDTEXT					&& FINE SCRITTURA QUERY
	
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
	
	
	CREATE CURSOR CUR_ANT_RIT (;
	    ORD_ANTRIT C(1),;
		ORD_NUMORD C(6),;
		ORD_DATORD C(10),;
		ORD_ANNO C(4),;
		ORD_MESE C(2),;
		ORD_DESMES C(20),;
		ORD_DTCONS C(10),;
		ORD_DTPRPR C(10),;
		ORD_DTCEFF C(10),;
		ORD_CODCLI C(10),;
		ORD_RAGSOC C(80),;
		ORD_GGDIFF N(5),;
		ORD_QTAROT N(5),;
		ORD_QTAMQ  N(17,3),;
		ORD_VALANT N(17,3),;
		ORD_ROTANT N(5),;
		ORD_QTAANT N(17,3),;
		ORD_VALRIT N(17,3),;
		ORD_ROTRIT N(5),;
		ORD_QTARIT N(17,3),;
		ORD_VALCLI N(17,3),;
		ORD_ROTCLI N(5),;
		ORD_QTACLI N(17,3),;
		ORD_VALORE N(17,3),;
        ORD_UM C(2),;
        ORD_IVA C(3),;
        PERC_IVA N(3),;
        ORD_CODART C(30),;
        ORD_DESART C(40),;
        ORD_QTAORD N(10,2),;
		CLI_GGEVAS N(5))	
		
    INDEX ON ORD_ANTRIT+ORD_DTCONS+ORD_RAGSOC+ORD_CODART TAG ORD_ANTRIT		
    INDEX ON ORD_MESE+ORD_ANTRIT+ORD_DTCONS+ORD_RAGSOC+ORD_CODART TAG ORD_MESE		
	
	SELECT CUR_ORDINI
	GO TOP
	
	_ORDINE_PRECEDENTE=""
	
	DO WHILE !EOF()
		
		SCATTER MEMVAR

* 		*** NUMERO ROTOLI
* 		SELECT COUNT(*) AS TOTALE FROM TAPPETO WHERE NUMORD=ALLTRIM(M.ORD_NUMORD) INTO CURSOR __NUMROTOLI
* 		SELECT __NUMROTOLI
* 		
* 		_QTAROT=0
* 		IF !EOF()
* 			_QTAROT=TOTALE
* 		ENDIF

* 		*** NUMERO ROTOLI
* 		SELECT SUM(LUNGH*ALTEZ/1000) AS TOTALE FROM TAPPETO WHERE NUMORD=ALLTRIM(M.ORD_NUMORD) INTO CURSOR __AREA
* 		SELECT __AREA
* 		
* 		_QTAMQ=0
* 		IF !EOF()
* 			_QTAMQ=TOTALE
* 		ENDIF
				
		SELECT MAX(DTCEFF) AS MAXDATA FROM TAPPETO WHERE NUMORD=ALLTRIM(M.ORD_NUMORD) INTO CURSOR __MAX_DTCEFF
		SELECT __MAX_DTCEFF
		
		_DTCEFF=M.ORD_DTCONS
		IF !EOF()
			_DTCEFF=MAXDATA
			_DTCEFF=RIBALTA2(DTOC(CTOD(RIBALTA2(_DTCEFF))+M.CLI_GGEVAS))
			
		ENDIF
				
		SELECT MAX(DTPRPR) AS MAXDATA FROM TAPPETO WHERE NUMORD=ALLTRIM(M.ORD_NUMORD) INTO CURSOR __MAX_DTPRPR
		SELECT __MAX_DTPRPR
		
		_DTPRPR=M.ORD_DTCONS
		IF !EOF()
			_DTPRPR=MAXDATA
		ENDIF
		
		SELECT CUR_ANT_RIT
		APPEND BLANK
		GATHER MEMVAR
		
		IF M.TAGGANCIO<>_ORDINE_PRECEDENTE
			_ORDINE_PRECEDENTE=M.TAGGANCIO
		ELSE
			REPLACE ORD_VALORE WITH 0
		ENDIF
		
		_MESE=SUBSTR(ORD_DTCONS,6,2)
		
		REPLACE ORD_MESE	WITH _MESE
		REPLACE ORD_DESMES	WITH GET_MESE(VAL(_MESE))
		REPLACE ORD_ANNO	WITH SUBSTR(ORD_DTCONS,1,4)
		***REPLACE ORD_QTAROT	WITH _QTAROT
		***REPLACE ORD_QTAMQ	WITH _QTAMQ
		
		
		REPLACE ORD_DTCEFF	WITH _DTCEFF
		REPLACE ORD_DTPRPR	WITH _DTPRPR
		
		IF ORD_DTCEFF>ORD_DTCONS
			REPLACE ORD_ANTRIT WITH "R"
		ELSE
			IF ORD_DTCEFF<ORD_DTCONS
				REPLACE ORD_ANTRIT 	WITH "A"
			ELSE
				REPLACE ORD_ANTRIT 	WITH ""
			ENDIF
		ENDIF
		
		REPLACE ORD_GGDIFF WITH CTOD(RIBALTA2(_DTCEFF))-CTOD(RIBALTA2(M.ORD_DTCONS))
		
		SELECT CUR_ORDINI
		SKIP
	
	ENDDO
    		

	SELECT CUR_ANT_RIT
	SET ORDER TO ORD_MESE
	GO TOP

    DO FORM FORM\PRD_STAMPA_ORDINI_ANT_RIT

* FINE - PROCEDURE STAMPA_RIEPILOGO_ORDINI
**********************************************************


**********************************************************
PROCEDURE GET_MESE
**********************************************************

LPARAMETERS _MESE_NUMERO

LOCAL _MESE_LETTERE

DO CASE 
		CASE _MESE_NUMERO =1
			_MESE_LETTERE="Gennaio"

		CASE _MESE_NUMERO =2
			_MESE_LETTERE="Febbraio"

		CASE _MESE_NUMERO =3
			_MESE_LETTERE="Marzo"
			
		CASE _MESE_NUMERO =4
			_MESE_LETTERE="Aprile"
			
		CASE _MESE_NUMERO =5
			_MESE_LETTERE="Maggio"
			
		CASE _MESE_NUMERO =6
			_MESE_LETTERE="Giugno"
			
		CASE _MESE_NUMERO =7
			_MESE_LETTERE="Luglio"
			
		CASE _MESE_NUMERO =8
			_MESE_LETTERE="Agosto"
			
		CASE _MESE_NUMERO =9
			_MESE_LETTERE="Settembre"
			
		CASE _MESE_NUMERO =10
			_MESE_LETTERE="Ottobre"
			
		CASE _MESE_NUMERO =11
			_MESE_LETTERE="Novembre"
			
		CASE _MESE_NUMERO =12
			_MESE_LETTERE="Dicembre"
			
		OTHERWISE			
			_MESE_LETTERE="...MESE NON VALIDO..."

ENDCASE

RETURN _MESE_LETTERE

* FINE - PROCEDURE GET_MESE
**********************************************************


**********************************************************
PROCEDURE STR_FILL_ZERO
**********************************************************
	LPARAMETERS _NUMERO_DA_RIEMPIRE,_NUMERO_DI_ZERI


	_STRINGA_DA_RIEMPIRE=REPLICATE("0",_NUMERO_DI_ZERI)+ALLTRIM(STR(_NUMERO_DA_RIEMPIRE)) 
	_STRINGA_DA_RIEMPIRE=SUBSTR(_STRINGA_DA_RIEMPIRE,LEN(_STRINGA_DA_RIEMPIRE)-_NUMERO_DI_ZERI+1)
	
	RETURN _STRINGA_DA_RIEMPIRE
		
* FINE - PROCEDURE FILLZERO
**********************************************************		
