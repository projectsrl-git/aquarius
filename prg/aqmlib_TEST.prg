		IF _Y_SCAR
			_OK_SCARICA_MAGAZZINO = .T.
		ENDIF
	
	ELSE

		MESSAGEBOX("Giacenza non disponibile",16,"Attenzione")
	
	ENDIF

ELSE 																		&& NON ESISTE GIACENZA O LA GIACENZA E' GIA' IMPEGNATA							

	MESSAGEBOX("Giacenza non disponibile",16,"Attenzione")

ENDIF

SELECT(_AQM_SEL)

RETURN _OK_SCARICA_MAGAZZINO


******************************************
PROCEDURE AQM_IMPEGNA_DISIMPEGNA_MAGAZZINO
******************************************

LPARAMETERS _par_segno,_par_unique,_par_quanti

IF PCOUNT() < 3
	MESSAGEBOX("Parametri insufficienti",16,"Attenzione")
	RETURN .F.
ENDIF

LOCAL _AQM_SS
_AQM_SS=SELECT()

x_sysm = "mag_unique = '" + _par_unique + "'"
x_cond = x_sysm
cSql   = "SELECT * FROM u_mag_gg WHERE " + x_cond 
IF !ExecRW(cSql,"U_MAG_GG","R")
   return(.f.)
ENDIF 
SELECT U_MAG_GG
GO TOP
IF !EOF()
	IF _par_segno = '+'
		REPLACE MAG_QTAIMP WITH MAG_QTAIMP + _par_quanti
	ELSE
		REPLACE MAG_QTAIMP WITH MAG_QTAIMP - _par_quanti
	ENDIF
	IF MAG_QTAIMP < 0
		REPLACE MAG_QTAIMP WITH 0
	ENDIF
	IF MAG_QTAIMP > MAG_GIACEN
		REPLACE MAG_QTAIMP WITH MAG_GIACEN
	ENDIF
ENDIF
IF !ExecRW(cSql,"U_MAG_GG","W")
   return(.f.)
ENDIF

SELECT(_AQM_SS)

RETURN


*****************************
FUNCTION AQM_CARICA_GIACENZA
*****************************

LOCAL _AQM_SEL
_AQM_SEL=SELECT()

_OK_CARICA_GIACENZA = .F.

=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

LOCAL_LEGAME 			= SYS(2015)  && NUOVO VALORE PER IL CAMPO DI LEGAME TRA U_MAG_GG E U_MAG_MO
AQM_LEGAME 				= LOCAL_LEGAME
ORIGINALE_AQM_LEGAME 	= LOCAL_LEGAME
LOCAL_DATAOGGI 			= RIBALTA2(DTOC(DATE()))
ORIGINALE_AQM_CODFOR 	= AQM_CODFOR
ORIGINALE_AQM_DESFOR 	= AQM_DESFOR
ORIGINALE_AQM_PREACQ 	= AQM_PREACQ
ORIGINALE_AQM_SC1 		= AQM_SC1
ORIGINALE_AQM_SC2 		= AQM_SC2
ORIGINALE_AQM_SC3 		= AQM_SC3
ORIGINALE_AQM_SC4 		= 0
ORIGINALE_AQM_SC5 		= 0
ORIGINALE_AQM_GIACEN 	= AQM_GIACEN
ORIGINALE_AQM_QTAKG 	= AQM_QTAKG
ORIGINALE_AQM_QTAMQ 	= AQM_QTAMQ
ORIGINALE_AQM_QTAML 	= AQM_QTAML
ORIGINALE_AQM_QTAMC 	= AQM_QTAMC   
ORIGINALE_AQM_NUMIDE 	= AQM_NUMIDE
ORIGINALE_AQM_PREACQ 	= AQM_PREACQ

=ACCESSO_PARAMETRO_TOP()
=ACCESSO_ANAGRAFICA_FORNITORE()
=ACCESSO_ANAGRAFICA_CLIENTE()
=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)

=AQM_CREA_U_MAG_MO("CREA-MOVIMENTO")

x_cond = "MAG_UNIQUE = '" + AQM_UNIQUE + "'"
Csql = "select * from u_mag_gg where " + x_cond
IF !ExecRW(Csql,"u_mag_gg","R")
	return(.f.)
ENDIF
SELECT U_MAG_GG
GO TOP
IF EOF()
	=AQM_CREA()
ELSE
	=AQM_SOMMA()
ENDIF
IF !ExecRW(cSql,"U_MAG_GG","W")
	return(.f.)
ENDIF

SELECT(_AQM_SEL)

_OK_CARICA_GIACENZA = .T.

RETURN _OK_CARICA_GIACENZA

**************************************************************************************
FUNCTION AQM_SCARICA_DALLA_GIACENZA_PIU_VECCHIA
**************************************************************************************
*!*	
*!*	LA FUNZIONE VIENE UTILIZZATA DALLE PROCEDURE CHE GESTISCONO LA CHIUSURA DELLE
*!*	GIACENZE NEGATIVE 
*!*	
*!*	LA SEGUENTE FUNZIONE EFFETTUA LO SCARICO DELLA GIACENZA DI MAGAZZINO PARTENDO
*!*	DAL PRODOTTO CARICATO PIU' VECCHIO SENZA CREARE NESSUN MOVIMENTO DI SCARICO 
*!*	
*!*	

LPARAMETERS __CODICE_MAGAZZINO__,__CODICE_ARTICOLO__,__GIACENZA__,_SCARICA_IMPEGNATO__,__ALTEZZ__,__LUNGHE__,_PAR_DTREGI

**=> ERASMO - INIZIO 08/01/2014
IF PCOUNT() >= 8
ELSE
	_PAR_DTREGI = DTOC(DATE())
ENDIF
**=> ERASMO - FINE 08/01/2014

=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()

_OK_SCARICA_MAGAZZINO = .F.

_ww_codsoc = PUB_CODSOC 
_ww_anaart = ALLTRIM(__CODICE_ARTICOLO__)
_ww_codmag = ALLTRIM(__CODICE_MAGAZZINO__)
_ww_prenot = .T.  && PARAMETRO PER SCARICARE SOLO GIACENZE NON PRENOTATE
_ww_codint = ""
_ww_altezz = __ALTEZZ__ 
_ww_lunghe = __LUNGHE__ 
_ww_fila_x = ""
_ww_pian_x = ""
_ww_ubic_x = ""
_par_scarica_impegnato = _SCARICA_IMPEGNATO__

_giac_disp = AQM_RILEVA_GIACENZE_DISPONIBILI(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x)



=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

*** DEFINIZIONE VARIABILI LOCALI DI GESTIONE 
LOCAL_AQM_GIACEN = __GIACENZA__
LOCAL_AQM_QTAKG  = 0
LOCAL_AQM_QTAMQ  = 0
LOCAL_AQM_QTAML  = 0
LOCAL_AQM_QTAMC  = 0



SELECT LOCAL_U_MAG_GG
GO TOP  


DO WHILE .NOT. EOF()

    SELECT LOCAL_U_MAG_GG


    ___ID_UNIQUE  = ID_UNIQUE 
    
    IF LOCAL_AQM_GIACEN > 0						&& luppa sino a che non ha TOLTO TUTTA LA QTA MOVIMENTATA di record di u_mag_gg
    ELSE 
      EXIT
    ENDIF    
    
    
	_e_cond = "id_unique = '" + ___ID_UNIQUE + "'"	
	Csql    = "select * from u_mag_gg where " + _e_cond + " order by mag_codart"
	IF !ExecRW(Csql,"u_mag_gg","R")
		   return(.f.)
	ENDIF

    SELECT U_MAG_GG
    IF !EOF()
 
        _X_ANAART__ = MAG_ANAART
  
 		_X_UNIMIS 	= PUB_UM
		_X_UMMAGA 	= PUB_UM
		_X_IVA		= PUB_IVA
 		_X_DESART 	= ''
 
 		ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODMAT = ''
		ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESMAT = ''
		ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_TIPART = ''

		  
		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "ART_CODPRI = '" + _X_ANAART__ + "'"
		x_cond = x_soci + " and " + x_codi
		cSql = "SELECT ART_CODPRI,ART_DESCR,ART_UNIMIS,ART_UMMAGA,ART_TIPART,ART_CODCOL,ART_ALTEZZ,ART_LUNGHE,ART_CODIVA,ART_PRZCOS,ART_PRZVEN,ART_UNIMIS,ART_UMMAGA,ART_COORD,ART_CODMAT,ART_DESMAT,ART_CODIMB,ART_DESIMB,ART_CODF1  FROM U_ART_PR WHERE " + x_cond
		IF !ExecCommand(cSql,"CjX_ART_PR")
		   return(.f.)
		ENDIF
		SELECT CjX_ART_PR
		GO TOP
		IF !EOF()
			_X_DESART  = ALLTRIM(ART_DESCR)
			_X_UNIMIS  = ART_UNIMIS
			_X_UMMAGA  = ART_UMMAGA
			_X_CODCOL  = ART_CODCOL
			_X_ALTEZZ  = ART_ALTEZZ
			_X_LUNGHE  = ART_LUNGHE
		    _X_IVA	   = ART_CODIVA
		    AQM_DESART = ART_DESCR
		    ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_TIPART = ART_TIPART
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_PREACQ = ART_PRZCOS 
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_PREVEN = ART_PRZVEN
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_UNIMIS = ART_UNIMIS
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_UNMAGA = ART_UMMAGA 
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_COORD  = ART_COORD 
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODMAT = ART_CODMAT
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESMAT = ART_DESMAT
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODIMB = ART_CODIMB
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESIMB = ART_DESIMB
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODFOR = ART_CODF1
			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESFOR = ""
		ENDIF
 
        SELECT U_MAG_GG
        
        AQM_UM     =  _X_UNIMIS 
        AQM_SEGNO  = '+'
        AQM_TOP    = PUB_CAUGNE 		&& CARICO CON CHIUSURA GIACENZA NEGATIVA

		v_seek   = 'TOP'+AQM_TOP
		v_chiave = "codice"
		IF seek_std('para',v_seek,v_chiave,'LOCAL_PARA')
			 SELECT LOCAL_PARA
			 LOCAL_NAT    = SUBSTR(LIBERA,1,1)   	&& (NATURA C=CARICO - S=SCARICO - D=DARE - A=AVERE)
			 LOCAL_LIB    = SUBSTR(LIBERA,12,1)  	&& (C=CLIENTE - F=FORNITORE - +/-=COMP.D.B. - A=ALTRO)
			 LOCAL_TMOV   = SUBSTR(LIBERA,33,2)				
			 LOCAL_TOPCAR = SUBSTR(LIBERA,35,3)  	&& CAUSALE CONTRARIA A QUELLA DIGITATA
		ELSE
			 LOCAL_NAT    = 'S'					 	&& (NATURA C=CARICO - S=SCARICO - D=DARE - A=AVERE)
			 LOCAL_LIB    = ''                   	&& (C=CLIENTE - F=FORNITORE - +/-=COMP.D.B. - A=ALTRO)
			 LOCAL_TMOV   = '-'				
			 LOCAL_TOPCAR = 'M--'				 	&& CAUSALE CONTRARIA A QUELLA DIGITATA
		ENDIF
        SELECT U_MAG_GG
        
		AQM_TIPMOV = LOCAL_TMOV
		  
	  
 		AQM_NUMMOV_LOCALE  = AQM_RILEVA_NUMERO_INTERNO()
   
	    AQM_NUMDOC  = "Gn"							&& NUMERO DOCUMENTO
	    AQM_DTDOCU  = RIBALTA2(DTOC(DATE()))		&& DATA DOCUMENTO
	    *AQM_DTREGI  = RIBALTA2(DTOC(DATE()))		&& DATA REGISTRAZIONE
	    AQM_DTREGI  = RIBALTA2(_PAR_DTREGI)			&& ERASMO - 08/01/2014
        AQM_IVAVEN  = _X_IVA

	

		IF _par_scarica_impegnato
			___DISPONIBILE 	= MAG_GIACEN
		ELSE
			___DISPONIBILE 	= MAG_GIACEN - MAG_QTAIMP
		ENDIF
        
        AQM_ANAART = MAG_ANAART
		AQM_CDAFOR = MAG_CDAFOR
		AQM_OINFOR = MAG_OINFOR
		AQM_PINFOR = MAG_PINFOR
		AQM_DTPFOR = MAG_DTPFOR
		AQM_TRAFOR = MAG_TRAFOR
		AQM_NBAFOR = MAG_NBAFOR
		AQM_BDAFOR = MAG_BDAFOR
		AQM_BALFOR = MAG_BALFOR
		AQM_PNKFOR = MAG_PNKFOR
        
        AQM_QTRES_MOVI = 0						&& QUANTITA' RESIDUA DEL MOVIMENTO
    
	    IF ___DISPONIBILE >= LOCAL_AQM_GIACEN  	 
	    
	      REPLACE MAG_GIACEN WITH MAG_GIACEN - LOCAL_AQM_GIACEN 
	      AQM_QTRES_MOVI = MAG_GIACEN
	      
	      IF _par_scarica_impegnato
	      	REPLACE MAG_QTAIMP WITH MAG_QTAIMP - LOCAL_AQM_GIACEN 
	      	IF MAG_QTAIMP < 0
	      		REPLACE MAG_QTAIMP WITH 0
	      	ENDIF
	      ENDIF
	      
			*** RESETTO E VALORIZZO LE QTA NELLE VARIE UNITA' DI MISURA SULLA RIGA DI GIACENZA
			REPLACE MAG_QTAMQ WITH 0
			REPLACE MAG_QTAML WITH 0
			REPLACE MAG_QTAKG WITH 0
			REPLACE MAG_QTAMC WITH 0   
			REPLACE MAG_QTANR WITH 0   
						
			_X_UMMAGA = AQM_TROVA_UMMAGA(__CODICE_ARTICOLO__)
			DO CASE
				CASE ALLTRIM(_X_UMMAGA) == "KG"
					REPLACE MAG_QTAKG WITH MAG_GIACEN
				CASE ALLTRIM(_X_UMMAGA) == "MQ"
					REPLACE MAG_QTAMQ WITH MAG_GIACEN
				CASE ALLTRIM(_X_UMMAGA) == "ML"
					REPLACE MAG_QTAML WITH MAG_GIACEN
				CASE ALLTRIM(_X_UMMAGA) == "MC"
					REPLACE MAG_QTAMC WITH MAG_GIACEN
				CASE ALLTRIM(_X_UMMAGA) == "NR"
					REPLACE MAG_QTANR WITH MAG_GIACEN
				
			ENDCASE
			
			X_TIPO = CERCATIPO(MAG_ANAART)
			IF X_TIPO = '1'  && BOBINE
				IF MAG_QTAMQ <= 0
					REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_LUNGHE,1)
				ENDIF
				IF MAG_QTAML <= 0
					REPLACE MAG_QTAML WITH TROVA_ML_DA_LU(MAG_LUNGHE,1)
				ENDIF
				IF MAG_QTAKG <= 0
					REPLACE MAG_QTAKG WITH TROVA_KG_DA_MQ(MAG_ANAART,MAG_SPESSO,MAG_QTAMQ,1)
				ENDIF
			ENDIF
			
			IF X_TIPO = '3'  && MANICOTTI
				IF ALLTRIM(_X_UMMAGA) == "NR"
					REPLACE MAG_QTAML WITH MAG_GIACEN * MAG_ALTEZZ / 1000
				ENDIF
			ENDIF
			
			IF X_TIPO = '6'  && PANNELLI TRUCIOLARI
				X_QTANR = 0
				DO CASE
					CASE ALLTRIM(_X_UMMAGA) == "MQ"
						X_QTANR = TROVA_NR_DA_MQ_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN)
					CASE ALLTRIM(_X_UMMAGA) == "MC"
						X_QTANR = TROVA_NR_DA_MC_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN,MAG_SPESSO)
				ENDCASE
				REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,X_QTANR)
				REPLACE MAG_QTAML WITH TROVA_ML_DA_LU(MAG_LUNGHE,X_QTANR)
				REPLACE MAG_QTAKG WITH 0
				REPLACE MAG_QTAMC WITH TROVA_MC_DA_AL_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,X_QTANR,MAG_SPESSO) 
			ENDIF
		

			IF X_TIPO = '8'  
				IF ALLTRIM(_X_UMMAGA) == "NR"
					REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN)
				ENDIF
			ENDIF

					
	      *!*	_________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 
	      
    
	      ORIGINALE_AQM_GIACEN   = LOCAL_AQM_GIACEN 
	      ORIGINALE_AQM_QTAKG    = LOCAL_AQM_QTAKG  
	      ORIGINALE_AQM_QTAMQ    = LOCAL_AQM_QTAMQ
	      ORIGINALE_AQM_QTAML    = LOCAL_AQM_QTAML 
	      ORIGINALE_AQM_QTAMC    = LOCAL_AQM_QTAMC 
				
	      *!*	_________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 
	      
	      LOCAL_AQM_GIACEN = 0
		  LOCAL_AQM_QTAKG  = 0
		  LOCAL_AQM_QTAMQ  = 0
		  LOCAL_AQM_QTAML  = 0
		  LOCAL_AQM_QTAMC  = 0  
		  
	    ELSE
		  
	      *!*	_________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 
	      ORIGINALE_AQM_GIACEN   = MAG_GIACEN
	      ORIGINALE_AQM_QTAKG    = MAG_QTAKG
	      ORIGINALE_AQM_QTAMQ    = MAG_QTAMQ
	      ORIGINALE_AQM_QTAML    = MAG_QTAML
	      ORIGINALE_AQM_QTAMC    = MAG_QTAMC  
	      *!*	_________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 
		  
	      *LOCAL_AQM_GIACEN = LOCAL_AQM_GIACEN - MAG_GIACEN
	      LOCAL_AQM_GIACEN = LOCAL_AQM_GIACEN - ___DISPONIBILE 
		  LOCAL_AQM_QTAKG  = LOCAL_AQM_QTAKG  - MAG_QTAKG
		  LOCAL_AQM_QTAMQ  = LOCAL_AQM_QTAMQ  - MAG_QTAMQ
		  LOCAL_AQM_QTAML  = LOCAL_AQM_QTAML  - MAG_QTAML
		  LOCAL_AQM_QTAMC  = LOCAL_AQM_QTAMC  - MAG_QTAMC  
		  
	      REPLACE MAG_GIACEN WITH 0
	      REPLACE MAG_QTAIMP WITH 0  
	      REPLACE MAG_QTAKG  WITH 0
	      REPLACE MAG_QTAMQ  WITH 0
	      REPLACE MAG_QTAML  WITH 0
	      REPLACE MAG_QTAMC  WITH 0  
	    ENDIF


        SELECT U_MAG_GG

		*!*	___________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 

	    ORIGINALE_AQM_PREACQ = MAG_PRZCON	&& PREZZO                              DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 					
	    ORIGINALE_AQM_SC1    = MAG_SC1   	&& SCONTO-1                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 					
	    ORIGINALE_AQM_SC2    = MAG_SC2   	&& SCONTO-2                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
	    ORIGINALE_AQM_SC3    = MAG_SC3   	&& SCONTO-3                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
	    ORIGINALE_AQM_SC4    = MAG_SC4   	&& SCONTO-4                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
	    ORIGINALE_AQM_SC5    = MAG_SC5   	&& SCONTO-5                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
        ORIGINALE_AQM_CODFOR = MAG_FORNIT   && CODICE FORNITORE                    DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
		ORIGINALE_AQM_DESFOR = MAG_DESFOR   && RAGIONE SOCIALE FORNITORE           DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO
	    ORIGINALE_AQM_NUMIDE = MAG_NUMIDE   && NUMERO IDENTIFICATIVO ORIGINALE     DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
        ORIGINALE_AQM_LEGAME = SYS(2015)	&& NUOVO LEGAME RELATIVO AL MOVIMENTO DI CARICO
        AQM_LEGSYS			 = SYS(2015)	&& NUOVO SYS RELATIVO AL MOVIMENTO DI CARICO        
        AQM_LEGAME_ORIGINALE_U_MAG_GG = MAG_LEGAME   && SYS DI LEGAME CHE LEGA U_MAG_GG E LE SEQUENZE DEI MOVIMENTI LEGATE A U_MAG_MO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO
 
		*!*	_________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 



		IF MAG_GIACEN > 0									&& NON SONO GESTITE GIACENZE NEGATIVE
		ELSE
		   REPLACE MAG_GIACEN WITH 0
		   REPLACE MAG_QTAMQ  WITH 0
		   REPLACE MAG_QTAKG  WITH 0
		   REPLACE MAG_QTAML  WITH 0
		   REPLACE MAG_QTAMC  WITH 0  
		   REPLACE MAG_QTAIMP WITH 0
		   REPLACE MAG_GKGIMP WITH 0
		   REPLACE MAG_GMLIMP WITH 0
		ENDIF

		IF EMPTY(ALLTRIM(PUB_MAGNO0))
		ELSE
		   IF MAG_GIACEN = 0								&& CANCELLA IL RECORD SU U_MAG_GG SE E' = 0 ED E' PREVISTO NEI PARAMETRI AZIENDALI 
		      IF ALLTRIM(MAG_CODMAG) $ PUB_MAGNO0
		      ELSE
		         DELETE
		      ENDIF
		   ENDIF
		ENDIF
		
		*** MOLTI DEI DATI DA SCRIVERE SUL MOVIMENTO DA CREARE DEVONO PROVENIRE 
		*** DALLA GIACENZA CHE STO SCARICANDO, QUINDI REINIZIALIZZO ALCUNE VARIABILI
		AQM_DATAGG = MAG_DATAGG
		AQM_CODART = MAG_CODART
		AQM_CODMAG = MAG_CODMAG
		AQM_FILA_N = MAG_FILA_N
		AQM_PIAN_N = MAG_PIAN_N
		AQM_UBIC_N = MAG_UBIC_N
		AQM_FILA_X = MAG_FILA_X
		AQM_PIAN_X = MAG_PIAN_X
		AQM_UBIC_X = MAG_UBIC_X
		AQM_NRLINT = MAG_NRLINT
		AQM_ALTEZZ = MAG_ALTEZZ
		AQM_LUNGHE = MAG_LUNGHE
		AQM_SPESSO = MAG_SPESSO
		AQM_PREACQ = MAG_PRZCON
		AQM_AAPROD = MAG_AAPROD
		AQM_SERBOL = MAG_SERBOL
		AQM_SERNUM = MAG_SERNUM
		AQM_NUMEDA = MAG_NUMEDA
		AQM_NUMEAL = MAG_NUMEAL
		AQM_CBFISC = MAG_CBFISC
		AQM_ORACAR = MAG_ORACAR
        
		AQM_UNIQUE = MAG_UNIQUE  

        *!*	____________________________________________________________________________________________________________________ AGGIORNA U_MAG_GG
		IF !ExecRW(cSql,"U_MAG_GG","W")						 
		   return(.f.)
		ENDIF


*ssx

 
*!*	        *!*	____________________________________________________________________________________________________________________ AGGIORNA U_MAG_MO M++
*!*			LOCAL_MOVIMENTO = "CREA-MOVIMENTO"		&& QUESTO MOVIMENTO TRACCIA IL RICARICO DI MAGAZZINO DELLA GIACENZA NEGATIVA
*!*			=AQM_CREA_U_MAG_MO(LOCAL_MOVIMENTO)
 
*!*			** CONTROAGGIORNA IL MOVIMENTO DI MAGAZZINO IN BASE ALLA GIACENZA VERA SCARICATA
*!*			x_lega1 = "MOV_LEGAME = '" + ALLTRIM(AQM_LEGAME_ORIGINALE_U_MAG_GG) + "'"
*!*			x_gian1 = "MOV_GIANEG = 1"
*!*			x_cond  = x_lega1 + " AND " + x_gian1 
*!*			cSql   = "SELECT * FROM U_MAG_MO where " + x_cond
*!*			IF !ExecRW(Csql,"U_MAG_MO","R")
*!*				   return(.f.)
*!*			ENDIF
*!*	 		SELECT U_MAG_MO
*!*	 		GO TOP
*!*	 		IF !EOF()
*!*	 			REPLACE MOV_GIANEG WITH .F.
*!*				*REPLACE MOV_DTREGI WITH AQM_DATAGG
*!*				REPLACE MOV_CODART WITH AQM_CODART
*!*				REPLACE MOV_CODMAG WITH AQM_CODMAG
*!*				REPLACE MOV_FILA_N WITH AQM_FILA_N
*!*				REPLACE MOV_PIAN_N WITH AQM_PIAN_N
*!*				REPLACE MOV_UBIC_N WITH AQM_UBIC_N
*!*				REPLACE MOV_FILA_X WITH AQM_FILA_X
*!*				REPLACE MOV_PIAN_X WITH AQM_PIAN_X
*!*				REPLACE MOV_UBIC_X WITH AQM_UBIC_X
*!*				REPLACE MOV_NRLINT WITH AQM_NRLINT
*!*				REPLACE MOV_ALTEZZ WITH AQM_ALTEZZ
*!*				REPLACE MOV_LUNGHE WITH AQM_LUNGHE
*!*				REPLACE MOV_SPESSO WITH AQM_SPESSO
*!*				REPLACE MOV_PREACQ WITH AQM_PREACQ
*!*				REPLACE MOV_AAPROD WITH AQM_AAPROD
*!*				REPLACE MOV_SERBOL WITH AQM_SERBOL
*!*				REPLACE MOV_SERNUM WITH AQM_SERNUM
*!*				REPLACE MOV_NUMEDA WITH AQM_NUMEDA
*!*				REPLACE MOV_NUMEAL WITH AQM_NUMEAL
*!*				REPLACE MOV_CBFISC WITH AQM_CBFISC
*!*				*REPLACE MOV_ORAMOV WITH AQM_ORACAR
*!*	 		ENDIF
*!*	 		IF !ExecRW(cSql,"U_MAG_MO","W")						 
*!*			   return(.f.)
*!*			ENDIF

 
 
 
      
*!*	        AQM_UM     =  _X_UNIMIS 
*!*	        AQM_SEGNO  = '-'
*!*	        AQM_TOP    = 'M--'

*!*			v_seek   = 'TOP'+AQM_TOP
*!*			v_chiave = "codice"
*!*			IF seek_std('para',v_seek,v_chiave,'LOCAL_PARA')
*!*				 SELECT LOCAL_PARA
*!*				 LOCAL_NAT    = SUBSTR(LIBERA,1,1)   && (NATURA C=CARICO - S=SCARICO - D=DARE - A=AVERE)
*!*				 LOCAL_LIB    = SUBSTR(LIBERA,12,1)  && (C=CLIENTE - F=FORNITORE - +/-=COMP.D.B. - A=ALTRO)
*!*				 LOCAL_TMOV   = SUBSTR(LIBERA,33,2)				
*!*				 LOCAL_TOPCAR = SUBSTR(LIBERA,35,3)  && CAUSALE CONTRARIA A QUELLA DIGITATA
*!*			ELSE
*!*				 LOCAL_NAT    = 'S'					 && (NATURA C=CARICO - S=SCARICO - D=DARE - A=AVERE)
*!*				 LOCAL_LIB    = ''                   && (C=CLIENTE - F=FORNITORE - +/-=COMP.D.B. - A=ALTRO)
*!*				 LOCAL_TMOV   = '-'				
*!*				 LOCAL_TOPCAR = 'M++'				 && CAUSALE CONTRARIA A QUELLA DIGITATA
*!*			ENDIF

*!*	        *!*	____________________________________________________________________________________________________________________ AGGIORNA U_MAG_MO M--
*!*			LOCAL_MOVIMENTO = "CREA-MOVIMENTO"		&& QUESTO MOVIMENTO TRACCIA LO SCARICO DELLA QTA RELATIVA ALLA GIACENZA NEGATIVA DAL PRIMO U_MAG_GGI POSITIVO DISPONIBILE
*!*			=AQM_CREA_U_MAG_MO(LOCAL_MOVIMENTO)



	ENDIF    
   

	SELECT LOCAL_U_MAG_GG
	SKIP +1

ENDDO WHILE .NOT. EOF()



RETURN	




**************************************************************************************
FUNCTION AQM_CARICA_GIACENZE_NEGATIVE
**************************************************************************************
*!*	
*!*	LA FUNZIONE VIENE UTILIZZATA DALLE PROCEDURE CHE GESTISCONO LA CHIUSURA DELLE
*!*	GIACENZE NEGATIVE 
*!*	
*!*	LA SEGUENTE FUNZIONE CREA IL MOVIMENTO DI CARICO DI MAGAZZINO
*!*	PER LA GIACENZA NEGATIVA RILEVATA TRASFORMANDOLA IN POSITIVO
*!*	E AZZERA LA GIACENZA NEGATIVA PER POI ANNULLARLA
*!*	
*!*	


LPARAMETERS __DATADAL__,__DATAAL__,__CODICE_MAGAZZINO__,__CODICE_ARTICOLO__,__GIACENZA__,_SCARICA_IMPEGNATO__,__ALTEZZ__,__LUNGHE__,_PAR_DTREGI

**=> ERASMO - INIZIO 08/01/2014
IF PCOUNT() >= 8
ELSE
	_PAR_DTREGI = DTOC(DATE())
ENDIF
**=> ERASMO - FINE 08/01/2014

=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()

_OK_SCARICA_MAGAZZINO = .F.
_par_scarica_impegnato = _SCARICA_IMPEGNATO__

*=AQM_CERCA_DETTAGLI_GIACENZE_NEGATIVE(__CODICE_ARTICOLO__,__DATADAL__,__DATAAL__)
=AQM_CERCA_DETTAGLI_GIACENZE_NEGATIVE(__CODICE_ARTICOLO__,__DATADAL__,__DATAAL__,__CODICE_MAGAZZINO__)  && ERASMO - 14/03/2014

=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

*** DEFINIZIONE VARIABILI LOCALI DI GESTIONE 
LOCAL_AQM_GIACEN = __GIACENZA__
IF LOCAL_AQM_GIACEN < 0
	LOCAL_AQM_GIACEN = LOCAL_AQM_GIACEN * -1	&& RENDE LA GIACENZA POSITIVA
ENDIF 
LOCAL_AQM_QTAKG  = 0
LOCAL_AQM_QTAMQ  = 0
LOCAL_AQM_QTAML  = 0
LOCAL_AQM_QTAMC  = 0


SELECT Gn_U_MAG_GG_DETTAGLI
GO TOP  


DO WHILE .NOT. EOF()

    SELECT Gn_U_MAG_GG_DETTAGLI


    ___ID_UNIQUE  = ID_UNIQUE 
    
    
	_e_cond = "id_unique = '" + ___ID_UNIQUE + "'"	
	Csql    = "select * from u_mag_gg where " + _e_cond + " order by mag_codart"
	IF !ExecRW(Csql,"u_mag_gg","R")
		   return(.f.)
	ENDIF

    SELECT U_MAG_GG
    IF !EOF()
    
		SCATTER MEMVAR memo 
		
		=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
				
				
		IF _par_scarica_impegnato
			___DISPONIBILE 	= MAG_GIACEN		
		ELSE
			___DISPONIBILE 	= MAG_GIACEN - MAG_QTAIMP
		ENDIF
        
        IF ___DISPONIBILE < 0
        	___DISPONIBILE = ___DISPONIBILE * -1		&& LA RENDE POSITIVA ESSENDO UNA GIACENZA NEGATIVA
        ENDIF
        

          _X_ANAART__ = MAG_ANAART
  
 		  _X_UNIMIS = PUB_UM
		  _X_UMMAGA = PUB_UM
		  _X_IVA	= PUB_IVA
 		  _X_DESART = ''
 
 
 
		  ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODMAT = ''
		  ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESMAT = ''
		  ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_TIPART = ''

		  
		  x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		  x_codi = "ART_CODPRI = '" + _X_ANAART__ + "'"
		  x_cond = x_soci + " and " + x_codi
		  cSql = "SELECT ART_CODPRI,ART_DESCR,ART_UNIMIS,ART_UMMAGA,ART_TIPART,ART_CODCOL,ART_ALTEZZ,ART_LUNGHE,ART_CODIVA,ART_PRZCOS,ART_PRZVEN,ART_UNIMIS,ART_UMMAGA,ART_COORD,ART_CODMAT,ART_DESMAT,ART_CODIMB,ART_DESIMB,ART_CODF1  FROM U_ART_PR WHERE " + x_cond
		  IF !ExecCommand(cSql,"CjX_ART_PR")
			 return(.f.)
		  ENDIF
		  SELECT CjX_ART_PR
		  GO TOP
		  IF !EOF()
				_X_DESART = ALLTRIM(ART_DESCR)
				_X_UNIMIS = ART_UNIMIS
				_X_UMMAGA = ART_UMMAGA
				_X_CODCOL = ART_CODCOL
				_X_ALTEZZ = ART_ALTEZZ
				_X_LUNGHE = ART_LUNGHE
		        _X_IVA	  = ART_CODIVA
		        AQM_DESART = ART_DESCR
		        ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_TIPART = ART_TIPART
			   	ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_PREACQ = ART_PRZCOS 
			   	ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_PREVEN = ART_PRZVEN
				ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_UNIMIS = ART_UNIMIS
				ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_UNMAGA = ART_UMMAGA 
				ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_COORD  = ART_COORD 
				ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODMAT = ART_CODMAT
				ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESMAT = ART_DESMAT
				ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODIMB = ART_CODIMB
				ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESIMB = ART_DESIMB
				ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODFOR = ART_CODF1
				ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESFOR = ""
		  ENDIF

          SELECT U_MAG_GG

          AQM_TOP    = PUB_CAUGNE				 && RICARICA LA GIACENZA NEGATIVA


		  v_seek   = 'TOP'+AQM_TOP
		  v_chiave = "codice"
		  IF seek_std('para',v_seek,v_chiave,'LOCAL_PARA')
			 SELECT LOCAL_PARA
			 LOCAL_NAT    = SUBSTR(LIBERA,1,1)   && (NATURA C=CARICO - S=SCARICO - D=DARE - A=AVERE)
			 LOCAL_LIB    = SUBSTR(LIBERA,12,1)  && (C=CLIENTE - F=FORNITORE - +/-=COMP.D.B. - A=ALTRO)
			 LOCAL_TMOV   = SUBSTR(LIBERA,33,2)				
			 LOCAL_TOPCAR = SUBSTR(LIBERA,35,3)  && CAUSALE CONTRARIA A QUELLA DIGITATA
		  ELSE
			 LOCAL_NAT    = 'C'					 && (NATURA C=CARICO - S=SCARICO - D=DARE - A=AVERE)
			 LOCAL_LIB    = ''                   && (C=CLIENTE - F=FORNITORE - +/-=COMP.D.B. - A=ALTRO)
			 LOCAL_TMOV   = '-'				
			 LOCAL_TOPCAR = 'R--'				 && CAUSALE CONTRARIA A QUELLA DIGITATA
		  ENDIF

          
		  AQM_TIPMOV = LOCAL_TMOV


	  
          SELECT U_MAG_GG
        
          AQM_UM     =  _X_UNIMIS 
          AQM_SEGNO  = '+'
          AQM_ANAART = MAG_ANAART
          AQM_DESART = _X_DESART 
		  AQM_CDAFOR = MAG_CDAFOR
		  AQM_OINFOR = MAG_OINFOR
		  AQM_PINFOR = MAG_PINFOR
		  AQM_DTPFOR = MAG_DTPFOR
		  AQM_TRAFOR = MAG_TRAFOR
		  AQM_NBAFOR = MAG_NBAFOR
		  AQM_BDAFOR = MAG_BDAFOR
		  AQM_BALFOR = MAG_BALFOR
		  AQM_PNKFOR = MAG_PNKFOR
		  
 		  AQM_NUMMOV_LOCALE  = AQM_RILEVA_NUMERO_INTERNO()
   
		  AQM_NUMDOC  = "Gn"						&& NUMERO DOCUMENTO
		  AQM_DTDOCU  = RIBALTA2(DTOC(DATE()))		&& DATA DOCUMENTO
		  *AQM_DTREGI  = RIBALTA2(DTOC(DATE()))		&& DATA REGISTRAZIONE
		  *AQM_DTREGI  = RIBALTA2(_PAR_DTREGI)		&& ERASMO - 08/01/2014
		  **=> ERASMO - INIZIO 07/03/2014
		  IF EMPTY(_PAR_DTREGI)
			  AQM_DTREGI  = RIBALTA2(DTOC(DATE()))
		  ELSE
			  AQM_DTREGI  = RIBALTA2(_PAR_DTREGI)
		  ENDIF
		  **=> ERASMO - FINE 07/03/2014
	      AQM_IVAVEN  = _X_IVA
	    
	      REPLACE MAG_GIACEN WITH 0 				&& LA GIACENZA VIENE AZZERATA PER POI ESSERE CANCELLATA
	      
	      IF _par_scarica_impegnato
	      	REPLACE MAG_QTAIMP WITH MAG_QTAIMP - ___DISPONIBILE 
	      	IF MAG_QTAIMP < 0
	      		REPLACE MAG_QTAIMP WITH 0
	      	ENDIF
	      ENDIF
	      
			*** RESETTO E VALORIZZO LE QTA NELLE VARIE UNITA' DI MISURA SULLA RIGA DI GIACENZA
			REPLACE MAG_QTAMQ WITH 0
			REPLACE MAG_QTAML WITH 0
			REPLACE MAG_QTAKG WITH 0
			REPLACE MAG_QTAMC WITH 0   
			REPLACE MAG_QTANR WITH 0   
						
			_X_UMMAGA = AQM_TROVA_UMMAGA(__CODICE_ARTICOLO__)
			DO CASE
				CASE ALLTRIM(_X_UMMAGA) == "KG"
					REPLACE MAG_QTAKG WITH ___DISPONIBILE 
				CASE ALLTRIM(_X_UMMAGA) == "MQ"
					REPLACE MAG_QTAMQ WITH ___DISPONIBILE 
				CASE ALLTRIM(_X_UMMAGA) == "ML"
					REPLACE MAG_QTAML WITH ___DISPONIBILE 
				CASE ALLTRIM(_X_UMMAGA) == "MC"
					REPLACE MAG_QTAMC WITH ___DISPONIBILE 
				CASE ALLTRIM(_X_UMMAGA) == "NR"
					REPLACE MAG_QTANR WITH ___DISPONIBILE 
				
			ENDCASE
			
			X_TIPO = CERCATIPO(MAG_ANAART)
			IF X_TIPO = '1'  && BOBINE
				IF MAG_QTAMQ <= 0
					REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_LUNGHE,1)
				ENDIF
				IF MAG_QTAML <= 0
					REPLACE MAG_QTAML WITH TROVA_ML_DA_LU(MAG_LUNGHE,1)
				ENDIF
				IF MAG_QTAKG <= 0
					REPLACE MAG_QTAKG WITH TROVA_KG_DA_MQ(MAG_ANAART,MAG_SPESSO,MAG_QTAMQ,1)
				ENDIF
			ENDIF
			
			IF X_TIPO = '3'  && MANICOTTI
				IF ALLTRIM(_X_UMMAGA) == "NR"
					REPLACE MAG_QTAML WITH ___DISPONIBILE * MAG_ALTEZZ / 1000
				ENDIF
			ENDIF
			
			IF X_TIPO = '6'  && PANNELLI TRUCIOLARI
				X_QTANR = 0
				DO CASE
					CASE ALLTRIM(_X_UMMAGA) == "MQ"
						X_QTANR = TROVA_NR_DA_MQ_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,___DISPONIBILE)
					CASE ALLTRIM(_X_UMMAGA) == "MC"
						X_QTANR = TROVA_NR_DA_MC_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,___DISPONIBILE,MAG_SPESSO)
				ENDCASE
				REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,X_QTANR)
				REPLACE MAG_QTAML WITH TROVA_ML_DA_LU(MAG_LUNGHE,X_QTANR)
				REPLACE MAG_QTAKG WITH 0
				REPLACE MAG_QTAMC WITH TROVA_MC_DA_AL_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,X_QTANR,MAG_SPESSO) 
			ENDIF
		

			IF X_TIPO = '8'  
				IF ALLTRIM(_X_UMMAGA) == "NR"
					REPLACE MAG_QTAMQ WITH TROVA_MQ_DA_AL(MAG_ALTEZZ,MAG_LUNGHE,___DISPONIBILE)
				ENDIF
			ENDIF

					
	        *!*	_________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 
	      

	        ORIGINALE_AQM_GIACEN   = ___DISPONIBILE
	        ORIGINALE_AQM_QTAKG    = MAG_QTAKG 
	        ORIGINALE_AQM_QTAMQ    = MAG_QTAMQ 
	        ORIGINALE_AQM_QTAML    = MAG_QTAML 
	        ORIGINALE_AQM_QTAMC    = MAG_QTAMC
				
	        *!*	_________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 
	      
	        LOCAL_AQM_GIACEN = 0
		    LOCAL_AQM_QTAKG  = 0
		    LOCAL_AQM_QTAMQ  = 0
		    LOCAL_AQM_QTAML  = 0
		    LOCAL_AQM_QTAMC  = 0  

            SELECT U_MAG_GG

			*!*	___________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 

		    ORIGINALE_AQM_PREACQ = MAG_PRZCON	&& PREZZO                              DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 					
		    ORIGINALE_AQM_SC1    = MAG_SC1   	&& SCONTO-1                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 					
		    ORIGINALE_AQM_SC2    = MAG_SC2   	&& SCONTO-2                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
		    ORIGINALE_AQM_SC3    = MAG_SC3   	&& SCONTO-3                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
		    ORIGINALE_AQM_SC4    = MAG_SC4   	&& SCONTO-4                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
		    ORIGINALE_AQM_SC5    = MAG_SC5   	&& SCONTO-5                            DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
	        ORIGINALE_AQM_CODFOR = MAG_FORNIT   && CODICE FORNITORE                    DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
			ORIGINALE_AQM_DESFOR = MAG_DESFOR   && RAGIONE SOCIALE FORNITORE           DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO
		    ORIGINALE_AQM_NUMIDE = MAG_NUMIDE   && NUMERO IDENTIFICATIVO ORIGINALE     DI ACQUISTO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO 
	        ORIGINALE_AQM_LEGAME = MAG_LEGAME   && SYS DI LEGAME CHE LEGA U_MAG_GG E LE SEQUENZE DEI MOVIMENTI LEGATE A U_MAG_MO ORIGINALE DEL MOVIMENTO DI CARICO PIU' VECCHIO
	 
			*!*	_________________________________________________________________________________________________SALVATAGGIO VARIABILI ORIGINALI AL MOMENTO DEL CARICO 



			REPLACE MAG_GIACEN WITH 0				&& AZZERA LE GIACENZE PER CANCELLARE IL RECORD SUBITO DOPO SE PREVISTO DA PARAMETRO PUB_MAGNO0
			REPLACE MAG_QTAMQ  WITH 0
			REPLACE MAG_QTAKG  WITH 0
			REPLACE MAG_QTAML  WITH 0
			REPLACE MAG_QTAMC  WITH 0  
			REPLACE MAG_QTAIMP WITH 0
			REPLACE MAG_GKGIMP WITH 0
			REPLACE MAG_GMLIMP WITH 0


			IF EMPTY(ALLTRIM(PUB_MAGNO0))
			ELSE
			   IF MAG_GIACEN = 0								&& CANCELLA IL RECORD SU U_MAG_GG SE E' = 0 ED E' PREVISTO NEI PARAMETRI AZIENDALI 
			      IF ALLTRIM(MAG_CODMAG) $ PUB_MAGNO0
			      ELSE
			         DELETE
			      ENDIF
			   ENDIF
			ENDIF
		

			*** MOLTI DEI DATI DA SCRIVERE SUL MOVIMENTO DA CREARE DEVONO PROVENIRE 
			*** DALLA GIACENZA CHE STO SCARICANDO, QUINDI REINIZIALIZZO ALCUNE VARIABILI
			AQM_DATAGG = MAG_DATAGG
			AQM_CODART = MAG_CODART
			AQM_CODMAG = MAG_CODMAG
			AQM_FILA_N = MAG_FILA_N
			AQM_PIAN_N = MAG_PIAN_N
			AQM_UBIC_N = MAG_UBIC_N
			AQM_FILA_X = MAG_FILA_X
			AQM_PIAN_X = MAG_PIAN_X
			AQM_UBIC_X = MAG_UBIC_X
			AQM_NRLINT = MAG_NRLINT
			AQM_ALTEZZ = MAG_ALTEZZ
			AQM_LUNGHE = MAG_LUNGHE
			AQM_SPESSO = MAG_SPESSO
			AQM_PREACQ = MAG_PRZCON
			AQM_AAPROD = MAG_AAPROD
			AQM_SERBOL = MAG_SERBOL
			AQM_SERNUM = MAG_SERNUM
			AQM_NUMEDA = MAG_NUMEDA
			AQM_NUMEAL = MAG_NUMEAL
			AQM_CBFISC = MAG_CBFISC
			AQM_ORACAR = MAG_ORACAR

	        
			AQM_UNIQUE = MAG_UNIQUE   

	        *!*	____________________________________________________________________________________________________________________ AGGIORNA U_MAG_GG
			IF !ExecRW(cSql,"U_MAG_GG","W")						 
			   return(.f.)
			ENDIF

	        *!*	____________________________________________________________________________________________________________________ AGGIORNA U_MAG_MO
			LOCAL_MOVIMENTO = "CREA-MOVIMENTO"
			=AQM_CREA_U_MAG_MO(LOCAL_MOVIMENTO)


	ENDIF    
   

	SELECT Gn_U_MAG_GG_DETTAGLI
	SKIP +1

ENDDO WHILE .NOT. EOF()




RETURN	



***************************************************
FUNCTION AQM_CERCA_DETTAGLI_GIACENZE_NEGATIVE
***************************************************
*PARAMETERS _ANAART____,_V_DATADA____,_V_DATAAL____
PARAMETERS _ANAART____,_V_DATADA____,_V_DATAAL____,_CODMAG____  && ERASMO - 14/03/2014


IF USED("Gn_U_MAG_GG_DETTAGLI")
	SELECT Gn_U_MAG_GG_DETTAGLI
	USE
ENDIF

*!*	cSql=""     
*!*	cNomeCursorSql="Gn_U_MAG_GG_DETTAGLI"
			
*!*	TEXT TO cSql NOSHOW

*!*		SELECT 
*!*			ID_UNIQUE, 
*!*			'999' AS MAG_CODMAG, 
*!*			MAG_ANAART, 
*!*			MAG_DESART, 
*!*			'' AS MAG_FORNIT, 
*!*			'' AS MAG_CODCOL, 
*!*			0 AS MAG_ALTEZZ, 
*!*			0 AS MAG_LUNGHE, 
*!*			MAG_GIACEN
*!*		FROM U_MAG_GG 
*!*		WHERE MAG_DATAGG BETWEEN '<<RIBALTA2(_V_DATADA____)>>' AND '<<RIBALTA2(_V_DATAAL____)>>'
*!*				AND MAG_DATAGG <> '' AND MAG_GIACEN < 0 AND
*!*				MAG_ANAART <> '.' AND MAG_ANAART = '<<_ANAART____>>'
*!*		ORDER BY MAG_ANAART,MAG_DATAGG,MAG_ORACAR
*!*		
*!*	ENDTEXT

**=> ERASMO - INIZIO 14/03/2014
IF PCOUNT() >= 4
ELSE
	_CODMAG____ = ""
ENDIF

cSql=""     
cNomeCursorSql="Gn_U_MAG_GG_DETTAGLI"
cCond = "MAG_DATAGG BETWEEN '" + RIBALTA2(_V_DATADA____) + "' AND '" + RIBALTA2(_V_DATAAL____) + "' AND MAG_DATAGG <> '' AND MAG_GIACEN < 0 AND MAG_ANAART <> '.' AND MAG_ANAART = '" + _ANAART____ + "'"
IF !EMPTY(_CODMAG____)
	cCond = cCond + " AND MAG_CODMAG = '" + _CODMAG____ + "'"
ENDIF

TEXT TO cSql NOSHOW

	SELECT 
		ID_UNIQUE, 
		MAG_CODMAG, 
		MAG_ANAART, 
		MAG_DESART, 
		'' AS MAG_FORNIT, 
		'' AS MAG_CODCOL, 
		0 AS MAG_ALTEZZ, 
		0 AS MAG_LUNGHE, 
		MAG_GIACEN
	FROM U_MAG_GG 
	WHERE <<cCond>>
	ORDER BY MAG_CODMAG,MAG_ANAART,MAG_DATAGG,MAG_ORACAR
	
ENDTEXT
**=> ERASMO - FINE 14/03/2014

IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF		





RETURN


**************************************************************************************
FUNCTION AQM_ANNULLA_GIACENZE_NEGATIVE
**************************************************************************************

LPARAMETERS __DATADAL__,__DATAAL__,__CODICE_ARTICOLO__,_PAR_DTREGI

**=> ERASMO - INIZIO 08/01/2014
IF PCOUNT() >= 4
ELSE
	_PAR_DTREGI = DTOC(DATE())
ENDIF
**=> ERASMO - FINE 08/01/2014

=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()

=AQM_CERCA_DETTAGLI_GIACENZE_NEGATIVE(__CODICE_ARTICOLO__,__DATADAL__,__DATAAL__)

=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

*** DEFINIZIONE VARIABILI LOCALI DI GESTIONE 
LOCAL_AQM_GIACEN = __GIACENZA__

SELECT Gn_U_MAG_GG_DETTAGLI
GO TOP  


DO WHILE .NOT. EOF()

    SELECT Gn_U_MAG_GG_DETTAGLI


    ___ID_UNIQUE  = ID_UNIQUE 
    
    
	_e_cond = "id_unique = '" + ___ID_UNIQUE + "'"	
	Csql    = "select * from u_mag_gg where " + _e_cond + " order by mag_codart"
	IF !ExecRW(Csql,"u_mag_gg","R")
		   return(.f.)
	ENDIF

    SELECT U_MAG_GG
    IF !EOF()
    
		SCATTER MEMVAR memo 
		
		=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
				
				
		IF _par_scarica_impegnato
			___DISPONIBILE 	= MAG_GIACEN		
		ELSE
			___DISPONIBILE 	= MAG_GIACEN - MAG_QTAIMP
		ENDIF
        
        IF ___DISPONIBILE < 0
        	___DISPONIBILE = ___DISPONIBILE * -1		&& LA RENDE POSITIVA ESSENDO UNA GIACENZA NEGATIVA
        ENDIF
        

          _X_ANAART__ = MAG_ANAART
  
 		  _X_UNIMIS = PUB_UM
		  _X_UMMAGA = PUB_UM
		  _X_IVA	= PUB_IVA
 		  _X_DESART = ''
 
 
 
		  ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODMAT = ''
		  ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESMAT = ''
		  ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_TIPART = ''

		  
		  x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		  x_codi = "ART_CODPRI = '" + _X_ANAART__ + "'"
		  x_cond = x_soci + " and " + x_codi
		  cSql = "SELECT ART_CODPRI,ART_DESCR,ART_UNIMIS,ART_UMMAGA,ART_TIPART,ART_CODCOL,ART_ALTEZZ,ART_LUNGHE,ART_CODIVA,ART_PRZCOS,ART_PRZVEN,ART_UNIMIS,ART_UMMAGA,ART_COORD,ART_CODMAT,ART_DESMAT,ART_CODIMB,ART_DESIMB,ART_CODF1  FROM U_ART_PR WHERE " + x_cond
		  IF !ExecCommand(cSql,"CjX_ART_PR")
			 return(.f.)
		  ENDIF
		  SELECT CjX_ART_PR
		  GO TOP
		  IF !EOF()
				_X_DESART = ALLTRIM(ART_DESCR)
