	IF !ExecCommand(cSql,"LOCAL_U_MAG_MO")
		return(.f.)
	ENDIF
		
	*IF PUB_GIANEG															
	*	SELECT LOCAL_U_MAG_MO												
	*	GO TOP       														
	*	DO WHILE .NOT. EOF()												
	*		=AQM_CANCELLA_GIACENZA_NEGATIVA_IN_MODIFICA_DDT(MOV_LEGAME)		
	*		SELECT LOCAL_U_MAG_MO											
	*		SKIP +1															
	*	ENDDO 																
	*ENDIF																	
	
	SELECT LOCAL_U_MAG_MO
	GO TOP
	DO WHILE !EOF()
		
		SELECT LOCAL_U_MAG_MO

		AQM_QTAMOV_MOVIMENTATA = MOV_QTAMOV
		AQM_QTAMQ_MOVIMENTATA = MOV_QTAMQ
		AQM_QTAKG_MOVIMENTATA = MOV_QTAKG
		AQM_QTAML_MOVIMENTATA = MOV_QTAML
		AQM_QTAMC_MOVIMENTATA = MOV_QTAMC

		SELECT LOCAL_U_MAG_MO
		SCATTER MEMVAR MEMO
		M.ID_UNIQUE = ""
		*LOCAL_LEGAME = M.MOV_LEGAME														&& SYS DI AGGANCIO A U_MAG_GG		

		=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_MOVIMENTO_MAGAZZINO")
	    AQM_SAVE_LEGSYS 		= ""
	    LOCAL_IDUNIQUE			= ""
	 	LOCAL_DATAOGGI   		= RIBALTA2(DTOC(DATE()))
	 	
		AQM_TOP = IIF(EMPTY(PUB_CAUDEP),PUB_MPIU,ALLTRIM(PUB_CAUDEP))  && Causale di carico magazzino agente / deposito DA PARAMETRI AZIENDALI
		AQM_CODMAG = ALLTRIM(_par_magd)
		*AQM_LEGAME = SYS(2015)  && ERASMO - 01/12/2014 *** IL CAMPO MOV_LEGAME SERVE TRASPORTARLO IDENTICO ANCHE SUL MAG. DESTINAZIONE, PER CONTINUARE A IDENTIFICARE, TRAMITE I VARI LEGAMI, IL RECORD DI TRACCIABILITA' (CON MOV_TRCKNG NON VUOTO)
		LOCAL_LEGAME = AQM_LEGAME
		AQM_DATAGG = AQM_DTREGI
		AQM_SEGNO = "+"
		AQM_UNIQUE = SYS(2015)
	 
		ORIGINALE_AQM_GIACEN 	= AQM_GIACEN
		ORIGINALE_AQM_QTAKG  	= AQM_QTAKG
		ORIGINALE_AQM_QTAMQ  	= AQM_QTAMQ
		ORIGINALE_AQM_QTAML  	= AQM_QTAML
		ORIGINALE_AQM_QTAMC  	= AQM_QTAMC

		ORIGINALE_AQM_LEGAME	= AQM_LEGAME
		ORIGINALE_AQM_NUMIDE 	= AQM_NUMIDE
	    ORIGINALE_AQM_PREACQ    = AQM_PREACQ


		=ACCESSO_PARAMETRO_TOP()
		=ACCESSO_ANAGRAFICA_FORNITORE()
		=ACCESSO_ANAGRAFICA_CLIENTE()
		=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)
		
	    LOCAL_MOVIMENTO = "CREA-MOVIMENTO"							
		=AQM_CREA_U_MAG_MO(LOCAL_MOVIMENTO,.F.)


	 	*_e_cond = "mag_legame = '" + LOCAL_LEGAME + "'"
	 	_e_cond = "mag_legame = '" + LOCAL_LEGAME + "' and mag_codmag = '" + AQM_CODMAG + "'"  && ERASMO - 30/12/2014 *** SICCOME IL MAG_LEGAME VIENE TRASPORTATO, FILTRO ANCHE PER MAGAZZINO, ALTRIMENTI POTREI TROVARE LO STESSO RECORD DI ORIGINE GIACENZA
		Csql    = "select * from u_mag_gg where " + _e_cond + " order by mag_codart"
		IF !ExecRW(Csql,"u_mag_gg","R")
			   return(.f.)
		ENDIF

	    SELECT U_MAG_GG
	    IF !EOF()

			_FUNZIONE = "AGGIORNA-U-MAG-GG"								&& AGGIORNA U_MAG_GG SOMMANDO LE QUANTITA' CHE DEVO RICARICARE
			
	    	AQM_SAVE_LEGSYS = MAG_LEGSYS											&& LEGA IL MOVIMENTO U_MAG_MO ALLA DDT U_BOL_DD 
	    	LOCAL_IDUNIQUE	= ID_UNIQUE
			AQM_GIACEN  	= AQM_QTAMOV_MOVIMENTATA 
			AQM_QTAMQ 		= AQM_QTAMQ_MOVIMENTATA  
			AQM_QTAKG 		= AQM_QTAKG_MOVIMENTATA  
			AQM_QTAML 		= AQM_QTAML_MOVIMENTATA  
			AQM_QTAMC 		= AQM_QTAMC_MOVIMENTATA
	    	
	    	=AQM_SOMMA()

			IF !ExecRW(cSql,"U_MAG_GG","W")												&& RICARICA LA GIACENZA SU U_MAG_GG	CON LA QUANTITA' IN PRECEDENZA MOVIMENTATA									
			   return(.f.)
			ENDIF

		ELSE
			
			AQM_GIACEN = AQM_QTAMOV_MOVIMENTATA
			AQM_QTAMQ = AQM_QTAMQ_MOVIMENTATA  
			AQM_QTAKG = AQM_QTAKG_MOVIMENTATA  
			AQM_QTAML = AQM_QTAML_MOVIMENTATA  
			AQM_QTAMC = AQM_QTAMC_MOVIMENTATA  
			
			=AQM_CREA()
			
			IF !ExecRW(cSql,"U_MAG_GG","W")													&& RICARICA LA GIACENZA SU U_MAG_GG	CON LA QUANTITA' IN PRECEDENZA MOVIMENTATA									
			   return(.f.)
			ENDIF
			
	    ENDIF	   

		SELECT LOCAL_U_MAG_MO
		SKIP +1

	ENDDO
	
ENDIF
