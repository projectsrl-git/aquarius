***********************************************
PROCEDURE AQM_RICALCOLA_EVASIONE_ORDINI_CLIENTI
***********************************************

LPARAMETERS _par_nomecur

LOCAL _AQM_SS
_AQM_SS=SELECT()

*** RICALCOLO DELLE QUANTITA' EVASE NEGLI ORDINI CLIENTI COINVOLTI
SELECT &_par_nomecur
SET FILTER TO
GO TOP
SCAN
	
	IF "*** COMMENTO ***" $ ORD_DESART
		LOOP
	ENDIF

	**=> ERASMO/SERGIO - INIZIO 05/03/2015
	*** IL POLIECO NON DEVE DETERMINARE CONDIZIONI DI CHIUSURA/APERTURA ORDINE
	IF SUBSTR(ORD_CODART,1,7) = 'POLIECO'
		LOOP
	ENDIF
	**=> ERASMO/SERGIO - FINE 05/03/2015
	
	*** ANNULLO LE QUANTITA' EVASE SU TUTTI I DETTAGLI ORDINI CLIENTI LEGATI
	SCATTER MEMVAR
	_X_DAGGANCIO = ""   
	x_lsys = "ord_legsys = '" + M.ORD_LEGSYS + "'"
	x_cond = x_lsys
	cSql   = "SELECT * FROM U_ORD_DD WHERE " + x_cond
	IF !ExecRW(cSql,"U_ORD_DD","R")
		return(.f.)
	ENDIF 
	SELECT U_ORD_DD
	GO TOP
	IF EOF()
	ELSE
		REPLACE ORD_QTAEV  WITH 0
		REPLACE ORD_NUMBOE WITH 0	
		REPLACE ORD_QTAKGE WITH 0	
		REPLACE ORD_QTAMQE WITH 0	 
		REPLACE ORD_QTAMLE WITH 0	 
		REPLACE ORD_QTAMCE WITH 0	 
		REPLACE ORD_SALCON WITH ""
		REPLACE ORD_CHIUSO WITH .F.
		
		_X_DAGGANCIO = DAGGANCIO   
		
	ENDIF
	IF !ExecRW(cSql,"U_ORD_DD","W")
		return(.f.)
	ENDIF
	
 
	IF !EMPTY(_X_DAGGANCIO)
		x_agga = "daggancio = '" + _X_DAGGANCIO + "'"
		x_comm = "ORD_DESART <> '*** COMMENTO ***'"
		x_cond = x_agga + " and " + x_comm  && ERASMO/SERGIO - 05/03/2015
		cSql	= "SELECT ORD_CODART,ORD_QTAEV,ORD_QTAORD,ORD_CHIUSO FROM U_ORD_DD WHERE " + x_cond
		IF !ExecCommand(cSql,"TMP_ORD_DD")
			return(.f.)
		ENDIF 
		V_OPEN = .F.
		SELECT TMP_ORD_DD
		GO TOP
		DO WHILE .T.
			IF EOF()
				EXIT
			ENDIF
			
			**=> ERASMO/SERGIO - INIZIO 05/03/2015
			*** IL POLIECO NON DEVE DETERMINARE CONDIZIONI DI CHIUSURA/APERTURA ORDINE
			IF SUBSTR(ORD_CODART,1,7) = 'POLIECO'
				SKIP +1
				LOOP
			ENDIF
			**=> ERASMO/SERGIO - FINE 05/03/2015
			
			IF ORD_QTAEV < ORD_QTAORD 
				IF ORD_CHIUSO
				ELSE
					V_OPEN = .T.
					EXIT
				ENDIF
			ENDIF
			SKIP +1
		ENDDO
		x_agga = "taggancio = '" + _X_DAGGANCIO + "'"
		x_cond = x_agga 
		cSql	= "SELECT * FROM U_ORD_TT WHERE " + x_cond
		IF !ExecRW(cSql,"U_ORD_TT","R")
			return(.f.) 
		ENDIF 
		SELECT U_ORD_TT
		GO TOP
		IF EOF()
		ELSE
			IF V_OPEN
				REPLACE ORD_CHIUSO WITH .F.
			ELSE
				REPLACE ORD_CHIUSO WITH .T.
			ENDIF
		ENDIF
		IF !ExecRW(cSql,"U_ORD_TT","W")
			return(.f.)
		ENDIF
	ENDIF
	
	*** RICALCOLO LE QUANTITA' EVASE SU TUTTI I DETTAGLI ORDINI CLIENTI LEGATI COINVOLGENDO EVENTUALI ALTRE DDT CLIENTI PRESENTI SUL DB
	SELECT &_par_nomecur
	x_lsys = "ord_legsys = '" + ORD_LEGSYS + "'"
	x_comm = "ORD_DESART <> '*** COMMENTO ***'"
	*x_cond = x_lsys + " and " + x_comm
	*cSql   = "SELECT * FROM U_BOL_DD WHERE " + x_cond + " order by daggancio"
	**=> ERASMO - INIZIO 11/07/2014
	x_tcau = "SUBSTRING(COALESCE(PARA.LIBERA,''),58,1) <> 'S' "  && ESCLUDO LE BOLLE CON TOP AVENTI IL FLAG "Non gestisce il magazzino e gli ordini clienti"
	x_cond = x_lsys + " and " + x_comm + " and " + x_tcau 
	cSql   = "SELECT ORD_CODART,ORD_LEGSYS,ORD_QTAORD,ORD_NUMBOB,ORD_QTAKG,ORD_QTAMQ,ORD_QTAML,ORD_QTAMC FROM U_BOL_DD " + CHR(13) + ;
	         "LEFT OUTER JOIN U_BOL_TT ON U_BOL_DD.DAGGANCIO = U_BOL_TT.TAGGANCIO " + CHR(13) + ;  && NON SEMPRE AVRO' LA TESTATA BOLLA DISPONIBILE, COME AD ESEMPIO IN CREAZIONE DDT DA PACKING LIST PPT, MA NON E' INDISPENSABILE (SERVE SOLO PER ESCLUDERE EVENTUALI CAUSALI DI BOLLE PREESISTENTI CHE NON DEVONO EVADERE L'ORDINE)
	         "LEFT OUTER JOIN PARA ON PARA.CODICE = 'TOP'+U_BOL_TT.ORD_CAUS " + CHR(13) + ;
	         "WHERE " + x_cond + " order by daggancio"
	**=> ERASMO - FINE 11/07/2014
	IF !ExecCommand(cSql,"CX_BOL_DD")
		return(.f.)
	ENDIF
	SELECT CX_BOL_DD
	GO TOP
	SCAN

		**=> ERASMO/SERGIO - INIZIO 05/03/2015
		*** IL POLIECO NON DEVE DETERMINARE CONDIZIONI DI CHIUSURA/APERTURA ORDINE
		IF SUBSTR(ORD_CODART,1,7) = 'POLIECO'
			LOOP
		ENDIF
		**=> ERASMO/SERGIO - FINE 05/03/2015
		
		SCATTER MEMVAR
		_X_DAGGANCIO = ''
		x_lsys = "ord_legsys = '" + M.ORD_LEGSYS + "'"
		x_comm = "ORD_DESART <> '*** COMMENTO ***'"  && ERASMO - 28/01/2015
		*x_cond = x_lsys
		x_cond = x_lsys + " and " + x_comm  && ERASMO - 28/01/2015
		cSql   = "SELECT * FROM U_ORD_DD WHERE " + x_cond
		IF !ExecRW(cSql,"U_ORD_DD","R")
			return(.f.)
		ENDIF 
		SELECT U_ORD_DD
		GO TOP
		IF EOF()
		ELSE
			_X_DAGGANCIO = DAGGANCIO
			REPLACE ORD_QTAEV  WITH ORD_QTAEV  + M.ORD_QTAORD
			REPLACE ORD_NUMBOE WITH ORD_NUMBOE + M.ORD_NUMBOB
			REPLACE ORD_QTAKGE WITH ORD_QTAKGE + M.ORD_QTAKG
			REPLACE ORD_QTAMQE WITH ORD_QTAMQE + M.ORD_QTAMQ
			REPLACE ORD_QTAMLE WITH ORD_QTAMLE + M.ORD_QTAML
			REPLACE ORD_QTAMCE WITH ORD_QTAMCE + M.ORD_QTAMC
			
			X_TIPO = CERCATIPO(ORD_CODART)
			X_CONDITION = .F.
			IF X_TIPO = '6' OR ;  && PANNELLI TRUCIOLARI
				X_TIPO = '9'  && DADI PRESSATI  
				X_CONDITION = (ORD_NUMBOE >= ORD_NUMBOB)
			ELSE
				X_CONDITION = (ORD_QTAEV >= ORD_QTAORD)
			ENDIF
			REPLACE ORD_CHIUSO WITH X_CONDITION
			
			*REPLACE ORD_SALCON WITH M.ORD_SALCON
		ENDIF
		IF !ExecRW(cSql,"U_ORD_DD","W")
			return(.f.)
		ENDIF
		
		IF !EMPTY(_X_DAGGANCIO)
			x_agga = "daggancio = '" + _X_DAGGANCIO + "'"
			x_comm = "ORD_DESART <> '*** COMMENTO ***'"
			x_cond = x_agga + " and " + x_comm  && ERASMO/SERGIO - 05/03/2015
			cSql	= "SELECT ORD_CODART,ORD_QTAEV,ORD_QTAORD,ORD_CHIUSO FROM U_ORD_DD WHERE " + x_cond
			IF !ExecCommand(cSql,"TMP_ORD_DD")
				return(.f.)
			ENDIF 
			V_OPEN = .F.
			SELECT TMP_ORD_DD
			GO TOP
			DO WHILE .T.
				IF EOF()
					EXIT
				ENDIF
					
				**=> ERASMO/SERGIO - INIZIO 05/03/2015
				*** IL POLIECO NON DEVE DETERMINARE CONDIZIONI DI CHIUSURA/APERTURA ORDINE
				IF SUBSTR(ORD_CODART,1,7) = 'POLIECO'
					SKIP +1
					LOOP
				ENDIF
				**=> ERASMO/SERGIO - FINE 05/03/2015
				
				IF ORD_QTAEV < ORD_QTAORD 
					IF ORD_CHIUSO
					ELSE
						V_OPEN = .T.
						EXIT
					ENDIF
				ENDIF
				SKIP +1
			ENDDO
			x_agga = "taggancio = '" + _X_DAGGANCIO + "'"
			x_cond = x_agga 
			cSql	= "SELECT * FROM U_ORD_TT WHERE " + x_cond
			IF !ExecRW(cSql,"U_ORD_TT","R")
				return(.f.) 
			ENDIF 
			SELECT U_ORD_TT
			GO TOP
			IF EOF()
			ELSE
				IF V_OPEN
					REPLACE ORD_CHIUSO WITH .F.
				ELSE
					REPLACE ORD_CHIUSO WITH .T.
				ENDIF
			ENDIF
			IF !ExecRW(cSql,"U_ORD_TT","W")
				return(.f.)
			ENDIF
		ENDIF
				
	ENDSCAN
	
ENDSCAN

SELECT(_AQM_SS)

RETURN


*************************************************
PROCEDURE AQM_RICALCOLA_EVASIONE_ORDINI_FORNITORI
*************************************************

LPARAMETERS _par_nomecur_dd,_par_nomecur_dl

LOCAL _AQM_SS
_AQM_SS=SELECT()


*** RICALCOLO DELLE QUANTITA' EVASE NEGLI ORDINI FORNITORI COINVOLTI
SELECT &_par_nomecur_dd
SET FILTER TO
GO TOP
SCAN
	
	IF "*** COMMENTO ***" $ ORD_DESART
		LOOP
	ENDIF
	
	SCATTER MEMVAR
	
	*** ANNULLO LE QUANTITA' EVASE SU TUTTI I DETTAGLI ORDINI FORNITORI LEGATI
	x_agga = "daggancio = '" + M.ORD_LEGAME + "'"
	x_csys = "ord_codsys = '" + M.ORD_LEGASY + "'"
	x_cond = x_agga + " and " + x_csys
	cSql   = "SELECT * FROM U_ORF_DD WHERE " + x_cond
	IF !ExecRW(cSql,"U_ORF_DD","R")
		return(.f.)
	ENDIF 
	SELECT U_ORF_DD
	GO TOP
	IF EOF()
	ELSE
		REPLACE ORD_QTAEV WITH 0
		REPLACE ORD_SALCON WITH ""
		REPLACE ORD_CHIUSO WITH .F.
	ENDIF
	IF !ExecRW(cSql,"U_ORF_DD","W")
		return(.f.)
	ENDIF
	

	*** AGGIORNO LA TESTATA ORDINE FORNITORE
	x_agga = "daggancio = '" + M.ORD_LEGAME + "'"
	x_cond = x_agga
	cSql	= "SELECT ORD_QTAEV,ORD_QTAORD,ORD_CHIUSO FROM U_ORF_DD WHERE " + x_cond
	IF !ExecCommand(cSql,"TMP_ORF_DD")
		return(.f.)
	ENDIF 
	V_OPEN = .F.
	SELECT TMP_ORF_DD
	GO TOP
	DO WHILE .T.
		IF EOF()
			EXIT
		ENDIF
		IF ORD_QTAEV < ORD_QTAORD 
			IF ORD_CHIUSO
			ELSE
				V_OPEN = .T.
				EXIT
			ENDIF
		ENDIF
		SKIP +1
	ENDDO
	x_agga = "taggancio = '" + M.ORD_LEGAME + "'"
	x_cond = x_agga 
	cSql	= "SELECT * FROM U_ORF_TT WHERE " + x_cond
	IF !ExecRW(cSql,"U_ORF_TT","R")
		return(.f.) 
	ENDIF 
	SELECT U_ORF_TT
	GO TOP
	IF EOF()
	ELSE
		IF V_OPEN
			REPLACE ORD_CHIUSO WITH .F.
		ELSE
			REPLACE ORD_CHIUSO WITH .T.
		ENDIF
	ENDIF
	
	IF !ExecRW(cSql,"U_ORF_TT","W")
		return(.f.)
	ENDIF

	
	SELECT &_par_nomecur_dl
	SET FILTER TO
	SET FILTER TO ORD_AGGORF = M.ORD_LEGAME .AND. ORD_SYSORF = M.ORD_LEGASY
	*SET ORDER TO I_ORDINE
	GO TOP
	SCAN
		SCATTER MEMVAR MEMO
		x_lega = "dlegame = '" + M.DLEGAME + "'"
		x_agga = "daggancio = '" + M.ORD_AGGORF + "'"
		x_csys = "ord_codsys = '" + M.ORD_CODORF + "'"
		x_cond = x_lega + " and " + x_agga + " and " + x_csys
		cSql	= "select * from u_orf_dl where " + x_cond
		IF !ExecRW(cSql,"U_ORF_DL","R")
			return(.f.)
		ENDIF
		SELECT U_ORF_DL
		GO TOP
		IF EOF()
		ELSE
			REPLACE ORD_QTAKGE WITH 0
			REPLACE ORD_QTAMQE WITH 0
			REPLACE ORD_QTAMLE WITH 0
			REPLACE ORD_SALCON WITH ""
			REPLACE ORD_CHIUSO WITH .F.
		ENDIF
		IF !ExecRW(cSql,"U_ORF_DL","W")
			return(.f.)
		ENDIF
	ENDSCAN
	
	*** ANNULLO LE QUANTITA' EVASE SU TUTTI I DETTAGLI ORDINI FORNITORI U_ORF_DL LEGATI COINVOLGENDO EVENTUALI ALTRE DDT DI CARICO PRESENTI SUL DB
	SELECT &_par_nomecur_dd
	SCATTER MEMVAR
	x_aggo = "ord_aggorf = '" + M.ORD_LEGAME + "'"
	x_syso = "ord_sysorf = '" + M.ORD_LEGASY + "'"
	x_cond = x_aggo + " and " + x_syso 
	cSql   = "select * from u_bfo_dl where " + x_cond
	IF !ExecCommand(cSql,"CX_BFO_DL")
		return(.f.)
	ENDIF
	SELECT CX_BFO_DL
	GO TOP
	SCAN
		SCATTER MEMVAR
			
		x_lega = "dlegame = '" + M.DLEGAME + "'"
		x_agga = "daggancio = '" + M.ORD_AGGORF + "'"
		x_csys = "ord_codsys = '" + M.ORD_CODORF + "'"
		x_cond = x_lega + " and " + x_agga + " and " + x_csys
		cSql	= "select * from u_orf_dl where " + x_cond
		IF !ExecRW(cSql,"U_ORF_DL","R")
			return(.f.)
		ENDIF
		SELECT U_ORF_DL
		GO TOP
		IF EOF()
		ELSE
			REPLACE ORD_QTAKGE WITH 0
			REPLACE ORD_QTAMQE WITH 0
			REPLACE ORD_QTAMLE WITH 0
			REPLACE ORD_SALCON WITH ""
			REPLACE ORD_CHIUSO WITH .F.
		ENDIF
		IF !ExecRW(cSql,"U_ORF_DL","W")
			return(.f.)
		ENDIF
	ENDSCAN
	
	
	
	*** RICALCOLO LE QUANTITA' EVASE SU TUTTI I DETTAGLI ORDINI FORNITORI LEGATI COINVOLGENDO EVENTUALI ALTRE DDT DI CARICO PRESENTI SUL DB
	SELECT &_par_nomecur_dd
	x_agga = "ORD_LEGAME = '" + ORD_LEGAME + "'"
	x_csys = "ORD_LEGASY = '" + ORD_LEGASY + "'"
	x_comm = "ORD_DESART <> '*** COMMENTO ***'"
	x_cond = x_agga + " and " + x_csys + " and " + x_comm
	cSql   = "SELECT * FROM U_BFO_DD WHERE " + x_cond + " order by daggancio"
	IF !ExecCommand(cSql,"CX_BFO_DD")
		return(.f.)
	ENDIF
	SELECT CX_BFO_DD
	GO TOP
	SCAN
		
		SCATTER MEMVAR
		
		x_agga = "daggancio = '" + M.ORD_LEGAME + "'"
		x_csys = "ord_codsys = '" + M.ORD_LEGASY + "'"
		x_comm = "ORD_DESART <> '*** COMMENTO ***'"
		x_cond = x_agga + " and " + x_csys + " and " + x_comm 
		cSql   = "SELECT * FROM U_ORF_DD WHERE " + x_cond
		IF !ExecRW(cSql,"U_ORF_DD","R")
			return(.f.)
		ENDIF 
		SELECT U_ORF_DD
		GO TOP
		IF EOF()
		ELSE
		
			REPLACE ORD_QTAEV WITH ORD_QTAEV + M.ORD_QTAORD
			*IF M.ORD_SALCON = 'S'
			*	REPLACE ORD_CHIUSO WITH .T.
			*ELSE
			*	REPLACE ORD_CHIUSO WITH .F.
			*ENDIF
			*REPLACE ORD_SALCON WITH M.ORD_SALCON
			**=> ERASMO - INIZIO 09/10/2014
			*** SE ALMENO UNO DEI DETTAGLI BFO E' STATO SETTATO CON ORD_SALCON A 'S' HA GIA' FORZATO 
			*** LA CHIUSURA DELLA RIGA ORDINE FORNITORE, QUINDI TESTO SE EVENTUALMENTE E' STATA GIA' CHIUSA
			IF ORD_CHIUSO
			ELSE
				IF M.ORD_SALCON = 'S'
					REPLACE ORD_CHIUSO WITH .T.
				ELSE
					REPLACE ORD_CHIUSO WITH .F.
				ENDIF
				REPLACE ORD_SALCON WITH M.ORD_SALCON
			ENDIF
			**=> ERASMO - FINE 09/10/2014			
		ENDIF
		IF !ExecRW(cSql,"U_ORF_DD","W")
			return(.f.)
		ENDIF
		
		x_agga = "daggancio = '" + M.ORD_LEGAME + "'"
		*x_cond = x_agga
		x_comm = "ORD_DESART <> '*** COMMENTO ***'"
		x_cond = x_agga + " and " + x_comm 
		cSql	= "SELECT ORD_QTAEV,ORD_QTAORD,ORD_CHIUSO FROM U_ORF_DD WHERE " + x_cond
		IF !ExecCommand(cSql,"TMP_ORF_DD")
			return(.f.)
		ENDIF 
		V_OPEN = .F.
		SELECT TMP_ORF_DD
		GO TOP
		DO WHILE .T.
			IF EOF()
				EXIT
			ENDIF
			IF ORD_QTAEV < ORD_QTAORD 
				IF ORD_CHIUSO
				ELSE
					V_OPEN = .T.
					EXIT
				ENDIF
			ENDIF
			SKIP +1
		ENDDO
		x_agga = "taggancio = '" + M.ORD_LEGAME + "'"
		x_cond = x_agga 
		cSql	= "SELECT * FROM U_ORF_TT WHERE " + x_cond
		IF !ExecRW(cSql,"U_ORF_TT","R")
			return(.f.) 
		ENDIF 
		SELECT U_ORF_TT
		GO TOP
		IF EOF()
		ELSE
		
			IF V_OPEN
				REPLACE ORD_CHIUSO WITH .F.
			ELSE
				REPLACE ORD_CHIUSO WITH .T.
			ENDIF
			
		ENDIF
		IF !ExecRW(cSql,"U_ORF_TT","W")
			return(.f.)
		ENDIF
		
		SELECT CX_BFO_DD
		SCATTER MEMVAR
		
		VV_DAGGANCIO = M.DAGGANCIO
		VV_DLEGAME	= M.ORD_LEGASY

		x_agga = "daggancio = '" + M.DAGGANCIO + "'"
		x_aggo = "ord_aggorf = '" + M.ORD_LEGAME + "'"
		x_syso = "ord_sysorf = '" + M.ORD_LEGASY + "'"
		x_cond = x_agga + " and " + x_aggo + " and " + x_syso 
		cSql   = "select * from u_bfo_dl where " + x_cond
		IF !ExecCommand(cSql,"CX_BFO_DL")
			return(.f.)
		ENDIF
		SELECT CX_BFO_DL
		GO TOP
		SCAN
			SCATTER MEMVAR
				
			x_lega = "dlegame = '" + M.DLEGAME + "'"
			x_agga = "daggancio = '" + M.ORD_AGGORF + "'"
			x_csys = "ord_codsys = '" + M.ORD_CODORF + "'"
			x_cond = x_lega + " and " + x_agga + " and " + x_csys
			cSql	= "select * from u_orf_dl where " + x_cond
			IF !ExecRW(cSql,"U_ORF_DL","R")
				return(.f.)
			ENDIF
			SELECT U_ORF_DL
			GO TOP
			IF EOF()
			ELSE
				IF ORD_UM = 'KG'
					V_QTACTRL = ORD_QTAKG
				ELSE
					V_QTACTRL = ORD_QTAMQ
				ENDIF
				IF V_QTACTRL > 0
					REPLACE ORD_QTAKGE WITH ORD_QTAKGE + M.ORD_QTAKG
					REPLACE ORD_QTAMQE WITH ORD_QTAMQE + M.ORD_QTAMQ
					REPLACE ORD_QTAMLE WITH ORD_QTAMLE + M.ORD_QTAML
				ENDIF
				REPLACE ORD_SALCON WITH M.ORD_SALCON
				
				IF M.ORD_SALCON = 'S'
					REPLACE ORD_CHIUSO WITH .T.
				ELSE
					REPLACE ORD_CHIUSO WITH .F.
				ENDIF
			
			ENDIF
			IF !ExecRW(cSql,"U_ORF_DL","W")
				return(.f.)
			ENDIF
		ENDSCAN
		
	ENDSCAN
	
ENDSCAN

SELECT(_AQM_SS)

RETURN



*******************************************************************************************************************************
PROCEDURE RILEVA_ORDINATO_A_FORNITORE	&& Funzione di rilevamento del materiale ordinato a fornitore
*******************************************************************************************************************************
*
*  OPZIONI POSSIBILI	:
*  						: se codice articolo presente : estrae tutti gli ordini a fornitore dell'articolo desiderato
*						: 								altrimenti estrae tutto
*						: se data cosegna dal al presente : estrae gli ordini a fornitore che devono essere consegnati
*						:									altrimenti estrae tutto
*						: se codice fornitore presente : estrae tutti gli ordini a fornitore del fornitore desiderato
*						: 								altrimenti estrae tutto
*						: se date consegna presenti : estrae tutti gli ordini a fornitore del periodo indicao
*						: 								altrimenti estrae tutto
*						: se ordini_da_consegnare = TUTTI estrae tutti gli ordini a fornitore 
*						:   					  = SI estrae solo gli ordini a fornitore con (ord_qtaord - ord_qtaev) > 0
*						:   					  = NO estrae solo gli ordini a fornitore con (ord_qtaord - ord_qtaev) =< 0
*						: se date ordini presenti : estrae tutti gli ordini a fornitore del periodo indicato
*						: 							altrimenti estrae tutto
*
*  OUTPUT				:
*						:
*						: cursore PRODOTTI_ORDINATI_A_FORNITORE , contenente tutte le righe degli ordini a frornitore per data consegna
*						: 
*
*
*
PARAMETERS _codicefornitore,_cdarticolo,_dataconsegna_dal,_dataconsegna_al,_ordini_da_consegnare,_dataordine_dal,_dataordine_al

LOCAL _AQM_SMAGS
_AQM_SMAGS=SELECT()



IF !EMPTY(alltrim(_dataordine_dal))
	x_dord = "ors_datord between '" + _dataordine_dal + "' and '" + _dataordine_al + "'"
ELSE
	x_dord = "ors_datord = ors_datord"
ENDIF


x_qtev = "ord_qtaord = ord_qtaord"

IF _ordini_da_consegnare = "SI"
	*x_qtev = "(ord_qtaord - ord_qtaev) > 0"
	x_qtev = "(ord_qtaord - ord_qtaev) > 0 AND ORD_CHIUSO = 0 AND DAGGANCIO NOT IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_CHIUSO = 1)"  && ERASMO - 17/12/2014
ENDIF

IF _ordini_da_consegnare = "NO"
	*x_qtev = " NOT ((ord_qtaord - ord_qtaev) > 0)"
	x_qtev = "((ord_qtaev >= ord_qtaord) OR ORD_CHIUSO = 1 OR DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_CHIUSO = 1))"  && ERASMO - 17/12/2014
ENDIF

IF !EMPTY(alltrim(_dataconsegna_dal))
	x_dsca  = "ord_datcon between '" + _dataconsegna_dal + "' and '" + _dataconsegna_al + "'"
ELSE
	x_dsca = "ord_datcon = ord_datcon"
ENDIF

IF !EMPTY(alltrim(_codicefornitore))
	x_ccli = "ors_codcli = '" + ALLTRIM(_codicefornitore) + "'"
ELSE
	x_ccli = "ors_codcli = ors_codcli"
ENDIF 

IF !EMPTY(ALLTRIM(_cdarticolo))
	x_cart = "ord_codart = '" + ALLTRIM(_cdarticolo) + "'"
ELSE
	x_cart = "ord_codart = ord_codart" 
ENDIF

*!*	   x_cmat = "ord_codmat = '" + ALLTRIM(_X_CODMAT) + "'"
x_cmat = "ord_codmat = ord_codmat" 
