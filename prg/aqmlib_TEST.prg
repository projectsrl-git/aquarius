********************************************************************************************************* 
 FUNCTION AQM_SCARICA_COMPONENTI_DISTINTA_BASE	&& FUNZIONE DI SCARICO DEI COMPONENTI DELLA DISTINTA BASE
********************************************************************************************************* 
*   FUNZIONE DI SCARICO MAGAZZINO DALLA DISTINTA BASE
*	
*	- SCARICA I COMPONENTI OTTENUTI DALL'ESPLOSIONE DELLA DISTINTA BASE
*
* 	- SE IMPOSTATO IL FLAG _XDB_FLAG   = SI : EFFETTUA IL CARICO AUTOMATICO DEL PRODOTTO FINITO
*										   
* 	- SE IMPOSTATO IL FLAG _XDB_MOVIM  = NO : NON CREA I MOVIMENTI SU U_MAG_MO
*

*PARA _XDB_FLAG,_XDB_MOVIM,_XDB_QTA,_XDB_TOP,_XDB_COD,_XDB_MAG,_XDB_CODCLI,_XDB_DATA,_XDB_NUMDOC,_XDB_DTREGI,_XDB_TOPC,_XDB_CODFOR

*!*	_N_PAR  = PARAMETERS()
*!*	IF _N_PAR   = 10
*!*		_XDB_TOPC = "100"
*!*	ENDIF

LOCAL _AQM_SS
_AQM_SS=SELECT()

SI_VIDEO = .F.
SI_LIV   = .F.
DO ALBERELLO  WITH SI_VIDEO,_XDB_COD,SI_LIV && ESPLODE LA DISTINTA BASE SU FILE WEXPLODE

SELECT WEXPLODE
GO TOP

DO WHILE .T.

   IF EOF()
      EXIT
   ENDIF
   
   IF DELETED()
	  SELECT WEXPLODE
	  SKIP+1
	  LOOP
   ENDIF	

   SCATTER MEMVAR MEMO 

   IF _XDB_FLAG  = "NO"          && SCARTA I GRUPPI E SOTTOGRUPPI
	  IF WTIP = "A"
	  ELSE
		 SELECT WEXPLODE
		 SKIP+1
		 LOOP
	  ENDIF
   ENDIF


  IF WEXP = "X"					&& SCARTA GLI ARTICOLI FANTASMA : NON DETERMINANO LA QUANTITA' MA IL PREZZO PER CUI NON TOCCANO IL MAGAZZINO
	 SELECT WEXPLODE
	 SKIP+1
	 LOOP
  ENDIF



   *-->> DETERMINA LA QTA DA SCARICARE IN FUNZIONE DELLA DISTINTA----------
	    	
   QT_QT   = _XDB_QTA * M.WQTA

   IF WTIP = "A" 	  																			 && TRATTA SOLO COMPONENTI          
		=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_DISTINTA_BASE")
		_OK_SCAR = AQM_SCARICA_MAGAZZINO_DA_DISTINTA_BASE()
   ENDIF

*!*	   * EFFETTUA IL MOVIMENTO DI CARICO AUTOMATICO SUL PRODOTTO FINITO -------
*!*	   IF _XDB_FLAG  = "SI"          
*!*		  IF WTIP = "T"																				 && TRATTA SOLO IL PRODOTTO FINITO    
*!*			=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
*!*			=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_DISTINTA_BASE")
*!*			AQM_NUMMOV_LOCALE  	= AQM_RILEVA_NUMERO_INTERNO()
*!*			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODMAT = ""
*!*			ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESMAT = ""
*!*			=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)		
*!*			AQM_CODMAT 			= ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_CODMAT  						&& CODICE MATERIALE
*!*			AQM_DESMAT 			= ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_DESMAT 							&& DESCRIZIONE MATERIALE
*!*			AQM_NUMIDE			= AQM_NUMMOV_LOCALE  
*!*			=AQM_CARICA_MAGAZZINO()
*!*	      ENDIF
*!*	   ENDIF

   SELECT WEXPLODE
   SKIP+1

ENDDO

SELECT(_AQM_SS)

RETURN(.T.)


***********************************************
FUNCTION AQM_SCARICA_MAGAZZINO_DA_DISTINTA_BASE
***********************************************

LOCAL _AQM_SEL
_AQM_SEL=SELECT()

_OK_SCARICA_MAGAZZINO = .F.

AQM_NUMMOV_LOCALE = AQM_RILEVA_NUMERO_INTERNO()


_OK_SCARICA_MAGAZZINO = .F.

_ww_codsoc = aqm_codsoc 
_ww_anaart = aqm_anaart 
_ww_codmag = aqm_codmag 
_ww_prenot = .T.  && PARAMETRO PER SCARICARE SOLO GIACENZE NON PRENOTATE
_ww_codint = ""
_ww_altezz = aqm_altezz 
_ww_lunghe = aqm_lunghe 
_ww_fila_x = ""
_ww_pian_x = ""
_ww_ubic_x = ""
_giac_disp = AQM_RILEVA_GIACENZE_DISPONIBILI(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x)

=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()	
LOCAL_AQM_GIACEN = AQM_GIACEN
LOCAL_DATAOGGI   = RIBALTA2(DTOC(DATE()))

=ACCESSO_PARAMETRO_TOP()
=ACCESSO_ANAGRAFICA_FORNITORE()
=ACCESSO_ANAGRAFICA_CLIENTE()
=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)

_Y_SCAR = AQM_SCARICA_GIACENZA(.T.)  && SCARICA LA GIACENZA DA U_MAG_GG ED ANCHE L'IMPEGNATO
IF _Y_SCAR
	_OK_SCARICA_MAGAZZINO = .T.
ENDIF

*!*	SELECT LOCAL_U_MAG_GG
*!*	GO TOP       
*!*	IF !EOF()
*!*		
*!*		_giac_disp = MAG_GIACEN
*!*		
*!*		=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()
*!*		
*!*		LOCAL_AQM_GIACEN = AQM_GIACEN
*!*		
*!*		IF _giac_disp >= LOCAL_AQM_GIACEN
*!*			
*!*			LOCAL_DATAOGGI   = RIBALTA2(DTOC(DATE()))

*!*			=ACCESSO_PARAMETRO_TOP()
*!*			=ACCESSO_ANAGRAFICA_FORNITORE()
*!*			=ACCESSO_ANAGRAFICA_CLIENTE()
*!*			=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)
*!*			
*!*			_Y_SCAR = AQM_SCARICA_GIACENZA()  && SCARICA LA GIACENZA DA U_MAG_GG
*!*			IF _Y_SCAR
*!*				_OK_SCARICA_MAGAZZINO = .T.
*!*			ENDIF
*!*			
*!*		ELSE

