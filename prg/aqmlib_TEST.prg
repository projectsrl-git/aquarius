					***         PROJECT SRL - LIBRERIA PER LA GESTIONE DEL MAGAZZINO                           ***
					***                       VALIDA PER LE VERSIONI DI AQUARIUS DAL                           ***
					***                       ############  09-04-2011  ############                           ***
					**********************************************************************************************

*!*	##############################################################################################################
*!*	*
*!*	* IL MAGAZZINO E' GESTITO CON DUE TABELLE 	______________________: U_MAG_GG / U_MAG_MO
*!*	*  											:   
*!*	*  											: U_MAG_GG   
*!*	*  											: CONTIENE LA SEQUENZA TEMPORALE DEI CARICHI A FRONTE DI UNA DDT O DI UN MOVIMENTO GENERICO DI CARICO 
*!*	*  					________________________:  
*!*	*  					: U_MAG_MO   
*!*	*  					: CONTIENE I DATI DEL MOVIMENTO DI CARICO/SCARICO EFFETTIVO 
*!*	*					:
*!*	* _______________________
*!*	* CARICO DI MAGAZZINO   :
*!*	*                       : LA FUNZIONE DI CARICO DA BFO O DA MOVIMAGA CREA TANTI RECORD SIA SU U_MAG_GG CHE SU U_MAG_MO , UN RECORD PER ARTICOLO CARICATO
*!*	*                       : PER VIA DELLA TRACCIABILITA' E OGNI RECORD CONTIENE IL PREZZO DI ACQUISTO AL MOMENTO DEL CARICO
*!*	* _______________________
*!*	* SCARICO DI MAGAZZINO  :
*!*	*                       : LA FUNZIONE DI SCARICO DA DDT O DA MOVIMAGA AGGANCIA IL RECORD PIU' VECCHIO DI U_MAG_GG , IL PRIMO IN ORDINE DI CARICO 
*!*	*                       : SI MEMORIZZA IL PREZZO AL MOMENTO DEL CARICO , SCARICA LA GIACENZA E NEL CASO CANCELLA IL RECORD SU U_MAG_GG SE PREVISTO
*!*	*						:
*!*	*                       : SALVA QUINDI SU U_MAG_MO 	:
*!*	*													:	IL PREZZO DI AQUISTO ORIGINALE 
*!*	*													:
*!*	*													:	SYS DI ACCESSO DALLA DDT CLIENTE AL MOVIMENTO DI MAGAZZINO E AL MAGAZZINO:
*!*	*													:
*!*	*													: 		1)	IL LEGAME TRA' LA RIGA DI U_BOL_DD E IL MOVIMENTO U_MAG_MO E' UNO A UNO : AD OGNO MODIFICA DI RIGA DDT 
*!*	*													:   		ORD_SYSMAG VIENE RIATTRIBUITO NUOVAMENTE (SER-01)
*!*	*													:		2)	U_BOL_DD.ORD_SYSMAG ---->> U_MAG_MO.MOV_LEGSYS ---->> MOV_LEGAME 
*!*	*													:		3)	U_MAG_MO.MOV_LEGAME ---->> U_MAG_GG.MAG_LEGAME
*!*	*													:		4)  MAG_LEGSYS NON E' USABILE PER GESTIRE IL LEGAME TRA U_MAG_GG E U_MAG_MO/U_BOL_DD
*!*	*													:
*!*	*													:
*!*	*													:	SYS DI ACCESSO DALLA BFO FORNITORE AL MOVIMENTO DI MAGAZZINO E AL MAGAZZINO:
*!*	*													:
*!*	*													:		1)	U_BFO_DD.ORD_SYSMAG ---->> U_MAG_MO.MOV_LEGSYS ---->> MOV_LEGAME  
*!*	*													:		2)	U_MAG_MO.MOV_LEGAME ---->> U_MAG_GG.MAG_LEGAME
*!*	*
*!*	*________________________
*!*	* FUNZIONI RICHIAMABILI :
*!*	*
*!*	*
*!*	*							AQM_GESTIONE_DETTAGLI_DDT				: GESTIONE DETTAGLI DELLA DDT DI SCARICO
*!*	*    						AQM_MAGACS 								: CARICA/SCARICA IL MAGAZZINO E CREA IL MOVIMENTO DI CARICO/SCARICO CORRISPONDENTE        
*!*	*							AQM_CREA_U_MAG_MO						: CREA IL MOVIMENTO DI CARICO/SCARICO MAGAZZINO
*!*	*							AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO	: DEFINISCE TUTTE LE VARIABILI USATE PER IL MAGAZZINO
*!*	*							AQM_VALORIZZA_VARIABILI_MAGAZZINO		: VALORIZZA LE VARIABILI USATE IN FUNZIONE DELLA PROCEDURA DI PROVENIENZA
*!*	*							AQM_SCARICA_MAGAZZINO_DDT				: SCARICA IL MAGAZZINO PARTENDO DAL MOVIMENTO DI CARICO NON IMPEGNATO PIU' VECCJIO
*!*	*							AQM_SCARICA_GIACENZA					: SCARICA LA GIACENZA E CREA IL MOVIMENTO DI SCARICO MAGAZZINO
*!*	*							AQM_CARICA_MAGAZZINO					: CARICA IL MAGAZZINO E CREA IL MOVIMENTO DI CARICO SUI MOVIMENTI
*!*	*							AQM_SCARICA_COMPONENTI_DISTINTA_BASE	: SCARICA COMPONENTI DELLA DISTINTA BASE
*!*	*
*!*	*
*!*	*
*!*	*________________________
*!*	* GESTIONE GIACENZE :
*!*	*
*!*	*							PUB_GIANEG = .T. DAI PARAMETRI AZIENDALI LA PROCEDURA PERMETTE DI GESTIRE LE GIACENZE NEGATIVE SU U_MAG_GG MOSTRANDOLE
*!*	*											 NEL CONTROLLO DI GESTIONE. LE GIACENZE VENGONO AZZERATE DALL'UTENTE CON UNA APPOSITA FUNZIONE NEL 
*!*	*											 CONTROLLO DI GESTIONE
*!*	*
*!*	*
*!*	*							PUB_MAGNO0 : CONTIENE NEI PARAMETRI AZIENDALI "CANCELLA_GIACENZE_A_ZERO" E PERMETTE DI CANCELLARE LE GIACENZE = 0
*!*	*
*!*	*
*!*	*
*!*	* ESEMPI :
*!*	*
*!*	*		CARICO MAGAZZINO :
*!*	*							=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
*!*	*							=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_DISTINTA_BASE")	
*!*	*							=AQM_CARICA_MAGAZZINO()					: CREA IL MAGAZZINO E IL MOVIMENTO DI MAGAZZINO
*!*	*
*!*	*		SCARICO MAGAZZINO :
*!*	*
*!*	*
*!*	*		SCARICO COMPONENTE CON RICARICO AUTOMATICO DEL PRODOTTO FINITO :
*!*	*							
*!*	*							=AQM_DEFINISCE_VARIABILI_DISTINTA_BASE()
*!*	*							=AQM_SCARICA_COMPONENTI_DISTINTA_BASE(_XDB_FLAG,_XDB_MOVIM,_XDB_QTA,_XDB_TOP,_XDB_COD,_XDB_MAG,_XDB_CODCLI,_XDB_DATA,_XDB_NUMDOC,_XDB_DTREGI,_XDB_TOPC,_XDB_CODFOR)
*!*	*
*!*	*
*!*	*		
*!*	*
*!*	*
*!*	*
*!*	*
*!*	*		
		



***********************************************************************
FUNCTION AQM_GESTIONE_DETTAGLI_DDT
***********************************************************************

LPARAMETERS _par_evaord,_par_forni,_par_caus,_par_magd,_par_magd_before

IF PCOUNT() < 1
	_par_evaord = .T.
ENDIF

 
IF PCOUNT() < 2
	_par_forni = .F.
ENDIF

IF _par_forni
	cNomeVarPubSau = "PUB_SAUFOR"
ELSE
	cNomeVarPubSau = "PUB_SAU"
ENDIF
 
LOCAL _AQM_SDDTS
_AQM_SDDTS=SELECT()

 
IF PCOUNT() < 3
	_par_caus = ""
ENDIF

**=> ERASMO - INIZIO 13/01/2014
IF PCOUNT() < 4
	_par_magd = ""
ENDIF
IF PCOUNT() < 5
	_par_magd_before = _par_magd
ENDIF
**=> ERASMO - FINE 13/01/2014

_XX_NOMAGAORDCLI = .F.
IF !EMPTY(_par_caus)
	x_cond = "codice = 'TOP" + _par_caus + "'"
	cSql   = "select LIBERA from para where " + x_cond 
	IF !ExecCommand(cSql,'TMP_PARA')
	   return(.f.)
	ENDIF
	SELECT TMP_PARA
	GO TOP
	IF !EOF()
		IF SUBSTR(LIBERA,58,1) == 'S'
			_XX_NOMAGAORDCLI = .T.
		ENDIF
	ENDIF
ENDIF
 

AQM_NUMMOV_LOCALE  = AQM_RILEVA_NUMERO_INTERNO()

SET DELETED OFF  && DEVO CONSIDERARE ANCHE LE RIGHE CONTRASSEGNATE COME ELIMINATE PER POTERLE CANCELLARE DAL DB

SELECT CU_BOL_DD
SET FILTER TO
SET ORDER TO SEQUEN
GO TOP

DO WHILE .NOT. EOF()

   IF DELETED()
      IF ALLTRIM(ORD_DESART) <> "*** COMMENTO ***"
			SCATTER MEMVAR MEMO
   			IF &cNomeVarPubSau AND !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART) AND !_XX_NOMAGAORDCLI  
	            =AQM_RICARICA_IL_MAGAZZINO("CU_BOL_DD",_par_magd_before)  && ERASMO - 13/01/2014
            ENDIF
      ENDIF
      SELECT CU_BOL_DD
      =AQM_CANCELLA_U_BOL_DD()
      SELECT CU_BOL_DD
      SKIP +1
      LOOP
   ENDIF
 
   
   *REPLACE DAGGANCIO WITH X_TAGG
   
   IF TYPE("X_TAGG") == 'C'
      IF !EMPTY(X_TAGG)
         REPLACE DAGGANCIO WITH X_TAGG
      ENDIF
   ENDIF
   
   IF EMPTY(ORD_SYSMAG)
   		REPLACE ORD_SYSMAG WITH SYS(2015)		&& SI TRATTA DI UNA RIGA DDT CLIENTE , IDENTIFICO IL SYS DI LEGAME POI AL RECORD DI MAGAZZINO U_MAG_MO
   ENDIF
   
   _ORD_QTANRC_DDT = ORD_QTANRC  
   
   IF ALLTRIM(ORD_DESART) <> "*** COMMENTO ***"
   
	   DO CASE 
	   
			CASE ALLTRIM(ORD_FLGMOD) = 'I'			&& INSERIMENTO RECORD DDT 			## ARTICOLO VERO ##
				
				SCATTER MEMVAR MEMO
				
	   			*IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
	   			IF &cNomeVarPubSau AND !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART) AND !_XX_NOMAGAORDCLI  
		            =AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		            =AQM_VALORIZZA_VARIABILI_MAGAZZINO("MENU_BOL000")
		            *_YES_SCAR = AQM_SCARICA_MAGAZZINO_DDT()
		            _YES_SCAR = AQM_SCARICA_MAGAZZINO_DDT(.T.,.T.,_par_magd)  && ERASMO - 13/01/2014
		            IF _YES_SCAR
		            	SELECT CU_BOL_DD
		            	SCATTER MEMVAR MEMO
						=AQM_INSERISCE_RIGA_ARTICOLO_DDT()
		            ELSE
						MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze" + CHR(13) + CHR(13) + ;
							"I dettagli DDT non verranno aggiornati completamente",16,"Attenzione")
						SELECT CU_BOL_DD
						DELETE
						SKIP +1
						LOOP
		            ENDIF
	            
	            ELSE
	            
	            	SELECT CU_BOL_DD
					=AQM_INSERISCE_RIGA_ARTICOLO_DDT()
	            
	            ENDIF


			CASE ALLTRIM(ORD_FLGMOD) = 'M'			&& MODIFICA RECORD DDT 				## ARTICOLO VERO ##
				
				SCATTER MEMVAR MEMO
				
	   			*IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
	   			IF &cNomeVarPubSau AND !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART) AND !_XX_NOMAGAORDCLI  
	   				
	   				_OLD_LEGSYS = M.ORD_SYSMAG
	   				ORD_SYSMAG_RIGENERATO = ""			&& VIENE VALORIZZATA NELLA AQM_RICARICA_IL_MAGAZZINO
					
					*=AQM_RICARICA_IL_MAGAZZINO()
					=AQM_RICARICA_IL_MAGAZZINO("CU_BOL_DD",_par_magd_before)  && ERASMO - 13/01/2014
					
					DO AQM_ATTENDI_N_SECONDI WITH 1  	&& ATTENDO IL SECONDO SUCCESSIVO PER DIFFERENZIARE CRONOLOGICAMENTE I MOVIMENTI DI CARICO/SCARICO
					REPLACE ORD_SYSMAG WITH ORD_SYSMAG_RIGENERATO 	
					M.ORD_SYSMAG = ORD_SYSMAG_RIGENERATO
		            =AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		            =AQM_VALORIZZA_VARIABILI_MAGAZZINO("MENU_BOL000")
		            *_YES_SCAR = AQM_SCARICA_MAGAZZINO_DDT()
		            _YES_SCAR = AQM_SCARICA_MAGAZZINO_DDT(.T.,.T.,_par_magd)  && ERASMO - 13/01/2014
		            
		            IF _YES_SCAR
		            	SELECT CU_BOL_DD
		            	SCATTER MEMVAR MEMO
						=AQM_MODIFICA_RIGA_ARTICOLO_DDT()
		            ELSE
						MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze" + CHR(13) + CHR(13) + ;
							"I dettagli DDT non verranno aggiornati completamente",16,"Attenzione")
						SELECT CU_BOL_DD
						DELETE
						SKIP +1
						LOOP
		            ENDIF
	            
	            ELSE
	            	
	            	SELECT CU_BOL_DD
					=AQM_MODIFICA_RIGA_ARTICOLO_DDT()
	            
	            ENDIF
	            
	 
			CASE ALLTRIM(ORD_FLGMOD) = 'A'			&& ANNULLO RECORD DDT                ## ARTICOLO VERO ##
				
				SCATTER MEMVAR MEMO
				
	   			*IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
	   			IF &cNomeVarPubSau AND !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART) AND !_XX_NOMAGAORDCLI  
		            *=AQM_RICARICA_IL_MAGAZZINO()
		            =AQM_RICARICA_IL_MAGAZZINO("CU_BOL_DD",_par_magd_before)  && ERASMO - 13/01/2014
	            ENDIF
				
				SELECT CU_BOL_DD
	 			=AQM_CANCELLA_U_BOL_DD()
	 			
	 			
			CASE ALLTRIM(ORD_FLGMOD) = 'X'			&& INSERIMENTO RECORD DDT DA GENERAZIONE AUTOMATICA DDT
				
				SCATTER MEMVAR MEMO
				
	   			*IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
	   			IF &cNomeVarPubSau AND !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART) AND !_XX_NOMAGAORDCLI  
	            
		            =AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		            =AQM_VALORIZZA_VARIABILI_MAGAZZINO("MENU_BOL000")
		            _YES_SCAR = AQM_SCARICA_MAGAZZINO_DDT_GUIDATO()
		            IF _YES_SCAR
		            	SELECT CU_BOL_DD
						*=AQM_INSERISCE_RIGA_ARTICOLO_DDT()  && LA RIGA DDT VIENE SCRITTA DIRETTAMENTE DALL'APPLICAZIONE CHIAMANTE
		            ELSE
						MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze" + CHR(13) + CHR(13) + ;
							"I dettagli DDT non verranno aggiornati completamente",16,"Attenzione")
						SELECT CU_BOL_DD
						DELETE
						SKIP +1
						LOOP
		            ENDIF
	            
	            ELSE
	            	
	            	*SELECT CU_BOL_DD
					*=AQM_INSERISCE_RIGA_ARTICOLO_DDT()  && LA RIGA DDT VIENE SCRITTA DIRETTAMENTE DALL'APPLICAZIONE CHIAMANTE
	            
	            ENDIF
 		
 		ENDCASE

    ELSE
    	
    	SCATTER MEMVAR MEMO
    
    	DO CASE

			CASE ALLTRIM(ORD_FLGMOD) = 'I'			&& INSERISCE RECORD DDT              ## *** COMMENTO *** ##

	    		=AQM_INSERISCE_COMMENTI_AUTOMATICI_DDT()  


			CASE ALLTRIM(ORD_FLGMOD) = 'M'			&& MODIFICA RECORD DDT               ## *** COMMENTO *** ##

	    		=AQM_MODIFICA_COMMENTI_UTENTE_DDT()  
		
		
			CASE ALLTRIM(ORD_FLGMOD) = 'A'			&& ANNULLO RECORD DDT                ## *** COMMENTO *** ##

	    		=AQM_CANCELLA_COMMENTI_UTENTE_DDT()
	    		
	    		
			CASE ALLTRIM(ORD_FLGMOD) = 'X'			&& INSERISCE RECORD DDT DA GENERAZIONE AUTOMATICA DDT ## *** COMMENTO *** ##

	    		*=AQM_INSERISCE_COMMENTI_AUTOMATICI_DDT()  && LA RIGA DDT VIENE SCRITTA DIRETTAMENTE DALL'APPLICAZIONE CHIAMANTE
      
    	ENDCASE
   
   ENDIF
   
   RELEASE _ORD_QTANRC_DDT  
   
   SELECT CU_BOL_DD
   SKIP +1

ENDDO

SET DELETED ON   

IF _par_evaord AND !_XX_NOMAGAORDCLI  
	DO AQM_RICALCOLA_EVASIONE_ORDINI_CLIENTI WITH "CU_BOL_DD"
ENDIF

SELECT CU_BOL_DD
SET ORDER TO SEQUEN 
SET FILTER TO ORD_FLGMOD <> 'A'
GO TOP

*!*	**=> ERASMO - INIZIO 21/02/2014
*!*	IF USED("CU_BOL_SN")
*!*		SELECT CU_BOL_SN
*!*		USE
*!*	ENDIF
*!*	**=> ERASMO - FINE 21/02/2014

SELECT(_AQM_SDDTS)

RETURN(.T.)



***********************************************
FUNCTION AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO      && _________________________________________________________________________________________________________ VARIABILI DI GESTIONE DEL MAGAZZINO
***********************************************

*!*	____________________________________________________________________________________________________________________________________ VARIABILI PER L'ACCESSO A U_MAG_GG
RELEASE AQM_CODSOC,AQM_DATAGG,AQM_ORACAR,AQM_CODART,AQM_CODMAG,AQM_CODFOR,AQM_GIACEN,AQM_FILA_N,AQM_PIAN_N,AQM_UBIC_N,AQM_PRZCON,AQM_ANAART
PUBLIC  AQM_CODSOC,AQM_DATAGG,AQM_ORACAR,AQM_CODART,AQM_CODMAG,AQM_CODFOR,AQM_GIACEN,AQM_FILA_N,AQM_PIAN_N,AQM_UBIC_N,AQM_PRZCON,AQM_ANAART


*!*	____________________________________________________________________________________________________________________________________ VARIABILI TABELLA U_MAG_GG
RELEASE AQM_DADOVE,AQM_DESART,AQM_CODPDV,AQM_DESFOR,AQM_QTAKG,AQM_QTAMQ,AQM_QTAML,AQM_FILA_X,AQM_PIAN_X,AQM_UBIC_X
RELEASE AQM_CODCLI,AQM_DESCLI
RELEASE AQM_QUAPRO,AQM_CLIINV	 


PUBLIC  AQM_DADOVE,AQM_DESART,AQM_CODPDV,AQM_DESFOR,AQM_QTAKG,AQM_QTAMQ,AQM_QTAML,AQM_FILA_X,AQM_PIAN_X,AQM_UBIC_X
PUBLIC  AQM_CODCLI,AQM_DESCLI
PUBLIC  AQM_QUAPRO,AQM_CLIINV	 


*!*	____________________________________________________________________________________________________________________________________ VARIABILI TABELLA U_MAG_MO
RELEASE AQM_PRSPOT
RELEASE AQM_TOP,AQM_NUMDOC,AQM_DTDOCU,AQM_PREVEN,AQM_PREACQ,AQM_SCONTO,AQM_IVAVEN,AQM_DTREGI,AQM_UM,AQM_COORD,AQM_VALUTA
RELEASE AQM_SERIE,AQM_AAPROD,AQM_CODTAG,AQM_DESTAG,AQM_CODCOL,AQM_DESCOL,AQM_CODMAT,AQM_DESMAT,AQM_NOTVAR,AQM_CODPDV
RELEASE AQM_SEGNO,AQM_TIPMOV,AQM_LEGSYS,AQM_LEGAME,AQM_NUMORF,AQM_DATORF,AQM_NUMIDE,AQM_SPESSO,AQM_ALTEZZ,AQM_LUNGHE
RELEASE AQM_NRLINT,AQM_NRDBOB,AQM_SERBOL,AQM_SERNUM,AQM_NUMEDA,AQM_NUMEAL,AQM_CBFISC,AQM_NUMMOV
RELEASE AQM_SC1,AQM_SC2,AQM_SC3,AQM_NUMMOV,AQM_CODINT 
RELEASE AQM_QTAIMP,AQM_GMLIMP,AQM_GKGIMP 
RELEASE AQM_UNIQUE,AQM_SAVE_LEGSYS  

PUBLIC  AQM_PRSPOT
PUBLIC  AQM_TOP,AQM_NUMDOC,AQM_DTDOCU,AQM_PREVEN,AQM_PREACQ,AQM_SCONTO,AQM_IVAVEN,AQM_DTREGI,AQM_UM,AQM_COORD,AQM_VALUTA
PUBLIC  AQM_SERIE,AQM_AAPROD,AQM_CODTAG,AQM_DESTAG,AQM_CODCOL,AQM_DESCOL,AQM_CODMAT,AQM_DESMAT,AQM_NOTVAR,AQM_CODPDV
PUBLIC  AQM_SEGNO,AQM_TIPMOV,AQM_LEGSYS,AQM_LEGAME,AQM_NUMORF,AQM_DATORF,AQM_NUMIDE,AQM_SPESSO,AQM_ALTEZZ,AQM_LUNGHE
PUBLIC  AQM_NRLINT,AQM_NRDBOB,AQM_SERBOL,AQM_SERNUM,AQM_NUMEDA,AQM_NUMEAL,AQM_CBFISC,AQM_NUMMOV
PUBLIC  AQM_SC1,AQM_SC2,AQM_SC3,AQM_NUMMOV,AQM_CODINT  
PUBLIC  AQM_QTAIMP,AQM_GMLIMP,AQM_GKGIMP 
PUBLIC  AQM_UNIQUE,AQM_SAVE_LEGSYS  

RELEASE AQM_CDAFOR,AQM_OINFOR,AQM_PINFOR,AQM_DTPFOR,AQM_TRAFOR,AQM_NBAFOR,AQM_BDAFOR,AQM_BALFOR,AQM_PNKFOR
PUBLIC  AQM_CDAFOR,AQM_OINFOR,AQM_PINFOR,AQM_DTPFOR,AQM_TRAFOR,AQM_NBAFOR,AQM_BDAFOR,AQM_BALFOR,AQM_PNKFOR

RELEASE AQM_QUAPRO_MOV,AQM_CLIINV_MOV	 
PUBLIC  AQM_QUAPRO_MOV,AQM_CLIINV_MOV	 


RELEASE AQM_QTAMC
PUBLIC  AQM_QTAMC

RELEASE AQM_QTANR,AQM_GIANEG
PUBLIC  AQM_QTANR,AQM_GIANEG

RELEASE AQM_ORAMOV
PUBLIC  AQM_ORAMOV

RELEASE AQM_SERIAL
PUBLIC  AQM_SERIAL

**=> ERASMO - INIZIO 16/02/2015
*** VARIABILE PER MEMORIZZARE LA DATA ORIGINALE DI PRIMO CARICO (ES. CASO BOBINE FILM NUDO RICARICATE A MAGAZZINO IN PRODUZIONE SPALMATURA)
RELEASE AQM_DATORI
PUBLIC  AQM_DATORI
**=> ERASMO - FINE 16/02/2015

=AQM_PULISCE_VARIABILI_MAGAZZINO()

RETURN(.T.)

****************************************
FUNCTION AQM_PULISCE_VARIABILI_MAGAZZINO && _________________________________________________________________________________________________________ VARIABILI DI GESTIONE DEL MAGAZZINO
****************************************
*!*	____________________________________________________________________________________________________________________________________ VARIABILI PER L'ACCESSO A U_MAG_GG
AQM_CODSOC	= ""
AQM_DATAGG  = ""
AQM_ORACAR  = ""
AQM_CODART  = ""
AQM_CODMAG  = ""
AQM_CODFOR  = ""
AQM_GIACEN  = 0
AQM_FILA_N  = 0
AQM_PIAN_N  = 0
AQM_UBIC_N  = 0
AQM_PRZCON  = 0
