****************************************
FUNCTION AQM_RILEVA_GIACENZE_DISPONIBILI
****************************************

LPARAMETERS _par_codsoc,_par_anaart,_par_codmag,_par_prenot,_par_codint,_par_altezz,_par_lunghe,_par_fila_x,_par_pian_x,_par_ubic_x,_par_umrit,_par_escl_mag_scarto,_par_cond_aggiuntiva

IF PCOUNT() >= 11
	_par_umrit = ALLTRIM(_par_umrit)
ELSE
	_par_umrit = ""
ENDIF

IF PCOUNT() >= 12
ELSE
	_par_escl_mag_scarto = .T.
ENDIF

IF PCOUNT() >= 13
ELSE
	_par_cond_aggiuntiva = ""
ENDIF


LOCAL _AQM_SS
_AQM_SS=SELECT()

LOCAL _RIT
_RIT = 0

_x_soci = "mag_codsoc = '" + _par_codsoc + "'"
_x_data = "mag_datagg <> ''"
*_x_codi = "mag_anaart = '" + ALLTRIM(_par_anaart) + "'"
_x_codi = IIF(EMPTY(_par_anaart),"1=1","mag_anaart = '" + ALLTRIM(_par_anaart) + "'")
*** FILTRO SU MAGAZZINI MULTIPLI
IF !EMPTY(_par_codmag)
	IF "'" $ _par_codmag
		_x_maga = "mag_codmag IN (" + ALLTRIM(_par_codmag) + ")"
	ELSE
		_x_maga = "mag_codmag = '" + ALLTRIM(_par_codmag) + "'"
	ENDIF
ELSE
	_x_maga = "1=1"
ENDIF
_x_pren = IIF(_par_prenot = .F.,"1=1","mag_prenot = 0")
_x_disp = "(mag_giacen - mag_qtaimp) > 0"
_x_cint = IIF(EMPTY(_par_codint),"1=1","mag_codart = '" + ALLTRIM(_par_codint) + "'")
_x_alte = IIF(_par_altezz <= 0,"1=1","mag_altezz = " + ALLTRIM(STR(_par_altezz,7,0)))
_x_lung = IIF(_par_lunghe <= 0,"1=1","mag_lunghe = " + ALLTRIM(STR(_par_lunghe,8,0)))
_x_fila = IIF(EMPTY(_par_fila_x),"1=1","mag_fila_x = '" + ALLTRIM(_par_fila_x) + "'")
_x_pian = IIF(EMPTY(_par_pian_x),"1=1","mag_pian_x = '" + ALLTRIM(_par_pian_x) + "'")
_x_ubic = IIF(EMPTY(_par_ubic_x),"1=1","mag_ubic_x = '" + ALLTRIM(_par_ubic_x) + "'")
_x_scrt = IIF(!_par_escl_mag_scarto,"1=1","mag_codmag not in ('" + ALLTRIM(PUB_SPASCA) + "','" + ALLTRIM(PUB_SCAPPT) + "')")   
_x_cond = _x_soci + " and " + _x_data + " and " + _x_codi + " and " + _x_maga + " and " + _x_pren + " and " + _x_disp + " and " + ;
          _x_cint + " and " + _x_alte + " and " + _x_lung + " and " + _x_fila + " and " + _x_pian + " and " + _x_ubic + " and " + _x_scrt 
*_x_cond = STRTRAN(_x_cond," and 1=1","")
**=> ERASMO - INIZIO 22/09/2014
IF !EMPTY(_par_cond_aggiuntiva)
	_x_cond = _x_cond + " and " + ALLTRIM(_par_cond_aggiuntiva)
ENDIF
**=> ERASMO - FINE 22/09/2014
Csql = "select u_mag_gg.*, u_art_pr.art_ummaga as mag_ummaga from u_mag_gg left outer join u_art_pr on art_codpri = mag_anaart where " + _x_cond + ;
	" order by mag_datagg,mag_oracar,mag_codart"

IF !ExecCommand(cSql,"LOCAL_U_MAG_GG")
   return(.f.)
ENDIF
SELECT LOCAL_U_MAG_GG
GO TOP
IF EOF()
*!*		** SCARICA LA GIACENZA A LIVELLO DI ARTICOLO
*!*		_x_cond = _x_soci + " and " + _x_data + " and " + _x_codi + " and " + _x_pren + " and " + _x_disp + " and " + ;
*!*		          _x_cint + " and " + _x_alte + " and " + _x_lung + " and " + _x_scrt 
*!*		_x_cond = STRTRAN(_x_cond," and 1=1","")
*!*		Csql    = "select * from u_mag_gg where " + _x_cond + " order by mag_datagg,mag_oracar,mag_codart"
*!*		IF !ExecCommand(cSql,"LOCAL_U_MAG_GG")
*!*		   return(.f.)
*!*		ENDIF
	*** BLOCCO ASTERISCATO PERCHE' NON PIU' NECESSARIO,
	*** CREATO ORIGINARIAMENTE PER XILOPAN CAUSA GESTIONE SUPERFICIALE DEI MAGAZZINI DI CARICO
ENDIF
SELECT LOCAL_U_MAG_GG
GO TOP
SCAN
	*_RIT = _RIT + (MAG_GIACEN - MAG_QTAIMP)

	IF EMPTY(_par_umrit)
		_RIT = _RIT + (MAG_GIACEN - MAG_QTAIMP)
	ELSE
		_cNomeCampoQtaUm = "MAG_QTA" + _par_umrit
		_cTipoArticolo = CERCATIPO(MAG_ANAART)
		DO CASE
			CASE _cTipoArticolo = '6' AND _par_umrit = "NR"
				__n_MAG_QTANR = 0
				DO CASE
					CASE ALLTRIM(MAG_UMMAGA) == "MQ"
						__n_MAG_QTANR = TROVA_NR_DA_MQ_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN)
					CASE ALLTRIM(MAG_UMMAGA) == "MC"
						__n_MAG_QTANR = TROVA_NR_DA_MC_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN,MAG_SPESSO)
				ENDCASE
				_RIT = _RIT + __n_MAG_QTANR
			

			CASE _cTipoArticolo = '9' AND _par_umrit = "NR"
				__n_MAG_QTANR = 0
				DO CASE
					CASE ALLTRIM(MAG_UMMAGA) == "MQ"
						__n_MAG_QTANR = TROVA_NR_DA_MQ_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN)
					CASE ALLTRIM(MAG_UMMAGA) == "MC"
						__n_MAG_QTANR = TROVA_NR_DA_MC_LEGNO(MAG_ALTEZZ,MAG_LUNGHE,MAG_GIACEN,MAG_SPESSO)
				ENDCASE
				_RIT = _RIT + __n_MAG_QTANR
			
			OTHERWISE
				_RIT = _RIT + &_cNomeCampoQtaUm
		ENDCASE
	ENDIF
ENDSCAN

SELECT(_AQM_SS)

RETURN _RIT



*********************************
FUNCTION AQM_GESTIONE_CARICHI_BFO
*********************************

LPARAMETERS _par_routine_chiamante
IF PCOUNT() = 0
	_par_routine_chiamante = ""
ENDIF
_par_routine_chiamante = ALLTRIM(_par_routine_chiamante)

LOCAL _AQM_SDDTS
_AQM_SDDTS=SELECT()

AQM_NUMMOV_LOCALE = AQM_RILEVA_NUMERO_INTERNO()

XXX_NUMORD = M.ORD_NUMORD

DO CASE
	
	CASE _par_routine_chiamante == "MENU_BFO000" OR _par_routine_chiamante == "MENU_BFOPES"
		*** NEL BFO000 LA DATA DEL DOCUMENTO E' ORD_DATOR2 MENTRE LA DATA DI REGISTRAZIONE E' ORD_DATORD
		XXX_DATORD = IIF(SUBSTR(M.ORD_DATOR2,3,1) = '/',RIBALTA2(M.ORD_DATOR2),M.ORD_DATOR2)
		PUB_DATREG = IIF(SUBSTR(M.ORD_DATORD,3,1) = '/',M.ORD_DATORD,RIBALTA2(M.ORD_DATORD))
		
	CASE _par_routine_chiamante == "RICARICHI_PRODUZIONE"
		*** NEI RICARICHI DI PRODUZIONE (ES. RICARICHI FILM NUDO IN BOBINE NON COMPLETAMENTE SPALMATE) UTILIZZO COME DATA DOCUMENTO M.ORD_DATOR2, MENTRE LA DATA DI REGISTRAZIONE E' M.ORD_DATORD
		XXX_DATORD = IIF(SUBSTR(M.ORD_DATOR2,3,1) = '/',RIBALTA2(M.ORD_DATOR2),M.ORD_DATOR2)
		PUB_DATREG = IIF(SUBSTR(M.ORD_DATORD,3,1) = '/',M.ORD_DATORD,RIBALTA2(M.ORD_DATORD))

	OTHERWISE
		XXX_DATORD = IIF(SUBSTR(M.ORD_DATORD,3,1) = '/',RIBALTA2(M.ORD_DATORD),M.ORD_DATORD)
		IF TYPE("PUB_DATREG") = 'C'
		ELSE
			PUBLIC PUB_DATREG 
			PUB_DATREG = ""
		ENDIF
		IF EMPTY(PUB_DATREG) OR PUB_DATREG = "  /  /    "
			PUB_DATREG = IIF(SUBSTR(M.ORD_DATORD,3,1) = '/',M.ORD_DATORD,RIBALTA2(M.ORD_DATORD))
		ENDIF
		
ENDCASE
 

 
IF TYPE("PUB_ORAMOV") = 'C'
ELSE
	PUBLIC PUB_ORAMOV
	PUB_ORAMOV = ""
ENDIF
 

XXX_CAUS = M.ORD_CAUS
XXX_VALUTA = M.ORD_VALUTA
XXX_CODBUN = M.ORD_CODBUN
XXX_NUMIDE = M.ORD_NUMIDE

SELECT CU_BFO_DD
SET FILTER TO
GO TOP

DO WHILE .T. 

	IF EOF()
		EXIT
	ENDIF

	IF DELETED()
		SKIP +1
		LOOP
	ENDIF

	IF ALLTRIM(ORD_DESART) = "*** COMMENTO ***"
		SKIP +1
		LOOP
	ENDIF

	IF ORD_FLGMOD = 'I' .OR. ORD_FLGMOD = 'M' .OR. ORD_FLGMOD = 'A'
	ELSE
		SKIP +1
		LOOP
	ENDIF
	
	IF AQM_ARTICOLO_DA_NON_MOVIMENTARE(ORD_CODART)
		SKIP +1
		LOOP
    ENDIF
	
	IF EMPTY(ORD_SYSMAG)
		REPLACE ORD_SYSMAG WITH SYS(2015)
	ENDIF
	
	SCATTER MEMVAR MEMO
	
	XXX_FLGMOD = M.ORD_FLGMOD
	
	IF ALLTRIM(XXX_FLGMOD) == 'M' .OR. ALLTRIM(XXX_FLGMOD) == 'A'
		
		=AQM_ANNULLA_CARICO_MAGAZZINO()
		DO AQM_ATTENDI_N_SECONDI WITH 1  && ATTENDO IL SECONDO SUCCESSIVO PER DIFFERENZIARE CRONOLOGICAMENTE I MOVIMENTI DI CARICO/SCARICO
		SELECT CU_BFO_DD
		REPLACE ORD_SYSMAG WITH ORD_SYSMAG_RIGENERATO 	
		M.ORD_SYSMAG = ORD_SYSMAG_RIGENERATO
		
	ENDIF
	
	RELEASE M.ORD_TIPBOB  && ERASMO - 23/09/2014
	
	SELECT CU_BFO_DD
	SCATTER MEMVAR MEMO
	XXX_ANAART = M.ORD_CODART
	XXX_CODFOR = M.ORS_CODCLI
	X_TIPO = CERCATIPO(M.ORD_CODART)
	
	IF ALLTRIM(XXX_FLGMOD) == 'I' .OR. ALLTRIM(XXX_FLGMOD) == 'M'
		
		IF X_TIPO = '1' .OR. X_TIPO = '2' .OR. X_TIPO = '7'  && BOBINE O ADESIVI O BOBINE DI CARTE GREZZE (CARICHI DA GESTIRE TRAMITE CU_BFO_DL)   
			SELECT CU_BFO_DL
			SET FILTER TO
			SET FILTER TO DAGGANCIO = M.DAGGANCIO .AND. ORD_AGGORF = M.ORD_LEGAME .AND. ORD_SYSORF = M.ORD_LEGASY .AND. ORD_TIPMOV <> 'A'
			SET ORDER TO I_ORDINE
			GO TOP
			SCAN
				
				IF ALLTRIM(ORD_UM) == "KG"
					V_QTACTRL = ORD_QTAKG
				ELSE
					V_QTACTRL = ORD_QTAMQ
				ENDIF
				IF V_QTACTRL > 0
				ELSE
					DELETE
					SKIP +1
					LOOP
				ENDIF
				
				PUB_TIPOBOB = ""
				*IF X_TIPO = '1'
				IF X_TIPO = '1' .OR. X_TIPO = '7'   
					PUB_TIPOBOB = "FNU"
					IF ALLTRIM(M.ORD_UM) == "KG"   
					ELSE
						PUB_TIPOBOB = "SPA"
					ENDIF
				ELSE
					IF X_TIPO = '2'
						PUB_TIPOBOB = "ADE"
					ELSE
						PUB_TIPOBOB = ""
					ENDIF
				ENDIF
				
				IF TYPE("M.ORD_TIPBOB") == 'C'
					PUB_TIPOBOB = M.ORD_TIPBOB
					*RELEASE M.ORD_TIPBOB
				ENDIF
				
				SCATTER MEMVAR MEMO
				
				=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
				=AQM_VALORIZZA_VARIABILI_MAGAZZINO("CU_BFO_DD-DL")
				_YES_CAR = AQM_CARICA_MAGAZZINO()
				IF !_YES_CAR
					MESSAGEBOX("Si č verificato un errore generico durante il carico del magazzino" + CHR(13) + CHR(13) + ;
						"I dettagli BFO non verranno aggiornati completamente",16,"Attenzione")
					SELECT CU_BFO_DD
					DELETE
					SKIP +1
					LOOP
				ENDIF
	            
				SELECT CU_BFO_DL
				REPLACE ORD_NRLINT WITH AQM_NRLINT
				REPLACE ORD_CODART WITH AQM_CODART
				
				IF XXX_CAUS = 'BFO'
					*** AGGIORNAMENTO TABELLA U_PRD_D3 (BOBINE PER PRODUZIONE)
					SELECT CU_BFO_DL
					_WW_PJ_PRGPRD1 = PJ_PRGPRD1
					_WW_PJ_PRGPRD2 = PJ_PRGPRD2
					_WW_PJ_PRGPRD3 = PJ_PRGPRD3
					_WW_DAPRENOTARE = .F.
					x_pj_1 = "pj_prgprd1 = '" + ALLTRIM(PJ_PRGPRD1) + "'"
					x_pj_2 = "pj_prgprd2 = '" + ALLTRIM(PJ_PRGPRD2) + "'"
					x_pj_3 = "pj_prgprd3 = '" + ALLTRIM(PJ_PRGPRD3) + "'"
					x_cond = x_pj_1 + " and " + x_pj_2 + " and " + x_pj_3
					cSql	= "SELECT * FROM U_PRD_D3 WHERE " + x_cond
					IF !ExecRW(cSql,"U_PRD_D3","R")
						return(.f.)
					ENDIF
					SELECT U_PRD_D3
					GO TOP
					IF EOF()
					ELSE
						REPLACE PR3_CODINT WITH AQM_CODART
						REPLACE PR3_ALTCAR WITH M.ORD_ALTEZZ
						REPLACE PR3_LUNCAR WITH M.ORD_LUNGHE
						REPLACE PR3_SPECAR WITH M.ORD_SPESSO
						_WW_DAPRENOTARE = .T.
					ENDIF
					IF !ExecRW(cSql,"U_PRD_D3","W")
						return(.f.)
					ENDIF
					
					*** AGGIORNAMENTO FLAG DI 'PRENOTATO' SU GIACENZA DI MAGAZZINO U_MAG_GG (BOBINE PER PRODUZIONE)
					IF _WW_DAPRENOTARE
						x_cond = "mag_codart = '" + ALLTRIM(AQM_CODART) + "'"
						cSql   = "UPDATE U_MAG_GG SET MAG_PRENOT = 1 WHERE " + x_cond
						IF !ExecCommand(cSql,"UPD_MAG_GG")
							return(.f.)
						ENDIF
					ENDIF
				ENDIF
				
			ENDSCAN
		
		ELSE
			
			IF X_TIPO = '6' OR X_TIPO = '9'  					&& PANNELLI TRUCIOLARI / DADI PRESSATI
				AQM_CODINT = ""
				AQM_NRLINT = 0
				AQM_NUMERO_LOTTO_INTERNO(M.ORD_CODART)
				SELECT CU_BFO_DD
				REPLACE ORD_CODFIS WITH AQM_CODINT
				REPLACE ORD_NRLINT WITH AQM_NRLINT
				SCATTER MEMVAR MEMO
			ENDIF
			
			IF X_TIPO = '0' .AND. ALLTRIM(M.ORD_SERIE) = 'ZI'  && GESTIONE ARTICOLI FISCALI
			
				_NEW_NRLINTFISC = AQM_NUMERO_LOTTO_INTERNO_FISCALE()
				SELECT CU_BFO_DD
				REPLACE ORD_CODFIS WITH _NEW_NRLINTFISC
				REPLACE ORD_NRLINT WITH ROUND(VAL(SUBSTR(_NEW_NRLINTFISC,AT('.',_NEW_NRLINTFISC)+1)),0)
				SCATTER MEMVAR MEMO
							
			ENDIF
			
			*=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
			*=AQM_VALORIZZA_VARIABILI_MAGAZZINO("CU_BFO_DD")
			*_YES_CAR = AQM_CARICA_MAGAZZINO()
			*IF !_YES_CAR
			*	MESSAGEBOX("Si č verificato un errore generico durante il carico del magazzino" + CHR(13) + CHR(13) + ;
			*		"I dettagli BFO non verranno aggiornati completamente",16,"Attenzione")
			*	SELECT CU_BFO_DD
			*	DELETE
			*	SKIP +1
			*	LOOP
			*ENDIF
			
			**=> ERASMO - INIZIO 24/02/2014
			*** GESTIONE SERIAL NUMBERS SE RELATIVO CURSORE ESISTENTE E VALORIZZATO
			IF USED("CU_BFO_SN")
				SELECT CU_BFO_SN
				SET FILTER TO DAGGANCIO = M.DAGGANCIO AND CODSYS = M.ORD_CODSYS
				GO TOP
				IF EOF()
					=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
					=AQM_VALORIZZA_VARIABILI_MAGAZZINO("CU_BFO_DD")
					_YES_CAR = AQM_CARICA_MAGAZZINO()
					IF !_YES_CAR
						MESSAGEBOX("Si č verificato un errore generico durante il carico del magazzino" + CHR(13) + CHR(13) + ;
							"I dettagli BFO non verranno aggiornati completamente",16,"Attenzione")
						SELECT CU_BFO_DD
						DELETE
						SKIP +1
						LOOP
					ENDIF
				ELSE
					SCAN
						M.ORS_NLOTFO = SERIAL
						M.ORD_QTAORD = QUANTI
						
						=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
						=AQM_VALORIZZA_VARIABILI_MAGAZZINO("CU_BFO_DD")
						_YES_CAR = AQM_CARICA_MAGAZZINO()
						IF !_YES_CAR
							MESSAGEBOX("Si č verificato un errore generico durante il carico del magazzino" + CHR(13) + CHR(13) + ;
								"I dettagli BFO non verranno aggiornati completamente",16,"Attenzione")
							SELECT CU_BFO_DD
							DELETE
							SKIP +1
							LOOP
						ENDIF
					ENDSCAN
				ENDIF
							
				SELECT CU_BFO_SN
				SET FILTER TO
				GO TOP
			ELSE
				=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
				=AQM_VALORIZZA_VARIABILI_MAGAZZINO("CU_BFO_DD")
				_YES_CAR = AQM_CARICA_MAGAZZINO()
				IF !_YES_CAR
					MESSAGEBOX("Si č verificato un errore generico durante il carico del magazzino" + CHR(13) + CHR(13) + ;
						"I dettagli BFO non verranno aggiornati completamente",16,"Attenzione")
					SELECT CU_BFO_DD
					DELETE
					SKIP +1
					LOOP
				ENDIF
			ENDIF
			
			IF PUB_GIANEG AND PUB_GNELAU
				DO AQM_ELIMINA_GIACENZE_NEGATIVE WITH M.ORD_MAGA,M.ORD_CODART,M.ORD_ALTEZZ,M.ORD_LUNGHE,"ELIMINA U_MAG_GG"
			ENDIF
			
		ENDIF
				

		*** SCARICO AUTOMATICO MATERIALE IN CONTO LAVORO LEGATO
		SELECT CU_BFO_DD
		IF !EMPTY(ORD_SYSCTL)
			_XX_SYSCTL = ORD_SYSCTL
			_XX_QTACTL = ORD_QTACTL
			_XX_QTAORD = ORD_QTAORD   
			x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
			x_uniq = "mag_unique = '" + _XX_SYSCTL + "'"
			x_data = "mag_datagg <> SPACE(10)"
			x_giac = "mag_giacen > 0"
			x_cond = x_soci + " and " + x_uniq + " and " + x_data + " and " + x_giac
			cSql   = "select * from u_mag_gg where " + x_cond
			IF !ExecCommand(cSql,'CU_MAG_GM')
			   return(.f.)
			ENDIF
			SELECT CU_MAG_GM
			GO TOP
			IF !EOF()
				SCATTER MEMVAR MEMO
				*** VALORIZZAZIONE VARIABILI CHE DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA (LA QUANTITA' DA SCARICARE E' CONTENUTA IN CU_MAG_GM.MAG_GIACEN)
				=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
				=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
				*** VALORIZZAZIONE VARIABILI CHE NON DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA
				AQM_DTDOCU = XXX_DATORD
				AQM_NUMDOC = XXX_NUMORD
				AQM_CODCLI = XXX_CODFOR
				AQM_TOP    = PUB_CTLO
				AQM_DTREGI = XXX_DATORD
				AQM_VALUTA = XXX_VALUTA
				AQM_LEGSYS = SYS(2015)
				AQM_GIACEN = _XX_QTACTL
				DO AQM_IMPEGNA_DISIMPEGNA_MAGAZZINO WITH "-",M.MAG_UNIQUE,AQM_GIACEN
				_OK_SCAR = AQM_SCARICA_MAGAZZINO()
				IF _OK_SCAR
					SELECT CU_BFO_DD
					REPLACE ORD_MOVCTL WITH AQM_LEGSYS
				ELSE
					MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze per conto lavoro",16,"Attenzione")
				ENDIF

			ELSE
				x_ctls = "ord_ctlsys = '" + _XX_SYSCTL + "'"
				x_soci = "mag_codsoc = '" + PUB_CODSOC + "'"
				x_data = "mag_datagg <> SPACE(10)"
				x_giac = "mag_giacen > 0"
				x_cond = x_ctls + " and " + x_soci + " and " + x_data + " and " + x_giac
				*cSql   = "SELECT ORD_CTLSYS,ORD_QTACTL,ORD_SYSMAG,MOV_LEGAME,U_MAG_GG.* FROM U_BOL_DD " + CHR(13) + ;
				         "LEFT OUTER JOIN U_MAG_MO ON MOV_LEGSYS = ORD_SYSMAG AND MOV_SEGNO = '+' " + CHR(13) + ;
				         "LEFT OUTER JOIN U_MAG_GG ON MAG_LEGAME = MOV_LEGAME WHERE " + x_cond	
				cSql   = "SELECT ORD_CTLSYS,ORD_QTACTL,ORD_SYSMAG,MOV_LEGAME,U_MAG_GG.* FROM U_BOL_DD " + CHR(13) + ;
				         "LEFT OUTER JOIN U_MAG_MO ON MOV_LEGSYS = ORD_SYSMAG AND MOV_SEGNO = '+' " + CHR(13) + ;
				         "LEFT OUTER JOIN U_MAG_GG ON MAG_LEGAME = MOV_LEGAME AND MAG_CODMAG = MOV_CODMAG WHERE " + x_cond	&& ERASMO - 30/12/2014 *** SICCOME IL MAG_LEGAME VIENE TRASPORTATO, FILTRO ANCHE PER MAGAZZINO, ALTRIMENTI POTREI TROVARE IL RECORD SBAGLIATO
				IF !ExecCommand(cSql,'CU_MAG_GM')
				   return(.f.)
				ENDIF
				SELECT CU_MAG_GM
				GO TOP
				IF !EOF()
					_XY_MOVCTL_LEGSYS = SYS(2015)
					SCAN
						SCATTER MEMVAR MEMO
						_XX_QTACTL = M.ORD_QTACTL
						_PERC_DA_SCAR = MIN(1,_XX_QTACTL / _XX_QTAORD)
						*** VALORIZZAZIONE VARIABILI CHE DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA (LA QUANTITA' DA SCARICARE E' CONTENUTA IN CU_MAG_GM.MAG_GIACEN)
						=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
						=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
						*** VALORIZZAZIONE VARIABILI CHE NON DIPENDONO DALLA RIGA DI GIACENZA SELEZIONATA
						AQM_DTDOCU = XXX_DATORD
						AQM_NUMDOC = XXX_NUMORD
						AQM_CODCLI = XXX_CODFOR
						AQM_TOP    = PUB_CTLO
						AQM_DTREGI = XXX_DATORD
						AQM_VALUTA = XXX_VALUTA
						AQM_LEGSYS = _XY_MOVCTL_LEGSYS
						AQM_GIACEN = M.MAG_QTAIMP * _PERC_DA_SCAR
						IF AQM_GIACEN > MAG_GIACEN
							AQM_GIACEN = M.MAG_GIACEN
						ENDIF
						DO AQM_IMPEGNA_DISIMPEGNA_MAGAZZINO WITH "-",M.MAG_UNIQUE,AQM_GIACEN
						_OK_SCAR = AQM_SCARICA_MAGAZZINO()
						IF _OK_SCAR
							SELECT CU_BFO_DD
							REPLACE ORD_MOVCTL WITH AQM_LEGSYS
						ELSE
							MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze per conto lavoro",16,"Attenzione")
						ENDIF
					ENDSCAN
				ENDIF
			ENDIF
		ENDIF

		
	ENDIF
	
	SELECT CU_BFO_DD
	SKIP +1

ENDDO

RELEASE PUB_DATREG   
RELEASE PUB_ORAMOV

SELECT(_AQM_SDDTS)

RETURN


*****************************
FUNCTION AQM_CARICA_MAGAZZINO
*****************************
**=> ERASMO - INIZIO 04/02/2015
LPARAMETERS _par_forza_legame

IF PCOUNT() >=1
ELSE
	_par_forza_legame = ""
ENDIF
**=> ERASMO - FINE 04/02/2015

LOCAL _AQM_SEL
_AQM_SEL=SELECT()

_OK_CARICA_MAGAZZINO = .F.

=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

*LOCAL_LEGAME 			= SYS(2015)  && NUOVO VALORE PER IL CAMPO DI LEGAME TRA U_MAG_GG E U_MAG_MO
**=> ERASMO - INIZIO 04/02/2015
*** SE PILOTATO DA PARAMETRO, FORZO LO STESSO LEGAME ORIGINARIO PER NON PERDERE IL RIFERIMENTO AL MOVIMENTO ORIGINALE 
*** IN CUI E' PRESENTE LA DATA DOCUMENTO DA CUI RICALCOLARE IL CAMBIO IN CASO DI ACQUISTO CON VALUTA ESTERA
IF !EMPTY(_par_forza_legame)
	LOCAL_LEGAME = _par_forza_legame
ELSE
	LOCAL_LEGAME = SYS(2015)  && NUOVO VALORE PER IL CAMPO DI LEGAME TRA U_MAG_GG E U_MAG_MO
ENDIF
**=> ERASMO - FINE 04/02/2015
AQM_LEGAME 				= LOCAL_LEGAME
ORIGINALE_AQM_LEGAME 	= LOCAL_LEGAME
LOCAL_DATAOGGI 			= RIBALTA2(DTOC(DATE()))
ORIGINALE_AQM_CODFOR 	= AQM_CODFOR
ORIGINALE_AQM_DESFOR 	= AQM_DESFOR
ORIGINALE_AQM_PREACQ 	= AQM_PREACQ
ORIGINALE_AQM_SC1 		= AQM_SC1
ORIGINALE_AQM_SC2 		= AQM_SC2
ORIGINALE_AQM_SC3 		= AQM_SC3
ORIGINALE_AQM_SC4 		= 0
ORIGINALE_AQM_SC5 		= 0
ORIGINALE_AQM_GIACEN 	= AQM_GIACEN
ORIGINALE_AQM_QTAKG 	= AQM_QTAKG
ORIGINALE_AQM_QTAMQ 	= AQM_QTAMQ
ORIGINALE_AQM_QTAML 	= AQM_QTAML
ORIGINALE_AQM_QTAMC 	= AQM_QTAMC   
ORIGINALE_AQM_NUMIDE 	= AQM_NUMIDE
ORIGINALE_AQM_PREACQ 	= AQM_PREACQ

LOCAL_CSC = ""		 
LOCAL_TOPCAR = ""	 
=ACCESSO_PARAMETRO_TOP()
=ACCESSO_ANAGRAFICA_FORNITORE()
=ACCESSO_ANAGRAFICA_CLIENTE()
=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)

=AQM_CREA_U_MAG_MO("CREA-MOVIMENTO")		&& ################################### CREA IL MOVIMENTO ###################################

Csql = "select * from u_mag_gg where 1=0"
IF !ExecRW(Csql,"u_mag_gg","R")
	return(.f.)
ENDIF


=AQM_CREA()									&& ################################### CREA LA GIACENZA ###################################
IF !ExecRW(cSql,"U_MAG_GG","W")				&& ################################### CREA LA GIACENZA ###################################
	return(.f.)								&& ################################### CREA LA GIACENZA ###################################
ENDIF										&& ################################### CREA LA GIACENZA ###################################

SELECT(_AQM_SEL)

_OK_CARICA_MAGAZZINO = .T.

IF TYPE("XXY_CODINT") == 'C'
	XXY_CODINT = AQM_CODINT
ENDIF
IF TYPE("XXY_NRLINT") == 'N'
	XXY_NRLINT = AQM_NRLINT
ENDIF
IF TYPE("XXY_UNIQUE") == 'C'
	XXY_UNIQUE = AQM_UNIQUE
ENDIF
**=> ERASMO - INIZIO 09/04/2015
IF TYPE("XXY_LEGAME") == 'C'
	XXY_LEGAME = AQM_LEGAME
ENDIF
**=> ERASMO - FINE 09/04/2015

IF LOCAL_CSC == "X"
	=AQM_DEFINISCE_VARIABILI_DISTINTA_BASE()
	_XDB_FLAG		= "NO"					&& SE = SI CARICA IN AUTOMATICO ANCHE IL PRODOTTO FINITO
	_XDB_MOVIM		= "SI"					&& CREA I MOVIMENTI SU U_MAG_MO
	_XDB_QTA		= AQM_GIACEN			&& QUANTITA' MOVIMETATA
	_XDB_TOP		= LOCAL_TOPCAR			&& TOP DI SCARICO COMPONENTE
	_XDB_TOPC		= AQM_TOP				&& TOP CONTRARIO USATO PER IL CARICO DEL GRUPPO
	_XDB_COD		= AQM_ANAART			&& CODICE ARTICOLO			
	_XDB_MAG		= AQM_CODMAG			&& CODICE MAGAZZIO
	_XDB_CODCLI		= AQM_CODCLI			&& CODICE CLIENTE
	_XDB_DATA		= AQM_DTDOCU			&& DATA DOCUMETO
	_XDB_NUMDOC		= AQM_NUMDOC			&& NUMERO DOCUMENTO
	_XDB_DTREGI		= AQM_DTREGI			&& DATA REGISTRAZIONE
	_XDB_CODFOR     = ""					&& CODICE FORNITORE PER CARICO AUTOMATICO PRODOTTO FINITO
	_OK_SCARICO_DIBA = AQM_SCARICA_COMPONENTI_DISTINTA_BASE()	&& FUNZIONE DI SCARICO DEI COMPONENTI DELLA DISTINTA BASE
ENDIF

RETURN _OK_CARICA_MAGAZZINO


*************************************
FUNCTION AQM_ANNULLA_CARICO_MAGAZZINO
*************************************

*!*	(-----) CREA IL MOVIMENTO DI SCARICO PER LA QUANTITA' IN PRECEDENZA MOVIMENTATA SU U_MAG_MO
*!*	(-----) SOTTRAE LA QUANTITA' IN PRECEDENZA MOVIMENTATA SU U_MAG_GG

LOCAL _AQM_SEL
_AQM_SEL=SELECT()

=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

ORD_SYSMAG_RIGENERATO 	= SYS(2015)							&& POSSO GESTIRE PIU RECORD U_MAG_MO , IL LEGSYS RIGENERATO DEVE ESSERE UNICO
*AQM_LEGSYS				= ORD_SYSMAG_RIGENERATO 			&& SER-01 RIGENERA ORD_SYSMAG PER LEGARE LA RIGA DDT AL NUOVO U_MAG_MO CHE CREO

LOCAL_CODSYS_RIGA_DDT	= M.ORD_CODSYS
LOCAL_LEGSYS 			= M.ORD_SYSMAG
LOCAL_QTAORD 			= M.ORD_QTAORD
LOCAL_QTAMQ  			= M.ORD_QTAMQ
LOCAL_QTAKG  			= M.ORD_QTAKG
LOCAL_QTAML  			= M.ORD_QTAML
LOCAL_QTAMC  			= M.ORD_QTAMC   
LOCAL_CAUS_DDT			= M.ORD_CAUS

_YY_SYSCTL = M.ORD_SYSCTL
_YY_QTACTL = M.ORD_QTACTL
_YY_MOVCTL = M.ORD_MOVCTL

_e_cond = "mov_legsys = '" + LOCAL_LEGSYS + "'"
Csql    = "select * from u_mag_mo where " + _e_cond
IF !ExecCommand(cSql,"LOCAL_U_MAG_MO")
	return(.f.)
ENDIF

SELECT LOCAL_U_MAG_MO
GO TOP
IF EOF()
	RETURN(.F.)
ENDIF
DO WHILE !EOF()
	
	SELECT LOCAL_U_MAG_MO
	
	AQM_QTAMOV_MOVIMENTATA_PRIMA_DELLA_MODIFICA_RIGA_DDT = MOV_QTAMOV 
	
	DO AQM_CONTRASSEGNA_MOVIMENTO_DOCMOD WITH MOV_UNIQUE

	SELECT LOCAL_U_MAG_MO
	SCATTER MEMVAR MEMO
	M.ID_UNIQUE = ""
	LOCAL_LEGAME = M.MOV_LEGAME  && SYS DI AGGANCIO A U_MAG_GG		
	M.MOV_TOP = PUB_MMEN  && SOSTITUISCO IL TOP IN QUANTO STO RICARICANDO LA VECCHIA GIACENZA
	
	=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
	=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_MOVIMENTO_MAGAZZINO")		
    AQM_SAVE_LEGSYS 		= ""
    LOCAL_IDUNIQUE			= ""
 	LOCAL_DATAOGGI   		= RIBALTA2(DTOC(DATE()))
 
	ORIGINALE_AQM_GIACEN 	= AQM_GIACEN											&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE									
	ORIGINALE_AQM_QTAKG  	= AQM_QTAKG												&& GIACENZA DEL PRECEDENTE MOVIMENTO DA RICARICARE						
