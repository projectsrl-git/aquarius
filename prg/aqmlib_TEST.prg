**********************************************************************
PROCEDURE AQM_ELIMINA_GIACENZE_NEGATIVE
**********************************************************************
LPARAMETERS _A_CODMAG,_A_ANAART,_A_ALTEZZ,_A_LUNGHE,_A_TIPO_INTERVENTO

IF PCOUNT() < 5
	MESSAGEBOX("Parametri insufficienti",16,"Attenzione")
	RETURN .F.
ENDIF

LOCAL ACT_SEL
ACT_SEL = SELECT()


*** ANNULLO EVENTUALI GIACENZE NEGATIVE A LIVELLO DI MAGAZZINO/ARTICOLO

x_maga = "MAG_CODMAG = '" + ALLTRIM(_A_CODMAG) + "'"
x_arti = "MAG_ANAART = '" + ALLTRIM(_A_ANAART) + "'"
x_data = "MAG_DATAGG <> ''"
x_giac = "MAG_GIACEN < 0"
x_cond = x_maga + " and " + x_arti + " and " + x_data + " and " + x_giac
Csql   = "SELECT MAG_CODMAG AS CODMAG, MAG_ANAART AS ANAART, SUM(MAG_GIACEN) AS GIA_NEG, CAST(0 as numeric(19,4)) AS GIA_MOV, SPACE(20) AS TIPO_INTERVENTO FROM U_MAG_GG " + CHR(13) + ;
         "WHERE " + x_cond + CHR(13) + ;
         "GROUP BY MAG_CODMAG, MAG_ANAART"
IF !ExecCommand(Csql,"CX_MAG_GN")
   return(.f.)
ENDIF
SELECT CX_MAG_GN
GO TOP
SCAN
	_X_GIA_MOV = 0		
	cSql=""     
	cNomeCursorSql="Gn_giac_mov"
	TEXT TO cSql NOSHOW
		SELECT 
			MOV_ANAART AS MOV_ANAART,
			MOV_CODMAG AS MOV_CODMAG,
			SUM(MOV_QTAMOV * CASE  MOV_SEGNO WHEN '+' THEN 1 ELSE -1 END ) AS MOV_QTAMOV
			FROM U_MAG_MO
			WHERE	MOV_DOCMOD = 0  AND  
					MOV_ANAART = '<<_A_ANAART>>' AND 
					MOV_CODMAG = '<<_A_CODMAG>>'
			GROUP BY MOV_ANAART,MOV_CODMAG
	ENDTEXT
	IF !ExecPreparedCommand(cSql,cNomeCursorSql)
		return(.F.)
	ENDIF
	SELECT Gn_giac_mov
	GO TOP
	IF !EOF()
		_X_GIA_MOV = MOV_QTAMOV
	ENDIF
	SELECT CX_MAG_GN
	REPLACE GIA_MOV WITH _X_GIA_MOV 
	
	IF GIA_MOV >= 0
		&& SALDO MOVIMENTI POSITIVO, GIACENZA NEGATIVA ELIMINABILE
		REPLACE TIPO_INTERVENTO WITH "ELIMINA U_MAG_GG"
	ELSE
		&& SALDO MOVIMENTI NEGATIVO, E' POSSIBILE FARE UNA COMPENSAZIONE CANCELLANDO U_MAG_GG E CREANDO IL MOVIMENTO CARICO DI MAGAZZINO SU U_MAG_GG/U_MAG_MO
		REPLACE TIPO_INTERVENTO WITH "COMPENSA U_MAG_GG"
	ENDIF
	
	SELECT CX_MAG_GN
	
	IF !EMPTY(_A_TIPO_INTERVENTO)
		IF _A_TIPO_INTERVENTO <> TIPO_INTERVENTO
			LOOP
		ENDIF
		IF _A_TIPO_INTERVENTO <> TIPO_INTERVENTO
			LOOP
		ENDIF
	ENDIF
	
	DO CASE
	
		CASE ALLTRIM(TIPO_INTERVENTO) == "COMPENSA U_MAG_GG"
			__CODICE_MAGAZZINO = CODMAG
			__CODICE_ARTICOLO = ANAART
			__ALTEZZ   = 0
			__LUNGHE   = 0
			__GIACENZA = ABS(GIA_NEG)
			_SCARICA_IMPEGNATO = .F.
			=AQM_CARICA_GIACENZE_NEGATIVE("01/01/1900","31/12/2999",__CODICE_MAGAZZINO,__CODICE_ARTICOLO,__GIACENZA,_SCARICA_IMPEGNATO,__ALTEZZ,__LUNGHE,DTOC(DATE()))
			
		CASE ALLTRIM(TIPO_INTERVENTO) == "ELIMINA U_MAG_GG"
			__CODICE_MAGAZZINO = CODMAG
			__CODICE_ARTICOLO = ANAART 
			__ALTEZZ 	= 0 
			__LUNGHE	= 0
			__GIACENZA  = ABS(GIA_NEG)
			_SCARICA_IMPEGNATO = .F.
			=AQM_SCARICA_DALLA_GIACENZA_PIU_VECCHIA(__CODICE_MAGAZZINO,__CODICE_ARTICOLO,__GIACENZA,_SCARICA_IMPEGNATO,__ALTEZZ,__LUNGHE,DTOC(DATE()))
			__DATADA = "01/01/1900"
			__DATAAL = "31/12/2999"
			cSql=""     
			cNomeCursorSql="DEL_MAG_GG"
			TEXT TO cSql NOSHOW
				DELETE	FROM U_MAG_GG 
				WHERE   MAG_DATAGG BETWEEN '<<RIBALTA2(__DATADA)>>' AND '<<RIBALTA2(__DATAAL)>>'  AND
						MAG_DATAGG <> ''	AND 
						MAG_GIACEN < 0		AND
						MAG_ANAART = '<<__CODICE_ARTICOLO>>'
			ENDTEXT
			IF !ExecPreparedCommand(cSql,cNomeCursorSql)
				return(.F.)
			ENDIF
		
	ENDCASE
	
ENDSCAN


SELECT(ACT_SEL)

RETURN


**=> ERASMO - INIZIO 19/09/2014
************************************************************************************************************************
PROCEDURE AQM_DATI_ULTIMA_MOVIMENTAZIONE_ARTICOLO
************************************************************************************************************************
LPARAMETERS _par_segno,_par_anaart,_par_aggiorna,_par_dtdocu,_par_numdoc,_par_qtamov,_par_preacq,_par_valuta,_par_legame 

IF PCOUNT() >= 1
ELSE
	_par_segno = ""
ENDIF

IF PCOUNT() >= 2
ELSE
	_par_anaart = ""
ENDIF

IF PCOUNT() >= 3
ELSE
	_par_aggiorna = .F.
ENDIF

IF PCOUNT() >= 4
ELSE
	_par_dtdocu = ""
ENDIF

IF PCOUNT() >= 5
ELSE
	_par_numdoc = ""
ENDIF

IF PCOUNT() >= 6
ELSE
	_par_qtamov = 0
ENDIF

IF PCOUNT() >= 7
ELSE
	_par_preacq = 0
ENDIF

IF PCOUNT() >= 8
ELSE
	_par_valuta = ""
ENDIF

IF PCOUNT() >= 9
ELSE
	_par_legame = ""
ENDIF

*** MEMORIZZO I DATI RELATIVI ALL'ULTIMA MOVIMENTAZIONE DI QUESTO ARTICOLO IN VARIABILI LOCALI
LOCAL _locANAART,_locNUMDOC,_locDTDOCU,_locQTAMOV,_locPREACQ,_locLEGAME
_locANAART = _par_anaart
_locNUMDOC = _par_numdoc 
_locDTDOCU = _par_dtdocu 
_locQTAMOV = _par_qtamov 
_locPREACQ = _par_preacq 
_locVALUTA = _par_valuta 
_locLEGAME = _par_legame

*** VALORIZZO VARIABILI PUBBLICHE PER UTILIZZARLE COME VARIABILI DI RITORNO ALLA ROUTINE CHIAMANTE
RELEASE PUB_ULNCAR,PUB_ULDCAR,PUB_ULQCAR,PUB_ULPCAR,PUB_ULNSCA,PUB_ULDSCA,PUB_ULQSCA,PUB_ULPSCA
PUBLIC PUB_ULNCAR,PUB_ULDCAR,PUB_ULQCAR,PUB_ULPCAR,PUB_ULNSCA,PUB_ULDSCA,PUB_ULQSCA,PUB_ULPSCA
PUB_ULNCAR = _locNUMDOC
PUB_ULDCAR = _locDTDOCU
PUB_ULQCAR = _locQTAMOV
PUB_ULPCAR = _locPREACQ
PUB_ULNSCA = _locNUMDOC
PUB_ULDSCA = _locDTDOCU
PUB_ULQSCA = _locQTAMOV
PUB_ULPSCA = _locPREACQ

IF EMPTY(_locANAART)
	RETURN
ENDIF

LOCAL _ACT_SELECT
_ACT_SELECT = SELECT()

*** SE I DATI RELATIVI ALL'ULTIMA MOVIMENTAZIONE DI QUESTO ARTICOLO SONO VUOTI O NON
*** VENGONO PASSATI PROCEDO ALLA RICERCA DI QUESTI DATI SUI MOVIMENTI DI MAGAZZINO
IF EMPTY(_locANAART) OR EMPTY(_locNUMDOC) OR EMPTY(_locDTDOCU) OR EMPTY(_locQTAMOV) OR EMPTY(_locPREACQ) OR EMPTY(_locVALUTA) OR EMPTY(_locLEGAME)
	x_arti = "MOV_ANAART = '" + _locANAART + "'"
	x_segn = "MOV_SEGNO = '" + _par_segno + "'"
	x_data = IIF(EMPTY(_locDTDOCU),"1=1","MOV_DTREGI <= '" + _locDTDOCU + "'")
	x_spot = "MOV_PRSPOT = 0"  && ERASMO - 29/09/2014
	x_gine = "MOV_NUMDOC <> 'Gn'"  && ERASMO - 26/01/2015 - ESCLUDE MOVIMENTI AUTOMATICI DI CARICO GIACENZE NEGATIVE
	x_cond = x_arti + " and " + x_segn + " and " + x_data + " and " + x_spot + " and " + x_gine 
	cSql = "SELECT TOP 1 MOV_ANAART, MOV_NUMDOC, MOV_DTDOCU, MOV_QTAMOV, MOV_PREACQ, MOV_VALUTA, MOV_LEGAME FROM U_MAG_MO WHERE " + x_cond + " ORDER BY MOV_DTREGI DESC, MOV_ORAMOV DESC"
	IF !ExecCommand(Csql,"TMP_MAG_MO")
	   return(.f.)
	ENDIF
	SELECT TMP_MAG_MO
	IF !EOF()
		_locNUMDOC = MOV_NUMDOC 
		_locDTDOCU = MOV_DTDOCU 
		_locQTAMOV = MOV_QTAMOV 
		_locPREACQ = MOV_PREACQ 
		_locVALUTA = MOV_VALUTA 
		_locLEGAME = MOV_LEGAME
	ELSE
		SELECT(_ACT_SELECT)
		RETURN
	ENDIF
ENDIF

*** SE MOVIMENTO DI SCARICO, CERCO LA VALUTA EFFETTIVA DAL MOVIMENTO DI ACQUISTO LEGATO
IF _par_segno = '-' AND !EMPTY(_locLEGAME)
	x_lega = "MOV_LEGAME = '" + _locLEGAME + "'"
	x_segn = "MOV_SEGNO = '+'"
	x_cond = x_lega + " and " + x_segn
	cSql = "SELECT TOP 1 MOV_VALUTA FROM U_MAG_MO WHERE " + x_cond + " ORDER BY MOV_DTREGI, MOV_ORAMOV"
	IF !ExecCommand(Csql,"TMP_MAG_MO")
	   return(.f.)
	ENDIF
	SELECT TMP_MAG_MO
	IF !EOF()
		_locVALUTA = MOV_VALUTA
	ENDIF
ENDIF

*** CONVERSIONE DEL PREZZO DI ACQUISTO NELL'ULTIMO CAMBIO DISPONIBILE ALLA DATA DOCUMENTO DEL MOVIMENTO
IF ALLTRIM(_locVALUTA) <> ALLTRIM(PUB_VALRIF)
	__PREZZO_VALRIF = 0
	x_cval = "VVA_CODVAL = '" + _locVALUTA + "'"
	x_data = "VVA_DATA <= '" + _locDTDOCU + "'"
	x_cond = x_cval + " and " + x_data
	cSql = "SELECT TOP 1 * FROM U_VVA_CH WHERE " + x_cond + " ORDER BY VVA_DATA DESC"
	IF !ExecCommand(Csql,"CURS_VVA_CH")
	   return(.f.)
	ENDIF
	SELECT CURS_VVA_CH
	IF !EOF()
		__CAMBIO_RECENTE = VVA_CHANGE
		__PREZZO_VALRIF = CAMBIO(_locVALUTA,_locPREACQ,__CAMBIO_RECENTE,"",.F.,6)
	ENDIF
	_locPREACQ = __PREZZO_VALRIF
ENDIF

PUB_ULNCAR = _locNUMDOC
PUB_ULDCAR = _locDTDOCU
PUB_ULQCAR = _locQTAMOV
PUB_ULPCAR = _locPREACQ
PUB_ULNSCA = _locNUMDOC
PUB_ULDSCA = _locDTDOCU
PUB_ULQSCA = _locQTAMOV
PUB_ULPSCA = _locPREACQ

*** AGGIORNAMENTO SCHEDA "MOVIMENTAZIONI" DELL'ANAGRAFICA ARTICOLI
IF _par_aggiorna
	cSql = ""
	IF _par_segno = '+'
		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "ART_CODPRI = '" + _locANAART + "'"
		x_cond = x_soci + " and " + x_codi 
		cSql = "SELECT * FROM U_ART_PR WHERE " + x_cond
		IF !ExecRW(Csql,"U_ART_PR","R")
		   return(.f.)
		ENDIF
		SELECT U_ART_PR
		GO TOP
		IF !EOF()
			REPLACE ART_ULNCAR WITH _locNUMDOC
			REPLACE ART_ULDCAR WITH _locDTDOCU
			REPLACE ART_ULQCAR WITH _locQTAMOV
			REPLACE ART_ULPCAR WITH _locPREACQ
		ENDIF
		IF !ExecRW(Csql,"U_ART_PR","W")
		   return(.f.)
		ENDIF
	ENDIF
				
	IF _par_segno = '-'
		x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
		x_codi = "ART_CODPRI = '" + _locANAART + "'"
		x_cond = x_soci + " and " + x_codi 
		cSql = "SELECT * FROM U_ART_PR WHERE " + x_cond
		IF !ExecRW(Csql,"U_ART_PR","R")
		   return(.f.)
		ENDIF
		SELECT U_ART_PR
		GO TOP
		IF !EOF()
			REPLACE ART_ULNSCA WITH _locNUMDOC
			REPLACE ART_ULDSCA WITH _locDTDOCU
			REPLACE ART_ULQSCA WITH _locQTAMOV
			REPLACE ART_ULPSCA WITH _locPREACQ
		ENDIF
		IF !ExecRW(Csql,"U_ART_PR","W")
		   return(.f.)
		ENDIF
	ENDIF
ENDIF

