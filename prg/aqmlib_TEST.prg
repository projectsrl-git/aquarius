***************************************************************************************************************************
FUNCTION AGGIORNA_LEAD_TIME_ARTICOLO_FORNITORE
***************************************************************************************************************************
*** FUNZIONE PER IMPLEMENTAZIONE PARAMETRO AZIENDALE:
*** "Aggiorna il lead time articolo fornitore in base alle ultime 4 consegne (solo per ordini a fornitore non pianificati)"
***************************************************************************************************************************
LPARAMETERS _par_codice_orf,_par_datreg_orf,_par_aggancio_orf,_par_codsys_orf

_RIT = .F.

_codice_articolo = ""

x_pian = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_PIANIF = 0)"  && SOLO ORDINI A FORNITORE NON PIANIFICATI
x_agga = "DAGGANCIO = '" + _par_aggancio_orf + "'"
x_csys = "ORD_CODSYS = '" + _par_codsys_orf + "'"
x_comm = "ORD_DESART <> '*** COMMENTO ***'"
x_cond = x_pian + " and " + x_agga + " and " + x_csys + " and " + x_comm 
cSql = "SELECT ORD_CODART FROM U_ORF_DD WHERE " + x_cond
IF !ExecCommand(cSql,"TMP_ORF_DD")
   return(.f.)
ENDIF
SELECT TMP_ORF_DD
GO TOP
IF EOF()
	RETURN _RIT
ENDIF

_codice_articolo = ALLTRIM(ORD_CODART)
_gg_consegna = 0

x_pian = "U_ORF_DD.DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_PIANIF = 0)"  && SOLO ORDINI A FORNITORE NON PIANIFICATI
x_forn = "U_ORF_DD.ORS_CODCLI = '" + _par_codice_orf + "'"
x_arti = "U_ORF_DD.ORD_CODART = '" + _codice_articolo + "'"
x_cond = x_pian + " and " + x_forn + " and " + x_arti 
cSql = "SELECT U_ORF_DD.ORS_DATORD AS DATORF, U_BFO_DD.ORS_DATORD AS DATBFO FROM U_ORF_DD " + CHR(13) + ;
       "LEFT OUTER JOIN U_BFO_DD ON U_BFO_DD.ORD_LEGAME = U_ORF_DD.DAGGANCIO AND U_BFO_DD.ORD_LEGASY = U_ORF_DD.ORD_CODSYS " + CHR(13) + ;
       "WHERE " + x_cond + " ORDER BY U_BFO_DD.ORS_DATORD DESC"
IF !ExecCommand(cSql,"TMP_ORF_BFO")
   return(.f.)
ENDIF
SELECT TMP_ORF_BFO
GO TOP
IF EOF()
	RETURN _RIT
ENDIF
_N_CONSEGNE = 0
SCAN
	_ACT_gg_consegna = CTOD(RIBALTA2(DATBFO)) - CTOD(RIBALTA2(DATORF))
	
	IF _ACT_gg_consegna > 0
	ELSE
		LOOP
	ENDIF
	
	_gg_consegna = _gg_consegna + _ACT_gg_consegna
	_N_CONSEGNE = _N_CONSEGNE + 1
	
	IF _N_CONSEGNE >= 4
		EXIT
	ENDIF
ENDSCAN

IF _N_CONSEGNE > 0 AND _gg_consegna > 0
ELSE
	RETURN _RIT
ENDIF

_media_gg_consegna = ROUND(_gg_consegna / _N_CONSEGNE,0)

IF _media_gg_consegna > 0
ELSE
	RETURN _RIT
ENDIF

*** AGGIORNAMENTO LEAD TIME FORNITORE IN TABELLA ANAGRAFICA ARTICOLI
x_soci = "ART_CODSOC = '" + PUB_CODSOC + "'"
x_codi = "ART_CODPRI = '" + _codice_articolo + "'"
x_cond = x_soci + " and " + x_codi
cSql = "SELECT ART_CODF1, ART_CODF2, ART_CODF3, ART_CODF4, ART_CODF5 FROM U_ART_PR AS PR WHERE " + x_cond
IF !ExecCommand(cSql,"TMP_ART_PR")
   return(.f.)
ENDIF
SELECT TMP_ART_PR
GO TOP
IF !EOF()
	DO CASE
		CASE ALLTRIM(_par_codice_orf) == ALLTRIM(ART_CODF1)
			cSql = "UPDATE U_ART_AN SET ART_LDTM1 = " + ALLTRIM(STR(_media_gg_consegna,3,0)) + " WHERE " + x_cond
			IF !ExecCommand(cSql,"UPD_ART_AN")
			   return(.f.)
			ENDIF
			_RIT = .T.

		CASE ALLTRIM(_par_codice_orf) == ALLTRIM(ART_CODF2)
			cSql = "UPDATE U_ART_AN SET ART_LDTM2 = " + ALLTRIM(STR(_media_gg_consegna,3,0)) + " WHERE " + x_cond
			IF !ExecCommand(cSql,"UPD_ART_AN")
			   return(.f.)
			ENDIF
			_RIT = .T.
			
		CASE ALLTRIM(_par_codice_orf) == ALLTRIM(ART_CODF3)
			cSql = "UPDATE U_ART_AN SET ART_LDTM3 = " + ALLTRIM(STR(_media_gg_consegna,3,0)) + " WHERE " + x_cond
			IF !ExecCommand(cSql,"UPD_ART_AN")
			   return(.f.)
			ENDIF
			_RIT = .T.
			
		CASE ALLTRIM(_par_codice_orf) == ALLTRIM(ART_CODF4)
			cSql = "UPDATE U_ART_AN SET ART_LDTM4 = " + ALLTRIM(STR(_media_gg_consegna,3,0)) + " WHERE " + x_cond
			IF !ExecCommand(cSql,"UPD_ART_AN")
			   return(.f.)
			ENDIF
			_RIT = .T.
			
		CASE ALLTRIM(_par_codice_orf) == ALLTRIM(ART_CODF5)
			cSql = "UPDATE U_ART_AN SET ART_LDTM5 = " + ALLTRIM(STR(_media_gg_consegna,3,0)) + " WHERE " + x_cond
			IF !ExecCommand(cSql,"UPD_ART_AN")
			   return(.f.)
			ENDIF
			_RIT = .T.			
	ENDCASE
ENDIF

RETURN _RIT



***************************************************************************************************************************
PROCEDURE GESTIONE_CU_BOL_SN
***************************************************************************************************************************
*** GESTIONE SERIAL NUMBERS LEGATI ALLA RIGA DDT
***************************************************************************************************************************

LOCAL _ACT_SEL
_ACT_SEL = SELECT()

_WY_ORD_NOTEBO = ""
SELECT CU_BOL_SN
SET FILTER TO
GO TOP

*** RICERCA TIPOLOGIA DI SERIAL NUMBER / LOTTO
_CODTSN = ""
*!*	_LINEA = ""
_TIPO_MASK = ""
*!*	_LET_CONTATORE = ""
*!*	_NUM_CONTATORE = ""
_RICHIEDE_SERIAL = .F.
_CODREF = ""

x_soci = "U_ART_AN.ART_CODSOC = '" + PUB_CODSOC + "'"
x_codi = "U_ART_AN.ART_CODPRI = '" + M.ORD_CODART + "'"
x_cond = x_soci + " and " + x_codi 
cSql   = "SELECT U_ART_AN.ART_CODTSN, U_ART_PR.ART_LINEA, U_ART_PR.ART_DESRID, COALESCE(PARA.LIBERA,'') AS TIPO_MASK, COALESCE(PARA.CODPGO,'') AS LET_CONTATORE, COALESCE(PARA.DESIVA,'') AS NUM_CONTATORE, COALESCE(PARA.ITALIANO,'') AS MESSAGGIO FROM U_ART_AN " + CHR(13) + ;
         "LEFT OUTER JOIN U_ART_PR ON U_ART_PR.ART_CODSOC = U_ART_AN.ART_CODSOC AND U_ART_PR.ART_CODPRI = U_ART_AN.ART_CODPRI " + CHR(13) + ;
         "LEFT OUTER JOIN PARA ON PARA.CODICE = 'TSN'+U_ART_AN.ART_CODTSN WHERE " + x_cond
IF !ExecCommand(cSql,"TMP_U_ART_PR")
	return(.f.)
ENDIF
SELECT TMP_U_ART_PR
GO TOP
IF !EOF()
	IF EMPTY(ART_CODTSN)
	ELSE
		_CODREF = ALLTRIM(ART_DESRID)
		_CODTSN = ALLTRIM(ART_CODTSN)
		*_LINEA = ALLTRIM(ART_LINEA)
		_TIPO_MASK = ALLTRIM(TIPO_MASK)
		*_LET_CONTATORE = ALLTRIM(LET_CONTATORE)
		*_NUM_CONTATORE = ALLTRIM(NUM_CONTATORE)
		
		IF "RICHIEDE_SERIAL=SI" $ MESSAGGIO
			_RICHIEDE_SERIAL = .T.
		ELSE
			_RICHIEDE_SERIAL = .F.
		ENDIF
	ENDIF
ENDIF

IF !EMPTY(_CODTSN)
	
	SELECT * FROM CU_BOL_SN WHERE ALLTRIM(DAGGANCIO) == ALLTRIM(M.DAGGANCIO) AND ALLTRIM(CODSYS) = ALLTRIM(M.ORD_CODSYS) INTO CURSOR CU_BOL_SN_TMP
	SELECT CU_BOL_SN_TMP
	GO TOP
	SCAN
		_DAGGANCIO	= DAGGANCIO
		_CODSYS		= CODSYS
		_CODART		= CODART
		_SERIAL		= SERIAL
		_QUANTI		= QUANTI
		
		IF EMPTY(_SERIAL)
			LOOP
		ENDIF
		
		IF EMPTY(_WY_ORD_NOTEBO)
			_WY_ORD_NOTEBO = IIF(!EMPTY(_CODREF),"REF: " + _CODREF + " - ","") + IIF(_RICHIEDE_SERIAL,"S/N: ","LOT: ") + ALLTRIM(_SERIAL) 
		ELSE
			_WY_ORD_NOTEBO = ALLTRIM(_WY_ORD_NOTEBO) + "; " + ALLTRIM(_SERIAL)
		ENDIF
		
		cSql="SELECT * FROM U_BOL_SN WHERE 1=0"
		IF !ExecRW(cSql,"U_BOL_SN","R")
		   return(.f.)
		ENDIF
		SELECT U_BOL_SN
		APPEND BLANK
		REPLACE DAGGANCIO	WITH _DAGGANCIO
		REPLACE CODSYS		WITH _CODSYS
		REPLACE CODART		WITH _CODART
		REPLACE SERIAL		WITH _SERIAL
		REPLACE QUANTI		WITH _QUANTI
		IF !ExecRW(cSql,"U_BOL_SN","W")
		   return(.f.)
		ENDIF
	ENDSCAN
	
	*** COMPOSIZIONE STRINGA DELLE COMPONENTI GESTITE A SERIAL NUMBER DA TRACCIARE UTILIZZATE
	CREATE CURSOR TMP_COMP_SERIALS (CODART C(16), DESART C(200), CODREF C(50), SERIALS M)
	INDEX ON CODART TAG I_CODART
	x_lsys = "MOV_LEGSYS = '" + M.ORD_SYSMAG + "'"
	x_cond = x_lsys
	*cSql="SELECT TOP 1 MOV_TRCKNG FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_LEGAME IN (SELECT MOV_LEGAME FROM U_MAG_MO WHERE " + x_cond +")"
	*cSql="SELECT TOP 1 MOV_TRCKNG FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_LEGAME IN (SELECT MOV_LEGAME FROM U_MAG_MO WHERE " + x_cond +") ORDER BY MOV_DTREGI, MOV_ORAMOV"  && ERASMO - 01/12/2014
	cSql="SELECT TOP 1 MOV_TRCKNG FROM U_MAG_MO WHERE MOV_SEGNO = '+' AND MOV_LEGAME IN (SELECT MOV_LEGAME FROM U_MAG_MO WHERE " + x_cond +") AND MOV_DOCMOD = 0 ORDER BY MOV_DTREGI, MOV_ORAMOV"  && ERASMO - 13/02/2015
	IF !ExecCommand(cSql,"TMP_TRCKNG")
	   return(.f.)
	ENDIF
	SELECT TMP_TRCKNG
	GO TOP
	IF !EOF()
		_cTRCKNG = ALLTRIM(MOV_TRCKNG)
		IF !EMPTY(_cTRCKNG)
			x_trck = "'" + _cTRCKNG + "' LIKE '%'+RTRIM(MOV_LEGAME)+'%' AND MOV_SERIAL <> ''"
			x_cond = x_trck 
			cSql="SELECT DISTINCT MOV_SERIAL,MOV_ANAART FROM U_MAG_MO WHERE " + x_cond 
			IF !ExecCommand(cSql,"TMP_TRCKNG")
			   return(.f.)
			ENDIF
			**=> ERASMO - INIZIO 27/05/2015
			SELECT TMP_TRCKNG
			GO TOP
			_SERIALE_PADRE_DA_SERIALE_FIGLIO = .F.
			SCAN
				_C_SERIAL = ALLTRIM(MOV_SERIAL)
				SELECT * FROM CU_BOL_SN_TMP WHERE ALLTRIM(SERIAL) = ALLTRIM(_C_SERIAL) INTO CURSOR CU_BOL_SN_TMP_CHK
				SELECT CU_BOL_SN_TMP_CHK
				GO TOP
				IF !EOF()
					_SERIALE_PADRE_DA_SERIALE_FIGLIO = .T.
					EXIT
				ENDIF
			ENDSCAN
			
			SELECT TMP_TRCKNG
			GO TOP
			**=> ERASMO - FINE 27/05/2015
			
			SCAN
				_C_RICHIEDE_SERIAL = .F.
				_C_CODART = MOV_ANAART
				_C_DESART = ""
				_C_SERIAL = ALLTRIM(MOV_SERIAL)
				_C_CODREF = ""
					
				**=> ERASMO - INIZIO 27/05/2015
				*** SE IL S/N DEL PADRE E' STATO GESTITO EREDITANDO IL S/N DEL CORRISPONDENTE CODICE FIGLIO, ALLORA FILTRO RISPETTO AI SERIAL NUMBER CONTENUTI NELLA TABELLA U_BOL_SN
				IF _SERIALE_PADRE_DA_SERIALE_FIGLIO
					SELECT * FROM CU_BOL_SN_TMP WHERE ALLTRIM(SERIAL) = ALLTRIM(_C_SERIAL) INTO CURSOR CU_BOL_SN_TMP_CHK
					SELECT CU_BOL_SN_TMP_CHK
					GO TOP
					IF EOF()
						SELECT TMP_TRCKNG
						LOOP
					ENDIF				
				ENDIF
				SELECT TMP_TRCKNG
				**=> ERASMO - FINE 27/05/2015
				
				x_soci = "U_ART_AN.ART_CODSOC = '" + PUB_CODSOC + "'"
				x_codi = "U_ART_AN.ART_CODPRI = '" + _C_CODART + "'"
				x_cond = x_soci + " and " + x_codi 
				cSql   = "SELECT U_ART_AN.ART_CODTSN, U_ART_PR.ART_DESCR, U_ART_PR.ART_LINEA, U_ART_PR.ART_DESRID, COALESCE(PARA.LIBERA,'') AS TIPO_MASK, " + CHR(13) + ;
				         "COALESCE(PARA.CODPGO,'') AS LET_CONTATORE, COALESCE(PARA.DESIVA,'') AS NUM_CONTATORE, COALESCE(PARA.ITALIANO,'') AS MESSAGGIO FROM U_ART_AN " + CHR(13) + ;
				         "LEFT OUTER JOIN U_ART_PR ON U_ART_PR.ART_CODSOC = U_ART_AN.ART_CODSOC AND U_ART_PR.ART_CODPRI = U_ART_AN.ART_CODPRI " + CHR(13) + ;
				         "LEFT OUTER JOIN PARA ON PARA.CODICE = 'TSN'+U_ART_AN.ART_CODTSN WHERE " + x_cond
				IF !ExecCommand(cSql,"TMP_U_ART_PR")
					return(.f.)
				ENDIF
				SELECT TMP_U_ART_PR
				GO TOP
				IF !EOF()
					_C_DESART = ALLTRIM(ART_DESCR)
					IF !EMPTY(ART_CODTSN)
						_C_CODREF = ALLTRIM(ART_DESRID)						
						IF "RICHIEDE_SERIAL=SI" $ MESSAGGIO
							_C_RICHIEDE_SERIAL = .T.
						ELSE
							_C_RICHIEDE_SERIAL = .F.
						ENDIF
					ENDIF
				ENDIF
				IF _C_RICHIEDE_SERIAL
					SELECT TMP_COMP_SERIALS
					SET ORDER TO I_CODART
					GO TOP
					SEEK _C_CODART
					IF FOUND()
						REPLACE SERIALS WITH ALLTRIM(SERIALS) + "; " + _C_SERIAL
					ELSE
						APPEND BLANK
						REPLACE CODART WITH _C_CODART 
						REPLACE DESART WITH _C_DESART 
						REPLACE CODREF WITH _C_CODREF 
						REPLACE SERIALS WITH _C_SERIAL 
					ENDIF
				ENDIF
			ENDSCAN
		ENDIF
	ENDIF
	SELECT TMP_COMP_SERIALS
	GO TOP
	IF !EOF()
		IF !EMPTY(_TIPO_MASK)  && PRODOTTO DI VENDITA DI TIPO "SISTEMA"
			_WY_ORD_NOTEBO = _WY_ORD_NOTEBO + CHR(13) + "Composed by:"
			SCAN
				_cActComp = "   " + ALLTRIM(DESART) + " - REF: " + ALLTRIM(CODREF) + " - S/N: " + ALLTRIM(SERIALS)
				_WY_ORD_NOTEBO = _WY_ORD_NOTEBO + CHR(13) + _cActComp
			ENDSCAN
		ELSE
			_WY_ORD_NOTEBO = ""
			SCAN
				_cActComp = "REF: " + ALLTRIM(CODREF) + " - S/N: " + ALLTRIM(SERIALS)
				_WY_ORD_NOTEBO = _WY_ORD_NOTEBO + IIF(EMPTY(_WY_ORD_NOTEBO),"",CHR(13)) + _cActComp
			ENDSCAN
		ENDIF
	ENDIF
	
	SELECT CU_BOL_SN_TMP
	USE

	*IF !EMPTY(_WY_ORD_NOTEBO)
	IF !EMPTY(_WY_ORD_NOTEBO) AND PUB_COMSNO  && ERASMO - 10/03/2014
		V_NOTEBO = ALLTRIM(V_NOTEBO) + IIF(EMPTY(V_NOTEBO),"",CHR(13)) + ALLTRIM(_WY_ORD_NOTEBO)
	ENDIF
	
ENDIF

SELECT(_ACT_SEL)

ENDPROC


*!*	*******************************
*!*	FUNCTION AQM_RILEVA_CONSISTENZA
*!*	*******************************

*!*	LPARAMETERS _par_codsoc,_par_anaart,_par_codmag,_par_prenot,_par_codint,_par_altezz,_par_lunghe,_par_fila_x,_par_pian_x,_par_ubic_x,_par_umrit,_par_escl_mag_scarto

*!*	IF PCOUNT() >= 11
*!*		_par_umrit = ALLTRIM(_par_umrit)
*!*	ELSE
*!*		_par_umrit = ""
*!*	ENDIF

*!*	IF PCOUNT() >= 12
*!*	ELSE
*!*		_par_escl_mag_scarto = .T.
*!*	ENDIF

*!*	LOCAL _AQM_SS
*!*	_AQM_SS=SELECT()

*!*	LOCAL _RIT
*!*	_RIT = 0

*!*	LOCAL _X_GIACENZA,_X_ORDCLI,_X_ORDCLI_SEMILAV,_X_ORDFOR,_X_PRODUZ,_X_PRODUZ_SEMILAV
*!*	_X_GIACENZA = 0
*!*	_X_ORDCLI = 0
*!*	_X_ORDCLI_SEMILAV = 0
*!*	_X_ORDFOR = 0
*!*	_X_PRODUZ = 0
*!*	_X_PRODUZ_SEMILAV = 0

*!*	*** GIACENZA DISPONIBILE SUL/SUI MAGAZZINO/I SELEZIONATO/I
*!*	_X_GIACENZA = AQM_RILEVA_GIACENZE_DISPONIBILI(_par_codsoc,_par_anaart,_par_codmag,_par_prenot,_par_codint,_par_altezz,_par_lunghe,_par_fila_x,_par_pian_x,_par_ubic_x,_par_umrit,_par_escl_mag_scarto)

*!*	_GIACENZA_CO = _X_GIACENZA  && ERASMO - 24/03/2014

*!*	*** ORDINI CLIENTI IN ESSERE
*!*	x_agga = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORD_TT WHERE ORD_CHIUSO = 0)"
*!*	x_comm = "ORD_DESART <> '*** COMMENTO ***'"
*!*	x_arti = "ORD_CODART = '" + _par_anaart + "'"
*!*	x_alte = IIF(_par_altezz <= 0,"1=1","ORD_ALTEZZ = " + ALLTRIM(STR(_par_altezz,7,0)))
*!*	x_lung = IIF(_par_lunghe <= 0,"1=1","ORD_LUNGHE = " + ALLTRIM(STR(_par_lunghe,8,0)))
*!*	x_open = "(ORD_CHIUSO = 0 AND ORD_SALCON <> 'S')"
*!*	IF !EMPTY(_par_codmag)
*!*		IF "'" $ _par_codmag
*!*			x_maga = "ORD_MAGA IN (" + ALLTRIM(_par_codmag) + ")"  && FILTRO SU MAGAZZINI MULTIPLI
*!*		ELSE
*!*			x_maga = "ORD_MAGA = '" + ALLTRIM(_par_codmag) + "'"  && FILTRO SU MAGAZZINO SINGOLO
*!*		ENDIF
*!*	ELSE
*!*		x_maga = "1=1"
*!*	ENDIF
*!*	x_cons = IIF(PUB_GGCNSO > 0, "ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","ORD_DATCON = ORD_DATCON")  && ERASMO - 28/10/2014
*!*	x_cond = x_agga + " and " + x_comm + " and " + x_arti + " and " + x_alte + " and " + x_lung + " and " + x_open + " and " + x_maga + " and " + x_cons
*!*	cSql = "SELECT SUM(CASE WHEN (ORD_QTAORD - ORD_QTAEV) > 0 THEN (ORD_QTAORD - ORD_QTAEV) ELSE 0 END) AS TOT_QTARES FROM U_ORD_DD " + ;
*!*	       "WHERE " + x_cond
*!*	IF !ExecCommand(cSql,"TMP_ORD_DD")
*!*	  return(.f.)
*!*	ENDIF
*!*	SELECT TMP_ORD_DD
*!*	GO TOP
*!*	IF !EOF()
*!*		IF !ISNULL(TOT_QTARES)
*!*			_X_ORDCLI = TOT_QTARES
*!*		ENDIF
*!*	ENDIF

*!*	_X_ORDCLI_SEMILAV = 0
*!*	*** ORDINI CLIENTI IN ESSERE CHE UTILIZZANO IL PRODOTTO PASSATO NEI PARAMETRI COME SEMILAVORATO
*!*	x_agga = "U_ORD_DD.DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORD_TT WHERE ORD_CHIUSO = 0)"
*!*	x_comm = "U_ORD_DD.ORD_DESART <> '*** COMMENTO ***'"
*!*	x_alte = IIF(_par_altezz <= 0,"1=1","U_ORD_DD.ORD_ALTEZZ = " + ALLTRIM(STR(_par_altezz,7,0)))
*!*	x_lung = IIF(_par_lunghe <= 0,"1=1","U_ORD_DD.ORD_LUNGHE = " + ALLTRIM(STR(_par_lunghe,8,0)))
*!*	x_open = "(U_ORD_DD.ORD_CHIUSO = 0 AND U_ORD_DD.ORD_SALCON <> 'S')"
*!*	IF !EMPTY(_par_codmag)
*!*		IF "'" $ _par_codmag
*!*			x_maga = "U_ORD_DD.ORD_MAGA IN (" + ALLTRIM(_par_codmag) + ")"  && FILTRO SU MAGAZZINI MULTIPLI
*!*		ELSE
*!*			x_maga = "U_ORD_DD.ORD_MAGA = '" + ALLTRIM(_par_codmag) + "'"  && FILTRO SU MAGAZZINO SINGOLO
*!*		ENDIF
*!*	ELSE
*!*		x_maga = "1=1"
*!*	ENDIF
*!*	x_cons = IIF(PUB_GGCNSO > 0, "U_ORD_DD.ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","U_ORD_DD.ORD_DATCON = U_ORD_DD.ORD_DATCON")  && ERASMO - 28/10/2014
*!*	x_cond = x_agga + " and " + x_comm + " and " + x_alte + " and " + x_lung + " and " + x_open + " and " + x_maga + " and " + x_cons
*!*	cSql = "SELECT CASE WHEN (ORD_QTAORD - ORD_QTAEV) > 0 THEN (ORD_QTAORD - ORD_QTAEV) ELSE 0 END AS ORD_QTARES, DIS.DIS_QTA " + CHR(13) + ;
*!*	       "FROM U_ORD_DD " + CHR(13) + ;
*!*	       "RIGHT OUTER JOIN U_DIS_DD AS DIS ON DIS.DIS_GRUPPO = U_ORD_DD.ORD_CODART AND DIS.DIS_CODART = '" + _par_anaart + "' " + CHR(13) + ;
*!*	       "WHERE " + x_cond
*!*	IF !ExecCommand(cSql,"TMP_ORD_DD")
*!*	  return(.f.)
*!*	ENDIF
*!*	SELECT TMP_ORD_DD
*!*	GO TOP
*!*	SCAN
*!*		_X_ORDCLI_SEMILAV = _X_ORDCLI_SEMILAV + (ORD_QTARES * DIS_QTA)
*!*	ENDSCAN


*!*	*** ORDINI A FORNITORI IN ESSERE
*!*	_X_UMMAGA = AQM_TROVA_UMMAGA(_par_anaart)
*!*	x_agga = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_CHIUSO = 0)"
*!*	x_comm = "ORD_DESART <> '*** COMMENTO ***'"
*!*	x_arti = "ORD_CODART = '" + _par_anaart + "'"
*!*	x_alte = IIF(_par_altezz <= 0,"1=1","ORD_ALTEZZ = " + ALLTRIM(STR(_par_altezz,7,0)))
*!*	x_lung = IIF(_par_lunghe <= 0,"1=1","ORD_LUNGHE = " + ALLTRIM(STR(_par_lunghe,8,0)))
*!*	IF !EMPTY(_par_codmag)
*!*		IF "'" $ _par_codmag
*!*			x_maga = "ORD_MAGA IN (" + ALLTRIM(_par_codmag) + ")"  && FILTRO SU MAGAZZINI MULTIPLI
*!*		ELSE
*!*			x_maga = "ORD_MAGA = '" + ALLTRIM(_par_codmag) + "'"  && FILTRO SU MAGAZZINO SINGOLO
*!*		ENDIF
*!*	ELSE
*!*		x_maga = "1=1"
*!*	ENDIF
*!*	x_cond = x_agga + " and " + x_comm + " and " + x_arti + " and " + x_alte + " and " + x_lung + " and " + x_maga
*!*	cSql = "SELECT ORS_RAGSOC, ORD_DATCON, ORD_UM, " + ;
*!*	       "ORD_QTAORD, ORD_QTAEV, ORD_QTAMQ, ORD_QTAKG, ORD_QTAML, ORD_QTAMC, ORD_NUMBOB FROM U_ORF_DD " + ;
*!*	       "WHERE " + x_cond + " ORDER BY ORD_DATCON"
*!*	IF !ExecCommand(cSql,"TMP_ORF_DD")
*!*	  return(.f.)
*!*	ENDIF
*!*	SELECT TMP_ORF_DD
*!*	GO TOP
*!*	DO WHILE !EOF()
*!*		
*!*		_X_QTAORD = ORD_QTAORD
*!*		_X_QTAEV  = ORD_QTAEV
*!*		_X_QTARES = ORD_QTAORD - ORD_QTAEV
*!*		IF _X_QTARES < 0
*!*			_X_QTARES = 0
*!*		ENDIF
*!*		IF _X_QTARES > 0
*!*		ELSE
*!*			SELECT TMP_ORF_DD
*!*			SKIP +1
*!*			LOOP
*!*		ENDIF
*!*		
*!*		_X_UNIMIS = ALLTRIM(ORD_UM)
*!*		_X_QTAKG = ORD_QTAKG
*!*		_X_QTAMQ = ORD_QTAMQ
*!*		_X_QTAML = ORD_QTAML
*!*		_X_QTAMC = ORD_QTAMC
*!*		_X_QTANR = ORD_NUMBOB
*!*		IF ALLTRIM(_X_UNIMIS) == 'KG'
*!*			_X_QTAKG = ORD_QTAORD
*!*		ENDIF
*!*		IF ALLTRIM(_X_UNIMIS) == 'MQ'
*!*			_X_QTAMQ = ORD_QTAORD
*!*		ENDIF
*!*		IF ALLTRIM(_X_UNIMIS) == 'ML'
*!*			_X_QTAML = ORD_QTAORD
*!*		ENDIF
*!*		IF ALLTRIM(_X_UNIMIS) == 'MC'
*!*			_X_QTAMC = ORD_QTAORD
*!*		ENDIF
*!*		IF ALLTRIM(_X_UNIMIS) == 'NR'
*!*			_X_QTANR = ORD_QTAORD
*!*		ENDIF
*!*		
*!*		_X_QTATEO = 0
*!*		
*!*		*** ESPRIMO LA QUANTITA' RESIDUA NELL'ORDINE A FORNITORE IN UNITA' DI MISURA DI MAGAZZINO
*!*		DO CASE
*!*			CASE _X_UNIMIS == _X_UMMAGA
*!*				_X_QTATEO = _X_QTARES
*!*			
*!*			CASE _X_UMMAGA = 'KG'
*!*				_X_QTATEO = ROUND(_X_QTARES * _X_QTAKG / _X_QTAORD, PUB_DECQTA)
*!*				
*!*			CASE _X_UMMAGA = 'MQ'
*!*				_X_QTATEO = ROUND(_X_QTARES * _X_QTAMQ / _X_QTAORD, PUB_DECQTA)
*!*				
*!*			CASE _X_UMMAGA = 'ML'
*!*				_X_QTATEO = ROUND(_X_QTARES * _X_QTAML / _X_QTAORD, PUB_DECQTA)
*!*				
*!*			CASE _X_UMMAGA = 'MC'
*!*				_X_QTATEO = ROUND(_X_QTARES * _X_QTAMC / _X_QTAORD, PUB_DECQTA)
*!*				
*!*			CASE _X_UMMAGA = 'NR'
*!*				_X_QTATEO = ROUND(_X_QTARES * _X_QTANR / _X_QTAORD, 0)
*!*		ENDCASE
*!*		
*!*		_X_ORDFOR = _X_ORDFOR + _X_QTATEO

*!*		SELECT TMP_ORF_DD
*!*		SKIP +1
*!*		
*!*	ENDDO


*!*	*** QUANTITA' IN PRODUZIONE PRODOTTO FINITO
*!*	_X_QTARESPRD = 0  && QUANTITA' RESIDUA DA PRODURRE
*!*	_X_QTAPRLPRD = 0  && SOLO QUANTITA' PRELEVATA
*!*	x_comp = "PA.COMP = '" + _par_anaart + "'"
*!*	x_open = "PR.FLGCLOSED = 0"
*!*	x_cond = x_comp + " and " + x_open
*!*	cSql = "SELECT COALESCE(SUM(QTA - QTAPROD),0) AS QTADAPROD, COALESCE(SUM(QTAPREL),0) AS QTAPREL FROM ( " + CHR(13) + ;
*!*	       "	SELECT PA.QTA, PA.QTAPROD, PC.QTAPREL FROM PROD_AVANZA AS PA " + CHR(13) + ;
*!*	       "	INNER JOIN PRODUZIONE AS PR ON PR.IDPRG = PA.IDPRG AND PR.PARENT = '' " + CHR(13) + ;
*!*	       "	LEFT OUTER JOIN (SELECT IDPRG, FASELA, SEQUEN, COUNT(*) AS QTAPREL FROM PROD_CARICHI WHERE QTAPROD = 0 GROUP BY IDPRG, FASELA, SEQUEN) AS PC ON PA.IDPRG = PC.IDPRG AND PA.FASELA = PC.FASELA AND PA.SEQUEN = PC.SEQUEN " + CHR(13) + ;
*!*	       "	WHERE " + x_cond + ") AS MAIN"

*!*	IF !ExecCommand(cSql,"CX_PROD_QTANECT")
*!*	  return(.f.)
*!*	ENDIF
*!*	SELECT CX_PROD_QTANECT
*!*	GO TOP
*!*	IF !EOF()
*!*		_X_QTARESPRD = QTADAPROD
*!*		_X_QTAPRLPRD = QTAPREL
*!*	ENDIF
*!*	_X_PRODUZ = _X_QTARESPRD


*!*	*** QUANTITA' MINIMA IN PRODUZIONE / GIACENZA COMPONENTI
*!*	_X_PRODUZ_SEMILAV = -1
*!*	x_codi = "DD.DIS_GRUPPO = '" + _par_anaart + "'"
*!*	*x_grup = "(SELECT COUNT(*) FROM U_DIS_DD WHERE DIS_GRUPPO = DD.DIS_CODART) > 0"
*!*	x_smov = "(SELECT ART_NONMOV FROM U_ART_PR WHERE ART_CODPRI = DD.DIS_CODART) = 0"  && SOLO COMPONENTI CHE MOVIMENTANO IL MAGAZZINO
*!*	x_cond = x_codi + " and " + x_smov 
*!*	cSql = "SELECT DIS_CODART, DIS_QTA FROM U_DIS_DD AS DD WHERE " + x_cond
*!*	IF !ExecCommand(cSql,"CX_DIS_SOTTOGR")
*!*	  return(.f.)
*!*	ENDIF
*!*	SELECT CX_DIS_SOTTOGR
*!*	GO TOP
*!*	SCAN
*!*		_X_CODART = ALLTRIM(DIS_CODART)
*!*		_X_DISQTA = DIS_QTA
*!*		_X_QTARESPRD = 0  && QUANTITA' RESIDUA DA PRODURRE
*!*		_X_QTAPRLPRD = 0  && SOLO QUANTITA' PRELEVATA
*!*		x_comp = "PA.COMP = '" + _X_CODART + "'"
*!*		x_open = "PR.FLGCLOSED = 0"
*!*		x_cond = x_comp + " and " + x_open
*!*		cSql = "SELECT COALESCE(SUM(QTA - QTAPROD),0) AS QTADAPROD, COALESCE(SUM(QTAPREL),0) AS QTAPREL FROM ( " + CHR(13) + ;
*!*		       "	SELECT PA.QTA, PA.QTAPROD, PC.QTAPREL FROM PROD_AVANZA AS PA " + CHR(13) + ;
*!*		       "	INNER JOIN PRODUZIONE AS PR ON PR.IDPRG = PA.IDPRG AND PR.PARENT = '' " + CHR(13) + ;
*!*		       "	LEFT OUTER JOIN (SELECT IDPRG, FASELA, SEQUEN, COUNT(*) AS QTAPREL FROM PROD_CARICHI WHERE QTAPROD = 0 GROUP BY IDPRG, FASELA, SEQUEN) AS PC ON PA.IDPRG = PC.IDPRG AND PA.FASELA = PC.FASELA AND PA.SEQUEN = PC.SEQUEN " + CHR(13) + ;
*!*		       "	WHERE " + x_cond + ") AS MAIN"

*!*		IF !ExecCommand(cSql,"CX_PROD_QTANECT")
*!*		  return(.f.)
*!*		ENDIF
*!*		SELECT CX_PROD_QTANECT
*!*		GO TOP
*!*		IF !EOF()
*!*			_X_QTARESPRD = QTADAPROD
*!*			_X_QTAPRLPRD = QTAPREL
*!*		ENDIF
*!*		
*!*		_GIAC_COMP = 0
*!*		_yy_codsoc = PUB_CODSOC
*!*		_yy_anaart = _X_CODART
*!*		_yy_codmag = _par_codmag
*!*		_yy_prenot = .T.  && SOLO GIACENZE NON PRENOTATE
*!*		_yy_codint = ""
*!*		_yy_altezz = 0
*!*		_yy_lunghe = 0
*!*		_yy_fila_x = ""
*!*		_yy_pian_x = ""
*!*		_yy_ubic_x = ""
*!*		_GIAC_COMP = AQM_RILEVA_GIACENZE_DISPONIBILI(_yy_codsoc,_yy_anaart,_yy_codmag,_yy_prenot,_yy_codint,_yy_altezz,_yy_lunghe,_yy_fila_x,_yy_pian_x,_yy_ubic_x)
*!*		
*!*		_GIAC_TEO_COMP = _GIAC_COMP + IIF(_X_DISQTA > 0, _X_QTARESPRD / _X_DISQTA, 0)
*!*		
*!*		IF _X_PRODUZ_SEMILAV = -1
*!*			_X_PRODUZ_SEMILAV = _GIAC_TEO_COMP
*!*		ELSE
*!*			_X_PRODUZ_SEMILAV = MIN(_X_PRODUZ_SEMILAV,_GIAC_TEO_COMP)
*!*		ENDIF
*!*	ENDSCAN
*!*	IF _X_PRODUZ_SEMILAV = -1
*!*		_X_PRODUZ_SEMILAV = 0
*!*	ENDIF


*!*	*** RICALCOLO CONSISTENZA
*!*	_RIT = _X_GIACENZA - _X_ORDCLI - _X_ORDCLI_SEMILAV + _X_ORDFOR + _X_PRODUZ + _X_PRODUZ_SEMILAV


*!*	SELECT(_AQM_SS)

*!*	RETURN _RIT


**=> ERASMO - INIZIO 28/10/2014
***************************************************************************************************************************************************************************************************************
FUNCTION AQM_RILEVA_CONSISTENZA
***************************************************************************************************************************************************************************************************************
LPARAMETERS _par_codsoc,_par_anaart,_par_codmag,_par_prenot,_par_codint,_par_altezz,_par_lunghe,_par_fila_x,_par_pian_x,_par_ubic_x,_par_umrit,_par_escl_mag_scarto,_par_waitview,_par_datfin,_par_solo_qtaprel

IF PCOUNT() >= 11
	_par_umrit = ALLTRIM(_par_umrit)
ELSE
	_par_umrit = ""
ENDIF

IF PCOUNT() >= 12
ELSE
	_par_escl_mag_scarto = .T.
ENDIF

IF PCOUNT() >= 13
ELSE
	_par_waitview = .F.
ENDIF

**=> ERASMO - INIZIO 05/02/2015
IF PCOUNT() >= 14
ELSE
	_par_datfin = ""
ENDIF
**=> ERASMO - FINE 05/02/2015

**=> ERASMO - INIZIO 02/04/2015
IF PCOUNT() >= 14
ELSE
	_par_solo_qtaprel = .T.
ENDIF
**=> ERASMO - FINE 02/04/2015

LOCAL _AQM_SS
_AQM_SS=SELECT()

LOCAL _RIT
_RIT = 0

LOCAL _X_GIACENZA
_X_GIACENZA = 0

*** GIACENZA DISPONIBILE SUL/SUI MAGAZZINO/I SELEZIONATO/I
_X_GIACENZA = AQM_RILEVA_GIACENZE_DISPONIBILI(_par_codsoc,_par_anaart,_par_codmag,_par_prenot,_par_codint,_par_altezz,_par_lunghe,_par_fila_x,_par_pian_x,_par_ubic_x,_par_umrit,_par_escl_mag_scarto)

*** LA VARIABILE "_GIACENZA_CO" E' UTILIZZATA DAI GESTIONALI PER DETERMINARE LA GIACENZA DISPONIBILE, INTEGRANDONE IL CALCOLO IN "AQM_RILEVA_CONSISTENZA"
_GIACENZA_CO = _X_GIACENZA


*LOCAL _X_ORDCLI,_X_ORDCLI_SEMILAV,_X_ORDFOR,_X_PRODUZ
_X_ORDCLI = 0
_X_ORDCLI_SEMILAV = 0
_X_ORDFOR = 0
_X_PRODUZ = 0

*** ORDINI CLIENTI IN ESSERE
x_agga = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORD_TT WHERE ORD_CHIUSO = 0)"
x_comm = "ORD_DESART <> '*** COMMENTO ***'"
x_arti = "ORD_CODART = '" + _par_anaart + "'"
x_alte = IIF(_par_altezz <= 0,"1=1","ORD_ALTEZZ = " + ALLTRIM(STR(_par_altezz,7,0)))
x_lung = IIF(_par_lunghe <= 0,"1=1","ORD_LUNGHE = " + ALLTRIM(STR(_par_lunghe,8,0)))
x_open = "(ORD_CHIUSO = 0 AND ORD_SALCON <> 'S')"
IF !EMPTY(_par_codmag)
	IF "'" $ _par_codmag
		x_maga = "ORD_MAGA IN (" + ALLTRIM(_par_codmag) + ")"  && FILTRO SU MAGAZZINI MULTIPLI
	ELSE
		x_maga = "ORD_MAGA = '" + ALLTRIM(_par_codmag) + "'"  && FILTRO SU MAGAZZINO SINGOLO
	ENDIF
ELSE
	x_maga = "1=1"
ENDIF
*x_cons = IIF(PUB_GGCNSO > 0, "ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","ORD_DATCON = ORD_DATCON")  && ERASMO - 28/10/2014
**=> ERASMO - INIZIO 05/02/2015
IF !EMPTY(_par_datfin)
	x_cons = "ORD_DATCON <= '" + RIBALTA2(_par_datfin) + "'"
ELSE
	x_cons = IIF(PUB_GGCNSO > 0, "ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","ORD_DATCON = ORD_DATCON")
ENDIF
**=> ERASMO - FINE 05/02/2015
x_cond = x_agga + " and " + x_comm + " and " + x_arti + " and " + x_alte + " and " + x_lung + " and " + x_open + " and " + x_maga + " and " + x_cons
cSql = "SELECT SUM(CASE WHEN (ORD_QTAORD - ORD_QTAEV) > 0 THEN (ORD_QTAORD - ORD_QTAEV) ELSE 0 END) AS TOT_QTARES FROM U_ORD_DD " + ;
       "WHERE " + x_cond
IF !ExecCommand(cSql,"TMP_ORD_DD")
  return(.f.)
ENDIF
SELECT TMP_ORD_DD
GO TOP
IF !EOF()
	IF !ISNULL(TOT_QTARES)
		_X_ORDCLI = TOT_QTARES
	ENDIF
ENDIF

_X_ORDCLI_SEMILAV = 0
*** ORDINI CLIENTI IN ESSERE CHE UTILIZZANO IL PRODOTTO PASSATO NEI PARAMETRI COME SEMILAVORATO
x_agga = "U_ORD_DD.DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORD_TT WHERE ORD_CHIUSO = 0)"
x_comm = "U_ORD_DD.ORD_DESART <> '*** COMMENTO ***'"
x_alte = IIF(_par_altezz <= 0,"1=1","U_ORD_DD.ORD_ALTEZZ = " + ALLTRIM(STR(_par_altezz,7,0)))
x_lung = IIF(_par_lunghe <= 0,"1=1","U_ORD_DD.ORD_LUNGHE = " + ALLTRIM(STR(_par_lunghe,8,0)))
x_open = "(U_ORD_DD.ORD_CHIUSO = 0 AND U_ORD_DD.ORD_SALCON <> 'S')"
IF !EMPTY(_par_codmag)
	IF "'" $ _par_codmag
		x_maga = "U_ORD_DD.ORD_MAGA IN (" + ALLTRIM(_par_codmag) + ")"  && FILTRO SU MAGAZZINI MULTIPLI
	ELSE
		x_maga = "U_ORD_DD.ORD_MAGA = '" + ALLTRIM(_par_codmag) + "'"  && FILTRO SU MAGAZZINO SINGOLO
	ENDIF
ELSE
	x_maga = "1=1"
ENDIF
*x_cons = IIF(PUB_GGCNSO > 0, "U_ORD_DD.ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","U_ORD_DD.ORD_DATCON = U_ORD_DD.ORD_DATCON")  && ERASMO - 28/10/2014
**=> ERASMO - INIZIO 05/02/2015
IF !EMPTY(_par_datfin)
	x_cons = "ORD_DATCON <= '" + RIBALTA2(_par_datfin) + "'"
ELSE
	x_cons = IIF(PUB_GGCNSO > 0, "ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","ORD_DATCON = ORD_DATCON")
ENDIF
**=> ERASMO - FINE 05/02/2015
x_cond = x_agga + " and " + x_comm + " and " + x_alte + " and " + x_lung + " and " + x_open + " and " + x_maga + " and " + x_cons
*!*	cSql = "SELECT CASE WHEN (ORD_QTAORD - ORD_QTAEV) > 0 THEN (ORD_QTAORD - ORD_QTAEV) ELSE 0 END AS ORD_QTARES, DIS.DIS_QTA " + CHR(13) + ;
*!*	       "FROM U_ORD_DD " + CHR(13) + ;
*!*	       "RIGHT OUTER JOIN U_DIS_DD AS DIS ON DIS.DIS_GRUPPO = U_ORD_DD.ORD_CODART AND DIS.DIS_CODART = '" + _par_anaart + "' " + CHR(13) + ;
*!*	       "WHERE " + x_cond
*!*	IF !ExecCommand(cSql,"TMP_ORD_DD")
*!*	  return(.f.)
*!*	ENDIF
*!*	SELECT TMP_ORD_DD
*!*	GO TOP
*!*	SCAN
*!*		_X_ORDCLI_SEMILAV = _X_ORDCLI_SEMILAV + (ORD_QTARES * DIS_QTA)
*!*	ENDSCAN
**=> ERASMO - INIZIO 04/05/2015
cSql = "SELECT CASE WHEN (ORD_QTAORD - ORD_QTAEV) > 0 THEN (ORD_QTAORD - ORD_QTAEV) ELSE 0 END AS ORD_QTARES, DIS.DIS_QTA, " + CHR(13) + ;
       "ORD_MAGA, ORD_CODART, ORD_DESART, ORS_NUMORD, ORS_DATORD, ORD_DATCON, ORS_CODCLI, ORS_RAGSOC, ORD_SPESSO, ORD_ALTEZZ, ORD_LUNGHE, ORD_NUMBOB, ORD_UM, ORD_QTAORD, ORD_QTAEV FROM U_ORD_DD " + CHR(13) + ;
       "RIGHT OUTER JOIN U_DIS_DD AS DIS ON DIS.DIS_GRUPPO = U_ORD_DD.ORD_CODART AND DIS.DIS_CODART = '" + _par_anaart + "' " + CHR(13) + ;
       "WHERE " + x_cond
IF !ExecCommand(cSql,"CU_ORDINI_INDIRETTI")
  return(.f.)
ENDIF
SELECT CU_ORDINI_INDIRETTI
GO TOP
SCAN
	_X_ORDCLI_SEMILAV = _X_ORDCLI_SEMILAV + (ORD_QTARES * DIS_QTA)
ENDSCAN
**=> ERASMO - FINE 04/05/2015


*** ORDINI A FORNITORI IN ESSERE
_X_UMMAGA = AQM_TROVA_UMMAGA(_par_anaart)
*x_agga = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_CHIUSO = 0)"
**=> ERASMO - INIZIO 02/04/2015
IF PUB_FLCONF
	x_agga = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_CHIUSO = 0 AND ORD_FLGCON = 1)"  && SOLO ORDINI FORNITORI CONFERMATI (COME DA PARAMETRO AZIENDALE)
ELSE
	x_agga = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_CHIUSO = 0)"
ENDIF
**=> ERASMO - FINE 02/04/2015
x_comm = "ORD_DESART <> '*** COMMENTO ***'"
x_arti = "ORD_CODART = '" + _par_anaart + "'"
x_alte = IIF(_par_altezz <= 0,"1=1","ORD_ALTEZZ = " + ALLTRIM(STR(_par_altezz,7,0)))
x_lung = IIF(_par_lunghe <= 0,"1=1","ORD_LUNGHE = " + ALLTRIM(STR(_par_lunghe,8,0)))
IF !EMPTY(_par_codmag)
	IF "'" $ _par_codmag
		x_maga = "ORD_MAGA IN (" + ALLTRIM(_par_codmag) + ")"  && FILTRO SU MAGAZZINI MULTIPLI
	ELSE
		x_maga = "ORD_MAGA = '" + ALLTRIM(_par_codmag) + "'"  && FILTRO SU MAGAZZINO SINGOLO
	ENDIF
ELSE
	x_maga = "1=1"
ENDIF
*x_cons = IIF(PUB_GGCNSO > 0, "ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","ORD_DATCON = ORD_DATCON")
**=> ERASMO - INIZIO 05/02/2015
IF !EMPTY(_par_datfin)
	x_cons = "ORD_DATCON <= '" + RIBALTA2(_par_datfin) + "'"
ELSE
	x_cons = IIF(PUB_GGCNSO > 0, "ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","ORD_DATCON = ORD_DATCON")
ENDIF
**=> ERASMO - FINE 05/02/2015
x_cond = x_agga + " and " + x_comm + " and " + x_arti + " and " + x_alte + " and " + x_lung + " and " + x_maga + " and " + x_cons 
cSql = "SELECT ORS_RAGSOC, ORD_DATCON, ORD_UM, " + ;
       "ORD_QTAORD, ORD_QTAEV, ORD_QTAMQ, ORD_QTAKG, ORD_QTAML, ORD_QTAMC, ORD_NUMBOB FROM U_ORF_DD " + ;
       "WHERE " + x_cond + " ORDER BY ORD_DATCON"
IF !ExecCommand(cSql,"TMP_ORF_DD")
  return(.f.)
ENDIF
SELECT TMP_ORF_DD
GO TOP
DO WHILE !EOF()
	
	_X_QTAORD = ORD_QTAORD
	_X_QTAEV  = ORD_QTAEV
	_X_QTARES = ORD_QTAORD - ORD_QTAEV
	IF _X_QTARES < 0
		_X_QTARES = 0
	ENDIF
	IF _X_QTARES > 0
	ELSE
		SELECT TMP_ORF_DD
		SKIP +1
		LOOP
	ENDIF
	
	_X_UNIMIS = ALLTRIM(ORD_UM)
	_X_QTAKG = ORD_QTAKG
	_X_QTAMQ = ORD_QTAMQ
	_X_QTAML = ORD_QTAML
	_X_QTAMC = ORD_QTAMC
	_X_QTANR = ORD_NUMBOB
	IF ALLTRIM(_X_UNIMIS) == 'KG'
		_X_QTAKG = ORD_QTAORD
	ENDIF
	IF ALLTRIM(_X_UNIMIS) == 'MQ'
		_X_QTAMQ = ORD_QTAORD
	ENDIF
	IF ALLTRIM(_X_UNIMIS) == 'ML'
		_X_QTAML = ORD_QTAORD
	ENDIF
	IF ALLTRIM(_X_UNIMIS) == 'MC'
		_X_QTAMC = ORD_QTAORD
	ENDIF
	IF ALLTRIM(_X_UNIMIS) == 'NR'
		_X_QTANR = ORD_QTAORD
	ENDIF
	
	_X_QTATEO = 0
	
	*** ESPRIMO LA QUANTITA' RESIDUA NELL'ORDINE A FORNITORE IN UNITA' DI MISURA DI MAGAZZINO
	DO CASE
		CASE _X_UNIMIS == _X_UMMAGA
			_X_QTATEO = _X_QTARES
		
		CASE _X_UMMAGA = 'KG'
			_X_QTATEO = ROUND(_X_QTARES * _X_QTAKG / _X_QTAORD, PUB_DECQTA)
			
		CASE _X_UMMAGA = 'MQ'
			_X_QTATEO = ROUND(_X_QTARES * _X_QTAMQ / _X_QTAORD, PUB_DECQTA)
			
		CASE _X_UMMAGA = 'ML'
			_X_QTATEO = ROUND(_X_QTARES * _X_QTAML / _X_QTAORD, PUB_DECQTA)
			
		CASE _X_UMMAGA = 'MC'
			_X_QTATEO = ROUND(_X_QTARES * _X_QTAMC / _X_QTAORD, PUB_DECQTA)
			
		CASE _X_UMMAGA = 'NR'
			_X_QTATEO = ROUND(_X_QTARES * _X_QTANR / _X_QTAORD, 0)
	ENDCASE
	
	_X_ORDFOR = _X_ORDFOR + _X_QTATEO

	SELECT TMP_ORF_DD
	SKIP +1
	
ENDDO
	
*** QUANTITA' IN PRODUZIONE PRODOTTO FINITO
_G_QTARESPRD = 0  && QUANTITA' RESIDUA DA PRODURRE
_G_QTAPRLPRD = 0  && SOLO QUANTITA' PRELEVATA
x_comp = "PA.COMP = '" + _par_anaart + "'"
x_open = "PR.FLGCLOSED = 0"
*x_cond = x_comp + " and " + x_open
**=> ERASMO - INIZIO 05/02/2015
IF !EMPTY(_par_datfin)
	x_cons = "PR.DTFIPR <= '" + RIBALTA2(_par_datfin) + "'"
ELSE
	x_cons = IIF(PUB_GGCNSO > 0, "PR.DTFIPR <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","PR.DTFIPR = PR.DTFIPR")
ENDIF
x_cond = x_comp + " and " + x_open + " and " + x_cons
**=> ERASMO - FINE 05/02/2015
cSql = "SELECT COALESCE(SUM(QTA - QTAPROD),0) AS QTADAPROD, COALESCE(SUM(QTAPREL),0) AS QTAPREL FROM ( " + CHR(13) + ;
       "	SELECT PA.QTA, PA.QTAPROD, PC.QTAPREL FROM PROD_AVANZA AS PA " + CHR(13) + ;
       "	INNER JOIN PRODUZIONE AS PR ON PR.IDPRG = PA.IDPRG AND PR.PARENT = '' " + CHR(13) + ;
       "	LEFT OUTER JOIN (SELECT IDPRG, FASELA, SEQUEN, SUM(CASE QTAPREL WHEN 0 THEN 1 ELSE QTAPREL END) AS QTAPREL FROM PROD_CARICHI WHERE QTAPROD = 0 GROUP BY IDPRG, FASELA, SEQUEN) AS PC " + CHR(13) + ;
       "		ON PA.IDPRG = PC.IDPRG AND PA.FASELA = PC.FASELA AND PA.SEQUEN = PC.SEQUEN " + CHR(13) + ;
       "	WHERE " + x_cond + ") AS MAIN"
IF !ExecCommand(cSql,"CX_PROD_QTANECT")
  return(.f.)
ENDIF
SELECT CX_PROD_QTANECT
GO TOP
IF !EOF()
	_G_QTARESPRD = QTADAPROD
	_G_QTAPRLPRD = QTAPREL
ENDIF
*_X_PRODUZ = _G_QTARESPRD
**=> ERASMO - INIZIO 02/04/2015
IF _par_solo_qtaprel
	_X_PRODUZ = _G_QTAPRLPRD 
ELSE
	_X_PRODUZ = _G_QTARESPRD
ENDIF
**=> ERASMO - FINE 02/04/2015

*** RICALCOLO CONSISTENZA SEMPLICE
_RIT = _X_GIACENZA - _X_ORDCLI - _X_ORDCLI_SEMILAV + _X_ORDFOR + _X_PRODUZ
	

*** SE IL PRODOTTO PASSATO E' UN GRUPPO DI.BA. LA CONSISTENZA VIENE ANCHE DETERMINATA IN BASE ALLE SUE COMPONENTI
**=> ERASMO - INIZIO 05/02/2015
CREATE CURSOR C_CONSIST_COMP (CODART C(16), DESART C(200), UM C(3), DIS_QTATOT N(19,PUB_DECQTA), GIACEN N(19,PUB_DECQTA), ;
	QTARESORD N(19,PUB_DECQTA), QTARESORF N(19,PUB_DECQTA), QTARESPRD N(19,PUB_DECQTA), QTAPRLPRD N(19,PUB_DECQTA), CONSIST N(19,PUB_DECQTA), QTAPROD N(19,PUB_DECQTA))
INDEX ON CODART TAG I_CODART ADDITIVE
**=> ERASMO - FINE 05/02/2015
x_grup = "DIT_GRUPPO = '" + _par_anaart + "'"
x_cond = x_grup
cSql = "SELECT DIT_GRUPPO FROM U_DIS_TT " + " WHERE " + x_cond
IF !ExecCommand(cSql,"TMP_DIS_TT")
  return(.f.)
ENDIF
SELECT TMP_DIS_TT
GO TOP
IF !EOF()  && GRUPPO DI.BA. -> CALCOLO SEMPLICE
	
	LOCAL _X_CODART,_X_DESART,_X_UM,_X_DIS_QTATOT,_X_QTARESORD,_X_GIACEN,_X_QTARESORF,_X_QTARESPRD,_X_QTAPRLPRD,_X_CONSIST
	
	*CREATE CURSOR C_CONSIST_COMP (CODART C(16), DESART C(200), UM C(3), DIS_QTATOT N(19,PUB_DECQTA), GIACEN N(19,PUB_DECQTA), ;
	*	QTARESORD N(19,PUB_DECQTA), QTARESORF N(19,PUB_DECQTA), QTARESPRD N(19,PUB_DECQTA), QTAPRLPRD N(19,PUB_DECQTA), CONSIST N(19,PUB_DECQTA), QTAPROD N(19,PUB_DECQTA))
	*INDEX ON CODART TAG I_CODART ADDITIVE
	
	*DO AQM_RILEVA_CONSISTENZA_COMPONENTI_NON_FITTIZIE WITH _par_anaart,1,_par_datfin
	DO AQM_RILEVA_CONSISTENZA_COMPONENTI_NON_FITTIZIE WITH _par_anaart,1,_par_datfin,_par_solo_qtaprel  && ERASMO - 02/04/2015
	
	LOCAL _X_MIN_CONSISTENZA
	
	SELECT C_CONSIST_COMP
	GO TOP
	SCAN
		IF DIS_QTATOT > 0
		ELSE
			LOOP
		ENDIF
		
		IF TYPE("_X_MIN_CONSISTENZA") <> 'N'
			_X_MIN_CONSISTENZA = CONSIST / DIS_QTATOT
		ELSE
			_X_MIN_CONSISTENZA = MIN(_X_MIN_CONSISTENZA, CONSIST / DIS_QTATOT)
		ENDIF
	ENDSCAN

	IF TYPE("_X_MIN_CONSISTENZA") <> 'N'
		_X_MIN_CONSISTENZA = 0
	ENDIF
	
	IF _X_UMMAGA = 'NR'
		_X_MIN_CONSISTENZA = ROUND(_X_MIN_CONSISTENZA,0)
	ENDIF
	
	IF _X_MIN_CONSISTENZA > 0
	ELSE
		_X_MIN_CONSISTENZA = 0
	ENDIF
	
	*** RICALCOLO CONSISTENZA
	_RIT = _RIT + _X_MIN_CONSISTENZA
ENDIF


SELECT(_AQM_SS)

RETURN _RIT


**********************************************************************
PROCEDURE AQM_RILEVA_CONSISTENZA_COMPONENTI_NON_FITTIZIE
**********************************************************************
LPARAMETERS _par_gruppo,_par_disqtatot,_par_datfin,_par_solo_qtaprel

LOCAL _cNomecur
_cNomecur = "CX_DIS_DD" + SYS(2015)

x_grup = "DIS.DIS_GRUPPO = '" + _par_gruppo + "'"
x_disq = "DIS.DIS_QTA > 0"
x_nomo = "ANA.ART_NONMOV = 0"
x_cond = x_grup + " and " + x_disq + " and " + x_nomo
cSql   = "SELECT DIS.DIS_CODART, DIS.DIS_DESCRI, DIS.DIS_FASELA, COALESCE(ANA.ART_UMMAGA,'') AS ART_UMMAGA, COALESCE(AN2.ART_NONVAL,CAST(0 AS BIT)) AS ART_NONVAL, " + CHR(13) + ;
         "DIS.DIS_QTA, DIS.DIS_FITTIZ, COALESCE(ANA.ART_MAGA,'') AS ART_MAGA, COALESCE(DIT.DIT_GRUPPO,'') AS DIT_GRUPPO FROM U_DIS_DD AS DIS " + CHR(13) + ;
         "LEFT OUTER JOIN U_ART_PR AS ANA ON ANA.ART_CODPRI = DIS.DIS_CODART " + CHR(13) + ;
         "LEFT OUTER JOIN U_ART_AN AS AN2 ON AN2.ART_CODPRI = ANA.ART_CODPRI " + CHR(13) + ;
         "LEFT OUTER JOIN U_DIS_TT AS DIT ON DIT.DIT_GRUPPO = DIS.DIS_CODART " + CHR(13) + ;
         "WHERE " + x_cond + " ORDER BY DIS.DIS_SEQUEN"
IF !ExecCommand(cSql,_cNomecur)
  return(.f.)
ENDIF

SELECT &_cNomecur
GO TOP
SCAN
	IF !EMPTY(DIS_FASELA)
		LOOP
	ENDIF
	
	_X_CODART = ALLTRIM(DIS_CODART)
	_X_DESART = ALLTRIM(DIS_DESCRI)
	_X_UM = ALLTRIM(ART_UMMAGA)
	_X_MAGA = ALLTRIM(ART_MAGA)
	_X_DIS_QTATOT = _par_disqtatot * DIS_QTA
	_X_DATFIN = _par_datfin  && ERASMO - 05/02/2015
	
	IF !DIS_FITTIZ  && NON DEVE ESSERE FITTIZIO
		*DO AQM_RILEVA_CONSISTENZA_AGGIUNGI_IN_CURSORE_COMPONENTI_NON_FITTIZIE
		DO AQM_RILEVA_CONSISTENZA_AGGIUNGI_IN_CURSORE_COMPONENTI_NON_FITTIZIE WITH _par_solo_qtaprel  && ERASMO - 02/04/2015
	ELSE
		*** CASO DEI PRODOTTI DI VENDITA CON COMPONENTI FITTIZI NON GESTITO, PER DIFFICOLTA' DI GESTIONE SUL RILEVAMENTO DEGLI ORDINI CLIENTI IN ESSERE CHE UTILIZZANO IL PRODOTTO COME SEMILAVORATO
		*DO AQM_RILEVA_CONSISTENZA_COMPONENTI_NON_FITTIZIE WITH _X_CODART,_X_DIS_QTATOT
		LOOP
	ENDIF	
ENDSCAN

SELECT &_cNomecur
USE

RETURN


****************************************************************************
PROCEDURE AQM_RILEVA_CONSISTENZA_AGGIUNGI_IN_CURSORE_COMPONENTI_NON_FITTIZIE
****************************************************************************
LPARAMETERS _par_solo_qtaprel  && ERASMO - 02/04/2015

*!*	SELECT C_CONSIST_COMP 
*!*	SET ORDER TO I_CODART
*!*	GO TOP

*!*	SEEK _X_CODART
*!*	IF FOUND()
*!*		SELECT C_CONSIST_COMP 
*!*		REPLACE QTARESORD      WITH QTARESORD + _X_QTARESORD
*!*		REPLACE QTAEVAORD      WITH QTAEVAORD + _X_QTAEVAORD
*!*		REPLACE QTAEVAORD_PREC WITH QTAEVAORD_PREC + _X_QTAEVAORD_PREC
*!*		REPLACE QTADISP        WITH GIACEN - QTARESORD
*!*		REPLACE CONSIST        WITH GIACEN - QTARESORD + QTARESORF + QTARESPRD
*!*		RETURN
*!*	ENDIF

*** GIACENZE
_X_GIACEN = 0
_ww_codsoc = PUB_CODSOC
_ww_anaart = _X_CODART
_ww_codmag = ""
*_ww_codmag = ""
_ww_prenot = .T.  && SOLO GIACENZE NON PRENOTATE
_ww_codint = ""
_ww_altezz = 0
_ww_lunghe = 0
_ww_fila_x = ""
_ww_pian_x = ""
_ww_ubic_x = ""
_X_GIACEN  = AQM_RILEVA_GIACENZE_DISPONIBILI(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x)


*** ORDINI A FORNITORE IN ESSERE
_X_QTARESORF = 0
**=> ERASMO - INIZIO 02/04/2015
IF PUB_FLCONF
	x_agga = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_CHIUSO = 0 AND ORD_FLGCON = 1)"  && SOLO ORDINI FORNITORI CONFERMATI (COME DA PARAMETRO AZIENDALE)
ELSE
	x_agga = "DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORF_TT WHERE ORD_CHIUSO = 0)"
ENDIF
**=> ERASMO - FINE 02/04/2015
x_comm = "ORD_DESART <> '*** COMMENTO ***'"
x_arti = "ORD_CODART = '" + _X_CODART + "'"
x_open = "(ORD_CHIUSO = 0 AND ORD_SALCON <> 'S')"
x_maga = "ORD_MAGA = ORD_MAGA"
*x_cons = IIF(PUB_GGCNSO > 0, "ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","ORD_DATCON = ORD_DATCON")
**=> ERASMO - INIZIO 05/02/2015
IF !EMPTY(_X_DATFIN)
	x_cons = "ORD_DATCON <= '" + RIBALTA2(_X_DATFIN) + "'"
ELSE
	x_cons = IIF(PUB_GGCNSO > 0, "ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","ORD_DATCON = ORD_DATCON")
ENDIF
**=> ERASMO - FINE 05/02/2015
*x_cond = x_comm + " and " + x_arti + " and " + x_open + " and " + x_maga + " and " + x_cons 
x_cond = x_agga + " and " + x_comm + " and " + x_arti + " and " + x_open + " and " + x_maga + " and " + x_cons  && ERASMO - 02/04/2015
cSql = "SELECT DAGGANCIO, ORS_NUMORD, ORS_RAGSOC, ORD_DATCON, ORD_MAGA, ORS_CODCLI, ORD_CODART, ORD_CODCOL, ORD_ALTEZZ, ORD_LUNGHE, ORD_UM, " + ;
       "ORD_QTAORD, ORD_QTAEV, ORD_QTAMQ, ORD_QTAKG, ORD_QTAML, ORD_QTAMC, ORD_NUMBOB FROM U_ORF_DD " + ;
       "WHERE " + x_cond + " ORDER BY ORD_DATCON"
IF !ExecCommand(cSql,"TMP_ORF_DD")
  return(.f.)
ENDIF
SELECT TMP_ORF_DD
GO TOP
SCAN
	
	_Y_QTAORD = ORD_QTAORD
	_Y_QTAEV  = ORD_QTAEV
	_Y_QTARES = ORD_QTAORD - ORD_QTAEV
	IF _Y_QTARES < 0
		_Y_QTARES = 0
	ENDIF
	IF _Y_QTARES > 0
	ELSE
		SELECT TMP_ORF_DD
		LOOP
	ENDIF
	
	_Y_UNIMIS = ALLTRIM(ORD_UM)
	_Y_QTAKG = ORD_QTAKG
	_Y_QTAMQ = ORD_QTAMQ
	_Y_QTAML = ORD_QTAML
	_Y_QTAMC = ORD_QTAMC
	_Y_QTANR = ORD_NUMBOB
	IF ALLTRIM(_Y_UNIMIS) == 'KG'
		_Y_QTAKG = ORD_QTAORD
	ENDIF
	IF ALLTRIM(_Y_UNIMIS) == 'MQ'
		_Y_QTAMQ = ORD_QTAORD
	ENDIF
	IF ALLTRIM(_Y_UNIMIS) == 'ML'
		_Y_QTAML = ORD_QTAORD
	ENDIF
	IF ALLTRIM(_Y_UNIMIS) == 'MC'
		_Y_QTAMC = ORD_QTAORD
	ENDIF
	IF ALLTRIM(_Y_UNIMIS) == 'NR'
		_Y_QTANR = ORD_QTAORD
	ENDIF
	
	_Y_QTATEO = 0
	
	_ummaga = AQM_TROVA_UMMAGA(_X_CODART)
	
	*** ESPRIMO LA QUANTITA' RESIDUA NELL'ORDINE A FORNITORE IN UNITA' DI MISURA DI MAGAZZINO
	DO CASE
		CASE _Y_UNIMIS == _ummaga
			_Y_QTATEO = _Y_QTARES
		
		CASE _ummaga = 'KG'
			_Y_QTATEO = ROUND(_Y_QTARES * _Y_QTAKG / _Y_QTAORD, PUB_DECQTA)
			
		CASE _ummaga = 'MQ'
			_Y_QTATEO = ROUND(_Y_QTARES * _Y_QTAMQ / _Y_QTAORD, PUB_DECQTA)
			
		CASE _ummaga = 'ML'
			_Y_QTATEO = ROUND(_Y_QTARES * _Y_QTAML / _Y_QTAORD, PUB_DECQTA)
			
		CASE _ummaga = 'MC'
			_Y_QTATEO = ROUND(_Y_QTARES * _Y_QTAMC / _Y_QTAORD, PUB_DECQTA)
			
		CASE _ummaga = 'NR'
			_Y_QTATEO = ROUND(_Y_QTARES * _Y_QTANR / _Y_QTAORD, 0)
	ENDCASE
	
	_X_QTARESORF = _X_QTARESORF + _Y_QTATEO

	SELECT TMP_ORF_DD
ENDSCAN

*** QUANTITA' IN PRODUZIONE E GIA' PRELEVATE
_X_QTARESPRD = 0
_X_QTAPRLPRD = 0
x_comp = "PA.COMP = '" + _X_CODART + "'"
x_open = "PR.FLGCLOSED = 0"
*x_cond = x_comp + " and " + x_open
**=> ERASMO - INIZIO 05/02/2015
IF !EMPTY(_X_DATFIN)
	x_cons = "PR.DTFIPR <= '" + RIBALTA2(_X_DATFIN) + "'"
ELSE
	x_cons = IIF(PUB_GGCNSO > 0, "PR.DTFIPR <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","PR.DTFIPR = PR.DTFIPR")
ENDIF
x_cond = x_comp + " and " + x_open + " and " + x_cons
**=> ERASMO - FINE 05/02/2015
cSql = "SELECT COALESCE(SUM(QTA - QTAPROD),0) AS QTADAPROD, COALESCE(SUM(QTAPREL),0) AS QTAPREL FROM ( " + CHR(13) + ;
       "	SELECT PA.QTA, PA.QTAPROD, PC.QTAPREL FROM PROD_AVANZA AS PA " + CHR(13) + ;
       "	INNER JOIN PRODUZIONE AS PR ON PR.IDPRG = PA.IDPRG AND PR.PARENT = '' " + CHR(13) + ;
       "	LEFT OUTER JOIN (SELECT IDPRG, FASELA, SEQUEN, SUM(CASE QTAPREL WHEN 0 THEN 1 ELSE QTAPREL END) AS QTAPREL FROM PROD_CARICHI WHERE QTAPROD = 0 GROUP BY IDPRG, FASELA, SEQUEN) AS PC " + CHR(13) + ;
       "		ON PA.IDPRG = PC.IDPRG AND PA.FASELA = PC.FASELA AND PA.SEQUEN = PC.SEQUEN " + CHR(13) + ;
       "	WHERE " + x_cond + ") AS MAIN"
IF !ExecCommand(cSql,"CX_PROD_QTANECT")
  return(.f.)
ENDIF
SELECT CX_PROD_QTANECT
GO TOP
IF !EOF()
	_X_QTARESPRD = QTADAPROD
	_X_QTAPRLPRD = QTAPREL
ENDIF


_X_QTARESORD = 0
*** ORDINI CLIENTI IN ESSERE CHE UTILIZZANO IL PRODOTTO COME SEMILAVORATO
x_agga = "U_ORD_DD.DAGGANCIO IN (SELECT TAGGANCIO FROM U_ORD_TT WHERE ORD_CHIUSO = 0)"
x_comm = "U_ORD_DD.ORD_DESART <> '*** COMMENTO ***'"
x_open = "(U_ORD_DD.ORD_CHIUSO = 0 AND U_ORD_DD.ORD_SALCON <> 'S')"
*x_cons = IIF(PUB_GGCNSO > 0, "U_ORD_DD.ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","U_ORD_DD.ORD_DATCON = U_ORD_DD.ORD_DATCON")
**=> ERASMO - INIZIO 05/02/2015
IF !EMPTY(_X_DATFIN)
	x_cons = "ORD_DATCON <= '" + RIBALTA2(_X_DATFIN) + "'"
ELSE
	x_cons = IIF(PUB_GGCNSO > 0, "ORD_DATCON <= '" + RIBALTA2(DTOC(DATE() + PUB_GGCNSO)) + "'","ORD_DATCON = ORD_DATCON")
ENDIF
**=> ERASMO - FINE 05/02/2015
x_cond = x_agga + " and " + x_comm + " and " + x_open + " and " + x_maga + " and " + x_cons
cSql = "SELECT CASE WHEN (ORD_QTAORD - ORD_QTAEV) > 0 THEN (ORD_QTAORD - ORD_QTAEV) ELSE 0 END AS ORD_QTARES, DIS.DIS_QTA " + CHR(13) + ;
       "FROM U_ORD_DD " + CHR(13) + ;
       "RIGHT OUTER JOIN U_DIS_DD AS DIS ON DIS.DIS_GRUPPO = U_ORD_DD.ORD_CODART AND DIS.DIS_CODART = '" + _X_CODART + "' " + CHR(13) + ;
       "WHERE " + x_cond
IF !ExecCommand(cSql,"TMP_ORD_DD")
  return(.f.)
ENDIF
SELECT TMP_ORD_DD
GO TOP
SCAN
	_X_QTARESORD = _X_QTARESORD + (ORD_QTARES * DIS_QTA)
ENDSCAN

*_X_CONSIST = _X_GIACEN - _X_QTARESORD + _X_QTARESORF + _X_QTARESPRD
**=> ERASMO - INIZIO 02/04/2015
IF _par_solo_qtaprel
	_X_CONSIST = _X_GIACEN - _X_QTARESORD + _X_QTARESORF + _X_QTAPRLPRD 
ELSE
	_X_CONSIST = _X_GIACEN - _X_QTARESORD + _X_QTARESORF + _X_QTARESPRD
ENDIF
**=> ERASMO - FINE 02/04/2015

SELECT C_CONSIST_COMP 
APPEND BLANK
REPLACE CODART         WITH _X_CODART
REPLACE DESART         WITH _X_DESART
REPLACE UM             WITH _X_UM
REPLACE DIS_QTATOT     WITH _X_DIS_QTATOT 
REPLACE QTARESORD      WITH _X_QTARESORD
REPLACE GIACEN         WITH _X_GIACEN
REPLACE QTARESORF      WITH _X_QTARESORF
REPLACE QTARESPRD      WITH _X_QTARESPRD
REPLACE QTAPRLPRD      WITH _X_QTAPRLPRD
REPLACE CONSIST        WITH _X_CONSIST 

RETURN
