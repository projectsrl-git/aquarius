*!*			*!*	NON TOCCA LA GIACENZA IN QUANTO NON ESISTE NULLA A MAGAZZINO

*!*		    =AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()
*!*			=ACCESSO_ANAGRAFICA_FORNITORE()
*!*			=ACCESSO_ANAGRAFICA_CLIENTE()
*!*			=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)

*!*			LOCAL_AQM_GIACEN 		= AQM_GIACEN
*!*			ORIGINALE_AQM_GIACEN  	= AQM_GIACEN
*!*			ORIGINALE_AQM_CODFOR	= AQM_CODFOR
*!*			ORIGINALE_AQM_DESFOR    = AQM_DESFOR 
*!*	   		ORIGINALE_AQM_PREACQ	= ORIGINALE_ANAGRAFICA_ARTICOLI_AQM_PREACQ 
*!*			LOCAL_DATAOGGI   		= RIBALTA2(DTOC(DATE()))
*!*			LOCAL_MOVIMENTO 		= "CREA-MOVIMENTO"
*!*			
*!*			_XDB_TOP_SAVE   		= AQM_TOP		&& SALVATAGGIO DEL TOP ORIGINALE
*!*			AQM_TOP					= "M++"			&& CARICO DI MAGAZZINO
*!*			=ACCESSO_PARAMETRO_TOP()
*!*			=AQM_CREA_U_MAG_MO(LOCAL_MOVIMENTO)

*!*			AQM_TOP			= _XDB_TOP_SAVE 		&& SCARICO DI MAGAZZINO
*!*			=ACCESSO_PARAMETRO_TOP()
*!*			=AQM_CREA_U_MAG_MO(LOCAL_MOVIMENTO)


*!*	ENDIF

SELECT(_AQM_SEL)

RETURN _OK_SCARICA_MAGAZZINO


************************************
FUNCTION ULTIMO_DOCUMENTO_NON_AQMLIB
************************************

LPARAMETERS _par_tipdoc

IF PCOUNT() >= 1
ELSE
	RETURN ""
ENDIF

_par_tipdoc = UPPER(ALLTRIM(_par_tipdoc))

IF EMPTY(_par_tipdoc) .AND. ;
	_par_tipdoc <> "BOL" .AND. ;
	_par_tipdoc <> "BFO" .AND. ;
	_par_tipdoc <> "REF"
	RETURN ""
ENDIF

LOCAL _AQM_SEL
_AQM_SEL=SELECT()

_cUltimoAggancio = ""

x_cond = "CODICE = 'AQM" + _par_tipdoc + "'"
*cSql   = "SELECT ID_UNIQUE, CODICE, DESCRI, LIBERA, PAR_DATINS FROM PARA where " + x_cond
cSql   = "SELECT * FROM PARA where " + x_cond   
IF !ExecRW(cSql,"PARA","R")
   RETURN .F.
ENDIF
SELECT PARA
GO TOP
IF EOF()
	*_cNomeTabella_tt = "U_" + _par_tipdoc + "_TT"
	*_cNomeCursore_tt = "CX_" + _par_tipdoc + "_TT"
	_cNomeTabella_tt = ""
	_cNomeCursore_tt = ""
	DO CASE
		CASE _par_tipdoc == "BOL"
			_cNomeTabella_tt = "U_BOL_TT"
			_cNomeCursore_tt = "CX_BOL_TT"
		CASE _par_tipdoc == "BFO"
			_cNomeTabella_tt = "U_BFO_TT"
			_cNomeCursore_tt = "CX_BFO_TT"
		CASE _par_tipdoc == "REF"
			_cNomeTabella_tt = "U_BOL_TT"
			_cNomeCursore_tt = "CX_BOL_TT"
		CASE _par_tipdoc == "BCL"			
			_cNomeTabella_tt = "U_BOL_TT"	
			_cNomeCursore_tt = "CX_BOL_TT"	
	ENDCASE
	cSql   = "SELECT TOP 1 TAGGANCIO FROM " + _cNomeTabella_tt + " ORDER BY TAGGANCIO DESC"
	IF !ExecCommand(cSql,_cNomeCursore_tt)
	   RETURN .F.
	ENDIF
	SELECT &_cNomeCursore_tt 
	GO TOP
	IF EOF()
		_cUltimoAggancio = "0000000000"
	ELSE
		_cUltimoAggancio = TAGGANCIO
	ENDIF

	SELECT PARA
	APPEND BLANK
	REPLACE CODICE WITH "AQM" + _par_tipdoc
	REPLACE DESCRI WITH "ULTIMO AGGANCIO TABELLA " + _cNomeTabella_tt + " NON GESTIBILE TRAMITE NUOVE PROCEDURE DI MAGAZZINO AQMLIB"
	REPLACE LIBERA WITH _cUltimoAggancio 
	REPLACE PAR_DATINS WITH RIBALTA2(DTOC(DATE())) 
ELSE
	_cUltimoAggancio = ALLTRIM(LIBERA)
ENDIF
IF !ExecRW(cSql,"PARA","W")
   RETURN .F.
ENDIF

SELECT(_AQM_SEL)

RETURN _cUltimoAggancio


*******************************************
PROCEDURE RESET_ULTIMO_DOCUMENTO_NON_AQMLIB
*******************************************

x_cond = "CODICE LIKE 'AQM%'"
cSql   = "SELECT SPACE(10) AS SELEZIONE, * FROM PARA where " + x_cond + " order by CODICE"
IF !ExecCommand(cSql,"SEL_PARA")
   RETURN .F.
ENDIF
SELECT SEL_PARA
GO TOP
IF EOF()
	MESSAGEBOX("Nessun parametro da resettare",64,"Informazione")
	RETURN
ENDIF
REPLACE SELEZIONE WITH "==>" ALL
GO TOP

DO prg\browseview WITH "SEL_PARA","Selezionare i parametri da eliminare","CODICE:Codice,W:10;DESCRI:Descrizione,W:80;PAR_DATINS:Data creazione,W:10;",500,800,.T.,.F.

IF NumeroRecordLetti > 0
ELSE
	MESSAGEBOX("Nessun parametro selezionato",64,"Informazione")
	RETURN .F.
ENDIF

_RISP = MESSAGEBOX("Confermare l'eliminazione dei parametri selezionati?",4+32+256,"Attenzione")
IF _RISP = 6
ELSE
	MESSAGEBOX("Nessun parametro resettato",64,"Informazione")
	RETURN .F.
ENDIF

_nDELETED = 0
SELECT SEL_PARA
GO TOP
SCAN
	IF ALLTRIM(SELEZIONE) == "==>"
		x_cond = "CODICE = '" + ALLTRIM(CODICE) + "'"
		cSql   = "DELETE FROM PARA where " + x_cond
		IF !ExecCommand(cSql,"DEL_PARA")
		   RETURN .F.
		ENDIF
		_nDELETED = _nDELETED + 1
	ENDIF
ENDSCAN

IF _nDELETED > 0
	MESSAGEBOX(ALLTRIM(STR(_nDELETED,10,0)) + " parametri resettati",64,"Informazione")
	RETURN .F.
ELSE
	MESSAGEBOX("Nessun parametro resettato",64,"Informazione")
	RETURN .F.
ENDIF

RETURN


**************************************
FUNCTION AQM_SPOSTA_GIACENZE_MAGAZZINO
**************************************

LPARAMETERS _par_nomecur,_par_topsca,_par_topcar,_par_legsys,_par_note,_par_numdoc,_par_dtdocu,_par_impegna,_par_gianeg,_par_oksrcdest,_par_scarica_impegnato,_par_new_legame

IF PCOUNT() >= 3
ELSE
	MESSAGEBOX("Parametri insufficienti per la FUNCTION AQM_SPOSTA_GIACENZE_MAGAZZINO",16,"Attenzione")
	RETURN .F.
ENDIF

IF PCOUNT() >= 4
ELSE
	_par_legsys = ""
ENDIF

IF PCOUNT() >= 5
ELSE
	_par_note = ""
ENDIF

RELEASE PUB_NOTEMOV
PUBLIC PUB_NOTEMOV
PUB_NOTEMOV = _par_note

IF PCOUNT() >= 6
ELSE
	_par_numdoc = ""
ENDIF

IF PCOUNT() >= 7
	IF SUBSTR(_par_dtdocu,3,1) = "/"
		_par_dtdocu = RIBALTA2(_par_dtdocu)
	ENDIF
ELSE
	_par_dtdocu = ""
ENDIF

IF PCOUNT() >= 8
ELSE
	_par_impegna = .F.
ENDIF

IF PCOUNT() >= 9
ELSE
	_par_gianeg = .F.
ENDIF

IF PCOUNT() >= 10
ELSE
	_par_oksrcdest = .F.
ENDIF

**=> ERASMO - INIZIO 28/03/2014
IF PCOUNT() >= 11
ELSE
	_par_scarica_impegnato = .F.
ENDIF
**=> ERASMO - FINE 28/03/2014

**=> ERASMO - INIZIO 13/02/2015
IF PCOUNT() >= 12
ELSE
	_par_new_legame = .F.
ENDIF
**=> ERASMO - FINE 13/02/2015


LOCAL _AQM_SEL
_AQM_SEL=SELECT()

AQM_NUMMOV_LOCALE = AQM_RILEVA_NUMERO_INTERNO()

_lRit = .T.

SELECT &_par_nomecur
GO TOP
IF EOF()
	RETURN .F.
ENDIF
DO WHILE !EOF()
	IF DELETED()
		SKIP +1
		LOOP
	ENDIF
	
	*IF MAG_CODMAG = MAG_CDMDES .AND. MAG_FILA_X = MAG_FILDES_X .AND. MAG_PIAN_X = MAG_PIADES_X .AND. MAG_UBIC_X = MAG_UBIDES_X
	IF (MAG_CODMAG = MAG_CDMDES .AND. MAG_FILA_X = MAG_FILDES_X .AND. MAG_PIAN_X = MAG_PIADES_X .AND. MAG_UBIC_X = MAG_UBIDES_X) AND !_par_oksrcdest  && ORIGINE E DESTINAZIONE POTREBBERO COINCIDERE NEL CASO PER ESEMPIO DI GESTIONE DEL SOLO IMPEGNATO
		MESSAGEBOX("Coordinate di Origine e Destinazione coincidenti" + CHR(13) + CHR(13) + ;
			"Impossibile spostare",16,"Attenzione")
		_lRit = .F.
		EXIT
	ENDIF
	
	IF MAG_PRENOT
		MESSAGEBOX("Giacenza prenotata per la produzione" + CHR(13) + CHR(13) + ;
			"Impossibile spostare",16,"Attenzione")
		_lRit = .F.
		EXIT
	ENDIF
	
	*IF MAG_QTAIMP > 0
	*	MESSAGEBOX("Giacenza impegnata in parte o completamente" + CHR(13) + CHR(13) + 
	*IF !_par_gianeg AND (MAG_GIADES - (MAG_GIACEN - MAG_QTAIMP)) <= 0			 
	IF !_par_gianeg AND ((MAG_GIACEN - MAG_QTAIMP) - MAG_GIADES) < 0  && ERASMO - 27/05/2014 - IL TEST ERA ERRATO
		MESSAGEBOX("Giacenza impegnata completamente" + CHR(13) + CHR(13) + ;	 
			"Impossibile spostare",16,"Attenzione")
		_lRit = .F.
		EXIT
	ENDIF
	
	SELECT &_par_nomecur
	SKIP +1
ENDDO

IF !_lRit
	SELECT(_AQM_SEL)
	RETURN .F.
ENDIF

_OK_GIACENZE_SCARICATE = .T.
_OK_GIACENZE_CARICATE = .T.

SELECT &_par_nomecur
GO TOP
IF EOF()
	RETURN .F.
ENDIF
DO WHILE !EOF()
	IF DELETED()
		SKIP +1
		LOOP
	ENDIF
	
	IF EMPTY(MAG_CDMDES)
		SKIP +1
		LOOP
	ENDIF
	
	IF MAG_GIADES > 0
	ELSE
		SKIP +1
		LOOP
	ENDIF
	
	M.MAG_SERDES = ""  && ERASMO - 27/05/2014
	
	SCATTER MEMVAR MEMO
	
	_ww_codsoc = M.MAG_CODSOC
	_ww_unique = M.MAG_UNIQUE
	_giac_disp = AQM_RILEVA_GIACENZA_LIBERA(_ww_codsoc,_ww_unique)
	
	SELECT LOCAL_U_MAG_GG
	GO TOP       
	*IF !EOF()
	IF !EOF() OR _par_gianeg  && ANCHE SENZA GIACENZA, SE PASSATO APPOSITO PARAMETRO
		
		*SCATTER MEMVAR MEMO
		IF !EOF()
			SCATTER MEMVAR MEMO
		ENDIF
		
        =AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
        =AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
		AQM_TOP = _par_topsca  && CAUSALE DI SCARICO
		IF !EMPTY(_par_numdoc)
			AQM_NUMDOC = _par_numdoc
		ENDIF
		IF !EMPTY(_par_dtdocu)
			AQM_DTDOCU = _par_dtdocu
		ENDIF
		=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

		*** DEFINIZIONE VARIABILI LOCALI DI GESTIONE 
		LOCAL_AQM_GIACEN = M.MAG_GIADES
		*LOCAL_AQM_QTAKG  = AQM_QTAKG
		*LOCAL_AQM_QTAMQ  = AQM_QTAMQ
		*LOCAL_AQM_QTAML  = AQM_QTAML
		
		*IF _giac_disp >= LOCAL_AQM_GIACEN
		IF _giac_disp >= LOCAL_AQM_GIACEN OR _par_gianeg   
				
			LOCAL_DATAOGGI   = RIBALTA2(DTOC(DATE()))

			*** ACCESSI ANAGRAFICI
			=ACCESSO_PARAMETRO_TOP()
			=ACCESSO_ANAGRAFICA_FORNITORE()
			=ACCESSO_ANAGRAFICA_CLIENTE()
			=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)
			
			IF !EMPTY(_par_legsys)
				AQM_LEGSYS = _par_legsys
			ENDIF

			*_Y_SCAR = AQM_SCARICA_GIACENZA()  && SCARICA LA GIACENZA DA U_MAG_GG
			_Y_SCAR = AQM_SCARICA_GIACENZA(_par_scarica_impegnato)  && ERASMO - 28/03/2014
			
			IF _Y_SCAR
				
				=AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
				=AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
				AQM_TOP = _par_topcar  && CAUSALE DI SCARICO
				IF !EMPTY(_par_numdoc)
					AQM_NUMDOC = _par_numdoc
				ENDIF
				IF !EMPTY(_par_dtdocu)
					AQM_DTDOCU = _par_dtdocu
				ENDIF
				AQM_CODMAG = M.MAG_CDMDES
				AQM_FILA_N = M.MAG_FILDES_N
				AQM_PIAN_N = M.MAG_PIADES_N
				AQM_UBIC_N = M.MAG_UBIDES_N
				AQM_FILA_X = M.MAG_FILDES_X
				AQM_PIAN_X = M.MAG_PIADES_X
				AQM_UBIC_X = M.MAG_UBIDES_X
				*AQM_LEGSYS = SYS(2015)
				AQM_UNIQUE = SYS(2015)
				AQM_DATAGG = RIBALTA2(DTOC(DATE()))
				AQM_ORACAR = TIME()
				AQM_GIACEN = M.MAG_GIADES
				
				**=> ERASMO - INIZIO 27/05/2014
				*** DURANTE LO SPOSTAMENTO FORZO IL S/N - LOTTO NELLA RIGA DI GIACENZA DI DESTINAZIONE
				IF !EMPTY(M.MAG_SERDES)
					AQM_SERIAL = M.MAG_SERDES
				ENDIF
				**=> ERASMO - FINE 27/05/2014
				
				IF _par_impegna
					AQM_QTAIMP = AQM_GIACEN
				ELSE
					AQM_QTAIMP = 0
				ENDIF
				
				*** VALORIZZO LA QTA IN UM MAGAZZINO CON LA QTA DA CARICARE
				_X_UMMAGA = AQM_TROVA_UMMAGA(AQM_ANAART)
				DO CASE
					CASE ALLTRIM(_X_UMMAGA) == "KG"
						AQM_QTAKG = M.MAG_GIADES
					CASE ALLTRIM(_X_UMMAGA) == "MQ"
						AQM_QTAMQ = M.MAG_GIADES
						AQM_QTANR = TROVA_NR_DA_MQ_LEGNO(M.MAG_ALTEZZ,M.MAG_LUNGHE,M.MAG_GIADES)
					CASE ALLTRIM(_X_UMMAGA) == "ML"
						AQM_QTAML = M.MAG_GIADES
					CASE ALLTRIM(_X_UMMAGA) == "MC"
						AQM_QTAMC = M.MAG_GIADES
						AQM_QTANR = TROVA_NR_DA_MC_LEGNO(M.MAG_ALTEZZ,M.MAG_LUNGHE,M.MAG_GIADES,M.MAG_SPESSO)
					CASE ALLTRIM(_X_UMMAGA) == "NR" 				
						AQM_QTANR = M.MAG_GIADES  					
					CASE ALLTRIM(_X_UMMAGA) == "N." 				
						AQM_QTANR = M.MAG_GIADES  					
					CASE ALLTRIM(_X_UMMAGA) == "N" 					
						AQM_QTANR = M.MAG_GIADES  					
				ENDCASE				


				IF !EMPTY(_par_legsys)
					AQM_LEGSYS = _par_legsys
				ENDIF
				
				*_YES_CAR = AQM_CARICA_MAGAZZINO()  && CARICA LA GIACENZA SU U_MAG_GG
				*_YES_CAR = AQM_CARICA_MAGAZZINO(AQM_LEGAME)  && ERASMO - 04/02/2015 - CARICA LA GIACENZA SU U_MAG_GG CON LO STESSO LEGAME PRECEDENTE (PER NON PERDERE LEGAME CON EVENTUALE MOVIMENTO DI CARICO ORIGINALE)
				**=> ERASMO - INIZIO 13/02/2015
				IF _par_new_legame
					_YES_CAR = AQM_CARICA_MAGAZZINO()  && CARICA LA GIACENZA SU U_MAG_GG CON UN NUOVO LEGAME
				ELSE
					_YES_CAR = AQM_CARICA_MAGAZZINO(AQM_LEGAME)  && CARICA LA GIACENZA SU U_MAG_GG CON LO STESSO LEGAME PRECEDENTE (PER NON PERDERE LEGAME CON EVENTUALE MOVIMENTO DI CARICO ORIGINALE)
				ENDIF
				**=> ERASMO - FINE 13/02/2015
				IF !_YES_CAR
					MESSAGEBOX("Si č verificato un errore generico durante il carico del magazzino" + CHR(13) + CHR(13) + ;
						"Le giacenze non verranno aggiornate completamente",16,"Attenzione")
					_OK_GIACENZE_CARICATE = .F.
					EXIT
				ENDIF
				
				**=> ERASMO - INIZIO 17/06/2014
				SELECT &_par_nomecur
				AFIELDS(A_STRU_CURSORE)
				IF ASCAN(A_STRU_CURSORE,"MAG_NEWUNQ",1,ALEN(A_STRU_CURSORE,1),1,8) > 0
					SELECT &_par_nomecur
					REPLACE MAG_NEWUNQ WITH AQM_UNIQUE
				ENDIF
				**=> ERASMO - FINE 17/06/2014
				
				**=> ERASMO - INIZIO 05/12/2014
				SELECT &_par_nomecur
				IF ASCAN(A_STRU_CURSORE,"MAG_NEWLEG",1,ALEN(A_STRU_CURSORE,1),1,8) > 0
					SELECT &_par_nomecur
					REPLACE MAG_NEWLEG WITH AQM_LEGAME
				ENDIF
				**=> ERASMO - FINE 05/12/2014
				
			ELSE
				MESSAGEBOX("Si č verificato un errore generico durante lo scarico del magazzino" + CHR(13) + CHR(13) + ;
					"Le giacenze non verranno aggiornate completamente",16,"Attenzione")
				_OK_GIACENZE_SCARICATE = .F.
				EXIT
			ENDIF
		
		ELSE

			MESSAGEBOX("Giacenza non disponibile",16,"Attenzione")
			_OK_GIACENZE_SCARICATE = .F.
			EXIT
		
		ENDIF

	ELSE 																		&& NON ESISTE GIACENZA O LA GIACENZA E' GIA' IMPEGNATA							

		MESSAGEBOX("Giacenza non disponibile",16,"Attenzione")
		_OK_GIACENZE_SCARICATE = .F.
		EXIT

	ENDIF
	
	SELECT &_par_nomecur
	SKIP +1
ENDDO

RELEASE PUB_NOTEMOV   

IF _OK_GIACENZE_SCARICATE .AND. _OK_GIACENZE_CARICATE
ELSE
	_lRit = .F.
ENDIF

SELECT(_AQM_SEL)

RETURN _lRit


******************************************
FUNCTION AQM_GESTIONE_DETTAGLI_DDT_CLAVORO
******************************************

LOCAL _AQM_SDDTS
_AQM_SDDTS=SELECT()

AQM_NUMMOV_LOCALE  = AQM_RILEVA_NUMERO_INTERNO()

SET DELETED OFF

SELECT CU_BOL_DD
SET FILTER TO
SET ORDER TO SEQUEN
GO TOP

DO WHILE .NOT. EOF()

   *IF DELETED()
   *   SKIP +1
   *   LOOP
   *ENDIF
   
   IF DELETED()
      IF ALLTRIM(ORD_DESART) <> "*** COMMENTO ***"
			SCATTER MEMVAR MEMO
   			IF PUB_SAU AND !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)
	            =AQM_RICARICA_DA_MAGAZZINO_CLAVORO()
            ENDIF
      ENDIF
      SELECT CU_BOL_DD
      =AQM_CANCELLA_U_BOL_DD("U_BOL_DD")
      SELECT CU_BOL_DD
      SKIP +1
      LOOP
   ENDIF

   REPLACE DAGGANCIO WITH X_TAGG
   IF EMPTY(ORD_SYSMAG)
   		REPLACE ORD_SYSMAG WITH SYS(2015)		&& SI TRATTA DI UNA RIGA DDT CLIENTE , IDENTIFICO IL SYS DI LEGAME POI AL RECORD DI MAGAZZINO U_MAG_MO
   ENDIF
   
   IF ALLTRIM(ORD_DESART) <> "*** COMMENTO ***"
   
	   DO CASE 
	   
			CASE ALLTRIM(ORD_FLGMOD) = 'I'			&& INSERIMENTO RECORD DDT 			## ARTICOLO VERO ##
				
				SCATTER MEMVAR MEMO
				
	   			IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
		            =AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		            =AQM_VALORIZZA_VARIABILI_MAGAZZINO("MENU_BCL000")
		            _YES_SCAR = AQM_MOVIMENTA_MAGAZZINO_DDT_CLAVORO()
		            IF _YES_SCAR
		            	SELECT CU_BOL_DD
		            	SCATTER MEMVAR MEMO
						=AQM_INSERISCE_RIGA_ARTICOLO_DDT("U_BOL_DD")
		            ELSE
						MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze" + CHR(13) + CHR(13) + ;
							"I dettagli DDT non verranno aggiornati completamente",16,"Attenzione")
						SELECT CU_BOL_DD
						DELETE
						SKIP +1
						LOOP
		            ENDIF
	            
	            ELSE
	            
	            	SELECT CU_BOL_DD
					=AQM_INSERISCE_RIGA_ARTICOLO_DDT("U_BOL_DD")
	            
	            ENDIF


			CASE ALLTRIM(ORD_FLGMOD) = 'M'			&& MODIFICA RECORD DDT 				## ARTICOLO VERO ##
				
				SCATTER MEMVAR MEMO
				
	   			IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
	   				_OLD_LEGSYS = M.ORD_SYSMAG
	   				=AQM_RICARICA_DA_MAGAZZINO_CLAVORO()
					DO AQM_ATTENDI_N_SECONDI WITH 1  && ATTENDO IL SECONDO SUCCESSIVO PER DIFFERENZIARE CRONOLOGICAMENTE I MOVIMENTI DI CARICO/SCARICO
					REPLACE ORD_SYSMAG WITH ORD_SYSMAG_RIGENERATO 	
					M.ORD_SYSMAG = ORD_SYSMAG_RIGENERATO
		            =AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		            =AQM_VALORIZZA_VARIABILI_MAGAZZINO("MENU_BCL000")
		            _YES_SCAR = AQM_MOVIMENTA_MAGAZZINO_DDT_CLAVORO()
		            IF _YES_SCAR
		            	SELECT CU_BOL_DD
		            	SCATTER MEMVAR MEMO
						=AQM_MODIFICA_RIGA_ARTICOLO_DDT("U_BOL_DD")
		            ELSE
						MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze" + CHR(13) + CHR(13) + ;
							"I dettagli DDT non verranno aggiornati completamente",16,"Attenzione")
						SELECT CU_BOL_DD
						DELETE
						SKIP +1
						LOOP
		            ENDIF
	            
	            ELSE
	            	
	            	SELECT CU_BOL_DD
					=AQM_MODIFICA_RIGA_ARTICOLO_DDT("U_BOL_DD")
	            
	            ENDIF
	            
	 
			CASE ALLTRIM(ORD_FLGMOD) = 'A'			&& ANNULLO RECORD DDT                ## ARTICOLO VERO ##
				
				SCATTER MEMVAR MEMO
				
	   			IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
	   				=AQM_RICARICA_DA_MAGAZZINO_CLAVORO()
	            ENDIF
				
				SELECT CU_BOL_DD
	 			=AQM_CANCELLA_U_BOL_DD("U_BOL_DD")
 		
 		ENDCASE

    ELSE
    	
    	SCATTER MEMVAR MEMO
    
    	DO CASE

			CASE ALLTRIM(ORD_FLGMOD) = 'I'			&& INSERISCE RECORD DDT              ## *** COMMENTO *** ##

	    		=AQM_INSERISCE_COMMENTI_AUTOMATICI_DDT("U_BOL_DD")  


			CASE ALLTRIM(ORD_FLGMOD) = 'M'			&& MODIFICA RECORD DDT               ## *** COMMENTO *** ##

	    		=AQM_MODIFICA_COMMENTI_UTENTE_DDT("U_BOL_DD")  
		
		
			CASE ALLTRIM(ORD_FLGMOD) = 'A'			&& ANNULLO RECORD DDT                ## *** COMMENTO *** ##

	    		=AQM_CANCELLA_COMMENTI_UTENTE_DDT("U_BOL_DD")
      
    	ENDCASE
   
   ENDIF

    
   SELECT CU_BOL_DD
   SKIP +1

ENDDO

SET DELETED ON

SELECT CU_BOL_DD
SET ORDER TO SEQUEN 
SET FILTER TO ORD_FLGMOD <> 'A'
GO TOP

SELECT(_AQM_SDDTS)

RETURN(.T.)


********************************************
FUNCTION AQM_MOVIMENTA_MAGAZZINO_DDT_CLAVORO
********************************************

LOCAL _AQM_SEL
_AQM_SEL=SELECT()

_OK_MOVIMENTA_MAGAZZINO = .F.

_ww_codsoc = aqm_codsoc 
_ww_anaart = aqm_anaart 
_ww_codmag = aqm_codmag 
_ww_prenot = .T.  && PARAMETRO PER SCARICARE SOLO GIACENZE NON PRENOTATE
_ww_codint = ""
_ww_altezz = aqm_altezz 
_ww_lunghe = aqm_lunghe 
_ww_fila_x = ""
_ww_pian_x = ""
_ww_ubic_x = ""
_giac_disp = AQM_RILEVA_GIACENZE_DISPONIBILI(_ww_codsoc,_ww_anaart,_ww_codmag,_ww_prenot,_ww_codint,_ww_altezz,_ww_lunghe,_ww_fila_x,_ww_pian_x,_ww_ubic_x)

IF M.ORD_FLGMOD = 'M' .AND. TYPE("_OLD_LEGSYS") == 'C'  && SE STO MODIFICANDO LA DDT FACCIO IN MODO DA SCARICARE CON PRECEDENZA LE GIACENZE APPENA RICARICATE
	LOCAL _AQM_SS
	_AQM_SS=SELECT()
	_x_lsys = "mag_legsys = '" + _OLD_LEGSYS + "'"  && CAMPO DI LEGAME CON LE GIACENZE APPENA RICARICATE
	_x_soci = "mag_codsoc = '" + _ww_codsoc + "'"
	_x_data = "mag_datagg <> ''"
	_x_codi = "mag_anaart = '" + ALLTRIM(_ww_anaart) + "'"
	_x_maga = "mag_codmag = '" + ALLTRIM(_ww_codmag) + "'"
	_x_pren = IIF(_ww_prenot = .F.,"1=1","mag_prenot = 0")
	_x_disp = "(mag_giacen - mag_qtaimp) > 0"
	_x_cint = IIF(EMPTY(_ww_codint),"1=1","mag_codart = '" + ALLTRIM(_ww_codint) + "'")
	_x_alte = IIF(_ww_altezz <= 0,"1=1","mag_altezz = " + ALLTRIM(STR(_ww_altezz,7,0)))
	_x_lung = IIF(_ww_lunghe <= 0,"1=1","mag_lunghe = " + ALLTRIM(STR(_ww_lunghe,8,0)))
	_x_fila = IIF(EMPTY(_ww_fila_x),"1=1","mag_fila_x = '" + ALLTRIM(_ww_fila_x) + "'")
	_x_pian = IIF(EMPTY(_ww_pian_x),"1=1","mag_pian_x = '" + ALLTRIM(_ww_pian_x) + "'")
	_x_ubic = IIF(EMPTY(_ww_ubic_x),"1=1","mag_ubic_x = '" + ALLTRIM(_ww_ubic_x) + "'")
	_x_cond = _x_lsys + " and " + _x_soci + " and " + _x_data + " and " + _x_codi + " and " + _x_maga + " and " + _x_pren + " and " + _x_disp + " and " + ;
	          _x_cint + " and " + _x_alte + " and " + _x_lung + " and " + _x_fila + " and " + _x_pian + " and " + _x_ubic
	_x_cond = STRTRAN(_x_cond," and 1=1","")
	Csql    = "select MAG_DATAGG,MAG_CODART,MAG_UNIQUE from u_mag_gg where " + _x_cond + " order by mag_datagg,mag_oracar,mag_codart"
	IF !ExecCommand(cSql,"PREFER_U_MAG_GG")
	   return(.f.)
	ENDIF
	SELECT PREFER_U_MAG_GG
	GO TOP
	IF EOF()
	ELSE
		UPDATE LOCAL_U_MAG_GG SET SELEZIONE = 'Z'
		SELECT PREFER_U_MAG_GG
		GO TOP
		SCAN
			_UNIQUE = MAG_UNIQUE
			UPDATE LOCAL_U_MAG_GG SET SELEZIONE = 'A' WHERE MAG_UNIQUE == _UNIQUE
		ENDSCAN
		SELECT LOCAL_U_MAG_GG 
		INDEX ON SELEZIONE+MAG_DATAGG+MAG_ORACAR+MAG_CODART TAG I_PREFER
		SET ORDER TO I_PREFER  && ORDINO IL CURSORE DELLE GIACENZE DA SCARICARE DALLA 'A' ALLA 'Z' IN MODO CHE ABBIANO LA PRECEDENZA LE GIACENZE APPENA RICARICATE
		GO TOP
	ENDIF
	SELECT(_AQM_SS)
ENDIF

SELECT *, SPACE(6) AS MAG_CDMDES, SPACE(5) AS MAG_FILDES_X, SPACE(5) AS MAG_PIADES_X, SPACE(5) AS MAG_UBIDES_X, ;
0 AS MAG_FILDES_N, 0 AS MAG_PIADES_N, 0 AS MAG_UBIDES_N, (0 * MAG_GIACEN) AS MAG_GIADES FROM LOCAL_U_MAG_GG WHERE 1 = 0 INTO CURSOR CTL_MAG_GG READWRITE

_RESIDUO_AQM_GIACEN = AQM_GIACEN
SELECT LOCAL_U_MAG_GG
GO TOP
SCAN
	SCATTER MEMVAR MEMO
	SELECT CTL_MAG_GG
	APPEND BLANK
	
	M.MAG_CDMDES = M.ORD_MAGD
	M.MAG_FILDES_X = ""
	M.MAG_PIADES_X = ""
	M.MAG_UBIDES_X = ""
	M.MAG_FILDES_N = 0
	M.MAG_PIADES_N = 0
	M.MAG_UBIDES_N = 0
	M.MAG_GIADES = 0
	IF M.MAG_GIACEN >= _RESIDUO_AQM_GIACEN
		M.MAG_GIADES = _RESIDUO_AQM_GIACEN
		_RESIDUO_AQM_GIACEN = 0
	ELSE
		M.MAG_GIADES = M.MAG_GIACEN
		_RESIDUO_AQM_GIACEN = _RESIDUO_AQM_GIACEN - M.MAG_GIACEN
	ENDIF
	
	GATHER MEMVAR MEMO
	
	IF _RESIDUO_AQM_GIACEN <= 0
		EXIT
	ENDIF
ENDSCAN

SELECT LOCAL_U_MAG_GG
USE

_V_LEGSYS = M.ORD_SYSMAG
_V_CAUSCA = M.ORD_CAUS
_V_CAUCAR = ""
x_cond = "codice = 'TOP" + ALLTRIM(_V_CAUSCA) + "'"
cSql   = "select * from para where " + x_cond 
IF !ExecCommand(cSql,'CUR_PARA')
   return(.f.)
ENDIF
SELECT CUR_PARA
GO TOP
IF EOF()
ELSE
   _V_CAUCAR = SUBSTR(LIBERA,35,3)
ENDIF
_OK_SPOSTATE = AQM_SPOSTA_GIACENZE_MAGAZZINO("CTL_MAG_GG",_V_CAUSCA,_V_CAUCAR,_V_LEGSYS,"",AQM_NUMDOC,AQM_DTDOCU,.T.)

IF _OK_SPOSTATE
	_OK_MOVIMENTA_MAGAZZINO = .T.
ELSE
	_OK_MOVIMENTA_MAGAZZINO = .F.
ENDIF

*!*	IF _RESIDUO_AQM_GIACEN > 0

*!*		IF PUB_CTRGIA
*!*			MESSAGEBOX("Giacenza non disponibile",16,"Attenzione")
*!*		ELSE
*!*			=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()
*!*			LOCAL_AQM_GIACEN = _RESIDUO_AQM_GIACEN
*!*			DO AQM_SCARICA_MAGAZZINO_SOLO_MOVIMENTI
*!*			_OK_MOVIMENTA_MAGAZZINO = .T.
*!*		ENDIF
*!*		
*!*		
*!*	ENDIF

SELECT(_AQM_SEL)

RETURN _OK_MOVIMENTA_MAGAZZINO


******************************************
FUNCTION AQM_RICARICA_DA_MAGAZZINO_CLAVORO
******************************************

LOCAL _AQM_SEL_RIC_CTL
_AQM_SEL_RIC_CTL=SELECT()

*** RICARICO DEL MAGAZZINO DI SEDE
_YES_CAR = AQM_RICARICA_IL_MAGAZZINO("CU_BOL_DD")  && RICARICA LA/LE GIACENZA/E SU U_MAG_GG
IF !_YES_CAR
	MESSAGEBOX("Si č verificato un errore generico durante il carico del magazzino" + CHR(13) + CHR(13) + ;
		"Le giacenze non verranno aggiornate completamente",16,"Attenzione")
	RETURN .F.
ENDIF

*** SCARICO DEL MAGAZZINO DI CONTO LAVORO
AQM_NUMMOV_LOCALE = AQM_RILEVA_NUMERO_INTERNO()

x_lsys  = "mov_legsys = '" + M.ORD_SYSMAG + "'"
x_cmag  = "mov_codmag = '" + M.ORD_MAGD + "'"
x_segn  = "mov_segno = '+'"
x_dmod  = "mov_docmod = 0"
_e_cond = x_lsys + " and " + x_cmag + " and " + x_segn + " and " + x_dmod
Csql    = "select * from u_mag_mo where " + _e_cond + " order by mov_codart"
IF !ExecCommand(cSql,"CX_MAG_MO")
	return(.f.)
ENDIF
SELECT CX_MAG_MO
GO TOP       
DO WHILE !EOF()

	_XX_QTAMOV = MOV_QTAMOV
	
	*x_cond   = "mag_legame = '" + MOV_LEGAME + "'"
	x_cond   = "mag_legame = '" + MOV_LEGAME + "' and mag_codmag = '" + MOV_CODMAG + "'"  && ERASMO - 30/12/2014 *** SICCOME IL MAG_LEGAME VIENE TRASPORTATO, FILTRO ANCHE PER MAGAZZINO, ALTRIMENTI POTREI TROVARE IL RECORD SBAGLIATO
	Csql     = "select * from u_mag_gg where " + x_cond + " order by mag_codsoc,mag_datagg,mag_codart"
	IF !ExecCommand(cSql,"CX_MAG_GG")
	   return(.f.)
	ENDIF
	SELECT CX_MAG_GG
	GO TOP
	DO WHILE !EOF()
		IF DELETED()
			SKIP +1
			LOOP
		ENDIF
		
		SCATTER MEMVAR
		
		_ww_codsoc = M.MAG_CODSOC
		_ww_unique = M.MAG_UNIQUE
		_giac_disp = AQM_RILEVA_GIACENZA_IMPEGNATA(_ww_codsoc,_ww_unique)
		
		SELECT LOCAL_U_MAG_GG
		GO TOP       
		IF !EOF()
			
			SCATTER MEMVAR MEMO
		
	        =AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
	        =AQM_VALORIZZA_VARIABILI_MAGAZZINO("AQMLIB_GIACENZA_MAGAZZINO")
	        AQM_NUMDOC = M.ORD_NUMORD
	        AQM_DTDOCU = IIF(SUBSTR(M.ORD_DATORD,3,1) = "/",RIBALTA2(M.ORD_DATORD),M.ORD_DATORD)
			AQM_TOP = PUB_MMEN  && CAUSALE DI SCARICO
			AQM_LEGSYS = M.ORD_SYSMAG
			
			=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

			LOCAL_AQM_GIACEN = _XX_QTAMOV 
			
			IF _giac_disp >= LOCAL_AQM_GIACEN
			
				LOCAL_DATAOGGI   = RIBALTA2(DTOC(DATE()))

				*** ACCESSI ANAGRAFICI
				=ACCESSO_PARAMETRO_TOP()
				=ACCESSO_ANAGRAFICA_FORNITORE()
				=ACCESSO_ANAGRAFICA_CLIENTE()
				=ACCESSO_ANAGRAFICA_ARTICOLI(AQM_ANAART)

				_Y_SCAR = AQM_SCARICA_GIACENZA(.T.,.T.)  && SCARICA LA GIACENZA DA U_MAG_GG SPECIFICANDO DI SCARICARE ANCHE L'IMPEGNATO E DI CONTRASSEGNARE IL MOVIMENTO COME DOCUMENTO MODIFICATO
				IF !_Y_SCAR
					MESSAGEBOX("Si č verificato un errore generico durante lo scarico del magazzino" + CHR(13) + CHR(13) + ;
						"Le giacenze non verranno aggiornate completamente",16,"Attenzione")
				ENDIF
			
			ELSE
				MESSAGEBOX("Giacenza non disponibile",16,"Attenzione")
			ENDIF
		ELSE 																		&& NON ESISTE GIACENZA O LA GIACENZA E' GIA' IMPEGNATA							
			MESSAGEBOX("Giacenza non disponibile",16,"Attenzione")
		ENDIF
		
		SELECT CX_MAG_GG
		SKIP +1
	ENDDO
	
	SELECT CX_MAG_MO
	
	DO AQM_CONTRASSEGNA_MOVIMENTO_DOCMOD WITH MOV_UNIQUE
	
	SELECT CX_MAG_MO
	SKIP +1

ENDDO

SELECT(_AQM_SEL_RIC_CTL)

RETURN .T.



**************************************
FUNCTION AQM_GESTIONE_DETTAGLI_DDT_REF
**************************************

LOCAL _AQM_SDDTREFS
_AQM_SDDTREFS=SELECT()

AQM_NUMMOV_LOCALE = AQM_RILEVA_NUMERO_INTERNO()

SELECT CU_BOL_DD
SET FILTER TO
SET ORDER TO SEQUEN
GO TOP

DO WHILE !EOF()

   IF DELETED()
      SKIP +1
      LOOP
   ENDIF

   REPLACE DAGGANCIO WITH X_TAGG
   IF EMPTY(ORD_SYSMAG)
   		REPLACE ORD_SYSMAG WITH SYS(2015)
   ENDIF
   
   IF ALLTRIM(ORD_DESART) <> "*** COMMENTO ***"
   
	   DO CASE 
	   
			CASE ALLTRIM(ORD_FLGMOD) = 'I'
				
				SCATTER MEMVAR MEMO
				
	   			IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
		            =AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		            =AQM_VALORIZZA_VARIABILI_MAGAZZINO("MENU_BOLRESFOR")
		            _YES_SCAR = AQM_SCARICA_MAGAZZINO_DDT_GUIDATO_REF()
		            IF _YES_SCAR
		            	SELECT CU_BOL_DD
		            	SCATTER MEMVAR MEMO
						=AQM_INSERISCE_RIGA_ARTICOLO_DDT("U_BOL_DD","REF")
		            ELSE
						MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze" + CHR(13) + CHR(13) + ;
							"I dettagli DDT non verranno aggiornati completamente",16,"Attenzione")
						SELECT CU_BOL_DD
						DELETE
						SKIP +1
						LOOP
		            ENDIF
	            
	            ELSE
	            
	            	SELECT CU_BOL_DD
					=AQM_INSERISCE_RIGA_ARTICOLO_DDT("U_BOL_DD","REF")
	            
	            ENDIF


			CASE ALLTRIM(ORD_FLGMOD) = 'M'
				
				SCATTER MEMVAR MEMO
				
	   			IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
	   				_OLD_LEGSYS = M.ORD_SYSMAG
					=AQM_RICARICA_IL_MAGAZZINO()
					DO AQM_ATTENDI_N_SECONDI WITH 1  && ATTENDO IL SECONDO SUCCESSIVO PER DIFFERENZIARE CRONOLOGICAMENTE I MOVIMENTI DI CARICO/SCARICO
					REPLACE ORD_SYSMAG WITH ORD_SYSMAG_RIGENERATO
					M.ORD_SYSMAG = ORD_SYSMAG_RIGENERATO
		            =AQM_DEFINISCE_AQM_VARIABILI_MAGAZZINO()
		            =AQM_VALORIZZA_VARIABILI_MAGAZZINO("MENU_BOLRESFOR")
		            _YES_SCAR = AQM_SCARICA_MAGAZZINO_DDT_GUIDATO_REF()
		            IF _YES_SCAR
		            	SELECT CU_BOL_DD
		            	SCATTER MEMVAR MEMO
						=AQM_MODIFICA_RIGA_ARTICOLO_DDT("U_BOL_DD","REF")
		            ELSE
						MESSAGEBOX("Si č verificato un errore generico durante l'aggiornamento delle giacenze" + CHR(13) + CHR(13) + ;
							"I dettagli DDT non verranno aggiornati completamente",16,"Attenzione")
						SELECT CU_BOL_DD
						DELETE
						SKIP +1
						LOOP
		            ENDIF
	            
	            ELSE
	            	
	            	SELECT CU_BOL_DD
					=AQM_MODIFICA_RIGA_ARTICOLO_DDT("U_BOL_DD","REF")
	            
	            ENDIF
	            
	 
			CASE ALLTRIM(ORD_FLGMOD) = 'A'			&& ANNULLO RECORD DDT                ## ARTICOLO VERO ##
				
				SCATTER MEMVAR MEMO
				
	   			IF PUB_SAU .AND. !AQM_ARTICOLO_DA_NON_MOVIMENTARE(M.ORD_CODART)  && GESTISCO IL MAGAZZINO SOLO SE E' VERO IL PARAMETRO AZIENDALE "Scarico magazzino nelle bolle" ED E' FALSO IL CAMPO U_ART_PR.ART_NONMOV per questo articolo
		            =AQM_RICARICA_IL_MAGAZZINO()
	            ENDIF
				
				SELECT CU_BOL_DD
	 			=AQM_CANCELLA_U_BOL_DD()
	 			
 		
 		ENDCASE

    ELSE
    	
    	SCATTER MEMVAR MEMO
    
    	DO CASE

			CASE ALLTRIM(ORD_FLGMOD) = 'I'			&& INSERISCE RECORD DDT              ## *** COMMENTO *** ##

	    		=AQM_INSERISCE_COMMENTI_AUTOMATICI_DDT()  


			CASE ALLTRIM(ORD_FLGMOD) = 'M'			&& MODIFICA RECORD DDT               ## *** COMMENTO *** ##

	    		=AQM_MODIFICA_COMMENTI_UTENTE_DDT()  
		
		
			CASE ALLTRIM(ORD_FLGMOD) = 'A'			&& ANNULLO RECORD DDT                ## *** COMMENTO *** ##

	    		=AQM_CANCELLA_COMMENTI_UTENTE_DDT()
      
    	ENDCASE
   
   ENDIF

    
   SELECT CU_BOL_DD
   SKIP +1

ENDDO


SELECT CU_BOL_DD
SET ORDER TO SEQUEN 
SET FILTER TO ORD_FLGMOD <> 'A'
GO TOP

SELECT(_AQM_SDDTREFS)

RETURN(.T.)


**********************************************
FUNCTION AQM_SCARICA_MAGAZZINO_DDT_GUIDATO_REF
**********************************************

LOCAL _AQM_SEL
_AQM_SEL=SELECT()

_OK_SCARICA_MAGAZZINO = .F.

SELECT CU_BOL_DD

_ww_codsoc = aqm_codsoc 
_ww_unique = RES_MAGUNQ
_giac_disp = AQM_RILEVA_GIACENZA_LIBERA(_ww_codsoc,_ww_unique)

*** MODIFICA PER PROBLEMA SELEZIONE GIACENZE PRENOTATE
IF _giac_disp > 0
ELSE
	_giac_disp = AQM_RILEVA_GIACENZA_PRENOTATA(_ww_codsoc,_ww_unique)
ENDIF

SELECT LOCAL_U_MAG_GG
GO TOP       
IF !EOF()	

	=AQM_GESTIONE_VARIABILI_ORIGINALI_LOCALI()

	*** DEFINIZIONE VARIABILI LOCALI DI GESTIONE 
	LOCAL_AQM_GIACEN = _giac_disp
	*LOCAL_AQM_QTAKG  = AQM_QTAKG
	*LOCAL_AQM_QTAMQ  = AQM_QTAMQ
	*LOCAL_AQM_QTAML  = AQM_QTAML
	
	IF _giac_disp >= LOCAL_AQM_GIACEN
	
		LOCAL_DATAOGGI   = RIBALTA2(DTOC(DATE()))

		*** ACCESSI ANAGRAFICI
		=ACCESSO_PARAMETRO_TOP()
