GO TOP
IF !EOF()
	MESSAGEBOX("Operazione terminata con errori",48,"Attenzione")
	BROWSE NORMAL
	EXPORT TO SYS(5)+SYS(2003)+"\ELEN_REG_DA_RETT.XLS" TYPE XL5
