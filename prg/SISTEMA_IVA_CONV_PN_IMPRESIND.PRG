LOCAL _PAR_DATADAL
_PAR_DATADAL = "01/07/2017"

*** SCELTA DATA REGISTRAZIONE MOVIMENTI
_PAR_DATADAL = PJ_INPUTBOX("Inserire la Data Registrazione Movimenti Dal","Data Registrazione Movimenti Dal",_PAR_DATADAL)
IF EMPTY(ALLTRIM(_PAR_DATADAL))
	MESSAGEBOX("Data Registrazione Movimenti Dal obbligatoria",16,"Attenzione")
	RETURN .F.
ENDIF
IF EMPTY(ALLTRIM(_PAR_DATADAL)) .OR. _PAR_DATADAL = '  /  /    '
	MESSAGEBOX("Data Registrazione Movimenti Dal obbligatoria",16,"Attenzione")
	_PAR_DATADAL = ""
	RETURN .T.
ENDIF
IF VALID_DATA(_PAR_DATADAL)
ELSE
	MESSAGEBOX("Data Registrazione Movimenti Dal non valida",16,"Attenzione")
	RETURN .F.
ENDIF
_PAR_DATADAL = OK_DATA(_PAR_DATADAL)


CREATE CURSOR ELEN_REG_DA_RETT (NUMPRO C(10), TOP C(3), NREGIS C(10), DTREG C(10), NDOC C(20), DTDOC C(10), DESMO1 C(200))
INDEX ON NUMPRO TAG I_NUMPRO

x_cond = "MOV_TOP <> 'APE' AND MOV_DTREG >= '" + RIBALTA2(_PAR_DATADAL) + "'"
cSql   = "SELECT MOV_NUMPRO,MOV_TOP FROM MOV_CONT WHERE " + x_cond + " GROUP BY MOV_NUMPRO,MOV_TOP ORDER BY MOV_NUMPRO"
IF !ExecCommand(cSql,"NPRO_MOV_CONT")
  return(.f.)
ENDIF
SELECT NPRO_MOV_CONT
GO TOP
SCAN
	_NUMPRO = MOV_NUMPRO
	_TOP = ALLTRIM(MOV_TOP)
	_CLI_FOR = ""
	
	WAIT WINDOWS "Elaborazione registrazione con MOV_NUMPRO = '" + _NUMPRO + "'" NOWAIT
	
*!*		IF MOV_NUMPRO = '0000001647'
*!*			SET STEP ON
*!*		ELSE
*!*			LOOP
*!*		ENDIF
		
	x_cond = "codice = 'TOP" + _TOP + "'"
	cSql   = "select * from para where " + x_cond
	IF !ExecCommand(cSql,"PARA_TOP")
	  return(.f.)
	ENDIF
	SELECT PARA_TOP
	GO TOP
	IF EOF()
		*MESSAGEBOX("TOP '" + _TOP + "' non presente in Aquarius",16,"Attenzione")
		
		x_npro = "MOV_NUMPRO = '" + _NUMPRO + "'"
		x_cond = x_uniq
		cSql   = "SELECT * FROM MOV_CONT WHERE " + x_cond
		IF !ExecRW(cSql,"MOV_CONT","R")
		  return(.f.)
		ENDIF
		SELECT MOV_CONT
		GO TOP
		SCAN
			REPLACE MOV_DESMO1 WITH 'DA RETT.MAN: TOP NON PRESENTE IN AQUARIUS'
		ENDSCAN
		SELECT MOV_CONT
		GO TOP
		M.NUMPRO = MOV_NUMPRO
		M.NREGIS = MOV_NREGIS
		M.DTREG = MOV_DTREG
		M.NDOC = MOV_NDOC
		M.DTDOC = MOV_DTDOC
		M.DESMO1 = MOV_DESMO1
		SELECT ELEN_REG_DA_RETT
		SET ORDER TO I_NUMPRO
		GO TOP
		SEEK M.NUMPRO
		IF !FOUND()
			APPEND BLANK
			GATHER MEMVAR
		ENDIF
		IF !ExecRW(cSql,"MOV_CONT","W")
		  return(.f.)
		ENDIF
		
		SELECT NPRO_MOV_CONT
		LOOP
	ELSE
		SELECT PARA_TOP
		IF SUBSTR(LIBERA,2,1) = 'S'  && SOLO TIPI TOP FATTURA/NOTA CREDITO
		ELSE
			SELECT NPRO_MOV_CONT
			LOOP
		ENDIF
		
		SELECT PARA_TOP
		IF SUBSTR(LIBERA,12,1) = 'C' OR SUBSTR(LIBERA,12,1) = 'F'  && SOLO TIPI TOP CLIENTE/FORNITORE
			_CLI_FOR = SUBSTR(LIBERA,12,1)
		ELSE
			SELECT NPRO_MOV_CONT
			LOOP
		ENDIF
	ENDIF
	
	*** ELIMINAZIONE RIGHE CONTO IVA NON NECESSARIO IN AQUARIUS
	x_npro = "MOV_NUMPRO = '" + _NUMPRO + "'"
	x_cont = "MOV_CONTO IN ('5059000002','5059000003')"
	x_cond = x_npro + " and " + x_cont 
	cSql   = "DELETE FROM MOV_CONT WHERE " + x_cond
	IF !ExecCommand(cSql,"DEL_MOV_CONT")
	  return(.f.)
	ENDIF
	
	*** CREAZIONE CURSORE DELLE CONTROPARTITE
	x_npro = "MOV_NUMPRO = '" + _NUMPRO + "'"
	x_cont = "(SUBSTRING(MOV_CONTO,1,4) NOT IN ('4041','3031') OR MOV_CONTO = '30310061900') AND MOV_CONTO <> ''"  && ESCLUDO CLIENTI E FORNITORI
	x_civa = "MOV_IVA = 'NO'"
	x_cond = x_npro + " and " + x_cont + " and " + x_civa
	cSql   = "SELECT * FROM MOV_CONT WHERE " + x_cond + " ORDER BY MOV_SEQUEN"
	IF !ExecCommand(cSql,"CUR_MOV_CONT_CTRPART")
	  return(.f.)
	ENDIF
	SELECT CUR_MOV_CONT_CTRPART
	
	*** CREAZIONE 2° CURSORE DELLE CONTROPARTITE
	IF !ExecCommand(cSql,"CUR_MOV_CONT_CTRPART_2")
	  return(.f.)
	ENDIF
	SELECT CUR_MOV_CONT_CTRPART_2
	
	*** CREAZIONE 3° CURSORE DELLE CONTROPARTITE
	IF !ExecCommand(cSql,"CUR_MOV_CONT_CTRPART_3")
	  return(.f.)
	ENDIF
	SELECT CUR_MOV_CONT_CTRPART_3
	
	*** SELEZIONE RIGHE CONTENENTI I CODICI IVA DA ATTRIBUIRE ALLE CONTROPARTITE
	x_npro = "MOV_NUMPRO = '" + _NUMPRO + "'"
	x_cont = "MOV_CONTO = ''"
	x_civa = "MOV_IVA <> 'NO'"
	x_cond = x_npro + " and " + x_cont + " and " + x_civa
	cSql   = "SELECT * FROM MOV_CONT WHERE " + x_cond + " ORDER BY MOV_SEQUEN"
	IF !ExecCommand(cSql,"CUR_MOV_CONT_IVA")
	  return(.f.)
	ENDIF
	SELECT CUR_MOV_CONT_IVA
	GO TOP
	SCAN
		_CODIVA = MOV_IVA
		_IMPONIBILE = MOV_IMP
		_IMPOSTA = MOV_IMPOST
		_ALIQUOTA = _IMPOSTA / _IMPONIBILE
		
		_OK_CORRISPONDENZA_PER_IMPORTO = .F.
		_OK_CORRISPONDENZA_PER_SOMMA_DI_2_IMPORTI = .F.
		_OK_CORRISPONDENZA_PER_SOMMA_DI_3_IMPORTI = .F.
		
		*** CERCO TRA LE CONTROPARTITE SE ESISTE CORRISPONDENZA PER IMPORTO
		SELECT CUR_MOV_CONT_CTRPART
		GO TOP
		SCAN
			IF MOV_IMP = _IMPONIBILE
				REPLACE MOV_IVA WITH _CODIVA
				REPLACE MOV_IMPOST WITH _IMPOSTA
				_TMOV = MOV_TMOV
				
				SELECT CUR_MOV_CONT_IVA
				REPLACE MOV_MODPAG WITH ""
				REPLACE MOV_CONTO WITH IIF(ALLTRIM(MOV_DESMO1) = 'V',"5059000003","5059000002")
				REPLACE MOV_TMOV WITH _TMOV
				_OK_CORRISPONDENZA_PER_IMPORTO = .T.				
			ENDIF
		ENDSCAN
		
		*** CERCO TRA LE CONTROPARTITE SE ESISTE CORRISPONDENZA PER SOMMA DI 2 IMPORTI
		IF !_OK_CORRISPONDENZA_PER_IMPORTO
			SELECT CUR_MOV_CONT_CTRPART
			GO TOP
			SCAN
				IF MOV_IVA <> "NO"
					LOOP
				ENDIF
				_CTRPART_IMPONIBILE = MOV_IMP
				_ID_UNQ_1 = ID_UNIQUE
				SELECT CUR_MOV_CONT_CTRPART_2
				GO TOP
				SCAN
					IF MOV_IVA <> "NO" OR ID_UNIQUE = _ID_UNQ_1
						LOOP
					ENDIF
					_CTRPART_IMPONIBILE_2 = MOV_IMP
					_ID_UNQ_2 = ID_UNIQUE
					IF _CTRPART_IMPONIBILE + _CTRPART_IMPONIBILE_2 = _IMPONIBILE
						REPLACE MOV_IVA WITH _CODIVA
						REPLACE MOV_IMPOST WITH _ALIQUOTA * MOV_IMP
						
						SELECT CUR_MOV_CONT_CTRPART
						REPLACE MOV_IVA WITH _CODIVA
						REPLACE MOV_IMPOST WITH _ALIQUOTA * MOV_IMP
						_TMOV = MOV_TMOV
						
						UPDATE CUR_MOV_CONT_CTRPART SET MOV_IVA = _CODIVA, MOV_IMPOST = (_ALIQUOTA * MOV_IMP) WHERE ID_UNIQUE = _ID_UNQ_2 
						
						SELECT CUR_MOV_CONT_IVA
						REPLACE MOV_MODPAG WITH ""
						REPLACE MOV_CONTO WITH IIF(ALLTRIM(MOV_DESMO1) = 'V',"5059000003","5059000002")
						REPLACE MOV_TMOV WITH _TMOV
						_OK_CORRISPONDENZA_PER_SOMMA_DI_2_IMPORTI = .T.
					ENDIF
				ENDSCAN
				
			ENDSCAN
		ENDIF
		=TABLEUPDATE(.T.,.T.,"CUR_MOV_CONT_CTRPART")
		
		*** CERCO TRA LE CONTROPARTITE SE ESISTE CORRISPONDENZA PER SOMMA DI 3 IMPORTI
		IF !_OK_CORRISPONDENZA_PER_SOMMA_DI_2_IMPORTI
			SELECT CUR_MOV_CONT_CTRPART
			GO TOP
			SCAN
				IF MOV_IVA <> "NO"
					LOOP
				ENDIF
				_CTRPART_IMPONIBILE = MOV_IMP
				_ID_UNQ_1 = ID_UNIQUE
				SELECT CUR_MOV_CONT_CTRPART_2
				GO TOP
				SCAN
					IF MOV_IVA <> "NO" OR ID_UNIQUE = _ID_UNQ_1
						LOOP
					ENDIF
					_CTRPART_IMPONIBILE_2 = MOV_IMP
					_ID_UNQ_2 = ID_UNIQUE
					SELECT CUR_MOV_CONT_CTRPART_3
					GO TOP
					SCAN
						IF MOV_IVA <> "NO" OR ID_UNIQUE = _ID_UNQ_1 OR ID_UNIQUE = _ID_UNQ_2
							LOOP
						ENDIF
						_CTRPART_IMPONIBILE_3 = MOV_IMP
						_ID_UNQ_3 = ID_UNIQUE
					
						IF _CTRPART_IMPONIBILE + _CTRPART_IMPONIBILE_2 + _CTRPART_IMPONIBILE_3 = _IMPONIBILE
							REPLACE MOV_IVA WITH _CODIVA
							REPLACE MOV_IMPOST WITH _ALIQUOTA * MOV_IMP
							
							SELECT CUR_MOV_CONT_CTRPART
							REPLACE MOV_IVA WITH _CODIVA
							REPLACE MOV_IMPOST WITH _ALIQUOTA * MOV_IMP
							_TMOV = MOV_TMOV
							
							UPDATE CUR_MOV_CONT_CTRPART SET MOV_IVA = _CODIVA, MOV_IMPOST = (_ALIQUOTA * MOV_IMP) WHERE ID_UNIQUE = _ID_UNQ_2
							UPDATE CUR_MOV_CONT_CTRPART SET MOV_IVA = _CODIVA, MOV_IMPOST = (_ALIQUOTA * MOV_IMP) WHERE ID_UNIQUE = _ID_UNQ_3
							
							SELECT CUR_MOV_CONT_IVA
							REPLACE MOV_MODPAG WITH ""
							REPLACE MOV_CONTO WITH IIF(ALLTRIM(MOV_DESMO1) = 'V',"5059000003","5059000002")
							REPLACE MOV_TMOV WITH _TMOV
							_OK_CORRISPONDENZA_PER_SOMMA_DI_3_IMPORTI = .T.
						ENDIF
					ENDSCAN
				ENDSCAN
			ENDSCAN
		ENDIF
		=TABLEUPDATE(.T.,.T.,"CUR_MOV_CONT_CTRPART")
		
		SELECT CUR_MOV_CONT_IVA
		IF !_OK_CORRISPONDENZA_PER_IMPORTO AND !_OK_CORRISPONDENZA_PER_SOMMA_DI_2_IMPORTI AND !_OK_CORRISPONDENZA_PER_SOMMA_DI_3_IMPORTI
			*MESSAGEBOX("RETTIFICARE MANUALMENTE LA REGISTRAZIONE CON NUMPRO '" + MOV_NUMPRO + "'",48,"Attenzione")
			REPLACE MOV_DESMO1 WITH "DA RETT.MAN: VERIFICARE RIGHE IVA"
			
			M.NUMPRO = MOV_NUMPRO
			M.NREGIS = MOV_NREGIS
			M.DTREG = MOV_DTREG
			M.NDOC = MOV_NDOC
			M.DTDOC = MOV_DTDOC
			M.DESMO1 = MOV_DESMO1
			SELECT ELEN_REG_DA_RETT
			SET ORDER TO I_NUMPRO
			GO TOP
			SEEK M.NUMPRO
			IF !FOUND()
				APPEND BLANK
				GATHER MEMVAR
			ENDIF
		ENDIF
	ENDSCAN
	
	*** AGGIORNAMENTO TABELLA SU DATABASE
	SELECT CUR_MOV_CONT_IVA
	GO TOP
	SCAN
		_ID_UNQ = ID_UNIQUE
		_MOV_MODPAG = MOV_MODPAG
		_MOV_CONTO  = MOV_CONTO
		_MOV_DESMO1 = MOV_DESMO1
		x_uniq = "ID_UNIQUE = '" + _ID_UNQ + "'"
		x_cond = x_uniq
		cSql   = "UPDATE MOV_CONT SET MOV_IMP = MOV_IMPOST, MOV_IMPVAL = 0, MOV_IMPOST = 0, MOV_MODPAG = '" + _MOV_MODPAG + "', MOV_CONTO = '" + _MOV_CONTO + "', MOV_DESMO1= '" + _MOV_DESMO1 + "' WHERE " + x_cond
		IF !ExecCommand(cSql,"CUR_MOV_CONT_IVA")
		  return(.f.)
		ENDIF
	ENDSCAN
	
	SELECT CUR_MOV_CONT_CTRPART
	GO TOP
	SCAN
		_ID_UNQ = ID_UNIQUE
		_MOV_IVA = MOV_IVA
		_MOV_IMPOST = MOV_IMPOST
		x_uniq = "ID_UNIQUE = '" + _ID_UNQ + "'"
		x_cond = x_uniq
		cSql   = "UPDATE MOV_CONT SET MOV_IVA = '" + _MOV_IVA + "', MOV_IMPOST = " + STRTRAN(STR(_MOV_IMPOST,10,2),',','.') + " WHERE " + x_cond
		IF !ExecCommand(cSql,"CUR_MOV_CONT_IVA")
		  return(.f.)
		ENDIF
	ENDSCAN
	
ENDSCAN

WAIT WINDOWS "Completamento elaborazione in corso (segnalazione registrazioni da inserire manualmente)..." NOWAIT

*** SEGNALAZIONE CASI PARTICOLARI DI FATTURE/N.CREDITO CON CONTROPARTITE ANCORA CON IVA 'NO' DA RETTIFICARE MANUALMENTE
cSql = "SELECT DISTINCT MOV_NUMPRO FROM MOV_CONT WHERE MOV_DTREG >= '" + RIBALTA2(_PAR_DATADAL) + "' AND MOV_TOP <> 'APE' AND MOV_IVA = 'NO' AND SUBSTRING(MOV_CONTO,1,4) NOT IN ('4041','3031') AND MOV_TOP IN " + ;
       "(SELECT SUBSTRING(CODICE,4,3) FROM PARA WHERE CODICE LIKE 'TOP%' AND SUBSTRING(LIBERA,2,1) = 'S') AND  MOV_NUMPRO IN (SELECT MOV_NUMPRO FROM MOV_CONT WHERE SUBSTRING(MOV_CONTO,1,4) IN ('4041','3031'))"
IF !ExecCommand(cSql,"TMP_MOV_CONT")
  return(.f.)
ENDIF
GO TOP
SCAN
	_NUMPRO = MOV_NUMPRO
	
	x_npro = "MOV_NUMPRO = '" + _NUMPRO + "' AND MOV_DTREG >= '" + RIBALTA2(_PAR_DATADAL) + "'"
	x_cond = x_npro 
	cSql   = "SELECT * FROM MOV_CONT WHERE " + x_cond
	IF !ExecRW(cSql,"MOV_CONT","R")
	  return(.f.)
	ENDIF
	SELECT MOV_CONT
	GO TOP
	SCAN
		REPLACE MOV_DESMO1 WITH 'DA RETT.MAN: VERIFICARE IVA NO'
	ENDSCAN
	SELECT MOV_CONT
	GO TOP
	M.NUMPRO = MOV_NUMPRO
	M.NREGIS = MOV_NREGIS
	M.DTREG = MOV_DTREG
	M.NDOC = MOV_NDOC
	M.DTDOC = MOV_DTDOC
	M.DESMO1 = MOV_DESMO1
	SELECT ELEN_REG_DA_RETT
	SET ORDER TO I_NUMPRO
	GO TOP
	SEEK M.NUMPRO
	IF !FOUND()
		APPEND BLANK
		GATHER MEMVAR
	ENDIF
	
	IF !ExecRW(cSql,"MOV_CONT","W")
	  return(.f.)
	ENDIF
ENDSCAN

WAIT WINDOWS "Completamento elaborazione in corso (aggiornamento campi SYS)..." NOWAIT

*** AGGIORNAMENTO CAMPI MOV_CONT.MOV_SYSCCO E INDICE.MOV_SYSDOC
SELECT NPRO_MOV_CONT
GO TOP
SCAN
	_NUMPRO = MOV_NUMPRO
	
	x_npro = "MOV_NUMPRO = '" + _NUMPRO + "' AND MOV_DTREG >= '" + RIBALTA2(_PAR_DATADAL) + "'"
	x_cond = x_npro 
	cSql   = "SELECT * FROM MOV_CONT WHERE " + x_cond
	IF !ExecRW(cSql,"MOV_CONT","R")
	  return(.f.)
	ENDIF
	SELECT MOV_CONT
	GO TOP
	SCAN
		REPLACE MOV_SYSCCO WITH SYS(2015)
	ENDSCAN
	IF !ExecRW(cSql,"MOV_CONT","W")
	  return(.f.)
	ENDIF
	
	x_npro = "MOV_NUMPRO = '" + _NUMPRO + "' AND MOV_DTREG >= '" + RIBALTA2(_PAR_DATADAL) + "'"
	x_cond = x_npro 
	cSql   = "SELECT * FROM INDICE WHERE " + x_cond
	IF !ExecRW(cSql,"INDICE","R")
	  return(.f.)
	ENDIF
	SELECT INDICE
	GO TOP
	SCAN
		REPLACE MOV_SYSDOC WITH SYS(2015)
	ENDSCAN
	IF !ExecRW(cSql,"INDICE","W")
	  return(.f.)
	ENDIF
ENDSCAN


WAIT WINDOWS "Completamento elaborazione in corso (aggiornamento MOV_TMOV e MOV_SEQUEN su righe iva)..." NOWAIT

cSql=""     
cNomeCursorSql="TMP1"
TEXT TO cSql NOSHOW
	UPDATE MC SET MOV_SEQUEN = MOV_SEQUEN + 90, MC.MOV_TMOV = 
		CASE
			WHEN (SELECT TOP 1 MOV_TMOV FROM MOV_CONT AS MX WHERE MX.MOV_DTREG >= '<<RIBALTA2(_PAR_DATADAL)>>' AND MX.MOV_NUMPRO = MC.MOV_NUMPRO AND SUBSTRING(MX.MOV_CONTO,1,4) IN ('4041','3031')) = 'A' THEN 'D'
			WHEN (SELECT TOP 1 MOV_TMOV FROM MOV_CONT AS MX WHERE MX.MOV_DTREG >= '<<RIBALTA2(_PAR_DATADAL)>>' AND MX.MOV_NUMPRO = MC.MOV_NUMPRO AND SUBSTRING(MX.MOV_CONTO,1,4) IN ('4041','3031')) = 'D' THEN 'A'
		END
	FROM MOV_CONT AS MC
	WHERE MOV_DTREG >= '<<RIBALTA2(_PAR_DATADAL)>>' AND MOV_CONTO IN ('5059000002','5059000003') AND MOV_NUMPRO IN (SELECT MOV_NUMPRO FROM MOV_CONT WHERE 'TOP'+MOV_TOP IN (SELECT CODICE FROM PARA WHERE CODICE LIKE 'TOP%' AND SUBSTRING(LIBERA,2,1) = 'S'))
ENDTEXT
IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF

WAIT WINDOWS "Completamento elaborazione in corso (sistemazione quadratura fatture CEE e reverse charge)..." NOWAIT

SELECT NPRO_MOV_CONT
GO TOP
SCAN
	IF MOV_TOP = '301' OR MOV_TOP = '303'
	ELSE
		LOOP
	ENDIF
	
	_NUMPRO = MOV_NUMPRO
	
	x_npro = "MOV_NUMPRO = '" + _NUMPRO + "' AND MOV_DTREG >= '" + RIBALTA2(_PAR_DATADAL) + "'"
	x_cond = x_npro 
	cSql   = "SELECT * FROM MOV_CONT WHERE " + x_cond + " ORDER BY MOV_SEQUEN"
	IF !ExecRW(cSql,"MOV_CONT","R")
	  return(.f.)
	ENDIF
	SELECT MOV_CONT
	GO TOP
	*** PRELEVO IVA FORNITORE E CANCELLO CONTO IVA CLIENTI
	_IVA_REVERSE = 0
	SCAN
		IF MOV_CONTO = '5059000003'
			DELETE
			LOOP
		ENDIF
		IF MOV_CONTO = '5059000002'
			_IVA_REVERSE = 	_IVA_REVERSE + MOV_IMP
		ENDIF
	ENDSCAN
	*** AGGIORNO TOTALE RIGA FORNITORE
	SELECT MOV_CONT
	GO TOP
	SCAN
		IF SUBSTR(MOV_CONTO,1,4) = '3031'
			REPLACE MOV_IMP WITH MOV_IMP + _IVA_REVERSE 
		ENDIF
	ENDSCAN
	IF !ExecRW(cSql,"MOV_CONT","W")
	  return(.f.)
	ENDIF
	
	*** AGGIORNO TOTALE SU INDICE
	x_npro = "MOV_NUMPRO = '" + _NUMPRO + "' AND MOV_DTREG >= '" + RIBALTA2(_PAR_DATADAL) + "'"
	x_cond = x_npro 
	cSql   = "SELECT * FROM INDICE WHERE " + x_cond
	IF !ExecRW(cSql,"INDICE","R")
	  return(.f.)
	ENDIF
	SELECT INDICE
	GO TOP
	SCAN
		REPLACE MOV_IMP WITH MOV_IMP + _IVA_REVERSE
	ENDSCAN
	IF !ExecRW(cSql,"INDICE","W")
	  return(.f.)
	ENDIF	
ENDSCAN

