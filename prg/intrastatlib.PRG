************************************************************************************************************************************
PROCEDURE INTRA_CARICA_PRIMA_NOTA
************************************************************************************************************************************
**
** FUNZIONALITA' :
**
**		CREA CURSORE1 (_PAR_INTRA_CURSOR1) : - Modello INTRA 2 bis - SEZIONE 1 			: ACQUISTO BENI
**		CREA CURSORE2 (_PAR_INTRA_CURSOR2) : - Modello INTRA 2 quater - SEZIONE 3		: ACQUISTO SERVIZI RICEVUTI
**		CREA CURSORE3 (_PAR_INTRA_CURSOR3) : - Modello INTRA 1 bis - SEZIONE 1 			: CESSIONE BENI
**		CREA CURSORE4 (_PAR_INTRA_CURSOR4) : - Modello INTRA 1 quater - SEZIONE 3		: CESSIONE SERVIZI RESI
**		CREA CURSORE5 (_PAR_INTRA_CURSOR5) : - Modello INTRA 2 ter - SEZIONE 2			: RETTIFICHE ACQUISTI BENI PERIODI PRECEDENTI
**		CREA CURSORE6 (_PAR_INTRA_CURSOR6) : - Modello INTRA 2 quinques - SEZIONE 4		: RETTIFICHE ACQUISTI SERVIZI PERIODI PRECEDENTI
**		CREA CURSORE7 (_PAR_INTRA_CURSOR7) : - Modello INTRA 1 ter - SEZIONE 2			: RETTIFICHE CESSIONI BENI PERIODI PRECEDENTI
**		CREA CURSORE8 (_PAR_INTRA_CURSOR8) : - Modello INTRA 1 quinques - SEZIONE 4		: RETTIFICHE ACQUISTI CESSIONE PERIODI PRECEDENTI
**
**		TIPO DI ESTRAZIONE DATI CONTABILI :
**
**			_PAR_FATTURE_CLI_FOR = "F" 	MOVIMENTI DI ACQUISTO
**			_PAR_FATTURE_CLI_FOR = "C" 	MOVIMENTI DI CESIONE
**			_PAR_FATTURE_CLI_FOR = "A" 	MOVIMENTI DI ACQUISTO+CESSIONE
**
**
** 		RESTITUISCE IL CURSORE >>>>>>> INTRA_MOV_CONT <<<<<<<  SE SI DESIDERA SOLO ESTRARRE I MOVIMENTI CONTABILI INTRASTAT E NON I CURSORI INTRASTAT
**
**
LPARAMETERS _PAR_DATA_DAL,_PAR_DATA_AL,_PAR_FATTURE_CLI_FOR,_PAR_INTRA,_PAR_INTRA_CURSOR1,_PAR_INTRA_CURSOR2,_PAR_INTRA_CURSOR3,_PAR_INTRA_CURSOR4,_PAR_INTRA_CURSOR5,_PAR_INTRA_CURSOR7,_PAR_INTRA_CURSOR6,_PAR_INTRA_CURSOR8


RELEASE _V_PROG_RIGA_RETTIFICHE_ACQUISTO_BENI,_V_PROG_RIGA_RETTIFICHE_ACQUISTO_SERVIZI
RELEASE _V_PROG_RIGA_RETTIFICHE_CESSIONE_BENI,_V_PROG_RIGA_RETTIFICHE_CESSIONE_SERVIZI
PUBLIC _V_PROG_RIGA_RETTIFICHE_ACQUISTO_BENI,_V_PROG_RIGA_RETTIFICHE_ACQUISTO_SERVIZI
PUBLIC _V_PROG_RIGA_RETTIFICHE_CESSIONE_BENI,_V_PROG_RIGA_RETTIFICHE_CESSIONE_SERVIZI

_V_PROG_RIGA_RETTIFICHE_ACQUISTO_BENI	 = 0
_V_PROG_RIGA_RETTIFICHE_ACQUISTO_SERVIZI = 0
_V_PROG_RIGA_RETTIFICHE_CESSIONE_BENI    = 0
_V_PROG_RIGA_RETTIFICHE_CESSIONE_SERVIZI = 0


RELEASE _V_DARE,_V_AVERE,_V_DATA_DAL,_V_DATA_AL,_INTRASTAT_MOVIMENTI_CONTABILI_ELABORATI,__NUMERO_PROGR_RIGA_1,_V_VALORE_EURO
RELEASE _V_QTA_IN_UM,_V_PORTO,_V_CLDOG,_V_VALORE_STATISTICO,_FATTURE_INTRA_CLIENTI_FORNITORI_,_V_FATTURE_CLI_FOR,_V_CREA_INTRA
RELEASE _V_VALORE_VALUTA,_V_PESO,_V_PROG_RIGA_ACQUISTO_BENI,_V_PROG_RIGA_ACQUISTO_SERVIZI,_V_NDOC,_V_DTDOC,_V_SERV_INTRA,_V_MOD_PAG,_V_MOD_INC,_V_NUM_RECORDS_TOTALI
RELEASE _V_VALORE_EURO_NUMERICO,_V_UNITA_SUPPLEMENTARI
RELEASE _V_INTRA_CURSOR1,_V_INTRA_CURSOR2,_V_INTRA_CURSOR3,_V_INTRA_CURSOR4


PUBLIC _V_DARE,_V_AVERE,_V_DATA_DAL,_V_DATA_AL,_INTRASTAT_MOVIMENTI_CONTABILI_ELABORATI,__NUMERO_PROGR_RIGA_1,_V_VALORE_EURO
PUBLIC _V_QTA_IN_UM,_V_PORTO,_V_CLDOG,_V_VALORE_STATISTICO,_FATTURE_INTRA_CLIENTI_FORNITORI_,_V_FATTURE_CLI_FOR,_V_CREA_INTRA
PUBLIC _V_VALORE_VALUTA,_V_PESO,_V_PROG_RIGA_ACQUISTO_BENI,_V_PROG_RIGA_ACQUISTO_SERVIZI,_V_NDOC,_V_DTDOC,_V_SERV_INTRA,_V_MOD_PAG,_V_MOD_INC,_V_NUM_RECORDS_TOTALI
PUBLIC _V_VALORE_EURO_NUMERICO,_V_UNITA_SUPPLEMENTARI
PUBLIC _V_INTRA_CURSOR1,_V_INTRA_CURSOR2,_V_INTRA_CURSOR3,_V_INTRA_CURSOR4


__NUMERO_PROGR_RIGA_1 						= 0
_V_DATA_DAL									= _PAR_DATA_DAL
_V_DATA_AL									= _PAR_DATA_AL
_V_FATTURE_CLI_FOR							= _PAR_FATTURE_CLI_FOR
_V_CREA_INTRA       						= _PAR_INTRA
_V_PROG_RIGA_ACQUISTO_BENI					= 0
_V_PROG_RIGA_ACQUISTO_SERVIZI				= 0
_V_NDOC 									= ""
_V_DTDOC									= ""
_V_SERV_INTRA								= ""
_V_MOD_PAG									= 0
_V_MOD_INC 									= ""
_V_VALORE_EURO_NUMERICO						= 0
_V_INTRA_CURSOR1							= _PAR_INTRA_CURSOR1
_V_INTRA_CURSOR2							= _PAR_INTRA_CURSOR2
_V_INTRA_CURSOR3							= _PAR_INTRA_CURSOR3
_V_INTRA_CURSOR4							= _PAR_INTRA_CURSOR4
_V_INTRA_CURSOR5							= _PAR_INTRA_CURSOR5
_V_INTRA_CURSOR7							= _PAR_INTRA_CURSOR7
_V_INTRA_CURSOR6							= _PAR_INTRA_CURSOR6
_V_INTRA_CURSOR8							= _PAR_INTRA_CURSOR8
_V_UNITA_SUPPLEMENTARI						= 0
_INTRASTAT_MOVIMENTI_CONTABILI_ELABORATI	= 0

DO CASE


	CASE _V_FATTURE_CLI_FOR = "F"
		WAIT WINDOW "Elaborazione movimenti contabili di ACQUISTO INTRACOMUNITARIO in corso. Questa operazione potrebbe richiedere qualche secondo..." NOWAIT

	CASE _V_FATTURE_CLI_FOR = "C"
		WAIT WINDOW "Elaborazione movimenti contabili di CESSIONI INTRACOMUNITARI in corso. Questa operazione potrebbe richiedere qualche secondo..." NOWAIT

*!*		CASE _V_FATTURE_CLI_FOR = "C"
*!*			WAIT WINDOW "Elaborazione movimenti contabili di ACQUISTO/CESSIONI INTRACOMUNITARI in corso. Questa operazione potrebbe richiedere qualche secondo..." NOWAIT


	OTHERWISE
		WAIT WINDOW "ATTENZIONE : NON HAI INDICATO IL TIPO DI ELABORAZIONE ????" NOWAIT
		RETURN	

ENDCASE
cSql=""
cNomeCursorSql="INTRA_MOV_CONT"

** ELABORA SOLO LE CONTROPARTITE IDENTIFICATE DA UN TOP INTRA 			: PARA.INTRA    					= SUBSTR(M.LIBERA,24,1) = 'S'
** ELABORA SOLO LE CONTROPARTITE DELLE FATTURE DEI PAESI MEMBRI CEE 	: PARA.FATTURE  					= SUBSTR(M.LIBERA,2,1)  = 'S'
** ELABORA SOLO LE CONTROPARTITE DEI PAESI MEMBRI CEE 					: MOV_STATO_CEE 					= 'CEE'
** ELABORA SOLO LE CONTROPARTITE IDENTIFICATE CON						: CON_TIPOCO    					= 'X'
** ESCLUDE I MOVIMENTI DI CONTABILITA' PREVISIONALE 					: MOV_CONTABILITA_PREVISIONALE 		<> 'P'
** ESCLUDE I MOVIMENTI DI CHIUSURA										: MOV_TOP 							<> 'CHI'

*		CASE WHEN MOV_EROG <> '' THEN MOV_EROG ELSE SUBSTRING(PARA3.LIBERA,1,100) END AS CPA_MOD_PAG,


TEXT TO cSql NOSHOW

	SELECT
		MOV.id_unique,			
		MOV_SOC,
		MOV_ANNO,
		(SELECT SUBSTRING(CON_CONTO,<<PUB_SOTTOG>>,13) FROM CONTI WHERE CON_ANNO=MOV.MOV_ANNO AND  CON_TIPOCO IN ('C','F') AND CON_CONTO IN (SELECT MOV_CONTO FROM MOV_CONT WHERE MOV_NUMPRO=MOV.MOV_NUMPRO)) AS MOV_CONTO,
		(SELECT CON_DESCR FROM CONTI WHERE CON_ANNO=MOV.MOV_ANNO AND  CON_TIPOCO IN ('C','F') AND CON_CONTO IN (SELECT MOV_CONTO FROM MOV_CONT WHERE MOV_NUMPRO=MOV.MOV_NUMPRO)) AS CON_DESCR,
		CONTI.CON_TIPOCO,
		MOV_NREGIS,
		MOV_DTREG,
		CASE WHEN SUBSTRING(PARA1.LIBERA,12,1) = 'C' THEN MOV_NPROT ELSE MOV_NDOC END AS MOV_NDOC,
		MOV_DTDOC,
	    MOV_TOP,
		SUBSTRING(PARA1.LIBERA,24,1) AS TOP_INTRA,
		SUBSTRING(PARA1.LIBERA,12,1) AS TOP_CLI_FOR,
		(CASE WHEN MOV_ANT_CAMB_SEGNO=1 THEN  -1 ELSE 1 END * MOV_IMP) AS MOV_IMP,
		MOV_TMOV,
		MOV_VALUTA,
		MOV_CAMBIO,
		MOV_IVA,
		SUBSTRING(PARA2.ITALIANO,1,100) AS FLG_BENI_SERVIZI,
		MOV_MODPAG,
		MOV_EROG AS CPA_MOD_PAG,
		MOV_PESO,
		MOV_TISPE,
		MOV_PORTO,
		MOV_CLDOG,
		MOV_SERV_INTRA,
		
		--CASE WHEN MOV_VALUTA ='EUR' THEN ROUND((CASE WHEN MOV_ANT_CAMB_SEGNO=1 THEN  -1 ELSE 1 END * MOV_IMP),0)
		--	ELSE ROUND((CASE WHEN MOV_ANT_CAMB_SEGNO=1 THEN  -1 ELSE 1 END * MOV_IMP)*MOV_CAMBIO,0) END AS MOV_IMPEUR_INTRA,
		--CASE WHEN MOV_VALUTA <>'EUR' THEN ROUND((CASE WHEN MOV_ANT_CAMB_SEGNO=1 THEN  -1 ELSE 1 END * MOV_IMP),0)
		--	ELSE 0 END AS MOV_IMPVAL_INTRA ,
		--CASE WHEN MOV_VALUTA ='EUR' THEN ROUND((CASE WHEN MOV_ANT_CAMB_SEGNO=1 THEN  -1 ELSE 1 END * MOV_IMP),0)
		--	ELSE ROUND((CASE WHEN MOV_ANT_CAMB_SEGNO=1 THEN  -1 ELSE 1 END * MOV_IMP)*MOV_CAMBIO,0) END AS MOV_IMPSTAT_INTRA,
			
		ROUND((CASE WHEN MOV_ANT_CAMB_SEGNO=1 THEN  -1 ELSE 1 END * MOV_IMPSTAT_INTRA),0) AS MOV_IMPEUR_INTRA,
		MOV_IMPVAL_INTRA,
		MOV_IMPSTAT_INTRA,
		
		MOV_NAZIONE_INTRA,
		CASE
			WHEN MOV_STATO_INTRA_PROV <> '' THEN MOV_STATO_INTRA_PROV
			ELSE SUBSTRING(PARA4.LIBERA,1,2) END AS MOV_STATO_INTRA_PROV,
		CASE
			WHEN MOV_STATO_INTRA_ORIG <> '' THEN MOV_STATO_INTRA_ORIG
			ELSE SUBSTRING(PARA4.LIBERA,1,2) END AS MOV_STATO_INTRA_ORIG,
		CASE
			WHEN MOV_STATO_INTRA_ORIG <> '' THEN MOV_STATO_INTRA_ORIG
			ELSE SUBSTRING(PARA4.LIBERA,1,2) END AS PAESE_ORIGINE,
		COALESCE(SUBSTRING(PARA4.ITALIANO,1,2),'') AS ITALIANO,
		MOV_PARTITA_IVA_INTRA,
		MOV_QTA_INTRA,
		MOV_COND_CONS_INTRA,
		COALESCE(SUBSTRING(PARA5.LIBERA,26,1),'') AS MOV_MEZZI_TRASP_INTRA,
		MOV_PROVIN_DESTI_INTRA,
		MOV_UNITA_SUPPL_INTRA,
		MOV_NUMPRO,	
		MOV_MODINC AS CPA_MOD_INC, 	
		MOV_INTRA_ok_ko,
		MOV_CONTABILITA_PREVISIONALE,
		COALESCE(PARA4.ITALIANO,'') AS MESSAGGIO_PARA4
	FROM MOV_CONT AS MOV
	LEFT OUTER JOIN PARA AS PARA1
	ON 'TOP'+MOV.MOV_TOP = PARA1.CODICE
	LEFT OUTER JOIN PARA AS PARA2
	ON 'IVA'+MOV.MOV_IVA = PARA2.CODICE
	LEFT OUTER JOIN PARA AS PARA3
	ON 'CPA'+MOV.MOV_MODPAG = PARA3.CODICE
	LEFT OUTER JOIN PARA AS PARA4
	ON 'STA'+MOV.MOV_NAZIONE_INTRA = PARA4.CODICE
	LEFT OUTER JOIN PARA AS PARA5
	ON 'MEZ'+MOV.MOV_TISPE = PARA5.CODICE
	LEFT OUTER JOIN CONTI AS CONTI
	ON MOV_CONTO=CONTI.CON_CONTO
	WHERE MOV_DTREG BETWEEN '<<_V_DATA_DAL>>' AND '<<_V_DATA_AL>>'
	AND MOV_TOP <> 'CHI'
	AND MOV_CONTABILITA_PREVISIONALE<>'P'
	AND SUBSTRING(PARA1.LIBERA,24,1)='S'
	AND SUBSTRING(PARA1.LIBERA,12,1)='<<_V_FATTURE_CLI_FOR>>'
	AND SUBSTRING(PARA1.LIBERA,2,1)='S'
	-- AND SUBSTRING(PARA1.LIBERA,23,1)='E'
	AND SUBSTRING(PARA1.LIBERA,11,1)<>'S'
	AND CONTI.CON_TIPOCO='X'
	AND CONTI.CON_ANNO=MOV_ANNO
	AND (SUBSTRING(PARA2.ITALIANO,1,100) = 'BENI-INTRASTAT' OR SUBSTRING(PARA2.ITALIANO,1,100) = 'SERVIZI-INTRASTAT')
	AND MOV.MOV_INTRA_DELETED = 0  -- && FILTRO PER RIGHE INTRA ELIMINATE CON APPOSITA FUNZIONE
	AND MOV_NUMPRO IN (SELECT MOV_NUMPRO FROM MOV_CONT WHERE SUBSTRING(MOV_CONTO,1,<<PUB_SOTTOG>>-1) IN ((SELECT SUBSTRING(LIBERA,1,<<PUB_SOTTOG>>-1) FROM PARA WHERE CODICE='GENCE'),(SELECT SUBSTRING(LIBERA,18,<<PUB_SOTTOG>>-1) FROM PARA WHERE CODICE='GENCE')) AND MOV_DTREG BETWEEN '<<_PAR_DATA_DAL>>' AND '<<_PAR_DATA_AL>>')
	ORDER BY TOP_CLI_FOR, MOV_NREGIS,MOV_CLDOG,MOV_SERV_INTRA,MOV_CONTO,MOV_DTREG,FLG_BENI_SERVIZI
	
ENDTEXT

**=> ERASMO/SERGIO - INIZIO 13/01/2022
IF PUB_CONTOSIMILCEE
	cSql=""
	TEXT TO cSql NOSHOW

		SELECT
			MOV.id_unique,			
			MOV_SOC,
			MOV_ANNO,
			(SELECT RIGHT('0000000000' + RTRIM(REVERSE(LEFT(REVERSE(CON_CONTO), CHARINDEX('.', REVERSE(CON_CONTO)) -1))), <<PUB_LCL>>)
				FROM CONTI WHERE CON_ANNO=MOV.MOV_ANNO AND  CON_TIPOCO IN ('C','F') AND CON_CONTO IN (SELECT MOV_CONTO FROM MOV_CONT WHERE MOV_NUMPRO=MOV.MOV_NUMPRO)) AS MOV_CONTO,
			(SELECT CON_DESCR FROM CONTI WHERE CON_ANNO=MOV.MOV_ANNO AND  CON_TIPOCO IN ('C','F') AND CON_CONTO IN (SELECT MOV_CONTO FROM MOV_CONT WHERE MOV_NUMPRO=MOV.MOV_NUMPRO)) AS CON_DESCR,
			CONTI.CON_TIPOCO,
