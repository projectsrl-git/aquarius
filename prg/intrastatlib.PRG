*******************************************
PROCEDURE CONTROLLA_DATI_INTRASTAT_IN_PRIMANOTA
*******************************************
LOCAL __CL_FO  ,_CI_SONO_ERRORI, _IVA_BENI_SERVIZI ,V_SEEK,V_CHIAVE

SELECT CORPO_MOV
GO TOP

_CI_SONO_ERRORI=.F.

DO WHILE !EOF()
	
	SEEK_CONTI('',PUB_CODSOC+PUB_ANNO+ALLTRIM(CONTO),'CON_CONTO','CON_CONTO','','CUR_CONT')
	
	IF SUBSTR(CUR_CONT.CON_TIPOCO,1,1) = "X"
	ELSE
		SELECT CORPO_MOV
		SKIP
		LOOP		
	ENDIF
	
	V_SEEK	= 'IVA' +	IVA
	V_CHIAVE= "CODICE"
	IF SEEK_STD('PARA',V_SEEK,V_CHIAVE,'CUR_PARA')
		SELECT CUR_PARA

		IF AT('SERVIZI-INTRASTAT',ITALIANO) > 0
			_IVA_BENI_SERVIZI =2		&& SERVIZI
   		ELSE
			IF AT('BENI-INTRASTAT',ITALIANO) > 0
				_IVA_BENI_SERVIZI =1		&& BENI
	   		ENDIF
	   	ENDIF 	
	
	ELSE
	   _IVA_BENI_SERVIZI =1			&& ACQUISTO/CESSIONE BENI
	ENDIF
		   	

	SELECT CORPO_MOV
	SCATTER MEMVAR
	

	DO CASE
		CASE _IVA_BENI_SERVIZI =1	&& BENI
	
			IF EMPTY(M.CLDOG)
				_CI_SONO_ERRORI=.T.
				EXIT 		
			ENDIF
		
			IF M.PESO = 0
				_CI_SONO_ERRORI=.T.
				EXIT 		
			ENDIF		
			
		CASE _IVA_BENI_SERVIZI =1	&& SERVIZI
		
			IF EMPTY(M.SERV_INTRA)
				_CI_SONO_ERRORI=.T.
				EXIT 		
			ENDIF		
		
	ENDCASE
		
	
	IF EMPTY(m.porto)
		_CI_SONO_ERRORI=.T.
		EXIT 		
	ENDIF
	
	IF EMPTY(m.cond_cons_intra)
		_CI_SONO_ERRORI=.T.
		EXIT 		
	ENDIF
	
	IF EMPTY(m.tispe)
		_CI_SONO_ERRORI=.T.
		EXIT 		
	ENDIF


	IF EMPTY(M.MEZZI_TRASP_INTRA)
		_CI_SONO_ERRORI=.T.
		EXIT 		
	ENDIF


	IF EMPTY(M.NAZIONE_INTRA)
		_CI_SONO_ERRORI=.T.
		EXIT 		
	ENDIF


	IF EMPTY(M.STATO_INTRA_PROV)
		_CI_SONO_ERRORI=.T.
		EXIT 		
	ENDIF

	IF VER_CONTO = 'F'	&& FATTURE ACQUISTO INTRASTAT
		IF M.QTA_INTRA = 0
			_CI_SONO_ERRORI=.T.
			EXIT 		
		ENDIF
	ELSE
		IF M.UNITA_SUPPL_INTRA = 0
			_CI_SONO_ERRORI=.T.
			EXIT 		
		ENDIF
	ENDIF

	IF EMPTY(M.PARTITA_IVA_INTRA)
		_CI_SONO_ERRORI=.T.
		EXIT 		
	ENDIF

	IF EMPTY(M.PROVIN_DESTI_INTRA)
		_CI_SONO_ERRORI=.T.
		EXIT 		
	ENDIF

	IF M.IMPSTAT_INTRA = 0
		_CI_SONO_ERRORI=.T.
		EXIT 		
	ENDIF

	SELECT CORPO_MOV
	SKIP
	
ENDDO

IF _CI_SONO_ERRORI
	__DATI_INTRA_VERIFICATI=.F.
	RETURN .f.
ENDIF

__DATI_INTRA_VERIFICATI=.T.
RETURN .T.


