************************************************************************************************************************************
FUNCTION INTRA_DETERMINA_IVA
************************************************************************************************************************************
*!*			:
*!*	RITORNA : _COD_IVA_INTRASTAT ,_COD_IVA_INTRASTAT_ESE
*!*			:
*!*			: accessi tabellari per determinare il codice iva intrastat :
*!*			:
*!*		1)	: _TIPO_CLI_FOR_ = 'C' accede all'anagrafica clienti e si salva il codice iva e il codice iva esente		>>>> _PERC_IVA_/_PERC_IVA_ESE_
*!*			: _TIPO_CLI_FOR_ = 'F' accede all'anagrafica fornitori e si salva il codice iva e il codice iva esente		>>>> _PERC_IVA_/_PERC_IVA_ESE_
*!*			:
*!*		2)	: se il cliente e' in sospensione iva valorizza la variabile												>>>> _SOSP_IVA
*!*			:
*!*		3)	: in funzione del codice nazione determina se il cliente/fornitore e' ITALIANO/CEE/EXTRACEE					>>>> _ITA_CEE_EXT
*!*			:
*!*		4)	: con il campo _TIPOLOGIA_DOCUMENTO_ accede alla tabella TPO (TIPOLOGIA DOCUMENTO)
*!*			: per verificare se si tratta di un servizio INTRASTAT														>>>> _SERVIZI_INTRASTAT
*!*			:
*!*		5)	: ricerca in tabella IVA del codice IVA INTRASTAT in base alle variabili valorizzate :
*!*		 	: _CLI_FOR_ITA_CEE_EXT + _SERVIZI_INTRASTAT + _PERC_IVA_ + _CLIENTE_SOSP_IVA
*!*			:
*!*			:
*!*			:
*!*	
LPARAMETERS _TIPO_CLI_FOR_,_CODICE_CLI_FOR_,_TIPOLOGIA_DOCUMENTO_

LOCAL _PERC_IVA_,_PERC_IVA_ESE_,_SOSP_IVA,_ITA_CEE_EXT,_SERVIZI_INTRASTAT,__CODICE_IVA
LOCAL _ESISTE_IVA_ESENTE,_COD_IVA,_COD_IVA_ESE

IF !PUB_INTRASTAT		&& SOLO SE E' ATTIVA LA GESTIONE INTRASTAT
	RETURN
ENDIF

_ESISTE_IVA_ESENTE		= .F.
_PERC_IVA_				= 0
_PERC_IVA_ESE_			= 0
_SOSP_IVA				= ""
_ITA_CEE_EXT			= ""
_SERVIZI_INTRASTAT		= ""
__CODICE_IVA 			= PUB_IVA

AABBSS_IVA= SELECT()

*!*	 ########################################### DETERMINA LE PERCENTUALI IVA / CODICI NAZIONI / IVA IN SOSPENSIONE ###########################################

DO CASE


	CASE _TIPO_CLI_FOR_ = "C"
	
		  x_soci = "cli_codsoc = '" + PUB_CODSOC + "'"
		  x_codi = "cli_codcli = '" + _CODICE_CLI_FOR_ + "'"
		  x_cond = x_soci + " and " + x_codi
		  Csql   = "select * from u_cli_an where " + x_cond + " order by cli_codsoc,cli_codcli"
		  IF !ExecCommand(cSql,"__cur_cliente")
		     return(.f.)
		  ENDIF
		  SELECT __cur_cliente
		  GO TOP
		  IF !EOF()
		

				IF SUBSTR(CLI_NAZION,1,2) = 'IT'
		       		_ITA_CEE_EXT = "ITA"				&& PAESE ITALIA				
				ELSE
					V_ER = SOTTOGEN(CLI_NAZION)
					IF  PUB_STATO_CEE 					
				   		_ITA_CEE_EXT = "CEE"			&& PAESE CEE				
					ENDIF
					IF  PUB_STATO_EXTRA_CEE 			
				   		_ITA_CEE_EXT = "EXT"			&& PAESE EXTRA CEE				
					ENDIF
		        ENDIF
		
		        IF !EMPTY(CLI_SOSIMP)					&& CLIENTE CON IVA SOSPENSIONE
		        	_SOSP_IVA	= "SOSP"
		        ENDIF
		
		
			  	IF !EMPTY(CLI_CODIVA)
			  	    _COD_IVA = CLI_CODIVA
			  	ELSE
			  		_COD_IVA = PUB_IVA
			  	ENDIF		
			
			  	IF !EMPTY(CLI_ALRID)
			  	    _COD_IVA_ESE = CLI_ALRID
				    _ESISTE_IVA_ESENTE = .T.	
			  	ELSE
			  	    _COD_IVA_ESE = ""
				    _ESISTE_IVA_ESENTE = .F.	
			  	ENDIF		

				v_seek	 = 'IVA'+_COD_IVA
				v_chiave = "codice"
				IF seek_std('para',v_seek,v_chiave,'__CUR_PARA')
				   SELECT __CUR_PARA
				   _PERC_IVA_ = VAL(SUBSTR(LIBERA,1,3))
				ELSE
				   _PERC_IVA_ = 0
				ENDIF
			
			    IF _ESISTE_IVA_ESENTE
					v_seek	 = 'IVA'+_COD_IVA_ESE
					v_chiave = "codice"
					IF seek_std('para',v_seek,v_chiave,'__CUR_PARA')
					   SELECT __CUR_PARA
					   _PERC_IVA_ESE_ = VAL(SUBSTR(LIBERA,1,3))
					   _ESISTE_IVA_ESENTE = .T.
					ELSE
					   _PERC_IVA_ESE_ = 0
					   _ESISTE_IVA_ESENTE = .F.
					ENDIF
		  		ENDIF
		
		  ELSE
		        WAIT WINDOWS "CLIENTE INESISTENTE , CODICE : " +_CODICE_CLI_FOR_ NOWAIT

		   		_ITA_CEE_EXT = "ITA"				&& PAESE ITALIA				

			 	_COD_IVA 			= PUB_IVA
		  	    _COD_IVA_ESE 		= ""
			    _PERC_IVA_ESE_ 		= 0
			    _ESISTE_IVA_ESENTE 	= .F.

				v_seek	 = 'IVA'+_COD_IVA
				v_chiave = "codice"
				IF seek_std('para',v_seek,v_chiave,'__CUR_PARA')
				   SELECT __CUR_PARA
				   _PERC_IVA_ = VAL(SUBSTR(LIBERA,1,3))
				ELSE
				   _PERC_IVA_ = 0
				ENDIF
		  ENDIF



	CASE _TIPO_CLI_FOR_ = "F"
	
		  x_soci = "for_codsoc = '" + PUB_CODSOC + "'"
		  *x_codi = "for_codcli = '" + SUBSTR(CGE_CON,PUB_SOTTOG,PUB_CONTO) + "'"
		  x_codi = "for_codcli = '" + IIF(PUB_CONTOSIMILCEE, TRC(PUB_LCL,ALLTRIM(SUBSTR(CGE_CON,RAT('.',CGE_CON,1)+1))), ALLTRIM(SUBSTR(CGE_CON,PUB_SOTTOG,PUB_CONTO))) + "'"  && SERGIO - 18/12/2021
		  
		  x_cond = x_soci + " and " + x_codi
		  Csql   = "select * from u_for_an where " + x_cond + " order by for_codsoc,for_codcli"
		  IF !ExecCommand(cSql,"__cur_fornitore")
		     return(.f.)
		  ENDIF
		  SELECT __cur_fornitore
		  GO TOP
		  IF !EOF()

				IF SUBSTR(FOR_NAZION,1,2) = 'IT'
		       		_ITA_CEE_EXT = "ITA"				&& PAESE ITALIA				
				ELSE
					V_ER = SOTTOGEN(FOR_NAZION)
					IF  PUB_STATO_CEE 					
				   		_ITA_CEE_EXT = "CEE"			&& PAESE CEE				
					ENDIF
					IF  PUB_STATO_EXTRA_CEE 			
				   		_ITA_CEE_EXT = "EXT"			&& PAESE EXTRA CEE				
					ENDIF
		        ENDIF

		
			  	IF !EMPTY(FOR_CODIVA)
			  	    _COD_IVA = FOR_CODIVA
			  	ELSE
			  		_COD_IVA = PUB_IVA
			  	ENDIF		
			
			  	IF !EMPTY(FOR_ALRID)
			  	    _COD_IVA_ESE = FOR_ALRID
				    _ESISTE_IVA_ESENTE = .T.	
			  	ELSE
			  	    _COD_IVA_ESE = ""
				    _ESISTE_IVA_ESENTE = .F.	
			  	ENDIF		

				v_seek	 = 'IVA'+_COD_IVA
				v_chiave = "codice"
				IF seek_std('para',v_seek,v_chiave,'__CUR_PARA')
				   SELECT __CUR_PARA
				   _PERC_IVA_ = VAL(SUBSTR(LIBERA,1,3))
				ELSE
				   _PERC_IVA_ = 0
				ENDIF
			
			    IF _ESISTE_IVA_ESENTE
					v_seek	 = 'IVA'+_COD_IVA_ESE
					v_chiave = "codice"
					IF seek_std('para',v_seek,v_chiave,'__CUR_PARA')
					   SELECT __CUR_PARA
					   _PERC_IVA_ESE_ = VAL(SUBSTR(LIBERA,1,3))
					   _ESISTE_IVA_ESENTE = .T.
					ELSE
					   _PERC_IVA_ESE_ = 0
					   _ESISTE_IVA_ESENTE = .F.
					ENDIF
		  		ENDIF
		
		  ELSE
		        WAIT WINDOWS "FORNITORE INESISTENTE , CODICE : " +_CODICE_CLI_FOR_ NOWAIT

	       		_ITA_CEE_EXT = "ITA"				&& PAESE ITALIA				

			 	_COD_IVA 			= PUB_IVA
		  	    _COD_IVA_ESE 		= ""
			    _PERC_IVA_ESE_ 		= 0
			    _ESISTE_IVA_ESENTE 	= .F.

				v_seek	 = 'IVA'+_COD_IVA
				v_chiave = "codice"
				IF seek_std('para',v_seek,v_chiave,'__CUR_PARA')
				   SELECT __CUR_PARA
				   _PERC_IVA_ = VAL(SUBSTR(LIBERA,1,3))
				ELSE
				   _PERC_IVA_ = 0
				ENDIF
		  ENDIF



	
	OTHERWISE

		  =MESSAGEBOX("CODIFICARE CORRETTAMENTE IL TIPO CLIENTE/FORNTORE"+CHR(13)+"FUNCTION : DETERMINA_IVA_PER_GESTIONE_INTRASTAT"+CHR(13)+'',16,'*** ATTENZIONE ***')
		  SELECT(AABBSS_IVA)
		  RETURN
		
ENDCASE

**=> ERASMO - INIZIO 21/02/2022
IF _ITA_CEE_EXT = "ITA"
	RETURN
ENDIF
**=> ERASMO - FINE 21/02/2022

*!*	 ########################################### DETERMINA SE SI TRATTA DI UN SERVIZIO INTRASTAT ###########################################

_SERVIZI_INTRASTAT		= ""
IF !EMPTY(_TIPOLOGIA_DOCUMENTO_)
	v_seek	 = 'TPO'+_TIPOLOGIA_DOCUMENTO_
	v_chiave = "codice"
	IF seek_std('para',v_seek,v_chiave,'__CUR_PARA')
	   SELECT __CUR_PARA
	   IF ALLTRIM(DESIVA) = "SI-SERVIZI-INTRASTAT"
		   _SERVIZI_INTRASTAT = "SERVIZI-INTRASTAT"
	   ENDIF
	   IF ALLTRIM(DESIVA) = "SI-BENI-INTRASTAT"
		   _SERVIZI_INTRASTAT = "BENI-INTRASTAT"
	   ENDIF
	ENDIF
ENDIF



*!*	 ########################################### DETERMINA IL CODICE IVA INTRASTAT IN FUNZIONE DELLE VARIABILI SOPRA GESTITE ###########################################

x_tipt   = "SUBSTRING(CODICE,1,3) = 'IVA'"
x_paese  = "NOTE LIKE '%" + ALLTRIM(_ITA_CEE_EXT) + "%'"	
x_cond   = x_tipt + " and " + x_paese
Csql     = "SELECT * FROM PARA WHERE " + x_cond
IF !ExecCommand(cSql,"cu_para_iva")
     return(.f.)
ENDIF
SELECT cu_para_iva
GO TOP

*!*	################ RICERCA DEL CODICE IVA FILTRANDO PER SERVIZIO INTRASTAT E PERCENTUALE IVA DA ANAGRAFICA CLIENTE ##############

** ##################################################### CERCA IVA INTRASTAT ######################################################

_PERC_IVA_DA_RICERCARE  = _PERC_IVA_							&& PERCENTUALE IVA DEL CODICE DI ANAGRAFICA
_COD_IVA_INTRASTAT      = _COD_IVA								&& CODICE IVA DA ANAGRAFICA	

SELECT cu_para_iva
GO TOP
DO WHILE .NOT. EOF()

	IF IVAESENTE 												&& NON TRATTA LE IVE IN ESENZIONE
		SELECT cu_para_iva
		SKIP +1
		LOOP
	ENDIF

	IF EMPTY(_SERVIZI_INTRASTAT) 								&& TIPOLOGIA DOCUMENTO NON E' SERVIZIO
	
		IF !EMPTY(ALLTRIM(ITALIANO))							&& SCARTA LE IVE DEI SERVIZI INTRASTAT
			SELECT cu_para_iva
			SKIP +1
			LOOP
		ENDIF
	
	ELSE 														&& TIPOLOGIA DOCUMENTO = SERVIZIO
	
		IF ALLTRIM(_SERVIZI_INTRASTAT) <> ALLTRIM(ITALIANO)		&& SCARTA LE IVE NON DEI SERVIZI INTRASTAT
			SELECT cu_para_iva
			SKIP +1
			LOOP
		ENDIF
	
	ENDIF
	
	IF EMPTY(_SOSP_IVA)											&& CLIENTE NON IN SOSPENSIONE IVA
		
		IF !EMPTY(ALLTRIM(DESIVA))								&& SCARTA LE IVE IN SOSPENSIONE IVA
			SELECT cu_para_iva
			SKIP +1
			LOOP
		ENDIF
	
	ELSE														&& CLIENTE in SOSPENSIONE IVA
	
		IF ALLTRIM(_SOSP_IVA) <> ALLTRIM(DESIVA)				&& SCARTA LE IVE NON IN SOSPENSIONE IVA
			SELECT cu_para_iva
			SKIP +1
			LOOP
		ENDIF
	
	ENDIF

	PERCENTUALE_IVA = VAL(SUBSTR(LIBERA,1,3))					&& PERCENTUALE DEL CODICE IVA IN ESAME
	
	IF   _PERC_IVA_DA_RICERCARE  = PERCENTUALE_IVA				&& CODICE IVA INTRASTAT TROVATOOOOOOOOOOOOOOOO
		_COD_IVA_INTRASTAT = ALLTRIM(SUBSTR(CODICE,4,3))	 	&& CODICE IVA INTRASTAT TROVATOOOOOOOOOOOOOOOO
		EXIT													&& CODICE IVA INTRASTAT TROVATOOOOOOOOOOOOOOOO
	ENDIF														&& CODICE IVA INTRASTAT TROVATOOOOOOOOOOOOOOOO
	SELECT cu_para_iva
	SKIP +1

ENDDO


** ############################################## CERCA IVA ESENTE INTRASTAT ######################################################

IF _ESISTE_IVA_ESENTE 												

	_PERC_IVA_DA_RICERCARE  = _PERC_IVA_ESE_						&& PERCENTUALE IVA ESENTE DEL CODICE DI ANAGRAFICA
	_COD_IVA_INTRASTAT_ESE  = _COD_IVA_ESE 							&& CODICE IVA ESENTE DA ANAGRAFICA		

	SELECT cu_para_iva
	GO TOP
	DO WHILE .NOT. EOF()


		IF !IVAESENTE 												&& TRATTA SOLO LE IVE IN ESENZIONE
			SELECT cu_para_iva
			SKIP +1
			LOOP
		ENDIF


		IF EMPTY(_SERVIZI_INTRASTAT) 								&& TIPOLOGIA DOCUMENTO NON E' SERVIZIO
		
			IF !EMPTY(ALLTRIM(ITALIANO))							&& SCARTA LE IVE DEI SERVIZI INTRASTAT
				SELECT cu_para_iva
				SKIP +1
				LOOP
			ENDIF
		
		ELSE 														&& TIPOLOGIA DOCUMENTO = SERVIZIO
		
			IF ALLTRIM(_SERVIZI_INTRASTAT) <> ALLTRIM(ITALIANO)		&& SCARTA LE IVE NON DEI SERVIZI INTRASTAT
				SELECT cu_para_iva
				SKIP +1
				LOOP
			ENDIF
		
		ENDIF

		IF EMPTY(_SOSP_IVA)											&& CLIENTE NON in SOSPENSIONE IVA
			
			IF !EMPTY(ALLTRIM(DESIVA))								&& SCARTA LE IVE IN SOSPENSIONE IVA
				SELECT cu_para_iva
				SKIP +1
				LOOP
			ENDIF
		
		ELSE														&& CLIENTE in SOSPENSIONE IVA
		
			IF ALLTRIM(_SOSP_IVA) <> ALLTRIM(DESIVA)				&& SCARTA LE IVE NON IN SOSPENSIONE IVA
				SELECT cu_para_iva
				SKIP +1
				LOOP
			ENDIF
		
		ENDIF


		PERCENTUALE_IVA = VAL(SUBSTR(LIBERA,1,3))					&& PERCENTUALE DEL CODICE IVA IN ESAME
		
		IF   _PERC_IVA_DA_RICERCARE  = PERCENTUALE_IVA				&& CODICE IVA INTRASTAT TROVATOOOOOOOOOOOOOOOO
			_COD_IVA_INTRASTAT_ESE = ALLTRIM(SUBSTR(CODICE,4,3))	&& CODICE IVA INTRASTAT TROVATOOOOOOOOOOOOOOOO
			EXIT													&& CODICE IVA INTRASTAT TROVATOOOOOOOOOOOOOOOO
		ENDIF														&& CODICE IVA INTRASTAT TROVATOOOOOOOOOOOOOOOO
		SELECT cu_para_iva
		SKIP +1
	
	ENDDO
ELSE

	_COD_IVA_INTRASTAT_ESE = _COD_IVA_ESE 							&& CODICE IVA DA ANAGRAFICA		

ENDIF


  	
SELECT(AABBSS_IVA)													&& NESSUNA GESTIONE INTRASTAT GESTISCE IL CODICE IVA O IL CODICE IVA ESENTE DI ANAGRAFICA
RETURN




************************************************************************************************************************************
FUNCTION INTRA_CONTROLLO_IVA
************************************************************************************************************************************
*!*			:
*!*	RITORNA : _INTRASTAT_ACQUISTO_CESSIONE_DA_CONTROLLARE = .T. SE IESISTE UN BENE/SERVIZIO INTRASTAT
*!*			:
*!*	        : la procedura controlla se nelle righe della prima nota esiste almeno una contropartita con ACQUISTO/CESSIONE INTRASTAT
*!*	        :
*!*	        :
*!*	        :
*!*	        :


IF !PUB_INTRASTAT		&& SOLO SE E' ATTIVA LA GESTIONE INTRASTAT
	RETURN
ENDIF



AxABBSS_IVA= SELECT()

SELECT CORPO_MOV
DATI_INTRA_VERIFICATI___ = DATI_INTRA_VERIFICATI

IF FATTURA = "S"					  						&& SOLO PER FATTURE DI VENDITA/AQUISTO
	
	IF ALLTRIM(IVA)  <> "NO"

		IF ____TIPO_CONTO = "X"								&& SOLO CONTROPARTITE ESCLUSO I CONTI IVA,CLIENTI/FORNITORI


			__CODICE_IVA_MOV_CONT = IVA
			v_seek	 = 'IVA'+__CODICE_IVA_MOV_CONT
			v_chiave = "codice"
			IF seek_std('para',v_seek,v_chiave,'CUR_PARA_CGE')
			
			    SELECT CUR_PARA_CGE
			
			    IF ALLTRIM(ITALIANO) = 'BENI-INTRASTAT' OR ALLTRIM(ITALIANO) = 'SERVIZI-INTRASTAT'

					   IF DATI_INTRA_VERIFICATI___  <> "SI"	
							__DATI_INTRA_VERIFICATI  = .F.		&& ESISTE ALMENO UNA RIGA INTRASTAT NON VERIFICATA
					   ENDIF	
			
			    ENDIF
			
			ENDIF

		ENDIF

	ENDIF

ENDIF

SELECT CORPO_MOV

SELECT(AxABBSS_IVA)													
RETURN


**
************************************************************************************************************************************
FUNCTION INTRA_CONTROLLO_FATTURE_CON_TOP_NON_CEE_MA_IVA_INTRASTAT
************************************************************************************************************************************
LPARAMETERS _PAR_DATA_DAL,_PAR_DATA_AL
*!* CONTROLLO FATTURE CON TOP "NON CEE" MA CON IVA INTRASTAT
*!* DEVE ESSERE SENZA RISULTATI


AxABBSS_CEE= SELECT()

cSql=""
cNomeCursorSql="INTRA_MOV_CONT"


*!*	TEXT TO cSql NOSHOW


*!*		SELECT
*!*			MOV_SOC,
*!*			MOV_ANNO,
*!*			(SELECT SUBSTRING(CON_CONTO,<<PUB_SOTTOG>>,13) FROM CONTI WHERE CON_ANNO=MOV.MOV_ANNO AND  CON_TIPOCO IN ('C','F') AND CON_CONTO IN (SELECT MOV_CONTO FROM MOV_CONT WHERE MOV_NUMPRO=MOV.MOV_NUMPRO)) AS MOV_CONTO,
*!*			(SELECT CON_DESCR FROM CONTI WHERE CON_ANNO=MOV.MOV_ANNO AND  CON_TIPOCO IN ('C','F') AND CON_CONTO IN (SELECT MOV_CONTO FROM MOV_CONT WHERE MOV_NUMPRO=MOV.MOV_NUMPRO)) AS CON_DESCR,
*!*			CONTI.CON_TIPOCO,
*!*			MOV_CONTO,
*!*			MOV_NREGIS,
*!*			MOV_DTREG,
*!*			MOV_NPROT,
*!*			MOV_NDOC,
*!*			MOV_DTDOC,
*!*		    MOV_TOP,
*!*			MOV_IMP,
*!*			MOV_TMOV,
*!*			MOV_VALUTA,
*!*			MOV_CAMBIO,
*!*			MOV_IVA,
*!*			MOV_MODPAG,
