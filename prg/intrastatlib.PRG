************************************************************************************************************************************
FUNCTION DECODIFICA_IMPORTO_NUMERICO_NEGATIVO
************************************************************************************************************************************
LPARAMETERS _VALORE_NUM_NEG

* TRASFORMA IL VALORE NUMERICO IN CARATTERE SECONDO LA TABELLA INTRASTAT
*!*	  Cifra   Valore
*!*		0 		p
*!*		1 		q
*!*		2 		r
*!*		3 		s
*!*		4 		t
*!*		5 		u
*!*		6 		v
*!*		7 		w
*!*		8 		x
*!*		9 		y


IF _VALORE_NUM_NEG < 0
ELSE

	__CAMPO 				 		= STR(_VALORE_NUM_NEG,13,0)
	__LUNGHEZZA_CAMPO 		 		= 13
	__TIPO_ALLINEAMENTO 	 		= 'SX'			&& IMPOSTA ZERI NON SIGNIFICATIVI A SINISTRA
	__TIPO_CARATTERE		 		= "0"
	__VALORE_NUM_NEG_TRASFORMATO 	= ALLINEA_CAMPO(__CAMPO,__LUNGHEZZA_CAMPO,__TIPO_ALLINEAMENTO,__TIPO_CARATTERE)
	RETURN(__VALORE_NUM_NEG_TRASFORMATO)	&& SESSUNA OPERAZIONE : VALORE POSITIVO LO RITRASFORMO IN CARATTERI

ENDIF

_VALORE_NUM_NEG = _VALORE_NUM_NEG * -1 && LO RENDO POSITIVO

__CAMPO 				 		= STR(_VALORE_NUM_NEG,13,0)
__LUNGHEZZA_CAMPO 		 		= 13
__TIPO_ALLINEAMENTO 	 		= 'SX'			&& IMPOSTA ZERI NON SIGNIFICATIVI A SINISTRA
__TIPO_CARATTERE		 		= "0"
_VALORE_NUM_NEG 				= ALLINEA_CAMPO(__CAMPO,__LUNGHEZZA_CAMPO,__TIPO_ALLINEAMENTO,__TIPO_CARATTERE)
__VALORE_NUM_NEG_TRASFORMATO    = _VALORE_NUM_NEG


DO CASE


	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '0'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 'p'
	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '1'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 'q'
	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '2'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 'r'
	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '3'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 's'
	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '4'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 't'
	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '5'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 'u'
	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '6'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 'v'
	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '7'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 'w'
	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '8'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 'x'
	CASE SUBSTR(_VALORE_NUM_NEG,13,1) = '9'
		__VALORE_NUM_NEG_TRASFORMATO = SUBSTR(__VALORE_NUM_NEG_TRASFORMATO,1,12) + 'y'


ENDCASE



__CAMPO 				 		= __VALORE_NUM_NEG_TRASFORMATO
__LUNGHEZZA_CAMPO 		 		= 13
__TIPO_ALLINEAMENTO 	 		= 'SX'			&& IMPOSTA ZERI NON SIGNIFICATIVI A SINISTRA
__TIPO_CARATTERE		 		= "0"
__VALORE_NUM_NEG_TRASFORMATO 	= ALLINEA_CAMPO(__CAMPO,__LUNGHEZZA_CAMPO,__TIPO_ALLINEAMENTO,__TIPO_CARATTERE)


RETURN(__VALORE_NUM_NEG_TRASFORMATO)


