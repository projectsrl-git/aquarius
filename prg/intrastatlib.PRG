IF !ExecPreparedCommand(cSql,cNomeCursorSql)
	return(.F.)
ENDIF	


IF _V_CREA_INTRA <> "SI"			&& SE USATA SOLO PER ESTRARRE I MOVIMENTI DI PRIMA NTA NEL CURSORE INTRA_MOV_CONT
	RETURN
ENDIF




SELECT INTRA_MOV_CONT
GO TOP

IF EOF()
   _INTRASTAT_MOVIMENTI_CONTABILI_ELABORATI =0
   RETURN		&& Nessun MOVIMENTO CONTABILE elaborato per il periodo digitato
ENDIF

DO WHILE !EOF()


	_V_DARE  = 0
	_V_AVERE  = 0

	IF MOV_TMOV  = "D" .OR. MOV_TMOV  = "A"
	ELSE
	WAIT WINDOW "Registrazione senza D/A"+STR(MOV_NREGIS,10,0)+"<<<<<<<<<<<<"
		SELECT INTRA_MOV_CONT
		SKIP +1
		LOOP
	ENDIF

    SELECT INTRA_MOV_CONT
    SCATTER MEMVAR MEMO

    **  ################################################ SISTEMAZIONE AUTOMATICA ######################################
    IF ISALPHA(SUBSTR(M.MOV_PARTITA_IVA_INTRA,1,1)) AND ISALPHA(SUBSTR(M.MOV_PARTITA_IVA_INTRA,2,1))
    	M.MOV_PARTITA_IVA_INTRA = ALLTRIM(SUBSTR(M.MOV_PARTITA_IVA_INTRA,3,20))
    	REPLACE MOV_PARTITA_IVA_INTRA WITH M.MOV_PARTITA_IVA_INTRA
    ENDIF
	IF M.MOV_PESO > 0
		_PESO_INT = INT(M.MOV_PESO)
		IF _PESO_INT = 0
			M.MOV_PESO = CEILING(M.MOV_PESO)		&& ARROTONDA ALLA CIFRA SUPERIORE NEL CASO DI PESI CON SOLE CIFRE DECIMALI
			REPLACE MOV_PESO WITH M.MOV_PESO
		ENDIF
	ENDIF
    **  ################################################ SISTEMAZIONE AUTOMATICA ######################################



*!*	 IF ALLTRIM(MOV_NREGIS) = '1723'
*!*	   SET STEP ON
*!*	 ENDIF


    _V_VALORE_EURO		= 0
    _V_VALORE_VALUTA	= 0


	*_V_VALORE_EURO   			= CEILING(MOV_IMP)  && INT(MOV_IMP)
	_V_VALORE_EURO   			= MOV_IMPEUR_INTRA  && CEILING(MOV_IMP)
	_V_VALORE_EURO_NUMERICO		= _V_VALORE_EURO
	*_V_VALORE_VALUTA 			= MOV_IMPVAL_INTRA
	_V_VALORE_VALUTA 			= 0  && ERASMO/FABIANO 24/03/2015
	
	*#######################################################################################################################################
