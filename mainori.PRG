SET DELETED OFF
CLOSE DATA ALL
USE RES_MENU EXCLUSIVE
=MODTBL(ALIAS(SELECT()),"RES_PROG","N(5,0)")
INDEX ON RES_VAR TAG RESVAR ADDITIVE
INDEX ON RES_PROG TAG RESPROG ADDITIVE

DELETE ALL

SET ORDER TO RESVAR
FOR H=1 TO _MAX
  _SEEK = "TAB_MENU_"+ALLTRIM(STR(H))+"_2"
  SEEK &_SEEK
  IF FOUND()
    RECAL
  ENDIF
NEXT

PACK

SET DELETED ON
NREC=RECCOUNT()
FOR H=1 TO _MAX
  _SEEK2="TAB_MENU_"+ALLTRIM(STR(H))+"_2"
  _SEEK1="TAB_MENU_"+ALLTRIM(STR(H))+"_1"
  _SEEK3="TAB_MENU_"+ALLTRIM(STR(H))+"_3"
  SEEK &_SEEK2
  IF !FOUND()
    APPEND BLANK
    REPLACE RES_PROG   WITH VAL(&_SEEK3)
    REPLACE RES_DESCRI WITH &_SEEK1
    REPLACE RES_VAR    WITH &_SEEK2
  ELSE
    REPLACE RES_PROG   WITH VAL(&_SEEK3)
  ENDIF
NEXT

SET ORDER TO RESPROG
GO TOP
COPY TO _SUPP_MENU
ZAP
APPEND FROM _SUPP_MENU
USE
=OPENDB("RES_OPER")
v_user="."
do while !eof()
  v_user=v_user+ALLTRIM(codice)+"."
  skip
enddo


USE RES_MENU EXCLUSIVE
REPLACE RES_USER WITH V_USER FOR EMPTY(RES_USER)


USE
RETURN(.T.)
