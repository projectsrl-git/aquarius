
************************************************************************************************
* -->> PROGRAMMA PER LA RICERCA DI UNA STRINGA DENTRO AI SORGENTI
*
* -->> SINTASSI:
* -->>          CERCASTP WITH _STR,_STR2
* -->>          DOVE: _STR    E'LA STRINGA DA CERCARE
* -->>                _STR2   E'LA STRINGA CON CUI SOSTITUIRE QUELLA TROVATA CERCARE
*
* -->> ESEMPIO:
* -->>          CERCASTP WITH "007","V_PIPPO"

************************************************************************************************
PARA _TIPO,_STR2
IF PARAMETER() < 2
   _STR2=""
ENDIF

SET DEFAULT TO C:\AQUARIUS\PRG

SET PROCEDURE TO WINLIB ADDITIVE

PUBLIC _IND
_IND=0

PIPPO=0

CREATE CURSOR WSCR(NOME C(20),POSIZ C(70))
INDEX ON NOME TAG I_WSCR ADDITIVE

CREATE CURSOR SORGENTI(RIGA1 C(250),RIGA2 C(250))

SET SAFE OFF

AA=0
BB=0
V_MODI=.F.

NTXT = ADIR(MATXT,'*.PRG')

FOR TXT = 1 TO NTXT

  NOMEFILE = MATXT[TXT,1]
  SELECT SORGENTI
  ZAP
  APPEND FROM &NOMEFILE SDF
  GO TOP
  V_MODI=.F.
  DO WHILE .NOT. EOF()	
	
    RIGAT = UPPER(RIGA1+RIGA2)

    IF _TIPO $ RIGAT
      IF !EMPTY(_STR2)
        REPLACE RIGA1 WITH STRTRAN(RIGA1,_TIPO,_STR2)
        REPLACE RIGA2 WITH STRTRAN(RIGA2,_TIPO,_STR2)
        V_MODI=.T.
        BB=BB+1
      ENDIF
   	  SELECT WSCR
   	  SET ORDER TO I_WSCR
      SEEK ALLTRIM(NOMEFILE)
      IF FOUND()
      ELSE
         APPEND BLANK
      ENDIF
      REPLACE NOME  WITH  NOMEFILE
      REPLACE POSIZ WITH  "STRINGA "+_TIPO +" TROVATA"
    ENDIF

    AA=AA+1
    WAIT WINDOWS "PROGRAMMI CONTROLLATI: "+STR(AA)+CHR(13)+;
    "STRINGHE SOSTITUITE:   "+STR(BB) NOWAIT

    SELECT SORGENTI
    SKIP +1
  ENDDO	

  IF V_MODI
    ERASE &NOMEFILE
    XX=FCREATE(NOMEFILE)
    IF XX < 0
      SELECT SORGENTI
      COPY TO &NOMEFILE SDF
    ELSE
      SELECT SORGENTI
      GO TOP
      DO WHILE !EOF()
        RIGA=RIGA1+RIGA2
        RIGA=STRTRAN(RIGA,CHR(13),"")
        RIGA=STRTRAN(RIGA,CHR(10),"")
        =FPUTS(XX,RTRIM(RIGA))
        SKIP+1
      ENDDO
      =FCLOSE(XX)
    ENDIF
  ENDIF
ENDFOR

SELECT WSCR
GO TOP
BROWSE NORMAL

DISPLAY ALL TO PRINTER PROMPT NOCONSOLE

WAIT WINDOW "OPERAZIONE TERMINATA"

SET DEFAULT TO C:\AQUARIUS\PRG

CLOSE ALL
CLEAR ALL

